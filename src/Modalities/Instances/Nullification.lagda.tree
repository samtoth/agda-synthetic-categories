\subtree[stt-005G]{
\date{2025-06-17}
\author{samueltoth}
\taxon{Definition}
\title{Null types}

\p{
Given a family of types #{A_i}, we say a type #{X} is #{A} \em{null} if
it is right orthogonal to each #{A_i}. Or equivalently, if the
obvious maps #{X \to (A_i \to X)} are equivalences for each #{i}.
}

%```agda
\agda{
module _
  {рқ“ҳ рқ“Ө рқ“Ҙ : Level} {I : Type рқ“ҳ}
  where

  is-null : (A : I вҶ’ Type рқ“Ө) вҶ’ Type рқ“Ҙ вҶ’ Type (рқ“ҳ вҠ” рқ“Ө вҠ” рқ“Ҙ)
  is-null A X = (i : I) вҶ’ is-equiv (const X (A i))

  is-null-is-prop
    : {A : I вҶ’ Type рқ“Ө}
    вҶ’ (X : Type рқ“Ҙ) вҶ’ is-prop (is-null A X)
  is-null-is-prop X = is-prop-О  О» a вҶ’ is-equiv-is-prop

  nullвүғ : {A : I вҶ’ Type рқ“Ө}
          {X : Type рқ“Ҙ} (_ : is-null A X) (i : I)
        вҶ’ X вүғ (A i вҶ’ X)
  nullвүғ {A} {X} An i = mkвүғ (const X (A i)) (An i)

  is-null-equiv
    : {A : I вҶ’ Type рқ“Ө}
      {X : Type рқ“Ҙ} {Y : Type рқ“Ҙ}
    вҶ’ X вүғ Y
    вҶ’ is-null A X
    вҶ’ is-null A Y
  is-null-equiv e anull i
    = is-equivвҶҗArrow-equiv
        {F = mk-amap fwd (postcomp _ fwd) ~refl}
        (has-is-eqv , postcomp-equiv has-is-eqv)
        (anull i) where
    open _вүғ_ e
}
%```
}

\subtree[fre-1234]{
\date{2026-03-10}
\author{fredrikbakke}
\title{Closure of null types under retracts}
\taxon{Lemma}

%```agda
\agda{
module _
  {рқ“ҳ рқ“Ө рқ“Ҙ : Level} {I : Type рқ“ҳ}
  where

  is-null-retract-exponent
    : {A : I вҶ’ Type рқ“Ө}
      {B : I вҶ’ Type рқ“Ө}
      {X : Type рқ“Ҙ}
    вҶ’ ((i : I) вҶ’ A i retract-of B i)
    вҶ’ is-null B X
    вҶ’ is-null A X
  is-null-retract-exponent {A = A} {B} {X} R Bnull i
    = is-equivвҶҗretract-equiv
        (mk-amap id (precomp X (R i .snd .fst)) ~refl)
        (mk-amap id (precomp X (R i .fst)) ~refl
        , ~refl
        , О» h вҶ’ funextвҶ’ О» a вҶ’ ap h (R i .snd .snd a))
        (Bnull i)

  is-null-retract
    : {A : I вҶ’ Type рқ“Ө}
      {X : Type рқ“Ҙ}
      {Y : Type рқ“Ҙ}
    вҶ’ X retract-of Y
    вҶ’ is-null A Y
    вҶ’ is-null A X
  is-null-retract {A = A} {X} {Y} R Anull i
    = is-equivвҶҗretract-equiv
        (mk-amap (R .fst) (postcomp (A i) (R .fst)) ~refl)
        ( mk-amap (R .snd .fst) (postcomp (A i) (R .snd .fst)) ~refl
        , R .snd .snd
        , О» h вҶ’ funextвҶ’ О» a вҶ’ R .snd .snd (h a))
        (Anull i)
}
%```
}

\subtree[stt-005H]{
\date{2025-06-17}
\author{samueltoth}
\taxon{Theorem}
\title{Null types are #{!\rm{-local}}}

\p{A type is #{A_i}-null iff it is #{(! : A_i \to 1)}-local.}

\proof{ \p{A type #{X} is #{!\rm{-local}} when the map #{- \circ\ ! :
(1 \to X) \to (A_i \to X)} is an equivalence.}
}

%```agda
\agda{
is-localвҶҗis-null : вҲҖ {рқ“ҳ рқ“Ө рқ“Ҙ} {I : Type рқ“ҳ} {A : I вҶ’ Type рқ“Ө}
                   вҶ’ {X : Type рқ“Ҙ}
                   вҶ’ is-null A X
                   вҶ’ is-local (О» i вҶ’ ! {A = A i}) X
is-localвҶҗis-null eq i = 3-for-2' (unit-const-is-equiv) (eq i)

is-local-singвҶҗis-null : вҲҖ {рқ“ҳ рқ“Ө рқ“Ҙ рқ“Ұ} {I : Type рқ“ҳ}
                          {A : I вҶ’ Type рқ“Ө}
                          {B : I вҶ’ Type рқ“Ҙ}
                          (Bsing : вҲҖ i вҶ’ is-singleton (B i))
                          (f : вҲҖ i вҶ’ A i вҶ’ B i)
                        вҶ’ {X : Type рқ“Ұ}
                        вҶ’ is-null A X
                        вҶ’ is-local f X
is-local-singвҶҗis-null Bsing f null i
  = 3-for-2'
    (is-equivвҒ»В№ (sing-ev-is-equiv global-funext (Bsing i)))
    (null i)

is-nullвҶҗis-local : вҲҖ {рқ“ҳ рқ“Ө рқ“Ҙ} {I : Type рқ“ҳ} {A : I вҶ’ Type рқ“Ө}
                   вҶ’ {X : Type рқ“Ҙ}
                   вҶ’ is-local (О» i вҶ’ ! {A = A i}) X
                   вҶ’ is-null A X
is-nullвҶҗis-local eq i = is-equiv-вҲҳ (eq i) unit-const-is-equiv

is-nullвҶҗis-local-sing : вҲҖ {рқ“ҳ рқ“Ө рқ“Ҙ рқ“Ұ} {I : Type рқ“ҳ}
                          {A : I вҶ’ Type рқ“Ө}
                          {B : I вҶ’ Type рқ“Ҙ}
                          (Bsing : вҲҖ i вҶ’ is-singleton (B i))
                          (f : вҲҖ i вҶ’ A i вҶ’ B i)
                        вҶ’ {X : Type рқ“Ұ}
                        вҶ’ is-local f X
                        вҶ’ is-null A X
is-nullвҶҗis-local-sing Bs f loc i
  = is-equiv-вҲҳ
      (loc i)
      (is-equivвҒ»В№ (sing-ev-is-equiv global-funext (Bs i)))
}
%```
}

\subtree[stt-005K]{
\date{2025-06-17}
\author{samueltoth}
\title{Nullification at a pointed family}
\taxon{Definition}

\p{The nullification of a pointed type can be constructed
using the [free algebraic injection](stt-005I)
higher inductive type. By definition, the free
algebraic injection already gives a section to
the precomposition map. Because any map #{A \to 1}
has a section, then the precomposition by this
map already has a retract, and so the type is not just
algebraically #{A}-injective, but #{A}-null.}

%```agda
\agda{
NullвҲҷ : вҲҖ {рқ“ҳ рқ“Ө рқ“Ҙ} {I : Type рқ“ҳ} (A : I вҶ’ Type рқ“Ө)
         (AвҲҷ : О  _ A) (X : Type рқ“Ҙ)
       вҶ’ Type рқ“Ҙ
NullвҲҷ A _ X = Free-inj
               (О» i вҶ’ ! {A = A i})
                X

NullвҲҷ-is-null : вҲҖ {рқ“ҳ рқ“Ө рқ“Ҙ} {I : Type рқ“ҳ}
                 {A : I вҶ’ Type рқ“Ө} (AвҲҷ : О  _ A)
                 {X : Type рқ“Ҙ}
               вҶ’ is-null A (NullвҲҷ A AвҲҷ X)
NullвҲҷ-is-null a = is-nullвҶҗis-local I where
  I : is-local (О» _ вҶ’ !) _
  I i = is-equivвҶҗqiso О» where
    .fst вҶ’ injector-Free-inj i .fst
    .snd .fst Оұ вҶ’ funextвҶ’ (О» _ вҶ’ Free-inj.is-ext (Оұ вҲҳ !) (a i))
    .snd .snd вҶ’ injector-Free-inj i .snd
}
%```
}

\subtree[stt-0065]{
\date{2025-06-21}
\author{samueltoth}
\title{Nullification is a [reflective subuniverse](stt-0041)}
\taxon{Corollary}


%```agda
\agda{
module _ where
  open is-globally-reflective
  open is-global-reflector

  Null-SubU
    : вҲҖ {рқ“ҳ рқ“Ө} {I : Type рқ“ҳ}
        (A : I вҶ’ Type рқ“Ө)
        рқ“Ұ
      вҶ’ SubU рқ“Ұ (рқ“Ұ вҠ” рқ“ҳ вҠ” рқ“Ө)
  Null-SubU A рқ“Ұ .Subtype.family = is-null A
  Null-SubU A рқ“Ұ .Subtype.has-is-subtype = is-null-is-prop

  Null-GSU : вҲҖ {рқ“ҳ рқ“Ө} {I : Type рқ“ҳ}
               (A : I вҶ’ Type рқ“Ө)
              вҶ’ GSU (_вҠ” (рқ“ҳ вҠ” рқ“Ө))
  Null-GSU A .GSU.S = Null-SubU A _
  Null-GSU A .GSU.S-equiv e anull i
    = is-equivвҶҗArrow-equiv
        {F = mk-amap fwd (postcomp _ fwd) ~refl}
        (has-is-eqv , postcomp-equiv has-is-eqv)
        (anull i) where open _вүғ_ e

  opaque
    NullвҲҷ-global-reflectors
      : вҲҖ {рқ“ҳ рқ“Ө} {I : Type рқ“ҳ}
          {A : I вҶ’ Type рқ“Ө}
          (aвҲҷ : вҲҖ i вҶ’ A i)
        вҶ’ is-globally-reflective (Null-GSU A)
    NullвҲҷ-global-reflectors a .в—Ӣ = NullвҲҷ _ a
    NullвҲҷ-global-reflectors a .О· = Free-inj.inc
    NullвҲҷ-global-reflectors a .has-is-reflector
      .в—ӢвҲҲS = NullвҲҷ-is-null a
    NullвҲҷ-global-reflectors a .has-is-reflector
      .reflects cnull = Free-inj-reflects _ (is-localвҶҗis-null cnull)

  NullвҲҷ-reflective
    : вҲҖ {рқ“ҳ рқ“Ө рқ“Ұ} {I : Type рқ“ҳ}
        {A : I вҶ’ Type рқ“Ө}
        (aвҲҷ : вҲҖ i вҶ’ A i)
      вҶ’ is-reflective (Null-SubU A рқ“Ұ)
  NullвҲҷ-reflective a = is-reflectiveвҶҗglobal (NullвҲҷ-global-reflectors a)
}
%```
}

\subtree[stt-006E]{
\date{2025-06-25}
\author{samueltoth}
\taxon{Theorem}
\title{Nullification is a #{\Sigma}-closed reflective subuniverse}

\p{Nullification is a #{\Sigma}-closed reflective subuniverse and so
is also a higher modality.}

\proof{
\p{By calculation:}

##{
\begin{align}
  \Sigma_{(x : X)} Y(x)  &\simeq \Sigma_{(x : X)} A_i \to Y(x) \\
                         &\simeq \Sigma_{(x : A_i \to X)} \Pi_{(a : A_i)} Y(f(a))\\
                         &\simeq A_i \to \Sigma_{(x : X)} Y(x)
\end{align}
}

\p{Where (1) and (2) follow from the fact #{X} and each #{Y(x)} are
#{A}-[null](stt-005G), and (3) is the [type theoretic theorem of
choice](foundations.TheoremOfChoice).}  }

%```agda
\agda{
ОЈ-is-null : вҲҖ {рқ“ҳ рқ“Ө рқ“Ҙ рқ“Ұ}
              {I : Type рқ“ҳ}
              {P : I вҶ’ Type рқ“Ө}
              {X : Type рқ“Ҙ} {Y : X вҶ’ Type рқ“Ұ}
            вҶ’ is-null P X
            вҶ’ (вҲҖ x вҶ’ is-null P (Y x))
            вҶ’ is-null P (ОЈ X Y)
ОЈ-is-null {P = P} {X = X} {Y} Xnull Ynull i
  = eqv where
  opaque
    I : ОЈ X Y вүғ (P i вҶ’ ОЈ X Y)
    I = ОЈ X Y
          вүғвҹЁ ОЈ-ap-вүғ (О» x вҶ’ nullвүғ (Ynull x) i) вҹ©
        ОЈ X (О» x вҶ’ P i вҶ’ Y x)
          вүғвҹЁ ОЈ-ap-вүғ-fst {B = О» f вҶ’ (a : P i) вҶ’ Y (f a)} (nullвүғ Xnull i)  вҹ©
        ОЈ (P i вҶ’ X) (О» f вҶ’ (a : P i) вҶ’ Y (f a))
          вүғвҹЁ ОЈ-О -swapвүғ (О» _ вҶ’ X) (О» _ вҶ’ Y) eвҒ»В№ вҹ©
        (P i вҶ’ ОЈ X Y) вүғвҲҺ

    eqv : is-equiv (const (ОЈ X Y) (P i))
    eqv = I ._вүғ_.has-is-eqv

Null-globally-ОЈ-closed : вҲҖ {рқ“ҳ рқ“Ө} {I : Type рқ“ҳ}
                   {P : I вҶ’ Type рқ“Ө}
                 вҶ’ is-globally-ОЈ-closed (Null-GSU P)
Null-globally-ОЈ-closed = ОЈ-is-null

Null-ОЈ-closed : вҲҖ {рқ“ҳ рқ“Ө рқ“Ұ} {I : Type рқ“ҳ}
                   {A : I вҶ’ Type рқ“Ө}
                 вҶ’ is-ОЈ-closed (Null-SubU A рқ“Ұ)
Null-ОЈ-closed {A = A}
  = is-ОЈ-closedвҶҗglobally (Null-GSU A) Null-globally-ОЈ-closed

NullвҲҷ-HigherModality
  : вҲҖ {рқ“ҳ рқ“Ө рқ“Ұ} {I : Type рқ“ҳ}
      {A : I вҶ’ Type рқ“Ө}
      (a : О  _ A)
    вҶ’ HigherModality рқ“Ұ
NullвҲҷ-HigherModality a = HigherModalityвҶҗSubU
                           (NullвҲҷ-reflective a)
                           (Null-ОЈ-closed)
}
%```
}

\subtree[fre-0003]{
\date{2025-06-29}
\author{samueltoth}
\date{2026-03-10}
\author{fredrikbakke}
\title{Closure properties of null types from closure properties of local types}
\taxon{Corollary}

\p{
Given a type family #{X : A \to \UU}, then #{X}-null types are closed under

\ul{
\li{contractible types}
\li{dependent products}
\li{forming identity types}
\li{forming pullbacks}
\li{forming cartesian products}
\li{forming fibers}
\li{forming retract types}
\li{forming equivalence types.}
}
}


%```agda
\agda{
module _
  {рқ“ҳ рқ“Ө : Level}
  {I : Type рқ“ҳ} (X : I вҶ’ Type рқ“Ө)
  (let X! =  О» i вҶ’ ! {A = X i}) where

  is-nulllвҶҗis-singleton
    : вҲҖ {рқ“Ҙ} {Y : Type рқ“Ҙ}
    вҶ’ is-singleton Y
    вҶ’ is-null X Y
  is-nulllвҶҗis-singleton sing
    = is-nullвҶҗis-local (is-localвҶҗis-singleton X! sing)

  рқҹҷ-is-null
    : is-null X рқҹҷ
  рқҹҷ-is-null
    = is-nullвҶҗis-local (рқҹҷ-is-local X!)

  О -is-null
    : вҲҖ {рқ“Ҙ рқ“Ұ}
        {A : Type рқ“Ҙ} {B : A вҶ’ Type рқ“Ұ}
      вҶ’ (вҲҖ a вҶ’ is-null X (B a))
      вҶ’ is-null X (О  A B)
  О -is-null bn
    = is-nullвҶҗis-local
        (О -is-local X! (О» a вҶ’ is-localвҶҗis-null (bn a)))

  пјқ-is-null
    : вҲҖ {рқ“Ҙ}
        {A : Type рқ“Ҙ}
      вҶ’ is-null X A
      вҶ’ вҲҖ {x y : A}
        вҶ’ is-null X (x пјқ y)
  пјқ-is-null null
    = is-nullвҶҗis-local
        (пјқ-is-local X! (is-localвҶҗis-null null))

  Pullback-is-null
    : вҲҖ {рқ“Ҙ рқ“Ұ рқ“§}
        {Y : Type рқ“Ҙ} {Z : Type рқ“Ұ} {Q : Type рқ“§}
        (f : Y вҶ’ Q) (g : Z вҶ’ Q)
      вҶ’ is-null X Y
      вҶ’ is-null X Z
      вҶ’ is-null X Q
      вҶ’ is-null X (Pullback f g)
  Pullback-is-null f g Ynull Znull Qnull
    = is-nullвҶҗis-local
        (Pullback-is-local X! f g
          (is-localвҶҗis-null Ynull)
          (is-localвҶҗis-null Znull)
          (is-localвҶҗis-null Qnull))

  fibre-is-null
    : вҲҖ {рқ“Ҙ рқ“Ұ}
        {Y : Type рқ“Ҙ} {Z : Type рқ“Ұ}
        (f : Y вҶ’ Z) (b : Z)
      вҶ’ is-null X Y
      вҶ’ is-null X Z
      вҶ’ is-null X (fibre f b)
  fibre-is-null f b Ynull Znull
    = is-nullвҶҗis-local
        (fibre-is-local X! f b
          (is-localвҶҗis-null Ynull)
          (is-localвҶҗis-null Znull))

  Г—-is-null
    : вҲҖ {рқ“Ҙ рқ“Ұ}
        {Y : Type рқ“Ҙ} {Z : Type рқ“Ұ}
      вҶ’ is-null X Y
      вҶ’ is-null X Z
      вҶ’ is-null X (Y Г— Z)
  Г—-is-null Ynull Znull
    = is-nullвҶҗis-local
        (Г—-is-local X!
          (is-localвҶҗis-null Ynull)
          (is-localвҶҗis-null Znull))

  retract-of-is-null
    : вҲҖ {рқ“Ҙ рқ“Ұ}
        {A : Type рқ“Ҙ} {B : Type рқ“Ұ}
      вҶ’ is-null X A
      вҶ’ is-null X B
      вҶ’ is-null X (A retract-of B)
  retract-of-is-null Anull Bnull
    = is-nullвҶҗis-local
        (retract-of-is-local X!
          (is-localвҶҗis-null Anull)
          (is-localвҶҗis-null Bnull))

  biinv-is-null
    : вҲҖ {рқ“Ҙ рқ“Ұ}
        {A : Type рқ“Ҙ} {B : Type рқ“Ұ}
      вҶ’ is-null X A
      вҶ’ is-null X B
      вҶ’ is-null X (biinv A B)
  biinv-is-null Anull Bnull
    = is-nullвҶҗis-local
        (biinv-is-local X!
          (is-localвҶҗis-null Anull)
          (is-localвҶҗis-null Bnull))

  вүғ-is-null
    : вҲҖ {рқ“Ҙ рқ“Ұ}
        {A : Type рқ“Ҙ} {B : Type рқ“Ұ}
      вҶ’ is-null X A
      вҶ’ is-null X B
      вҶ’ is-null X (A вүғ B)
  вүғ-is-null Anull Bnull
    = is-nullвҶҗis-local
        (вүғ-is-local X!
          (is-localвҶҗis-null Anull)
          (is-localвҶҗis-null Bnull))
}
%```
}

\subtree[fre-0000]{
\date{2026-03-09}
\author{fredrikbakke}
\title{The universe of null types in a subuniverse at a family of propositions}
\taxon{Theorem}

\p{
Let #{P_i} be a family of propositions, and let #{\mathcal{S}} be a
[global subuniverse](stt-007A) which is closed under dependent products over each
#{P_i}. Then the type of #{P}-null types in #{\mathcal{S}} is again #{P}-null.
}

%```agda
\agda{
Null-in-GSU
  : {Оұ : Level вҶ’ Level} {рқ“ҳ рқ“Ө : Level} {I : Type рқ“ҳ}
  вҶ’ (P : I вҶ’ Type рқ“Ө)
  вҶ’ GSU Оұ
  вҶ’ вҲҖ рқ“Ҙ вҶ’ Type (lsuc (рқ“Ө вҠ” рқ“Ҙ) вҠ” Оұ (рқ“Ө вҠ” рқ“Ҙ) вҠ” рқ“ҳ)
Null-in-GSU {рқ“Ө = рқ“Ө} P S рқ“Ҙ
  = ОЈ[ X вҲ¶ Type (рқ“Ө вҠ” рқ“Ҙ) ] ((X вҲҲ GSU.S S) Г— is-null P X)

Null-in-GSU-is-nullвҶҗis-prop
  : {Оұ : Level вҶ’ Level} {рқ“ҳ рқ“Ө рқ“Ҙ : Level} {I : Type рқ“ҳ}
    {P : I вҶ’ Type рқ“Ө} {S : GSU Оұ}
  вҶ’ ((i : I) вҶ’ is-prop (P i))
  вҶ’ ( {рқ“Ұ : Level} (i : I) {B : P i вҶ’ Type рқ“Ұ}
      вҶ’ (вҲҖ a вҶ’ (B a) вҲҲ GSU.S S)
      вҶ’ (О  (P i) B) вҲҲ GSU.S S)
  вҶ’ is-null P (Null-in-GSU P S рқ“Ҙ)
Null-in-GSU-is-nullвҶҗis-prop {рқ“Ө = рқ“Ө} {рқ“Ҙ = рқ“Ҙ} {P = P} {S = S} is-prop-P SО  i
  = is-equivвҶҗqiso qiso where
  U = Null-in-GSU P S рқ“Ҙ
  SU = GSU.S S

  is-in-SU-and-is-null-is-prop
    : (X : Type (рқ“Ө вҠ” рқ“Ҙ)) вҶ’ is-prop ((X вҲҲ SU) Г— is-null P X)
  is-in-SU-and-is-null-is-prop X
    = is-prop-ОЈ (вҲҲ-is-prop SU X) (О» _ вҶ’ is-null-is-prop X)

  qiso : quasi-iso (const U (P i))
  qiso .fst f
    = ( О  (P i) (fst вҲҳ f)
      , SО  i (О» a вҶ’ snd (f a) .fst)
      , О -is-null P (О» a вҶ’ snd (f a) .snd))
  qiso .snd .fst (X , XвҲҲS , Xnull)
    = ОЈ-pathвҶ’ (ua (nullвүғ Xnull i eвҒ»В№) , is-in-SU-and-is-null-is-prop _ _ _)
  qiso .snd .snd f
    = funextвҶ’ О» a вҶ’ ОЈ-pathвҶ’
      ( ua (mkвүғ (ev a)
                (sing-evбөҲ-is-equiv global-funext (mk-singl a (is-prop-P i a))))
      , is-in-SU-and-is-null-is-prop _ _ _)
}
%```
}

\subtree[fre-0001]{
\date{2026-03-09}
\author{fredrikbakke}
\title{The universe of null types at a family of propositions}
\taxon{Corollary}

\p{
For a family of propositions #{P_i}, the type of #{P}-null types is itself #{P}-null.
}

%```agda
\agda{
Null-U
  : {рқ“ҳ рқ“Ө : Level}
  вҶ’ {I : Type рқ“ҳ}
  вҶ’ (P : I вҶ’ Type рқ“Ө)
  вҶ’ (рқ“Ҙ : Level) вҶ’ Type (рқ“ҳ вҠ” lsuc рқ“Ө вҠ” lsuc рқ“Ҙ)
Null-U P рқ“Ҙ = Null-in-GSU P Full-GSU рқ“Ҙ

Null-U-is-nullвҶҗis-prop
  : {рқ“ҳ рқ“Ө рқ“Ҙ : Level}
    {I : Type рқ“ҳ}
    {P : I вҶ’ Type рқ“Ө}
  вҶ’ ((i : I) вҶ’ is-prop (P i))
  вҶ’ is-null P (Null-U P рқ“Ҙ)
Null-U-is-nullвҶҗis-prop {рқ“Ҙ = рқ“Ҙ} {P = P} is-prop-P
  = Null-in-GSU-is-nullвҶҗis-prop
      {рқ“Ҙ = рқ“Ҙ}
      {P = P}
      {S = Full-GSU}
      (is-prop-P)
      (О» _ _ вҶ’ tt)
}
%```
}

\subtree[fre-0004]{
\date{2026-03-10}
\author{fredrikbakke}
\title{Null types and singleton-codomain local types}
\taxon{Theorem}

%```agda
\agda{
Nullвүғ!Local : вҲҖ {рқ“ҳ рқ“Ө рқ“Ҙ} {I : Type рқ“ҳ} {A : I вҶ’ Type рқ“Ө}
              вҶ’ Subtype-equiv (Local-SubU (О» i вҶ’ ! {A = A i}) рқ“Ҙ)
                              (Null-SubU A рқ“Ҙ)
Nullвүғ!Local A = (is-nullвҶҗis-local , is-localвҶҗis-null )


Null-globally-reflective
  : вҲҖ {рқ“ҳ рқ“Ө} {I : Type рқ“ҳ} {A : I вҶ’ Type рқ“Ө}
  вҶ’ is-globally-reflective (Null-GSU A)
Null-globally-reflective {A = A}
  = is-globally-reflective-subtype-equiv
      Nullвүғ!Local
      (Local-global-reflectors (О» i вҶ’ ! {A = A i}))

module _ {рқ“ҳ рқ“Ө рқ“Ҙ рқ“Ұ : Level} {I : Type рқ“ҳ}
         {A : I вҶ’ Type рқ“Ө} {B : I вҶ’ Type рқ“Ҙ}
         where
  open is-reflective
  open is-reflector

  Local-ОЈ-closed
    : (f : (i : I) вҶ’ A i вҶ’ B i)
    вҶ’ (вҲҖ i вҶ’ is-singleton (B i))
    вҶ’ is-ОЈ-closed (Local-SubU f рқ“Ұ)
  Local-ОЈ-closed f sngl aloc bloc
    = is-local-singвҶҗis-null sngl f
        (Null-ОЈ-closed
        (is-nullвҶҗis-local-sing sngl f aloc)
           О» a вҶ’ is-nullвҶҗis-local-sing sngl f (bloc a))

  Local-HigherModality
    : (f : (i : I) вҶ’ A i вҶ’ B i)
    вҶ’ (вҲҖ i вҶ’ is-singleton (B i))
    вҶ’ HigherModality рқ“Ұ
  Local-HigherModality f s = HigherModalityвҶҗSubU
                               (Local-reflective f)
                               (Local-ОЈ-closed f s)
}
%```
}

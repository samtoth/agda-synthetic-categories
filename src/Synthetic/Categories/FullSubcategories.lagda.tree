\subtree[rie-1234]{
\title{Full subtypes}
\author{emilyriehl}

\p{Recall that a [subtype](Foundations.Subtypes) of a type #{A} is a family of
propositions #{ПҶ} indexed by #{A}. Formally, this data is given by a family of types
that we abusively denote #{ПҶ : A \to \UU} together with a proof that each type #{ПҶ a}
is a proposition for all #{a : A}. From this data, one may construct a type
#{ОЈ_{A} ПҶ} with an embedding #{ОЈ_{A} ПҶ \to A}.}

\p{Given a crisp type #{A :^\flat \UU} and a family of propositions #{ПҶ} indexed by
#{\flat A}, the \em{full-subtype} is defined to be #{ОЈ_{A} \sharp \overline{ПҶ}} where
#{\overline{ПҶ} : A \to \sharp UU} denotes the adjoint transpose of the family #{ПҶ}
under the adjunction #{\flat вҠЈ \sharp}, which defines a family of types over #{A}
after postcomposing with the dependent sharp modal operator
#{\sharp : \sharp \UU \to \UU}.}


\agda{
module FullSubtype {@вҷӯ рқ“Ө рқ“Ҙ} {@вҷӯ A : Type рқ“Ө} ( ПҶ : Subtype вҹЁвҷӯ| A вҹ© рқ“Ҙ) where

  full-subtype : Type (рқ“Ө вҠ” рқ“Ҙ)
  full-subtype = ОЈ A (О» a вҶ’ вҹЁвҷҜ| modвҷӯ a вҲҲ ПҶ вҹ©)

  full-subtype-incl : full-subtype вҶ’ A
  full-subtype-incl = fst

  full-subtype-family : (a : A) вҶ’ Type рқ“Ҙ
  full-subtype-family a = вҹЁвҷҜ| modвҷӯ a вҲҲ ПҶ вҹ©

  full-subtype-family-is-prop : (a : A) вҶ’ is-prop (full-subtype-family a)
  full-subtype-family-is-prop a = вҷҜ-is-prop (вҲҲ-is-prop ПҶ (modвҷӯ a))

  Subtype-full-subtype : Subtype A рқ“Ҙ
  Subtype-full-subtype = mk-subtype full-subtype-family-is-prop
}
}

\subtree[rie-2718]{
\title{Universal property of full subtypes}
\author{emilyriehl}

\p{The inclusion of a full subtype is orthogonal to all counits of the modality
#{\sharp}. This orthogonality means that to define a map
#{f : X \to ОЈ_{A} \overline{ПҶ}} is to define a map #{f : \flat X вҶ’ A} for which the
elements #{f x} satisfy the predicate #{ПҶ}.}

\p{Under the hypothesis that the inclusion #{\partial\Delta^1 \to \Delta^1} is
equivalent to the #{\flat} counit of #{\Delta^1}, it follows from this orthogonality
that the full subtype inclusion is fully faithful.
}

\agda{
  ОөвҷӯвҠҘfull-subtype-family :
    {@вҷӯ рқ“Ұ : Level} вҶ’ (@вҷӯ X : Type рқ“Ұ)
    вҶ’ are-orthogonal-fam (Оөвҷӯ: X) full-subtype-family
  ОөвҷӯвҠҘfull-subtype-family X =
    are-orthogonal-famвҶҗunique-extensions {P = full-subtype-family}
      (О» F
        вҶ’ mk-singl
          ((transpose X (F .ArrFam-map.bot) (F .ArrFam-map.top) )
          , О» x вҶ’ full-subtype-family-is-prop ((F .ArrFam-map.bot) (Оөвҷӯ x)) _ _ )
          О» e
            вҶ’ ExtбөҲ-Subtype-is-prop {A = вҹЁвҷӯ| X вҹ©} Оөвҷӯ Subtype-full-subtype F _ _) where
      transpose : {@вҷӯ рқ“Ұ : Level} вҶ’ (@вҷӯ X : Type рқ“Ұ) вҶ’ (f : X вҶ’ A)
          вҶ’ О  вҹЁвҷӯ| X вҹ© ((О» a вҶ’ вҹЁвҷҜ| modвҷӯ (f a) вҲҲ ПҶ вҹ©) вҲҳ (Оөвҷӯ: _))
          вҶ’ О  X (О» a вҶ’ вҹЁвҷҜ| modвҷӯ (f a) вҲҲ ПҶ вҹ©)
      transpose X f s x .counitвҷҜ = s (modвҷӯ x) .counitвҷҜ

  ОөвҷӯвҠҘfull-subtype-incl : {@вҷӯ рқ“Ұ : Level} вҶ’ (@вҷӯ X : Type рқ“Ұ)
    вҶ’ are-orthogonal (Оөвҷӯ: X) (full-subtype-incl )
  ОөвҷӯвҠҘfull-subtype-incl _ =
    are-orthogonal-fstвҶҗare-orthogonal-fam (ОөвҷӯвҠҘfull-subtype-family _)

  module _ (ax : is-equiv вҲӮО”В№-to-вҷӯО”В№) where

    is-ff-full-subtype-incl : is-ff (full-subtype-incl )
    is-ff-full-subtype-incl _ =
      left-orthogonal-homotopy _ homotopy-вҲӮО”В№-incl
        (left-orthogonal-вҲҳ (Оөвҷӯ: О”В№) вҲӮО”В№-to-вҷӯО”В№ _
          (ОөвҷӯвҠҘfull-subtype-incl О”В№) (equivвҠҘ ax _))
}
}

\subtree[rie-4321]{
\title{Full subcategories}

\p{When #{A} is a category, a full subtype over #{A} is called a
\em{full subcategory} and satisfies additional properties. Future work will show
that this is a category.}

\agda{
module FullSubcategory {@вҷӯ рқ“Ө рқ“Ҙ} {@вҷӯ A : Type рқ“Ө} {Ac : is-category A}
  ( ПҶ : Subtype вҹЁвҷӯ| A вҹ© рқ“Ҙ) where

  open FullSubtype ПҶ public renaming
    ( full-subtype to full-subcat ;
      full-subtype-incl to full-subcat-incl ;
      full-subtype-family to full-subcat-family)

}
}

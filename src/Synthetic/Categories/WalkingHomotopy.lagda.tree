\subtree[stt-00DK]{
\title{The walking left homotopy}
\taxon{Definition}
\date{2026-01-29}
\author{samueltoth}

\p{
We define the walking homotopy #{\Delta_\sim} as the [cofibre](Core.Cofibres) of
#{d_2 : О”В№ \to О”ВІ}, which contracts the edge #{0 \leq 1}.
}

\agda{
О”~в–ө-contracted-edge : О”В№ вҶ’ О”ВІ
О”~в–ө-contracted-edge i = i , i0

О”~в–ө : Type рқ“ҳ
О”~в–ө = Cofibre О”~в–ө-contracted-edge

src-О”~в–ө : О”В№ вҶ’ О”~в–ө
src-О”~в–ө = О№вӮҒ вҲҳ О”ВІ-diagonal

tgt-О”~в–ө : О”В№ вҶ’ О”~в–ө
tgt-О”~в–ө = О№вӮҒ вҲҳ (i1 ,_)
}
}

\subtree[stt-00PX]{
\title{The walking left homotopy classifies left homotopies}
\taxon{Theorem}
\author{samueltoth}
\date{2026-01-29}

\p{
We show that a map
#{\Delta_\sim \to A} is equivalent to the type consisting of a pair of morphisms and
a homotopy between them.
}

\agda{
module _ {рқ“Ө} {A : Type рқ“Ө} where

  О”~в–ө-rep1 : (О”~в–ө вҶ’ A) вүғ ОЈ[ x вҲ¶ A ] Ext (Оӣ[2,1]-incl вҲҳ О№вӮҒ) (const _ _ x)
  О”~в–ө-rep1 = Cofibre-map-repr О”~в–ө-contracted-edge

  _ : (f : О”~в–ө вҶ’ A)
    вҶ’ f вҲҳ src-О”~в–ө ~ О”~в–ө-rep1 ._вүғ_.fwd f .snd .fst вҲҳ О”ВІ-diagonal
  _ = О» _ вҶ’ ~refl

  О”~в–ө-rep2
    : (О”~в–ө вҶ’ A)
    вүғ ОЈ[ x вҲ¶ A ]
      ОЈ[ f вҲ¶ Ext {B = Оӣ[2,1]} О№вӮҒ (const _ _ x) ]
        Ext Оӣ[2,1]-incl (f .fst)
  О”~в–ө-rep2
    =  О”~в–ө-rep1
    вҲҷe ОЈ-snd-вүғ (О» a вҶ’ Ext-compose global-funext Оӣ[2,1]-incl О№вӮҒ (const _ _ a))

  _ : (f : О”~в–ө вҶ’ A)
    вҶ’ f вҲҳ src-О”~в–ө ~ О”~в–ө-rep2 ._вүғ_.fwd f .snd .snd .fst вҲҳ О”ВІ-diagonal
  _ = О» _ вҶ’ ~refl

  Оӣ[2,1]-ext-l
    : (f : О”В№ вҶ’ A)
    вҶ’ Ext {B = Оӣ[2,1]} О№вӮҒ f вүғ ОЈ[ g вҲ¶ (О”В№ вҶ’ A)] (g i0 пјқ f i1)
  Оӣ[2,1]-ext-l f
    = Ext {B = Оӣ[2,1]} О№вӮҒ f
        вүғвҹЁ ОЈ-snd-вүғ (О» _ вҶ’ funextвүғ eвҒ»В№) вҹ©
      ОЈ[ x вҲ¶ (Оӣ[2,1] вҶ’ A) ] (x вҲҳ О№вӮҒ пјқ f)
        вүғвҹЁ ОЈ-fst-вүғ {B = О» x вҶ’ x .fst пјқ f} (Pushout-UPвүғ вҲҷe cocone-reprвүғ) вҹ©
      _
        вүғвҹЁ remove-singleton-structure Sing'-is-singleton (_ , refl) вҹ©
      _
        вүғвҹЁ ОЈ-snd-вүғ (О» a вҶ’ unit-UPвүғ вҲҷe symвүғ) вҹ©
      ОЈ[ g вҲ¶ (О”В№ вҶ’ A)] (g i0 пјқ f i1) вүғвҲҺ

  Оӣ[2,1]-ext-lвҶ’
    : (f : О”В№ вҶ’ A)
    вҶ’ Ext {B = Оӣ[2,1]} О№вӮҒ f вҶ’ ОЈ[ g вҲ¶ (О”В№ вҶ’ A)] (g i0 пјқ f i1)
  Оӣ[2,1]-ext-lвҶ’ f (e , p) = (e вҲҳ О№вӮӮ , sym (ap e Оӣ[2,1]-glue) вҲҷ p i1)

  Оӣ[2,1]-ext-lвҶҗ
    : (f : О”В№ вҶ’ A)
    вҶ’ ОЈ[ g вҲ¶ (О”В№ вҶ’ A)] (g i0 пјқ f i1) вҶ’ Ext {B = Оӣ[2,1]} О№вӮҒ f
  Оӣ[2,1]-ext-lвҶҗ f (g , k) = (cogap (mk-cocone f g (О» _ вҶ’ sym k))) , ~refl

  Оӣ[2,1]-ext-l-is-equiv
    : (f : О”В№ вҶ’ A) вҶ’ is-equiv (Оӣ[2,1]-ext-lвҶ’ f)
  Оӣ[2,1]-ext-l-is-equiv f
    = is-equiv-вҲҳ~ H
        (Оӣ[2,1]-ext-lвҶ’=-is-equiv f)
        (bwd-is-equiv (ОЈ-snd-вүғ (О» _ вҶ’ funextвүғ))) where

      Оӣ[2,1]-ext-lвҶ’=
        : {рқ“Ө : Level} {A : Type рқ“Ө} (f : О”В№ вҶ’ A)
        вҶ’ fibre (precomp-О  (О» _ вҶ’ A) О№вӮҒ) f
        вҶ’ ОЈ[ g вҲ¶ (О”В№ вҶ’ A)] (g i0 пјқ f i1)
      Оӣ[2,1]-ext-lвҶ’= {A = A} .(precomp-О  (О» _ вҶ’ A) О№вӮҒ e) (e , refl)
        = (e вҲҳ О№вӮӮ , sym (ap e Оӣ[2,1]-glue))

      HJ
        : {e : Оӣ[2,1] вҶ’ A} {f : О”В№ вҶ’ A}
          (q : e вҲҳ О№вӮҒ пјқ f)
        вҶ’ Оӣ[2,1]-ext-lвҶ’= f (e , q)
        пјқ (e вҲҳ О№вӮӮ , sym (ap e Оӣ[2,1]-glue) вҲҷ happly q i1)
      HJ refl = ОЈ-pathвҶ’ (refl , sym (вҲҷ-reflr _))

      H : Оӣ[2,1]-ext-lвҶ’= f вҲҳ _вүғ_.bwd (ОЈ-snd-вүғ (О» _ вҶ’ funextвүғ))
        ~ Оӣ[2,1]-ext-lвҶ’ f
      H (e , p)
        = HJ (funextвҶ’ p)
        вҲҷ ap
            (О» r вҶ’ (e вҲҳ О№вӮӮ , sym (ap e Оӣ[2,1]-glue) вҲҷ r))
            (happly (_вүғ_.Оө funextвүғ p) i1)

      Оӣ[2,1]-ext-lвҶҗ=
        : (f : О”В№ вҶ’ A)
        вҶ’ ОЈ[ g вҲ¶ (О”В№ вҶ’ A)] (g i0 пјқ f i1)
        вҶ’ fibre (precomp-О  (О» _ вҶ’ A) О№вӮҒ) f
      Оӣ[2,1]-ext-lвҶҗ= f (g , k) = (cogap (mk-cocone f g (О» _ вҶ’ sym k)) , refl)

      Оӣ[2,1]-ext-lвҶ’=-is-equiv
        : (f : О”В№ вҶ’ A) вҶ’ is-equiv (Оӣ[2,1]-ext-lвҶ’= f)
      Оӣ[2,1]-ext-lвҶ’=-is-equiv f = is-equivвҶҗqinv
        ( Оӣ[2,1]-ext-lвҶҗ= f
        , uncurry
            (О» where
              f refl вҶ’ fibre-pathвҶ’
                ( funextвҶ’
                    (sym вҲҳ pushout-rec-unique _ _ ~refl ~refl
                      (О» _ вҶ’ вҲҷ-reflr _ вҲҷ sym sym-sym))
                , вҲҷ-reflr _ вҲҷ sym (commutes-prewhisker-funext _)
                  вҲҷ funext-refl))
        , uncurry (О» x y вҶ’ ОЈ-pathвҶ’ (refl , (ap sym (pushout-rec-apОІ tt) вҲҷ sym-sym))))

  О”~в–ө-rep3
    : (О”~в–ө вҶ’ A) вүғ ОЈ[ f вҲ¶ (О”В№ вҶ’ A) ] Ext Оӣ[2,1]-incl (make-horn (О»hom f) (idH _))
  О”~в–ө-rep3
    = (О”~в–ө вҶ’ A)
        вүғвҹЁ О”~в–ө-rep2 вҹ©
      ОЈ[ x вҲ¶ A ]
      (ОЈ (Ext О№вӮҒ (const A О”В№ x)) (Ext Оӣ[2,1]-incl вҲҳ fst))
        вүғвҹЁ ОЈ-assoc eвҒ»В№ вҹ©
      ОЈ[ xe вҲ¶ (ОЈ[ x вҲ¶ A ] Ext О№вӮҒ (const _ _ x)) ] (Ext Оӣ[2,1]-incl вҲҳ fst) (xe .snd)
        вүғвҹЁ mkвүғ lem lem-is-eqv вҹ©
      ОЈ[ f вҲ¶ (О”В№ вҶ’ A) ] (Ext Оӣ[2,1]-incl (make-horn (О»hom f) (idH (f _))))
        вүғвҲҺ where

      H : (a : ОЈ[ x вҲ¶ A ] Ext О№вӮҒ (const _ _ x))
        вҶ’ a .snd .fst
        ~ make-horn (О»hom (a .snd .fst вҲҳ О№вӮӮ)) (idH _)
      H (x , a , p) = pushout-rec-unique _ _
        (О» i вҶ’ p i вҲҷ sym (p i1) вҲҷ ap a Оӣ[2,1]-glue) ~refl
        О» _ вҶ’ ap (_вҲҷ refl) (sym (symвҲҷ (p i1) (ap a Оӣ[2,1]-glue)))

      lem
        : ОЈ[ xe вҲ¶ (ОЈ[ x вҲ¶ A ] Ext О№вӮҒ (const _ _ x)) ]
          (Ext Оӣ[2,1]-incl вҲҳ fst) (xe .snd)
        вҶ’ ОЈ[ f вҲ¶ (О”В№ вҶ’ A)] Ext Оӣ[2,1]-incl (make-horn (О»hom f) (idH _))
      lem (a , b , p) = (a .snd .fst вҲҳ О№вӮӮ , b , p вҲҷh H a)

      lem-is-eqv : is-equiv lem
      lem-is-eqv
        = is-equiv-вҲҳ
            (total-is-equivвҶҗfst-is-equiv
              (is-equiv-вҲҳ
                  (singleton-fst-is-equiv (О» _ вҶ’ Sing-is-singleton))
                  (is-equiv-вҲҳ
                    (ОЈ-comm ._вүғ_.fwd-is-equiv)
                    (is-total-equivвҶҗis-fibrewise-equiv
                      (О» a вҶ’ Оӣ[2,1]-ext-l-is-equiv (const A О”В№ a))))))
            (is-total-equivвҶҗis-fibrewise-equiv
              О» a вҶ’ is-total-equivвҶҗis-fibrewise-equiv
                О» b вҶ’ вҲҷh-is-equiv' (H a))

  _ : (f : О”~в–ө вҶ’ A) вҶ’ f вҲҳ src-О”~в–ө ~ О”~в–ө-rep3 ._вүғ_.fwd f .snd .fst вҲҳ О”ВІ-diagonal
  _ = О» _ вҶ’ ~refl

  О”~в–ө-rep4
    : (О”~в–ө вҶ’ A)
    вүғ ОЈ[ f вҲ¶ (О”В№ вҶ’ A) ] ОЈ[ g вҲ¶ Hom A (f i0) (f i1) ] Hom2 (О»hom f) (idH _) g
  О”~в–ө-rep4 = О”~в–ө-rep3
          вҲҷe ОЈ-snd-вүғ
              (О» f вҶ’ ОЈ-snd-вүғ (О» _ вҶ’ funextвүғ eвҒ»В№)
                  вҲҷe mkвүғ _ (compositeвҶҗhorn-extension-is-equiv (О»hom f) (idH _)))

  rep4-О”~в–өtgt
    : fst вҲҳ О”~в–ө-rep4 ._вүғ_.fwd ~ precomp A (tgt-О”~в–ө)
  rep4-О”~в–өtgt = ~refl

  rep4-О”~в–өsrc
    : HomбөҲ.hom вҲҳ fst вҲҳ snd вҲҳ О”~в–ө-rep4 ._вүғ_.fwd ~ precomp A (src-О”~в–ө)
  rep4-О”~в–өsrc f
    = compositeвҶҗhorn-extension-diagonal _ _
        (total-map (О» _ вҶ’ funextвҶ’) (О”~в–ө-rep3 ._вүғ_.fwd f .snd))
}
}

\subtree[stt-00DL]{
\taxon{Corollary}
\author{samueltoth}
\date{2026-01-29}

\p{
As a corollary of \ref{stt-00CH}, we have that the map that picks out the source (or
the target) of the walking homotopy is a Segal equivalence.
}

\agda{
opaque
  tgt-is-segal-equiv
    : is-segal-equiv tgt-О”~в–ө
  tgt-is-segal-equiv {Q = Q} qpc
    = is-equiv-вҲҳ
        {f = fst}
        {g = О”~в–ө-rep4 ._вүғ_.fwd}
        (singleton-fst-is-equiv
          (О» f вҶ’ SingS-is-single вҰғ Hom-lhomotopy-IdS qpc вҰ„ _))
        (О”~в–ө-rep4 ._вүғ_.fwd-is-equiv)

  src-is-segal-equiv
    : is-segal-equiv src-О”~в–ө
  src-is-segal-equiv {Q = Q} qpc
    = is-equiv-вҲҳ~
        {f = (HomбөҲ.hom вҲҳ fst вҲҳ snd)}
        {g = О”~в–ө-rep4 ._вүғ_.fwd}
        (rep4-О”~в–өsrc)
        (is-equivвҶҗqinv lemma)
        (О”~в–ө-rep4 ._вүғ_.fwd-is-equiv) where
    lemma : quasi-inv {A = ОЈ[ f вҲ¶ (О”В№ вҶ’ Q) ]
                             ОЈ[ g вҲ¶ Hom Q (f i0) (f i1) ]
                               Hom2 (О»hom f) (idH _) g}
                     {B = О”В№ вҶ’ Q} (HomбөҲ.hom вҲҳ fst вҲҳ snd)
    lemma .fst a = (a , О»hom a , refl~в–ө (О»hom a))
    lemma .snd .fst (a , b , p)
      = ОЈ-pathвҶ’ ( sym (ap HomбөҲ.hom (IdвҶҗIdS вҰғ Hom-lhomotopy-IdS qpc вҰ„ p))
                , (composite-is-prop qpc _ _ _ _))
    lemma .snd .snd a = refl
}
}

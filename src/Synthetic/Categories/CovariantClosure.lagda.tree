\subtree[stt-00KG]{
\title{Families of paths in covariant families are covariant}
\taxon{Lemma}

\p{If #{B : A \to \Type} is a covariant family, and #{a\ b : \Pi_A B} are a
pair of sections, then the family #{i \mapsto a(i) = b(i)} is also covariant.}


\proof{
\p{We prove the analogous result for left fibrations. Consider the following
diagram:}

\quiver{
\begin{tikzcd}
	{a = b} && A \\
	\\
	A && B \\
	\\
	&& A
	\arrow[from=1-1, to=1-3]
	\arrow[from=1-1, to=3-1]
	\arrow["\lrcorner"{anchor=center, pos=0.125}, draw=none, from=1-1, to=3-3]
	\arrow["a", from=1-3, to=3-3]
	\arrow["b", from=3-1, to=3-3]
	\arrow[equals, from=3-1, to=5-3]
	\arrow["p", from=3-3, to=5-3]
\end{tikzcd}
}

\p{Now #{p} is a left fibration by assumption, and so too is #{pa} since #{a} is
a section, so by the left cancellative property of left fibrations, we have that
#{a} is a left fibration. Finally, #{a({-}) = b({-})} is obtained as a pullback
of #{a} and hence is also a left fibration.}
}

\agda{
opaque
  Ôºù-is-covariant
    : ‚àÄ {ùì§ ùì•} {A : Type ùì§} {B : A ‚Üí Type ùì•} (x y : ŒÝ A B)
      ‚Üí is-covariant B
      ‚Üí is-covariant (Œª a ‚Üí x a Ôºù y a)
  Ôºù-is-covariant {A = A} {B} x y Bc
    = is-covariant‚Üîis-left-fibration _ .snd lf where
    is-left : is-left-fibration {A = A} {B = Œ£ A B} (Œª a ‚Üí a , y a)
    is-left = right-orthogonal-left-cancel (point i0)
                (is-covariant‚Üîis-left-fibration _ .fst Bc)
                (point i0 ‚ä•id)

    pb : Arrow-map (fst: Œª a ‚Üí x a Ôºù y a) {D = Œ£ A B} (Œª a ‚Üí a , y a)
    pb .Arrow-ŒÝ.top = fst
    pb .Arrow-ŒÝ.bot a = (a , x a)
    pb .Arrow-ŒÝ.comm (a , p) = Œ£-path‚Üí (refl , p)

    pb-is-cart : is-cartesian pb
    pb-is-cart = is-cartesian‚Üêis-pullback pb
      (is-equiv-‚àò
        {f = total-map Œª a ‚Üí total-map Œª b ‚Üí Œ£-path‚Üí}
        {Œª (a , b) ‚Üí a , a , refl , b }
        (is-total-equiv‚Üêis-fibrewise-equiv
          (Œª a ‚Üí is-total-equiv‚Üêis-fibrewise-equiv
            (Œª b ‚Üí Œ£-path ._‚âÉ_.fwd-is-equiv)))
        (is-equiv‚Üêqinv
          ( (Œª where (a , b , refl , p) ‚Üí a , p)
          , ~refl
          , Œª where (a , b , refl , p) ‚Üí refl)))

    lf : is-left-fibration (fst: Œª a ‚Üí x a Ôºù y a)
    lf = orthogonal‚Üêbase-change (point i0) pb pb-is-cart is-left
}
}

\subtree[tot-0556]{
\title{Contravariance of the family #{i \mapsto (i = 0)}}
\date{2026-06-22}
\taxon{Lemma}

\p{Assuming [quasicoherence](), or more specifically that every endomap on #{Œî^1} is
monotone, the family #{i \mapsto (i = 0)} is contravariant.}

\proof{
\p{We want to show the family #{{-} = 0} is orthogonal to #{\{1\} \to \Delta^1}. Since
this is a family of propositions it suffices to show that lifts merely exist. Then for
each #{\sigma : Œî^1 \to Œî^1} such that #{\sigma(1) = 0} we need to show that
#{\sigma(i) = 0} for each #{i}, but this follows from the fact that #{\sigma} is
monotone.
}
}

\agda{
contravariant-base-change
  : ‚àÄ {ùì§ ùì• ùì¶} {A : Type ùì§} {B : Type ùì•} {P : B ‚Üí Type ùì¶}
    ‚Üí (f : A ‚Üí B)
    ‚Üí is-contravariant P ‚Üí is-contravariant (P ‚àò f)
contravariant-base-change F Pc f x‚ÇÄ = Pc (F ‚àò f) x‚ÇÄ

module _ (phoa : Œî¬π-endos-are-mono) where

  ‚óè-unique-extensions : has-unique-extensions (point i1) (_Ôºù i0)
  ‚óè-unique-extensions (mk-afmap œÉ p) .centre .fst a
    = ‚â§-antisym (‚â§-trans (phoa œÉ auto!) (‚â§‚ÜêÔºù (p tt))) auto!
  ‚óè-unique-extensions (mk-afmap œÉ p) .centre .snd a = prop!
  ‚óè-unique-extensions F .central
    = Ext·µà-Subtype-is-prop
        (point i1)
        (mk-subtype {family = _Ôºù i0} Œª _ _ _ ‚Üí prop!)
        F _

  ‚óè-is-contravariant
    : ‚àÄ {ùì§} {A : Type ùì§} (f : A ‚Üí Œî¬π)
      ‚Üí is-contravariant ((_Ôºù i0) ‚àò f)
  ‚óè-is-contravariant f
    = contravariant-base-change {P = _Ôºù i0} f
        (is-right-family‚Üîis-contravariant (_Ôºù i0) .fst
          (are-orthogonal-fam‚Üêunique-extensions ‚óè-unique-extensions))
}
}

\subtree[stt-00OM]{
\title{Exponentiating covariant families}
\taxon{Lemma}

\p{We show that given a [contravariant type family](stt-00OD) #{F},
and a [covariant type family](stt-00AY) #{G}, the type family given by
#{x \mapsto F(x) \to G(x)} is also covariant.}

\proof{
\p{First notice that solutions to the left lifting problem are in bijection with
solutions to the right lifting problem.}

\quiver{
\begin{tikzcd}[cramped]
	{\{0\}} && {{G_x}^{F_x}} && {F_{f(0)}} && {G_x} \\
	\\
	{\Delta^1} && X && {\Sigma_{i} F_{f(i)}} && X
	\arrow["h", from=1-1, to=1-3]
	\arrow[from=1-1, to=3-1]
	\arrow[from=1-3, to=3-3]
	\arrow["h", from=1-5, to=1-7]
	\arrow["{(0, -)}"', from=1-5, to=3-5]
	\arrow[from=1-7, to=3-7]
	\arrow["f"', from=3-1, to=3-3]
	\arrow["{f\pi_1}"', from=3-5, to=3-7]
\end{tikzcd}
}

\p{Now we may see that the leftmost map of the second diagram is obtained
as the pullback of #{\{0\} \to \Delta^1} by the projection
#{\Sigma_{i} F_{f(i)} \to \Delta^1}. Hence we have a lifting problem where the
left map is a pullback of a left anodyne map by a right fibration and hence
is a left anodyne map. Since the right family is covariant by assumption, this
means solutions to the lifting problem exist uniquely.}
}

\remark{
\p{We have not yet formalised the fact that left-anodyne maps are stable under
base change by right fibrations.}
}


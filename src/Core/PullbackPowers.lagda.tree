\subtree[stt-004C]{
\title{Pullback power is a gap map}
\taxon{Theorem}

\p{The name pullback power comes from the fact that for any pair
of maps, we can define a square as follows:}

\quiver{
\begin{tikzcd}
	{C^B} && {C^A} \\
	\\
	{D^B} && {D^A}
	\arrow["{{-} \circ f}", from=1-1, to=1-3]
	\arrow["{g \circ {-}}"', from=1-1, to=3-1]
	\arrow["{g \circ {-}}", from=1-3, to=3-3]
	\arrow["{{-} \circ f}"', from=3-1, to=3-3]
\end{tikzcd}
}

\p{Then the gap map of this square is the [pullback power](stt-004D) in the
sense that the following triangle commutes.}

\quiver{
\begin{tikzcd}
	& {B \to C} \\
	\\
	{\Hom(f,g)} && {D^B\times_{D^A}C^A}
	\arrow["{\pullpow{f}{g}}"', from=1-2, to=3-1]
	\arrow["gap", from=1-2, to=3-3]
	\arrow["\sim"', from=3-1, to=3-3]
\end{tikzcd}
}

\agda{
module _ {ūĚď§ ūĚď• ūĚď¶ ūĚďú} {A : Type ūĚď§} {B : Type ūĚď•}
         {C : Type ūĚď¶} {D : Type ūĚďú} (f : A ‚Üí B)
         (g : C ‚Üí D)  where

  power-hom : Arrow-map (postcomp B g) (postcomp A g)
  power-hom .Arrow-map.top = precomp _ f
  power-hom .Arrow-map.bot = precomp _ f
  power-hom .Arrow-map.comm = ~refl

  pb-power-cone : Cone (mk-cospan (A ‚Üí D) (precomp _ f) (postcomp _ g)) (B ‚Üí C)
  pb-power-cone = snd (Cone‚ÜźArrow-map power-hom)

  pullback-gap~pullback-power :
    gap pb-power-cone ~ pullback‚Üźarrow' ‚ąė pullback-power f g
  pullback-gap~pullback-power f
    = pullback-path‚Üí (refl , refl , ‚ąô-refll _ ‚ąô funext-refl ‚ąô sym (‚ąô-reflr _))
}
}

\subtree[stt-004L]{
% \title{The pullback power is an equiv is a pullback}
\taxon{Corollary}

\p{For a pair of maps #{f} and #{g}, the following are equivalent:}
\ol{
\li{The [pullback power](stt-004D) of #{f} with #{g} is an equivalence}
\li{The square of \ref{stt-004C} is cartesian}
\li{The cone given by the pullback power is a pullback cone}
}

\agda{
module _
  {ūĚď§ ūĚď• ūĚď¶ ūĚďú}
  {A : Type ūĚď§} {B : Type ūĚď•} (f : A ‚Üí B)
  {C : Type ūĚď¶} {D : Type ūĚďú} (g : C ‚Üí D)
  where

  power-pb‚Üźpb-power-is-equiv
    : is-equiv (pullback-power f g)
    ‚Üí up-pullback _ (pb-power-cone f g)
  power-pb‚Üźpb-power-is-equiv pb-eq
    = up-pullback‚Üźis-pullback
        (pb-power-cone f g)
        (homotopy-is-equiv
          (pullback-gap~pullback-power f g h‚ĀĽ¬Ļ)
          (is-equiv-‚ąė (Arrow-map‚ČÉpullback' ._‚ČÉ_.fwd-is-equiv) pb-eq))

  pb-power-is-equiv‚Üźpower-pb
    : up-pullback _ (pb-power-cone f g)
    ‚Üí is-equiv (pullback-power f g)
  pb-power-is-equiv‚Üźpower-pb pb = 3-for-2~ (pullback-gap~pullback-power f g)
                                           (Arrow-map‚ČÉpullback' ._‚ČÉ_.fwd-is-equiv)
                                           (is-pullback‚Üźup-pullback _ pb)

  power-hom-cartesian‚Üźpullback-power
    : is-equiv (pullback-power f g)
    ‚Üí is-cartesian (power-hom f g)
  power-hom-cartesian‚Üźpullback-power ppeq
    = is-cartesian‚Üźup-pullback (power-hom f g) lem where
    lem : up-pullback _ (pb-power-cone f g)
    lem = power-pb‚Üźpb-power-is-equiv ppeq

  pullback-power‚Üźpower-hom-cartesian
    : is-cartesian (power-hom f g)
    ‚Üí is-equiv (pullback-power f g)
  pullback-power‚Üźpower-hom-cartesian pb = 3-for-2~ {f = pullback‚Üźarrow'}
                                     (pullback-gap~pullback-power f g)
                                     (Arrow-map‚ČÉpullback' ._‚ČÉ_.fwd-is-equiv)
                                     gap-is-equiv where
    gap-is-equiv : is-pullback (pb-power-cone f g)
    gap-is-equiv = is-pullback‚Üźup-pullback _ (up-pullback‚Üźis-cartesian _ pb)
}
}


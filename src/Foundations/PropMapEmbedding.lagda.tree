\agda{
is-embeddingвЖРis-prop-map
  : вИА {рЭУ§ рЭУ•} {A : Type рЭУ§} {B : Type рЭУ•} вЖТ {f : A вЖТ B}
    вЖТ is-prop-map f вЖТ is-embedding f
is-embeddingвЖРis-prop-map {f = f} pm {x} {y}
  = is-fibrewise-equivвЖРis-total-equiv {f = ќї y p вЖТ ap f {b = y} p}
                                      I y where
  I : is-equiv (ќї (a , b) вЖТ (a , ap f b))
  I = is-equivвЖРsingle-to-prop
         Sing-is-singleton
         (is-propвЖРequiv-to-prop (ќ£-ap-вЙГ ќї _ вЖТ symвЙГ) (pm (f x)))
         (total-map _)

fibre-single-at-valsвЖРis-embedding
  : вИА {рЭУ§ рЭУ•} {A : Type рЭУ§} {B : Type рЭУ•} {f : A вЖТ B}
    вЖТ is-embedding f вЖТ вИА a вЖТ is-singleton (fibre f (f a))
fibre-single-at-valsвЖРis-embedding {f = f} emb a
  = is-singleвЖРequiv-to-single (ќ£-ap-вЙГ (ќї aвВБ вЖТ mkвЙГ _ emb)) Sing'-is-singleton

is-prop-mapвЖРis-embedding
  : вИА {рЭУ§ рЭУ•} {A : Type рЭУ§} {B : Type рЭУ•} {f : A вЖТ B}
    вЖТ is-embedding f вЖТ is-prop-map f
is-prop-mapвЖРis-embedding femb b = is-propвЖРis-single-if-inhabited
  ќї where (a , refl) вЖТ fibre-single-at-valsвЖРis-embedding femb a

\subtree[tot-0003]{
\title{Detexting Connectivity}
\taxon{Definition}


\p{We say that a family #{G} \em{detects connectivity} if the  [#{\flat} discrete
types](tot-0002) are exactly the #{G}-null types.}

%```agda
\agda{
detects-connectivity : έΙΑ {ΏζΥα ΏζΥν} {I : Type ΏζΥα} (G : I έΗΤ Type ΏζΥν) έΗΤ Type╧Κ
detects-connectivity G
  = έΙΑ {@έβφ ΏζΥν} {@έβφ X : Type ΏζΥν} έΗΤ is-null G X έΘΦ is-έβφ-discrete X
}
%```

\p{If #{G} detects connectivitiym then nullification at #{G} gives a modality
#{\int} which is a left adjoint to #{\flat} \citet{9.15}{shulman-2017}}

%```agda
\agda{
έβφ-map-is-equiv
  : έΙΑ {@έβφ ΏζΥν ΏζΥξ} {@έβφ A : Type ΏζΥν} {@έβφ B : Type ΏζΥξ} (@έβφ f : A έΗΤ B)
    έΗΤ @έβφ is-equiv f έΗΤ is-equiv (έβφ-map f)
έβφ-map-is-equiv f fe = is-equivέΗΡqiso
  ( έβφ-map bwd
  , (╬╗ {(modέβφ x) έΗΤ apέβφ modέβφ (╬╖ x)})
  , ╬╗ {(modέβφ x) έΗΤ apέβφ modέβφ (╬╡ x)}) where
  open is-equiv fe

lemma : έΙΑ {@έβφ ΏζΥν ΏζΥξ}  {@έβφ A : Type ΏζΥν} {@έβφ B : Type ΏζΥξ}
        έΗΤ is-έβφ-discrete A
        έΗΤ is-equiv {A = έθρέβφ| (A έΗΤ έθρέβφ| B έθσ) έθσ} (έβφ-map (precomp _ ╬╡έβφ))
lemma = {!!}

module έΙτ {@έβφ ΏζΥα ΏζΥν} {@έβφ I : Type ΏζΥα} (@έβφ G : I έΗΤ Type ΏζΥν)
         (@έβφ Gconn : detects-connectivity G)
         where
  private
    έΙτ-GSU : GSU ((ΏζΥν έΛΦ ΏζΥα) έΛΦ_)
    έΙτ-GSU = Null-GSU G

  open GSU έΙτ-GSU public
  -- open GRSUInduction ?
  --                    Null-globally-╬μ-closed public


  open is-globally-reflective (Null-globally-reflective {A = G})
    public renaming (έΩΜ to έΙτ; έΩΜέΙΙS to έΙτέΙΙS)

  έΙτ-is-discrete
    : έΙΑ {@έβφ ΏζΥν} {@έβφ A : Type ΏζΥν} έΗΤ is-έβφ-discrete (έΙτ A)
  έΙτ-is-discrete = Gconn .fst έΙτέΙΙS

  έΙτ-discrete-reflection
    : έΙΑ {ΏζΥν} {@έβφ ΏζΥξ} {A : Type ΏζΥν} {@έβφ B : Type ΏζΥξ} έΗΤ is-έβφ-discrete B
      έΗΤ is-equiv {A = έΙτ A έΗΤ B} (_έΙα ╬╖)
  έΙτ-discrete-reflection bd = reflects (Gconn .snd bd)

  έΙτ-discrete-rec
    : έΙΑ {ΏζΥν} {@έβφ ΏζΥξ} {A : Type ΏζΥν} {@έβφ B : Type ΏζΥξ} έΗΤ is-έβφ-discrete B
      έΗΤ (A έΗΤ B) έΗΤ (έΙτ A έΗΤ B)
  έΙτ-discrete-rec bd = is-equiv.bwd (έΙτ-discrete-reflection bd)

  έΙτέΛμέβφ-╧Χ : έΙΑ {@έβφ ΏζΥν ΏζΥξ}  {@έβφ A : Type ΏζΥν} {@έβφ B : Type ΏζΥξ}
        έΗΤ έθρέβφ| (A έΗΤ έθρέβφ| B έθσ) έθσ έΗΤ έθρέβφ| (έΙτ A έΗΤ B) έθσ
  έΙτέΛμέβφ-╧Χ = έβφ-map (precomp _ ╬╡έβφ) έΙα έβφ-map (έΙτ-discrete-rec έβφ-is-έβφ-discrete)

  έΙτέΛμέβφ : έΙΑ {@έβφ ΏζΥν ΏζΥξ}  {@έβφ A : Type ΏζΥν} {@έβφ B : Type ΏζΥξ}
        έΗΤ έθρέβφ| (A έΗΤ έθρέβφ| B έθσ) έθσ έΚΔ έθρέβφ| (έΙτ A έΗΤ B) έθσ
  έΙτέΛμέβφ = mkέΚΔ (έΙτέΛμέβφ-╧Χ)
    (is-equiv-έΙα
      (lemma έΙτ-is-discrete)
      (έβφ-map-is-equiv _ (is-equivέΒ╗┬╣ (έΙτ-discrete-reflection έβφ-is-έβφ-discrete))))
}

\subtree[tot-AA01]{
\title{The data of a covariant fibration over #{Δ^2}}
\taxon{Definition}

\agda{
Cov-Δ²-bundle
  : ∀ {𝓤} (B : Type 𝓤) 𝓥 → Type (𝓘 ⊔ 𝓤 ⊔ lsuc 𝓥)
Cov-Δ²-bundle B 𝓥
  = Σ[ X Y Z ∶ Σ (B → Type 𝓥) is-covariant ]
    ((fibrewise-map (Y .fst) (Z .fst)) × (fibrewise-map (X .fst) (Y .fst)))
}

\agda{
Cov-Δ²-bundle'
  : ∀ {𝓤} (B : Type 𝓤) 𝓥 → Type (𝓘 ⊔ 𝓤 ⊔ lsuc 𝓥)
Cov-Δ²-bundle' B 𝓥
  = Σ[ X Y Y' Z ∶ Σ (B → Type 𝓥) is-covariant ]
    Σ[ e ∶ (∀ b → Y .fst b ≃ Y' .fst b) ]
    ((fibrewise-map (Y' .fst) (Z .fst)) × (fibrewise-map (X .fst) (Y .fst)))

Cov-Δ²-bundle-coh
  : ∀ {𝓤 𝓥} {B : Type 𝓤} → Cov-Δ²-bundle' B 𝓥 → Cov-Δ²-bundle B 𝓥
Cov-Δ²-bundle-coh (X , Y , Y' , Z , e , f , g)
  = ( X
    , Y
    , Z
    , (λ b → f b ∘ e b ._≃_.fwd)
    , g)

Cov-Δ²-bundle-decoh
  : ∀ {𝓤 𝓥} {B : Type 𝓤} → Cov-Δ²-bundle B 𝓥 → Cov-Δ²-bundle' B 𝓥
Cov-Δ²-bundle-decoh (A , B , C , f , g)
  = ( A
    , B
    , B
    , C
    , (λ _ → id≃)
    , f
    , g)
}
}

\subtree[tot-A002]{
\title{Characterising the identity type of a covariant bundle over #{Δ^2}}
\taxon{Lemma}

\agda{
cov-Δ²-bundle-Id
  : ∀ {𝓤 𝓥} {B : Type 𝓤} (x y : Cov-Δ²-bundle B 𝓥)
    → Type (𝓤 ⊔ 𝓥)
cov-Δ²-bundle-Id
  ((A , _) , (B , _) , (C , _) , f , g)
  ((X , _) , (Y , _) , (Z , _) , α , β)
  = Σ[ e ∶ (∀ a → A a ≃ X a)] Σ[ j ∶ (∀ b → B b ≃ Y b)] Σ[ k ∶ (∀ c → C c ≃ Z c)]
     ( (∀ x → k x ._≃_.fwd ∘ f x ~ α x ∘ j x ._≃_.fwd)
     × (∀ x → j x ._≃_.fwd ∘ g x ~ β x ∘ e x ._≃_.fwd))


cov-Δ²-bundle'-Id
  : ∀ {𝓤 𝓥} {B : Type 𝓤} (x y : Cov-Δ²-bundle' B 𝓥)
    → Type (𝓤 ⊔ 𝓥)
cov-Δ²-bundle'-Id
  ((A , _) , (B , _) , (B' , _) , (C , _) , H , f , g)
  ((X , _) , (Y , _) , (Y' , _) , (Z , _) , K , α , β)
  = Σ[ e ∶ (∀ a → A a ≃ X a)]
    Σ[ j ∶ (∀ b → B b ≃ Y b)]
    Σ[ l ∶ (∀ b → B' b ≃ Y' b) ]
    Σ[ k ∶ (∀ c → C c ≃ Z c)]
     ( (∀ x → l x ._≃_.fwd ∘ H x ._≃_.fwd ~ K x ._≃_.fwd ∘ j x ._≃_.fwd)
     × (∀ x → k x ._≃_.fwd ∘ f x ~ α x ∘ l x ._≃_.fwd)
     × (∀ x → j x ._≃_.fwd ∘ g x ~ β x ∘ e x ._≃_.fwd))

cov-Δ²-bundle-Id-refl
  : ∀ {𝓤 𝓥} {B : Type 𝓤} (x : Cov-Δ²-bundle B 𝓥)
    → cov-Δ²-bundle-Id x x
cov-Δ²-bundle-Id-refl x
  = ( (λ _ → id≃)
    , (λ _ → id≃)
    , (λ _ → id≃)
    , (λ _ → ~refl)
    , (λ _ → ~refl))

opaque
  cov-Δ²-bundle-Id-is-torsorial
    : ∀ {𝓤 𝓥} {B : Type 𝓤} (x : Cov-Δ²-bundle B 𝓥)
      → is-singleton (Σ _ (cov-Δ²-bundle-Id x))
  cov-Δ²-bundle-Id-is-torsorial (A , B , C , f , g)
    = is-singleton-structure←parts
        (SingS-is-single A)
        (A , (λ _ → id≃))
        (is-singleton-structure←parts
          (SingS-is-single B)
          (B , (λ _ → id≃))
          (is-singleton-structure←parts
            (SingS-is-single C)
            (C , (λ _ → id≃))
            (is-singleton-structure←parts
              (SingS-is-single f)
              (f , (λ _ → ~refl))
              (SingS-is-single g))))

cov-Δ²-bundle-Id←Arrow-equivs
  : ∀ {𝓤 𝓥} {B : Type 𝓤} (x y : Cov-Δ²-bundle B 𝓥)
      (F : ∀ b → Arrow-equiv (x .snd .snd .snd .fst b) (y .snd .snd .snd .fst b))
      (G : ∀ b → Arrow-equiv (x .snd .snd .snd .snd b) (y .snd .snd .snd .snd b))
      (h : ∀ b → F b .fst .Arrow-map.top ~ G b .fst .Arrow-map.bot)
    → cov-Δ²-bundle-Id x y
cov-Δ²-bundle-Id←Arrow-equivs x y F G H .fst b
  = mk≃ (G b .fst .Arrow-map.top) (G b .snd .fst)
cov-Δ²-bundle-Id←Arrow-equivs x y F G H .snd .fst b
  = mk≃ (G b .fst .Arrow-map.bot) (G b .snd .snd)
cov-Δ²-bundle-Id←Arrow-equivs x y F G H .snd .snd .fst b
  = mk≃ (F b .fst .Arrow-map.bot) (F b .snd .snd)
cov-Δ²-bundle-Id←Arrow-equivs x y F G H .snd .snd .snd .fst b
  = F b .fst .Arrow-map.comm ∙h (y .snd .snd .snd .fst b ◂ H b)
cov-Δ²-bundle-Id←Arrow-equivs x y F G H .snd .snd .snd .snd b
  = G b .fst .Arrow-map.comm

instance
  cov-Δ²-bundle-IdS
    : ∀ {𝓤 𝓥} {B : Type 𝓤} → Identity-system (Cov-Δ²-bundle B 𝓥) (𝓤 ⊔ 𝓥)
  cov-Δ²-bundle-IdS .Identity-system.IdS = cov-Δ²-bundle-Id
  cov-Δ²-bundle-IdS .Identity-system.IdS←Id {x} refl = cov-Δ²-bundle-Id-refl x
  cov-Δ²-bundle-IdS .Identity-system.IdS←Id-is-equiv x
    = fundamental-Id _ (cov-Δ²-bundle-Id-is-torsorial x) _
}
}

\subtree[tot-R007]{
\title{The induced transport of a covariant family over #{Δ²}}
\taxon{Construction}

\p{Given a covariant type family over #{B \times \Delta^2}, we can construct a
[covariant bundle over #{Δ^2}](tot-A002).}

\agda{
tr²Σ' : ∀ {𝓤 𝓥} {B : Type 𝓤}
      → (Σ (B × Δ² → Type 𝓥) is-covariant)
      → Cov-Δ²-bundle' B 𝓥
tr²Σ' (F , Fcov)
  = ( (F ∘ (_, δ₂² i0) , covariant-base-change {P = F} (_, δ₂² i0) Fcov)
    , (F ∘ (_, δ₂² i1) , covariant-base-change {P = F} (_, δ₂² i1) Fcov)
    , (F ∘ (_, δ₀² i0) , covariant-base-change {P = F} (_, δ₀² i0) Fcov)
    , (F ∘ (_, δ₀² i1) , covariant-base-change {P = F} (_, δ₀² i1) Fcov)
    , (λ b → tr≃ (F ∘ (b ,_)) Δ²-refl)
    , (λ b → tr-cov {P = F ∘ (b ,_)} (covariant-base-change {P = F} (b ,_) Fcov) δ₀²)
    , (λ b → tr-cov {P = F ∘ (b ,_)} (covariant-base-change {P = F} (b ,_) Fcov) δ₂²))

Δ²-point-incl : Fin 3 → Δ²
Δ²-point-incl fzero = (i0 , i0)
Δ²-point-incl (fsuc fzero) = (i1 , i0)
Δ²-point-incl (fsuc (fsuc x)) = (i1 , i1)

Δ¹-point-incl : Fin 2 → Δ¹
Δ¹-point-incl fzero = i0
Δ¹-point-incl (fsuc fzero) = i1

instance
  Number-Δ¹ : Number Δ¹
  Number-Δ¹ .Number.Constraint m = m <ℕ 2
  Number-Δ¹ .Number.fromNat n = Δ¹-point-incl (Fin←ℕ n 2 auto!)

instance
  Number-Δ² : Number Δ²
  Number-Δ² .Number.Constraint m = m <ℕ 3
  Number-Δ² .Number.fromNat n = Δ²-point-incl (Fin←ℕ n 3 auto!)

Δ²-0≤1 : Hom Δ² 0 1
Δ²-0≤1 .Homᵈ.hom i = (i , 0)
Δ²-0≤1 .Homᵈ.hom0 = refl
Δ²-0≤1 .Homᵈ.hom1 = refl

Δ²-1≤2 : Hom Δ² 1 2
Δ²-1≤2 .Homᵈ.hom i = (i1 , i)
Δ²-1≤2 .Homᵈ.hom0  = Δ²-refl
Δ²-1≤2 .Homᵈ.hom1  = Δ²-refl

tr-Δ²-0≤1-lemma
  : ∀ {𝓤} (F : Δ² → Type 𝓤) (Fc : is-covariant F)
    → Arrow-equiv
        (tr-cov-hom {P = F} Fc Δ²-0≤1)
        (tr-cov-hom {P = (F ∘ δ₂²)}
          (covariant-base-change {P = F} δ₂² Fc)
          0≤1)
tr-Δ²-0≤1-lemma F Fc .fst .Arrow-Π.top = id
tr-Δ²-0≤1-lemma F Fc .fst .Arrow-Π.bot = id
tr-Δ²-0≤1-lemma F Fc .fst .Arrow-Π.comm a
  = tr-cov-hom-unique
      F Fc Δ²-0≤1 a
      (tr-cov-hom {P = F ∘ δ₂²} (covariant-base-change {P = F} δ₂² Fc) 0≤1 a)
      (tr-cov-over {P = F ∘ δ₂²} (covariant-base-change {P = F} δ₂² Fc) 0≤1 a)
tr-Δ²-0≤1-lemma F Fc .snd = (id-is-equiv , id-is-equiv)

tr-Δ²-1≤2-lemma
  : ∀ {𝓤} (F : Δ² → Type 𝓤) (Fc : is-covariant F)
    → Arrow-equiv
        (tr-cov-hom {P = F} Fc Δ²-1≤2)
        (tr-cov-hom {P = (F ∘ δ₀²)}
          (covariant-base-change {P = F} δ₀² Fc)
          0≤1)
tr-Δ²-1≤2-lemma F Fc .fst .Arrow-Π.top = tr F Δ²-refl
tr-Δ²-1≤2-lemma F Fc .fst .Arrow-Π.bot = tr F Δ²-refl
tr-Δ²-1≤2-lemma F Fc .fst .Arrow-Π.comm a
  = sym
     (tr-cov-hom-unique
       (F ∘ δ₀²)
       (covariant-base-change {P = F} δ₀² Fc)
       0≤1
       (tr F Δ²-refl a)
       (tr F Δ²-refl (tr-cov-hom {P = F} Fc Δ²-1≤2 a))
       (adjust-homᵈ (F ∘ δ₀²)
         (ap (λ p → tr F p a) (Δ²-is-set _ _ _  _))
         (ap (λ p → tr F p (tr-cov-hom {P = F} Fc Δ²-1≤2 a)) (Δ²-is-set _ _ _ _))
         (tr-cov-over {P = F} Fc Δ²-1≤2 a)))
tr-Δ²-1≤2-lemma F Fc .snd = (tr-is-equiv Δ²-refl , tr-is-equiv Δ²-refl)

tr²Σ : ∀ {𝓤 𝓥} {B : Type 𝓤}
      → (Σ (B × Δ² → Type 𝓥) is-covariant)
      → Cov-Δ²-bundle B 𝓥
tr²Σ (F , Fcov)
  = ( (F ∘ (_, 0) , covariant-base-change {P = F} (_, 0) Fcov)
    , (F ∘ (_, 1) , covariant-base-change {P = F} (_, 1) Fcov)
    , (F ∘ (_, 2) , covariant-base-change {P = F} (_, 2) Fcov)
    , (λ b → tr-cov-hom {P = F ∘ (b ,_)} (covariant-base-change {P = F} (b ,_) Fcov) Δ²-1≤2)
    , (λ b → tr-cov-hom {P = F ∘ (b ,_)} (covariant-base-change {P = F} (b ,_) Fcov) Δ²-0≤1))
}
}

\subtree[tot-R002]{
\title{The gluing of a composable pair of maps}


\agda{
module HornGluing
  {𝓤 𝓥} {B : Type 𝓤}
  (X Y Z : B → Type (𝓘 ⊔ 𝓥)) (β : ∀ b → Y b → Z b) (α : ∀ b → X b → Y b)
  where

  fibre-map : ∀ i → fibrewise-map (Gl X Y α ∘ (_, i)) Z
  fibre-map i b = β b ∘ fst

  fibre-map-at-1 : ∀ b → Arrow-equiv (fibre-map i1 b) (β b)
  fibre-map-at-1 b .fst .Arrow-Π.top = fst
  fibre-map-at-1 b .fst .Arrow-Π.bot = id
  fibre-map-at-1 b .fst .Arrow-Π.comm = ~refl
  fibre-map-at-1 b .snd .fst = Gl-1-is-equiv X Y α b
  fibre-map-at-1 b .snd .snd = id-is-equiv

  fibre-map-at-0 : ∀ b → Arrow-equiv (fibre-map i0 b) (β b ∘ α b)
  fibre-map-at-0 b .fst .Arrow-Π.top = Gl-0 X Y α b
  fibre-map-at-0 b .fst .Arrow-Π.bot = id
  fibre-map-at-0 b .fst .Arrow-Π.comm (y , p) = ap (β b) (sym (p refl .snd))
  fibre-map-at-0 b .snd .fst = Gl-0-is-equiv X Y α b
  fibre-map-at-0 b .snd .snd = id-is-equiv

  Gl² : B × Δ² → Type (𝓘 ⊔ 𝓥)
  Gl² (b , (i , j)) = Gl (λ b' → Gl X Y α (b' , i)) Z (fibre-map i) (b , j)

  Gl²' : (B × Δ¹) × Δ¹ → Type (𝓘 ⊔ 𝓥)
  Gl²' = Gl (Gl X Y α) (Z ∘ fst) (uncurry fibre-map ∘ ×-swap→)

  Gl²-as-base-change : Gl² ~ Gl²' ∘ _≃_.bwd ×-assoc ∘ (id ⊗ □←Δ²-upper)
  Gl²-as-base-change = ~refl

  Gl²-0 : fibrewise-map (Gl² ∘ (_, δ₂² i0)) X
  Gl²-0 b = Gl-0 X Y α b ∘ Gl-0 _ Z (fibre-map i0) b

  Gl²-0-is-equiv
    : is-fibrewise-equiv Gl²-0
  Gl²-0-is-equiv b
    = is-equiv-∘ (Gl-0-is-equiv X Y α b) (Gl-0-is-equiv _ Z (fibre-map i0) b)

  Gl²-1 : fibrewise-map (Gl² ∘ (_, δ₂² i1)) Y
  Gl²-1 b = Gl-1 X Y α b ∘ Gl-0 _ Z (fibre-map i1) b

  Gl²-1-is-equiv
    : is-fibrewise-equiv Gl²-1
  Gl²-1-is-equiv b
    = is-equiv-∘ (Gl-1-is-equiv X Y α b) (Gl-0-is-equiv _ Z (fibre-map i1) b)

  Gl²-1' : fibrewise-map (Gl² ∘ (_, δ₀² i0)) Y
  Gl²-1' = Gl²-1

  Gl²-2 : fibrewise-map (Gl² ∘ (_, δ₀² i1)) Z
  Gl²-2 = Gl-1 _ Z _

  Gl²-2-is-equiv : is-fibrewise-equiv Gl²-2
  Gl²-2-is-equiv = Gl-1-is-equiv _ Z _

  tr-Gl²-refl
    : ∀ {i j} {p q : j ≤ i} b → tr (Gl² ∘ (b ,_)) (Δ²-refl {p = p}{q}) ~ id
  tr-Gl²-refl b x = tr∘ (Gl²' ∘ _≃_.bwd ×-assoc ∘ (b ,_)) □←Δ²-upper Δ²-refl
                  ∙ sym (tr-refl _ x prop!)
}
}

\subtree[tot-R003]{
\title{Covariance of directed horn glueing}
\taxon{Lemma}

\proof{
The directed horn glueing family arrises as a base-change of a directed gluing of
covariant families, which by \ref{tot-L003} is covariant.
}

\agda{
module Gl²-cov
  {𝓤 𝓥} {B : Type 𝓤}
  (X Y Z : B → Type (𝓘 ⊔ 𝓥)) (β : ∀ b → Y b → Z b) (α : ∀ b → X b → Y b)
  where
  open HornGluing {𝓤} {𝓥} X Y Z β α

  Gl²'-is-covariant
    : is-covariant X → is-covariant Y → is-covariant Z
    → is-covariant Gl²'
  Gl²'-is-covariant Xc Yc Zc
    = Gl-is-covariant
        (Gl X Y α)
        (Z ∘ fst)
        (uncurry fibre-map ∘ ×-swap→)
        (Gl-is-covariant X Y α Xc Yc)
        (covariant-base-change {P = Z} fst Zc)

  Gl²-is-covariant
    : is-covariant X → is-covariant Y → is-covariant Z
    → is-covariant Gl²
  Gl²-is-covariant Xc Yc Zc
    = covariant-base-change
        {P = Gl²'}
        (_≃_.bwd ×-assoc ∘ (id ⊗ □←Δ²-upper))
        (Gl²'-is-covariant Xc Yc Zc)

  Gl²∘-is-covariant
    : is-covariant X → is-covariant Y → is-covariant Z
    → ∀ {𝓧} {A : Type 𝓧} (f : A → B × Δ²)
      → is-covariant (Gl² ∘ f)
  Gl²∘-is-covariant Xc Yc Zc f
    = covariant-base-change
        {P = Gl²}
        f
        (Gl²-is-covariant Xc Yc Zc)
}
}


\subtree[tot-L034]{
\title{Directed #{\Delta^2} univalence for covariant families}
\taxon{Theorem}

\p{The map defined in \ref{tot-R007} induces an equivalence between covariant
families over #{B \times \Delta^2} and the type consisting of a tripple of covariant
families over #{B} and fibrewise maps between them.}

\agda{
module _
  {𝓤 𝓥} {B : Type 𝓤}
  where
  open Gl²-cov {𝓤} {𝓥}

  tr²Σ-inv
    : Cov-Δ²-bundle B (𝓥 ⊔ 𝓘)
    → (Σ (B × Δ² → Type (𝓥 ⊔ 𝓘)) is-covariant)
  tr²Σ-inv ((A , Ac) , (B , Bc) , (C , Cc) , β , α)
    = (HornGluing.Gl² {𝓤} {𝓥} A B C β α , Gl²-is-covariant A B C β α Ac Bc Cc)
}


\agda{
module _
  {𝓤 𝓥} {B : Type 𝓤} (c@((X , Xc) , (Y , Yc) , (Z , Zc) , f , g) : Cov-Δ²-bundle B (𝓘 ⊔ 𝓥))
  where
  open HornGluing {𝓤} {𝓥} X Y Z f g
  open Gl²-cov {𝓤} {𝓥} X Y Z f g

  tr-Gl²-0≤1
    : ∀ b
      → Arrow-equiv
        (tr-cov-hom
          {P = Gl² ∘ (b ,_)}
          (Gl²∘-is-covariant Xc Yc Zc (b ,_))
          Δ²-0≤1)
        (g b)
  tr-Gl²-0≤1 b
    = tr-cov-hom (Gl²∘-is-covariant Xc Yc Zc (b ,_)) Δ²-0≤1

    Arr≃⟨ tr-Δ²-0≤1-lemma (Gl² ∘ (b ,_)) (Gl²∘-is-covariant Xc Yc Zc (b ,_)) ⟩

     tr-cov-hom (Gl²∘-is-covariant Xc Yc Zc λ i → (b , δ₂² i)) 0≤1

    Arr≃⟨ adjust-tr-cov-hom
           (Gl²∘-is-covariant Xc Yc Zc (λ i → b , δ₂² i))
           (Gl∘-is-covariant (b ,_) X Y g Xc Yc)
           (Gl-0 (Gl X Y g ∘ (b ,_)) (const (Z b)) (λ i → fibre-map i b))
           (Gl-0-is-equiv (Gl X Y g ∘ (b ,_)) (const (Z b)) (λ i → fibre-map i b))
           0≤1 ⟩

     tr-cov-hom (Gl∘-is-covariant (b ,_) X Y g Xc Yc) 0≤1

   Arr≃⟨ tr-Gl-0≤1H {𝓤} {𝓥} g Xc Yc b ⟩

     g b Arr≃∎

  lemma2
    : ∀ {𝓤 𝓥 𝓦} {X : Type 𝓤} {Y : Type 𝓥} (f : X → Y)
        (F : Y → Type 𝓦) (Fc : is-covariant F)
        (Ffc : is-covariant (F ∘ f))
        (h : covariant-base-change {P = F} f Fc ＝ Ffc)
        {a b : X}
        (h : Hom X a b)
        (g : Hom Y (f a) (f b))
        (p : g ＝ ap-hom f h)
      → tr-cov-hom {P = F} Fc g
      ~ tr-cov-hom {P = F ∘ f} Ffc h
  lemma2 f F Fc Ffc refl h _ refl x = tr-cov-hom-unique F Fc (ap-hom f h) x
    (tr-cov-hom (covariant-base-change {P = F} f Fc) h x)
    (adjust-homᵈ (F ∘ f ∘ h .Homᵈ.hom)
      (ap (λ p → coe p x) (ap-∘ F f _ ∙ ap (ap F) (ap-sym f (h .Homᵈ.hom0))))
      (ap (λ p → coe p _) (ap-∘ F f _ ∙ ap (ap F) (ap-sym f (h .Homᵈ.hom1))))
      (tr-cov-over (covariant-base-change {P = F} f Fc) h x) )

  opaque
    unfolding tr-cov-hom
    tr-Gl²-1≤2
      : ∀ b
        → Arrow-equiv
            (tr-cov-hom
                {P = Gl² ∘ (b ,_)}
                (Gl²∘-is-covariant Xc Yc Zc (b ,_))
                Δ²-1≤2)
            (f b)
    tr-Gl²-1≤2 b
      = tr-cov-hom (Gl²∘-is-covariant Xc Yc Zc (b ,_)) Δ²-1≤2

      Arr≃⟨ tr-Δ²-1≤2-lemma (Gl² ∘ (b ,_)) (Gl²∘-is-covariant Xc Yc Zc (b ,_)) ⟩

        tr-cov-hom {P = Gl² ∘ (λ i → b , δ₀² i)}
          (Gl²∘-is-covariant Xc Yc Zc λ i → b , δ₀² i) 0≤1

      Arr≃⟨ adjust-tr-cov-hom
              {F = Gl² ∘ (λ i → b , δ₀² i)}
              (Gl²∘-is-covariant Xc Yc Zc λ i → b , δ₀² i)
              (Gl∘-is-covariant (b ,_) (Gl X Y g ∘ (_, i1)) Z (fibre-map i1)
                (Gl∘-is-covariant (_, i1) X Y g Xc Yc) Zc)
              (λ _ → id) (λ _ → id-is-equiv) 0≤1 ⟩

        tr-cov-hom
          {P = Gl (Gl X Y g ∘ (_, i1)) Z (fibre-map i1) ∘ (b ,_)}
          (Gl∘-is-covariant (b ,_) (Gl X Y g ∘ (_, i1)) Z (fibre-map i1)
            (Gl∘-is-covariant (_, i1) X Y g Xc Yc) Zc)
          0≤1

      Arr≃⟨  tr-Gl-0≤1H {𝓤} {𝓥}
              (fibre-map i1)
              (Gl∘-is-covariant (_, i1) X Y g Xc Yc) Zc b  ⟩

        f b ∘ Gl-1 X Y g b

      Arr≃⟨ (  mk-amap (Gl-1 X Y g b) id ~refl
            , (Gl-1-is-equiv X Y g b , id-is-equiv)) ⟩

        f b Arr≃∎

    tr-Gl²-1~
      : ∀ b → tr-Gl²-1≤2 b .fst .Arrow-map.top ~ tr-Gl²-0≤1 b .fst .Arrow-map.bot
    tr-Gl²-1~ b = Gl²-1 b ◂ tr-Gl²-refl b

    tr²Σ-section
      : cov-Δ²-bundle-Id {𝓤} {𝓘 ⊔ 𝓥} {B} (tr²Σ (tr²Σ-inv {𝓤} {𝓥} c)) c
    tr²Σ-section
      = cov-Δ²-bundle-Id←Arrow-equivs
          (tr²Σ (tr²Σ-inv {𝓤} {𝓥} c))
          c
          tr-Gl²-1≤2
          tr-Gl²-0≤1
          tr-Gl²-1~
}

\agda{
Δ²-top : ∀ x {p} → Hom Δ² x ((i1 , i1) ⦃ p ⦄)
Δ²-top (i , j) .Homᵈ.hom k = (i ∨ k , j ∨ k)
Δ²-top x .Homᵈ.hom0 = Δ²-ext (0-bottom , 0-bottom)
Δ²-top x .Homᵈ.hom1 = Δ²-ext (1-coinit , 1-coinit)

Δ²-top-is-id : ∀ p → Δ²-top ((i1 , i1) ⦃ p ⦄) ＝ idH ((i1 , i1) ⦃ p ⦄)
Δ²-top-is-id p = Hom-ext→
  ( (λ i → Δ²-ext ((∨-comm ∙ 1-coinit) , ∨-comm ∙ 1-coinit) )
  , Δ²-is-set _ _ _ _
  , Δ²-is-set _ _ _ _)

Δ²-hom←≤ : ∀ x y → (x I[x].≤ y) → Hom Δ² x y
Δ²-hom←≤ x y p = mk-hom (λ i → (x I[x].∨ ι-const i) I[x].∧ (x I[x].∨ y))
  {!!} {!!}

module _
  {𝓤 𝓥} {B : Type 𝓤}
  (FF@(F , Fc) : Σ (B × Δ² → Type (𝓘 ⊔ 𝓥)) is-covariant)
  (let Fbc b = covariant-base-change {P = F} (b ,_) Fc)
  where
  open HornGluing {𝓤} {𝓥}
         (F ∘ (_, 0)) (F ∘ (_, 1)) (F ∘ (_, 2))
         (λ b → tr-cov-hom {P = F ∘ (b ,_)} (Fbc b) Δ²-1≤2)
         (λ b → tr-cov-hom {P = F ∘ (b ,_)} (Fbc b) Δ²-0≤1)

  opaque
    unfolding tr-cov-hom
    Gl²←cov-fam
      : ∀ (b : B × Δ²)
        → F b → Gl² b
    Gl²←cov-fam (b , ij) x .fst
      = tr-cov-hom {P = F ∘ (b ,_)} (Fbc b) (Δ²-top ij) x
    Gl²←cov-fam (b , (i , i0)) x .snd refl .fst
      = Gl←cov-fam {𝓤} {𝓥}
          ( (λ (b , i) → F (b , (i , i0)))
          , covariant-base-change {P = F} (id ⊗ (_, i0)) Fc)
          (b , i)
          (tr F (ap (b ,_) Δ²-refl) x)
    Gl²←cov-fam (b , (i , i0)) x .snd refl .snd
      = (tr-cov-hom {P = F ∘ (b ,_)} (Fbc b) Δ²-1≤2
             (tr-cov-hom {P = F ∘ (λ i → b , (i , i0))}
                (covariant-base-change {P = F} (λ i → b , (i , i0)) Fc)
                (Δ¹-hom←≤ 1-top)
                (tr F (ap (b ,_) Δ²-refl) x)))
      ＝⟨ {!!} ⟩
          (tr-cov-hom {P = F ∘ (b ,_)} (Fbc b) Δ²-1≤2
             (tr-cov-hom {P = F ∘ (b ,_)}
                (Fbc b)
                (Δ²-hom←≤ ((i , i0) ⦃ 0-init ⦄) 1 (Δ²-ext (1-top , ≤-refl)))
                (tr F (ap (b ,_) Δ²-refl) x)))
      ＝⟨ {!!} ⟩
        (tr-cov-hom {P = F ∘ (b ,_)} (Fbc b) (Δ²-top (i , i0))
                (tr F (ap (b ,_) Δ²-refl) x))
      ＝⟨ ap (tr-cov-hom {P = F ∘ (b ,_)} (Fbc b) (Δ²-top (i , i0)))
             (sym (tr-refl (ap (b ,_) Δ²-refl) x (ap (ap (b ,_)) (Δ²-is-set _ _ _ _)))) ⟩
          Gl²←cov-fam (b , (i , i0)) x .fst
      ∎

    Gl²←cov-fam-is-equiv-at-0
      : ∀ b → is-equiv (Gl²←cov-fam (b , 0))
    Gl²←cov-fam-is-equiv-at-0 b
      = 3-for-2
          (Gl²-0-is-equiv b)
          (tr-is-equiv (ap (b ,_) (Δ²-ext (refl , refl))))

    Gl²←cov-fam-is-equiv-at-1
      : ∀ b → is-equiv (Gl²←cov-fam (b , 1))
    Gl²←cov-fam-is-equiv-at-1 b
      = 3-for-2~
          (λ x
           → sym
              ( tr-cov-idH~
                 (F ∘ (λ a → (b , (a , i0))))
                 (λ f → Fc (λ a → b , (f a , i0)))
                 (Δ¹-hom←≤ 1-top)
                 (Δ¹-hom-≤-refl 1-top)
                 (x) )
              ∙ ap (tr-cov-hom (λ f → Fc (λ a → b , (f a , i0))) (Δ¹-hom←≤ 1-top))
                   (tr-refl
                     (ap (b ,_) (Δ²-ext (refl , refl)))
                     x
                     (ap (ap (b ,_)) (Δ²-is-set _ _ _ _))))
          (Gl²-1-is-equiv b)
          id-is-equiv

    Gl²←cov-fam-is-equiv-at-2
      : ∀ b → is-equiv (Gl²←cov-fam (b , 2))
    Gl²←cov-fam-is-equiv-at-2 b
      = 3-for-2~
          (tr-cov-idH~
            (F ∘ (b ,_)) (Fbc b)
            (Δ²-top 2)
            (Δ²-top-is-id ≤-refl) h⁻¹)
          (Gl²-2-is-equiv b)
          id-is-equiv

module _
  {@♭ 𝓤 𝓥} {@♭ B : Type 𝓤}
  (@♭ crisp-cov-Nat-is-equiv
        : ∀ {@♭ 𝓤} (@♭ F G : Σ (B × Δ² → Type 𝓤) is-covariant)
            (@♭ α : ∀ i → F .fst i → G .fst i)
          → @♭ (∀ x → is-equiv (α ((id ⊗ Δ²-point-incl) x)))
          → is-fibrewise-equiv α)
  where
  open HornGluing {𝓤} {𝓥}

  Gl²←cov-fam-is-equiv
    : ∀ (@♭ F : Σ (B × Δ² → Type (𝓥 ⊔ 𝓘)) is-covariant) (b : B × Δ²)
      → is-equiv (Gl²←cov-fam {𝓤} {𝓥} F b)
  Gl²←cov-fam-is-equiv F = crisp-cov-Nat-is-equiv
    F
    (tr²Σ-inv {𝓤} {𝓥 ⊔ 𝓘}{B} (tr²Σ F))
    (Gl²←cov-fam F)
    (λ { (b , fzero) → Gl²←cov-fam-is-equiv-at-0 F b
       ; (b , fsuc fzero) → Gl²←cov-fam-is-equiv-at-1 F b
       ; (b , fsuc (fsuc fzero)) → Gl²←cov-fam-is-equiv-at-2 F b})

  opaque
    tr²Σ-is-♭-equiv
      : is-equiv (♭-map (tr²Σ {𝓤}{𝓘 ⊔ 𝓥}{B}))
    tr²Σ-is-♭-equiv
      = is-equiv←qinv
          ( (♭-map (tr²Σ-inv {𝓤} {𝓘 ⊔ 𝓥}))
          , ♭-ind (λ F
                   → mapply♭ (mod♭ (ext! λ a
                   → mk≃ (Gl²←cov-fam {𝓤} {𝓥} F a) (Gl²←cov-fam-is-equiv F a) e⁻¹)))
          , ♭-ind (λ a → mapply♭ (mod♭ (ext! (tr²Σ-section {𝓤}{𝓥} a)))))
}
}

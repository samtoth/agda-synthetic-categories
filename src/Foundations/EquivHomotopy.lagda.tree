\date{2025-03-31}
\title{Stability of equivalence under homotopy}
\taxon{Module}
\import{stt-macros}


\agda{
module Foundations.EquivHomotopy where

open import Foundations.Universes
open import Foundations.QuasiEquivalences
open import Foundations.CoherentEquivalences
open import Foundations.FunctionInverses
open import Foundations.Sigma
open import Foundations.Homotopy
}


\p{Since being a quasi-equivalence is stated via two homotopies, it is stable under homotopy. Hence being an equivalence is also stable under homotopy.}

\agda{
homotopy-section
  : ∀ {𝓤 𝓥} {A : Type 𝓤} {B : Type 𝓥}
      {f g : A → B}
    → (f ~ g)
    → section f
    → section g
homotopy-section H (h , sec) = (h , (H ~⁻¹) ▸ h ~∙ sec)

homotopy-retraction
  : ∀ {𝓤 𝓥} {A : Type 𝓤} {B : Type 𝓥}
      {f g : A → B}
    → (f ~ g)
    → retraction f
    → retraction g
homotopy-retraction H (h , ret) = (h , h ◂ (H ~⁻¹) ~∙ ret)

homotopy-qinv
  : ∀ {𝓤 𝓥} {A : Type 𝓤} {B : Type 𝓥}
    → {f g : A → B}
    → (f ~ g)
    → quasi-inv f
    → quasi-inv g
homotopy-qinv H (f⁻¹ , R , S) .fst = f⁻¹
homotopy-qinv {g = g} H (f⁻¹ , R , S) .snd .fst =  f⁻¹ ◂ (H ~⁻¹) ~∙ R
homotopy-qinv {g = g} H (f⁻¹ , R , S) .snd .snd =  (H ~⁻¹) ▸ f⁻¹ ~∙ S

homotopy-is-equiv
  : ∀ {𝓤 𝓥} {A : Type 𝓤} {B : Type 𝓥}
    → {f g : A → B}
    → (f ~ g)
    → is-equiv f
    → is-equiv g
homotopy-is-equiv H e = is-equiv←qinv (homotopy-qinv H (qinv←is-equiv e))
}

\subtree[stt-00DE]{
\taxon{Definition}
\title{Pushout joins}

\p{Just as we could [extend the product bifunctor to an operation on
arrows](stt-00BS), we can do the same for the [directed join](stt-00CW)
bifunctor. Given maps #{f : A \to B} and #{g : C \to D}, we define
#{f \hat{\bjoin} g} to be the cogap map of the following square.}

\quiver{
\begin{tikzcd}
	{A \bjoin C} && {A \bjoin D} \\
	& \bullet \\
	{B \bjoin C} && {B \bjoin D}
	\arrow["{A \bjoin g}", from=1-1, to=1-3]
	\arrow["{f\bjoin C}"', from=1-1, to=3-1]
	\arrow[from=1-3, to=2-2]
	\arrow["{f \bjoin D}", from=1-3, to=3-3]
	\arrow["\lrcorner"{anchor=center, pos=0.125, rotate=180}, draw=none, from=2-2, to=1-1]
	\arrow["{f \hat{\bjoin}g}", from=2-2, to=3-3]
	\arrow[from=3-1, to=2-2]
	\arrow["{B \bjoin g}"', from=3-1, to=3-3]
\end{tikzcd}
}

\p{We also note that this map can be considered a map in the slice over #{D}.}

\agda{
Join-square
  : тИА {ЁЭУд ЁЭУе ЁЭУж ЁЭУЬ}
      {A : Type ЁЭУд} {B : Type ЁЭУе} (f : A тЖТ B)
      {X : Type ЁЭУж} {Y : Type ЁЭУЬ} (g : X тЖТ Y)
    тЖТ Arrow-map (f тЧЗтВБ id: X) (f тЧЗтВБ id: Y)
Join-square f g .Arrow-map.top = id тЧЗтВБ g
Join-square f g .Arrow-map.bot = id тЧЗтВБ g
Join-square f g .Arrow-map.comm = (тЧЗтВБ-тИШ id f g id ~тБ╗┬╣) ~тИЩ тЧЗтВБ-тИШ f id id g

Pushout-join
  : тИА {ЁЭУд ЁЭУе ЁЭУж ЁЭУЬ}
      {A : Type ЁЭУд} {B : Type ЁЭУе} (f : A тЖТ B)
      {X : Type ЁЭУж} {Y : Type ЁЭУЬ} (g : X тЖТ Y)
    тЖТ PushoutтВА (CoconeтЖРArrow-map (Join-square f g) .fst) тЖТ B тЧЗ Y
Pushout-join f g = cogap-mapтЖРsquare (Join-square f g)

Pushout-join-coslice
  : тИА {ЁЭУд ЁЭУе ЁЭУж ЁЭУЬ}
      {A : Type ЁЭУд} {B : Type ЁЭУе} (f : A тЖТ B)
      {X : Type ЁЭУж} {Y : Type ЁЭУЬ} (g : X тЖТ Y)
    тЖТ Coslice-map
        {X = PushoutтВА (CoconeтЖРArrow-map (Join-square f g) .fst)}
        (╬╣тВВ тИШ тЖС-╬╣тВВ)
        {Y = B тЧЗ Y}
        (тЖС-╬╣тВВ)
Pushout-join-coslice f g .fst = Pushout-join f g
Pushout-join-coslice f g .snd = ~refl
}
}

\subtree[stt-00DF]{
\title{Pullback Slices}
\taxon{Definition}

\p{Now given a map in the coslice #{s : t \to^A t'}, and a map #{f : X \to Y},
we construct the \strong{pullback slice} #{s \hat{/} f} as the gap map of the
following square:}

\quiver{
\begin{tikzcd}
	{S_{/t}} && {S_{/tf}} \\
	& \bullet \\
	{T_{/t'}} && {T_{/t'f}}
	\arrow[from=1-1, to=1-3]
	\arrow["{s \hat{/}f}", dashed, from=1-1, to=2-2]
	\arrow[from=1-1, to=3-1]
	\arrow[from=1-3, to=3-3]
	\arrow[from=2-2, to=1-3]
	\arrow[from=2-2, to=3-1]
	\arrow["\lrcorner"{anchor=center, pos=0.125}, draw=none, from=2-2, to=3-3]
	\arrow[from=3-1, to=3-3]
\end{tikzcd}
}


\agda{
extend-slice-map
  : тИА {ЁЭУд ЁЭУе ЁЭУж ЁЭУз} {P : Type ЁЭУд} {Q : Type ЁЭУе} {A : Type ЁЭУж} {B : Type ЁЭУз}
      (p : P тЖТ A) (q : Q тЖТ A) (f : A тЖТ B)
    тЖТ Slice-map p q тЖТ Slice-map (f тИШ p) (f тИШ q)
extend-slice-map p q f = total-map (╬╗ _ тЖТ f тЧВ_)

slice-square
  : тИА {ЁЭУд ЁЭУе ЁЭУЬ ЁЭУЭ} {A : Type ЁЭУд} {B : Type ЁЭУе} (f : A тЖТ B)
      {K : Type ЁЭУЬ} {p : K тЖТ A}
      {S : Type ЁЭУЭ} {q : S тЖТ A} (g : Slice-map p q)
    тЖТ Arrow-map (postcompose-slice q f) (postcompose-slice p f)
slice-square f {p = p} {q = q} G .Arrow-map.top
  = slice-map-slice p q G
slice-square f {p = p} {q = q} G .Arrow-map.bot
  = slice-map-slice (f тИШ p) (f тИШ q) (extend-slice-map p q f G)
slice-square f G .Arrow-map.comm a
  = ╬г-pathтЖТ (refl , (funextтЖТ
      (╬╗ k тЖТ Hom-extтЖТ (~refl , ap-тИЩ f _ refl , ap-тИЩ f _ (G .snd k)))))

pullback-slice
  : тИА {ЁЭУд ЁЭУе ЁЭУЬ ЁЭУЭ} {A : Type ЁЭУд} {B : Type ЁЭУе} (f : A тЖТ B)
      {K : Type ЁЭУЬ} {p : K тЖТ A}
      {S : Type ЁЭУЭ} {q : S тЖТ A} (g : Slice-map p q)
    тЖТ Slice A q
    тЖТ Pullback (slice-map-slice (f тИШ p) (f тИШ q) (extend-slice-map _ q f g))
        (postcompose-slice p f)
pullback-slice f g = gap-mapтЖРsquare (slice-square f g)

slice-hom
  : тИА {ЁЭУд ЁЭУе ЁЭУЬ ЁЭУЭ} {A : Type ЁЭУд} {B : Type ЁЭУе} (f : A тЖТ B)
      {K : Type ЁЭУЬ}
      {S : Type ЁЭУЭ} {q : S тЖТ A} (t : K тЖТ S)
    тЖТ Arrow-map (postcompose-slice q f) (postcompose-slice (q тИШ t) f)
slice-hom f t .Arrow-map.top = precompose-slice _ t
slice-hom f t .Arrow-map.bot = precompose-slice _ t
slice-hom f t .Arrow-map.comm a = refl

pullback-slice'
  : тИА {ЁЭУд ЁЭУе ЁЭУЬ ЁЭУЭ} {A : Type ЁЭУд} {B : Type ЁЭУе} (f : A тЖТ B)
      {K : Type ЁЭУЬ}
      {S : Type ЁЭУЭ} (q : S тЖТ A) (t : K тЖТ S)
    тЖТ Slice A q тЖТ Pullback (precompose-slice (f тИШ q) t)
                    (postcompose-slice (q тИШ t) f)
pullback-slice' f q t = gap-mapтЖРsquare (slice-hom f t)

hom-fam-as-slice
  : тИА {ЁЭУд} {A : Type ЁЭУд}
    тЖТ тИА x
    тЖТ Arrow-map
        (pullback-slice (!: A) {p = ┬б} {q = point x} (┬б , (╬╗ ())))
        (fst {B = (╬╗ y тЖТ Hom A y x)})
hom-fam-as-slice x .Arrow-map.top (a , b) = a , b tt
hom-fam-as-slice x .Arrow-map.bot (a , b , p) = b .fst
hom-fam-as-slice x .Arrow-map.comm = ~refl
}
}


\subtree[stt-00DR]{
\title{The pushout join, pullback slice adjunction}
\taxon{Theorem}

\p{Just as the product-hom adjunction can be extended to an adjunction between
the [pushout product](stt-00BS) and the [pullback power](Core.PullbackPowers), we
can extend the [join-slice adjunction](stt-00D5), to an adjunction between the
[pushout join](stt-00DE) and [pullback slice](stt-00DF).}

\remark{
\p{This result has not been formalised - and I suspect it would be quite involved
and require dealing with a lot of coherence. See \citek{JKL2026} for a
discussion (and formalisation) of the pushout-product and pullback-hom adjunction
mentioned above.}
}

\agda{
power-hom-coslice
  : тИА {ЁЭУд ЁЭУе ЁЭУж ЁЭУЬ ЁЭУи} {Y : Type ЁЭУи}
      {A : Type ЁЭУд} {B : Type ЁЭУе} (p : Y тЖТ A) (q : Y тЖТ B) (F : Coslice-map p q)
      {C : Type ЁЭУж} {D : Type ЁЭУЬ} (r : Y тЖТ C) (s : Y тЖТ D) (G : Coslice-map r s)
    тЖТ Arrow-map (Coslice-map-precompose r F) (Coslice-map-precompose s F)
power-hom-coslice p q F r s G .Arrow-map.top = Coslice-map-postcompose q G
power-hom-coslice p q F r s G .Arrow-map.bot = Coslice-map-postcompose p G
power-hom-coslice p q F r s G .Arrow-map.comm x
  = ╬г-pathтЖТ (refl , (funextтЖТ (╬╗ a тЖТ ap (_тИЩ G .snd a) (ap-тИЩ (G .fst) _ (x .snd a)
                  тИЩ ap (_тИЩ ap (G .fst) _)
                         (sym (ap-тИШ (G .fst) (x .fst) (F .snd a))))
                  тИЩ тИЩ-assoc _ (ap (G .fst) (x .snd a)) (G .snd a))))

pullback-coslice-power
  : тИА {ЁЭУд ЁЭУе ЁЭУж ЁЭУЬ ЁЭУи} {Y : Type ЁЭУи}
      {A : Type ЁЭУд} {B : Type ЁЭУе} (p : Y тЖТ A) (q : Y тЖТ B) (F : Coslice-map p q)
      {C : Type ЁЭУж} {D : Type ЁЭУЬ} (r : Y тЖТ C) (s : Y тЖТ D) (G : Coslice-map r s)
    тЖТ Coslice-map q r
    тЖТ Pullback (Coslice-map-postcompose p G) (Coslice-map-precompose s F)
pullback-coslice-power p q F r s G
  = gap-mapтЖРsquare (power-hom-coslice p q F r s G)
}
}

\subtree[tot-1001]{
\title{Pullback Coslices}
\taxon{Definition}

% TODO: Add diagram!!!

\agda{
coslice-square
  : тИА {ЁЭУд ЁЭУе ЁЭУЬ ЁЭУЭ} {A : Type ЁЭУд} {B : Type ЁЭУе} (f : A тЖТ B)
      {K : Type ЁЭУЬ} {p : K тЖТ A}
      {S : Type ЁЭУЭ} {q : S тЖТ A} (g : Slice-map p q)
    тЖТ Arrow-map (postcompose-coslice q f) (postcompose-coslice p f)
coslice-square f {p = p} {q = q} G .Arrow-map.top
  = coslice-map-slice q p G
coslice-square f {p = p} {q = q} G .Arrow-map.bot
  = coslice-map-slice (f тИШ q) (f тИШ p) (extend-slice-map p q f G)
coslice-square f G .Arrow-map.comm a
  =  ╬г-pathтЖТ (refl , (funextтЖТ
      (╬╗ k тЖТ Hom-extтЖТ (~refl , ap-тИЩ f _ (G .snd k) ,  ap-тИЩ f _ refl))))

pullback-coslice
  : тИА {ЁЭУд ЁЭУе ЁЭУЬ ЁЭУЭ} {A : Type ЁЭУд} {B : Type ЁЭУе} (f : A тЖТ B)
      {K : Type ЁЭУЬ} {p : K тЖТ A}
      {S : Type ЁЭУЭ} {q : S тЖТ A} (g : Slice-map p q)
    тЖТ Coslice A q
    тЖТ Pullback (coslice-map-slice (f тИШ q) (f тИШ p) (extend-slice-map _ q f g))
        (postcompose-coslice p f)
pullback-coslice f g = gap-mapтЖРsquare (coslice-square f g)
}
}

\subtree[fre-00OI]{
\title{Categories}
\taxon{Definition}
\author{fredrikbakke}

\agda{
fam-is-category : вЁ„вӮҒб¶ -carrier fam-is-precategory (point (!бҙё: рқ“ҳ в„‘))
fam-is-category = fam-is-precategory вЁ„вӮҒб¶  (point (!бҙё: рқ“ҳ в„‘))

is-category
  : вҲҖ {рқ“Ө} вҶ’ Type рқ“Ө вҶ’ Type (рқ“ҳ вҠ” рқ“Ө)
is-category A = is-local fam-is-category A

module _ {рқ“Ө} {A : Type рқ“Ө} where

  is-category-is-prop  : is-prop (is-category A)
  is-category-is-prop = is-local-is-prop A

  is-precategoryГ—is-rezk-completeвҶҗis-category
    : is-category A вҶ’ is-precategory A Г— is-rezk-complete A
  is-precategoryГ—is-rezk-completeвҶҗis-category
    = Г—-is-localвҶҗis-local-вЁ„вӮҒб¶ 

  is-precategoryвҶҗis-category
    : is-category A вҶ’ is-precategory A
  is-precategoryвҶҗis-category Acat
    = is-precategoryГ—is-rezk-completeвҶҗis-category Acat .fst

  is-simplicialвҶҗis-category
    : is-category A вҶ’ is-simplicial A
  is-simplicialвҶҗis-category
    = is-simplicialвҶҗis-precategory вҲҳ is-precategoryвҶҗis-category

  is-triangulatedвҶҗis-category
    : is-category A вҶ’ is-triangulated A
  is-triangulatedвҶҗis-category
    = simp-is-triangulated вҲҳ is-simplicialвҶҗis-category

  is-rezk-completeвҶҗis-category
    : is-category A вҶ’ is-rezk-complete A
  is-rezk-completeвҶҗis-category Acat
    = is-precategoryГ—is-rezk-completeвҶҗis-category Acat .snd

  is-categoryвҶҗis-precategoryвҶҗis-rezk-complete
    : is-precategory A вҶ’ is-rezk-complete A вҶ’ is-category A
  is-categoryвҶҗis-precategoryвҶҗis-rezk-complete
    = is-local-вЁ„вӮҒб¶ вҶҗis-local

  is-categoryвҶҗis-segalГ—is-simplicialГ—is-rezk-complete
    : is-segal A вҶ’ is-simplicial A вҶ’ is-rezk-complete A вҶ’ is-category A
  is-categoryвҶҗis-segalГ—is-simplicialГ—is-rezk-complete A-is-segal A-is-simplicial
    = is-categoryвҶҗis-precategoryвҶҗis-rezk-complete
        (is-precategoryвҶҗis-segalвҶҗis-simplicial A-is-segal A-is-simplicial)

  is-complete-segalГ—is-simplicialвҶҗis-category
    : is-category A вҶ’ is-complete-segal A Г— is-simplicial A
  is-complete-segalГ—is-simplicialвҶҗis-category Acat
    = is-complete-segalвҶҗis-segalвҶҗis-rezk-complete
        (is-segalвҶҗis-precategory (is-precategoryвҶҗis-category Acat))
        (is-rezk-completeвҶҗis-category Acat)
    , is-simplicialвҶҗis-category Acat

  is-categoryвҶҗis-complete-segalГ—is-simplicial
    : is-complete-segal A Г— is-simplicial A вҶ’ is-category A
  is-categoryвҶҗis-complete-segalГ—is-simplicial (Arzk , A-is-simplicial)
    = is-categoryвҶҗis-segalГ—is-simplicialГ—is-rezk-complete
        (is-segalГ—is-rezk-completeвҶҗis-complete-segal Arzk .fst)
        (A-is-simplicial)
        (is-segalГ—is-rezk-completeвҶҗis-complete-segal Arzk .snd)

  is-categoryвүғis-complete-segalГ—is-simplicial
    : is-category A вүғ (is-complete-segal A Г— is-simplicial A)
  is-categoryвүғis-complete-segalГ—is-simplicial
    = equivвҶҗlogical
        is-category-is-prop
        ( Г—-is-prop is-complete-segal-is-prop (is-null-is-prop A))
        ( is-complete-segalГ—is-simplicialвҶҗis-category
        , is-categoryвҶҗis-complete-segalГ—is-simplicial)
}

\agda{
Category-SubU : вҲҖ {рқ“Ө} вҶ’ SubU рқ“Ө (рқ“Ө вҠ” рқ“ҳ)
Category-SubU = Local-SubU fam-is-category _

Category-gSubU : gSubU (_вҠ” рқ“ҳ)
Category-gSubU = Local-gSubU fam-is-category

Category-is-globally-reflective
  : is-globally-reflective Category-gSubU
Category-is-globally-reflective = Local-global-reflectors fam-is-category

Category-gRSubU : gRSubU (_вҠ” рқ“ҳ)
Category-gRSubU .gRSubU.GS = Category-gSubU
Category-gRSubU .gRSubU.GS-is-globally-reflective = Category-is-globally-reflective

open gSubU Category-gSubU public using () renaming
  ( вҲҲSвҶҗequiv to is-categoryвҶҗequiv)
open gReflectiveClosure Category-gRSubU public using () renaming
  ( О вҲҲS to О -is-category
  ; ULiftвҲҲS to ULift-is-category
  ; рқҹҷвҲҲS to рқҹҷ-is-category
  ; вҲҲSвҶҗis-singleton to is-categoryвҶҗis-singleton
  ; вҲҲSвҶҗretract to is-categoryвҶҗretract
  ; PullbackвҲҲS to Pullback-is-category
  ; fibreвҲҲS to fibre-is-category
  ; ExtвҲҲS to Ext-is-category
  ; Г—вҲҲS to Г—-is-category
  ; пјқвҲҲS to пјқ-is-category
  ; ~вҲҲS to ~-is-category
  ; retractвҲҲS to retract-is-category
  ; biinvвҲҲS to biinv-is-category
  ; вүғвҲҲS to вүғ-is-category
  ; EqualiserвҲҲS to Equaliser-is-category
  ; Seq-limвҲҲS to Seq-lim-is-category
  ; preidempotent-mapвҲҲS to preidempotent-map-is-category
  ; qidempotent-mapвҲҲS to qidempotent-map-is-category
  ; idempotent-mapвҲҲS to idempotent-map-is-category
  ; RetractsвҲҲS to Retracts-is-category)
open gRSubUHomClosure Category-gRSubU public using () renaming
  ( HomвҲҲS to Hom-is-category)

module Cat where
  open gRSubU Category-gRSubU public
  open gReflectiveClosure Category-gRSubU public
  open gRSubUHomClosure Category-gRSubU public

Category-U : (рқ“Ө : Level) вҶ’ Type (lsuc (рқ“ҳ вҠ” рқ“Ө))
Category-U рқ“Ө = ОЈ[ A вҲ¶ Type (рқ“ҳ вҠ” рқ“Ө) ] is-category A

Category-U-is-simplicial
  : {рқ“Ө : Level} вҶ’ is-simplicial (Category-U рқ“Ө)
Category-U-is-simplicial {рқ“Ө}
  = is-simplicialвҶҗequiv
      ((ОЈ-snd-вүғ О» A вҶ’ is-categoryвүғis-complete-segalГ—is-simplicial {A = A}) eвҒ»В№)
      (Null-in-gSubU-is-nullвҶҗis-prop
        {рқ“Ө = рқ“ҳ} {рқ“Ҙ = рқ“Ө}
        {P = fam-is-simplicial}
        {S = CompleteSegal-gSubU}
        (fam-is-simplicial-is-prop)
        (О» _ вҶ’ О -is-complete-segal))
}
}


\subtree[fre-44QA]{
\title{Comparison map between the total space of identities and isomorphisms}
\author{fredrikbakke}
\taxon{Lemma}
\date{2026-05-15}

\agda{
is-IsoвҶҗId-equiv : вҲҖ {рқ“Ө} вҶ’ Type рқ“Ө вҶ’ Type (рқ“ҳ вҠ” рқ“Ө)
is-IsoвҶҗId-equiv A = (a b : A) вҶ’ is-equiv (IsoвҶҗId: a b)

TotalId' : вҲҖ {рқ“Ө} вҶ’ Type рқ“Ө вҶ’ Type рқ“Ө
TotalId' A = ОЈ[ a вҲ¶ A ] ОЈ[ b вҲ¶ A ] (a пјқ b)

module _ {рқ“Ө} {A : Type рқ“Ө} where

  refl-TotalId' : A вҶ’ TotalId' A
  refl-TotalId' a = a , a , refl

  TotalIsoвҶҗTotalId' : TotalId' A вҶ’ TotalIso A
  TotalIsoвҶҗTotalId' = total-map О» a вҶ’ total-map О» b вҶ’ IsoвҶҗId: a b

  refl-TotalId'-is-equiv : is-equiv refl-TotalId'
  refl-TotalId'-is-equiv = mk-eqv qinv ~refl where
    qinv : quasi-inv refl-TotalId'
    qinv .fst = fst
    qinv .snd .fst = ~refl
    qinv .snd .snd (a , .a , refl) = refl

  id-TotalIso-is-equivвҶҗis-IsoвҶҗId-equiv
    : is-IsoвҶҗId-equiv A вҶ’ is-equiv id-TotalIso
  id-TotalIso-is-equivвҶҗis-IsoвҶҗId-equiv Aiso
    = is-equiv-вҲҳ
        ( is-total-equivвҶҗis-fibrewise-equiv О» a
        вҶ’ is-total-equivвҶҗis-fibrewise-equiv О» b
        вҶ’ Aiso a b)
        refl-TotalId'-is-equiv

  TotalIsoвҶҗTotalId'-refl-TotalId'
    : TotalIsoвҶҗTotalId' вҲҳ refl-TotalId' ~ id-TotalIso
  TotalIsoвҶҗTotalId'-refl-TotalId' = ~refl

  TotalIsoвҶҗTotalId'-fst
    : id-TotalIso вҲҳ fst ~ TotalIsoвҶҗTotalId'
  TotalIsoвҶҗTotalId'-fst (a , .a , refl) = refl
}
}

\subtree[fre-F900]{
\title{A Segal type is Rezk-complete iff \code{IsoвҶҗId} is an equivalence}
\taxon{Proposition}
\author{fredrikbakke}
\date{2026-05-15}

\p{
In fact, we show the backwards implication is true without assuming Segalness.
}

\agda{
module _ {рқ“Ө} {A : Type рқ“Ө} where

  is-rezk-completeвҶҗis-IsoвҶҗId-equiv
    : is-IsoвҶҗId-equiv A
    вҶ’ is-rezk-complete A
  is-rezk-completeвҶҗis-IsoвҶҗId-equiv A-iso
    = is-localбҙёвҶҗis-null О» _ вҶ’ is-equivвҶҗqinv qinv where
    module totid = is-equiv (id-TotalIso-is-equivвҶҗis-IsoвҶҗId-equiv A-iso)

    qinv : quasi-inv (const A в„‘)
    qinv .fst F = totid.bwd (в„‘-repвҶ’ F)
    qinv .snd .fst a = ap fst (totid.Оө (в„‘-repвҶ’ (const A в„‘ a)))
    qinv .snd .snd F
      = sym (в„‘-repвҶҗid (totid.bwd (в„‘-repвҶ’ F)))
      вҲҷ ap в„‘-repвҶҗ (totid.Оө (в„‘-repвҶ’ F))
      вҲҷ в„‘-repвҶҗвҶ’ F

  id-TotalIso-is-equivвҶҗis-rezk-complete
    : is-segal A вҶ’ is-rezk-complete A вҶ’ is-equiv (id-TotalIso {A = A})
  id-TotalIso-is-equivвҶҗis-rezk-complete A-is-segal A-is-rezk-complete
    = is-equiv-вҲҳ~
        (в„‘-repвҶ’const A-is-segal)
        (в„‘-repвҶ’-is-equiv A-is-segal)
        (is-nullвҶҗis-localбҙё A-is-rezk-complete tt)

  is-IsoвҶҗId-equivвҶҗis-rezk-complete
    : is-segal A вҶ’ is-rezk-complete A вҶ’ is-IsoвҶҗId-equiv A
  is-IsoвҶҗId-equivвҶҗis-rezk-complete A-is-segal A-is-rezk-complete a
    = is-fibrewise-equivвҶҗis-total-equiv
        (is-fibrewise-equivвҶҗis-total-equiv
          (is-equiv-вҲҳ~
            (TotalIsoвҶҗTotalId'-fst)
              (id-TotalIso-is-equivвҶҗis-rezk-complete A-is-segal A-is-rezk-complete)
              (is-equivвҒ»В№ refl-TotalId'-is-equiv))
          (a))

  is-rezk-completeвҮ”is-IsoвҶҗId-equiv
    : is-segal A вҶ’ is-rezk-complete A вҮ” is-IsoвҶҗId-equiv A
  is-rezk-completeвҮ”is-IsoвҶҗId-equiv A-is-segal
    = ( is-IsoвҶҗId-equivвҶҗis-rezk-complete A-is-segal
      , is-rezk-completeвҶҗis-IsoвҶҗId-equiv)
}
}

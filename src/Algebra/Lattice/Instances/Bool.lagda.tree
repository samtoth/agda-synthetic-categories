\agda{
module Algebra.Lattice.Instances.Bool where

open import Foundations.Prelude
open import UF

open import Algebra.Lattice
open import Modalities.Instances.Truncation
}
%```


\subtree[stt-109R]{
\title{The lattice of booleans}
\taxon{Example}

%```agda
\agda{
Bool-Lattice : Lattice Bool
Bool-Lattice .Lattice.0l = false
Bool-Lattice .Lattice.1l = true
Bool-Lattice .Lattice._∧_ = _&_
Bool-Lattice .Lattice._∨_ = _||_
Bool-Lattice .Lattice.str-is-lattice = l where
  l : is-lattice false true _&_ _||_
  l .is-lattice.car-is-0-truncated = is-truncated←is-set Bool-is-set
  l .is-lattice.∧-assoc {true} {true} {true} = refl
  l .is-lattice.∧-assoc {true} {true} {false} = refl
  l .is-lattice.∧-assoc {true} {false} = refl
  l .is-lattice.∧-assoc {false} = refl
  l .is-lattice.∨-assoc {true} = refl
  l .is-lattice.∨-assoc {false} {true} = refl
  l .is-lattice.∨-assoc {false} {false} {true} = refl
  l .is-lattice.∨-assoc {false} {false} {false} = refl
  l .is-lattice.∧-comm {true} {true} = refl
  l .is-lattice.∧-comm {false} {true} = refl
  l .is-lattice.∧-comm {true} {false} = refl
  l .is-lattice.∧-comm {false} {false} = refl
  l .is-lattice.∨-comm {true} {true} = refl
  l .is-lattice.∨-comm {true} {false} = refl
  l .is-lattice.∨-comm {false} {true} = refl
  l .is-lattice.∨-comm {false} {false} = refl
  l .is-lattice.∨-∧-abs {true} = refl
  l .is-lattice.∨-∧-abs {false} = refl
  l .is-lattice.∧-∨-abs {true} = refl
  l .is-lattice.∧-∨-abs {false} = refl
  l .is-lattice.0-bottom {true} = refl
  l .is-lattice.0-bottom {false} = refl
  l .is-lattice.1-top {true} = refl
  l .is-lattice.1-top {false} = refl

Bool-distributive : is-distributive Bool-Lattice
Bool-distributive .is-distributive.has-is-distrib {true} {y} {z} = refl
Bool-distributive .is-distributive.has-is-distrib {false} {false} {z} = refl
Bool-distributive .is-distributive.has-is-distrib {false} {true} {true} = refl
Bool-distributive .is-distributive.has-is-distrib {false} {true} {false} = refl

Bool-initial : ∀ {𝓤} {A : Type 𝓤} (M : Lattice A)
             → is-singleton (Σ (Bool → A) (is-lattice-hom Bool-Lattice M))
Bool-initial {_} {A} M = mk-singl (ι , lem) unique where
  open Lattice M
  open is-lattice-hom

  ι : Bool → A
  ι true = 1l
  ι false = 0l

  lem : is-lattice-hom Bool-Lattice M ι
  lem .pres-∨ {true} {y} = sym (∨-comm ∙ 1-coinit)
  lem .pres-∨ {false} {true} = sym 1-coinit
  lem .pres-∨ {false} {false} = sym 0-bottom
  lem .pres-∧ {true} {true} = sym 1-top
  lem .pres-∧ {true} {false} = sym (∧-comm ∙ 0-init)
  lem .pres-∧ {false} {y} = sym 0-init
  lem .pres-0 = refl
  lem .pres-1 = refl

  unique : (x : Σ (Bool → A) (is-lattice-hom Bool-Lattice M)) →
           (ι , lem) ＝ x
  unique (f , p) = Σ-path→ (funext→ H , is-lattice-hom-is-prop _ _ _ _ p) where
    H : ι ~ f
    H true = sym (p .pres-1)
    H false = sym (p .pres-0)
}
%```
}

\subtree[stt-00DG]{
\taxon{Lemma}
\title{Precategories are left Segal}

\p{A [simplicial type](stt-00AC) is [Segal](stt-00AI) iff it
is [left Segal](stt-00DA).}

\proof{

\p{We factorise the defining map for left Segal types as follows:}

\quiver{
\begin{tikzcd}
	{\Lambda^2_1} && {\Delta^2} \\
	\\
	\\
	{1 \ltimes \Delta^1 \simeq \square +^{\Delta^1}1} && {\ttt +^{\Delta^1}1}
	\arrow["{\sim_{\textit{Segal}}}", from=1-1, to=1-3]
	\arrow[from=1-1, to=4-1]
	\arrow["{\sim_{\textit{Segal}}}", from=1-3, to=4-3]
	\arrow["{\sim_{\textit{simp}}}", from=4-3, to=4-1]
\end{tikzcd}
}

\p{The top map is a Segal equivalence by definition. Likewise the bottom map
is a simplicial equivalence, which follows from \ref{stt-00DC}. Finally,
\ref{stt-00DI} gives the right most map as a Segal equivalence.}
}

%```agda
\agda{
1‚ãâŒî¬π‚Üêcone : Pushout {B = ‚ñ°^ 2} (_, i0) (!: Œî¬π) ‚Üí ùüô ‚ãâ Œî¬π
1‚ãâŒî¬π‚Üêcone = Pushout‚ÇÅ
  (mk-span-map
    (Œª (a , b) ‚Üí b , tt , a)
    (Œª i ‚Üí ‚àÇŒî¬π-0 , tt , i)
    inl
    ~refl
    ~refl)

1‚ãâŒî¬π-is-cone : quasi-iso 1‚ãâŒî¬π‚Üêcone
1‚ãâŒî¬π-is-cone .fst = ‚Üë-rec (mk-right-cocone Œπ‚ÇÇ (Œπ‚ÇÅ ‚àò (_, i1))
                           Œª where (_ , i) ‚Üí mk-hom (Œπ‚ÇÅ ‚àò (i ,_))
                                                    (glue i)
                                                    refl)
1‚ãâŒî¬π-is-cone .snd .fst = pushout-ind _
  (mk-cocone·µà ~refl ~refl
    (Œª i ‚Üí Id·µà-func‚ÜêSquare
               {f = (1‚ãâŒî¬π-is-cone .fst ‚àò 1‚ãâŒî¬π‚Üêcone)} {id} (glue i) refl refl
               (Square-degen-hor _ _
                 (ap-‚àò (1‚ãâŒî¬π-is-cone .fst) 1‚ãâŒî¬π‚Üêcone (glue i)
                 ‚àô ap (ap (1‚ãâŒî¬π-is-cone .fst)) (pushout-rec-apŒ≤ _ ‚àô ‚àô-reflr _)
                 ‚àô pushout-rec-apŒ≤ _ ‚àô sym (ap-id (glue i))))))
1‚ãâŒî¬π-is-cone .snd .snd = pushout-ind _
  (mk-cocone·µà ~refl (‚äé-ind (~refl , (Œª i ‚Üí glue (‚àÇŒî¬π-1 , tt , i))))
    Œª { (mk-lift true , _ , i)
           ‚Üí Id·µà-func‚ÜêSquare (glue (‚àÇŒî¬π-1 , tt , i)) refl (glue (‚àÇŒî¬π-1 , tt , i))
               (coe
                 (Square-functorial-bot (sym (ap-id (glue (‚àÇŒî¬π-1 , _ , i)))))
                 (Square-flatten-vert
                   (sym (ap-‚àò 1‚ãâŒî¬π‚Üêcone (1‚ãâŒî¬π-is-cone .fst) (glue _)
                   ‚àô ap (ap 1‚ãâŒî¬π‚Üêcone) (pushout-rec-apŒ≤ _)))))
      ; (mk-lift false , _ , i)
           ‚Üí Id·µà-func‚ÜêSquare (glue (‚àÇŒî¬π-0 , tt , i)) refl refl
               (Square-degen-hor _ _
                 (ap-‚àò 1‚ãâŒî¬π‚Üêcone (1‚ãâŒî¬π-is-cone .fst) (glue (‚àÇŒî¬π-0 , tt , i))
                 ‚àô ap (ap 1‚ãâŒî¬π‚Üêcone) (pushout-rec-apŒ≤ _) ‚àô pushout-rec-apŒ≤ _
                 ‚àô ‚àô-reflr _ ‚àô sym (ap-id (glue _)))) })

‚ßÖ-‚ñ°-degen-incl
  : Pushout {B = ‚ßÖ} (Œπ‚ÇÇ ‚àò (_, i0)) ! ‚Üí Pushout {B = ‚ñ°^ 2} (_, i0) !
‚ßÖ-‚ñ°-degen-incl
  = Pushout‚ÇÅ (mk-span-map ‚ßÖ-incl id id ~refl ~refl)

strong-segal-factorisation
  : 1‚ãâŒî¬π‚Üêcone ‚àò ‚ßÖ-‚ñ°-degen-incl ‚àò ‚ßÖ-degen‚ÜêŒî¬≤ ‚àò Œõ[2,1]-incl ~ weird-horn-inclusion
strong-segal-factorisation
  = pushout-rec-unique _ _
      ~refl
      (Œª i ‚Üí glue (‚àÇŒî¬π-1 , tt , i))
      Œª _ ‚Üí ap (_‚àô glue (‚àÇŒî¬π-1 , tt , i0))
              ( ap-‚àò (1‚ãâŒî¬π‚Üêcone ‚àò ‚ßÖ-‚ñ°-degen-incl ‚àò ‚ßÖ-degen‚ÜêŒî¬≤)
                     Œõ[2,1]-incl (glue tt)
              ‚àô ap (ap (1‚ãâŒî¬π‚Üêcone ‚àò ‚ßÖ-‚ñ°-degen-incl ‚àò ‚ßÖ-degen‚ÜêŒî¬≤))
                   (pushout-rec-apŒ≤ tt)
              ‚àô ap-‚àò Œπ‚ÇÅ _ Œî¬≤-refl
              ‚àô ap (ap Œπ‚ÇÅ) (is-set‚Üêis-truncated
                    (√ó-is-truncated car-is-set (√ó-is-truncated ùüô-is-truncated car-is-set))
                     _ _ _ refl))


is-based-triangulated
  : ‚àÄ {ùì§} {A : Type ùì§}
    ‚Üí  ‚ßÖ-incl ‚ä• A ‚Üí ‚ßÖ-‚ñ°-degen-incl ‚ä• A
is-based-triangulated {A = A} ttA
  = left-orthogonal-type-pushout‚ÇÅ map .snd (lem ‚àò ev tt)  where
  -- A map colim(‚ßÖ ‚Üê Œî¬π ‚Üí ùüô) ‚Üí colim(‚ñ° ‚Üê Œî¬π ‚Üí ùüô)
  -- is equivalently a map in the coslice under Œî¬π from ‚ßÖ ‚Üí ‚ñ°
  map : Coslice-map {A = Œî¬π} (Œπ‚ÇÇ ‚àò (_, i0)) (_, i0)
  map .fst = ‚ßÖ-incl
  map .snd = ~refl

  lem : ‚àÄ x ‚Üí map ‚ä• (Œª _ ‚Üí x)
  lem x = coslice-orthogonality map .fst ttA (Œª _ ‚Üí x)

1‚ãâŒî¬π‚ÜêŒî¬≤-is-simplicial-equiv
  : is-precategory-equiv (1‚ãâŒî¬π‚Üêcone ‚àò ‚ßÖ-‚ñ°-degen-incl ‚àò ‚ßÖ-degen‚ÜêŒî¬≤)
1‚ãâŒî¬π‚ÜêŒî¬≤-is-simplicial-equiv {_} {Q} Qsi Qse
  = is-equiv-‚àò
      {f = precomp Q ‚ßÖ-degen‚ÜêŒî¬≤}
      {g = precomp Q ‚ßÖ-‚ñ°-degen-incl ‚àò precomp Q 1‚ãâŒî¬π‚Üêcone}
      (‚ßÖ-degen‚ÜêŒî¬≤-is-segal-equiv Qse)
      (is-equiv-‚àò
        (is-based-triangulated (simp-is-triangulated Qsi tt))
        (precomp-equiv (is-equiv‚Üêqiso 1‚ãâŒî¬π-is-cone)))

opaque
  is-left-segal‚Üêis-segal
    : ‚àÄ {ùì§} {A : Type ùì§} ‚Üí is-simplicial A ‚Üí is-segal A
      ‚Üí is-left-segal A
  is-left-segal‚Üêis-segal {A = A} asimp apc tt
    = is-equiv~‚àò (Œª h ‚Üí funext‚Üí Œª a ‚Üí ap h (sym (strong-segal-factorisation a)))
        (apc tt)
        (1‚ãâŒî¬π‚ÜêŒî¬≤-is-simplicial-equiv asimp apc)

hom-fam-is-cov‚áîis-precategory
  : ‚àÄ {ùì§} {A : Type ùì§} ‚Üí is-simplicial A
    ‚Üí is-segal A ‚áî (‚àÄ x ‚Üí is-covariant (Hom A x))
hom-fam-is-cov‚áîis-precategory Asimp
  = (is-left-segal‚Üêis-segal Asimp , is-segal‚Üêis-left-segal)
  ‚àô‚áî (hom-fam-is-cov‚áîis-left-segal ‚áî‚Åª¬π)

coslice-is-left‚áîis-precategory
  : ‚àÄ {ùì§} {A : Type ùì§} ‚Üí is-simplicial A
    ‚Üí is-segal A ‚áî (‚àÄ x ‚Üí is-left-fibration {A = Coslice A (point x)} fst)
coslice-is-left‚áîis-precategory Asimp
  = hom-fam-is-cov‚áîis-precategory Asimp
  ‚àô‚áî postcomp-ŒÝ-‚áî (Œª a ‚Üí hom-fam-is-cov‚áîis-left-fibration a)
}
%```
}

\subtree[stt-00GB]{
\title{Characterisation of the covariant action of #{\Hom}}
\date{2026-03-20}
\author{fredrikbakke}
\taxon{Theorem}

\p{
Given a [left Segal](stt-00DA) type #{A}, the covariant action of
the family #{(a : A) \mapsto \Hom_A(a,{-})} is given by postcomposition.
}

\proof{
\p{
By [covariance of representable families](stt-00D9), the family
#{\Hom_A(a,-)} is covariant. Since [left Segal](stt-00DA) types are
[Segal](stt-00AI) by \ref{stt-00DB}, composition is unique. For
composable morphisms #{f : \Hom_A(a,b)} and #{g : \Hom_A(b,c)}, choose a 2-simplex
#{\sigma} witnessing their composition. Restricting that 2-simplex along the map
#{(s,t) \mapsto (s,s \wedge t)} produces a dependent homotopy over #{g} from #{f} to
#{g \circ f}. Since covariant transport is defined as the centre of the contractible
type of such dependent lifts, this point must coincide with the transport of #{f}
along #{g}. Hence transporting along #{g} sends #{f} to #{g \circ f}.
}
}

%```agda
\agda{
module CovariantActionPostcomp
  {ùì§ : Level} {A : Type ùì§} (ùê¥‚Çó : is-left-segal A)
  (let ùê¥ = is-segal‚Üêis-left-segal ùê¥‚Çó)
  where

  tr-cov-hom-is-comp
    : {a b c : A}
      (g : Hom A b c) (f : Hom A a b)
    ‚Üí tr-cov-hom (hom-fam-cov ùê¥‚Çó _) g f
      Ôºù g ‚àò[ ùê¥ ] f
  tr-cov-hom-is-comp {a} (mk-hom gh refl refl) f@(mk-hom fh refl fh1)
    = ap fst (hom-fam-cov ùê¥‚Çó a gh f .central (gf , comp-hov))
    where
    g = mk-hom gh refl refl
    gf = g ‚àò[ ùê¥ ] f
    œÉ = ‚àò[_]-is-composite {f = g} {g = f} ùê¥

    bd : (x : ‚àÇŒî¬≤) ‚Üí œÉ .fst (‚àÇŒî¬≤-incl x) Ôºù make-‚àÇŒî¬≤ g f gf x
    bd = happly (œÉ .snd)

    face2 : (s : Œî¬π) ‚Üí œÉ .fst (s , i0) Ôºù fh s
    face2 s = bd (Œπ‚ÇÅ (Œπ‚ÇÅ s))

    face0 : (t : Œî¬π) ‚Üí œÉ .fst (i1 , t) Ôºù gh t
    face0 t = bd (Œπ‚ÇÅ (Œπ‚ÇÇ t))

    diag : (s : Œî¬π) ‚Üí œÉ .fst (s , s) Ôºù gf .Hom·µà.hom s
    diag s = bd (Œπ‚ÇÇ s)

    wedge-hom : (t : Œî¬π) ‚Üí Hom A (fh i0) (gh t)
    wedge-hom t = mk-hom
      (Œª s ‚Üí œÉ .fst ((s , s ‚àß t) ‚¶É ‚àß-‚â§-eliml auto! ‚¶Ñ))
      (ap (œÉ .fst) (Œî¬≤-ext (refl , 0-init)) ‚àô face2 i0)
      (ap (œÉ .fst) (Œî¬≤-ext (refl , ‚àß-comm ‚àô 1-top)) ‚àô face0 t)

    horn-glue : Œπ‚ÇÅ {f = point i1} {g = point i0} i1
              Ôºù Œπ‚ÇÇ i0
    horn-glue = glue tt

    horn-cocone : Cocone (mk-span ùüô (point i1) (point i0)) A
    horn-cocone = mk-cocone fh gh (Œª _ ‚Üí fh1 ‚àô sym refl)

    diag-glue0
      : face2 i0
        Ôºù (ap (œÉ .fst ‚àò ‚àÇŒî¬≤-incl) (glue ‚àÇŒî¬π-0) ‚àô diag i0) ‚àô gf .Hom·µà.hom0
    diag-glue0
      = sym (homotopy-cancel bd (glue ‚àÇŒî¬π-0))
      ‚àô ap ((ap (œÉ .fst ‚àò ‚àÇŒî¬≤-incl) (glue ‚àÇŒî¬π-0) ‚àô diag i0) ‚àô_)
           (ap sym (pushout-rec-apŒ≤ ‚àÇŒî¬π-0)
           ‚àô ap sym (‚àô-refll (sym (gf .Hom·µà.hom0)))
           ‚àô sym-sym)

    diag-glue1
      : face0 i1
        Ôºù (ap (œÉ .fst ‚àò ‚àÇŒî¬≤-incl) (glue ‚àÇŒî¬π-1) ‚àô diag i1) ‚àô gf .Hom·µà.hom1
    diag-glue1
      = sym (homotopy-cancel bd (glue ‚àÇŒî¬π-1))
      ‚àô ap ((ap (œÉ .fst ‚àò ‚àÇŒî¬≤-incl) (glue ‚àÇŒî¬π-1) ‚àô diag i1) ‚àô_)
           (ap sym (pushout-rec-apŒ≤ ‚àÇŒî¬π-1)
           ‚àô ap sym (‚àô-refll (sym (gf .Hom·µà.hom1)))
           ‚àô sym-sym)

    comp-hov-hom0-path : Hom-path (wedge-hom i0) f
    comp-hov-hom0-path
      = ( (Œª s ‚Üí ap (œÉ .fst) (Œî¬≤-ext (refl , ‚àß-comm ‚àô 0-init)) ‚àô face2 s)
        , ‚àô-reflr _ ‚àô ap (Œª p ‚Üí ap (œÉ .fst) p ‚àô face2 i0) (Œî¬≤-is-set _ _ _ _)
        , ‚àô-assoc (ap (œÉ .fst) (Œî¬≤-ext (refl , ‚àß-comm ‚àô 0-init))) (face2 i1) fh1
          ‚àô ap (ap (œÉ .fst) (Œî¬≤-ext (refl , ‚àß-comm ‚àô 0-init)) ‚àô_)
                (ap (face2 i1 ‚àô_)
                    (sym (‚àô-reflr fh1)
                    ‚àô sym (pushout-rec-apŒ≤ {c = horn-cocone} tt)
                    ‚àô ap-‚àò (make-‚àÇŒî¬≤ g f gf) ‚àÇŒî¬≤‚ÜêŒõ[2,1] horn-glue)
                ‚àô homotopy-natural bd (ap ‚àÇŒî¬≤‚ÜêŒõ[2,1] horn-glue))
          ‚àô sym (‚àô-assoc (ap (œÉ .fst) (Œî¬≤-ext (refl , ‚àß-comm ‚àô 0-init)))
                          (ap (œÉ .fst ‚àò ‚àÇŒî¬≤-incl) (ap ‚àÇŒî¬≤‚ÜêŒõ[2,1] horn-glue))
                          (face0 i0))
          ‚àô ap (_‚àô face0 i0)
               (ap (ap (œÉ .fst) (Œî¬≤-ext (refl , ‚àß-comm ‚àô 0-init)) ‚àô_)
                    (ap-‚àò (œÉ .fst) ‚àÇŒî¬≤-incl (ap ‚àÇŒî¬≤‚ÜêŒõ[2,1] horn-glue))
               ‚àô sym (ap-‚àô (œÉ .fst) (Œî¬≤-ext (refl , ‚àß-comm ‚àô 0-init))
                                     (ap ‚àÇŒî¬≤-incl (ap ‚àÇŒî¬≤‚ÜêŒõ[2,1] horn-glue)))
               ‚àô ap (ap (œÉ .fst)) (Œî¬≤-is-set _ _ _ _)))

    comp-hov-hom1-path : Hom-path (wedge-hom i1) gf
    comp-hov-hom1-path
      = ( (Œª s ‚Üí ap (œÉ .fst) (Œî¬≤-ext (refl , 1-top)) ‚àô diag s)
        , ‚àô-assoc (ap (œÉ .fst) (Œî¬≤-ext (refl , 1-top))) (diag i0) (gf .Hom·µà.hom0)
          ‚àô ap (_‚àô (diag i0 ‚àô gf .Hom·µà.hom0))
               (ap (ap (œÉ .fst))
                   (Œî¬≤-is-set _ _
                     (Œî¬≤-ext (refl , 1-top))
                     (Œî¬≤-ext (refl , 0-init) ‚àô ap ‚àÇŒî¬≤-incl (glue ‚àÇŒî¬π-0)))
               ‚àô ap-‚àô (œÉ .fst) (Œî¬≤-ext (refl , 0-init)) (ap ‚àÇŒî¬≤-incl (glue ‚àÇŒî¬π-0))
               ‚àô ap (ap (œÉ .fst) (Œî¬≤-ext (refl , 0-init)) ‚àô_)
                    (sym (ap-‚àò (œÉ .fst) ‚àÇŒî¬≤-incl (glue ‚àÇŒî¬π-0))))
          ‚àô ‚àô-assoc (ap (œÉ .fst) (Œî¬≤-ext (refl , 0-init)))
                    (ap (œÉ .fst ‚àò ‚àÇŒî¬≤-incl) (glue ‚àÇŒî¬π-0))
                    (diag i0 ‚àô gf .Hom·µà.hom0)
          ‚àô ap (ap (œÉ .fst) (Œî¬≤-ext (refl , 0-init)) ‚àô_)
               (sym (‚àô-assoc (ap (œÉ .fst ‚àò ‚àÇŒî¬≤-incl) (glue ‚àÇŒî¬π-0))
                             (diag i0) (gf .Hom·µà.hom0))
               ‚àô sym diag-glue0)
        , ‚àô-assoc (ap (œÉ .fst) (Œî¬≤-ext (refl , 1-top))) (diag i1) (gf .Hom·µà.hom1)
          ‚àô ap (_‚àô (diag i1 ‚àô gf .Hom·µà.hom1))
               (ap (ap (œÉ .fst))
                   (Œî¬≤-is-set _ _
                     (Œî¬≤-ext (refl , 1-top))
                     (Œî¬≤-ext (refl , ‚àß-comm ‚àô 1-top) ‚àô ap ‚àÇŒî¬≤-incl (glue ‚àÇŒî¬π-1)))
               ‚àô ap-‚àô (œÉ .fst)
                      (Œî¬≤-ext (refl , ‚àß-comm ‚àô 1-top))
                      (ap ‚àÇŒî¬≤-incl (glue ‚àÇŒî¬π-1))
               ‚àô ap (ap (œÉ .fst) (Œî¬≤-ext (refl , ‚àß-comm ‚àô 1-top)) ‚àô_)
                    (sym (ap-‚àò (œÉ .fst) ‚àÇŒî¬≤-incl (glue ‚àÇŒî¬π-1))))
          ‚àô ‚àô-assoc (ap (œÉ .fst) (Œî¬≤-ext (refl , ‚àß-comm ‚àô 1-top)))
                    (ap (œÉ .fst ‚àò ‚àÇŒî¬≤-incl) (glue ‚àÇŒî¬π-1))
                    (diag i1 ‚àô gf .Hom·µà.hom1)
          ‚àô ap (ap (œÉ .fst) (Œî¬≤-ext (refl , ‚àß-comm ‚àô 1-top)) ‚àô_)
               (sym (‚àô-assoc (ap (œÉ .fst ‚àò ‚àÇŒî¬≤-incl) (glue ‚àÇŒî¬π-1))
                             (diag i1) (gf .Hom·µà.hom1))
               ‚àô sym diag-glue1))

    comp-hov : Hom·µà (Hom A (fh i0) ‚àò gh) f gf
    comp-hov .Hom·µà.hom = wedge-hom
    comp-hov .Hom·µà.hom0 = Hom-ext‚Üí comp-hov-hom0-path
    comp-hov .Hom·µà.hom1 = Hom-ext‚Üí comp-hov-hom1-path
}
%```
}

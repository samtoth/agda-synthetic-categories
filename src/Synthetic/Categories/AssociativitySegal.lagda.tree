\subtree[fre-FB4F]{
\taxon{Proof}
\author{fredrikbakke}
\date{2026-04-30}

\agda{
вҲҷ-reflrвҶҗloop-out-of-О”В№
  : {рқ“Ө : Level}
    {A : Type рқ“Ө} {i : О”В№} {p : i пјқ i}
  вҶ’ (f : О”В№ вҶ’ A)
  вҶ’ {x : A}
  вҶ’ (q : x пјқ f i)
  вҶ’ q вҲҷ ap f p пјқ q
вҲҷ-reflrвҶҗloop-out-of-О”В№ {p = p} f q
  = ap (q вҲҷ_) (ap (ap f) (is-prop-separated _ _ p refl)) вҲҷ вҲҷ-reflr q
}

\agda{
module AssocProof
  {рқ“Ө : Level} {A : Type рқ“Ө} (рқҗҙ : is-segal A) {a b c d : A}
  (h : Hom A c d) (g : Hom A b c) (f : Hom A a b)
  (let gf = g вҲҳ[ рқҗҙ ] f)
  (let hg = h вҲҳ[ рқҗҙ ] g)
  (let gf-composite = вҲҳ[ рқҗҙ ]-is-composite {g} {f})
  (let hg-composite = вҲҳ[ рқҗҙ ]-is-composite {h} {g})
  (let fвҮ’g = composite-square g f gf-composite)
  (let gвҮ’h = composite-square h g hg-composite)
  where

  middle-composite
    : ОЈ[ p вҲ¶ Hom (О”В№ вҶ’ A) (f .HomбөҲ.hom) (h .HomбөҲ.hom) ] Hom2 gвҮ’h fвҮ’g p
  middle-composite
    = compositeвҶҗhorn-extension gвҮ’h fвҮ’g
        (centre (segal-unique-composite (О -is-segal О» _ вҶ’ рқҗҙ) gвҮ’h fвҮ’g))

  middle-hom : Hom (О”В№ вҶ’ A) (f .HomбөҲ.hom) (h .HomбөҲ.hom)
  middle-hom = middle-composite .fst

  middle-Hom2 : Hom2 gвҮ’h fвҮ’g middle-hom
  middle-Hom2 = middle-composite .snd

  middle-simplex : О”ВІ вҶ’ О”В№ вҶ’ A
  middle-simplex = middle-Hom2 .fst

  middle-boundary
    : middle-simplex вҲҳ вҲӮО”ВІ-incl ~ make-вҲӮО”ВІ gвҮ’h fвҮ’g middle-hom
  middle-boundary = middle-Hom2 .snd

  left-face-middle-simplex : О”ВІ вҶ’ A
  left-face-middle-simplex Пғ = middle-simplex Пғ (Poly.О”ВІ.t Пғ)

  right-face-middle-simplex : О”ВІ вҶ’ A
  right-face-middle-simplex Пғ = middle-simplex Пғ (Poly.О”ВІ.s Пғ)

  triple-composite : Hom A a d
  triple-composite .HomбөҲ.hom t = middle-hom .HomбөҲ.hom t t
  triple-composite .HomбөҲ.hom0
    = happly (middle-hom .HomбөҲ.hom0) i0 вҲҷ f .HomбөҲ.hom0
  triple-composite .HomбөҲ.hom1
    = happly (middle-hom .HomбөҲ.hom1) i1 вҲҷ h .HomбөҲ.hom1
}

\p{The triple composite is the composite #{(h вҲҳ g) вҲҳ f}.}

\agda{
  left-horn-glue
    : ap (О» x вҶ’ make-вҲӮО”ВІ gвҮ’h fвҮ’g middle-hom (О№вӮҒ x) (Оӣ[2,1]-left-eval x)) Оӣ[2,1]-glue
    пјқ composite-square-target g f gf-composite i0
    вҲҷ sym (composite-square-source h g hg-composite i0)
  left-horn-glue
    = ap-diag-ev (make-вҲӮО”ВІ gвҮ’h fвҮ’g middle-hom вҲҳ О№вӮҒ) Оӣ[2,1]-left-eval Оӣ[2,1]-glue
    вҲҷ вҲҷ-reflrвҶҗloop-out-of-О”В№
        (make-вҲӮО”ВІ gвҮ’h fвҮ’g middle-hom (О№вӮҒ (О№вӮӮ i0)))
        (happly (ap (О» x вҶ’ make-вҲӮО”ВІ gвҮ’h fвҮ’g middle-hom (О№вӮҒ x)) Оӣ[2,1]-glue) i0)
    вҲҷ ap (О» q вҶ’ happly q i0) (horn-glue gвҮ’h fвҮ’g)
    вҲҷ happly-вҲҷ (fвҮ’g .HomбөҲ.hom1) (sym (gвҮ’h .HomбөҲ.hom0)) i0
    вҲҷ apвӮӮ _вҲҷ_
        (happly funext-redex i0)
        (happly-sym-at (gвҮ’h .HomбөҲ.hom0) i0 вҲҷ ap sym (happly funext-redex i0))

  left-horn-post
    : (О» x вҶ’ make-вҲӮО”ВІ gвҮ’h fвҮ’g middle-hom (О№вӮҒ x) (Оӣ[2,1]-left-eval x))
    ~ make-horn hg f
  left-horn-post
    = pushout-rec-unique _ _
        (composite-square-bottom g f gf-composite)
        (composite-square-diagonal h g hg-composite)
        ( О» _
          вҶ’ ap (_вҲҷ composite-square-diagonal h g hg-composite i0) left-horn-glue
          вҲҷ вҲҷ-assoc _ _ _
          вҲҷ ap (composite-square-target g f gf-composite i0 вҲҷ_)
               (composite-square-lower-left h g hg-composite)
          вҲҷ sym (вҲҷ-assoc _ _ _)
          вҲҷ ap (_вҲҷ sym (hg .HomбөҲ.hom0))
               (composite-square-lower-right g f gf-composite)
          вҲҷ вҲҷ-assoc _ _ _)

  left-boundary-post
    : (О» x вҶ’ make-вҲӮО”ВІ gвҮ’h fвҮ’g middle-hom x (вҲӮО”ВІ-left-eval x))
    ~ make-вҲӮО”ВІ hg f triple-composite
  left-boundary-post
    = pushout-rec-unique _ _
        left-horn-post
        ~refl
        О» where
          (mk-lift false)
            вҶ’ вҲҷ-reflr _
            вҲҷ ap-diag-ev (make-вҲӮО”ВІ gвҮ’h fвҮ’g middle-hom) вҲӮО”ВІ-left-eval (glue вҲӮО”В№-0)
            вҲҷ вҲҷ-reflrвҶҗloop-out-of-О”В№
                (make-вҲӮО”ВІ gвҮ’h fвҮ’g middle-hom (О№вӮӮ i0))
                (happly (ap (make-вҲӮО”ВІ gвҮ’h fвҮ’g middle-hom) (glue вҲӮО”В№-0)) i0)
            вҲҷ ap (О» q вҶ’ happly q i0) (pushout-rec-apОІ вҲӮО”В№-0)
            вҲҷ happly-вҲҷ (fвҮ’g .HomбөҲ.hom0) (sym (middle-hom .HomбөҲ.hom0)) i0
            вҲҷ apвӮӮ _вҲҷ_
                (happly funext-redex i0)
                (happly-sym-at (middle-hom .HomбөҲ.hom0) i0)
            вҲҷ ap (_вҲҷ sym (happly (middle-hom .HomбөҲ.hom0) i0))
                 (composite-square-sourceпјқbottom-i0 g f gf-composite)
            вҲҷ ap (_ вҲҷ_)
                 (sym (tail-sym-cancel (happly (middle-hom .HomбөҲ.hom0) i0)
                                       (f .HomбөҲ.hom0)))
          (mk-lift true)
            вҶ’ вҲҷ-reflr _
            вҲҷ ap-diag-ev (make-вҲӮО”ВІ gвҮ’h fвҮ’g middle-hom) вҲӮО”ВІ-left-eval (glue вҲӮО”В№-1)
            вҲҷ вҲҷ-reflrвҶҗloop-out-of-О”В№
                (make-вҲӮО”ВІ gвҮ’h fвҮ’g middle-hom (О№вӮӮ i1))
                (happly (ap (make-вҲӮО”ВІ gвҮ’h fвҮ’g middle-hom) (glue вҲӮО”В№-1)) i1)
            вҲҷ ap (О» q вҶ’ happly q i1) (pushout-rec-apОІ вҲӮО”В№-1)
            вҲҷ happly-вҲҷ (gвҮ’h .HomбөҲ.hom1) (sym (middle-hom .HomбөҲ.hom1)) i1
            вҲҷ apвӮӮ _вҲҷ_
                (happly funext-redex i1)
                (happly-sym-at (middle-hom .HomбөҲ.hom1) i1)
            вҲҷ ap (_ вҲҷ_)
                 (sym (tail-sym-cancel (happly (middle-hom .HomбөҲ.hom1) i1)
                                       (h .HomбөҲ.hom1)))
            вҲҷ sym (вҲҷ-assoc _ _ _)
            вҲҷ ap (_вҲҷ sym (happly (middle-hom .HomбөҲ.hom1) i1 вҲҷ h .HomбөҲ.hom1))
                 (composite-square-upper-right h g hg-composite)
            вҲҷ вҲҷ-assoc _ _ _

  left-triangle-triple-composite : Hom2 hg f triple-composite
  left-triangle-triple-composite .fst = left-face-middle-simplex
  left-triangle-triple-composite .snd x
    = happly (middle-boundary x) (вҲӮО”ВІ-left-eval x) вҲҷ left-boundary-post x
}

\p{The triple composite is the composite #{h вҲҳ (g вҲҳ f)}.}

\agda{
  right-horn-glue
    : ap (О» x вҶ’ make-вҲӮО”ВІ gвҮ’h fвҮ’g middle-hom (О№вӮҒ x) (Оӣ[2,1]-right-eval x)) Оӣ[2,1]-glue
    пјқ composite-square-target g f gf-composite i1
    вҲҷ sym (composite-square-source h g hg-composite i1)
  right-horn-glue
    = ap-diag-ev (make-вҲӮО”ВІ gвҮ’h fвҮ’g middle-hom вҲҳ О№вӮҒ) Оӣ[2,1]-right-eval Оӣ[2,1]-glue
    вҲҷ вҲҷ-reflrвҶҗloop-out-of-О”В№
        ((make-вҲӮО”ВІ gвҮ’h fвҮ’g middle-hom вҲҳ О№вӮҒ) (О№вӮӮ i0))
        (happly (ap (make-вҲӮО”ВІ gвҮ’h fвҮ’g middle-hom вҲҳ О№вӮҒ) Оӣ[2,1]-glue) i1)
    вҲҷ ap (О» q вҶ’ happly q i1) (horn-glue gвҮ’h fвҮ’g)
    вҲҷ happly-вҲҷ (fвҮ’g .HomбөҲ.hom1) (sym (gвҮ’h .HomбөҲ.hom0)) i1
    вҲҷ apвӮӮ _вҲҷ_
        (happly funext-redex i1)
        (happly-sym-at (gвҮ’h .HomбөҲ.hom0) i1 вҲҷ ap sym (happly funext-redex i1))

  right-horn-post
    : (О» x вҶ’ make-вҲӮО”ВІ gвҮ’h fвҮ’g middle-hom (О№вӮҒ x) (Оӣ[2,1]-right-eval x))
    ~ make-horn h gf
  right-horn-post
    = pushout-rec-unique _ _
        (composite-square-diagonal g f gf-composite)
        (composite-square-right h g hg-composite)
        ( О» _
          вҶ’ ap (_вҲҷ composite-square-right h g hg-composite i0) right-horn-glue
          вҲҷ вҲҷ-assoc _ _ _
          вҲҷ ap (composite-square-target g f gf-composite i1 вҲҷ_)
               (composite-square-upper-left h g hg-composite)
          вҲҷ sym (вҲҷ-assoc _ _ _)
          вҲҷ ap (_вҲҷ sym (h .HomбөҲ.hom0))
               (composite-square-upper-right g f gf-composite)
          вҲҷ вҲҷ-assoc _ _ _)

  right-boundary-post
    : (О» x вҶ’ make-вҲӮО”ВІ gвҮ’h fвҮ’g middle-hom x (вҲӮО”ВІ-right-eval x))
    ~ make-вҲӮО”ВІ h gf triple-composite
  right-boundary-post
    = pushout-rec-unique _ _
        right-horn-post
        ~refl
        О» where
          (mk-lift false)
            вҶ’ вҲҷ-reflr _
            вҲҷ ap-diag-ev (make-вҲӮО”ВІ gвҮ’h fвҮ’g middle-hom) вҲӮО”ВІ-right-eval (glue вҲӮО”В№-0)
            вҲҷ вҲҷ-reflrвҶҗloop-out-of-О”В№
                (make-вҲӮО”ВІ gвҮ’h fвҮ’g middle-hom (О№вӮӮ i0))
                (happly (ap (make-вҲӮО”ВІ gвҮ’h fвҮ’g middle-hom) (glue вҲӮО”В№-0)) i0)
            вҲҷ ap (О» q вҶ’ happly q i0) (pushout-rec-apОІ вҲӮО”В№-0)
            вҲҷ happly-вҲҷ (fвҮ’g .HomбөҲ.hom0) (sym (middle-hom .HomбөҲ.hom0)) i0
            вҲҷ apвӮӮ _вҲҷ_
                (happly funext-redex i0)
                (happly-sym-at (middle-hom .HomбөҲ.hom0) i0)
            вҲҷ ap (_ вҲҷ_)
                 (sym (tail-sym-cancel (happly (middle-hom .HomбөҲ.hom0) i0)
                                       (f .HomбөҲ.hom0)))
            вҲҷ sym (вҲҷ-assoc _ _ _)
            вҲҷ ap (_вҲҷ sym (happly (middle-hom .HomбөҲ.hom0) i0 вҲҷ f .HomбөҲ.hom0))
                 (double-transpose-вҲҷвҒ»В№ _ _ (f .HomбөҲ.hom0) (gf .HomбөҲ.hom0)
                   (composite-square-lower-left g f gf-composite))
            вҲҷ вҲҷ-assoc _ _ _
          (mk-lift true)
            вҶ’ вҲҷ-reflr _
            вҲҷ ap-diag-ev (make-вҲӮО”ВІ gвҮ’h fвҮ’g middle-hom) вҲӮО”ВІ-right-eval (glue вҲӮО”В№-1)
            вҲҷ вҲҷ-reflrвҶҗloop-out-of-О”В№
                (make-вҲӮО”ВІ gвҮ’h fвҮ’g middle-hom (О№вӮӮ i1))
                (happly (ap (make-вҲӮО”ВІ gвҮ’h fвҮ’g middle-hom) (glue вҲӮО”В№-1)) i1)
            вҲҷ ap (О» q вҶ’ happly q i1) (pushout-rec-apОІ вҲӮО”В№-1)
            вҲҷ happly-вҲҷ (gвҮ’h .HomбөҲ.hom1) (sym (middle-hom .HomбөҲ.hom1)) i1
            вҲҷ apвӮӮ _вҲҷ_
                (happly funext-redex i1)
                (happly-sym-at (middle-hom .HomбөҲ.hom1) i1)
            вҲҷ ap (_вҲҷ sym (happly (middle-hom .HomбөҲ.hom1) i1))
                 (composite-square-targetпјқright-i1 h g hg-composite)
            вҲҷ ap (_ вҲҷ_)
                 (sym (tail-sym-cancel (happly (middle-hom .HomбөҲ.hom1) i1)
                                       (h .HomбөҲ.hom1)))

  right-triangle-triple-composite : Hom2 h gf triple-composite
  right-triangle-triple-composite .fst = right-face-middle-simplex
  right-triangle-triple-composite .snd x
    = happly (middle-boundary x) (вҲӮО”ВІ-right-eval x)
    вҲҷ right-boundary-post x
}

\agda{
  middle-shuffle-composite
    :  ОЈ[ в„“ вҲ¶ Hom A a d ] (Hom2 (h вҲҳ[ рқҗҙ ] g) f в„“ Г— Hom2 h (g вҲҳ[ рқҗҙ ] f) в„“)
  middle-shuffle-composite
    = triple-composite
    , left-triangle-triple-composite
    , right-triangle-triple-composite
}
}

\subtree[fre-B849]{
\taxon{Theorem}
\author{fredrikbakke}
\date{2026-04-30}

\agda{
module _ {рқ“Ө : Level} {A : Type рқ“Ө} (рқҗҙ : is-segal A) where

  opaque
    вҲҳ-assocвҶҗis-segal
      : {a b c d : A}
      вҶ’ (h : Hom A c d)
      вҶ’ (g : Hom A b c)
      вҶ’ (f : Hom A a b)
      вҶ’ (h вҲҳ[ рқҗҙ ] g) вҲҳ[ рқҗҙ ] f пјқ h вҲҳ[ рқҗҙ ] (g вҲҳ[ рқҗҙ ] f)
    вҲҳ-assocвҶҗis-segal h g f =
      let open AssocProof рқҗҙ h g f
      in _вүғ_.fwd (Hom2вүғвҲҳпјқ рқҗҙ) left-triangle-triple-composite
       вҲҷ sym (_вүғ_.fwd (Hom2вүғвҲҳпјқ рқҗҙ) right-triangle-triple-composite)

вҲҳ[_]-assoc
  : {рқ“Ө : Level} {A : Type рқ“Ө} {a b c d : A} (рқҗҙ : is-segal A)
  вҶ’ {h : Hom A c d}
  вҶ’ {g : Hom A b c}
  вҶ’ {f : Hom A a b}
  вҶ’ (h вҲҳ[ рқҗҙ ] g) вҲҳ[ рқҗҙ ] f пјқ h вҲҳ[ рқҗҙ ] (g вҲҳ[ рқҗҙ ] f)
вҲҳ[ рқҗҙ ]-assoc {h} {g} {f} = вҲҳ-assocвҶҗis-segal рқҗҙ h g f
}
}

\subtree[fre-00OQ]{
\title{Associativity in precategories}
\date{2026-04-30}
\author{fredrikbakke}
\taxon{Corollary}

\agda{
module _
  {рқ“Ө : Level} {A : Type рқ“Ө} (рқҗҙвӮҡ : is-precategory A)
  (let рқҗҙ = is-segalвҶҗis-precategory рқҗҙвӮҡ)
  where

  вҲҳ-assocвҶҗis-precategory
    : {a b c d : A}
      (h : Hom A c d) (g : Hom A b c) (f : Hom A a b)
    вҶ’ (h вҲҳ[ рқҗҙ ] g) вҲҳ[ рқҗҙ ] f
    пјқ h вҲҳ[ рқҗҙ ] (g вҲҳ[ рқҗҙ ] f)
  вҲҳ-assocвҶҗis-precategory = вҲҳ-assocвҶҗis-segal рқҗҙ
}
}

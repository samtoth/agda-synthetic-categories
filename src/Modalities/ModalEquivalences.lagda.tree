\subtree[fre-LMAO]{
\taxon{Definition}
\title{Universal property of glboal subuniverse equivalences}

\p{
Given a global subuniverse #{K} and a map #{f : A \to B}, then #{f} is a
#{K}-\em{equivalence} if for every type #{U} in #{K},
the precomposition map #{U^f} is an equivalence.
}

% ```agda
\agda{
up-gmodal-equiv : тИА {╬▒ ЁЭУд ЁЭУе} (K : gSubU ╬▒)
                  тЖТ {A : Type ЁЭУд} {B : Type ЁЭУе}
                  тЖТ (A тЖТ B)
                  тЖТ Type╧Й
up-gmodal-equiv K f
  = тИА {ЁЭУЪ} {U : Type ЁЭУЪ}
  тЖТ U тИИ gSubU.S K
  тЖТ is-equiv (precomp U f)
}
%```
}

\subtree{
\date{2026-03-19}
\author{fredrikbakke}
\taxon{Lemma}
\title{3-for-2 for global subuniverse equivalences}

\p{
Global #{K}-equivalences satisfy the 3-for-2 property. Given a commuting triangle of
#{K}-equivalences, if two of the three maps are #{K}-equivalences then so is the
third.
}

% ```agda
\agda{
up-gmodal-equiv-тИШ
  : тИА {╬▒ ЁЭУд ЁЭУе ЁЭУж}
      (K : gSubU ╬▒)
      {A : Type ЁЭУд} {B : Type ЁЭУе} {C : Type ЁЭУж}
      (f : A тЖТ B) (g : B тЖТ C)
    тЖТ up-gmodal-equiv K f
    тЖТ up-gmodal-equiv K g
    тЖТ up-gmodal-equiv K (g тИШ f)
up-gmodal-equiv-тИШ K f g fe ge UтИИK
  = is-equiv-тИШ (fe UтИИK) (ge UтИИK)

up-gmodal-equiv-right-cancel
  : тИА {╬▒ ЁЭУд ЁЭУе ЁЭУж}
      (K : gSubU ╬▒)
      {A : Type ЁЭУд} {B : Type ЁЭУе} {C : Type ЁЭУж}
      (f : A тЖТ B) (g : B тЖТ C)
    тЖТ up-gmodal-equiv K f
    тЖТ up-gmodal-equiv K (g тИШ f)
    тЖТ up-gmodal-equiv K g
up-gmodal-equiv-right-cancel K f g fe gfe UтИИK
  = 3-for-2 (fe UтИИK) (gfe UтИИK)

up-gmodal-equiv-left-cancel
  : тИА {╬▒ ЁЭУд ЁЭУе ЁЭУж}
      (K : gSubU ╬▒)
      {A : Type ЁЭУд} {B : Type ЁЭУе} {C : Type ЁЭУж}
      (f : A тЖТ B) (g : B тЖТ C)
    тЖТ up-gmodal-equiv K g
    тЖТ up-gmodal-equiv K (g тИШ f)
    тЖТ up-gmodal-equiv K f
up-gmodal-equiv-left-cancel K f g ge gfe UтИИK
  = 3-for-2' (ge UтИИK) (gfe UтИИK)
}
%```
}

\subtree{
\date{2026-03-19}
\author{fredrikbakke}
\taxon{Lemma}
\title{#{K}-equivalences are closed under retracts of arrows}

\p{
If #{f} is a retract of #{g} as an arrow, and #{g} is a global #{K}-equivalence,
then so is #{f}.
}

% ```agda
\agda{
up-gmodal-equivтЖРincoherent-retraction-arrow-map
  : тИА {╬▒ ЁЭУд ЁЭУе ЁЭУж ЁЭУЫ}
      (K : gSubU ╬▒)
      {A : Type ЁЭУд} {B : Type ЁЭУе} {f : A тЖТ B}
      {X : Type ЁЭУж} {Y : Type ЁЭУЫ} {g : X тЖТ Y}
      (F : Arrow-map f g)
    тЖТ incoherent-retraction-arrow-map F
    тЖТ up-gmodal-equiv K g
    тЖТ up-gmodal-equiv K f
up-gmodal-equivтЖРincoherent-retraction-arrow-map K {f = f} {g = g} F R ge UтИИK
  = is-equivтЖРretraction-equiv
      (precomp-square (R .fst) _)
      (precomp-incoh)
      (ge UтИИK)
  where
  precomp-incoh
    : incoherent-retraction-arrow-map (precomp-square (R .fst) _)
  precomp-incoh
    = precomp-square F _
    , ( (╬╗ a тЖТ ap (a тИШ_) (funextтЖТ (R .snd .snd)))
      , (╬╗ a тЖТ ap (a тИШ_) (funextтЖТ (R .snd .fst))))

up-gmodal-equivтЖРretraction-arrow-map
  : тИА {╬▒ ЁЭУд ЁЭУе ЁЭУж ЁЭУЫ}
      (K : gSubU ╬▒)
      {A : Type ЁЭУд} {B : Type ЁЭУе} {f : A тЖТ B}
      {X : Type ЁЭУж} {Y : Type ЁЭУЫ} {g : X тЖТ Y}
      (F : Arrow-map f g)
    тЖТ retraction-arrow-map F
    тЖТ up-gmodal-equiv K g
    тЖТ up-gmodal-equiv K f
up-gmodal-equivтЖРretraction-arrow-map K F R
  = up-gmodal-equivтЖРincoherent-retraction-arrow-map K F
      (R .fst , (R .snd .fst , R .snd .snd .fst))
}
%```
}

\subtree{
\date{2026-03-19}
\author{fredrikbakke}
\taxon{Lemma}
\title{Global subuniverse equivalences with local domain and codomain}

\p{
If a #{K}-equivalence has both domain and codomain in #{K}, then it is an actual
equivalence.
}

% ```agda
\agda{
is-equivтЖРup-gmodal-equiv-domain-codomain
  : тИА {╬▒ ЁЭУд ЁЭУе} (K : gSubU ╬▒)
      {A : Type ЁЭУд} {B : Type ЁЭУе}
      (f : A тЖТ B)
    тЖТ A тИИ gSubU.S K
    тЖТ B тИИ gSubU.S K
    тЖТ up-gmodal-equiv K f
    тЖТ is-equiv f
is-equivтЖРup-gmodal-equiv-domain-codomain K {A = A} {B = B} f AтИИK BтИИK feq
  = is-equivтЖРequiv-precomp-domain-codomain
      (feq {U = A} AтИИK)
      (feq {U = B} BтИИK)
}
%```
}

\subtree{
\date{2026-03-19}
\author{fredrikbakke}
\taxon{Module}
\title{Modal equivalences, given reflections of domains}

\p{
If #{f : A \to B} is a map between types with #{K}-reflections, then we say #{f} is
a #{K}-equivalence if its reflection is an equivalence.
}

\agda{
module gReflectorModalEquivalences
    {╬▒ ЁЭУд ЁЭУе} {GS : gSubU ╬▒}
    {A : Type ЁЭУд} {B : Type ЁЭУе}
    (RA : gReflector GS A)
    (RB : gReflector GS B) where
  open gSubU GS
  module A = gReflector RA
  module B = gReflector RB
  module F = gReflectorMap RA RB

  is-gmodal-equiv
    : (A тЖТ B) тЖТ Type _
  is-gmodal-equiv f = is-equiv (F.тЧЛтВБ f)

  precomp-тЧЛтВБ-is-equivтЖРup-gmodal-equiv
    : (f : A тЖТ B)
    тЖТ up-gmodal-equiv GS f
    тЖТ тИА {ЁЭУЪ} {U : Type ЁЭУЪ}
    тЖТ U тИИ S
    тЖТ is-equiv (precomp U (F.тЧЛтВБ f))
  precomp-тЧЛтВБ-is-equivтЖРup-gmodal-equiv f feq {U = U} UтИИS
    = 3-for-2
        (A.reflects UтИИS)
        (is-equiv~тИШ comm (feq UтИИS) (B.reflects UтИИS))
    where
    comm
      : precomp U A.╬╖ тИШ precomp U (F.тЧЛтВБ f)
      ~ precomp U f тИШ precomp U B.╬╖
    comm h = funextтЖТ ╬╗ a тЖТ ap h (F.тЧЛтВБ-╬▓ f a)

  is-gmodal-equivтЖРup-gmodal-equiv
    : (f : A тЖТ B)
    тЖТ up-gmodal-equiv GS f
    тЖТ is-gmodal-equiv f
  is-gmodal-equivтЖРup-gmodal-equiv f feq
    = is-equivтЖРequiv-precomp-domain-codomain
        (precomp-тЧЛтВБ-is-equivтЖРup-gmodal-equiv f feq A.тЧЛтИИS)
        (precomp-тЧЛтВБ-is-equivтЖРup-gmodal-equiv f feq B.тЧЛтИИS)

  up-gmodal-equivтЖРis-gmodal-equiv
    : (f : A тЖТ B)
    тЖТ is-gmodal-equiv f
    тЖТ up-gmodal-equiv GS f
  up-gmodal-equivтЖРis-gmodal-equiv f feq {U = U} UтИИS
    = 3-for-2' (B.reflects UтИИS)
        (homotopy-is-equiv
          {f = precomp U A.╬╖ тИШ precomp U (F.тЧЛтВБ f)}
          {g = precomp U f тИШ precomp U B.╬╖}
          comm
          (is-equiv-тИШ (A.reflects UтИИS) (precomp-equiv feq)))
    where
    comm
      : precomp U A.╬╖ тИШ precomp U (F.тЧЛтВБ f)
      ~ precomp U f тИШ precomp U B.╬╖
    comm h = funextтЖТ ╬╗ a тЖТ ap h (F.тЧЛтВБ-╬▓ f a)
}
%```
}

\subtree{
\date{2026-03-19}
\author{fredrikbakke}
\taxon{Module}

\agda{
module gRSubUModalEquivalences {╬▒} (RS : gRSubU ╬▒) where
  open gRSubU RS
  open ReflectiveClosureс╡Н RS
  open gRSubUEquivMap RS

  module RModal {ЁЭУд ЁЭУе} {A : Type ЁЭУд} {B : Type ЁЭУе}
    = gReflectorModalEquivalences
        (gReflectorтЖРgRSubU RS A)
        (gReflectorтЖРgRSubU RS B)

  open RModal public
}
%```
}

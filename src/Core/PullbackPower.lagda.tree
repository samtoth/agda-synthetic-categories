%```

\subtree[stt-00EN]{
\taxon{Construction}
\title{Dependent pullback power}
\author{fredrikbakke}

\p{
Given an [arrow](stt-00EE) #{f : A \to B} and a dependent arrow over it
#{g : (b : B) \to X(b) \to Y(b)}, then we may form the \em{dependent pullback power}
#{\pulldpow_f g} as the gap map in the square

\quiver{
\begin{tikzcd}
	(\Pi_{(b : B)} X(b)) && (\Pi_{(b : B)}Y(b)) \\
	& \Hom^\mathrm{d}(f, g) \\
	(\Pi_{(a : A)} X(f(a))) && (\Pi_{(a : A)}Y(f(a)))
	\arrow[from=1-1, to=1-3]
	\arrow[from=1-1, to=3-1]
	\arrow[from=1-3, to=3-3]
	\arrow[from=2-2, to=1-3]
	\arrow[from=2-2, to=3-1]
	\arrow[from=3-1, to=3-3]
	\arrow[dashed, from=1-1, to=2-2, "{\pulldpow_f g}"]
	\arrow[phantom, from=2-2, to=3-3, "\lrcorner" very near start]
\end{tikzcd}
}

where #{\Hom^\mathrm{d}(f, g)} is the type of
[dependent morphisms of arrows](stt-00EF).
}

%```agda
\agda{
module _ {ً‌“¤1 ً‌“¤2 ً‌“¤3 ً‌“¤4}
         {A : Type ً‌“¤1} {B : Type ً‌“¤2} (f : A â†’ B)
         {X : B â†’ Type ً‌“¤3} {Y : B â†’ Type ً‌“¤4} (g : (b : B) â†’ X b â†’ Y b) where

  خ ج‚ : ((b : B) â†’ X b) â†’ Arrow-خ  f g
  خ ج‚ l = mk-amap (precomp-خ  X f l) (postcomp-خ  g l) ~refl
}
%```
}

\subtree[stt-004D]{
\title{Pullback power}
\taxon{Construction}

\quiver{
\begin{tikzcd}
	A && C \\
	\\
	B && D
	\arrow[dashed, from=1-1, to=1-3]
	\arrow["f"', from=1-1, to=3-1]
	\arrow["g", from=1-3, to=3-3]
	\arrow["l"{description}, from=3-1, to=1-3]
	\arrow[dashed, from=3-1, to=3-3]
\end{tikzcd}
}

\p{Given a pair of arrows as above, any diagonal map
gives rise to a square for which it is trivially a lifting.}
\p{This is the nondependent case of the [dependent pullback power](stt-00EN).}

%```agda
\agda{
module _ {ً‌“¤ ً‌“¥ ً‌“¦ ً‌“œ}
         {A : Type ً‌“¤} {B : Type ً‌“¥} (f : A â†’ B)
         {C : Type ً‌“¦} {D : Type ً‌“œ} (f' : C â†’ D) where

  pullback-power : (B â†’ C) â†’ Arrow-map f f'
  pullback-power = خ ج‚ f (خ» _ â†’ f')

  infixl 40 âں¨_,_âں©
  âں¨_,_âں© = pullback-power

  pullback-power-lifts : (l : B â†’ C) â†’ Lift (pullback-power l)
  pullback-power-lifts l .Lift.lift = l
  pullback-power-lifts l .Lift.K = ~refl
  pullback-power-lifts l .Lift.L = ~refl
  pullback-power-lifts l .Lift.pastes = ~refl
}
%```

\p{The pullback power of #{f} with #{g} is sometimes written #{\pullpow{f}{g}}.}
}

\subtree[stt-004C]{
\title{Pullback power is a gap map}
\taxon{Theorem}

\p{The name pullback power comes from the fact that for any pair
of maps, we can define a square as follows:}

\quiver{
\begin{tikzcd}
	{C^B} && {C^A} \\
	\\
	{D^B} && {D^A}
	\arrow["{{-} \circ f}", from=1-1, to=1-3]
	\arrow["{g \circ {-}}"', from=1-1, to=3-1]
	\arrow["{g \circ {-}}", from=1-3, to=3-3]
	\arrow["{{-} \circ f}"', from=3-1, to=3-3]
\end{tikzcd}
}

\p{Then the gap map of this square is the [pullback power](stt-004D) in the
sense that the following triangle commutes.}

\quiver{
\begin{tikzcd}
	& {B \to C} \\
	\\
	{\Hom(f,g)} && {D^B\times_{D^A}C^A}
	\arrow["{\pullpow{f}{g}}"', from=1-2, to=3-1]
	\arrow["gap", from=1-2, to=3-3]
	\arrow["\sim"', from=3-1, to=3-3]
\end{tikzcd}
}

%```agda
\agda{
module _ {ً‌“¤ ً‌“¥ ً‌“¦ ً‌“œ} {A : Type ً‌“¤} {B : Type ً‌“¥}
         {C : Type ً‌“¦} {D : Type ً‌“œ} (f : A â†’ B)
         (g : C â†’ D)  where

  power-hom : Arrow-map (postcomp B g) (postcomp A g)
  power-hom .Arrow-map.top = precomp _ f
  power-hom .Arrow-map.bot = precomp _ f
  power-hom .Arrow-map.comm = ~refl

  pb-power-cone : Cone (mk-cospan (A â†’ D) (precomp _ f) (postcomp _ g)) (B â†’ C)
  pb-power-cone = snd (Coneâ†گArrow-map power-hom)

  pullback-gap~pullback-power :
    gap pb-power-cone ~ pullbackâ†گarrow' âˆک pullback-power f g
  pullback-gap~pullback-power f = ext! (~refl , ~refl , sym funext-refl)
}
%```
}

\subtree[stt-004L]{
% \title{The pullback power is an equiv  is a pullback}
\taxon{Corollary}

\p{For a pair of maps #{f} and #{g}, the following are equivalent:}
\ol{
\li{The [pullback power](stt-004D) of #{f} with #{g} is an equivalence}
\li{The square of \ref{stt-004C} is cartesian}
\li{The cone given by the pullback power is a pullback cone}
}

%```agda
\agda{
module _ {ً‌“¤ ً‌“¥ ً‌“¦ ً‌“œ}
         {A : Type ً‌“¤} {B : Type ً‌“¥} (f : A â†’ B)
         {C : Type ً‌“¦} {D : Type ً‌“œ} (g : C â†’ D) where

  power-pbâ†گpb-power-is-equiv : is-equiv (pullback-power f g)
                             â†’ is-pullbackد‰ _ (pb-power-cone f g)
  power-pbâ†گpb-power-is-equiv pb-eq = is-pullbackâ†گgap (pb-power-cone f g)
    (homotopy-is-equiv (pullback-gap~pullback-power f g ~âپ»آ¹)
                       (is-equiv-âˆک (Arrow-mapâ‰ƒpullback' ._â‰ƒ_.has-is-eqv)
                                   pb-eq))

  pb-power-is-equivâ†گpower-pb : is-pullbackد‰ _ (pb-power-cone f g)
                             â†’ is-equiv (pullback-power f g)
  pb-power-is-equivâ†گpower-pb pb = 3-for-2~ (pullback-gap~pullback-power f g)
                                           (Arrow-mapâ‰ƒpullback' ._â‰ƒ_.has-is-eqv)
                                           (gap-is-equivâ†گis-pullback _ pb)

  power-hom-cartesianâ†گpullback-power : is-equiv (pullback-power f g)
                                     â†’ is-cartesian (power-hom f g)
  power-hom-cartesianâ†گpullback-power ppeq
    = is-cartesianâ†گis-pullback (power-hom f g) lem where
    lem : is-pullbackد‰ _ (pb-power-cone f g)
    lem = power-pbâ†گpb-power-is-equiv ppeq

  pullback-powerâ†گpower-hom-cartesian : is-cartesian (power-hom f g)
                                     â†’ is-equiv (pullback-power f g)
  pullback-powerâ†گpower-hom-cartesian pb = 3-for-2~ {f = pullbackâ†گarrow'}
                                     (pullback-gap~pullback-power f g)
                                     (Arrow-mapâ‰ƒpullback' ._â‰ƒ_.has-is-eqv)
                                     gap-is-equiv where
    gap-is-equiv : is-equiv (gap (pb-power-cone f g))
    gap-is-equiv = gap-is-equivâ†گis-pullback _ (is-pullbackâ†گis-cartesian _ pb)
}
%```
}

\subtree[stt-004K]{

\subtree[stt-004P]{
\title{Fibres of the postcomposition map}
\taxon{Theorem}

%```agda
\agda{
fibre-postcompтЙГ
  : тИА {ЁЭУд ЁЭУе ЁЭУж} {A : Type ЁЭУд} {B : Type ЁЭУе}
      {C : Type ЁЭУж} (f : A тЖТ B) (h : C тЖТ B)
    тЖТ fibre (postcomp C f) h тЙГ  ╬а C (fibre f тИШ h)
fibre-postcompтЙГ f h = mkтЙГ fwd (is-equivтЖРqiso fwd-qiso) where
  fwd : fibre (postcomp _ f) h тЖТ ╬а _ (fibre f тИШ h)
  fwd (g , p) c = (g c , happly p c)

  fwd-qiso : quasi-iso fwd
  fwd-qiso .fst g = (fst тИШ g , funextтЖТ (snd тИШ g))
  fwd-qiso .snd .fst (h , p) = ╬г-pathтЖТ (refl , (_тЙГ_.╬╖ funextтЙГ p))
  fwd-qiso .snd .snd g
    = funextтЖТ (╬╗ a тЖТ ╬г-pathтЖТ ( refl
                             , happly (_тЙГ_.╬╡ funextтЙГ (snd тИШ g)) a)
                             )
}
%```
}

\subtree[stt-00JL]{
\title{Fibres of the composition of maps}
\taxon{Lemma}

%```agda
\agda{
fibre-тИШ
  : тИА {ЁЭУд ЁЭУе ЁЭУж} {A : Type ЁЭУд} {B : Type ЁЭУе} {C : Type ЁЭУж}
      {f : B тЖТ C} {g : A тЖТ B}
    тЖТ тИА a тЖТ fibre (f тИШ g) a тЙГ ╬г[ x тИ╢ fibre f a ] fibre g (fst x)
fibre-тИШ {f = f} {g = g} c = equivтЖРqiso qiso where
  qiso : fibre (f тИШ g) c тЙЕ ╬г (fibre f c) (╬╗ x тЖТ fibre g (fst x))
  qiso ._тЙЕ_.fwd (x , p) = ((g x , p) , (x , refl))
  qiso ._тЙЕ_.fwd-iso .fst ((x , p) , (y , refl)) = (y , p)
  qiso ._тЙЕ_.fwd-iso .snd .fst (a , refl) = refl
  qiso ._тЙЕ_.fwd-iso .snd .snd ((x , p) , (y , refl)) = refl
}
%```

\p{The following lemma is exercise 4.4 of \citek{HoTT}.}

%```agda
\agda{
unstable-octahedron-map
  : тИА {ЁЭУд ЁЭУе ЁЭУж} {A : Type ЁЭУд} {B : Type ЁЭУе} {C : Type ЁЭУж}
      (f : B тЖТ C) (g : A тЖТ B)
    тЖТ тИА b тЖТ fibre (f тИШ g) (f b) тЖТ fibre f (f b)
unstable-octahedron-map f g b (x , p) = (g x , p)

fibre-unstable-octahedron
  : тИА {ЁЭУд ЁЭУе ЁЭУж} {A : Type ЁЭУд} {B : Type ЁЭУе} {C : Type ЁЭУж}
      {f : B тЖТ C} {g : A тЖТ B}
    тЖТ тИА a тЖТ fibre g a тЙГ fibre (unstable-octahedron-map f g a) (a , refl)
fibre-unstable-octahedron {f = f} {g} a ._тЙГ_.fwd (x , refl)
  = ((_ , refl) , refl)
fibre-unstable-octahedron {f = f} {g} a ._тЙГ_.has-is-eqv
  .is-equiv.qiso .fst (_ , refl)  = (_ , refl)
fibre-unstable-octahedron {f = f} {g} a ._тЙГ_.has-is-eqv
  .is-equiv.qiso .snd .fst (_ , refl) = refl
fibre-unstable-octahedron {f = f} {g} a ._тЙГ_.has-is-eqv
  .is-equiv.qiso .snd .snd (_ , refl) = refl
fibre-unstable-octahedron {f = f} {g} a ._тЙГ_.has-is-eqv
  .is-equiv.coherent (_ , refl) = refl
}
%```
}

\subtree[fre-LMAB]{
\taxon{Definition}
\title{Universal property of #{K}-connected maps}

\p{
Given a global subuniverse #{K} and a map #{f : A \to B}, then #{f} satisfies the
\em{universal property of #{K}-connected maps} if for every #{K}-valued family of
types #{U} over #{B}, the dependent precomposition map
#{\prod_{b : B} U(b) \to \prod_{a : A} U(f(a))} is an equivalence.
}

\p{
We use the abbreviation \code{up} for "universal property".
}

% ```agda
\agda{
up-connected-map : вИА {ќ± рЭУ§ рЭУ•} (K : gSubU ќ±)
                    вЖТ {A : Type рЭУ§} {B : Type рЭУ•}
                    вЖТ (A вЖТ B)
                    вЖТ TypeѕЙ
up-connected-map K f
  = вИА {рЭУЪ} {U : _ вЖТ Type рЭУЪ}
  вЖТ (вИА b вЖТ U b вИИ gSubU.S K)
  вЖТ is-equiv (precomp-ќ† U f)

up-connected-!-fibre
  : вИА {ќ± рЭУ§ рЭУ•} (K : gSubU ќ±)
      {A : Type рЭУ§} {B : Type рЭУ•}
      (f : A вЖТ B)
  вЖТ TypeѕЙ
up-connected-!-fibre K f
  = вИА b вЖТ up-modal-equiv K (!: fibre f b)

up-connected-fibres
  : вИА {ќ± рЭУ§ рЭУ•} (K : gSubU ќ±)
      {A : Type рЭУ§} {B : Type рЭУ•}
      (f : A вЖТ B)
  вЖТ TypeѕЙ
up-connected-fibres K f
  = вИА b {рЭУЪ} {U : Type рЭУЪ}
    вЖТ U вИИ gSubU.S K
    вЖТ is-equiv (const U (fibre f b))
}
%```
}

\subtree[fre-1003]{
\date{2026-03-19}
\author{fredrikbakke}
\taxon{Definition}
\title{#{K}-Connected maps}

\p{
If #{K} is a reflective subuniverse, a map is \em{#{K}-connected} if all of its
fibres have contractible reflections.
}

\agda{
is-connected-map
  : вИА {ќ± рЭУ§ рЭУ•} (RS : gRSubU ќ±) {A : Type рЭУ§} {B : Type рЭУ•}
  вЖТ (A вЖТ B) вЖТ Type (рЭУ§ вКФ рЭУ•)
is-connected-map RS {B = B} f = (b : B) вЖТ is-connected RS (fibre f b)

is-connected-map' : вИА {рЭУ§ рЭУ• рЭУЬ} {A : Type рЭУ§} {B : Type рЭУ•}
                     {S : SubU (рЭУ§ вКФ рЭУ•) рЭУЬ}
                   вЖТ is-reflective S
                   вЖТ (A вЖТ B) вЖТ Type (рЭУ§ вКФ рЭУ•)
is-connected-map' {B = B} rfl f = (b : B) вЖТ is-connected' rfl (fibre f b)
}
%```
}

\subtree[stt-0A2A]{
\title{Modal units are connected iff the modality is #{\Sigma}-closed}
\taxon{Lemma}
\author{samueltoth}

%```agda
\agda{
ќЈ-is-connected
  : вИА {ќ±} (RS : gRSubU ќ±)
  вЖТ is-globally-ќ£-closed (gRSubU.GS RS)
  вЖТ вИА {рЭУ§}{A : Type рЭУ§}
  вЖТ is-connected-map RS (gRSubU.ќЈ RS {A = A})
ќЈ-is-connected RS Gќ£ {_} {A} x
  = mk-singl
      (ind {P = ќї x вЖТ вЧЛ (fibre ќЈ x)}
           (ќї _ вЖТ вЧЛвИИS) (ќї a вЖТ ќЈ (a , refl)) x)
      (ind (ќї _ вЖТ пЉЭвИИS вЧЛвИИS) ќї where (y , refl) вЖТ ind-ќ≤ _ _ y) where
  open gRSubU RS
  open gReflectiveClosure RS
  open gRSubUInduction RS Gќ£
}
%```
}

\subtree[stt-0A2B]{
\title{Connected maps are closed under composition and are right cancellable}
\taxon{Lemma}
\author{samueltoth}
\author{fredrikbakke}

% ```agda
\agda{
up-connected-map-вИШ
  : вИА {ќ± рЭУ§ рЭУ• рЭУ¶}
      (K : gSubU ќ±)
      {A : Type рЭУ§} {B : Type рЭУ•} {C : Type рЭУ¶}
      (f : A вЖТ B) (g : B вЖТ C)
  вЖТ up-connected-map K f
  вЖТ up-connected-map K g
  вЖТ up-connected-map K (g вИШ f)
up-connected-map-вИШ K f g fconn gconn UвИИK
  = is-equiv-вИШ (fconn (UвИИK вИШ g)) (gconn UвИИK)

up-connected-map-right-cancel
  : вИА {ќ± рЭУ§ рЭУ• рЭУ¶}
      (K : gSubU ќ±)
      {A : Type рЭУ§} {B : Type рЭУ•} {C : Type рЭУ¶}
      (f : A вЖТ B) (g : B вЖТ C)
  вЖТ up-connected-map K f
  вЖТ up-connected-map K (g вИШ f)
  вЖТ up-connected-map K g
up-connected-map-right-cancel K f g fconn gfconn UвИИK
  = 3-for-2 (fconn (UвИИK вИШ g)) (gfconn UвИИK)
}
%```

%```agda
\agda{
module _ {ќ±} (RS : gRSubU ќ±)
         where
  open gRSubU RS
  open gReflectiveClosure RS

  is-connected-map'-~
    : вИА {рЭУ§ рЭУ•} {A : Type рЭУ§} {B : Type рЭУ•} {f g : A вЖТ B} вЖТ f ~ g
      вЖТ is-connected-map RS f вЖТ is-connected-map RS g
  is-connected-map'-~ = funext-rec _ ќї where refl вЖТ id

  is-connected-mapвЖРis-equiv
    : вИА {рЭУ§ рЭУ•} {A : Type рЭУ§} {B : Type рЭУ•} {f : A вЖТ B}
      вЖТ is-equiv f вЖТ is-connected-map RS f
  is-connected-mapвЖРis-equiv feq b = вЧЛ-is-singleton (is-contr-mapвЖРis-equiv feq b)


module _ {ќ±} (RS : gRSubU ќ±)
         (Sќ£ : is-globally-ќ£-closed (gRSubU.GS RS))
         where
  open gRSubU RS
  open gReflectiveReasoning RS
  open gRSubUInduction RS Sќ£

  is-connected-map'-right-cancel-iff
    : вИА {рЭУ§ рЭУ• рЭУ¶} {A : Type рЭУ§} {B : Type рЭУ•} {C : Type рЭУ¶} {f : B вЖТ C}
        {g : A вЖТ B}
      вЖТ is-connected-map RS g
      вЖТ is-connected-map RS f
      вЗФ is-connected-map RS (f вИШ g)
  is-connected-map'-right-cancel-iff {f = f}{g} gconn
    = ( (ќї fc c вЖТ is-singleвЖРequiv-to-single (eqv c eвБї¬є) (fc c))
       , ќї fgc c вЖТ is-singleвЖРequiv-to-single (eqv c) (fgc c)) where
    eqv : вИА z вЖТ вЧЛ (fibre (f вИШ g) z) вЙГ вЧЛ (fibre f z)
    eqv z
      = вЧЛ (fibre (f вИШ g) z) вЙГвЯ® вЧЛ-вЙГ (fibre-вИШ z) вЯ©
        вЧЛ (ќ£ (fibre f z) (ќї x вЖТ fibre g (fst x)))
                            вЙГвЯ® mkвЙГ _ (ќ£вЧЛ-is-equiv RS _) вЯ©
        вЧЛ (ќ£ (fibre f z) (ќї x вЖТ вЧЛ (fibre g (fst x))))
                            вЙГвЯ® вЧЛ-вЙГ (ќ£-singleton (ќї x вЖТ gconn (fst x))) вЯ©
        вЧЛ (fibre f z)       вЙГвИО

  is-connected-map'-вИШ
    : вИА {рЭУ§ рЭУ• рЭУ¶} {A : Type рЭУ§} {B : Type рЭУ•} {C : Type рЭУ¶} {f : B вЖТ C}
        {g : A вЖТ B}
      вЖТ is-connected-map RS g
      вЖТ is-connected-map RS f
      вЖТ is-connected-map RS (f вИШ g)
  is-connected-map'-вИШ gc = is-connected-map'-right-cancel-iff gc .fst

  is-connected-mapвЖРis-arrow-equiv
    : вИА {рЭУ§ рЭУ• рЭУ¶ рЭУЬ} {A : Type рЭУ§} {B : Type рЭУ•} {X : Type рЭУ¶} {Y : Type рЭУЬ}
        {f : A вЖТ B} {g : X вЖТ Y}
      вЖТ (F : Arrow-map f g)
      вЖТ is-Arrow-equiv F
      вЖТ is-connected-map RS f
      вЖТ is-connected-map RS g
  is-connected-mapвЖРis-arrow-equiv {f = f} {g = g} F fe fconn
    = is-connected-map'-right-cancel-iff
        {f = g} {F .Arrow-map.top}
        (is-connected-mapвЖРis-equiv RS (fe .fst)) .snd
        (is-connected-map'-~ RS
          (F .Arrow-map.comm)
          (is-connected-map'-вИШ fconn (is-connected-mapвЖРis-equiv RS (fe .snd))))

  is-connected-mapвЖРis-arrow-equivвБї¬є
    : вИА {рЭУ§ рЭУ• рЭУ¶ рЭУЬ} {A : Type рЭУ§} {B : Type рЭУ•} {X : Type рЭУ¶} {Y : Type рЭУЬ}
        {f : A вЖТ B} {g : X вЖТ Y}
      вЖТ (F : Arrow-map f g)
      вЖТ (let module F = Arrow-map F)
      вЖТ is-Arrow-equiv F
      вЖТ is-connected-map RS g
      вЖТ is-connected-map RS f
  is-connected-mapвЖРis-arrow-equivвБї¬є F fe
    = is-connected-mapвЖРis-arrow-equiv
        (ArrowвБї¬євЖРis-Arrow-equiv F fe)
        (ArrowвБї¬є-is-equiv F fe)
}
%```
}

\subtree[stt-02AE]{
\author{fredrikbakke}
\author{samueltoth}
\taxon{Theorem}
\title{Connected maps are left orthogonal to modal maps}

% ```agda
\agda{
up-connected-mapвЗФorthogonal-map
  : вИА {ќ± рЭУ§ рЭУ•} (K : gSubU ќ±)
      {A : Type рЭУ§} {B : Type рЭУ•}
      (f : A вЖТ B)
  вЖТ up-connected-map K f
  вЖТ {рЭУ¶ рЭУЫ : Level} {C : Type рЭУ¶} {D : Type рЭУЫ}
    (g : C вЖТ D)
  вЖТ is-modal-map K g
  вЖТ are-orthogonal f g
up-connected-mapвЗФorthogonal-map K f fconn g gвИИK
  = orthogonalвЖРprecomp-ќ† ќї h вЖТ fconn (ќї b вЖТ gвИИK (h b))

up-connected-mapвЖРorthogonal-map
  : вИА {ќ± рЭУ§ рЭУ•} (K : gSubU ќ±)
      {A : Type рЭУ§} {B : Type рЭУ•}
      (f : A вЖТ B)
    вЖТ (вИА {рЭУ¶ рЭУЫ} {C : Type рЭУ¶} {D : Type рЭУЫ}
        (g : C вЖТ D)
        вЖТ is-modal-map K g
        вЖТ are-orthogonal f g)
    вЖТ up-connected-map K f
up-connected-mapвЖРorthogonal-map K f orth {U = U} UвИИK
  = is-equivвЖРArrow-equivвБї¬є {F = eq .fst} (eq .snd)
      (precomp-ќ†вЖРorthogonal id (orth fst fstвИИK)) where

  fstвИИK : is-modal-map K (fst {B = U})
  fstвИИK b = gSubU.вИИSвЖРequiv K (fibre-straighten U b eвБї¬є) (UвИИK b)

  eq = precomp-ќ†-straighten-Arrow-equiv U f
}
%```

% ```agda
\agda{
module _ {ќ±} (GR : gRSubU ќ±) where

  open gRSubU GR
  open gReflectiveClosure GR
  open gReflectiveReasoning GR

  connectedвК•modal : вИА {рЭУ§ рЭУ• рЭУ¶ рЭУЬ} {A : Type рЭУ§} {B : Type рЭУ•} {f : A вЖТ B}
                      {X : Type рЭУ¶} {Y : Type рЭУЬ} {g : X вЖТ Y}
                    вЖТ is-connected-map' (is-reflectiveвЖРgRSubU GR) f
                    вЖТ is-modal-map' S g
                    вЖТ f вК• g
  connectedвК•modal {f = f} {g = g} fconn gmod
    = orthogonalвЖРis-cartesian
        (ќї h вЖТ is-equivвЖРArrow-equivвБї¬є {F = amap h}
                 (amap-is-equiv h)
                 (up fconn (gmod вИШ h))) where
    up
      : is-connected-map' (is-reflectiveвЖРgRSubU GR) f
      вЖТ up-connected-map GS f
    up fconn {U = U} UвИИS
      = is-equiv-вИШ
          {f = fact1}
          fact1-is-equiv
          (postcomp-ќ†-equiv (ќї {b}
            вЖТ is-equiv-вИШ
                (reflects (UвИИS b))
                (is-equivвБї¬є (sing-ev-is-equiv global-funext (fconn b))))) where
      fact1 : (b : (вИА z вЖТ fibre f z вЖТ U z)) вЖТ (вИА a вЖТ U (f a))
      fact1 g a = g (f a) (a , refl)

      fact1-is-equiv : is-equiv fact1
      fact1-is-equiv = is-equivвЖРqiso
        ((ќї where g b (x , refl) вЖТ g x)
        , (ќї g вЖТ funextвЖТ (ќї b вЖТ funextвЖТ (ќї where (a , refl) вЖТ refl)) )
        , ~refl )

    amap : вИА h вЖТ Arrow-map (arrow-fibre (power-hom f g) h)
                           (precomp-ќ† (ќї b вЖТ fibre g (h b)) f)
    amap h .Arrow-map.top = fibre-postcompвЙГ g h ._вЙГ_.fwd
    amap h .Arrow-map.bot = fibre-postcompвЙГ g (h вИШ f) ._вЙГ_.fwd
    amap h .Arrow-map.comm (k , refl) = refl

    amap-is-equiv : вИА h вЖТ is-Arrow-equiv (amap h)
    amap-is-equiv h .fst = fibre-postcompвЙГ g h ._вЙГ_.has-is-eqv
    amap-is-equiv h .snd = fibre-postcompвЙГ g (h вИШ f) ._вЙГ_.has-is-eqv
}
%```
}

\subtree[fre-1004]{
\date{2026-03-20}
\author{fredrikbakke}
\taxon{Proposition}
\title{Closure properties of #{K}-connected maps}

\p{
Connected maps are stable under homotopies, retracts of arrows, and cobase change.
}

% ```agda
\agda{
up-connected-map-homotopy
  : вИА {ќ± рЭУ§ рЭУ•}
      (K : gSubU ќ±)
      {A : Type рЭУ§} {B : Type рЭУ•}
      {f g : A вЖТ B}
    вЖТ f ~ g
    вЖТ up-connected-map K f
    вЖТ up-connected-map K g
up-connected-map-homotopy K {f = f} {g = g} H fconn
  = up-connected-mapвЖРorthogonal-map K g ќї h hmodal
      вЖТ left-orthogonal-homotopy h H
          (up-connected-mapвЗФorthogonal-map K f fconn h hmodal)

up-connected-map-вИШ~
  : вИА {ќ± рЭУ§ рЭУ• рЭУ¶}
      (K : gSubU ќ±)
      {A : Type рЭУ§} {B : Type рЭУ•} {C : Type рЭУ¶}
      {h : A вЖТ C}
      (f : A вЖТ B) (g : B вЖТ C)
    вЖТ h ~ g вИШ f
    вЖТ up-connected-map K f
    вЖТ up-connected-map K g
    вЖТ up-connected-map K h
up-connected-map-вИШ~ K f g H fconn gconn
  = up-connected-map-homotopy K (H ~вБї¬є)
      (up-connected-map-вИШ K f g fconn gconn)

up-connected-map-right-cancel~
  : вИА {ќ± рЭУ§ рЭУ• рЭУ¶}
      (K : gSubU ќ±)
      {A : Type рЭУ§} {B : Type рЭУ•} {C : Type рЭУ¶}
      {h : A вЖТ C}
      (f : A вЖТ B) (g : B вЖТ C)
    вЖТ h ~ g вИШ f
    вЖТ up-connected-map K f
    вЖТ up-connected-map K h
    вЖТ up-connected-map K g
up-connected-map-right-cancel~ K f g H fconn hconn
  = up-connected-map-right-cancel K f g fconn
      (up-connected-map-homotopy K H hconn)

up-connected-mapвЖРretraction-arrow-map
  : вИА {ќ± рЭУ§ рЭУ• рЭУ¶ рЭУЫ}
      (K : gSubU ќ±)
      {A : Type рЭУ§} {B : Type рЭУ•} {f : A вЖТ B}
      {X : Type рЭУ¶} {Y : Type рЭУЫ} {g : X вЖТ Y}
      (F : Arrow-map f g)
    вЖТ retraction-arrow-map F
    вЖТ up-connected-map K g
    вЖТ up-connected-map K f
up-connected-mapвЖРretraction-arrow-map K {f = f} {g = g} F R gconn
  = up-connected-mapвЖРorthogonal-map K f ќї h hmodal
      вЖТ left-orthogonal-retraction f g F R h
          (up-connected-mapвЗФorthogonal-map K g gconn h hmodal)

up-connected-mapвЖРcocartesian
  : вИА {ќ± рЭУ§ рЭУ• рЭУ¶ рЭУЫ}
      (K : gSubU ќ±)
      {A : Type рЭУ§} {B : Type рЭУ•} {f : A вЖТ B}
      {X : Type рЭУ¶} {Y : Type рЭУЫ} {g : X вЖТ Y}
      (F : Arrow-map f g)
    вЖТ is-cocartesianѕЙ F
    вЖТ up-connected-map K f
    вЖТ up-connected-map K g
up-connected-mapвЖРcocartesian K {f = f} {g = g} F cocart fconn
  = up-connected-mapвЖРorthogonal-map K g ќї h hmodal
      вЖТ left-orthogonal-pushout F cocart h
          (up-connected-mapвЗФorthogonal-map K f fconn h hmodal)

up-connected-map-ќєвВВ
  : вИА {ќ± рЭУ§ рЭУ• рЭУ¶}
      (K : gSubU ќ±)
      {A : Type рЭУ§} {B : Type рЭУ•} {C : Type рЭУ¶}
      (f : A вЖТ B) (g : A вЖТ C)
    вЖТ up-connected-map K f
    вЖТ up-connected-map K (ќєвВВ {f = f} {g = g})
up-connected-map-ќєвВВ K f g
  = up-connected-mapвЖРcocartesian K
      (Pushout-square (mk-span _ f g))
      (Pushout-square-is-cocartesian (mk-span _ f g))
}
%```
}

\subtree[fre-1005]{
\date{2026-03-19}
\author{fredrikbakke}
\taxon{Lemma}
\title{#{K}-connected maps are #{K}-equivalences}

% ```agda
\agda{
up-modal-equivвЖРup-connected-map
  : вИА {ќ± рЭУ§ рЭУ•} (K : gSubU ќ±)
      {A : Type рЭУ§} {B : Type рЭУ•}
      (f : A вЖТ B)
  вЖТ up-connected-map K f
  вЖТ up-modal-equiv K f
up-modal-equivвЖРup-connected-map K f fconn UвИИK = fconn (ќї _ вЖТ UвИИK)

module gRSubUConnectedModalEquivalences {ќ±} (RS : gRSubU ќ±) where
  open gRSubU RS

}
%```

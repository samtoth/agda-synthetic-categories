    up-connected-!-fibreтЖРis-connected-map fconn
      = up-connected-!-fibresтЖРup-connected-fibres GS f
          (up-connected-fibresтЖРis-connected-map fconn)

    is-connected-mapтЖРup-connected-!-fibre
      : up-connected-!-fibre GS f
      тЖТ is-connected-map RS f
    is-connected-mapтЖРup-connected-!-fibre fibterm b
      = is-singleтЖРequiv-to-single
          (mkтЙГ (тЧЛтВБ (!: fibre f b))
            (is-modal-equivтЖРup-modal-equiv RS (fibterm b))

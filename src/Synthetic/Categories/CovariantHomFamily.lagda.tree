\subtree[stt-00D6]{
\title{Unstraightening hom families}
\taxon{Remark}

\p{The unstraightening of the family #{\Hom(x,-)} is #{X_{x/} \to X}. Thus
representable families are covariant iff #{X_{x/} \to X} are all left fibrations.}


%```agda
\agda{
hom-fam-is-covвҮ”is-left-fibration
  : вҲҖ {рқ“Ө} {X : Type рқ“Ө} x
  вҶ’ is-covariant (О» a вҶ’ Hom X x a)
  вҮ” is-left-fibration {A = Coslice X (point x)} fst
hom-fam-is-covвҮ”is-left-fibration x
  = is-covariantвҮ”is-left-fibration (О» a вҶ’ Hom _ x a)
  вҲҷвҮ” right-orthogonal-iffвҶҗequiv (О» _ вҶ’ i0) amap amap-eq where
  amap : Arrow-map (fst {B = О» c вҶ’ (i : рқҹҷ) вҶ’ Hom _ x c})
                   (fst {B = О» a вҶ’ Hom _ x a})
  amap .Arrow-map.top = total-map (О» a вҶ’ ev tt)
  amap .Arrow-map.bot = id
  amap .Arrow-map.comm = ~refl

  amap-eq : is-Arrow-equiv amap
  amap-eq .fst = is-total-equivвҶҗis-fibrewise-equiv (О» a вҶ’ unit-ev-is-equiv)
  amap-eq .snd = id-is-equiv
}
%```
}

\subtree[stt-00D9]{
\taxon{Therem}
\title{Covariance of representable families}

\p{We show that a type #{A} is [left Segal](stt-00DA) iff the family
#{\Hom(x,-)} is covariant for each #{x}.}

\proof{
We will show that every #{A_{x/} \to A} is a left fibration iff A is right
orthogonal to the map #{\Lambda^2_1 \to 1 \bjoin \Delta^1}.

\p{First we give an equivalence of arrows:}

\quiver{
\begin{tikzcd}
	{1\bjoin \Delta^1 \to_\bullet A} && {{A_{x/}}^{\Delta^1}} \\
	\\
	{\Lambda^2_1 \to_\bullet A} && {A^{\Delta^1} \times_A A_{x/}}
	\arrow["\sim", from=1-1, to=1-3]
	\arrow[from=1-1, to=3-1]
	\arrow[from=1-3, to=3-3]
	\arrow["\sim"', from=3-1, to=3-3]
\end{tikzcd}
}

\p{The top equivalence is given by the [join-coslice adjunction](stt-00D5), and
the bottom via the universal property of the horn.}


\p{Now we use \ref{stt-00DC} to finish the proof.}
}

\closedScope{
\subtree[stt-00DD]{
\title{The bottom equivalence}
%```agda
\agda{
char-coslice-lift : вҲҖ {рқ“Ө} {A : Type рқ“Ө} x
      вҶ’ Arrow-map (point i0) {C = Coslice A (point x)} (fst)
      вҶ’ Coslice-map {X = Оӣ[2,1]} (О» _ вҶ’ О№вӮҒ i0) (point x)
char-coslice-lift x (mk-amap top bot comm)
  = cogap (mk-cocone (top tt .snd tt .HomбөҲ.hom)
                     bot
                     (О» c вҶ’ top tt .snd tt .HomбөҲ.hom1 вҲҷ sym (comm c)))
  , О» _ вҶ’ HomбөҲ.hom0 (top tt .snd tt)

opaque
  char-coslice-lift-is-equiv
    : вҲҖ {рқ“Ө} {A : Type рқ“Ө} x
    вҶ’ is-equiv (char-coslice-lift {A = A} x)
  char-coslice-lift-is-equiv x = is-equivвҶҗqiso qiso where
    qiso : quasi-iso (char-coslice-lift x)
    qiso .fst (a , b) = mk-amap (О» _ вҶ’ _ , (О» _ вҶ’ mk-hom (a вҲҳ О№вӮҒ) (b tt) refl))
                                (a вҲҳ О№вӮӮ)
                                (ap a вҲҳ sym вҲҳ glue)
    qiso .snd .fst (mk-amap top bot comm)
      = let pth = ( top tt .snd tt .HomбөҲ.hom1
                  , О» i вҶ’ ( ~refl
                          , Square-degen-vert _ _ refl
                          , Square-flatten-hor refl))
        in Arrow-map-pathвҶ’
          ( (О» a вҶ’ Coslice-pathвҶ’ pth)
          , (~refl
          , О» _ вҶ’ ap (_вҲҷ ap fst (Coslice-pathвҶ’ pth))
                    (ap-sym _ (glue tt) вҲҷ ap sym (pushout-rec-apОІ tt))
                вҲҷ ap (sym (HomбөҲ.hom1 (top tt .snd tt) вҲҷ sym (comm tt)) вҲҷ_)
                     (Coslice-path-ap-fst pth)
                вҲҷ ap (_вҲҷ top tt .snd tt .HomбөҲ.hom1) (вҲҷ-symsym _ (sym (comm tt)))
                вҲҷ вҲҷ.cancell _  (вҲҷ-sym' (HomбөҲ.hom1 (top tt .snd tt)))
                               {f = sym (sym (comm tt))}
                вҲҷ sym-sym ))
    qiso .snd .snd (a , p)
      = ext! ( sym вҲҳ pushout-rec-unique _ _ ~refl ~refl
                      (О» _ вҶ’ вҲҷ-reflr _ вҲҷ sym (ap sym (ap-sym a _) вҲҷ sym-sym))
             , ~refl)
}
%```
}
}

%```agda
\agda{
coslice-is-leftвҮ”left-inner-coslice
  : вҲҖ {рқ“Ө} {A : Type рқ“Ө} x
  вҶ’ is-left-fibration {A = Coslice A (point x)} fst
  вҮ” (is-equiv (Coslice-map-precompose (point x) Оӣ[2,1]-inclв—…вҲҷ))
coslice-is-leftвҮ”left-inner-coslice x
  = (orthogonalвҮ”pb-power-is-equiv вҮ”вҒ»В№)
  вҲҷвҮ” topвҮ”bot-is-equivвҶҗArrow-equiv amap amap-eq module Cov-hom where
  amap : Arrow-map (pullback-power (О» _ вҶ’ i0) (О» r вҶ’ fst r))
                   (Coslice-map-precompose (О» _ вҶ’ x) Оӣ[2,1]-inclв—…вҲҷ)
  amap .Arrow-map.top = joinвҶҗcoslice-map (О» _ вҶ’ x)
  amap .Arrow-map.bot = char-coslice-lift x
  amap .Arrow-map.comm f = ext!
    ( sym вҲҳ pushout-rec-unique _ _ ~refl ~refl
          (О» a вҶ’ ap (_вҲҷ refl) ( ap-вҲҳ _ _ (glue a)
                              вҲҷ ap (ap (pushout-rec _)) (pushout-rec-apОІ a)
                              вҲҷ pushout-rec-apОІ _))
    , О» _ вҶ’ вҲҷ-reflr _ вҲҷ pushout-rec-apОІ _)

  amap-eq : is-Arrow-equiv amap
  amap-eq .fst = joinвҶҗcoslice-map-is-equiv (О» _ вҶ’ x)
  amap-eq .snd = char-coslice-lift-is-equiv x

hom-fam-is-covвҮ”is-left-segal
  : вҲҖ {рқ“Ө} {A : Type рқ“Ө}
    вҶ’ (вҲҖ x вҶ’ is-covariant (О» a вҶ’ Hom A x a))
    вҮ” is-left-segal A
hom-fam-is-covвҮ”is-left-segal {рқ“Ө}{A}
  =  postcomp-О -вҮ” (О»
       x вҶ’  hom-fam-is-covвҮ”is-left-fibration x
         вҲҷвҮ” coslice-is-leftвҮ”left-inner-coslice x)
  вҲҷвҮ” logicalвҶҗequiv (precomp-О -вүғ _ unit-UPвүғ)
  вҲҷвҮ” (coslice-orthogonality (Оӣ[2,1]-inclв—…вҲҷ) вҮ”вҒ»В№)
  вҲҷвҮ” logicalвҶҗequiv {рқ“Ҙ = рқ“ҳ вҠ” рқ“Ө} (unit-UPвүғ eвҒ»В№)

hom-fam-cov
  : {рқ“Ө : Level} {A : Type рқ“Ө} вҶ’ is-left-segal A вҶ’ (a : A) вҶ’ is-covariant (Hom A a)
hom-fam-cov = hom-fam-is-covвҮ”is-left-segal .snd
}
%```
}

\subtree[fre-B0C1]{
\title{A triangulated type is Segal iff #{\Hom(x,{-})} is covariant for all #{x}}
\taxon{corollary}
\author{samueltoth}
\author{fredrikbakke}

%```agda
\agda{
hom-fam-is-covвҮ”is-segalвҶҗtriangulated
  : вҲҖ {рқ“Ө} {A : Type рқ“Ө} вҶ’ is-triangulated A
    вҶ’ is-segal A вҮ” (вҲҖ x вҶ’ is-covariant (Hom A x))
hom-fam-is-covвҮ”is-segalвҶҗtriangulated Atri
  = (is-left-segalвҶҗis-segalвҶҗis-triangulated Atri , is-segalвҶҗis-left-segal)
  вҲҷвҮ” (hom-fam-is-covвҮ”is-left-segal вҮ”вҒ»В№)

coslice-is-leftвҮ”is-segalвҶҗtriangulated
  : вҲҖ {рқ“Ө} {A : Type рқ“Ө} вҶ’ is-triangulated A
    вҶ’ is-segal A вҮ” (вҲҖ x вҶ’ is-left-fibration {A = Coslice A (point x)} fst)
coslice-is-leftвҮ”is-segalвҶҗtriangulated Atri
  = hom-fam-is-covвҮ”is-segalвҶҗtriangulated Atri
  вҲҷвҮ” postcomp-О -вҮ” (О» a вҶ’ hom-fam-is-covвҮ”is-left-fibration a)
}
%```
}

\subtree[stt-00GB]{
\title{Characterisation of the covariant action of #{\Hom}}
\date{2026-03-20}
\author{fredrikbakke}
\taxon{Theorem}

\p{
Given a [left Segal](stt-00DA) type #{A}, the covariant action of
the family #{(a : A) \mapsto \Hom_A(a,{-})} is given by postcomposition.
}

\proof{
\p{
By [covariance of representable families](stt-00D9), the family
#{\Hom_A(a,-)} is covariant. Since [left Segal](stt-00DA) types are
[Segal](stt-00AI) by \ref{stt-00DB}, composition is unique. For
composable morphisms #{f : \Hom_A(a,b)} and #{g : \Hom_A(b,c)}, choose a 2-simplex
#{\sigma} witnessing their composition. Restricting that 2-simplex along the map
#{(s,t) \mapsto (s,s \wedge t)} produces a dependent homotopy over #{g} from #{f} to
#{g \circ f}. Since covariant transport is defined as the centre of the contractible
type of such dependent lifts, this point must coincide with the transport of #{f}
along #{g}. Hence transporting along #{g} sends #{f} to #{g \circ f}.
}
}

%```agda
\agda{
module CovariantActionPostcomp
  {рқ“Ө : Level} {A : Type рқ“Ө} (рқҗҙвӮ— : is-left-segal A)
  (let рқҗҙ = is-segalвҶҗis-left-segal рқҗҙвӮ—)
  where

  tr-cov-hom-is-comp
    : {a b c : A}
      (g : Hom A b c) (f : Hom A a b)
    вҶ’ tr-cov-hom (hom-fam-cov рқҗҙвӮ— _) g f
      пјқ g вҲҳ[ рқҗҙ ] f
  tr-cov-hom-is-comp {a} (mk-hom gh refl refl) f@(mk-hom fh refl fh1)
    = ap fst (hom-fam-cov рқҗҙвӮ— a gh f .central (gf , comp-hov))
    where
    g = mk-hom gh refl refl
    gf = g вҲҳ[ рқҗҙ ] f
    Пғ = вҲҳ[_]-is-composite {f = g} {g = f} рқҗҙ

    bd : (x : вҲӮО”ВІ) вҶ’ Пғ .fst (вҲӮО”ВІ-incl x) пјқ make-вҲӮО”ВІ g f gf x
    bd = Пғ .snd

    face2 : (s : О”В№) вҶ’ Пғ .fst (s , i0) пјқ fh s
    face2 s = bd (О№вӮҒ (О№вӮҒ s))

    face0 : (t : О”В№) вҶ’ Пғ .fst (i1 , t) пјқ gh t
    face0 t = bd (О№вӮҒ (О№вӮӮ t))

    diag : (s : О”В№) вҶ’ Пғ .fst (s , s) пјқ gf .HomбөҲ.hom s
    diag s = bd (О№вӮӮ s)

    wedge-hom : (t : О”В№) вҶ’ Hom A (fh i0) (gh t)
    wedge-hom t = mk-hom
      (О» s вҶ’ Пғ .fst ((s , s вҲ§ t) вҰғ вҲ§-вүӨ-eliml вүӨ-refl вҰ„))
      (ap (Пғ .fst) (О”ВІ-ext (refl , 0-init)) вҲҷ face2 i0)
      (ap (Пғ .fst) (О”ВІ-ext (refl , вҲ§-comm вҲҷ 1-top)) вҲҷ face0 t)

    horn-glue : О№вӮҒ {f = point i1} {g = point i0} i1
              пјқ О№вӮӮ i0
    horn-glue = glue tt

    horn-cocone : Cocone (mk-span рқҹҷ (point i1) (point i0)) A
    horn-cocone = mk-cocone fh gh (О» _ вҶ’ fh1 вҲҷ sym refl)

    diag-glue0
      : face2 i0
        пјқ (ap (Пғ .fst вҲҳ вҲӮО”ВІ-incl) (glue вҲӮО”В№-0) вҲҷ diag i0) вҲҷ gf .HomбөҲ.hom0
    diag-glue0
      = sym (homotopy-cancel bd (glue вҲӮО”В№-0))
      вҲҷ ap ((ap (Пғ .fst вҲҳ вҲӮО”ВІ-incl) (glue вҲӮО”В№-0) вҲҷ diag i0) вҲҷ_)
           (ap sym (pushout-rec-apОІ вҲӮО”В№-0)
           вҲҷ ap sym (вҲҷ-refll (sym (gf .HomбөҲ.hom0)))
           вҲҷ sym-sym)

    diag-glue1
      : face0 i1
        пјқ (ap (Пғ .fst вҲҳ вҲӮО”ВІ-incl) (glue вҲӮО”В№-1) вҲҷ diag i1) вҲҷ gf .HomбөҲ.hom1
    diag-glue1
      = sym (homotopy-cancel bd (glue вҲӮО”В№-1))
      вҲҷ ap ((ap (Пғ .fst вҲҳ вҲӮО”ВІ-incl) (glue вҲӮО”В№-1) вҲҷ diag i1) вҲҷ_)
           (ap sym (pushout-rec-apОІ вҲӮО”В№-1)
           вҲҷ ap sym (вҲҷ-refll (sym (gf .HomбөҲ.hom1)))
           вҲҷ sym-sym)

    comp-hov-hom0-path : Hom-path (wedge-hom i0) f
    comp-hov-hom0-path
      = ( (О» s вҶ’ ap (Пғ .fst) (О”ВІ-ext (refl , вҲ§-comm вҲҷ 0-init)) вҲҷ face2 s)
        , вҲҷ-reflr _ вҲҷ ap (О» p вҶ’ ap (Пғ .fst) p вҲҷ face2 i0) (О”ВІ-is-set _ _ _ _)
        , вҲҷ-assoc (ap (Пғ .fst) (О”ВІ-ext (refl , вҲ§-comm вҲҷ 0-init))) (face2 i1) fh1
          вҲҷ ap (ap (Пғ .fst) (О”ВІ-ext (refl , вҲ§-comm вҲҷ 0-init)) вҲҷ_)
                (ap (face2 i1 вҲҷ_)
                    (sym (вҲҷ-reflr fh1)
                    вҲҷ sym (pushout-rec-apОІ {c = horn-cocone} tt)
                    вҲҷ ap-вҲҳ (make-вҲӮО”ВІ g f gf) вҲӮО”ВІвҶҗОӣ[2,1] horn-glue)
                вҲҷ homotopy-natural bd (ap вҲӮО”ВІвҶҗОӣ[2,1] horn-glue))
          вҲҷ sym (вҲҷ-assoc (ap (Пғ .fst) (О”ВІ-ext (refl , вҲ§-comm вҲҷ 0-init)))
                          (ap (Пғ .fst вҲҳ вҲӮО”ВІ-incl) (ap вҲӮО”ВІвҶҗОӣ[2,1] horn-glue))
                          (face0 i0))
          вҲҷ ap (_вҲҷ face0 i0)
               (ap (ap (Пғ .fst) (О”ВІ-ext (refl , вҲ§-comm вҲҷ 0-init)) вҲҷ_)
                    (ap-вҲҳ (Пғ .fst) вҲӮО”ВІ-incl (ap вҲӮО”ВІвҶҗОӣ[2,1] horn-glue))
               вҲҷ sym (ap-вҲҷ (Пғ .fst) (О”ВІ-ext (refl , вҲ§-comm вҲҷ 0-init))
                                     (ap вҲӮО”ВІ-incl (ap вҲӮО”ВІвҶҗОӣ[2,1] horn-glue)))
               вҲҷ ap (ap (Пғ .fst)) (О”ВІ-is-set _ _ _ _)))

    comp-hov-hom1-path : Hom-path (wedge-hom i1) gf
    comp-hov-hom1-path
      = ( (О» s вҶ’ ap (Пғ .fst) (О”ВІ-ext (refl , 1-top)) вҲҷ diag s)
        , вҲҷ-assoc (ap (Пғ .fst) (О”ВІ-ext (refl , 1-top))) (diag i0) (gf .HomбөҲ.hom0)
          вҲҷ ap (_вҲҷ (diag i0 вҲҷ gf .HomбөҲ.hom0))
               (ap (ap (Пғ .fst))
                   (О”ВІ-is-set _ _
                     (О”ВІ-ext (refl , 1-top))
                     (О”ВІ-ext (refl , 0-init) вҲҷ ap вҲӮО”ВІ-incl (glue вҲӮО”В№-0)))
               вҲҷ ap-вҲҷ (Пғ .fst) (О”ВІ-ext (refl , 0-init)) (ap вҲӮО”ВІ-incl (glue вҲӮО”В№-0))
               вҲҷ ap (ap (Пғ .fst) (О”ВІ-ext (refl , 0-init)) вҲҷ_)
                    (sym (ap-вҲҳ (Пғ .fst) вҲӮО”ВІ-incl (glue вҲӮО”В№-0))))
          вҲҷ вҲҷ-assoc (ap (Пғ .fst) (О”ВІ-ext (refl , 0-init)))
                    (ap (Пғ .fst вҲҳ вҲӮО”ВІ-incl) (glue вҲӮО”В№-0))
                    (diag i0 вҲҷ gf .HomбөҲ.hom0)
          вҲҷ ap (ap (Пғ .fst) (О”ВІ-ext (refl , 0-init)) вҲҷ_)
               (sym (вҲҷ-assoc (ap (Пғ .fst вҲҳ вҲӮО”ВІ-incl) (glue вҲӮО”В№-0))
                             (diag i0) (gf .HomбөҲ.hom0))
               вҲҷ sym diag-glue0)
        , вҲҷ-assoc (ap (Пғ .fst) (О”ВІ-ext (refl , 1-top))) (diag i1) (gf .HomбөҲ.hom1)
          вҲҷ ap (_вҲҷ (diag i1 вҲҷ gf .HomбөҲ.hom1))
               (ap (ap (Пғ .fst))
                   (О”ВІ-is-set _ _
                     (О”ВІ-ext (refl , 1-top))
                     (О”ВІ-ext (refl , вҲ§-comm вҲҷ 1-top) вҲҷ ap вҲӮО”ВІ-incl (glue вҲӮО”В№-1)))
               вҲҷ ap-вҲҷ (Пғ .fst)
                      (О”ВІ-ext (refl , вҲ§-comm вҲҷ 1-top))
                      (ap вҲӮО”ВІ-incl (glue вҲӮО”В№-1))
               вҲҷ ap (ap (Пғ .fst) (О”ВІ-ext (refl , вҲ§-comm вҲҷ 1-top)) вҲҷ_)
                    (sym (ap-вҲҳ (Пғ .fst) вҲӮО”ВІ-incl (glue вҲӮО”В№-1))))
          вҲҷ вҲҷ-assoc (ap (Пғ .fst) (О”ВІ-ext (refl , вҲ§-comm вҲҷ 1-top)))
                    (ap (Пғ .fst вҲҳ вҲӮО”ВІ-incl) (glue вҲӮО”В№-1))
                    (diag i1 вҲҷ gf .HomбөҲ.hom1)
          вҲҷ ap (ap (Пғ .fst) (О”ВІ-ext (refl , вҲ§-comm вҲҷ 1-top)) вҲҷ_)
               (sym (вҲҷ-assoc (ap (Пғ .fst вҲҳ вҲӮО”ВІ-incl) (glue вҲӮО”В№-1))
                             (diag i1) (gf .HomбөҲ.hom1))
               вҲҷ sym diag-glue1))

    comp-hov : HomбөҲ (Hom A (fh i0) вҲҳ gh) f gf
    comp-hov .HomбөҲ.hom = wedge-hom
    comp-hov .HomбөҲ.hom0 = Hom-extвҶ’ comp-hov-hom0-path
    comp-hov .HomбөҲ.hom1 = Hom-extвҶ’ comp-hov-hom1-path
}
%```
}

\date{2025-04-17}
\taxon{Module}
\title{Universal property of the [empty type](Foundations.Empty)}
\import{stt-macros}


% ```agda
\agda{
open import Foundations.Universes
open import Foundations.FunExt

module Foundations.EmptyUP (fe : FunExt-global) where

open import Foundations.Empty
open import Foundations.Unit
open import Foundations.Identity
open import Foundations.QuasiEquivalences
open import Foundations.CoherentEquivalences
open import Foundations.Sigma
open import Foundations.Functions
open import Foundations.EquivOfSingleton
open import Foundations.Singletons
}
% ```

\subtree[stt-002X]{
\taxon{Theorem}

% ```agda
\agda{
K¡-𝟙-is-equiv : ∀ {𝓤} {A : Type 𝓤} → is-equiv (point (¡: A))
K¡-𝟙-is-equiv = is-equiv←qinv qinv where
  qinv : quasi-inv _
  qinv .fst _ = _
  qinv .snd .fst _ = refl
  qinv .snd .snd f = WithFunExt-global.funext→ fe λ ()

K¡-sing-is-equiv : ∀ {𝓤 𝓥} {A : Type 𝓤} {B : Type 𝓥}
                   → is-singleton A
                   → is-equiv (λ (_ : A) → ¡: B)
K¡-sing-is-equiv s = is-equiv←qinv qinv where
  qinv : quasi-inv _
  qinv .fst _ = s .centre
  qinv .snd .fst a = s .central a
  qinv .snd .snd _ = WithFunExt-global.funext→ fe λ ()

∅-UP≃ : ∀ {𝓤} {A : Type 𝓤} → 𝟙 ≃ (∅ → A)
∅-UP≃ = mk≃ (λ _ → ¡) K¡-𝟙-is-equiv

∅-UP-sing : ∀ {𝓤} {A : Type 𝓤} → is-singleton (∅ → A)
∅-UP-sing = mk-singl ¡ λ x → WithFunExt-global.funext→ fe (λ ())
}
% ```
}

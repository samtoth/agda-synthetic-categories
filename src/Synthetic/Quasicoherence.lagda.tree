\date{2026-03-12}
\title{Quasicoherent Algebras}
\author{markwilliams}
\taxon{Module}
\import{stt-macros}

\agda{
open import Foundations.Universes
open import Algebra.Lattice
open import Algebra.Lattice.Instances.Polynomial
open import Algebra.Order.Monotone

module Synthetic.Quasicoherence
  {ūĚďė}
  (őĒ¬Ļ : Type ūĚďė)
  (I : Lattice őĒ¬Ļ)
  (I-distr : is-distributive I)
  (let I[x] = Free-Algebra I I-distr)
  (let module I[x] = Algebra (Free-Algebra I I-distr))
  where

open Lattice I renaming (0l to i0; 1l to i1)

open import Axioms.UF
}

\agda-imports{
\agda{
open import Synthetic.Directedness őĒ¬Ļ I

open import Foundations.Prelude


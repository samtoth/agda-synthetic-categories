\subtree[stt-00G4]{
\title{Equivalences are fully faithful}
\taxon{Lemma}
\date{2026-03-11}
\author{samueltoth}

\p{If #{F} is a family of equivalences, then so is the induced map on total-homs
#{\Sigma_{a,b}\Hom_A(a,b) \to \Sigma_{a',b'}\Hom_B(a',b')}. Since this map
is given by #{\Sigma_F \Sigma_F \textsf{ap-hom}(F)}, by the relevant 3 for 2
theorem, we have that the total is an equivalence, each #{F} is an equivalence so
#{\textsf{ap-hom}(F)} is also an equivalence.}

\agda{
module _ {ً‌“¤ ً‌“¥} {A : Type ً‌“¤} {B : Type ً‌“¥} where

  is-ff'â†گis-equiv
    : {f : A â†’ B} â†’ is-equiv f â†’ is-ff' f
  is-ff'â†گis-equiv {f = f} Fe {x} {y}
    = is-fibrewise-equivâ†گis-total-equiv (eq2 x) y where
    eq1 : is-equiv (total-map خ» a â†’ map-خ£ f خ» _ â†’ ap-hom f)
    eq1 = 3-for-2
            {f = total-map-fst f}
            (total-is-equivâ†گfst-is-equiv Fe)
            (ap-total-hom-is-equiv Fe)

    eq2 : âˆ€ a â†’ is-equiv (total-map خ» b â†’ ap-hom f {a} {b})
    eq2 a = 3-for-2 {f = total-map-fst f}
              (total-is-equivâ†گfst-is-equiv Fe)
              (is-fibrewise-equivâ†گis-total-equiv eq1 a)
}
}

\subtree[stt-00LV]{
\title{Equivalence of definitions of fully faithful maps}
\taxon{Theorem}
\author{fredrikbakke}
\date{2026-04-05}

\p{
The [orthogonality based](stt-00LR) and [action-on-homs based](stt-00G3) predicates
are equivalent.
}
\proof{
\p{
Let #{\iota : \partial\Delta^1 \hookrightarrow \Delta^1} be the boundary inclusion.
Given a map #{f : A \to B}, then we have an equivalence of arrows

\quiver{
\begin{tikzcd}
(\Delta^1 \to A) && \Sigma_{(x, y : A)}\Hom_A(x,y) \\
\\
\Hom_{\Arr}(\iota , f) && \Sigma_{(x, y : A)}\Hom_B(f(x),f(y))
\arrow["\sim", from=1-1, to=1-3]
\arrow["\pullpow{\iota}{f}", from=1-1, to=3-1]
\arrow["\sim", from=3-1, to=3-3]
\arrow["\Sigma\Sigma{\mathrm{ap\text{-}hom}_f}", from=1-3, to=3-3]
\end{tikzcd}
}

The left map is an equivalence iff #{f} is right orthogonal to the boundary inclusion
of #{\Delta^1}, and, since total maps are equivalences if and only if they're
fibrewise equivalences, the right map is an equivalence iff #{f}'s action on homs is
an equivalence.
}
}

\agda{
module CompareFF {ً‌“¤ ً‌“¥ : Level} {A : Type ً‌“¤} {B : Type ً‌“¥} (f : A â†’ B) where

  TotalHomâ†گarr-map-âˆ‚خ”آ¹-incl
    : Arrow-map âˆ‚خ”آ¹-incl f
    â†’ خ£[ x y âˆ¶ A ] Hom B (f x) (f y)
  TotalHomâ†گarr-map-âˆ‚خ”آ¹-incl F
    = ( F .Arrow-map.top âˆ‚خ”آ¹-0
      , F .Arrow-map.top âˆ‚خ”آ¹-1
      , mk-hom
          (F .Arrow-map.bot)
          (F .Arrow-map.comm âˆ‚خ”آ¹-0)
          (F .Arrow-map.comm âˆ‚خ”آ¹-1))

  arr-map-âˆ‚خ”آ¹-inclâ†گTotalHom
    : خ£[ x y âˆ¶ A ] Hom B (f x) (f y)
    â†’ Arrow-map âˆ‚خ”آ¹-incl f
  arr-map-âˆ‚خ”آ¹-inclâ†گTotalHom (x , y , h)
    = mk-amap (âˆ‚خ”آ¹-UPâ†’ (x , y)) (ext .fst) ext-comm
    where
    ext : Ext âˆ‚خ”آ¹-incl (make-âˆ‚خ”آ¹ (f y) (f x))
    ext = Homâ‰ƒExt-âˆ‚خ”آ¹-incl ._â‰ƒ_.fwd h

    ext-comm
      : precomp-خ  (خ» _ â†’ B) âˆ‚خ”آ¹-incl (ext .fst)
      ~ postcomp-خ  (خ» a â†’ f) (âˆ‚خ”آ¹-UPâ†’ (x , y))
    ext-comm a = ext .snd a âˆ™ sym (happly (fâˆکâˆ‚خ”آ¹-UPâ†’ï¼‌make-âˆ‚خ”آ¹ f x y) a)

  arr-map-âˆ‚خ”آ¹-inclâ†گTotalHom-sec
    : âˆ€ (x y : A) (h : Hom B (f x) (f y))
      â†’ (x , y , h) ï¼‌ TotalHomâ†گarr-map-âˆ‚خ”آ¹-incl (arr-map-âˆ‚خ”آ¹-inclâ†گTotalHom (x , y , h))
  arr-map-âˆ‚خ”آ¹-inclâ†گTotalHom-sec x y h@(mk-hom hh p0 p1)
    = خ£-pathâ†’
        ( refl
        , خ£-pathâ†’
            ( refl
            , Hom-extâ†’
                ( ~refl
                , ap (خ» q â†’ p0 âˆ™ sym q) (happly funext-redex âˆ‚خ”آ¹-0) âˆ™ âˆ™-reflr _
                , ap (خ» q â†’ p1 âˆ™ sym q) (happly funext-redex âˆ‚خ”آ¹-1) âˆ™ âˆ™-reflr _)))

  arr-map-âˆ‚خ”آ¹-inclâ‰ƒTotalHom
    : Arrow-map âˆ‚خ”آ¹-incl f
    â‰ƒ خ£[ x y âˆ¶ A ] Hom B (f x) (f y)
  arr-map-âˆ‚خ”آ¹-inclâ‰ƒTotalHom = equivâ†گqequiv qeqv where
    qeqv : Arrow-map âˆ‚خ”آ¹-incl f â‰ٹ (خ£[ x âˆ¶ A ] خ£[ y âˆ¶ A ] Hom B (f x) (f y))
    qeqv ._â‰ٹ_.fwd = TotalHomâ†گarr-map-âˆ‚خ”آ¹-incl
    qeqv ._â‰ٹ_.fwd-qinv .fst = arr-map-âˆ‚خ”آ¹-inclâ†گTotalHom
    qeqv ._â‰ٹ_.fwd-qinv .snd .fst F
      = Arrow-map-pathâ†’
          ( happly (âˆ‚خ”آ¹-UP-خ· (F .Arrow-map.top))
          , ~refl
          , خ» where
              âˆ‚خ”آ¹-0
                â†’ ap (خ» p â†’ (Arrow-خ .comm F âˆ‚خ”آ¹-0 âˆ™ sym p)
                          âˆ™ ap f (happly (âˆ‚خ”آ¹-UP-خ· (Arrow-خ .top F)) âˆ‚خ”آ¹-0))
                     (happly funext-redex âˆ‚خ”آ¹-0)
                âˆ™ ap (خ» p â†’ (Arrow-خ .comm F âˆ‚خ”آ¹-0 âˆ™ refl) âˆ™ ap f p)
                     (happly funext-redex âˆ‚خ”آ¹-0)
                âˆ™ âˆ™-reflr _
                âˆ™ âˆ™-reflr _
              âˆ‚خ”آ¹-1
                â†’ ap (خ» p â†’ (Arrow-خ .comm F âˆ‚خ”آ¹-1 âˆ™ sym p)
                          âˆ™ ap f (happly (âˆ‚خ”آ¹-UP-خ· (Arrow-خ .top F)) âˆ‚خ”آ¹-1))
                     (happly funext-redex âˆ‚خ”آ¹-1)
                âˆ™ ap (خ» p â†’ (Arrow-خ .comm F âˆ‚خ”آ¹-1 âˆ™ refl) âˆ™ ap f p)
                     (happly funext-redex âˆ‚خ”آ¹-1)
                âˆ™ âˆ™-reflr _
                âˆ™ âˆ™-reflr _)
    qeqv ._â‰ٹ_.fwd-qinv .snd .snd (x , y , h) = sym (arr-map-âˆ‚خ”آ¹-inclâ†گTotalHom-sec x y h)

  total-ap-hom
    : خ£[ x y âˆ¶ A ] Hom A x y
    â†’ خ£[ x y âˆ¶ A ] Hom B (f x) (f y)
  total-ap-hom = total-map خ» x â†’ total-map خ» y â†’ ap-hom f {x} {y}

  total-ap-hom-square
    : Arrow-map (pullback-power âˆ‚خ”آ¹-incl f) total-ap-hom
  total-ap-hom-square .Arrow-map.top = total-hom ._â‰ƒ_.fwd
  total-ap-hom-square .Arrow-map.bot = TotalHomâ†گarr-map-âˆ‚خ”آ¹-incl
  total-ap-hom-square .Arrow-map.comm l = refl

  total-ap-hom-square-is-equiv : is-Arrow-equiv total-ap-hom-square
  total-ap-hom-square-is-equiv
    = total-hom ._â‰ƒ_.fwd-is-equiv
    , arr-map-âˆ‚خ”آ¹-inclâ‰ƒTotalHom ._â‰ƒ_.fwd-is-equiv

module _ {ً‌“¤ ً‌“¥} {A : Type ً‌“¤} {B : Type ً‌“¥} {f : A â†’ B} where

  is-ff'â†گis-ff : is-ff f â†’ is-ff' f
  is-ff'â†گis-ff خ¹âٹ¥f {x} {y}
    = is-fibrewise-equivâ†گis-total-equiv
        (is-fibrewise-equivâ†گis-total-equiv
            (tgt-is-equivâ†گArrow-equiv

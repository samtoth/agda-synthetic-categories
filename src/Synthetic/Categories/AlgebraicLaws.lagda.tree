\subtree[stt-00GA]{
\title{Unit laws of composition}
\date{2026-03-20}
\author{fredrikbakke}
\taxon{Proposition}

\p{
In a [Segal type](stt-00AI), both unit laws for composition hold. Both follow from
uniqueness of composition together with reflexivity of
[left and right homotopies](stt-00CH).
}

\agda{
module _ {рЭУ§ : Level} {A : Type рЭУ§} {a b : A} (рЭРі : is-segal A) where

  opaque
    вИШ[_]-right-unit : {f : Hom A a b} вЖТ idH b вИШ[ рЭРі ] f пЉЭ f
    вИШ[_]-right-unit {f} = _вЙГ_.fwd (Hom2вЙГвИШпЉЭ рЭРі) (reflвЦµ~ f)

    вИШ[_]-left-unit : {f : Hom A a b} вЖТ f вИШ[ рЭРі ] idH a пЉЭ f
    вИШ[_]-left-unit {f} = _вЙГ_.fwd (Hom2вЙГвИШпЉЭ рЭРі) (refl~вЦµ f)

}
}

\subtree[stt-00G9]{
\title{Associativity of composition for left Segal types}
\date{2026-03-20}
\author{fredrikbakke}
\taxon{Corollary}

\p{
From functoriality of [covariant transport of postcomposition](stt-00GB), we derive
associativity of composition.
}

\p{
I believe I first saw this result mentioned by [[emilyriehl]], it might be
formalised in [[rzk-shott]] somewhere.
}

\agda{
module _
  {рЭУ§ : Level} {A : Type рЭУ§} (рЭРівВЧ : is-left-segal A)
  (let рЭРі = is-segalвЖРis-left-segal рЭРівВЧ)
  (let open CovariantActionPostcomp рЭРівВЧ)
  where

  вИШ-assocвЖРis-left-segal
    : {a b c d : A}
      (h : Hom A c d) (g : Hom A b c) (f : Hom A a b)
    вЖТ (h вИШ[ рЭРі ] g) вИШ[ рЭРі ] f
    пЉЭ h вИШ[ рЭРі ] (g вИШ[ рЭРі ] f)
  вИШ-assocвЖРis-left-segal h g f
    = (h вИШ[ рЭРі ] g) вИШ[ рЭРі ] f
        пЉЭвЯ® sym (tr-cov-hom-is-comp (h вИШ[ рЭРі ] g) f) вЯ©
      tr-cov-hom (hom-fam-cov рЭРівВЧ _) (h вИШ[ рЭРі ] g) f
        пЉЭвЯ® tr-cov-вИШ рЭРі (Hom A _) (hom-fam-cov рЭРівВЧ _) h g f вЯ©
      tr-cov-hom (hom-fam-cov рЭРівВЧ _) h (tr-cov-hom (hom-fam-cov рЭРівВЧ _) g f)
        пЉЭвЯ® ap (tr-cov-hom (hom-fam-cov рЭРівВЧ _) h) (tr-cov-hom-is-comp g f) вЯ©
      tr-cov-hom (hom-fam-cov рЭРівВЧ _) h (g вИШ[ рЭРі ] f)
        пЉЭвЯ® tr-cov-hom-is-comp h (g вИШ[ рЭРі ] f) вЯ©
      h вИШ[ рЭРі ] (g вИШ[ рЭРі ] f) вИО
}
}

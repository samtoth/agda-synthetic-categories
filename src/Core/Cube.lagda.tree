\subtree[stt-00B2]{
\title{Commuting cube}
\taxon{Definition}

\p{Given a pair of arrow maps #{F : f \to g} and #{G : h \to k}, we define the
type of commuting cubes, consisting of a quadruple of maps, fillers for each
of the resulting faces, and a coherence that fills in the solid area of the
cube. Alternatively, this data can be packages up as pair of arrow maps
#{L : f \to h} and #{R : g \to k} together with a homotopy of arrow maps
#{GL \sim RF}.}

\quiver{
\begin{tikzcd}[cramped]
	& X && Z \\
	A && C \\
	& Y && W \\
	B && D
	\arrow[from=1-2, to=1-4]
	\arrow[from=1-2, to=3-2]
	\arrow[from=1-4, to=3-4]
	\arrow[from=2-1, to=1-2]
	\arrow[from=2-1, to=2-3]
	\arrow[from=2-1, to=4-1]
	\arrow[from=2-3, to=1-4]
	\arrow[from=2-3, to=4-3]
	\arrow[from=3-2, to=3-4]
	\arrow[from=4-1, to=3-2]
	\arrow[from=4-1, to=4-3]
	\arrow[from=4-3, to=3-4]
\end{tikzcd}
}

\agda{
record Cube {ЁЭУд ЁЭУе ЁЭУж ЁЭУз ЁЭУЫ ЁЭУЬ ЁЭУЭ ЁЭУЮ}
            {A : Type ЁЭУд} {B : Type ЁЭУе} {f : A тЖТ B}
            {C : Type ЁЭУж} {D : Type ЁЭУз} {g : C тЖТ D}
            (F : Arrow-map f g)
            {X : Type ЁЭУЫ} {Y : Type ЁЭУЬ} {h  : X тЖТ Y}
            {Z : Type ЁЭУЭ} {W : Type ЁЭУЮ} {k : Z тЖТ W}
            (G : Arrow-map h k) : Type (ЁЭУд тКФ ЁЭУе тКФ ЁЭУж тКФ ЁЭУз тКФ ЁЭУЫ тКФ ЁЭУЬ тКФ ЁЭУЭ тКФ ЁЭУЮ) where
  constructor mk-cube
  module F = Arrow-map F
  module G = Arrow-map G
  field
    left : Arrow-map f h
    right : Arrow-map g k
    comm : Arrow-map-path (paste-squares G left) (paste-squares right F)

  module left = Arrow-map left
  module right = Arrow-map right

  topl : A тЖТ X
  topl = left .Arrow-map.top

  topr : C тЖТ Z
  topr = right .Arrow-map.top

  botl : B тЖТ Y
  botl = left .Arrow-map.bot

  botr : D тЖТ W
  botr = right .Arrow-map.bot

  bot : G.bot тИШ botl ~ botr тИШ F.bot
  bot = comm .snd .fst

  top : G.top тИШ topl ~ topr тИШ F.top
  top = comm .fst


  top-amap : Arrow-map F.top G.top
  top-amap .Arrow-map.top = topl
  top-amap .Arrow-map.bot = topr
  top-amap .Arrow-map.comm = top ~тБ╗┬╣

  bot-amap : Arrow-map F.bot G.bot
  bot-amap .Arrow-map.top = botl
  bot-amap .Arrow-map.bot = botr
  bot-amap .Arrow-map.comm = bot ~тБ╗┬╣

  fill-hex
    : тИА a тЖТ Hexagon
              (ap G.bot (left.comm a)) (G.comm (left.top a)) (ap k (top a))
              (bot (f a)) (ap right.bot (F.comm a)) (right.comm (F.top a))
  fill-hex a .Hexagon.un-hex
    = sym (тИЩ-assoc (ap G.bot (left.comm a)) _ (ap k (top a)))
    тИЩ comm .snd .snd a
}
}


\subtree[stt-00B3]{
\title{Cartesian commuting cubes preserve pullbacks}
\taxon{Theorem}

\p{Consider a commuting cube where the left and right squares are cartesian,}
\quiver{
\begin{tikzcd}[cramped]
	& X && Z \\
	A && C \\
	& Y && W \\
	B && D
	\arrow[from=1-2, to=1-4]
	\arrow[from=1-2, to=3-2]
	\arrow[from=1-4, to=3-4]
	\arrow[from=2-1, to=1-2]
	\arrow[from=2-1, to=2-3]
	\arrow[from=2-1, to=4-1]
	\arrow[from=2-3, to=1-4]
	\arrow[from=2-3, to=4-3]
	\arrow[from=3-2, to=3-4]
	\arrow[from=4-1, to=3-2]
	\arrow[from=4-1, to=4-3]
	\arrow[from=4-3, to=3-4]
\end{tikzcd}
}

\p{then the front square is cartesian if the back square is.}

\proof{
\p{Follows from the 3 for 2 property for cartesian squares.}
}


\agda{
front-cartesianтЖРcartesian-cube
  : тИА {ЁЭУд ЁЭУе ЁЭУж ЁЭУз ЁЭУЫ ЁЭУЬ ЁЭУЭ ЁЭУЮ}
      {A : Type ЁЭУд} {B : Type ЁЭУе} {f : A тЖТ B}
      {C : Type ЁЭУж} {D : Type ЁЭУз} {g : C тЖТ D}
      (F : Arrow-map f g)
      {X : Type ЁЭУЫ} {Y : Type ЁЭУЬ} {h  : X тЖТ Y}
      {Z : Type ЁЭУЭ} {W : Type ЁЭУЮ} {k : Z тЖТ W}
      (G : Arrow-map h k)
    тЖТ (cube : Cube F G) тЖТ let open Cube cube
    in is-cartesian left тЖТ is-cartesian right
    тЖТ is-cartesian G тЖТ is-cartesian F
front-cartesianтЖРcartesian-cube {f = f} F {k = k} G cube leftCart rightCart GCart
  = 3-for-2-cartesian
      comm
      (compose-cartesian GCart leftCart)
      rightCart where
  open Cube cube
}
}

\subtree[stt-00BP]{
\title{Equivalences of squares preserve pullbacks}
\taxon{Corollary}
\contributor{fredrikbakke}

\p{We define square-equivalences in the obvious way, just asking both the left
and right squares to be [arrow equivalences](stt-004R). Since arrow equivalences
are in particular cartesian squares, this result follows trivially from
\ref{stt-00B3}.}

\agda{
is-Cube-equiv
  : тИА {ЁЭУд ЁЭУе ЁЭУж ЁЭУз ЁЭУЫ ЁЭУЬ ЁЭУЭ ЁЭУЮ}
      {A : Type ЁЭУд} {B : Type ЁЭУе} {f : A тЖТ B}
      {C : Type ЁЭУж} {D : Type ЁЭУз} {g : C тЖТ D}
      {F : Arrow-map f g}
      {X : Type ЁЭУЫ} {Y : Type ЁЭУЬ} {h  : X тЖТ Y}
      {Z : Type ЁЭУЭ} {W : Type ЁЭУЮ} {k : Z тЖТ W}
      {G : Arrow-map h k}
    тЖТ Cube F G тЖТ Type (ЁЭУд тКФ ЁЭУе тКФ ЁЭУж тКФ ЁЭУз тКФ ЁЭУЫ тКФ ЁЭУЬ тКФ ЁЭУЭ тКФ ЁЭУЮ)
is-Cube-equiv ╬▒ = is-Arrow-equiv left ├Ч is-Arrow-equiv right where
  open Cube ╬▒

module _
  {ЁЭУд ЁЭУе ЁЭУж ЁЭУз ЁЭУЫ ЁЭУЬ ЁЭУЭ ЁЭУЮ}
  {A : Type ЁЭУд} {B : Type ЁЭУе}
  {C : Type ЁЭУж} {D : Type ЁЭУз}
  {X : Type ЁЭУЫ} {Y : Type ЁЭУЬ}
  {Z : Type ЁЭУЭ} {W : Type ЁЭУЮ}
  where

  opaque
    front-cartesianтЖРequiv-cube
      : {f : A тЖТ B} {g : C тЖТ D} {F : Arrow-map f g}
        {h : X тЖТ Y} {k : Z тЖТ W} {G : Arrow-map h k}
      тЖТ (╬▒ : Cube F G)
      тЖТ is-Cube-equiv ╬▒
      тЖТ is-cartesian G
      тЖТ is-cartesian F
    front-cartesianтЖРequiv-cube {F = F} {G = G} ╬▒ (le , re)
      = front-cartesianтЖРcartesian-cube
          F G ╬▒
          (is-cartesianтЖРis-equiv _ le)
          (is-cartesianтЖРis-equiv _ re)

    back-cartesianтЖРequiv-cube
      : {f : A тЖТ B} {g : C тЖТ D} {F : Arrow-map f g}
        {h : X тЖТ Y} {k : Z тЖТ W} {G : Arrow-map h k}
      тЖТ (╬▒ : Cube F G)
      тЖТ is-Cube-equiv ╬▒
      тЖТ is-cartesian F
      тЖТ is-cartesian G
    back-cartesianтЖРequiv-cube {F = F} {G = G} ╬▒ ╬▒e cart
      = right-cancel-cartesian
          {a = G} {left} {paste-squares right F}
          (Arrow-map-pathтЖРid (sym (Arrow-map-pathтЖТ comm)))
          (compose-cartesian (is-cartesianтЖРis-equiv right (╬▒e .snd)) cart)
          (╬▒e .fst)   where
      open Cube ╬▒

    frontтЗФback-cartesianтЖРequiv-cube
      : {f : A тЖТ B} {g : C тЖТ D} {F : Arrow-map f g}
        {h : X тЖТ Y} {k : Z тЖТ W} {G : Arrow-map h k}
      тЖТ (╬▒ : Cube F G)
      тЖТ is-Cube-equiv ╬▒
      тЖТ is-cartesian F
      тЗФ is-cartesian G
    frontтЗФback-cartesianтЖРequiv-cube ╬▒ eq
      = (back-cartesianтЖРequiv-cube ╬▒ eq , front-cartesianтЖРequiv-cube ╬▒ eq)
}

\agda{
module _
  {ЁЭУд ЁЭУе ЁЭУж ЁЭУз ЁЭУЫ ЁЭУЬ ЁЭУЭ ЁЭУЮ}
  {A : Type ЁЭУд} {B : Type ЁЭУе} {f : A тЖТ B}
  {C : Type ЁЭУж} {D : Type ЁЭУз} {g : C тЖТ D}
  {F : Arrow-map f g}
  {X : Type ЁЭУЫ} {Y : Type ЁЭУЬ} {h  : X тЖТ Y}
  {Z : Type ЁЭУЭ} {W : Type ЁЭУЮ} {k : Z тЖТ W}
  {G : Arrow-map h k}
  where

  opaque
    back-cartesianтЖРequiv-transpose-cube
      : (╬▒ : Cube (transpose-square F) (transpose-square G))
      тЖТ is-Cube-equiv ╬▒
      тЖТ is-cartesian F
      тЖТ is-cartesian G
    back-cartesianтЖРequiv-transpose-cube ╬▒ eq Fcart
      = untranspose-is-cartesian G
          (back-cartesianтЖРequiv-cube
            {F = transpose-square F}
            {G = transpose-square G}
            ╬▒ eq
            (transpose-is-cartesian F Fcart))

    front-cartesianтЖРequiv-transpose-cube
      : (╬▒ : Cube (transpose-square F) (transpose-square G))
      тЖТ is-Cube-equiv ╬▒
      тЖТ is-cartesian G
      тЖТ is-cartesian F
    front-cartesianтЖРequiv-transpose-cube ╬▒ eq Gcart
      = untranspose-is-cartesian F
          (front-cartesianтЖРequiv-cube
            {F = transpose-square F}
            {G = transpose-square G}
            ╬▒ eq
            (transpose-is-cartesian G Gcart))

    frontтЗФback-cartesianтЖРequiv-transpose-cube
      : (╬▒ : Cube (transpose-square F) (transpose-square G))
      тЖТ is-Cube-equiv ╬▒
      тЖТ is-cartesian F
      тЗФ is-cartesian G
    frontтЗФback-cartesianтЖРequiv-transpose-cube ╬▒ eq
      = ( back-cartesianтЖРequiv-transpose-cube ╬▒ eq
        , front-cartesianтЖРequiv-transpose-cube ╬▒ eq)
}
}

\subtree[stt-00BF]{
\taxon{Construction}
\title{Gap map square from cubes}

\p{There is a forgetful functor from the category of squares to the
category of cospan maps. On objects, we have already shown that [a square
is comprised of a cospan together with a cone over it](stt-002Z), now we give
(part of) the action on morhpisms: each cube gives rise to a
[map of cospans](stt-00BG).}

\agda{
module _ where
  open Cube
  cospan-mapтЖРcube
    : тИА {ЁЭУд ЁЭУе ЁЭУж ЁЭУз ЁЭУЫ ЁЭУЬ ЁЭУЭ ЁЭУЮ}
        {A : Type ЁЭУд} {B : Type ЁЭУе} {f : A тЖТ B}
        {C : Type ЁЭУж} {D : Type ЁЭУз} {g : C тЖТ D}
        {F : Arrow-map f g}
        {X : Type ЁЭУЫ} {Y : Type ЁЭУЬ} {h  : X тЖТ Y}
        {Z : Type ЁЭУЭ} {W : Type ЁЭУЮ} {k : Z тЖТ W}
        {G : Arrow-map h k}
      тЖТ (cube : Cube F G)
      тЖТ Cospan-map (ConeтЖРArrow-map F .fst) (ConeтЖРArrow-map G .fst)
  cospan-mapтЖРcube ╬▒ .Cospan-map.hтВБ = botl ╬▒
  cospan-mapтЖРcube ╬▒ .Cospan-map.hтВВ = botr ╬▒
  cospan-mapтЖРcube ╬▒ .Cospan-map.hтВГ = topr ╬▒
  cospan-mapтЖРcube ╬▒ .Cospan-map.H = bot ╬▒ ~тБ╗┬╣
  cospan-mapтЖРcube ╬▒ .Cospan-map.K = right.comm ╬▒
}

\p{Consequently, a map of squares (a cube) also induces a map of arrows between
the respective [gap maps](stt-003L).}

\agda{
gap-map-squareтЖРcube
  : тИА {ЁЭУд ЁЭУе ЁЭУж ЁЭУз ЁЭУЫ ЁЭУЬ ЁЭУЭ ЁЭУЮ}
      {A : Type ЁЭУд} {B : Type ЁЭУе} {f : A тЖТ B}
      {C : Type ЁЭУж} {D : Type ЁЭУз} {g : C тЖТ D}
      (F : Arrow-map f g)
      {X : Type ЁЭУЫ} {Y : Type ЁЭУЬ} {h  : X тЖТ Y}
      {Z : Type ЁЭУЭ} {W : Type ЁЭУЮ} {k : Z тЖТ W}
      (G : Arrow-map h k)
    тЖТ (cube : Cube F G)
    тЖТ Arrow-map (gap-mapтЖРsquare F) (gap-mapтЖРsquare G)
gap-map-squareтЖРcube F G ╬▒ .Arrow-map.top = ╬▒ .Cube.left.top
gap-map-squareтЖРcube F G ╬▒ .Arrow-map.bot = PullbackтВБ (cospan-mapтЖРcube ╬▒)
gap-map-squareтЖРcube {f = f} F {k = k} G
   ╬▒@(mk-cube L R (lc , rc , fill)) .Arrow-map.comm a
  = pullback-pathтЖТ ( ╬▒ .Cube.left.comm a
                   , sym (Cube.top ╬▒ a)
                   , un-square
                       (coe
                         (ap (╬╗ p тЖТ Square _ p _ _) (sym (ap-sym k (lc a))))
                         (Hexagon.Square-compress-left
                          (tr
                           (╬╗ p тЖТ
                             Hexagon (ap (Arrow-map.bot G) (Arrow-map.comm L a))
                                     (Arrow-map.comm G (Arrow-map.top L a))
                                     (ap k (lc a))
                                     p
                                     (ap (Arrow-map.bot R) (Arrow-map.comm F a))
                                     (Arrow-map.comm R (Arrow-map.top F a)))
                           (sym sym-sym)
                           (Cube.fill-hex ╬▒ a)))))
}

\subtree[stt-00BI]{
\taxon{Conjecture}

\p{This map is an equivalence.}
}
}

\subtree[stt-00BH]{
\taxon{Definition}
\title{Partially coherent retracts of squares}

\p{A fully coherent notion of retract for a cube #{\alpha : F \to G} involves a
lot of data:}

\ul{
\li{A cube #{\beta : G \to F}}
\li{A path of cubes #{\beta \alpha = 1} - which itself involves:
\ul{
\li{Paths #{\beta_{tl} \alpha_{tl} = 1}, for each corner of the squares}
\li{Such that the fillers of the resulting squares are also equal to #{1}}
\li{And the result of pasting the fillers of the whole cubes together results
in the filler of the identity cube.}
}
}
}

\p{Recall that a [cube induces a map of gap maps](stt-00BF). It follows that a retract
of cubes should induce a retract of [gap maps](stt-003L) (retracts are preserved by
all functors after all). In HoTT, a retract of maps contains extra coherence data,
namely that the squares paste together to form the identity; however, we also
define a notion of [incoherent retracts](stt-00BJ), which are enough for certain results
[such as the fact incoherent retracts preserve equivalence](stt-00BK). Correspondingly,
we define
a \strong{1-coherent} or \strong{partially coherent} retract of squares to be
a cube in the opposite direction, together with a retract of the top-left map
and a (fully-coherent) retract of the induced cospan map. We show that this data
induces an incoherent retract of the gap maps. Under the [above conjecture](stt-00BI),
we expect the type of 1-coherent cube retracts to be equivalent to the type
of incoherent retracts of gap maps (although this has not been formalised).}

\agda{
1-coherent-retraction-cube
  : тИА {ЁЭУд ЁЭУе ЁЭУж ЁЭУз ЁЭУЫ ЁЭУЬ ЁЭУЭ ЁЭУЮ}
      {A : Type ЁЭУд} {B : Type ЁЭУе} {f : A тЖТ B}
      {C : Type ЁЭУж} {D : Type ЁЭУз} {g : C тЖТ D}
      {F : Arrow-map f g}
      {X : Type ЁЭУЫ} {Y : Type ЁЭУЬ} {h  : X тЖТ Y}
      {Z : Type ЁЭУЭ} {W : Type ЁЭУЮ} {k : Z тЖТ W}
      {G : Arrow-map h k}
    тЖТ Cube F G
    тЖТ Type (ЁЭУд тКФ ЁЭУе тКФ ЁЭУж тКФ ЁЭУз тКФ ЁЭУЫ тКФ ЁЭУЬ тКФ ЁЭУЭ тКФ ЁЭУЮ)
1-coherent-retraction-cube {F = F} {G = G} ╬▒@(mk-cube L R p)
  = ╬г[ ╬▓ тИ╢ Cube G F ]
     (retraction-witness (Cube.topl ╬▒) (Cube.topl ╬▓)
      ├Ч
     retraction-witness-cospan (cospan-mapтЖРcube ╬▒) (cospan-mapтЖРcube ╬▓))
}

\proof{
The fact that the induced gap map square is a retract follows from the
fact that [pullbacks are functorial with respect to their cospan](stt-00BN).
}

\agda{
gap-map-square-retтЖРcube-partial-ret
  : тИА {ЁЭУд ЁЭУе ЁЭУж ЁЭУз ЁЭУЫ ЁЭУЬ ЁЭУЭ ЁЭУЮ}
      {A : Type ЁЭУд} {B : Type ЁЭУе} {f : A тЖТ B}
      {C : Type ЁЭУж} {D : Type ЁЭУз} {g : C тЖТ D}
      (F : Arrow-map f g)
      {X : Type ЁЭУЫ} {Y : Type ЁЭУЬ} {h  : X тЖТ Y}
      {Z : Type ЁЭУЭ} {W : Type ЁЭУЮ} {k : Z тЖТ W}
      (G : Arrow-map h k)
    тЖТ (cube : Cube F G)
    тЖТ (ret : 1-coherent-retraction-cube cube)
    тЖТ incoherent-retraction-arrow-map (gap-map-squareтЖРcube F G cube)
gap-map-square-retтЖРcube-partial-ret {g = g} F G ╬▒ (╬▓ , tlr , cspr)
  = (ret  , tlr ,  ret2) where
  open Cube
  ret : Arrow-map (gap-mapтЖРsquare G) (gap-mapтЖРsquare F)
  ret = gap-map-squareтЖРcube _ _ ╬▓


  ret-cspn : PullbackтВБ
            (cospan-map-compose (cospan-mapтЖРcube ╬▓) (cospan-mapтЖРcube ╬▒))
         ~ PullbackтВБ (id-cospan-map)
  ret-cspn
    = happly
        (ap PullbackтВБ {cospan-map-compose (cospan-mapтЖРcube ╬▓) _} {id-cospan-map}
          (ext! (cospan-retraction-is-cospan-retraction (cospan-mapтЖРcube ╬▒)
                                                  (cospan-mapтЖРcube ╬▓ , cspr))))

  ret2 : retraction-witness
           (gap-map-squareтЖРcube _ _ ╬▒ .Arrow-map.bot)
           (ret .Arrow-map.bot)
  ret2 = PullbackтВБ-тИШ (cospan-mapтЖРcube ╬▓) (cospan-mapтЖРcube ╬▒)
       ~тИЩ ret-cspn
       ~тИЩ PullbackтВБ-id
}
}

\subtree[stt-00BE]{
\title{Retracts of cartesian squares are cartesian}
\taxon{Corollary}

\p{Given a [1-coherent retract of squares](stt-00BH) #{F \hookrightarrow G}, if
#{G} is cartesian, then so is #{F}.}

\proof{This follows from the fact that [1-coherent retracts of squares induce
incoherent retracts of the respective gap maps](stt-00BH), and that [retracts of
equivalences are equivalences](stt-00BK)}


\agda{
opaque
  is-cartesianтЖР1-coherent-retraction-cube
    : тИА {ЁЭУд ЁЭУе ЁЭУж ЁЭУз ЁЭУЫ ЁЭУЬ ЁЭУЭ ЁЭУЮ}
        {A : Type ЁЭУд} {B : Type ЁЭУе} {f : A тЖТ B}
        {C : Type ЁЭУж} {D : Type ЁЭУз} {g : C тЖТ D}
        {F : Arrow-map f g}
        {X : Type ЁЭУЫ} {Y : Type ЁЭУЬ} {h  : X тЖТ Y}
        {Z : Type ЁЭУЭ} {W : Type ЁЭУЮ} {k : Z тЖТ W}
        {G : Arrow-map h k}
      тЖТ (cube : Cube F G)
      тЖТ 1-coherent-retraction-cube cube

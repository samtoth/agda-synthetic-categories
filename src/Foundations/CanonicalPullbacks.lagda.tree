}
% ```


\subtree[stt-003J]{
\taxon{Definition}
\title{The canonical pullback of a cospan}

\p{For any cospan #{B \xrightarrow{f} A \xleftarrow{g} C}, there exists a pullback
   cone defined as: #{(\Sigma_{(x : B)}\Sigma_{(y : C)}(f(x) = g(y)), \pi_1, \pi_2)}
   which we call the canonical pullback of #{f} and #{g}. It is written #{B \times_A C}.}

% ```agda
\agda{
module _ {𝓤 𝓥 𝓦} {A : Type 𝓤} {B : Type 𝓥} {C : Type 𝓦}
         (f : B → A) (g : C → A) where
 Pullback : Type (𝓤 ⊔ 𝓥 ⊔ 𝓦)
 Pullback = Σ[ x ∶ B ] Σ[ y ∶ C ] (f x ＝ g y)

 pullback : Cone (mk-cospan A f g) Pullback
 pullback = mk-cone fst (fst ∘ snd) (snd ∘ snd)

module pb {𝓤 𝓥 𝓦} {A : Type 𝓤} {B : Type 𝓥} {C : Type 𝓦}
          {f : B → A} {g : C → A}
       where open Cone (pullback f g) public renaming (i to π₁; j to π₂)
}
% ```
}

\subtree[stt-003L]{
\taxon{Definition}
\title{The gap map}

\p{
Given a cone #{C} over a cospan #{S}, we can define a map called the gap-map from
the apex of #{C} to the pullback of #{S}.
}

% ```agda
\agda{
gap : ∀ {𝓤 𝓥 𝓦} {A : Type 𝓤} {B : Type 𝓥} {C : Type 𝓦}
        {f : B → A} {g : C → A}
        {𝓜} {D : Type 𝓜}
      → Cone (mk-cospan A f g) D
      → D → Pullback f g
gap (mk-cone i j filler) d = (i d , j d , filler d)
}
% ```
}

\subtree[stt-003K]{
\taxon{Theorem}
\title{Canonical pullbacks are pullbacks}

\p{This either follows from noticing that the gap map on the pullback cone itself
is definitionally a section and a retraction of [cone-map](stt-003I), or from
repeatedly applying the universal property of sigma types:}

##{
\begin{align*}
  (Q \to \Sigma_{(x : B)}\Sigma_{(y : C)}(f(x) = g(y)))
    &\simeq \Sigma_{(i : Q \to B)}((q : Q) \to (\Sigma_{(y : C)}(f(i(q)) = g(y)))) \\
    &\simeq \Sigma_{(i : Q \to B)}\Sigma_{(j : Q \to C)}((q : Q) \to f(i(q)) = g(j(q))) \\
    &\simeq \textrm{Cone}_S(Q)
\end{align*}
}

% ```agda
\agda{
pullback-is-pullback : ∀ {𝓤 𝓥 𝓦} {A : Type 𝓤} {B : Type 𝓥} {C : Type 𝓦}
                         {f : B → A} {g : C → A}
                       → is-pullbackω (mk-cospan _ f g) (pullback f g)
pullback-is-pullback {f = f} {g = g} .is-pullbackω.has-is-pb Q
  = mk-eqv (gap , ~refl , ~refl) ~refl
}
% ```
}

\subtree[stt-003M]{
\taxon{Theorem}
\title{Pullbacks via the gap map}
\p{A cone #{D} is a pullback iff #{\textrm{gap}(D)} is an equivalence}

\proof{
\p{We need to show that for any #{Q}, #{\textrm{gap}(D) : D \toeq B \times_A C} is an
equivalence iff
#{\textrm{cone-map}(D) : (Q \to D) \to Cone_S(Q)} is.
We know that #{{-} \circ \textrm{gap}(D) : (Q \to D) \to (Q \to B \times_A C)} is an equivalence
iff the gap map is, so we use then use the fact canonical pullbacks are pullbacks and
[[Foundations.3for2]] to finish the proof. The situation can be summarised as follows:
}
\quiver{
\begin{tikzcd}
        {Q \to D} && {Q \to B \times_A C} \\
	\\
	& {\textrm{Cone}_S(Q)}
	\arrow["{{-} \circ \textrm{gap}(D)}", from=1-1, to=1-3]
	\arrow["{\textrm{cone-map}(D)}"'{pos=0.4}, from=1-1, to=3-2]
	\arrow["\sim", from=1-3, to=3-2]
\end{tikzcd}
}
}

% ```agda
\agda{
module WithFunExt-gap (FE : FE.FunExt-global) where
  open FE.WithFunExt-global FE
  open CE FE

  is-pullback←gap : ∀ {𝓤 𝓥 𝓦} {A : Type 𝓤} {B : Type 𝓥} {C : Type 𝓦}
                      {f : B → A} {g : C → A}
                      {𝓜} {D : Type 𝓜}
                      (C : Cone (mk-cospan _ f g) D)
                    → is-equiv (gap C)
                    → is-pullbackω (mk-cospan _ f g) C
  is-pullback←gap C ge@(mk-eqv bwd qi) .is-pullbackω.has-is-pb Q
    = is-equiv-∘ (pullback-is-pullback .is-pullbackω.has-is-pb Q)
                 (postcomp-equiv ge)

  gap-is-equiv←is-pullback : ∀ {𝓤 𝓥 𝓦}
                      {A : Type 𝓤} {B : Type 𝓥} {C : Type 𝓦}
                      {f : B → A} {g : C → A}
                      {𝓜} {D : Type 𝓜}
                      (C : Cone (mk-cospan _ f g) D)
                     → is-pullbackω (mk-cospan _ f g) C
                     → is-equiv (gap C)
  gap-is-equiv←is-pullback C Cpb
    = is-equiv←postcomp (gap C)
      λ {_} {Q} → 3-for-2 (pullback-is-pullback .is-pullbackω.has-is-pb Q)
                          (Cpb .is-pullbackω.has-is-pb Q)
}
% ```
}

\subtree[stt-003O]{
\taxon{Theorem}
\title{Fibres of projections}

\p{Given a cospan, #{A \xrightarrow{f} C \xleftarrow{g} B}, we can classify the fibres of maps #{\pi_1 : A \times_C B \to A} and #{\pi_2 : A \times_C B \to B}:}

##{ \fibre{\pi_1}{a} \simeq \fibre{g}{f(a)} \\
    \fibre{\pi_2}{b} \simeq \fibre{f}{g(a)}
}

\proof{
\p{This follows from [elementary properties of the #{\Sigma} type](Foundations.SigmaProperties): }
% ```agda
\agda{
module _ {𝓤 𝓥 𝓦} {A : Type 𝓤} {B : Type 𝓥} {C : Type 𝓦}
         (f : B → A) (g : C → A) where
  open pb {f = f} {g}

  fib-π₁ : ∀ b → fibre π₁ b ≃ fibre g (f b)
  fib-π₁ b
    = fibre π₁ b                                    ≃⟨⟩
      Σ[ p ∶ Pullback _ _ ] ((π₁ p) ＝ b)            ≃⟨ Σ-assoc ⟩
      (Σ[ b' ∶ B ]
        ((Σ[ c ∶ C ] (f b' ＝ g c)) × (b' ＝ b)))    ≃⟨ Σ-ap-≃ (λ b → ×-swap) ⟩
      Σ[ b' ∶ B ] ((b' ＝ b) ×
        (Σ[ c ∶ C ] (f b' ＝ g c)))                  ≃⟨ Σ-＝singl ⟩
      (Σ[ c ∶ C ] (f b ＝ g c))                      ≃⟨ Σ-ap-≃ (λ c → sym≃) ⟩
      fibre g (f b) ≃∎

  fib-π₂ : ∀ c → fibre π₂ c ≃ fibre f (g c)
  fib-π₂ c
    = fibre π₂ c                                    ≃⟨⟩
      Σ[ p ∶ Pullback _ _ ] ((π₂ p) ＝ c)            ≃⟨ Σ-assoc ⟩
      (Σ[ b ∶ B ]
        ((Σ[ p ∶ (Σ[ c' ∶ C ] (f b ＝ g c')) ]
          (fst p ＝ c))))                           ≃⟨ Σ-ap-≃ (λ b → Σ-assoc) ⟩
      (Σ[ b ∶ B ]
        ((Σ[ c' ∶ C ] ((f b ＝ g c') × (c' ＝ c)))))  ≃⟨ Σ-ap-≃ (λ b → Σ-ap-≃ (λ c → ×-swap)) ⟩
      (Σ[ b ∶ B ]
        ((Σ[ c' ∶ C ] ((c' ＝ c) × (f b ＝ g c')))))  ≃⟨ Σ-ap-≃ (λ b → Σ-＝singl) ⟩
      (Σ[ b ∶ B ] (f b ＝ g c ))                     ≃⟨⟩
      fibre f (g c) ≃∎
}
% ```
}
}

\subtree[fre-0415]{
\date{2026-03-10}
\author{fredrikbakke}
\taxon{Theorem}
\title{Fibres as pullbacks}

\p{
The [fibre](stt-000M) of a map #{f : A \to B} at an element #{b : B} is the pullback

\quiver{
\begin{tikzcd}
	\fibre{f}{b} && A \\
	\\
	1 && B
	\arrow[from=1-1, to=1-3]
	\arrow[from=1-1, to=3-1]
	\arrow["f", from=1-3, to=3-3]
	\arrow["b", from=3-1, to=3-3]
	\arrow[from=1-1, to=3-3, phantom, "\lrcorner" very near start]
\end{tikzcd}
}
}

% ```agda
\agda{
module _
  {𝓤 𝓥 : Level} {A : Type 𝓤} {B : Type 𝓥}
  (f : A → B) (b : B)
  where

  pullback-point-cone
    : Cone (mk-cospan _ (point b) f) (fibre f b)
  pullback-point-cone = mk-cone ! fst (sym ∘ snd)

  pullback-point-gap-is-equiv
    : is-equiv (gap pullback-point-cone)
  pullback-point-gap-is-equiv = mk-eqv (bwd , ret , sec) coh where
    bwd : Pullback (point b) f → fibre f b
    bwd (tt , a , p) = a , sym p
    ret : retraction-witness (gap pullback-point-cone) bwd
    ret (a , p) = Σ-path→ (refl , sym-sym {p = p})
    sec : section-witness (gap pullback-point-cone) bwd
    sec (tt , a , p) = Σ-path→ (refl , Σ-path→ (refl , sym-sym {p = p}))
    coh : qiso-coh (bwd , ret , sec)
    coh (a , refl) = refl

  fibre≃pullback-point
    : fibre f b ≃ Pullback (point b) f
  fibre≃pullback-point
    = mk≃ (gap pullback-point-cone)
          (pullback-point-gap-is-equiv)

  pullback-point≃fibre
    : Pullback (point b) f ≃ fibre f b
  pullback-point≃fibre = fibre≃pullback-point e⁻¹
}
% ```
}

\subtree[fre-6767]{
\date{2026-03-10}
\author{fredrikbakke}
\taxon{Theorem}
\title{Products as pullbacks}

\p{
The [cartesian product](stt-001C) of two types #{A \times B} is the pullback

\quiver{
\begin{tikzcd}
	A \times B && B \\
	\\
	A && 1
	\arrow[from=1-1, to=1-3]
	\arrow[from=1-1, to=3-1]
	\arrow[from=1-3, to=3-3]
	\arrow[from=3-1, to=3-3]
	\arrow[from=1-1, to=3-3, phantom, "\lrcorner" very near start]
\end{tikzcd}
}
}

% ```agda
\agda{
module _
  {𝓤 𝓥 : Level} {A : Type 𝓤} {B : Type 𝓥}
  where

  pullback-!-cone
    : Cone (mk-cospan 𝟙 (!: A) (!: B)) (A × B)
  pullback-!-cone = mk-cone fst snd (λ _ → refl)

  pullback-!-gap-is-equiv
    : is-equiv (gap pullback-!-cone)
  pullback-!-gap-is-equiv = mk-eqv (bwd , ~refl , sec) ~refl where
    bwd : Pullback (!: A) (!: B) → A × B
    bwd (x , y , p) = x , y

    sec : section-witness (gap pullback-!-cone) bwd
    sec (x , y , p)
      = Σ-path→
          ( refl
          , Σ-path→
            ( refl
            , is-set←is-single 𝟙-is-singleton tt tt refl p))

  ×≃pullback-!
    : A × B ≃ Pullback (!: A) (!: B)
  ×≃pullback-!
    = mk≃ (gap pullback-!-cone) pullback-!-gap-is-equiv
}
% ```
}


\subtree[fre-6169]{
\date{2026-03-10}
\author{fredrikbakke}
\taxon{Theorem}
\title{Retracts as pullbacks}

\p{
The type of [retracts](Foundations.Retract) #{A \to B \to A} can be presented as a
pullback, in fact, a fibre:

\quiver{
\begin{tikzcd}
\mathsf{retract}(A,B) && (A \to B) \times (B \to A) \\
\\
1 && A \to A
\arrow[from=1-1, to=1-3]
\arrow[from=1-1, to=3-1]
\arrow[from=1-3, to=3-3, "{-}\circ{-}"]
\arrow[from=3-1, to=3-3, "\id"]
\arrow[from=1-1, to=3-3, draw=none, "\lrcorner" very near start]
\end{tikzcd}
}
}

\agda{
module WithFunExt (FE : FE.FunExt-global) where
  open FE.WithFunExt-global FE
  open CE FE

  module _
    {𝓤 𝓥 : Level} {A : Type 𝓤} {B : Type 𝓥}
    where

    retract-cone
      : Cone
          (mk-cospan (A → A) (point id) comp-pair)
          (retract A B)
    retract-cone
      = mk-cone ! (λ (s , r , _) → (s , r)) (funext→ ∘ _~⁻¹ ∘ snd ∘ snd)

    retract-gap-is-equiv
      : is-equiv (gap (retract-cone))
    retract-gap-is-equiv = is-equiv←qiso qiso where
      qiso : quasi-iso (gap (retract-cone))
      qiso .fst (tt , (s , r) , p) = s , r , happly (sym p)
      qiso .snd .fst (s , r , p)
        = Σ-path→ (refl , Σ-path→ (refl , funext→ retp)) where
          retp : happly (sym (funext→ (p ~⁻¹))) ~ p
          retp a
            = happly (happly-sym (funext→ (p ~⁻¹)) a) a
            ∙ ap sym (happly (funext.ε (p ~⁻¹)) a)
            ∙ sym-sym
      qiso .snd .snd (tt , (s , r) , p) = Σ-path→
        ( refl
        , Σ-path→
            ( refl
            , ap funext→ (funext→ (λ a →
                ap sym (happly (happly-sym p a) a) ∙ sym-sym))
              ∙ funext.η p))

    retract≃pullback
      : retract A B
      ≃ Pullback (point id) comp-pair
    retract≃pullback
      = mk≃ (gap (retract-cone)) (retract-gap-is-equiv)

    retract≃fibre-∘
      : fibre comp-pair id
      ≃ retract A B
    retract≃fibre-∘
      =  (pullback-point≃fibre comp-pair id e⁻¹)
      ∙≃ (retract≃pullback e⁻¹)

    section-total≃retract
      : (Σ[ f ∶ (A → B) ] section f)
      ≃ (retract B A)
    section-total≃retract
      = Σ-comm
}
% ```
}

\subtree[stt-005X]{
\title{The diagonal map}
\taxon{Definition}

\p{Given a map #{f : A \to B}, we can form a map #{\Delta_f : A \to A \times_B A}
called the \em{diagonal map} of #{f}.}

%```agda
\agda{
diagonal : ∀ {𝓤 𝓥} {A : Type 𝓤} {B : Type 𝓥}
             (f : A → B)
           → A → Pullback f f
diagonal f a = (a , a , refl)
}
%```
}

\subtree[stt-006B]{
\date{2025-06-23}
\title{Diagonal equivalence}
\taxon{Theorem}

\p{The diagonal of map #{f} is an equivalence iff #{f} is.}

%```agda
\agda{
diagonal-is-equiv : ∀ {𝓤 𝓥} {A : Type 𝓤} {B : Type 𝓥}
                      {f : A → B}
                    → is-equiv f
                    → is-equiv (diagonal f)
diagonal-is-equiv {f = f} feq
  = is-equiv⁻¹ (singleton-fst-is-equiv λ x
        → is-single←equiv-to-single
            (Σ-ap-≃ λ a
              → mk≃ (ap f) (is-embedding←is-equiv feq))
            Sing-is-singleton)
}
%```
}

\subtree[stt-007Z]{
\date{2025-07-23}
\taxon{Lemma}
\title{Pulling back equivalences}

\p{We show that if #{g : B \to C} is an equivalence,
then pulling back #{g} along any map gives an equivalence}


%```agda
\agda{
pullback-equiv₁ : ∀ {𝓤 𝓥 𝓦} {A : Type 𝓤} {B : Type 𝓥} {C : Type 𝓦}
                    {f : A → C} {g : B → C}
                  → let open pb
                  in is-equiv g
                  →  is-equiv π₁
pullback-equiv₁ {f = f} {g} geq
  = is-equiv←is-contr-map (λ
      a → is-single←equiv-to-single
            (fib-π₁ f g a e⁻¹)
            (is-contr-map←is-equiv geq (f a)))
}
%```
}

\subtree[stt-009P]{
\title{Pullback is commutative}
\taxon{Theorem}

%```agda
\agda{
pullback-swap : ∀ {𝓤 𝓥 𝓦} {A : Type 𝓤} {B : Type 𝓥} {C : Type 𝓦}
                  {f : A → C} {g : B → C}
                → Pullback f g ≃ Pullback g f
pullback-swap {f = f}{g}
    = Pullback f g ≃⟨ Σ-comm ⟩
      (Σ[ a ∶ _ ] Σ[ b ∶ _ ] (f b ＝ g a))
        ≃⟨ Σ-ap-≃ (λ _ → Σ-ap-≃ (λ _ → sym≃)) ⟩
      Pullback g f ≃∎
}
%```
}

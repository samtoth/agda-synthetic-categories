\agda{
module Ergonomics.Name where
}

\agda-imports{
\agda{
open import Foundations.Universes
open import Ergonomics.Builtins
open import Ergonomics.Fixity
}
}

\agda{
postulate Name : Type
{-# BUILTIN QNAME Name #-}

primitive
  primQNameEquality : Name → Name → Bool

\date{2025-02-22}
\title{Coherent Equivalences}
\taxon{Module}

\import{stt-macros}

\agda{
module Foundations.Equivalences where
}

\imports{
\agda{
open import Foundations.Universes
open import Foundations.QuasiEquivalences
open import Foundations.Sigma
open import Foundations.Functions
open import Foundations.FunctionInverses
open import Foundations.Homotopy
open import Foundations.Identity
open import Foundations.IdentityReasoning
}
}

\p{
We can upgrade a [quasi-equivalence](Foundations.QuasiEquivalences) into a
homotopy-correct equivalence by adding an extra coherence condition, that makes being
an equivalence into a proposition.
}

\subtree[stt-000K]{
\taxon{Remark}
\title{Half-adjoint equivalence}

\p{The definition of a quasi-equivalence involves:}

\ul{
\li{#{f : A \to B}}
\li{#{g : B \to A}}
\li{#{\eta : f \circ g = \id}}
\li{#{\varepsilon : \id = g \circ f}}
}

\p{The names #{\eta} and #{\varepsilon} remind us that this looks like the data of an adjunction. But we are missing the laws, often called the zig-zag laws. One of which state that the following 2-cell contracts to the identity:
}

\quiver{
% https://q.uiver.app/#
\begin{tikzcd}
	A &&&& A \\
	\\
	&& B &&&& B
	\arrow[""{name=0, anchor=center, inner sep=0}, no head, from=1-1, to=1-5]
	\arrow["\id", shift left, no head, from=1-1, to=1-5]
	\arrow["f"', from=1-1, to=3-3]
	\arrow["f"', from=1-5, to=3-7]
	\arrow["g"', from=3-3, to=1-5]
	\arrow[""{name=1, anchor=center, inner sep=0}, "\id"', no head, from=3-3, to=3-7]
	\arrow[shift left, no head, from=3-3, to=3-7]
	\arrow["\varepsilon", shorten <=7pt, shorten >=11pt, Rightarrow, from=0, to=3-3]
	\arrow["\eta", shorten <=7pt, shorten >=7pt, Rightarrow, from=1-5, to=1]
\end{tikzcd}
}

\p{In symbols, this is: #{f \cdot \varepsilon \circ \eta \cdot f = \id}, where
#{\cdot} denotes horizontal composition and #{\circ} denotes vertical composition.}
}

\p{Note that in our formalisation #{\varepsilon} is a 2-cell in the opposite direction, but since all 2-cells are invertible, this makes no difference to the definition and makes the formalisation slightly smoother.}

\subtree[stt-001R]{
\taxon{Definition}
\title{Coherence data for [quasi-equivalences](Foundations.QuasiEquivalences)}

\agda{
qinv-coh : ‚ąÄ {ūĚď§ ūĚď•} {A : Type ūĚď§} {B : Type ūĚď•} {f : A ‚Üí B} ‚Üí quasi-inv f ‚Üí Type (ūĚď§ ‚äĒ ūĚď•)
qinv-coh {f = f} (g , őĶ , ő∑) = f ‚óā őĶ ~ ő∑ ‚Ėł f
}
}

\subtree[stt-001U]{
\taxon{Definition}
\title{Equivalences}


\p{Of the many equivalent notions of equivalences in HoTT, we will single out coherent equivalences as the default one in the library.}

\agda{
record is-equiv {ūĚď§ ūĚď•} {A : Type ūĚď§} {B : Type ūĚď•} (f : A ‚Üí B) : Type (ūĚď§ ‚äĒ ūĚď•) where
  constructor mk-eqv
  field
    qinv     : quasi-inv f
    coherent : qinv-coh qinv

  qeqv : A ‚Čä B
  qeqv = mk‚Čä f qinv

  open _‚Čä_ qeqv public hiding (fwd)

  őĶ : f ‚ąė bwd ~ id
  őĶ x = section-fwd .snd x

  őĶ‚ĀĽ¬Ļ : id ~ f ‚ąė bwd
  őĶ‚ĀĽ¬Ļ = őĶ h‚ĀĽ¬Ļ

  ő∑ : bwd ‚ąė f ~ id
  ő∑ x = retraction-fwd .snd x

  ő∑‚ĀĽ¬Ļ : id ~ bwd ‚ąė f
  ő∑‚ĀĽ¬Ļ = ő∑ h‚ĀĽ¬Ļ

  coh‚ĀĽ¬Ļ :  (f ‚óā ő∑‚ĀĽ¬Ļ) ~ (őĶ‚ĀĽ¬Ļ ‚Ėł f)
  coh‚ĀĽ¬Ļ a = ap-sym f (ő∑ a) ‚ąô ap sym (coherent a)

  swizzle-bwd
    : ‚ąÄ {ūĚď¶} {C : Type ūĚď¶}
        (g : C ‚Üí B) (h : C ‚Üí A)
      ‚Üí g ~ f ‚ąė h ‚Üí bwd ‚ąė g ~ h
  swizzle-bwd g h K = bwd ‚óā K ‚ąôh ő∑ ‚Ėł h
}

\p{We also define the packaged version of an equivalence together with the proof of it being an equivalence}

\agda{
infix 6 _‚ČÉ_
record _‚ČÉ_ {ūĚď§ ūĚď•} (A : Type ūĚď§) (B : Type ūĚď•) : Type (ūĚď§ ‚äĒ ūĚď•) where
  constructor mk‚ČÉ
  field
    fwd : A ‚Üí B
    fwd-is-equiv : is-equiv fwd

  open is-equiv fwd-is-equiv public

qinv‚Üźis-equiv
  : ‚ąÄ {ūĚď§ ūĚď•} {A : Type ūĚď§} {B : Type ūĚď•} {f : A ‚Üí B} ‚Üí is-equiv f ‚Üí quasi-inv f
qinv‚Üźis-equiv = is-equiv.qinv

qeqv‚Üźequiv
  : ‚ąÄ {ūĚď§ ūĚď•} {A : Type ūĚď§} {B : Type ūĚď•} ‚Üí A ‚ČÉ B ‚Üí A ‚Čä B
qeqv‚Üźequiv (mk‚ČÉ _ fwd-is-equiv) = qeqv where open is-equiv fwd-is-equiv
}
}


\subtree[stt-000J]{
\taxon{Theorem}
\title{Quasi-equivalences can be made coherent}
% HoTT book. 4.2.3

\p{Every quasi-equivalence can be upgraded to a coherent equivalence.}

\proof{
\p{Since we (are soon to) know that being an equivalence is a proposition, and that quasi-equivalences aren't equivalent to equivalences,
we know that whatever the map is, it cannot be a section of the obvious map #{\textrm{is-equiv}(f) \to \textrm{quasi-inv}(f)}, and so as a
result we know we will have to be a bit clever about how we choose the 2-cells of our coherent equivalence.}

\p{The proof goes through by cooking up a 2-cell #{\varepsilon} that makes the coherence go through trivially.
Working backwards, we need an #{\varepsilon '} such that #{\varepsilon' f = \eta f}. }


\quiver{
% https://q.uiver.app/#
\begin{tikzcd}
	fgf &&&&&& f \\
	&&&& fgf \\
	& fgfgf \\
	&&&&& fgf
	\arrow["{f\eta}", from=1-1, to=1-7]
	\arrow[""{name=0, anchor=center, inner sep=0}, equals, from=1-1, to=2-5]
	\arrow["{\varepsilon^{-1} fgf}"', from=1-1, to=3-2]
	\arrow["{f\eta}"', from=2-5, to=1-7]
	\arrow["{\varepsilon fgf}", from=3-2, to=2-5]
	\arrow[""{name=1, anchor=center, inner sep=0}, "{fgf \eta}", from=3-2, to=4-6]
	\arrow[""{name=2, anchor=center, inner sep=0}, "{f\eta gf}"', bend right,from=3-2, to=4-6]
	\arrow["{\varepsilon f}"', bend right, from=4-6, to=1-7]
	\arrow["2", shorten <=11pt, shorten >=8pt, Rightarrow, from=4-6, to=2-5]
	\arrow["1"', shorten <=11pt, shorten >=11pt, Rightarrow, from=3-2, to=0]
	\arrow["3"', shorten <=2pt, shorten >=2pt, Rightarrow, from=2, to=1]
\end{tikzcd}
}


\p{
Consider the above diagram, and in particular note that the lower boundary is given by morphisms of the form #{\alpha f} for some alpha.
By taking the horizontal composition of these #{\alpha}'s gives us our desired #{\epsilon' := \varepsilon^{-1} fg \cdot f \eta g \cdot \varepsilon}. It satisfies the necessary equations by the vertical composite of the cells:
}

\ol{
\li{Trivially follows from paths forming groupoids.}
\li{The naturality of homotopies.}
\li{\citet{2.4.3}{HoTT} [[stt-001O]]}
}

\agda{
is-equiv‚Üźqinv : ‚ąÄ {ūĚď§ ūĚď•} {A : Type ūĚď§} {B : Type ūĚď•} {f : A ‚Üí B} ‚Üí quasi-inv f ‚Üí is-equiv f
is-equiv‚Üźqinv {f = f} (g , ő∑ , őĶ) = mk-eqv (g , ő∑ , őĶ') coh where opaque
  őĶ' : f ‚ąė g ~ id
  őĶ' = (őĶ h‚ĀĽ¬Ļ) ‚Ėł f ‚Ėł g ‚ąôh
      f ‚óā ő∑ ‚Ėł g       ‚ąôh
      őĶ

  lem3 : g ‚óā f ‚óā ő∑ ~ ő∑ ‚Ėł g ‚Ėł f
  lem3 x = sym (ap-‚ąė g f (ő∑ x)) ‚ąô n where
    n : ((g ‚ąė f) ‚óā ő∑) x ÔľĚ (ő∑ ‚Ėł g ‚Ėł f) x
    n = sym (homotopy-inverse (g ‚ąė f) ő∑ x)

  lem2 : őĶ ‚Ėł f ‚Ėł g ‚Ėł f ‚ąôh f ‚óā ő∑ ~ f ‚óā g ‚óā f ‚óā ő∑ ‚ąôh őĶ ‚Ėł f
  lem2 x = I ‚ąô ap (_‚ąô (őĶ (f x))) (ap-‚ąė f g (ap f (ő∑ x))) where
    I : őĶ (f (g (f x))) ‚ąô (ap f (ő∑ x)) ÔľĚ
         ap (őĽ z ‚Üí (f ‚ąė g) z) (ap f (ő∑ x)) ‚ąô őĶ (f x)
    I = ap (őĶ (f (g (f x))) ‚ąô_) (sym (ap-id (ap f (ő∑ x)))) ‚ąô
        homotopy-natural őĶ {f (g (f x))} (ap f (ő∑ x))

  lem1 : f ‚óā ő∑ ~
           (((őĶ ‚Ėł f ‚Ėł g ‚Ėł f) h‚ĀĽ¬Ļ) ‚ąôh őĶ ‚Ėł f ‚Ėł g ‚Ėł f ‚ąôh f ‚óā ő∑)
  lem1 a = ‚ąô.insertr _ {h = őĶ (f (g (f a)))} {i = sym (őĶ (f (g (f a))))} (‚ąô-sym' (őĶ (f (g (f a))))) {_} {ap f (ő∑ a)}

  coh : qinv-coh (g , ő∑ , őĶ')
  coh
    = (f ‚óā ő∑)
        ~‚ü® lem1 ‚ü©
      ((őĶ ‚Ėł f ‚Ėł g ‚Ėł f) h‚ĀĽ¬Ļ) ‚ąôh őĶ ‚Ėł f ‚Ėł g ‚Ėł f ‚ąôh f ‚óā ő∑
        ~‚ü® ~refl: ((őĶ ‚Ėł f ‚Ėł g ‚Ėł f) h‚ĀĽ¬Ļ) ‚ü©‚ąôh‚ü® lem2 ‚ü©
      ((őĶ ‚Ėł f ‚Ėł g ‚Ėł f) h‚ĀĽ¬Ļ) ‚ąôh (f ‚óā g ‚óā f ‚óā ő∑) ‚ąôh őĶ ‚Ėł f
        ~‚ü® (~refl: ((őĶ ‚Ėł f ‚Ėł g ‚Ėł f) h‚ĀĽ¬Ļ)) ‚ü©‚ąôh‚ü® (f ‚ü©‚óā‚ü® lem3) ‚ü©‚ąôh‚ü® ~refl: (őĶ ‚Ėł f) ‚ü©
      ((őĶ ‚Ėł f ‚Ėł g ‚Ėł f) h‚ĀĽ¬Ļ) ‚ąôh f ‚óā (ő∑ ‚Ėł g ‚Ėł f) ‚ąôh őĶ ‚Ėł f
        ~‚ü®‚ü©
        őĶ' ‚Ėł f
        ~‚ąé

equiv‚Üźqequiv : ‚ąÄ {ūĚď§ ūĚď•} {A : Type ūĚď§} {B : Type ūĚď•} ‚Üí A ‚Čä B ‚Üí A ‚ČÉ B
equiv‚Üźqequiv (mk‚Čä fwd fwd-qinv) = mk‚ČÉ fwd (is-equiv‚Üźqinv fwd-qinv)

‚ČÉ-rep‚Čä  : ‚ąÄ {ūĚď§ ūĚď•} {A : Type ūĚď§} {B : Type ūĚď•} ‚Üí (A ‚ČÉ B) ‚Čä ő£ (A ‚Üí B) is-equiv
‚ČÉ-rep‚Čä ._‚Čä_.fwd (mk‚ČÉ f e) = f , e
‚ČÉ-rep‚Čä ._‚Čä_.fwd-qinv .fst (f , e) = mk‚ČÉ f e
‚ČÉ-rep‚Čä ._‚Čä_.fwd-qinv .snd .fst _ = refl
‚ČÉ-rep‚Čä ._‚Čä_.fwd-qinv .snd .snd _ = refl

‚ČÉ-rep : ‚ąÄ {ūĚď§ ūĚď•} {A : Type ūĚď§} {B : Type ūĚď•} ‚Üí (A ‚ČÉ B) ‚ČÉ ő£ (A ‚Üí B) is-equiv
‚ČÉ-rep = equiv‚Üźqequiv ‚ČÉ-rep‚Čä
}
}
}

\subtree[stt-005T]{
\date{2025-06-19}
\title{Assuming the codomain to construct an equivalence}
\taxon{Proposition}
  \p{To show that a function is an equivalence,
  it suffices show that it is an equivalence assuming a point
  in the codomain.}

\agda{
is-equiv‚Üźis-equiv-if-cod
  : ‚ąÄ {ūĚď§ ūĚď•} {A : Type ūĚď§}
      {B : Type ūĚď•}
      {f : A ‚Üí B}
    ‚Üí (B ‚Üí is-equiv f)
    ‚Üí is-equiv f
is-equiv‚Üźis-equiv-if-cod {f = f} feqb
  = is-equiv‚Üźqinv
      ( (őĽ b ‚Üí bwd (feqb b) b)
      , (őĽ a ‚Üí ő∑ (feqb (f a)) a)
      , őĽ b ‚Üí őĶ (feqb b) b)
    where open is-equiv
}
}

\subtree[stt-00R6]{
\date{2026-05-27}
\title{Injective maps with sections are equivalences}
\taxon{Proposition}
\author{fredrikbakke}

\agda{
is-equiv‚Üźsection‚Üźinjective
  : ‚ąÄ {ūĚď§ ūĚď•} {A : Type ūĚď§} {B : Type ūĚď•} {f : A ‚Üí B}
    ‚Üí ({x y : A} ‚Üí f x ÔľĚ f y ‚Üí x ÔľĚ y)
    ‚Üí section f
    ‚Üí is-equiv f
is-equiv‚Üźsection‚Üźinjective {f = f} I (g , őĶ)
  = is-equiv‚Üźqinv (g , I ‚ąė őĶ ‚ąė f , őĶ)
}
}

\subtree[stt-001T]{
\title{Equivalences form an #{‚ąě}-groupoid over types}
\author{samueltoth}
\author{fredrikbakke}
\date{2026-04-23}

\p{
We show that equivalence forms a reflexive, transitive and symmetric relation on
types. More concretely, we show the identity map is an equivalence, that equivalences
compose, and that equivalences may be inverted. We construct each explicitly to
maintain control over the section and retraction homotopies.
}

\agda{
id-is-equiv : ‚ąÄ {ūĚď§} {A : Type ūĚď§} ‚Üí is-equiv (id: A)
id-is-equiv = mk-eqv (id , ~refl , ~refl) ~refl

id‚ČÉ : ‚ąÄ {ūĚď§} {A : Type ūĚď§} ‚Üí A ‚ČÉ A
id‚ČÉ = mk‚ČÉ id id-is-equiv

id‚ČÉ: : ‚ąÄ {ūĚď§} (A : Type ūĚď§) ‚Üí A ‚ČÉ A
id‚ČÉ: A = id‚ČÉ
}

\agda{
is-equiv-‚ąė-qinv
  : ‚ąÄ {ūĚď§ ūĚď• ūĚď¶} {A : Type ūĚď§} {B : Type ūĚď•} {C : Type ūĚď¶}
      {f : B ‚Üí C} {g : A ‚Üí B}
    ‚Üí is-equiv f ‚Üí is-equiv g
    ‚Üí quasi-inv (f ‚ąė g)
is-equiv-‚ąė-qinv {f = f} {g} fe ge .fst
  = is-equiv.bwd ge ‚ąė is-equiv.bwd fe
is-equiv-‚ąė-qinv {f = f} {g} fe ge .snd .fst
  = is-equiv.bwd ge ‚óā is-equiv.ő∑ fe ‚Ėł g ‚ąôh is-equiv.ő∑ ge
is-equiv-‚ąė-qinv {f = f} {g} fe ge .snd .snd
  = f ‚óā is-equiv.őĶ ge ‚Ėł is-equiv.bwd fe ‚ąôh is-equiv.őĶ fe

opaque
  is-equiv-‚ąė-coh
    : ‚ąÄ {ūĚď§ ūĚď• ūĚď¶} {A : Type ūĚď§} {B : Type ūĚď•} {C : Type ūĚď¶}
        {f : B ‚Üí C} {g : A ‚Üí B}
        (fe : is-equiv f) (ge : is-equiv g)
      ‚Üí qinv-coh (is-equiv-‚ąė-qinv fe ge)
  is-equiv-‚ąė-coh {f = f} {g} fe ge = coh where
    module ef = is-equiv fe
    module eg = is-equiv ge

    ret : eg.bwd ‚ąė ef.bwd ‚ąė f ‚ąė g ~ id
    ret = is-equiv-‚ąė-qinv fe ge .snd .fst

    sec : f ‚ąė g ‚ąė eg.bwd ‚ąė ef.bwd ~ id
    sec = is-equiv-‚ąė-qinv fe ge .snd .snd

    coh‚āĀ
      : ‚ąÄ a
        ‚Üí ap (f ‚ąė g) (ret a)
        ÔľĚ ap f (ap (g ‚ąė eg.bwd) (ef.ő∑ (g a)) ‚ąô eg.őĶ (g a))
    coh‚āĀ a
      = ap (f ‚ąė g) (ret a)
          ÔľĚ‚ü® ap-‚ąô (f ‚ąė g) (ap eg.bwd (ef.ő∑ (g a))) (eg.ő∑ a) ‚ü©
        ap (f ‚ąė g) (ap eg.bwd (ef.ő∑ (g a))) ‚ąô ap (f ‚ąė g) (eg.ő∑ a)
          ÔľĚ‚ü® ap (_‚ąô ap (f ‚ąė g) (eg.ő∑ a)) (ap-‚ąė f g (ap eg.bwd (ef.ő∑ (g a)))) ‚ü©
        ap f (ap g (ap eg.bwd (ef.ő∑ (g a)))) ‚ąô ap (f ‚ąė g) (eg.ő∑ a)
          ÔľĚ‚ü® ap (_‚ąô ap (f ‚ąė g) (eg.ő∑ a)) (ap (ap f) (sym (ap-‚ąė g eg.bwd (ef.ő∑ (g a))))) ‚ü©
        ap f (ap (g ‚ąė eg.bwd) (ef.ő∑ (g a))) ‚ąô ap (f ‚ąė g) (eg.ő∑ a)
          ÔľĚ‚ü® ap (ap f (ap (g ‚ąė eg.bwd) (ef.ő∑ (g a))) ‚ąô_) (ap-‚ąė f g (eg.ő∑ a)) ‚ü©
        ap f (ap (g ‚ąė eg.bwd) (ef.ő∑ (g a))) ‚ąô ap f (ap g (eg.ő∑ a))
          ÔľĚ‚ü® ap (ap f (ap (g ‚ąė eg.bwd) (ef.ő∑ (g a))) ‚ąô_) (ap (ap f) (eg.coherent a)) ‚ü©
        ap f (ap (g ‚ąė eg.bwd) (ef.ő∑ (g a))) ‚ąô ap f (eg.őĶ (g a))
          ÔľĚ‚ü® sym (ap-‚ąô f (ap (g ‚ąė eg.bwd) (ef.ő∑ (g a))) (eg.őĶ (g a))) ‚ü©
        ap f (ap (g ‚ąė eg.bwd) (ef.ő∑ (g a)) ‚ąô eg.őĶ (g a))
          ‚ąé

    coh‚āā
      : ‚ąÄ a
        ‚Üí ap f (ap (g ‚ąė eg.bwd) (ef.ő∑ (g a)) ‚ąô eg.őĶ (g a))
        ÔľĚ ap f (eg.őĶ (ef.bwd (f (g a)))) ‚ąô ap f (ef.ő∑ (g a))
    coh‚āā a
      = ap f (ap (g ‚ąė eg.bwd) (ef.ő∑ (g a)) ‚ąô eg.őĶ (g a))
          ÔľĚ‚ü® ap (ap f)
               ( sym (homotopy-natural eg.őĶ (ef.ő∑ (g a)))
               ‚ąô ap (eg.őĶ (ef.bwd (f (g a))) ‚ąô_) (ap-id (ef.ő∑ (g a)))) ‚ü©
        ap f (eg.őĶ (ef.bwd (f (g a))) ‚ąô ef.ő∑ (g a))
          ÔľĚ‚ü® ap-‚ąô f (eg.őĶ (ef.bwd (f (g a)))) (ef.ő∑ (g a)) ‚ü©
        ap f (eg.őĶ (ef.bwd (f (g a)))) ‚ąô ap f (ef.ő∑ (g a))
          ‚ąé

    coh‚āÉ
      : ‚ąÄ a
        ‚Üí ap f (eg.őĶ (ef.bwd (f (g a)))) ‚ąô ap f (ef.ő∑ (g a))
        ÔľĚ sec (f (g a))
    coh‚āÉ a
      = ap f (eg.őĶ (ef.bwd (f (g a)))) ‚ąô ap f (ef.ő∑ (g a))
          ÔľĚ‚ü® ap (ap f (eg.őĶ (ef.bwd (f (g a)))) ‚ąô_) (ef.coherent (g a)) ‚ü©
        ap f (eg.őĶ (ef.bwd (f (g a)))) ‚ąô ef.őĶ (f (g a))
          ÔľĚ‚ü®‚ü©
        sec (f (g a))
          ‚ąé

    coh : qinv-coh (is-equiv-‚ąė-qinv fe ge)
    coh a = coh‚āĀ a ‚ąô coh‚āā a ‚ąô coh‚āÉ a

is-equiv-‚ąė
  : ‚ąÄ {ūĚď§ ūĚď• ūĚď¶} {A : Type ūĚď§} {B : Type ūĚď•} {C : Type ūĚď¶}
      {f : B ‚Üí C} {g : A ‚Üí B}
    ‚Üí is-equiv f ‚Üí is-equiv g
    ‚Üí is-equiv (f ‚ąė g)
is-equiv-‚ąė fe ge = mk-eqv (is-equiv-‚ąė-qinv fe ge) (is-equiv-‚ąė-coh fe ge)

equiv-comp
  : ‚ąÄ {ūĚď§ ūĚď• ūĚď¶} {A : Type ūĚď§} {B : Type ūĚď•} {C : Type ūĚď¶}
    ‚Üí A ‚ČÉ B ‚Üí B ‚ČÉ C ‚Üí A ‚ČÉ C
equiv-comp (mk‚ČÉ f e) (mk‚ČÉ g e') = mk‚ČÉ (g ‚ąė f) (is-equiv-‚ąė e' e)
}

\agda{
is-equiv‚ĀĽ¬Ļ-qinv
  : ‚ąÄ {ūĚď§ ūĚď•} {A : Type ūĚď§} {B : Type ūĚď•} {f : A ‚Üí B}
    ‚Üí (e : is-equiv f)
    ‚Üí quasi-inv (is-equiv.bwd e)
is-equiv‚ĀĽ¬Ļ-qinv e = bwd-qinv (qinv‚Üźis-equiv e)

opaque
  is-equiv‚ĀĽ¬Ļ-coh
    : ‚ąÄ {ūĚď§ ūĚď•} {A : Type ūĚď§} {B : Type ūĚď•} {f : A ‚Üí B}
      ‚Üí (e : is-equiv f)
      ‚Üí qinv-coh (is-equiv‚ĀĽ¬Ļ-qinv e)
  is-equiv‚ĀĽ¬Ļ-coh {A = A} {B = B} {f = f} e = coh where
    open is-equiv e using (bwd; ő∑; őĶ; coherent)

    qinv : quasi-inv bwd
    qinv = is-equiv‚ĀĽ¬Ļ-qinv e

    unap-ap-f
      : ‚ąÄ {x y : A} {p q : x ÔľĚ y}
        ‚Üí ap f p ÔľĚ ap f q
        ‚Üí p ÔľĚ q

    unap-ap-f {x} {y}
      = unap‚Üźretraction-witness
          (unap‚Üźretraction-witness bwd ő∑ {x} {y})
          (ap-retraction-witness bwd ő∑ {x} {y})

    coh‚āĀ
      : ‚ąÄ b
        ‚Üí ap (f ‚ąė bwd) (őĶ b) ÔľĚ őĶ (f (bwd b))
    coh‚āĀ b
      = ap (f ‚ąė bwd) (őĶ b)
          ÔľĚ‚ü® sym (‚ąô-reflr (ap (f ‚ąė bwd) (őĶ b))) ‚ü©
        ap (f ‚ąė bwd) (őĶ b) ‚ąô refl
          ÔľĚ‚ü® ap (ap (f ‚ąė bwd) (őĶ b) ‚ąô_) (sym (‚ąô-sym (őĶ b))) ‚ü©
        ap (f ‚ąė bwd) (őĶ b) ‚ąô (őĶ b ‚ąô sym (őĶ b))
          ÔľĚ‚ü® sym (‚ąô-assoc (ap (f ‚ąė bwd) (őĶ b)) (őĶ b) (sym (őĶ b))) ‚ü©
        (ap (f ‚ąė bwd) (őĶ b) ‚ąô őĶ b) ‚ąô sym (őĶ b)
          ÔľĚ‚ü® ap ((ap (f ‚ąė bwd) (őĶ b) ‚ąô őĶ b) ‚ąô_) (sym (ap sym (ap-id (őĶ b)))) ‚ü©
        (ap (f ‚ąė bwd) (őĶ b) ‚ąô őĶ b) ‚ąô sym (ap id (őĶ b))
          ÔľĚ‚ü® homotopy-cancel őĶ (őĶ b) ‚ü©
        őĶ (f (bwd b))
          ‚ąé

    coh‚āā : (b : B) ‚Üí ap f (ap bwd (őĶ b)) ÔľĚ őĶ (f (bwd b))
    coh‚āā b = sym (ap-‚ąė f bwd (őĶ b)) ‚ąô coh‚āĀ b

    coh‚āÉ : (b : B) ‚Üí őĶ (f (bwd b)) ÔľĚ ap f (ő∑ (bwd b))
    coh‚āÉ b = sym (coherent (bwd b))

    coh : qinv-coh qinv
    coh b = unap-ap-f (coh‚āā b ‚ąô coh‚āÉ b)

is-equiv‚ĀĽ¬Ļ
  : ‚ąÄ {ūĚď§ ūĚď•} {A : Type ūĚď§} {B : Type ūĚď•} {f : A ‚Üí B}
    ‚Üí (e : is-equiv f) ‚Üí is-equiv (is-equiv.bwd e)
is-equiv‚ĀĽ¬Ļ e = mk-eqv (is-equiv‚ĀĽ¬Ļ-qinv e) (is-equiv‚ĀĽ¬Ļ-coh e)

bwd-is-equiv
  : ‚ąÄ {ūĚď§ ūĚď•} {A : Type ūĚď§} {B : Type ūĚď•} (e : A ‚ČÉ B)
    ‚Üí is-equiv (_‚ČÉ_.bwd e)
bwd-is-equiv e = is-equiv‚ĀĽ¬Ļ (_‚ČÉ_.fwd-is-equiv e)
}

\agda{
coe-is-equiv
  : ‚ąÄ {ūĚď§} {A B : Type ūĚď§} (p : A ÔľĚ B)
    ‚Üí is-equiv (coe p)
coe-is-equiv refl = id-is-equiv

coe‚ČÉ : ‚ąÄ {ūĚď§} {A B : Type ūĚď§} ‚Üí A ÔľĚ B ‚Üí A ‚ČÉ B
coe‚ČÉ p = mk‚ČÉ (coe p) (coe-is-equiv p)

tr‚ČÉ : ‚ąÄ {ūĚď§ ūĚď•} {A : Type ūĚď§} (P : A ‚Üí Type ūĚď•) ‚Üí ‚ąÄ {a b} ‚Üí a ÔľĚ b ‚Üí P a ‚ČÉ P b
tr‚ČÉ P p = coe‚ČÉ (ap P p)
{-# NOINLINE tr‚ČÉ #-}

equiv‚ÜźId : ‚ąÄ {ūĚď§} {A B : Type ūĚď§} ‚Üí A ÔľĚ B ‚Üí A ‚ČÉ B
equiv‚ÜźId = coe‚ČÉ
{-# NOINLINE equiv‚ÜźId #-}

fwd-equiv‚ÜźId
  : ‚ąÄ {ūĚď§} {A B : Type ūĚď§} (p : A ÔľĚ B)
    ‚Üí _‚ČÉ_.fwd (equiv‚ÜźId p) ÔľĚ coe p
fwd-equiv‚ÜźId = ~refl
}
}

\subtree[stt-001S]{
\taxon{Notation}

\title{Reasoning combinators for equivalences}

\agda{
_‚ąôe_
  : ‚ąÄ {ūĚď§ ūĚď• ūĚď¶} {A : Type ūĚď§} {B : Type ūĚď•} {C : Type ūĚď¶}
    ‚Üí A ‚ČÉ B ‚Üí B ‚ČÉ C ‚Üí A ‚ČÉ C
_‚ąôe_ = equiv-comp

infixl 15 _‚ąôe_

_e‚ĀĽ¬Ļ : ‚ąÄ {ūĚď§ ūĚď•} {A : Type ūĚď§} {B : Type ūĚď•} ‚Üí A ‚ČÉ B ‚Üí B ‚ČÉ A
(mk‚ČÉ f e)  e‚ĀĽ¬Ļ = mk‚ČÉ (is-equiv.bwd e) (is-equiv‚ĀĽ¬Ļ e)

‚ČÉ‚ü®‚ü©-syntax
  : ‚ąÄ {ūĚď§ ūĚď• ūĚď¶} (A : Type ūĚď§) {B : Type ūĚď•} {C : Type ūĚď¶}
    ‚Üí B ‚ČÉ C ‚Üí A ‚ČÉ B ‚Üí A ‚ČÉ C
‚ČÉ‚ü®‚ü©-syntax A g f = equiv-comp f g


_‚ČÉ‚ü®‚ü©_ : ‚ąÄ {ūĚď§ ūĚď•} (A : Type ūĚď§) {B : Type ūĚď•} ‚Üí A ‚ČÉ B ‚Üí A ‚ČÉ B
x ‚ČÉ‚ü®‚ü© x‚ČÉy = x‚ČÉy

_‚ČÉ‚ąé : ‚ąÄ {‚Ąď} (A : Type ‚Ąď) ‚Üí A ‚ČÉ A
x ‚ČÉ‚ąé = id‚ČÉ

infix 25 _e‚ĀĽ¬Ļ

infixr 0 ‚ČÉ‚ü®‚ü©-syntax _‚ČÉ‚ü®‚ü©_
infix  1 _‚ČÉ‚ąé

syntax ‚ČÉ‚ü®‚ü©-syntax x q p = x ‚ČÉ‚ü® p ‚ü© q
}
}

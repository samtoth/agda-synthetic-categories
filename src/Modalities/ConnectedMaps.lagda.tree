\subtree[fre-LMAB]{
\taxon{Definition}
\title{Universal property of #{K}-connected maps}

\p{
Given a global subuniverse #{K} and a map #{f : A \to B}, then #{f} satisfies the
\em{universal property of #{K}-connected maps} if for every #{K}-valued family of
types #{U} over #{B}, the dependent precomposition map
#{\prod_{b : B} U(b) \to \prod_{a : A} U(f(a))} is an equivalence.
}

% ```agda
\agda{
up-gconnected-map : тИА {╬▒ ЁЭУд ЁЭУе} (K : gSubU ╬▒)
                    тЖТ {A : Type ЁЭУд} {B : Type ЁЭУе}
                    тЖТ (A тЖТ B)
                    тЖТ Type╧Й
up-gconnected-map K f
  = тИА {ЁЭУЪ} {U : _ тЖТ Type ЁЭУЪ}
  тЖТ (тИА b тЖТ U b тИИ gSubU.S K)
  тЖТ is-equiv (precomp-╬а U f)

gconnected-map-!-fibre
  : тИА {╬▒ ЁЭУд ЁЭУе} (K : gSubU ╬▒)
      {A : Type ЁЭУд} {B : Type ЁЭУе}
      (f : A тЖТ B)
  тЖТ Type╧Й
gconnected-map-!-fibre K f
  = тИА b тЖТ up-gmodal-equiv K (!: fibre f b)

gconnected-fibres
  : тИА {╬▒ ЁЭУд ЁЭУе} (K : gSubU ╬▒)
      {A : Type ЁЭУд} {B : Type ЁЭУе}
      (f : A тЖТ B)
  тЖТ Type╧Й
gconnected-fibres K f
  = тИА b {ЁЭУЪ} {U : Type ЁЭУЪ}
    тЖТ U тИИ gSubU.S K
    тЖТ is-equiv (const U (fibre f b))
}
%```
}


\subtree{
\date{2026-03-19}
\author{fredrikbakke}
\taxon{Definition}
\title{#{K}-Connected maps}

\p{
If #{K} is a reflective subuniverse, a map is \em{#{K}-connected} if all of its
fibres have contractible reflections.
}

\agda{
module _ {╬▒} (RS : gRSubU ╬▒) where
  open gRSubU RS

  is-gconnected-map
    : тИА {ЁЭУд ЁЭУе} {A : Type ЁЭУд} {B : Type ЁЭУе}
    тЖТ (A тЖТ B) тЖТ Type _
  is-gconnected-map {B = B} f = (b : B) тЖТ is-singleton (тЧЛ (fibre f b))

is-connected-map : тИА {ЁЭУд ЁЭУе ЁЭУЬ} {A : Type ЁЭУд} {B : Type ЁЭУе}
                     {S : SubU (ЁЭУд тКФ ЁЭУе) ЁЭУЬ}
                   тЖТ is-reflective S
                   тЖТ (A тЖТ B) тЖТ Type (ЁЭУд тКФ ЁЭУе)
is-connected-map rfl f = тИА b тЖТ is-connected rfl (fibre f b)
}
%```
}

\subtree{
\date{2026-03-19}
\author{fredrikbakke}
\taxon{Lemma}
\title{Closure of #{K}-connected maps under composition}

% ```agda
\agda{
up-gconnected-map-тИШ
  : тИА {╬▒ ЁЭУд ЁЭУе ЁЭУж}
      (K : gSubU ╬▒)
      {A : Type ЁЭУд} {B : Type ЁЭУе} {C : Type ЁЭУж}
      (f : A тЖТ B) (g : B тЖТ C)
  тЖТ up-gconnected-map K f
  тЖТ up-gconnected-map K g
  тЖТ up-gconnected-map K (g тИШ f)
up-gconnected-map-тИШ K f g fconn gconn UтИИK
  = is-equiv-тИШ (fconn (UтИИK тИШ g)) (gconn UтИИK)

up-gconnected-map-right-cancel
  : тИА {╬▒ ЁЭУд ЁЭУе ЁЭУж}
      (K : gSubU ╬▒)
      {A : Type ЁЭУд} {B : Type ЁЭУе} {C : Type ЁЭУж}
      (f : A тЖТ B) (g : B тЖТ C)
  тЖТ up-gconnected-map K f
  тЖТ up-gconnected-map K (g тИШ f)
  тЖТ up-gconnected-map K g
up-gconnected-map-right-cancel K f g fconn gfconn UтИИK
  = 3-for-2 (fconn (UтИИK тИШ g)) (gfconn UтИИK)
}
%```
}

\subtree{
\date{2026-03-19}
\author{fredrikbakke}
\taxon{Theorem}
\title{Connected maps are left orthogonal to modal maps}

% ```agda
\agda{
up-gconnected-mapтЗФorthogonal-map
  : тИА {╬▒ ЁЭУд ЁЭУе} (K : gSubU ╬▒)
      {A : Type ЁЭУд} {B : Type ЁЭУе}
      (f : A тЖТ B)
  тЖТ up-gconnected-map K f
  тЖТ {ЁЭУж ЁЭУЫ : Level} {C : Type ЁЭУж} {D : Type ЁЭУЫ}
    (g : C тЖТ D)
  тЖТ is-gmodal-map K g
  тЖТ are-orthogonal f g
up-gconnected-mapтЗФorthogonal-map K f fconn g gтИИK
  = orthogonalтЖРprecomp-╬а ╬╗ h тЖТ fconn (╬╗ b тЖТ gтИИK (h b))

up-gconnected-mapтЖРorthogonal-map
  : тИА {╬▒ ЁЭУд ЁЭУе} (K : gSubU ╬▒)
      {A : Type ЁЭУд} {B : Type ЁЭУе}
      (f : A тЖТ B)
    тЖТ (тИА {ЁЭУж ЁЭУЫ} {C : Type ЁЭУж} {D : Type ЁЭУЫ}
        (g : C тЖТ D)
        тЖТ is-gmodal-map K g
        тЖТ are-orthogonal f g)
    тЖТ up-gconnected-map K f
up-gconnected-mapтЖРorthogonal-map K f orth {U = U} UтИИK
  = is-equivтЖРArrow-equivтБ╗┬╣ {F = eq .fst} (eq .snd)
      (precomp-╬атЖРorthogonal id (orth fst fstтИИK)) where

  fstтИИK : is-gmodal-map K (fst {B = U})
  fstтИИK b = gSubU.тИИSтЖРequiv K (fibre-straighten U b eтБ╗┬╣) (UтИИK b)

  eq = precomp-╬а-straighten-Arrow-equiv U f
}
%```
}

\subtree{
\date{2026-03-19}
\author{fredrikbakke}
\taxon{Lemma}
\title{#{K}-connected maps are #{K}-equivalences}

% ```agda
\agda{
up-gmodal-equivтЖРup-gconnected-map
  : тИА {╬▒ ЁЭУд ЁЭУе} (K : gSubU ╬▒)
      {A : Type ЁЭУд} {B : Type ЁЭУе}
      (f : A тЖТ B)
  тЖТ up-gconnected-map K f
  тЖТ up-gmodal-equiv K f
up-gmodal-equivтЖРup-gconnected-map K f fconn UтИИK = fconn (╬╗ _ тЖТ UтИИK)

module gRSubUConnectedModalEquivalences {╬▒} (RS : gRSubU ╬▒) where
  open gRSubU RS
  open gRSubUModalEquivalences RS

}

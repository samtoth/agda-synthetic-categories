\date{2025-06-04}
\author{samueltoth}
\taxon{Module}
\import{stt-macros}
\title{Orthogonal Factorisation Systems}

\agda{
module Modalities.Factorisation where

open import UF
open import Foundations.Prelude
}

\subtree[stt-004W]{
\title{Wide subcategories of the category of types}
\contributor{fredrikbakke}
\taxon{Definition}

\p{
We define the type of wide subcategories of #{\UU} - that is - subtypes
of all arrows which are closed under composition and that contains equivalences.}

\agda{
record WideSubcatType 𝓤 𝓥 : Type (lsuc (𝓤 ⊔ 𝓥)) where
  field
    K : {A B : Type 𝓤} → Subtype (A → B) 𝓥
    ≃∈K : {A B : Type 𝓤} (e : A ≃ B) → (_≃_.fwd e) ∈ K
    _∘∈K_
      : {A B C : Type 𝓤} {g : B → C} {f : A → B}
      → g ∈ K → f ∈ K → g ∘ f ∈ K

  id∈K : ∀ {A : Type 𝓤} → (id: A) ∈ K
  id∈K = ≃∈K id≃
}
}

\subtree[stt-004X]{
\title{Factorisation}
\taxon{Definition}

\agda{
record Factorisation {𝓤 𝓥} (LL RR : WideSubcatType 𝓤 𝓥)
                     {A B : Type 𝓤} (f : A → B) : Type (lsuc 𝓤 ⊔ 𝓥) where
  open WideSubcatType LL renaming (K to L) using ()
  open WideSubcatType RR renaming (K to R) using ()
  field
    Im : Type 𝓤
    l : A → Im
    r : Im → B
    l∈L : l ∈ L
    r∈R : r ∈ R

    comm : r ∘ l ＝ f
}
}

\subtree[stt-004V]{
\title{Orthogonal Factorisation System}
\contributor{fredrikbakke}
\taxon{Definition}

\agda{
record OFS 𝓤 𝓥 : Type (lsuc (𝓤 ⊔ 𝓥)) where
  field
    Ll Rr : WideSubcatType 𝓤 𝓥
  open WideSubcatType Ll public using () renaming
    ( K to L; ≃∈K to ≃∈L; id∈K to id∈L; _∘∈K_ to _L∘_)
  open WideSubcatType Rr public using () renaming
    ( K to R; ≃∈K to ≃∈R; id∈K to id∈R; _∘∈K_ to _R∘_)

  field
    factorisation
      : {A B : Type 𝓤} (f : A → B)
      → is-singleton (Factorisation Ll Rr f)
}
}

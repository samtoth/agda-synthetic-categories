\agda{
record CospanбµИ {рЭУ§ рЭУ• рЭУ¶} (S : Cospan рЭУ§ рЭУ• рЭУ¶) рЭУ§' рЭУ•' рЭУ¶'
         : Type (рЭУ§ вКФ рЭУ• вКФ рЭУ¶ вКФ lsuc (рЭУ§' вКФ рЭУ•' вКФ рЭУ¶')) where
  open Cospan S
  field
    CentreбµИ : Centre вЖТ Type рЭУ§'
    LeftбµИ   : Left вЖТ Type рЭУ•'
    leftбµИ   : вИА l вЖТ LeftбµИ l вЖТ CentreбµИ (left l)
    RightбµИ  : Right вЖТ Type рЭУ¶'
    rightбµИ  : вИА r вЖТ RightбµИ r вЖТ CentreбµИ (right r)


unquoteDecl CospanбµИ-reprвЙЕ CospanбµИ-reprвЙГ
  = make-record-repr CospanбµИ-reprвЙЕ CospanбµИ-reprвЙГ (quote CospanбµИ)
}

\date{2025-04-14}
\title{Miscellaneous properties of Sigma Types}
\taxon{Module}
\import{stt-macros}

% ```agda
\agda{
module Foundations.SigmaProperties where

open import Foundations.Universes
open import Foundations.Empty
open import Foundations.Sigma
open import Foundations.SigmaPath
open import Foundations.Identity
open import Foundations.DependentIdentity
open import Foundations.Functions
open import Foundations.QuasiIsomorphism
open import Foundations.CoherentIsomorphism
open import Foundations.Singleton
open import Foundations.EquivContrFibre
open import Foundations.EquivSingleton
open import Foundations.Coproducts
open import Foundations.Homotopy
}
% ```

% ```agda
\agda{
total-map-fst : вҲҖ {рқ“Ө рқ“Ҙ рқ“Ұ} {A : Type рқ“Ө} {A' : Type рқ“Ҙ} (f : A' вҶ’ A)
                вҶ’ {B : A вҶ’ Type рқ“Ұ} вҶ’ ОЈ A' (B вҲҳ f) вҶ’ ОЈ A B
total-map-fst f (a , b) = (f a , b)

total-is-equivвҶҗfst-is-equiv
  : вҲҖ {рқ“Ө рқ“Ҙ рқ“Ұ} {A : Type рқ“Ө} {A' : Type рқ“Ҙ} {B : A вҶ’ Type рқ“Ұ}
    {f : A' вҶ’ A} вҶ’ is-equiv f вҶ’ is-equiv (total-map-fst f {B})
total-is-equivвҶҗfst-is-equiv {B = B} {f} feq = is-equivвҶҗqiso the-iso where
  open is-equiv feq

  lem : вҲҖ {a} {b : (B вҲҳ f) a} вҶ’
      tr (B вҲҳ f) (О· a) (tr B (sym (Оө (f a))) b) пјқ b
  lem {a} {b} = tr (B вҲҳ f ) (О· a) _   пјқвҹЁ trвҲҳ B f (О· a) вҹ©
                tr B (ap f (О· a)) _   пјқвҹЁ ap (О» p вҶ’ tr B p (tr B (sym (Оө (f a))) b))
                                             (coherent a) вҹ©
                tr B (Оө (f a)) _      пјқвҹЁ trвҲҷtr-sym' {P = B} (Оө (f a)) b вҹ©
                b вҲҺ

  the-iso : quasi-iso (total-map-fst f)
  the-iso .fst (a , b) = (bwd a , tr B (sym (Оө a)) b)
  the-iso .snd .fst (a , b) = ОЈ-pathвҶ’ (О· a ,  lem)
  the-iso .snd .snd (a , b) = ОЈ-pathвҶ’ (Оө a ,  trвҲҷtr-sym' (Оө a) b)

ОЈ-ap-вүғ-fst : вҲҖ {рқ“Ө рқ“Ҙ рқ“Ұ} {A : Type рқ“Ө} {A' : Type рқ“Ҙ} {B : A вҶ’ Type рқ“Ұ}
             вҶ’ ((mkвүғ f _) : A' вүғ A) вҶ’ ОЈ A' (B вҲҳ f) вүғ ОЈ A B
ОЈ-ap-вүғ-fst (mkвүғ f feq)
  = mkвүғ (total-map-fst f) (total-is-equivвҶҗfst-is-equiv feq)

ОЈ-ap-вүғ-fst-bwd : вҲҖ {рқ“Ө рқ“Ҙ рқ“Ұ} {A : Type рқ“Ө} {A' : Type рқ“Ҙ} {B : A вҶ’ Type рқ“Ұ}
                 вҶ’ (e : A вүғ A') вҶ’ ОЈ A' (B вҲҳ _вүғ_.bwd e) вүғ ОЈ A B
ОЈ-ap-вүғ-fst-bwd (mkвүғ _ e)
  = mkвүғ (total-map-fst (is-equiv.bwd e))
        (total-is-equivвҶҗfst-is-equiv (is-equivвҒ»В№ e))

ОЈ-assoc : вҲҖ {рқ“Ө рқ“Ҙ рқ“Ұ} {A : Type рқ“Ө} {B : A вҶ’ Type рқ“Ҙ} {C : (a : A) вҶ’ B a вҶ’ Type рқ“Ұ}
          вҶ’ ОЈ (ОЈ A B) (О» x вҶ’ C (fst x) (snd x)) вүғ ОЈ A О» a вҶ’ ОЈ (B a) О» b вҶ’ C a b
ОЈ-assoc {A = A} {B} {C} = equivвҶҗqiso iso where
  fwd : ОЈ (ОЈ A B) (О» x вҶ’ C (fst x) (snd x)) вҶ’ ОЈ A (О» a вҶ’ ОЈ (B a) (C a))
  fwd ((a , b) , c) = a , (b , c)

  iso : ОЈ (ОЈ A B) (О» x вҶ’ C (fst x) (snd x)) вү… ОЈ A (О» a вҶ’ ОЈ (B a) (C a))
  iso ._вү…_.fwd = fwd
  iso ._вү…_.fwd-iso .fst (x , y , z) = (x , y) , z
  iso ._вү…_.fwd-iso .snd .fst a = refl
  iso ._вү…_.fwd-iso .snd .snd a = refl


ОЈ-singl : вҲҖ {рқ“Ө рқ“Ҙ} {A : Type рқ“Ө} {B : A вҶ’ Type рқ“Ҙ}
          вҶ’ is-singleton A
          вҶ’ (x : A) -- todo use @default to make it use singleton if not given
          вҶ’ ОЈ[ a вҲ¶ A ] B a
          вүғ B x
ОЈ-singl {A = A} {B} sa x = equivвҶҗqiso iso where
  prp : is-prop A
  prp = is-propвҶҗis-single sa

  iso : ОЈ A B вү… B x
  iso ._вү…_.fwd (a , b) = tr B (prp a x) b
  iso ._вү…_.fwd-iso .fst b = (x , b)
  iso ._вү…_.fwd-iso .snd .fst (a , b)
    = ОЈ-pathвҶ’ ((prp x a) ,  IdбөҲ-inr {P = ap B (prp x a)}
              (ap (О» p вҶ’ coe p b)
               (ap (ap B) (is-propвҶҗis-single (пјқ-is-singleвҶҗis-prop prp _ _) _ _)
               вҲҷ ap-sym B (prp x a))))
  iso ._вү…_.fwd-iso .snd .snd bx
    = ap (О» p вҶ’ tr B p bx) (вҲҷ-sym' (sa .central x))

ОЈ-пјқsingl : вҲҖ {рқ“Ө рқ“Ҙ} {A : Type рқ“Ө} {a' : A} {B : (a : A) вҶ’ a пјқ a' вҶ’ Type рқ“Ҙ}
        вҶ’ ОЈ A (О» a вҶ’ ОЈ (a пјқ a') О» p вҶ’ B a p) вүғ B a' refl
ОЈ-пјқsingl {A = A} {a'} {B} = equivвҶҗqiso iso where
  iso : ОЈ A (О» a вҶ’ ОЈ (a пјқ a') (B a)) вү… B a' refl
  iso ._вү…_.fwd (.a' , refl , ba) = ba
  iso ._вү…_.fwd-iso .fst ba = a' , refl , ba
  iso ._вү…_.fwd-iso .snd .fst (.a' , refl , ba) = refl
  iso ._вү…_.fwd-iso .snd .snd _ = refl


ОЈ-пјқsingl' : вҲҖ {рқ“Ө рқ“Ҙ} {A : Type рқ“Ө} {a' : A} {B : (a : A) вҶ’ a' пјқ a вҶ’ Type рқ“Ҙ}
        вҶ’ ОЈ A (О» a вҶ’ ОЈ (a' пјқ a) О» p вҶ’ B a p) вүғ B a' refl
ОЈ-пјқsingl' {A = A} {a'} {B} = equivвҶҗqiso iso where
  iso : ОЈ A (О» a вҶ’ ОЈ (a' пјқ a) (B a)) вү… B a' refl
  iso ._вү…_.fwd (.a' , refl , ba) = ba
  iso ._вү…_.fwd-iso .fst ba = a' , refl , ba
  iso ._вү…_.fwd-iso .snd .fst (.a' , refl , ba) = refl
  iso ._вү…_.fwd-iso .snd .snd _ = refl


ОЈ-comm : вҲҖ {рқ“Ө рқ“Ҙ рқ“Ұ} {A : Type рқ“Ө} {B : Type рқ“Ҙ} {C : A вҶ’ B вҶ’ Type рқ“Ұ}
         вҶ’ (ОЈ A О» a вҶ’ ОЈ B (C a)) вүғ (ОЈ B О» b вҶ’ ОЈ A О» a вҶ’ C a b)
ОЈ-comm {A = A} {B} {C} = mkвүғ f (is-equivвҶҗqiso iso) where
  f : ОЈ A (О» a вҶ’ ОЈ B (C a)) вҶ’ ОЈ B (О» b вҶ’ ОЈ A (О» a вҶ’ C a b))
  f (a , b , c) = b , a , c

  iso : quasi-iso f
  iso .fst (b , a , c) = a , b , c
  iso .snd .fst _ = refl
  iso .snd .snd _ = refl

Г—-вҲ… : вҲҖ {рқ“Ө} {A : Type рқ“Ө} вҶ’ вҲ… Г— A вүғ вҲ…
Г—-вҲ… = mkвүғ fst (is-equivвҶҗqiso iso) where
  iso : quasi-iso fst
  iso .fst ()
  iso .snd .fst ()
  iso .snd .snd ()


Г—-swapвҶ’ : вҲҖ {рқ“Ө рқ“Ҙ} {A : Type рқ“Ө} {B : Type рқ“Ҙ} вҶ’ A Г— B вҶ’ B Г— A
Г—-swapвҶ’ (a , b) = b , a

Г—-swap : вҲҖ {рқ“Ө рқ“Ҙ} {A : Type рқ“Ө} {B : Type рқ“Ҙ}
         вҶ’ (A Г— B) вүғ (B Г— A)
Г—-swap {A = A} {B} = mkвүғ Г—-swapвҶ’ (is-equivвҶҗqiso qiso)  where
  qiso : quasi-iso Г—-swapвҶ’
  qiso .fst (b , a) = (a , b)
  qiso .snd .fst (a , b) = refl
  qiso .snd .snd (b , a) = refl

Г—-assoc
  : вҲҖ {рқ“Ө рқ“Ҙ рқ“Ұ}
      {A : Type рқ“Ө}
      {B : Type рқ“Ҙ}
      {C : Type рқ“Ұ}
    вҶ’ (A Г— B) Г— C вүғ A Г— (B Г— C)
Г—-assoc = ОЈ-assoc

вҠ—-is-equiv : вҲҖ {рқ“Ө рқ“Ҙ рқ“Ұ рқ“ң} {A : Type рқ“Ө} {B : Type рқ“Ҙ}
               {C : Type рқ“Ұ} {D : Type рқ“ң}
               {f : A вҶ’ B} {g : C вҶ’ D}
             вҶ’ is-equiv f вҶ’ is-equiv g
             вҶ’ is-equiv (f вҠ— g)
вҠ—-is-equiv {f = f}{g} feq geq = is-equivвҶҗqiso the-iso where
    open is-equiv
    the-iso : quasi-iso (f вҠ— g)
    the-iso .fst (b , d) = (bwd feq b , bwd geq d)
    the-iso .snd .fst (a , c) = Г—-pathвҶ’ ((О· feq a) , (О· geq c))
    the-iso .snd .snd (b , d) = Г—-pathвҶ’ ((Оө feq b) , (Оө geq d))

_Г—вүғ_ : вҲҖ {рқ“Ө рқ“Ҙ рқ“Ұ рқ“ң} {A : Type рқ“Ө} {B : Type рқ“Ҙ} {C : Type рқ“Ұ} {D : Type рқ“ң}
       вҶ’ A вүғ C вҶ’ B вүғ D вҶ’ (A Г— B) вүғ (C Г— D)
(mkвүғ f ef) Г—вүғ (mkвүғ g eg) = mkвүғ (f вҠ— g) (вҠ—-is-equiv ef eg)

ОЈ-tr : вҲҖ {рқ“Ө рқ“Ҙ рқ“Ұ} {A : Type рқ“Ө} {B : Type рқ“Ҙ} {C : A вҶ’ B вҶ’ Type рқ“Ұ}
         {a b : A} {p : a пјқ b} {b : B} {c : C a b}
       вҶ’ (tr (О» a вҶ’ ОЈ B (C a)) p (b , c)) пјқ (b , tr (О» a вҶ’ C a b) p c)
ОЈ-tr {p = refl} = refl

ОЈ-interchange : вҲҖ {рқ“Ө рқ“Ҙ рқ“Ұ рқ“ң} {A : Type рқ“Ө} {B : A вҶ’ Type рқ“Ҙ} {C : A вҶ’ Type рқ“Ұ}
                  {D : (a : A) вҶ’ B a вҶ’ C a вҶ’ Type рқ“ң} вҶ’
                  (ОЈ[ t@(a , b) вҲ¶ ОЈ A B ] (ОЈ (C a) (D a b)))
                    вүғ
                  (ОЈ[ t@(a , c) вҲ¶ ОЈ A C ] (ОЈ[ b вҲ¶ B a ] (D a b c)))
ОЈ-interchange = equivвҶҗqiso iso where
  iso : вҲҖ {рқ“Ө} {рқ“Ҙ} {рқ“Ұ} {рқ“ң} {A : Type рқ“Ө} {B : A вҶ’ Type рқ“Ҙ}
        {C : A вҶ’ Type рқ“Ұ} {D : (a : A) вҶ’ B a вҶ’ C a вҶ’ Type рқ“ң} вҶ’
      ОЈ (ОЈ A B) (О» t вҶ’ ОЈ (C (t .fst)) (D (t .fst) (t .snd))) вү…
      ОЈ (ОЈ A C) (О» t вҶ’ ОЈ (B (t .fst)) (О» b вҶ’ D (t .fst) b (t .snd)))
  iso ._вү…_.fwd ((a , b) , (c , d))= (a , c) , (b , d)
  iso ._вү…_.fwd-iso .fst ((a , c) , (b , d))= ((a , b) , (c , d))
  iso ._вү…_.fwd-iso .snd .fst ((_ , _) , (_ , _))= refl
  iso ._вү…_.fwd-iso .snd .snd a = refl
}
% ```

\subtree[stt-002T]{
\taxon{Theorem}
\title{Sums of singleton}

\p{Given a family of singleton types #{P : A \to \UU}, the projection from the straightening is an equivalence.}
\proof{
\citet{4.9.3}{HoTT}
\p{The fibre of the projection #{\pi : \Sigma_{(x : A)}P(x) \to A} at some #{x : A} is equivalent to #{P(x)}. By assumption
we have the each #{P(x)} is singleton, and therefore so is each fibre of #{\pi}, thus it is an equivalence. }

% ```agda
\agda{
fibre-straighten : вҲҖ {рқ“Ө рқ“Ҙ} {A : Type рқ“Ө} (P : A вҶ’ Type рқ“Ҙ) вҶ’
                   вҲҖ x вҶ’ fibre (fst {B = P}) x вүғ P x
fibre-straighten P x = equivвҶҗqiso lem where
  lem : fibre fst x вү… P x
  lem ._вү…_.fwd ((a , p) , refl) = p
  lem ._вү…_.fwd-iso .fst p = (x , p) , refl
  lem ._вү…_.fwd-iso .snd .fst (_ , refl) = refl
  lem ._вү…_.fwd-iso .snd .snd a = refl

singleton-fst-is-equiv : вҲҖ {рқ“Ө рқ“Ҙ} {A : Type рқ“Ө} {P : A вҶ’ Type рқ“Ҙ}
              вҶ’ (вҲҖ x вҶ’ is-singleton (P x))
              вҶ’ is-equiv (fst {B = P})
singleton-fst-is-equiv {P = P} sngl
  = is-equivвҶҗis-contr-map О»
      b вҶ’ is-singleвҶҗequiv-to-single (fibre-straighten P b eвҒ»В№) (sngl b)


ОЈ-singleton : вҲҖ {рқ“Ө рқ“Ҙ} {A : Type рқ“Ө} {P : A вҶ’ Type рқ“Ҙ}
              вҶ’ (вҲҖ x вҶ’ is-singleton (P x))
              вҶ’ ОЈ A P вүғ A
ОЈ-singleton {P = P} sngl
  = mkвүғ fst (singleton-fst-is-equiv sngl)
}
% ```
}
}

\subtree[stt-009B]{
\title{Commuting coproducts with dependent sums}
\taxon{Theorem}

\p{There is an equivalence #{\Sigma_{A + B} (Q[f,g]) \simeq
\Sigma_A(Qf) + \Sigma_B(Qg)}}

%```agda
\agda{
ОЈ-вҠҺвүғ : вҲҖ {рқ“Ө рқ“Ҙ рқ“Ұ} {A : Type рқ“Ө} {B : Type рқ“Ҙ} (P  : A вҠҺ B вҶ’ Type рқ“Ұ)
      вҶ’ (ОЈ _ (P вҲҳ inl)) вҠҺ (ОЈ _ (P вҲҳ inr)) вүғ ОЈ (A вҠҺ B) P
ОЈ-вҠҺвүғ P = mkвүғ вҠҺ[ total-map-fst inl , total-map-fst inr ]
            (is-equivвҶҗqiso iso) where
  iso : quasi-iso вҠҺ[ total-map-fst inl , total-map-fst inr ]
  iso .fst (inl x , p) = inl (x , p)
  iso .fst (inr x , p) = inr (x , p)
  iso .snd .fst = вҠҺ-ind (~refl , ~refl)
  iso .snd .snd (inl x , p) = refl
  iso .snd .snd (inr x , p) = refl
}
%```
}

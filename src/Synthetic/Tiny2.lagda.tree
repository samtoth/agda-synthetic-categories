  --       ⟨♭| ((I → Γ) → A × B) ⟩                  ≃⟨ ♭≃ (Σ-Π-swap≃ (λ _ → A) (λ _ _ → B)) ⟩
  --       ⟨♭| (((I → Γ) → A) × ((I → Γ) → B)) ⟩    ≃⟨ ♭-pres-× ⟩

      тЖТ is-cartesian F
  is-cartesianтЖР1-coherent-retraction-cube ╬▒ ╬▓ gcart
    = is-cartesianтЖРis-pullback _
        (is-equivтЖРincoherent-retraction-equiv
          (gap-map-squareтЖРcube _ _ ╬▒)
          (gap-map-square-retтЖРcube-partial-ret _ _ ╬▒ ╬▓)
          (is-pullbackтЖРup-pullback _
            (up-pullbackтЖРis-cartesian _ gcart)))
}
}

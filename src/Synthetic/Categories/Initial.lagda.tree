\subtree[stt-00FO]{
\title{Initial objects}
\taxon{Definition}

\p{
We call an object #{a : A} \em{initial} if for every #{b : A}, the type #{\Hom(a,b)}
is a singleton.
}

%```agda
\agda{
is-initial : вИА {рЭУ§} {A : Type рЭУ§} вЖТ A вЖТ Type (рЭУШ вКФ рЭУ§)
is-initial a = вИА b вЖТ is-singleton (Hom _ a b)
}
%```
}

\subtree[stt-00FP]{
\taxon{Lemma}

\p{An object #{a} is initial iff the codomain projection #{A_{a/} \to A} is
an equivalence.}

\proof{
\p{Follows by considering fibres.}
}

%```agda
\agda{
is-initialвЖРslice-proj-is-equiv
  : вИА {рЭУ§} {A : Type рЭУ§} a
    вЖТ is-equiv (ќї ((f , _) : ќ£[ f вИґ (ќФ¬є вЖТ A)] (f i0 пЉЭ a)) вЖТ f i1)
    вЖТ is-initial a
is-initialвЖРslice-proj-is-equiv a eq b
  = is-singleвЖРequiv-to-single
      (ќ£-assoc вИЩвЙГ HomбµИ-reprвЙГ eвБї¬є)
      (is-contr-mapвЖРis-equiv eq b)
}
%```
}

\subtree[stt-00G0]{
\taxon{Lemma}
\title{Initial objects are preserved by left adjoints}

\p{
For a map #{l : A \to B}, if there is a map #{r} with #{l \dashv r},
#{l(a)} is an initial object of #{B} if #{a} is initial in #{A}.
}

%```agda
\agda{
is-initialвЖРladj
  : вИА {рЭУ§ рЭУ•} {A : Type рЭУ§} {B : Type рЭУ•} {a : A}
    вЖТ (l : A вЖТ B) (r : B вЖТ A)
    вЖТ (l вК£ r)
    вЖТ is-initial a
    вЖТ is-initial (l a)
is-initialвЖРladj f g fg ai b
  = is-singleвЖРequiv-to-single (fg _ b eвБї¬є) (ai (g b))
}
%```

\p{
In particular, since [equivalences are left adjoints](stt-00G2), they also preserve
initial objects.
}

%```agda
\agda{
opaque
  is-initialвЖРis-equiv
    : вИА {рЭУ§ рЭУ•} {A : Type рЭУ§} {B : Type рЭУ•} {a : A}
      вЖТ {F : A вЖТ B} вЖТ is-equiv F
      вЖТ is-initial a вЖТ is-initial (F a)
  is-initialвЖРis-equiv {F = F}
    = is-initialвЖРladj F _  вИШ is-left-adjointвЖРis-equiv
}
%```
}

\subtree[stt-00LJ]{
\title{Initiality in the coslice}
\taxon{Theorem}
\author{samueltoth}
\author{fredrikbakke}

\p{
If #{A} is a precategory, then #{(a , \id)} is an initial object in the representable
coslice #{\Sigma_{x : A}\Hom_A(a,x)}.
}

%```agda
\agda{
module _ {рЭУ§ : Level} {A : Type рЭУ§} (рЭРівВЧ : is-left-segal A) where

  tr-cov-hom-idH
    : {a b : A} (f : Hom A a b)
    вЖТ tr-cov-hom (hom-fam-cov рЭРівВЧ a) f (idH a) пЉЭ f
  tr-cov-hom-idH f
    = CovariantActionPostcomp.tr-cov-hom-is-comp рЭРівВЧ f (idH _)
    вИЩ вИШ-left-unit (is-segalвЖРis-left-segal рЭРівВЧ) f

  Sing'-HomвЙГHom-repr-coslice
    : {a b : A} (f : Hom A a b)
    вЖТ Sing' (Hom A a b) f вЙГ Hom (ќ£ A (Hom _ a)) (a , idH a) (b , f)
  Sing'-HomвЙГHom-repr-coslice {a} f
    = ќ£-ap-вЙГ
        (ќї g вЖТ пЉЭ-postcomp-вЙГ (tr-cov-hom-idH g)
             вИЩвЙГ Hom-cov'вЙГ (Hom _ a) (hom-fam-cov рЭРівВЧ a) g (idH a) f)
    вИЩвЙГ Hom-ќ£вЙГ eвБї¬є

  coslice-init'-left-segal
    : (a : A) вЖТ is-initial {A = ќ£ A (Hom _ a)} (a , idH a)
  coslice-init'-left-segal a (b , f)
    = is-singleвЖРequiv-to-single (Sing'-HomвЙГHom-repr-coslice f) Sing'-is-singleton

coslice-init'
  : {рЭУ§ : Level} {A : Type рЭУ§} (As : is-segal A) (Asimp : is-simplicial A) (a : A)
  вЖТ is-initial (a , idH a)
coslice-init' As Asimp
  = coslice-init'-left-segal
      (is-left-segalвЖРis-segalвЖРis-triangulated (simp-is-triangulated Asimp) As)
}
%```

\p{
As a corollary, if #{A} is a precategory (or more generally left Segal), then
#{(a , \id)} is an initial object in #{A_{a/}}.
}

%```agda
\agda{
coslice-init-left-segal
  : {рЭУ§ : Level} {A : Type рЭУ§} (рЭРівВЧ : is-left-segal A) (a : A)
  вЖТ is-initial {A = Coslice A (point a)} (a , ќї _ вЖТ idH a)
coslice-init-left-segal рЭРівВЧ a
  = is-initialвЖРis-equiv
      (ќ£-ap-вЙГ (ќї _ вЖТ unit-UPвЙГ eвБї¬є) ._вЙГ_.has-is-eqv)
      (coslice-init'-left-segal рЭРівВЧ a)

coslice-init
  : {рЭУ§ : Level} {A : Type рЭУ§} (As : is-segal A) (Asimp : is-simplicial A) (a : A)
  вЖТ is-initial {A = Coslice A (point a)} (a , ќї _ вЖТ idH a)
coslice-init As Asimp
  = coslice-init-left-segal
      (is-left-segalвЖРis-segalвЖРis-triangulated (simp-is-triangulated Asimp) As)
}
%```
}

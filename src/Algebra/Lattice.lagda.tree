\subtree[stt-009T]{
\title{Lattices}
\taxon{Definition}
\p{A lattice #{L} is an algebraic structure with a pair of commutative monoids
#{\wedge,\vee}, satisfying absorption laws.  Equivalently this
structure can be described by a poset, with operations taking binary meets
(#{\land}) and joins (#{\lor}) for each pair of elements.}

%```agda
\agda{
record is-lattice {ЁЭУд} {L : Type ЁЭУд} (0l 1l : L) (_тИз_ : L тЖТ L тЖТ L)
                  (_тИи_ : L тЖТ L тЖТ L) : Type ЁЭУд where
  no-eta-equality
  field
    car-is-0-truncated  : is-truncated 0 L
    тИз-assoc : {x y z : L} тЖТ x тИз (y тИз z) я╝Э (x тИз y) тИз z
    тИи-assoc : {x y z : L} тЖТ x тИи (y тИи z) я╝Э (x тИи y) тИи z
    тИз-comm : {x y : L} тЖТ x тИз y я╝Э y тИз x
    тИи-comm : {x y : L} тЖТ x тИи y я╝Э y тИи x
    тИи-тИз-abs : {x y : L} тЖТ x тИи (x тИз y) я╝Э x
    тИз-тИи-abs : {x y : L} тЖТ x тИз (x тИи y) я╝Э x
    0-bottom : {x : L} тЖТ x тИи 0l я╝Э x
    1-top    : {x : L} тЖТ x тИз 1l я╝Э x

  instance
    Car-is-truncated : тИА {k} тЖТ Is-truncated (ЁЭХЛтЖРтДХ k) L
    Car-is-truncated = truncation-instance _ car-is-0-truncated

record Lattice {тДУ} (L : Type тДУ) : Type тДУ where
  field
    0l 1l : L
    _тИз_ : L тЖТ L тЖТ L
    _тИи_ : L тЖТ L тЖТ L
    str-is-lattice : is-lattice 0l 1l (_тИз_) (_тИи_)
  infixr 25 _тИз_
  infixr 24 _тИи_

  _тЙд_ : L тЖТ L тЖТ Type тДУ
  x тЙд y = x тИз y я╝Э x

  open is-lattice str-is-lattice public

  is-prop-separated : тИА x y тЖТ is-prop (x я╝Э y)
  is-prop-separated x y = is-setтЖРis-truncated car-is-0-truncated x y

  1-coinit : тИА {x} тЖТ x тИи 1l я╝Э 1l
  1-coinit {x}
    =   x тИи 1l
      я╝ЭтЯи ap (_тИи 1l) (sym 1-top тИЩ тИз-comm) тЯй
        (1l тИз x) тИи 1l
      я╝ЭтЯи тИи-comm тИЩ тИи-тИз-abs тЯй
        1l тИО

  0-init : тИА {x} тЖТ 0l тИз x я╝Э 0l
  0-init {x}
    =   0l тИз x
      я╝ЭтЯи ap (0l тИз_) (sym (тИи-comm тИЩ 0-bottom)) тЯй
        (0l тИз (0l тИи x))
      я╝ЭтЯи тИз-тИи-abs тЯй
        0l тИО

  тИз-idem : тИА {x : L} тЖТ x тИз x я╝Э x
  тИз-idem {x} = x тИз x             я╝ЭтЯи ap (x тИз_) (sym тИи-тИз-abs) тЯй
               x тИз (x тИи (x тИз x)) я╝ЭтЯи тИз-тИи-abs тЯй
               x тИО

  тИи-idem : тИА {x : L} тЖТ x тИи x я╝Э x
  тИи-idem {x} = (x тИи x)        я╝ЭтЯи ap (x тИи_) (sym 1-top) тЯй
               (x тИи (x тИз 1l)) я╝ЭтЯи тИи-тИз-abs тЯй
               x тИО

  тИи-тИз-abs' : тИА {a b} тЖТ (a тИи b) тИз b я╝Э b
  тИи-тИз-abs' = ap (_тИз _) тИи-comm тИЩ тИз-comm тИЩ тИз-тИи-abs

  тИз-тИи-abs' : тИА {a b} тЖТ (a тИз b) тИи b я╝Э b
  тИз-тИи-abs' = ap (_тИи _) тИз-comm тИЩ тИи-comm тИЩ тИи-тИз-abs

  =тИитЖР= : тИА {a b} тЖТ a я╝Э b тЖТ a я╝Э a тИи b
  =тИитЖР= {a} {b} p = sym тИи-idem тИЩ ap (a тИи_) p

  =тИи'тЖР= : тИА {a b} тЖТ a я╝Э b тЖТ a я╝Э b тИи a
  =тИи'тЖР= {a} {b} p = sym тИи-idem тИЩ ap (_тИи a) p

  тЙд-is-poset : is-poset (_тЙд_)
  тЙд-is-poset =
    record { тЙд-is-prop = тЙд-is-prop
           ; тЙд-refl = тЙд-refl
           ; тЙд-trans = тЙд-trans
           ; тЙд-antisym = тЙд-antisym }
    where
      тЙд-is-prop : {x y : L} тЖТ is-prop (x тЙд y)
      тЙд-is-prop = is-prop-separated _ _

      тЙд-refl : {x : L} тЖТ x тЙд x
      тЙд-refl = тИз-idem

      тЙд-trans : {x y z : L} тЖТ x тЙд y тЖТ y тЙд z тЖТ x тЙд z
      тЙд-trans {x} {y} {z} p q =  x тИз z        я╝ЭтЯи ap (_тИз z) (sym p) тЯй
                                  (x тИз y) тИз z я╝ЭтЯи sym тИз-assoc тЯй
                                  x тИз (y тИз z) я╝ЭтЯи ap (x тИз_) q тЯй
                                  x тИз y       я╝ЭтЯи p тЯй
                                  x тИО

      тЙд-antisym : {x y : L} тЖТ x тЙд y тЖТ y тЙд x тЖТ x я╝Э y
      тЙд-antisym {x} {y} p q = sym p тИЩ тИз-comm тИЩ q


  open is-poset тЙд-is-poset public

  тЙдтЖРя╝Э : тИА {a b} тЖТ a я╝Э b тЖТ a тЙд b
  тЙдтЖРя╝Э refl = тЙд-refl

  тЙетЖРя╝Э : тИА {a b} тЖТ a я╝Э b тЖТ b тЙд a
  тЙетЖРя╝Э refl = тЙд-refl

  тЙд-max : тИА {a b} тЖТ a тЙд b тЖТ a тИи b я╝Э b
  тЙд-max {a} {b} p
    = a тИи b             я╝ЭтЯи ap (_тИи b) (sym p) тЯй
      (a тИз b) тИи b       я╝ЭтЯи тИз-тИи-abs' тЯй
      b тИО

  тЙдтЖРтИи : тИА {a b} тЖТ a тИи b я╝Э b тЖТ a тЙд b
  тЙдтЖРтИи {a} {b} p
    = a тИз b           я╝ЭтЯи ap (a тИз_) (sym p) тЯй
      a тИз (a тИи b)     я╝ЭтЯи тИз-тИи-abs тЯй
      a тИО

  тИи-UP : тИА {a b c} тЖТ a тЙд c ├Ч b тЙд c тЖТ (a тИи b тЙд c)
  тИи-UP {a} {b} {c} (f , g)
    = тЙдтЖРтИи (sym тИи-assoc тИЩ тЙд-max (ap (a тИз_) (тЙд-max g) тИЩ f) тИЩ тЙд-max g)

  тИи-UP-is-equiv : тИА {a b c} тЖТ is-equiv (тИи-UP {a}{b}{c})
  тИи-UP-is-equiv {a} {b} {c} = is-equivтЖРinverse
                    (├Ч-is-prop (is-prop-separated _ _) (is-prop-separated _ _))
                    (is-prop-separated _ _)
                    ╬╗ x тЖТ ap (_тИз _) (sym (тИз-тИи-abs {a}{b}) )
                          тИЩ sym тИз-assoc тИЩ ap (a тИз_) x
                          тИЩ тИз-тИи-abs
                        , ap (_тИз _) (sym (тИз-тИи-abs {b} {a}))
                          тИЩ sym тИз-assoc
                          тИЩ ap (b тИз_) (ap (_тИз c) тИи-comm тИЩ x тИЩ тИи-comm)
                          тИЩ тИз-тИи-abs

  тИи-тЙд-introl : тИА {a b c} тЖТ a тЙд b тЖТ a тЙд (b тИи c)
  тИи-тЙд-introl p = тЙд-trans p тИз-тИи-abs

  тИи-тЙд-intror : тИА {a b c} тЖТ a тЙд c тЖТ a тЙд (b тИи c)
  тИи-тЙд-intror p = тЙд-trans p (ap (_ тИз_) тИи-comm тИЩ тИз-тИи-abs)

  тИз-UP : тИА {a b c} тЖТ a тЙд b ├Ч a тЙд c тЖТ a тЙд b тИз c
  тИз-UP (p , q) = тИз-assoc тИЩ ap (_тИз _) p тИЩ q

  тИз-тЙд-eliml : тИА {a b c} тЖТ a тЙд c тЖТ (a тИз b) тЙд c
  тИз-тЙд-eliml {a}{b}{c} p = тИз-comm тИЩ тИз-assoc тИЩ ap (_тИз b) (тИз-comm тИЩ p)

  тИз-тЙд-elimr : тИА {a b c} тЖТ b тЙд c тЖТ (a тИз b) тЙд c
  тИз-тЙд-elimr {a}{b}{c} q = sym тИз-assoc тИЩ ap (a тИз_) q

  instance
    тЙд-bot : тИА {i} тЖТ 0l тЙд i
    тЙд-bot = 0-init

    тЙд-refl-inst : тИА {i} тЖТ i тЙд i
    тЙд-refl-inst = тЙд-refl

    тЙд-top = 1-top
    {-# INCOHERENT тЙд-refl-inst тЙд-top #-}

    тЙд-тИз : тИА {a b c d} тЖТ тжГ _ : a тЙд b тжД тЖТ тжГ _ : c тЙд d тжД
          тЖТ (a тИз c) тЙд (b тИз d)
    тЙд-тИз = тИз-UP (тИз-тЙд-eliml auto! , тИз-тЙд-elimr auto!)

    тЙд-тИи : тИА {a b c d} тЖТ тжГ _ : a тЙд b тжД тЖТ тжГ _ : c тЙд d тжД
          тЖТ (a тИи c) тЙд (b тИи d)
    тЙд-тИи = тИи-UP (тИи-тЙд-introl auto! , тИи-тЙд-intror auto!)
}
%```
}

\subtree[stt-00A4]{
\title{Lattice homomorphisms}
\taxon{Definition}

\p{Given [lattice structures](stt-009T) #{L} and #{M} over sets #{A} and #{B}, we say
that a function #{f : A \to B} is a \strong{lattice homomorphism} when it
preserves the lattice operations. Being a lattice homomorphisms is a
[property](stt-0009) of a function.}

%```agda
\agda{
record is-lattice-hom
        {ЁЭУд} {ЁЭУд'} {A : Type ЁЭУд} {B : Type ЁЭУд'}
        (L : Lattice A) (M : Lattice B) (f : A тЖТ B) : Type (ЁЭУд тКФ ЁЭУд') where
  private
    module A = Lattice L
    module B = Lattice M
  field
    pres-тИи : {x y : A} тЖТ f (x A.тИи y) я╝Э f x B.тИи f y
    pres-тИз : {x y : A} тЖТ f (x A.тИз y) я╝Э f x B.тИз f y
    pres-0 : f A.0l я╝Э B.0l
    pres-1 : f A.1l я╝Э B.1l

unquoteDecl lattice-hom-reprтЙК lattice-hom-reprтЙГ
  = make-record-repr lattice-hom-reprтЙК lattice-hom-reprтЙГ
                     (quote is-lattice-hom)

is-lattice-hom-is-prop
  : тИА {ЁЭУд ЁЭУе} {A : Type ЁЭУд} {B : Type ЁЭУе}
      (L : Lattice A) (M : Lattice B) (f : A тЖТ B)
    тЖТ is-prop (is-lattice-hom L M f)
is-lattice-hom-is-prop {A = A} {B} L M f
  = is-propтЖРequiv-to-prop
      (lattice-hom-reprтЙГ eтБ╗┬╣) (is-propтЖРis-truncated trunc!) where
   open Lattice L
   open Lattice M
}
%```
}

\subtree[stt-009Z]{
\taxon{Definition}
\title{Lattice algebras and algebra morphisms}

\p{Fixing a lattice #{L}, we say that a lattice #{M} with a map of sets from
#{L} (that is - an object of the [coslice category](stt-0062) under #{L}) is a
lattice algebra if the underlying function is a
[lattice homomorphism](stt-009Y). Given a pair of coslices #{f} and #{g} under
#{L} which are lattice algebras, we say that a [coslice map](stt-0062) #{f \to
g} is a lattice algebra homomorphism if the underlying map is a
[lattice homomorphism](stt-009Y). }

%```agda
\agda{
is-lattice-algebra : тИА {ЁЭУд ЁЭУе : Level} {A : Type ЁЭУд} {B : Type ЁЭУе}
                       (L : Lattice A) (M : Lattice B) (f : A тЖТ B)
                     тЖТ Type (ЁЭУд тКФ ЁЭУе)
is-lattice-algebra = is-lattice-hom

is-lattice-alg-hom : тИА {ЁЭУд ЁЭУе ЁЭУж} {A : Type ЁЭУд} {B : Type ЁЭУе} {C : Type ЁЭУж}
                        (L : Lattice A)
                        (M : Lattice B) {f : A тЖТ B}
                      тЖТ is-lattice-algebra L M f
                      тЖТ (N : Lattice C) {g : A тЖТ C}
                      тЖТ is-lattice-algebra L N g
                      тЖТ Coslice-map f g тЖТ Type (ЁЭУе тКФ ЁЭУж)
is-lattice-alg-hom L M _ N _ (h , H) = is-lattice-hom M N h
}
%```
}

\subtree[stt-00A0]{
\taxon{Theorem}
\title{The initial lattice algebra}

\p{The initial coslice (the identity function) is also the initial lattice
algebra.}

%```agda
\agda{
initial-lattice-algebra : тИА {ЁЭУд : Level} {A : Type ЁЭУд} (L : Lattice A)
                          тЖТ is-lattice-algebra L L id
initial-lattice-algebra L .is-lattice-hom.pres-тИи = refl
initial-lattice-algebra L .is-lattice-hom.pres-тИз = refl
initial-lattice-algebra L .is-lattice-hom.pres-0 = refl
initial-lattice-algebra L .is-lattice-hom.pres-1 = refl

initial-lattice-algebra-is-initial
  : тИА {ЁЭУд ЁЭУе} {A : Type ЁЭУд} (L : Lattice A) {X : Type ЁЭУе} (M : Lattice X)
      {f : A тЖТ X}
    тЖТ (falg : is-lattice-algebra L M f)
    тЖТ is-singleton
        (╬г _ (is-lattice-alg-hom L L (initial-lattice-algebra L) M falg))
initial-lattice-algebra-is-initial L M {f} falg
  = mk-singl (initial-coslice f .centre , falg)
             (╬г-is-prop (is-propтЖРis-single (initial-coslice f))
                        (╬╗ a тЖТ is-lattice-hom-is-prop _ _ _) _)
}
%```
}

\subtree[stt-009S]{
\title{Congruences}
\taxon{Definition}
\p{An equivalence relation #{\sim} on a lattice #{L} is a congruence if it
respects all lattice operations}

%```agda
\agda{
module Congruence where


record LatticeCongruence {ЁЭУд ЁЭУе} {A : Type ЁЭУд} (L : Lattice A)
                         (_~_ : A тЖТ A тЖТ Type ЁЭУе) : Type (ЁЭУд тКФ ЁЭУе) where
  open Lattice L
  field
    ~-equivalence : is-equivalence-relation (_~_)
    ~-тИи : {a1 a2 b1 b2 : A} тЖТ a1 ~ b1 тЖТ a2 ~ b2 тЖТ a1 тИи a2 ~ b1 тИи b2
    ~-тИз : {a1 a2 b1 b2 : A} тЖТ a1 ~ b1 тЖТ a2 ~ b2 тЖТ a1 тИз a2 ~ b1 тИз b2

  open is-equivalence-relation (~-equivalence) public


module _ {ЁЭУд} {ЁЭУе} {A : Type ЁЭУд} {L : Lattice A} where
  open Lattice L
  data тЯк_тЯл (R : A тЖТ A тЖТ Type ЁЭУе) : A тЖТ A тЖТ Type (ЁЭУд тКФ ЁЭУе) where
    тЯктЯл-inc  : {a b : A} тЖТ R a b тЖТ тЯк R тЯл a b
    тЯктЯл-refl : {a : A} тЖТ тЯк R тЯл a a
    тЯктЯл-sym  : {a b : A} тЖТ тЯк R тЯл a b тЖТ тЯк R тЯл b a
    тЯктЯл-trans : {a b c : A} тЖТ тЯк R тЯл a b тЖТ тЯк R тЯл b c тЖТ тЯк R тЯл a c
    тЯктЯл-тИи : {a1 a2 b1 b2 : A} тЖТ тЯк R тЯл a1 b1 тЖТ тЯк R тЯл a2 b2 тЖТ тЯк R тЯл (a1 тИи a2) (b1 тИи b2)
    тЯктЯл-тИз : {a1 a2 b1 b2 : A} тЖТ тЯк R тЯл a1 b1 тЖТ тЯк R тЯл a2 b2 тЖТ тЯк R тЯл (a1 тИз a2) (b1 тИз b2)

  тЯктЯл-congruence : {R : A тЖТ A тЖТ Type ЁЭУе}
                тЖТ LatticeCongruence L (╬╗ x y тЖТ тХС тЯк R тЯл x y тХС)
  тЯктЯл-congruence {R} = l-con where
    open LatticeCongruence
    open Trunc {n = -1}
    module E = is-equivalence-relation

    l-eq : is-equivalence-relation (╬╗ x y тЖТ тХС тЯк R тЯл x y тХС)
    l-eq .E.~-is-prop = is-propтЖРis-truncated тЧЛтИИS
    l-eq .E.reflexive = ╬╖ тЯктЯл-refl
    l-eq .E.symmetric a = do
      rxy тЖР a
      return (тЯктЯл-sym rxy)
    l-eq .E.transitive a b = do
      rxy тЖР a
      ryz тЖР b
      return (тЯктЯл-trans rxy ryz)

    l-con : LatticeCongruence L (╬╗ x y тЖТ тХС тЯк _ тЯл x y тХС)
    l-con .~-equivalence = l-eq
    l-con .~-тИи p q = do
      r1 тЖР p
      r2 тЖР q
      return (тЯктЯл-тИи r1 r2)
    l-con .~-тИз p q = do
      r1 тЖР p
      r2 тЖР q
      return (тЯктЯл-тИз r1 r2)
}
%```
}


\subtree[stt-00A3]{
\title{Distributive lattices}
\taxon{Definition}

%```agda
\agda{
record is-distributive {ЁЭУд} {L : Type ЁЭУд} (Lat : Lattice L)  : Type ЁЭУд where
  open Lattice Lat

  field
    has-is-distrib : тИА {x y z} тЖТ x тИи (y тИз z) я╝Э (x тИи y) тИз (x тИи z)

  distrib-тИи-тИз = has-is-distrib

  distrib-тИи-тИз' : тИА {x y z} тЖТ (x тИз y) тИи z я╝Э (x тИи z) тИз (y тИи z)
  distrib-тИи-тИз' = тИи-comm тИЩ distrib-тИи-тИз тИЩ apтВВ _тИз_ тИи-comm тИи-comm

  distrib-тИз-тИи : тИА {x y z} тЖТ x тИз (y тИи z) я╝Э (x тИз y) тИи (x тИз z)
  distrib-тИз-тИи {x} {y} {z}
    = тМЬ x тМЭ тИз (y тИи z)             я╝ЭтЯи ap! (sym тИз-тИи-abs) тЯй
      ((x тИз (x тИи z)) тИз (y тИи z) )  я╝ЭтЯи sym тИз-assoc тЯй
      (x тИз (x тИи z) тИз (y тИи z))     я╝ЭтЯи apтВВ _тИз_
                                         (sym тИи-тИз-abs тИЩ тИи-comm)
                                         (sym (distrib-тИи-тИз')) тЯй
      ((x тИз y тИи x) тИз (x тИз y тИи z)) я╝ЭтЯи sym distrib-тИи-тИз тЯй
      ((x тИз y) тИи (x тИз z)) тИО

  distrib-тИз-тИи' : тИА {x y z} тЖТ (x тИи y) тИз z я╝Э (x тИз z) тИи (y тИз z)
  distrib-тИз-тИи' = тИз-comm тИЩ distrib-тИз-тИи тИЩ apтВВ _тИи_ тИз-comm тИз-comm

  distribтВВ-тИз-тИи : тИА {x y z w}
                 тЖТ x тИз (y тИи z тИи w) я╝Э x тИз y тИи x тИз z тИи x тИз w
  distribтВВ-тИз-тИи {x} {y}{z}{w}
    = distrib-тИз-тИи тИЩ ap (x тИз y тИи_) distrib-тИз-тИи

  distribтВВ-тИз-тИи' : тИА {x y z w}
                 тЖТ (y тИи z тИи w) тИз x я╝Э y тИз x тИи z тИз x тИи w тИз x
  distribтВВ-тИз-тИи' {x} {y}{z}{w}
    = тИз-comm тИЩ distribтВВ-тИз-тИи тИЩ apтВГ (╬╗ x y z тЖТ x тИи (y тИи z)) тИз-comm тИз-comm тИз-comm

  opaque
    polynomial-mult
      : тИА {aтВА aтВБ bтВА bтВБ} x тЖТ
          (aтВА тИи (aтВБ тИз x)) тИз (bтВА тИи (bтВБ тИз x))
        я╝Э (aтВА тИз bтВА) тИи (((aтВБ тИз bтВА) тИи (aтВА тИз bтВБ) тИи (aтВБ тИз bтВБ)) тИз x)
    polynomial-mult {aтВА} {aтВБ} {bтВА} {bтВБ} x
      = (aтВА тИи aтВБ тИз x) тИз (bтВА тИи bтВБ тИз x)
          я╝ЭтЯи distrib-тИз-тИи тЯй
        ((aтВА тИи aтВБ тИз x) тИз bтВА тИи тМЬ (aтВА тИи aтВБ тИз x) тИз bтВБ тИз x тМЭ)
          я╝ЭтЯи ap! (тИз-assoc тИЩ ap (_тИз x) distrib-тИз-тИи' тИЩ distrib-тИз-тИи' ) тЯй
        ((aтВА тИи aтВБ тИз x) тИз bтВА тИи (aтВА тИз bтВБ) тИз x тИи тМЬ ((aтВБ тИз x) тИз bтВБ) тИз x тМЭ)
          я╝ЭтЯи ap! (ap (_тИз x) (sym тИз-assoc тИЩ ap (aтВБ тИз_) тИз-comm) тИЩ sym тИз-assoc
                     тИЩ ap (aтВБ тИз_) (sym тИз-assoc тИЩ ap (bтВБ тИз_) тИз-idem)) тЯй
        (тМЬ (aтВА тИи aтВБ тИз x) тИз bтВА тМЭ тИи (aтВА тИз bтВБ) тИз x тИи aтВБ тИз bтВБ тИз x)
          я╝ЭтЯи ap! (distrib-тИз-тИи'
                 тИЩ ap (aтВА тИз bтВА тИи_) (sym тИз-assoc тИЩ ap (aтВБ тИз_) тИз-comm)) тЯй
        ((aтВА тИз bтВА тИи (aтВБ тИз bтВА тИз x)) тИи (aтВА тИз bтВБ) тИз x тИи aтВБ тИз bтВБ тИз x)
          я╝ЭтЯи apтВВ _тИи_ (ap (aтВА тИз bтВА тИи_) тИз-assoc)
                      (ap ((aтВА тИз bтВБ) тИз x тИи_) тИз-assoc тИЩ sym distrib-тИз-тИи') тЯй
        ((aтВА тИз bтВА) тИи ((aтВБ тИз bтВА) тИз x)) тИи (aтВА тИз bтВБ тИи aтВБ тИз bтВБ) тИз x
          я╝ЭтЯи sym тИи-assoc тИЩ ap (aтВА тИз bтВА тИи_) (sym distrib-тИз-тИи') тЯй
        (aтВА тИз bтВА тИи (aтВБ тИз bтВА тИи aтВА тИз bтВБ тИи aтВБ тИз bтВБ) тИз x) тИО

    polynomial-mult'
      : тИА {aтВА aтВБ bтВА bтВБ} x тЖТ
           ((aтВА тИз x) тИи aтВБ) тИз ((bтВА тИз x) тИи bтВБ)
        я╝Э (((aтВА тИз bтВБ) тИи (aтВБ тИз bтВА) тИи (aтВА тИз bтВА)) тИз x) тИи (aтВБ тИз bтВБ)
    polynomial-mult' {aтВА} {aтВБ} {bтВА} {bтВБ} x
      = ((aтВА тИз x тИи aтВБ) тИз (bтВА тИз x тИи bтВБ))
          я╝ЭтЯи apтВВ _тИз_ тИи-comm тИи-comm тЯй
        ((aтВБ тИи aтВА тИз x) тИз (bтВБ тИи bтВА тИз x))
          я╝ЭтЯи polynomial-mult x тЯй
        (aтВБ тИз bтВБ тИи (aтВА тИз bтВБ тИи aтВБ тИз bтВА тИи aтВА тИз bтВА) тИз x)
          я╝ЭтЯи тИи-comm тЯй
        ((aтВА тИз bтВБ тИи aтВБ тИз bтВА тИи aтВА тИз bтВА) тИз x тИи aтВБ тИз bтВБ) тИО
}
%```
}

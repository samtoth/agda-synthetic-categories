open import Ergonomics.Extensionality
open import Ergonomics.Marker
}
% ```


\subtree[stt-002S]{
\taxon{Definition}
\title{Joins of types}

\p{The join of types #{A} and #{B}, written #{A * B} is
the pushout of the span
#{A \xleftarrow{\pi_1} A \times B \xrightarrow{\pi_2} B}}

\quiver{
\begin{tikzcd}
	{A \times B} && A \\
	\\
	B && {A * B}
	\arrow[from=1-1, to=1-3]
	\arrow[from=1-1, to=3-1]
	\arrow[from=1-3, to=3-3]
	\arrow[from=3-1, to=3-3]
	\arrow["\lrcorner"{anchor=center, pos=0.125, rotate=180}, draw=none, from=3-3, to=1-1]
\end{tikzcd}
}

% ```agda
\agda{
infixl 25 _*_

_*_ : вҲҖ {рқ“Ө рқ“Ҙ} вҶ’ Type рқ“Ө вҶ’ Type рқ“Ҙ вҶ’ Type (рқ“Ө вҠ” рқ“Ҙ)
A * B = Pushout {A = A Г— B} fst snd
}
% ```
}


\subtree[stt-002V]{
\title{Singleton joins}

\p{The join of a singleton with any type is also a singleton}

\proof{
\p{This follows from the fact that [pushing an equivalence out gives
an equivalence](stt-0080).}
}

% ```agda
\agda{
*-comm : вҲҖ {рқ“Ө рқ“Ҙ} {A : Type рқ“Ө} {B : Type рқ“Ҙ} вҶ’ A * B вүғ B * A
*-comm {A = A} {B} = pushout-comm вҲҷвүғ (Pushout-adjust-equiv Г—-swap)


*-single' : вҲҖ {рқ“Ө рқ“Ҙ} {A : Type рқ“Ө} {B : Type рқ“Ҙ}
            вҶ’ is-singleton B вҶ’ is-singleton (A * B)
*-single' {A = A} {B} sb
  = is-singleвҶҗequiv-to-single (mkвүғ _ О№вӮӮ-is-equiv) sb where
  О№вӮӮ-is-equiv : is-equiv {B = A * B} О№вӮӮ
  О№вӮӮ-is-equiv = dom-is-equivвҶҗcocartesian
                  (mk-amap snd О№вӮҒ glue)
                  (singleton-fst-is-equiv (О» _ вҶ’ sb))
                  (is-cocartesianвҶҗis-pushout Pushout-is-pushoutПү)

*-single : вҲҖ {рқ“Ө рқ“Ҙ} {A : Type рқ“Ө} {B : Type рқ“Ҙ}
           вҶ’ is-singleton A вҶ’ is-singleton (A * B)
*-single sa
  = is-singleвҶҗequiv-to-single *-comm (*-single' sa)
}
% ```
}

\subtree[stt-002W]{
\taxon{Theorem}
\title{Joins of propositions}

\p{The universal property for joins of propositions says that
for propositions #{P} and #{Q}, to eliminate into a proposition #{R},
it suffices to supply #{P \to R}, and #{Q \to R}}

\p{As an easy corollary, we have that the join of two propositions
is again a proposition.}

% ```agda
\agda{
*-prop-disj : вҲҖ {рқ“Ө рқ“Ҙ рқ“Ұ} {A : Type рқ“Ө} {B : Type рқ“Ҙ}
              {Q : Type рқ“Ұ}
           вҶ’ is-prop A вҶ’ is-prop B
           вҶ’ is-prop Q
           вҶ’ (A * B вҶ’ Q) вҶ’ (A вҶ’ Q) Г— (B вҶ’ Q)
*-prop-disj a b q f = (f вҲҳ О№вӮҒ , f вҲҳ О№вӮӮ)


*-prop-disjвүғ : вҲҖ {рқ“Ө рқ“Ҙ рқ“Ұ}
              {A : Type рқ“Ө} {B : Type рқ“Ҙ} {Q : Type рқ“Ұ}
           вҶ’ (pq : is-prop Q)
           вҶ’ (A * B вҶ’ Q) вүғ ((A вҶ’ Q) Г— (B вҶ’ Q))
*-prop-disjвүғ {A = A} {B} {Q} pq
 = (A * B вҶ’ Q)
      вүғвҹЁ Pushout-UPвүғ вҹ©
   Cocone (mk-span _ fst snd) Q
      вүғвҹЁ cocone-reprвүғ вҹ©
   ОЈ[ f вҲ¶ (A вҶ’ Q) ] ОЈ[ g вҲ¶ (B вҶ’ Q) ] (f вҲҳ fst ~ g вҲҳ snd)
      вүғвҹЁ ОЈ-ap-вүғ (О» f вҶ’ ОЈ-ap-вүғ (О» g вҶ’ curryвүғ)) вҹ©
   ОЈ[ f вҲ¶ (A вҶ’ Q) ] ОЈ[ g вҲ¶ (B вҶ’ Q) ] ((a : A) (b : B) вҶ’ f a пјқ g b)
      вүғвҹЁ ОЈ-ap-вүғ (О» a вҶ’ ОЈ-singleton (О» x вҶ’ О -is-single О»
                     b вҶ’ О -is-single (О»
                       c вҶ’ пјқ-is-singleвҶҗis-prop pq _ _))) вҹ©
   ((A вҶ’ Q) Г— (B вҶ’ Q)) вүғвҲҺ

*-prop-UP : вҲҖ {рқ“Ө рқ“Ҙ рқ“Ұ} {A : Type рқ“Ө} {B : Type рқ“Ҙ}
              {Q : Type рқ“Ұ}
              (ap : is-prop A) (bp : is-prop B)
              (qp : is-prop Q)
            вҶ’ is-equiv (*-prop-disj ap bp qp)
*-prop-UP ap bp qp = *-prop-disjвүғ qp ._вүғ_.has-is-eqv

opaque
  *-prop-rec
    : вҲҖ {рқ“Ө рқ“Ҙ рқ“Ұ}
        {A : Type рқ“Ө} {B : Type рқ“Ҙ} {Q : Type рқ“Ұ}
      вҶ’ (pq : is-prop Q)
      вҶ’ (A вҶ’ Q) вҶ’ (B вҶ’ Q) вҶ’ (A * B вҶ’ Q)
  *-prop-rec pq f g = _вүғ_.bwd (*-prop-disjвүғ pq) (f , g)
{-# NOINLINE *-prop-rec #-}

*-is-prop : вҲҖ {рқ“Ө рқ“Ҙ} {A : Type рқ“Ө} {B : Type рқ“Ҙ}
            вҶ’ is-prop A вҶ’ is-prop B
            вҶ’ is-prop (A * B)
*-is-prop aprop bprop = is-propвҶҗis-single-if-inhabited
  (*-prop-rec is-single-is-prop
    (О» a вҶ’ *-single (mk-singl a (aprop a)))
    (О» b вҶ’ *-single' (mk-singl b (bprop b))))
}
% ```
}


\subtree[stt-009U]{
\title{Joins with the empty type}

\p{The join #{A * 0} for any type #{A} is equivalent to #{A}.}

\proof{The map #{A \times 0 \to 0} is an equivalence so by
\ref{stt-008O}, so must #{A \to A * 0}.}

%```agda
\agda{
*-вҲ… : вҲҖ {рқ“Ө} {A : Type рқ“Ө} вҶ’ A вүғ вҲ… * A
*-вҲ… = mkвүғ О№вӮӮ (dom-is-equivвҶҗcocartesian (mk-amap snd О№вӮҒ glue)
             (Г—-вҲ… ._вүғ_.has-is-eqv) (is-cocartesianвҶҗis-pushout
                                     Pushout-is-pushoutПү))
}
%```
}

\subtree[stt-009L]{
\title{Functoriality of the join}
\taxon{Theorem}

\p{The join operator on types defines a functor
#{\SS \times \SS \to \SS}. We define the action of #{*} on functions,
and show that it preserves equivalences.}

%```agda
\agda{
_*вӮҒ_ : вҲҖ {рқ“Ө рқ“ң рқ“Ҙ рқ“Ұ} {A : Type рқ“Ө} {A' : Type рқ“ң}
         {B : Type рқ“Ҙ} {B' : Type рқ“Ұ}
       вҶ’ (A вҶ’ A') вҶ’ (B вҶ’ B') вҶ’ A * B вҶ’ A' * B'
f *вӮҒ g = pushout-rec (mk-cocone (О№вӮҒ вҲҳ f) (О№вӮӮ вҲҳ g) (glue вҲҳ (f вҠ— g)))

*вӮҒ-is-equiv : вҲҖ {рқ“Ө рқ“ң рқ“Ҙ рқ“Ұ} {A : Type рқ“Ө} {A' : Type рқ“ң}
                {B : Type рқ“Ҙ} {B' : Type рқ“Ұ}
              вҶ’ {f : A вҶ’ A'} {g : B вҶ’ B'}
              вҶ’ is-equiv f вҶ’ is-equiv g
              вҶ’ is-equiv (f *вӮҒ g)
*вӮҒ-is-equiv {A = A}{B = B}{f = f} {g} feq geq = is-equivвҶҗqinv qinv where
  module f = is-equiv feq
  module g = is-equiv geq


  opaque
    sec : вҲҖ a вҶ’
        Square (ap ((f *вӮҒ g) вҲҳ (f.bwd *вӮҒ g.bwd)) (glue a))
               (ap id (glue a))
               (((О№вӮҒ в—Ӯ f.Оө) вҲҳ fst) a)
               (((О№вӮӮ в—Ӯ g.Оө) вҲҳ snd) a)
    sec p@(a , b) = mk-square (
      вҢң ap ((f *вӮҒ g) вҲҳ (f.bwd *вӮҒ g.bwd)) (glue p) вҢқ вҲҷ ((О№вӮӮ в—Ӯ g.Оө) b)
                                    пјқвҹЁ ap! (ap-вҲҳ _ _ (glue p)) вҹ©
      ap (f *вӮҒ g) вҢң ap (f.bwd *вӮҒ g.bwd) (glue p) вҢқ вҲҷ ((О№вӮӮ в—Ӯ g.Оө) b)
                                    пјқвҹЁ ap! (pushout-rec-apОІ p) вҹ©
      вҢң ap (f *вӮҒ g) (glue (f.bwd a , g.bwd b)) вҢқ вҲҷ ((О№вӮӮ в—Ӯ g.Оө) b)
                                    пјқвҹЁ ap! (pushout-rec-apОІ ((f.bwd вҠ— g.bwd) p)) вҹ©
      (glue вҲҳ (f вҠ— g) вҲҳ (f.bwd вҠ— g.bwd)) p вҲҷ (вҢң О№вӮӮ в—Ӯ g.Оө в–ё snd вҢқ) p
                                    пјқвҹЁ ap! ( sym (ap-вҲҳ О№вӮӮ snd (Г—-pathвҶ’ (f.Оө a , g.Оө b))
                                            вҲҷ ap (ap О№вӮӮ) Г—-path-ap-snd)) вҹ©
      ((glue вҲҳ (f вҠ— g) вҲҳ (f.bwd вҠ— g.bwd)) ~вҲҷ (О№вӮӮ вҲҳ snd в—Ӯ Г—~ (f.Оө , g.Оө))) p
                                    пјқвҹЁвҹ©
      (glue ~вҲҳ Г—~ (f.Оө , g.Оө)) p    пјқвҹЁ switch-~вҲҳ glue (Г—~ (f.Оө , g.Оө)) p вҹ©
      (glue ~вҲҳ' Г—~ (f.Оө , g.Оө)) p   пјқвҹЁ ap (_вҲҷ glue p) (ap-вҲҳ О№вӮҒ fst (Г—~ (f.Оө , g.Оө) p)) вҹ©
       ((О№вӮҒ в—Ӯ fst в—Ӯ Г—~ (f.Оө , g.Оө)) ~вҲҷ glue) p
                                    пјқвҹЁ ap (О» x вҶ’ (ap О№вӮҒ x) вҲҷ glue p) Г—-path-ap-fst вҹ©
      ap О№вӮҒ (f.Оө a) вҲҷ вҢң glue p вҢқ    пјқвҹЁ ap! (sym (ap-id (glue p))) вҹ©
      ap О№вӮҒ (f.Оө a) вҲҷ ap id (glue p) вҲҺ)

    -- I wanted to generalise sec, and then give f.bwd and g.bwd
    -- but because is-equivвҒ»В№ goes via composing quasi-inverses it
    -- messes with the Оө
    ret : вҲҖ a вҶ’
        Square (ap ((f.bwd *вӮҒ g.bwd) вҲҳ (f *вӮҒ g)) (glue a))
               (ap id (glue a))
               (((О№вӮҒ в—Ӯ f.О·) вҲҳ fst) a)
               (((О№вӮӮ в—Ӯ g.О·) вҲҳ snd) a)
    ret p@(a , b) = mk-square (
        вҢң ap ((f.bwd *вӮҒ g.bwd) вҲҳ (f *вӮҒ g)) (glue p) вҢқ вҲҷ ((О№вӮӮ в—Ӯ g.О·) b)
                                      пјқвҹЁ ap! (ap-вҲҳ _ _ (glue p)) вҹ©
        ap (f.bwd *вӮҒ g.bwd) вҢң ap (f *вӮҒ g) (glue p) вҢқ вҲҷ ((О№вӮӮ в—Ӯ g.О·) b)
                                      пјқвҹЁ ap! (pushout-rec-apОІ p) вҹ©
        вҢң ap (f.bwd *вӮҒ g.bwd) (glue (f a , g b)) вҢқ вҲҷ ((О№вӮӮ в—Ӯ g.О·) b)
                                      пјқвҹЁ ap! (pushout-rec-apОІ ((f вҠ— g) p)) вҹ©
        (glue вҲҳ (f.bwd вҠ— g.bwd) вҲҳ (f вҠ— g)) p вҲҷ (вҢң О№вӮӮ в—Ӯ g.О· в–ё snd вҢқ) p
                                      пјқвҹЁ ap! ( sym (ap-вҲҳ О№вӮӮ snd (Г—-pathвҶ’ (f.О· a , g.О· b))
                                              вҲҷ ap (ap О№вӮӮ) Г—-path-ap-snd)) вҹ©
        ((glue вҲҳ (f.bwd вҠ— g.bwd) вҲҳ (f вҠ— g)) ~вҲҷ (О№вӮӮ вҲҳ snd в—Ӯ Г—~ (f.О· , g.О·))) p
                                      пјқвҹЁвҹ©
        (glue ~вҲҳ Г—~ (f.О· , g.О·)) p    пјқвҹЁ switch-~вҲҳ glue (Г—~ (f.О· , g.О·)) p вҹ©
        (glue ~вҲҳ' Г—~ (f.О· , g.О·)) p   пјқвҹЁ ap (_вҲҷ glue p) (ap-вҲҳ О№вӮҒ fst (Г—~ (f.О· , g.О·) p)) вҹ©
         ((О№вӮҒ в—Ӯ fst в—Ӯ Г—~ (f.О· , g.О·)) ~вҲҷ glue) p
                                      пјқвҹЁ ap (О» x вҶ’ (ap О№вӮҒ x) вҲҷ glue p) Г—-path-ap-fst вҹ©
        ap О№вӮҒ (f.О· a) вҲҷ вҢң glue p вҢқ    пјқвҹЁ ap! (sym (ap-id (glue p))) вҹ©
        ap О№вӮҒ (f.О· a) вҲҷ ap id (glue p) вҲҺ)

  qinv : quasi-inv (f *вӮҒ g)
  qinv .fst = f.bwd *вӮҒ g.bwd
  qinv .snd .fst = pushout-ind _ (mk-coconeбөҲ (О№вӮҒ в—Ӯ f.О·) (О№вӮӮ в—Ӯ g.О·)
                    О» a вҶ’ IdбөҲ-funcвҶҗSquare
                           {f = (f.bwd *вӮҒ g.bwd) вҲҳ (f *вӮҒ g)}
                           {id} (glue a)
                           (ap О№вӮҒ (f.О· (fst a))) ((О№вӮӮ в—Ӯ g.О·) (snd a))
                           (ret a))
  qinv .snd .snd = pushout-ind _ (mk-coconeбөҲ (О№вӮҒ в—Ӯ f.Оө) (О№вӮӮ в—Ӯ g.Оө)
                   (О» a вҶ’  IdбөҲ-funcвҶҗSquare {f = (f *вӮҒ g) вҲҳ (f.bwd *вӮҒ g.bwd)} {id}
                               (glue a) _ _
                               (sec a)))

*-вүғ : вҲҖ {рқ“Ө рқ“Ҙ рқ“Ұ рқ“ң} {A : Type рқ“Ө} {B : Type рқ“Ҙ} {C : Type рқ“Ұ} {D : Type рқ“ң}
      вҶ’ A вүғ C вҶ’ B вүғ D вҶ’ A * B вүғ C * D
*-вүғ (mkвүғ l le) (mkвүғ r re)
  = mkвүғ (l *вӮҒ r) (*вӮҒ-is-equiv le re)
}
%```
}

\subtree[stt-00FH]{
\taxon{Theorem}
\date{2026-03-06}
\author{fredrikbakke}
\title{Null-homotopies of maps out of a join}

\p{
Given a map #{q : A * B \to Q}, each point #{a : A} determines a
[null-homotopy](stt-00F3) of the restriction #{q \circ \iota_2 : B \to Q}. Moreover,
null-homotopies of #{q} are equivalent to null-homotopies of this induced family over
#{A}.
}

%```agda
\agda{
join-null-homotopy-at
  : {рқ“Ө рқ“Ҙ рқ“Ұ : Level}
    {A : Type рқ“Ө} {B : Type рқ“Ҙ} {Q : Type рқ“Ұ}
  вҶ’ (q : A * B вҶ’ Q)
  вҶ’ A
  вҶ’ null-homotopy (q вҲҳ О№вӮӮ)
join-null-homotopy-at q a .fst = q (О№вӮҒ a)
join-null-homotopy-at q a .snd b = ap q (glue (a , b))

join-recвүғnull-homotopies
  : {рқ“Ө рқ“Ҙ рқ“Ұ : Level}
    {A : Type рқ“Ө} {B : Type рқ“Ҙ} {Q : Type рқ“Ұ}
  вҶ’ (A * B вҶ’ Q)
  вүғ ОЈ[ r вҲ¶ (B вҶ’ Q) ] ((a : A) вҶ’ null-homotopy r)
join-recвүғnull-homotopies {A = A} {B} {Q}
  = (A * B вҶ’ Q)
      вүғвҹЁ Pushout-UPвүғ вҹ©
    Cocone (mk-span _ fst snd) Q
      вүғвҹЁ cocone-reprвүғ вҹ©
    ОЈ[ l вҲ¶ (A вҶ’ Q) ] ОЈ[ r вҲ¶ (B вҶ’ Q) ] (l вҲҳ fst ~ r вҲҳ snd)
      вүғвҹЁ ОЈ-ap-вүғ (О» l вҶ’ ОЈ-ap-вүғ (О» r вҶ’ curryвүғ)) вҹ©
    ОЈ[ l вҲ¶ (A вҶ’ Q) ] ОЈ[ r вҲ¶ (B вҶ’ Q) ] ((a : A) (b : B) вҶ’ l a пјқ r b)
      вүғвҹЁ ОЈ-comm вҹ©
    ОЈ[ r вҲ¶ (B вҶ’ Q) ] ОЈ[ l вҲ¶ (A вҶ’ Q) ] ((a : A) (b : B) вҶ’ l a пјқ r b)
      вүғвҹЁ ОЈ-ap-вүғ (О» r вҶ’ ОЈ-О -swapвүғ (О» _ вҶ’ Q) (О» a q вҶ’ (b : B) вҶ’ q пјқ r b) eвҒ»В№) вҹ©
    ОЈ[ r вҲ¶ (B вҶ’ Q) ] ((a : A) вҶ’ ОЈ[ q вҲ¶ Q ] ((b : B) вҶ’ q пјқ r b))
      вүғвҹЁвҹ©
    ОЈ[ r вҲ¶ (B вҶ’ Q) ] ((a : A) вҶ’ null-homotopy r)
      вүғвҲҺ

join-recбөҲвүғnull-homotopies
  : {рқ“Ө1 рқ“Ө2 рқ“Ө3 рқ“Ө4 рқ“Ө5 : Level}
    {A : Type рқ“Ө1}
    {X : A вҶ’ Type рқ“Ө2}
    {B : A вҶ’ Type рқ“Ө3}
    {Y : (a : A) вҶ’ X a вҶ’ Type рқ“Ө4}
    {Q : (a : A) (x : X a) вҶ’ Type рқ“Ө5}
  вҶ’ ((a : A) (x : X a) вҶ’ B a * Y a x вҶ’ Q a x)
  вүғ ОЈ[ r вҲ¶ ((a : A) (x : X a) вҶ’ Y a x вҶ’ Q a x) ]
      ((a : A) (b : B a) (x : X a) вҶ’ null-homotopy (r a x))
join-recбөҲвүғnull-homotopies
  {A = A} {X} {B} {Y} {Q}
  = ((a : A) (x : X a) вҶ’ B a * Y a x вҶ’ Q a x)
      вүғвҹЁ О -ap-вүғ (О» a вҶ’ О -ap-вүғ (О» _ вҶ’ join-recвүғnull-homotopies)) вҹ©
    ((a : A) (x : X a) вҶ’ ОЈ[ r вҲ¶ (Y a x вҶ’ Q a x) ] ((b : B a) вҶ’ null-homotopy r))
      вүғвҹЁ О -ap-вүғ
            ( О» a
              вҶ’ ОЈ-О -swapвүғ
                  (О» x вҶ’ Y a x вҶ’ Q a x)
                  (О» x r вҶ’ (b : B a) вҶ’ null-homotopy r)) вҹ©
    ((a : A)
      вҶ’ ОЈ[ r вҲ¶ ((x : X a) вҶ’ Y a x вҶ’ Q a x) ]
          ((x : X a) вҶ’ (b : B a) вҶ’ null-homotopy (r x)))
      вүғвҹЁ ОЈ-О -swapвүғ
            (О» a вҶ’ (x : X a) вҶ’ Y a x вҶ’ Q a x)
            (О» a r вҶ’ (x : X a) (b : B a) вҶ’ null-homotopy (r x)) вҹ©
    (ОЈ[ r вҲ¶ ((a : A) (x : X a) вҶ’ Y a x вҶ’ Q a x) ]
      ((a : A) вҶ’ (x : X a) (b : B a) вҶ’ null-homotopy (r a x)))
      вүғвҹЁ ОЈ-ap-вүғ (О» _ вҶ’ О -ap-вүғ (О» _ вҶ’ flipвүғ)) вҹ©
    (ОЈ[ r вҲ¶ ((a : A) (x : X a) вҶ’ Y a x вҶ’ Q a x) ]
      ((a : A) вҶ’ (b : B a) (x : X a) вҶ’ null-homotopy (r a x)))
      вүғвҲҺ

module _
  {рқ“Ө рқ“Ҙ рқ“Ұ : Level}
  {A : Type рқ“Ө} {B : Type рқ“Ҙ} {Q : Type рқ“Ұ}
  (q : A * B вҶ’ Q)
  (l : Q)
  where

  join-path-from-left
    : (a : A)
    вҶ’ const Q B (q (О№вӮҒ a)) ~ q вҲҳ О№вӮӮ
  join-path-from-left a b = ap q (glue (a , b))

  join-ind-pathsвүғnull-homotopy-inner-over
    : (r : (b : B) вҶ’ l пјқ q (О№вӮӮ b))
    вҶ’ (a : A)
    вҶ’ (ОЈ[ t вҲ¶ l пјқ q (О№вӮҒ a) ]
        ((b : B) вҶ’ Idб¶  (О» j вҶ’ l пјқ q j) (glue (a , b)) t (r b)))
    вүғ ((l , r) пјқ join-null-homotopy-at q a)
  join-ind-pathsвүғnull-homotopy-inner-over r a
    = (ОЈ[ t вҲ¶ l пјқ q (О№вӮҒ a) ]
        ((b : B) вҶ’ Idб¶  (О» j вҶ’ l пјқ q j) (glue (a , b)) t (r b)))
        вүғвҹЁ ОЈ-ap-вүғ (О» t вҶ’ О -ap-вүғ (О» b вҶ’ Idб¶ -const-вүғ' q (glue (a , b)) t (r b))) вҹ©
      (ОЈ[ t вҲ¶ l пјқ q (О№вӮҒ a) ]
        ((b : B) вҶ’ t вҲҷ join-path-from-left a b пјқ r b))
        вүғвҹЁ null-homotopy-pathвүғ
              {f = q вҲҳ О№вӮӮ}
              r
              (join-path-from-left a)
              eвҒ»В№ вҹ©
      ((l , r) пјқ join-null-homotopy-at q a)
        вүғвҲҺ

  join-ind-pathsвүғnull-homotopy-inner
    : (r : (b : B) вҶ’ l пјқ q (О№вӮӮ b))
    вҶ’ (ОЈ[ t вҲ¶ ((a : A) вҶ’ l пјқ q (О№вӮҒ a)) ]
        (((a , b) : A Г— B) вҶ’ Idб¶  (О» j вҶ’ l пјқ q j) (glue (a , b)) (t a) (r b)))
    вүғ ((a : A) вҶ’ (l , r) пјқ join-null-homotopy-at q a)
  join-ind-pathsвүғnull-homotopy-inner r
    = (ОЈ[ t вҲ¶ ((a : A) вҶ’ l пјқ q (О№вӮҒ a)) ]
        (((a , b) : A Г— B) вҶ’ Idб¶  (О» j вҶ’ l пјқ q j) (glue (a , b)) (t a) (r b)))
        вүғвҹЁ ОЈ-ap-вүғ (О» t вҶ’ curryвүғ) вҹ©
      (ОЈ[ t вҲ¶ ((a : A) вҶ’ l пјқ q (О№вӮҒ a)) ]
        ((a : A) (b : B) вҶ’ Idб¶  (О» j вҶ’ l пјқ q j) (glue (a , b)) (t a) (r b)))
        вүғвҹЁ ОЈ-О -swapвүғ
              (О» a вҶ’ l пјқ q (О№вӮҒ a))
              (О» a t вҶ’ (b : B) вҶ’ Idб¶  (О» j вҶ’ l пјқ q j) (glue (a , b)) t (r b))
              eвҒ»В№ вҹ©
      ((a : A)
        вҶ’ ОЈ[ t вҲ¶ l пјқ q (О№вӮҒ a) ]
          ((b : B) вҶ’ Idб¶  (О» j вҶ’ l пјқ q j) (glue (a , b)) t (r b)))
        вүғвҹЁ О -ap-вүғ (join-ind-pathsвүғnull-homotopy-inner-over r) вҹ©
      ((a : A) вҶ’ (l , r) пјқ join-null-homotopy-at q a)
        вүғвҲҺ

  join-ind-pathsвүғnull-homotopy-at
    : (((j : A * B) вҶ’ l пјқ q j))
    вүғ (ОЈ[ r вҲ¶ ((b : B) вҶ’ l пјқ q (О№вӮӮ b)) ]
        ((a : A) вҶ’ (l , r) пјқ join-null-homotopy-at q a))
  join-ind-pathsвүғnull-homotopy-at
    = (((j : A * B) вҶ’ l пјқ q j))
        вүғвҹЁ Pushout-UPбөҲвүғ eвҒ»В№ вҹ©
      CoconeбөҲ (mk-span _ fst snd) pushout (О» j вҶ’ l пјқ q j)
        вүғвҹЁ coconeD-reprвүғ вҹ©
      (ОЈ[ t вҲ¶ ((a : A) вҶ’ l пјқ q (О№вӮҒ a)) ]
       ОЈ[ r вҲ¶ ((b : B) вҶ’ l пјқ q (О№вӮӮ b)) ]
         (((a , b) : A Г— B) вҶ’ Idб¶  (О» j вҶ’ l пјқ q j) (glue (a , b)) (t a) (r b)))
        вүғвҹЁ ОЈ-comm вҹ©
      (ОЈ[ r вҲ¶ ((b : B) вҶ’ l пјқ q (О№вӮӮ b)) ]
       ОЈ[ t вҲ¶ ((a : A) вҶ’ l пјқ q (О№вӮҒ a)) ]
         (((a , b) : A Г— B) вҶ’ Idб¶  (О» j вҶ’ l пјқ q j) (glue (a , b)) (t a) (r b)))
        вүғвҹЁ ОЈ-ap-вүғ join-ind-pathsвүғnull-homotopy-inner вҹ©
      (ОЈ[ r вҲ¶ ((b : B) вҶ’ l пјқ q (О№вӮӮ b)) ]
        ((a : A) вҶ’ (l , r) пјқ join-null-homotopy-at q a))
        вүғвҲҺ

join-null-homotopiesвүғ
  : {рқ“Ө рқ“Ҙ рқ“Ұ : Level}
    {A : Type рқ“Ө} {B : Type рқ“Ҙ} {Q : Type рқ“Ұ}
  вҶ’ (q : A * B вҶ’ Q)
  вҶ’ null-homotopy q вүғ null-homotopy (join-null-homotopy-at q)
join-null-homotopiesвүғ {A = A} {B} {Q} q
  = null-homotopy q
      вүғвҹЁ ОЈ-ap-вүғ (join-ind-pathsвүғnull-homotopy-at q) вҹ©
    (ОЈ[ l вҲ¶ Q ]
     ОЈ[ r вҲ¶ ((b : B) вҶ’ l пјқ q (О№вӮӮ b)) ]
       ((a : A) вҶ’ (l , r) пјқ join-null-homotopy-at q a))
      вүғвҹЁ ОЈ-assoc eвҒ»В№ вҹ©
    null-homotopy (join-null-homotopy-at q)
      вүғвҲҺ

join-null-homotopiesбөҲвүғ
  : {рқ“Ө рқ“Ҙ рқ“Ұ рқ“  : Level}
    {X : Type рқ“Ө}
    {B : Type рқ“Ҙ}
    {Y : X вҶ’ Type рқ“Ұ}
    {Q : X вҶ’ Type рқ“ }
  вҶ’ (q : (x : X) вҶ’ B * Y x вҶ’ Q x)
  вҶ’ ((x : X) вҶ’ null-homotopy (q x))
  вүғ null-homotopy (О» b x вҶ’ join-null-homotopy-at (q x) b)
join-null-homotopiesбөҲвүғ {X = X} q
  = ((x : X) вҶ’ null-homotopy (q x))
      вүғвҹЁ О -ap-вүғ (О» x вҶ’ join-null-homotopiesвүғ (q x)) вҹ©
    ((x : X) вҶ’ null-homotopy (join-null-homotopy-at (q x)))
      вүғвҹЁ null-homotopy-curryвүғ (О» x b вҶ’ join-null-homotopy-at (q x) b) вҹ©
    null-homotopy (О» b x вҶ’ join-null-homotopy-at (q x) b)
      вүғвҲҺ
}

\subtree[stt-00JV]{
\title{Sharp codiscrete maps lift crisply against the flat counit}
\taxon{Lemma}

\citet{3.1.2}{MR23}

\p{This follows straightforwardly from the fact that for any reflective
subuniverse, connected and modal maps are the (respectively) left and right
classes of an orthogonal factorisation system, and the fact that
#{\varepsilon} is a #{\sharp}-connected map.}

\agda{
lifts-ε♭←is-♯-codiscrete
  : ∀ {@♭ 𝓤 𝓥} {@♭ A : Type 𝓤} {@♭ B : Type 𝓥} {@♭ f : A → B}
    → @♭ is-♯-codiscrete-map f
    → (∀ {@♭ 𝓠} {@♭ Q : Type 𝓠} → are-♭-orthogonal (ε♭: Q) f)
lifts-ε♭←is-♯-codiscrete {f = f} fcd {_} {Q}
  = ♭-is-cartesian (power-hom ε♭ f)
      (is-cartesian←are-orthogonal
        (gRSubUConnectedCharacterisation.connected⊥modal ♯-gRSubU
          (is-♯-connected←is-♯-equiv ε-is-♯-equiv)
          fcd))
}
}


\subtree[fre-0001]{
\taxon{Definition}
\title{Walking morphisms in #{\Type}}
\author{fredrikbakke}

% ```agda
\agda{
record Arrow (рЭУ§ рЭУ• : Level) : Type (lsuc рЭУ§ вКФ lsuc рЭУ•) where
  constructor mk-arrow
  no-eta-equality
  field
    {dom} : Type рЭУ§
    {cod} : Type рЭУ•
    f : dom вЖТ cod
}
% ```
}

\subtree[fre-0002]{
\taxon{Definition}
\date{2026-02-20}
\title{Dependent morphisms of arrows}

\p{
Given an arrow #{f : A \to B}, a \em{dependent arrow} over #{f} is a family of arrows
over its domain, #{g : (b : B) \to X(b) \to Y(b)}. Given such a dependent arrow, then a
\em{dependent morphism of arrows} is a pair of dependent functions
#{i : (b : B) \to Y(b)} and #{j : (a : A) \to X (f(a))} so that #{i \circ f \sim g \circ j}.
}

% ```agda
\agda{
module _
  {рЭУ§1 рЭУ§2 рЭУ§3 рЭУ§4 : Level}
  {A : Type рЭУ§1}
  {B : Type рЭУ§2}
  (f : A вЖТ B)
  {X : B вЖТ Type рЭУ§3}
  {Y : B вЖТ Type рЭУ§4}
  (g : (b : B) вЖТ X b вЖТ Y b)
  where

  record Arrow-ќ† : Type (рЭУ§1 вКФ рЭУ§2 вКФ рЭУ§3 вКФ рЭУ§4) where
    constructor mk-amap
    field
      top : (a : A) вЖТ X (f a)
      bot : (b : B) вЖТ Y b
      comm : precomp-ќ† Y f bot ~ postcomp-ќ† (ќї a вЖТ g (f a)) top

  unquoteDecl Arrow-ќ†-reprвЙЕ Arrow-ќ†-reprвЙГ
    = make-record-repr Arrow-ќ†-reprвЙЕ Arrow-ќ†-reprвЙГ (quote Arrow-ќ†)
}
% ```
}

\subtree[stt-003U]{
\taxon{Definition}
\title{Morphisms of arrows}

\p{
Given a pair of arrows, we define a morphism between them to be a commutative square,
that is, a pair of a maps and a homotopy witnessing that the square commutes.
}

% ```agda
\agda{
module _
  {рЭУ§ рЭУ• рЭУ¶ рЭУЫ}
  {A : Type рЭУ§} {B : Type рЭУ•} (f : A вЖТ B)
  {C : Type рЭУ¶} {D : Type рЭУЫ} (f' : C вЖТ D)
  where

  Arrow-map : Type (рЭУ§ вКФ рЭУ• вКФ рЭУ¶ вКФ рЭУЫ)
  Arrow-map = Arrow-ќ† f (ќї _ вЖТ f')

  Arrow-map-reprвЙЕ : Arrow-map вЙЕ _
  Arrow-map-reprвЙЕ = Arrow-ќ†-reprвЙЕ f (ќї _ вЖТ f')

  Arrow-map-reprвЙГ : Arrow-map вЙГ _
  Arrow-map-reprвЙГ = Arrow-ќ†-reprвЙГ f (ќї _ вЖТ f')

module Arrow-map = Arrow-ќ†
}
% ```
}

\subtree[fre-0003]{
\taxon{Theorem}
\date{2026-02-20}
\title{The type of dependent morphisms of arrows as a pullback}
\author{fredrikbakke}

\p{The type #{\Hom^{\mathrm{d}}(f,g)} is the pullback of #{g \circ {-}} and
#{{-} \circ f}.}

%```agda
\agda{
module _
  {рЭУ§1 рЭУ§2 рЭУ§3 рЭУ§4 : Level}
  {A : Type рЭУ§1}
  {B : Type рЭУ§2}
  {f : A вЖТ B}
  {X : B вЖТ Type рЭУ§3}
  {Y : B вЖТ Type рЭУ§4}
  {g : (b : B) вЖТ X b вЖТ Y b}
  where

  Arrow-ќ†-cone
    : Cone (mk-cospan ((a : A) вЖТ Y (f a))
                      (precomp-ќ† Y f)
                      (postcomp-ќ† (ќї a вЖТ g (f a))))
           (Arrow-ќ† f g)
  Arrow-ќ†-cone .Cone.i p = Arrow-ќ†.bot p
  Arrow-ќ†-cone .Cone.j p = Arrow-ќ†.top p
  Arrow-ќ†-cone .Cone.filler p = funextвЖТ (Arrow-ќ†.comm p)

  Arrow-ќ†вЙГpullback-repr
    : Arrow-ќ† f g
    вЙГ Pullback (precomp-ќ† Y f) (postcomp-ќ† (ќї a вЖТ g (f a)))
  Arrow-ќ†вЙГpullback-repr
    = Arrow-ќ† f g
        вЙГвЯ® Arrow-ќ†-reprвЙГ f g вЯ©
      ќ£[ t вИґ ((a : A) вЖТ X (f a)) ]
      ќ£[ b вИґ ((b : B) вЖТ Y b) ]
       (precomp-ќ† Y f b ~ postcomp-ќ† (ќї a вЖТ g (f a)) t)
        вЙГвЯ® ќ£-comm вЯ©
      ќ£[ b вИґ ((b : B) вЖТ Y b) ]
      ќ£[ t вИґ ((a : A) вЖТ X (f a)) ]
       (precomp-ќ† Y f b ~ postcomp-ќ† (ќї a вЖТ g (f a)) t)
        вЙГвЯ® ќ£-ap-вЙГ (ќї _ вЖТ ќ£-ap-вЙГ ќї _ вЖТ (funextвЙГ eвБї¬є)) вЯ©
      Pullback (precomp-ќ† Y f) (postcomp-ќ† (ќї a вЖТ g (f a)))
        вЙГвИО

  Arrow-ќ†вЙГpullback-repr~gap
    : Arrow-ќ†вЙГpullback-repr ._вЙГ_.fwd ~ gap Arrow-ќ†-cone
  Arrow-ќ†вЙГpullback-repr~gap = ~refl

  Arrow-ќ†-gap-is-equiv : is-equiv (gap Arrow-ќ†-cone)
  Arrow-ќ†-gap-is-equiv
    = homotopy-is-equiv (Arrow-ќ†вЙГpullback-repr~gap)
                        (Arrow-ќ†вЙГpullback-repr ._вЙГ_.has-is-eqv)

  Arrow-ќ†вЙГpullback
    : Arrow-ќ† f g
    вЙГ Pullback (precomp-ќ† Y f) (postcomp-ќ† (ќї a вЖТ g (f a)))
  Arrow-ќ†вЙГpullback
    = mkвЙГ (gap Arrow-ќ†-cone) (Arrow-ќ†-gap-is-equiv)
}
%```
}

\subtree[stt-004H]{
\taxon{Theorem}
\date{2025-05-17}
\title{The type of morphisms of arrows as a pullback}

\p{The type #{\Hom(f,g)} is the pullback of #{g \circ {-}} and #{{-} \circ f}.}

%```agda
\agda{
module _ {рЭУ§ рЭУ•} {A : Type рЭУ§} {B : Type рЭУ•} {f : A вЖТ B}
         {рЭУ¶ рЭУЫ} {C : Type рЭУ¶} {D : Type рЭУЫ} {g : C вЖТ D} where

  Arrow-mapвЙГpullback' : Arrow-map f g вЙГ Pullback (_вИШ f) (g вИШ_)
  Arrow-mapвЙГpullback' = Arrow-ќ†вЙГpullback {f = f} {g = ќї _ вЖТ g}

  Arrow-mapвЙГpullback : Arrow-map f g вЙГ Pullback (g вИШ_) (_вИШ f)
  Arrow-mapвЙГpullback = Arrow-mapвЙГpullback' вИЩвЙГ pullback-swap

  pullbackвЖРarrow' : Arrow-map f g вЖТ Pullback (_вИШ f) (g вИШ_)
  pullbackвЖРarrow' = Arrow-mapвЙГpullback' ._вЙГ_.fwd

  pullbackвЖРarrow : Arrow-map f g вЖТ Pullback (g вИШ_) (_вИШ f)
  pullbackвЖРarrow = Arrow-mapвЙГpullback ._вЙГ_.fwd
}
%```
}

\subtree[stt-004I]{
\title{Characterising the paths of morphisms of arrows}
\taxon{Theorem}

%```agda
\agda{
module _ {рЭУ§ рЭУ•} {A : Type рЭУ§} {B : Type рЭУ•} {f : A вЖТ B}
         {рЭУ¶ рЭУЫ} {C : Type рЭУ¶} {D : Type рЭУЫ} {f' : C вЖТ D} where

  Arrow-map-path : вИА (G H : Arrow-map f f') вЖТ Type _
  Arrow-map-path (mk-amap t b H) (mk-amap t' b' H')
    = ќ£[ p вИґ t ~ t' ] ќ£[ q вИґ b ~ b' ]
      (H ~вИЩ (f' вЧВ p) ~ q вЦЄ f ~вИЩ H')

  Arrow-map-path-refl : {G : Arrow-map f f'} вЖТ Arrow-map-path G G
  Arrow-map-path-refl = ~refl , ~refl , ~вИЩ-reflr _

  Arrow-map-path-is-Rppred : вИА (G : Arrow-map f f')
                             вЖТ Reflexive-ppred _ G _
  Arrow-map-path-is-Rppred G = (Arrow-map-path G) , Arrow-map-path-refl

  Arrow-map-pathвЖРid : вИА {G H : Arrow-map f f'} вЖТ (G пЉЭ H) вЖТ Arrow-map-path G H
  Arrow-map-pathвЖРid refl = Arrow-map-path-refl

  opaque
    Arrow-map-pathвЙГ : вИА (G H : Arrow-map f f') вЖТ (G пЉЭ H) вЙГ Arrow-map-path G H
    Arrow-map-pathвЙГ G@(mk-amap t b h) H
      = mkвЙГ Arrow-map-pathвЖРid
            (fundamental-Id
              (Arrow-map-path G)
              (is-singleвЖРequiv-to-single
                (ќ£-ap-вЙГ-fst (Arrow-map-reprвЙГ _ _ eвБї¬є))
                (is-singleton-structureвЖРparts (SingS-is-single t)
                  (t , ~refl)
                  (is-singleton-structureвЖРparts (SingS-is-single b)
                    (b , ~refl)
                    (SingS-is-single ќї a вЖТ h a вИЩ refl))))
              (ќї _ вЖТ Arrow-map-pathвЖРid) H)

    Arrow-map-pathвЖТ : вИА {G H : Arrow-map f f'} вЖТ Arrow-map-path G H
                      вЖТ (G пЉЭ H)
    Arrow-map-pathвЖТ = _вЙГ_.bwd (Arrow-map-pathвЙГ _ _)

    Arrow-map-pathвЖТ-refl : вИА {G : Arrow-map f f'}
                          вЖТ Arrow-map-pathвЖТ (Arrow-map-path-refl {G = G}) пЉЭ refl
    Arrow-map-pathвЖТ-refl
      = unap-equiv (Arrow-map-pathвЙГ _ _ ._вЙГ_.has-is-eqv)
                   (is-equiv.ќµ (Arrow-map-pathвЙГ _ _ ._вЙГ_.has-is-eqv) _)
}
%```
}

\subtree[stt-003X]{
\taxon{Theorem}
\title{Arrows and squares form a category}

% ```agda
\agda{
id-square : вИА {рЭУ§ рЭУ•} {A : Type рЭУ§} {B : Type рЭУ•} {f : A вЖТ B}
            вЖТ Arrow-map f f
id-square = mk-amap id id ~refl

module _ {рЭУ§ рЭУ•} {A : Type рЭУ§} {B : Type рЭУ•} {f : A вЖТ B}
         {рЭУ§' рЭУ•'} {A' : Type рЭУ§'} {B' : Type рЭУ•'} {f' : A' вЖТ B'}
        {рЭУ§'' рЭУ•''} {A'' : Type рЭУ§''} {B'' : Type рЭУ•''} {f'' : A'' вЖТ B''} where
  paste-squares : Arrow-map f' f'' вЖТ Arrow-map f f'
                  вЖТ Arrow-map f f''
  paste-squares (mk-amap g' h' comm') (mk-amap g h comm)
    = mk-amap (g' вИШ g) (h' вИШ h) (h' вЧВ comm ~вИЩ comm' вЦЄ g)
}
% ```
}

\subtree[stt-003V]{
\taxon{Definition}
\title{Cartesian squares}

\p{Given a map of arrows #{f \to f'}, we can define a family of functions
from the fibre over #{f} to the fibre over #{f'}. If this map is a
fibrewise equivalence, then we say that the square is cartesian (or a pullback
square).
}

% ```agda
\agda{
module _ {рЭУ§ рЭУ•} {A : Type рЭУ§} {B : Type рЭУ•} {f : A вЖТ B}
         {рЭУ¶ рЭУЫ} {C : Type рЭУ¶} {D : Type рЭУЫ} {f' : C вЖТ D} where
  arrow-fibre :  (gs : Arrow-map f f') вЖТ
                 вИА (b : B)
                 вЖТ fibre f b вЖТ fibre f' (gs .Arrow-map.bot b)
  arrow-fibre (mk-amap g g' hom) b (a , p) = (g a , sym (hom a) вИЩ ap g' p)

  is-cartesian : Arrow-map f f' вЖТ Type (рЭУ§ вКФ рЭУ• вКФ рЭУ¶ вКФ рЭУЫ)
  is-cartesian a = is-fibrewise-equiv (arrow-fibre a)

  is-cartesian-is-prop
    : вИА {F : Arrow-map f f'} вЖТ is-prop (is-cartesian F)
  is-cartesian-is-prop
    = is-prop-ќ† (ќї a вЖТ is-equiv-is-prop)
}
% ```
}

\subtree[stt-003W]{
\taxon{Theorem}
\title{Horizontal composition of cartesian squares}

% ```agda
\agda{
module _ {рЭУ§ рЭУ•} {A : Type рЭУ§} {B : Type рЭУ•} {f : A вЖТ B}
         {рЭУ§' рЭУ•'} {A' : Type рЭУ§'} {B' : Type рЭУ•'} {f' : A' вЖТ B'}
        {рЭУ§'' рЭУ•''} {A'' : Type рЭУ§''} {B'' : Type рЭУ•''} {f'' : A'' вЖТ B''} where

  arrow-fibre-вИШ
    : вИА (F : Arrow-map f' f'') (G : Arrow-map f f')
      вЖТ вИА b
      вЖТ arrow-fibre (paste-squares F G) b
      ~ arrow-fibre F (Arrow-map.bot G b) вИШ arrow-fibre G b
  arrow-fibre-вИШ F@(mk-amap f f' fcomm) G@(mk-amap g g' gcomm) b (a , p)
    = ќ£-pathвЖТ (refl , lem) where
       lem : sym (ap f' (gcomm a) вИЩ fcomm (g a)) вИЩ ap (f' вИШ g') p пЉЭ
              sym (fcomm (g a)) вИЩ ap f' (sym (gcomm a) вИЩ ap g' p)
       lem = вМЬ sym (ap f' (gcomm a) вИЩ fcomm (g a)) вМЭ вИЩ ap (f' вИШ g') p
               пЉЭвЯ® ap! (вИЩ-symsym (ap f' (gcomm a)) _) вЯ©
             (sym (fcomm (g a)) вИЩ вМЬ sym (ap f' (gcomm a)) вМЭ) вИЩ ap (f' вИШ g') p
               пЉЭвЯ® ap! (sym (ap-sym f' _)) вЯ©
             (sym (fcomm (g a)) вИЩ ap f' (sym (gcomm a))) вИЩ ap (f' вИШ g') p
               пЉЭвЯ® вИЩ-assoc (sym (fcomm (g a))) _ _ вЯ©
             sym (fcomm (g a)) вИЩ ap f' (sym (gcomm a)) вИЩ вМЬ ap (f' вИШ g') p вМЭ
               пЉЭвЯ® ap! (ap-вИШ f' g' p) вЯ©
             sym (fcomm (g a)) вИЩ вМЬ ap f' (sym (gcomm a)) вИЩ (ap f' (ap g' p)) вМЭ
               пЉЭвЯ® ap! (sym (ap-вИЩ f' (sym _) (ap g' p))) вЯ©
             sym (fcomm (g a)) вИЩ ap f' (sym (gcomm a) вИЩ ap g' p) вИО

  compose-cartesian :  вИА {a : Arrow-map f' f''} {b : Arrow-map f f'}
                     вЖТ (ae : is-cartesian a) вЖТ (be : is-cartesian b)
                     вЖТ  is-cartesian (paste-squares a b)
  compose-cartesian {a} {b} ae be x
    = tr is-equiv (funextвЖТ (arrow-fibre-вИШ a b x ~вБї¬є))
       (is-equiv-вИШ {f = arrow-fibre a (b .Arrow-map.bot x)} {g = arrow-fibre b x}
         (ae (b .Arrow-map.bot x))
         (be x)) where
    module b = is-equiv (be x)
    module a = is-equiv (ae (b .Arrow-map.bot x))

    open Arrow-map

    II : (x : B) (fib : fibre f x) вЖТ
       sym (paste-squares a b .Arrow-map.comm (fib .fst)) вИЩ
         ap (paste-squares a b .Arrow-map.bot) (fib .snd)
        пЉЭ
       (arrow-fibre a (b .Arrow-map.bot x) вИШ arrow-fibre b x)
         fib .snd
    II x (aa , p)
     = sym (paste-squares a b .comm aa) вИЩ ap (paste-squares a b .bot) p
         пЉЭвЯ®вЯ©
       вМЬ sym (ap (a .bot) (b .comm aa) вИЩ a .comm (b .top aa)) вМЭ вИЩ ap (a .bot вИШ b .bot) p
         пЉЭвЯ® ap! (вИЩ-symsym (ap (a .bot) (b .comm aa)) _) вЯ©
       (sym (a .comm (b .top aa)) вИЩ sym (ap (a .bot) (b .comm aa))) вИЩ ap (a .bot вИШ b .bot) p
         пЉЭвЯ® вИЩ-assoc (sym (a .comm (b .top aa))) _ (ap (a .bot вИШ b .bot) p) вЯ©
       sym (a .comm (b .top aa)) вИЩ вМЬ sym (ap (a .bot) (b .comm aa)) вМЭ вИЩ ap (a .bot вИШ b .bot) p
         пЉЭвЯ® ap! (sym (ap-sym (a .bot) _)) вЯ©
       sym (a .comm (b .top aa)) вИЩ ap (a .bot) (sym (b .comm aa)) вИЩ вМЬ ap (a .bot вИШ b .bot) p вМЭ
         пЉЭвЯ® ap! (ap-вИШ _ _ _) вЯ©
       sym (a .comm (b .top aa)) вИЩ вМЬ ap (a .bot) (sym (b .comm aa)) вИЩ ap (a .bot) (ap (b .bot) p) вМЭ
         пЉЭвЯ® ap! (sym (ap-вИЩ (a .bot) (sym (b .comm aa)) _)) вЯ©
       sym (a .comm (b .top aa)) вИЩ ap (a .bot) (sym (b .comm aa) вИЩ ap (b .bot) p)
         пЉЭвЯ®вЯ©
       (arrow-fibre a (b .bot x) вИШ arrow-fibre b x) (aa , p) .snd вИО

  3-for-2-cartesian : вИА {a : Arrow-map f' f''} {b : Arrow-map f f'}
                        {H : Arrow-map f f''}
                      вЖТ Arrow-map-path H (paste-squares a b)
                      вЖТ is-cartesian H
                      вЖТ is-cartesian a
                      вЖТ is-cartesian b
  3-for-2-cartesian {a = F@(mk-amap f f' fcomm)} {b = G@(mk-amap g g' gcomm)}
                    K abcart bcart b
    = 3-for-2~ (arrow-fibre-вИШ F G b)
               (bcart (g' b))
               (tr is-cartesian (Arrow-map-pathвЖТ K) abcart b)
}
% ```
}

\subtree[stt-002Z]{
\taxon{Theorem}
\title{Arrow morphisms are squares}

\p{We now have (at least) three things that can be called squares. We give functions
to convert from arrow-map squares, to either cones over cospans or cocones over spans.}

% ```agda
\agda{
CoconeвЖРArrow-map : вИА {рЭУ§ рЭУ•} {A : Type рЭУ§} {B : Type рЭУ•} {f : A вЖТ B}
                  {рЭУ¶ рЭУЫ} {C : Type рЭУ¶} {D : Type рЭУЫ} {f' : C вЖТ D}
                вЖТ Arrow-map f f' вЖТ ќ£[ S вИґ  Span рЭУ§ рЭУ• рЭУ¶ ] Cocone S D
CoconeвЖРArrow-map {f = f} {f' = f'} (mk-amap g g' comm)
  = (mk-span _ f g) , mk-cocone g' f' comm

Arrow-mapвЖРCocone : вИА {рЭУ§ рЭУ• рЭУ¶ рЭУЬ} {S : Span рЭУ§ рЭУ• рЭУ¶} {D : Type рЭУЬ}
                   вЖТ (C : Cocone S D)
                   вЖТ Arrow-map (Span.left S) (Cocone.q C)
Arrow-mapвЖРCocone {S = S} C = mk-amap S.right C.p C.filler where
  module S = Span S
  module C = Cocone C

ConeвЖРArrow-map : вИА {рЭУ§ рЭУ•} {A : Type рЭУ§} {B : Type рЭУ•} {f : A вЖТ B}
                  {рЭУ¶ рЭУЫ} {C : Type рЭУ¶} {D : Type рЭУЫ} {f' : C вЖТ D}
                 вЖТ Arrow-map f f' вЖТ ќ£[ S вИґ Cospan рЭУЫ рЭУ• рЭУ¶ ] Cone S A
ConeвЖРArrow-map {f = f} {f' = f'} (mk-amap top bot comm)
  = (mk-cospan _ bot f') , mk-cone f top comm
}
% ```
}

\subtree[stt-004E]{
\taxon{Defition}

\title{(co)gap maps from squares}

% ```agda
\agda{
gap-mapвЖРsquare : вИА {рЭУ§ рЭУ•} {A : Type рЭУ§} {B : Type рЭУ•} {f : A вЖТ B}
                   {рЭУ¶ рЭУЫ} {C : Type рЭУ¶} {D : Type рЭУЫ} {f' : C вЖТ D}
                 вЖТ (g : Arrow-map f f')
                 вЖТ A вЖТ Pullback (g .Arrow-map.bot) f'
gap-mapвЖРsquare g = gap (ConeвЖРArrow-map g .snd)

cogap-mapвЖРsquare : вИА {рЭУ§ рЭУ•} {A : Type рЭУ§} {B : Type рЭУ•} {f : A вЖТ B}
                   {рЭУ¶ рЭУЫ} {C : Type рЭУ¶} {D : Type рЭУЫ} {f' : C вЖТ D}
                 вЖТ (g : Arrow-map f f')
                 вЖТ Pushout f (g .Arrow-map.top) вЖТ D
cogap-mapвЖРsquare g = cogap (CoconeвЖРArrow-map g .snd)
}
% ```
}

\subtree[stt-003C]{
\title{Pullback squares from cartesian arrow maps}
\taxon{Theorem}
\p{We show that a [cartesian](stt-003V) arrow map gives a pullback square.
 That is, a square is cartesian iff the corresponding cone is a pullback cone.}

\proof{
\p{Suppose we have a square:}

\quiver{
\begin{tikzcd}
	A && C \\
	\\
	B && D
	\arrow["g", from=1-1, to=1-3]
	\arrow["f"', from=1-1, to=3-1]
	\arrow["{f'}", from=1-3, to=3-3]
	\arrow["{g'}"', from=3-1, to=3-3]
\end{tikzcd}
}

\p{such that the map #{\fibre{g'}{a} \toeq \fibre{g}{f'(a)}} is
an equivalence. Then to verify it is a pullback, then we need
to show that the induced map #{A \to C \times_D B} is also an equivalence.}

\p{We can view both of these maps as living in a slice over #{C}, and a
by [[stt-003D]], a map in the slice is in equivalence iff if is an equivalence
on fibres.}

\quiver{
\begin{tikzcd}
	A && {B \times_D C} \\
	& B
	\arrow["{\textit{gap}}", from=1-1, to=1-3]
	\arrow["f"', from=1-1, to=2-2]
	\arrow["{\pi_1}", from=1-3, to=2-2]
\end{tikzcd}
}

\p{So we need to show #{\fibre{f}{c} \to \fibre{\pi_1}{c}} is an equivalence. The
fibre of the projection is equivalent to the fibre of #{g} at #{f(c)}, and so by the
[3-for-2](foundations.3for2) property of equivalences we have that the square is a
pullback.}

% ```agda
\agda{
is-pullbackвЖРis-cartesian : вИА {рЭУ§ рЭУ• рЭУ¶ рЭУЬ}
  {A : Type рЭУ§} {B : Type рЭУ•} {f : A вЖТ B}
  {C : Type рЭУ¶} {D : Type рЭУЬ} {f' : C вЖТ D}
  вЖТ (g : Arrow-map f f')
  вЖТ is-cartesian g
  вЖТ let (s , c) = ConeвЖРArrow-map g
  in is-pullbackѕЙ s c
is-pullbackвЖРis-cartesian {A = A} {B} {f = f} {C} {D} {f' = f'} G pbsq
  = is-pullbackвЖРgap cone (is-equivвЖРon-fibres slice-map slice-equiv) where
  cospan = ConeвЖРArrow-map G .fst
  cone = ConeвЖРArrow-map G .snd

  g : A вЖТ C
  g = G .Arrow-map.top

  g' : B вЖТ D
  g' = G .Arrow-map.bot

  open pb

  slice-map : Slice-map f ѕАвВБ
  slice-map .fst = gap cone
  slice-map .snd = ~refl

  lem : {a = b : B} вЖТ
      arrow-fibre G b ~
      fib-ѕАвВБ g' f' b ._вЙГ_.fwd вИШ Slice-fibre (gap cone , ~refl) b
  lem (a , refl) = ќ£-pathвЖТ (refl , (вИЩ-reflr _))

  slice-equiv : is-fibrewise-equiv (Slice-fibre {q = ѕАвВБ} (gap cone , ~refl))
  slice-equiv b = 3-for-2~ {f = fib-ѕАвВБ g' f' b ._вЙГ_.fwd}
                           lem
                           (fib-ѕАвВБ g' f' b ._вЙГ_.has-is-eqv)
                           (pbsq b)


is-cartesianвЖРis-pullback : вИА {рЭУ§ рЭУ• рЭУ¶ рЭУЬ}
  {A : Type рЭУ§} {B : Type рЭУ•} {f : A вЖТ B}
  {C : Type рЭУ¶} {D : Type рЭУЬ} {f' : C вЖТ D}
  вЖТ (g : Arrow-map f f')
  вЖТ let (s , c) = ConeвЖРArrow-map g
  in is-pullbackѕЙ s c
  вЖТ is-cartesian g
is-cartesianвЖРis-pullback {f = f} {f' = f'} g pb b
  = homotopy-is-equiv lem
                      (is-equiv-вИШ (fib-ѕАвВБ bot f' b ._вЙГ_.has-is-eqv)
                                  (fibre-equivвЖРis-equiv slice-map gap-is-equiv b )) where
  open Arrow-map g
  open pb

  cospan = ConeвЖРArrow-map g .fst
  cone = ConeвЖРArrow-map g .snd

  gap-is-equiv : is-equiv (gap (mk-cone f top comm))
  gap-is-equiv = gap-is-equivвЖРis-pullback _ pb

  slice-map : Slice-map f ѕАвВБ
  slice-map .fst = gap cone
  slice-map .snd = ~refl

  lem : fib-ѕАвВБ bot f' b ._вЙГ_.fwd вИШ
      Slice-fibre slice-map b
      ~ arrow-fibre g b
  lem (a , refl) = ќ£-pathвЖТ (refl , sym (вИЩ-reflr _))

is-cartesianвЖРgap-is-equiv
  : вИА {рЭУ§ рЭУ• рЭУ¶ рЭУЬ} {A : Type рЭУ§} {B : Type рЭУ•} {f : A вЖТ B}
      {C : Type рЭУ¶} {D : Type рЭУЬ} {g : C вЖТ D}
    вЖТ (F : Arrow-map f g)
    вЖТ is-equiv (gap (ConeвЖРArrow-map F .snd))
    вЖТ is-cartesian F
is-cartesianвЖРgap-is-equiv F gap
  = is-cartesianвЖРis-pullback F (is-pullbackвЖРgap _ gap)
}
% ```
}
}

\subtree[stt-003P]{
\taxon{Definition}
\title{Squares from pre/post-composition}

\p{Given a square of the form:}

\quiver{
\begin{tikzcd}
	A && C \\
	\\
	B && D
	\arrow["g", from=1-1, to=1-3]
	\arrow["f"', from=1-1, to=3-1]
	\arrow["{f'}", from=1-3, to=3-3]
	\arrow["{g'}"', from=3-1, to=3-3]
\end{tikzcd}
}

\p{For all types #{Q}, we obtain squares:}

\quiver{
\begin{tikzcd}
	{Q \to A} && {Q \to C} \\
	\\
	{Q \to B} && {Q \to D}
	\arrow["{g \circ {-}}", from=1-1, to=1-3]
	\arrow["{f \circ {-}}"', from=1-1, to=3-1]
	\arrow["{f' \circ {-}}", from=1-3, to=3-3]
	\arrow["{g' \circ {-}}"', from=3-1, to=3-3]
\end{tikzcd}
}

\p{and}

\quiver{
\begin{tikzcd}
	{D \to Q} && {B \to Q} \\
	\\
	{C \to Q} && {A \to Q}
	\arrow["{{-} \circ g'}", from=1-1, to=1-3]
	\arrow["{{-} \circ f'}"', from=1-1, to=3-1]
	\arrow["{{-} \circ f'}", from=1-3, to=3-3]
	\arrow["{{-} \circ g}"', from=3-1, to=3-3]
\end{tikzcd}
}

% ```agda
\agda{
precomp-square : вИА {рЭУ§ рЭУ• рЭУ¶ рЭУЬ}
  {A : Type рЭУ§} {B : Type рЭУ•} {f : A вЖТ B}
  {C : Type рЭУ¶} {D : Type рЭУЬ} {f' : C вЖТ D}
  (g : Arrow-map f f')
  вЖТ вИА {рЭУЫ} (C : Type рЭУЫ) вЖТ Arrow-map (precomp C f') (precomp C f)
precomp-square (mk-amap top bot p) C
 = mk-amap (_вИШ bot) (_вИШ top) ќї f вЖТ funextвЖТ (f вЧВ (p ~вБї¬є))

postcomp-square : вИА {рЭУ§ рЭУ• рЭУ¶ рЭУЬ}
  {A : Type рЭУ§} {B : Type рЭУ•} {f : A вЖТ B}
  {C : Type рЭУ¶} {D : Type рЭУЬ} {f' : C вЖТ D}
  (g : Arrow-map f f')
  вЖТ вИА {рЭУЫ} (C : Type рЭУЫ) вЖТ Arrow-map (postcomp C f) (postcomp C f')
postcomp-square (mk-amap top bot p) C
  = mk-amap (top вИШ_) (bot вИШ_) ќї f вЖТ funextвЖТ (p вЦЄ f)
}
% ```
}

\remark{
\p{Precomposing squares gives the result of applying the functor
#{\Hom(Q,H)} to the square. It is a well known result that this functor preserves
pullback Likewise, postcomposition is given by #{\Hom({-},Q)}, and this functor turns
pushouts in to pullbacks.
}
}

\subtree[stt-003R]{
\title{Precomposition of cartesian squares}
\taxon{Theorem}

\p{Given a square of the following form:}

\quiver{
\begin{tikzcd}
	A && C \\
	\\
	B && D
	\arrow["g", from=1-1, to=1-3]
	\arrow["f"', from=1-1, to=3-1]
	\arrow["{f'}", from=1-3, to=3-3]
	\arrow["{g'}"', from=3-1, to=3-3]
\end{tikzcd}
}

\p{We show that the square obtained via precomposition
   is cartesian iff the original square is.
}

\proof{

\p{
First note that the type of cones on #{(Q \to B) \to (Q \to D) \leftarrow (Q \to C)}
is equivalent to the canonical pullback of #{B \to D \leftarrow C}. We can construct
the following triangle, and apply the three for two property for equivalences:
}

\quiver{
\begin{tikzcd}
	{(A \to Q)} &&& {(B \to Q)\times_{(C \to Q)} (D \to Q)} \\
	\\
	&& {\textrm{Cone}(f,g)}
	\arrow["{\textit{gap}}", from=1-1, to=1-4]
	\arrow["{\textrm{cone-map}}"', from=1-1, to=3-3]
	\arrow["\sim", from=1-4, to=3-3]
\end{tikzcd}
}

% ```agda
\agda{
unquoteDecl cone-reprвЙЕ cone-reprвЙГ
  = make-record-repr cone-reprвЙЕ cone-reprвЙГ (quote Cone)

postcomp-coneвЙГpb : вИА {рЭУ§ рЭУ• рЭУ¶ рЭУЬ}
  {A : Type рЭУ§} {B : Type рЭУ•}
  {C : Type рЭУ¶} {f : A вЖТ B}
  {g : C вЖТ B} {D : Type рЭУЬ}
  вЖТ Cone (mk-cospan B f g) D вЙГ Pullback (postcomp D f) (postcomp D g)
postcomp-coneвЙГpb {f = f} {g = g} {D = D}
  = Cone (mk-cospan _ f g) D              вЙГвЯ® cone-reprвЙГ вЯ©
    ќ£[ f' вИґ (D вЖТ _) ] ќ£[ g' вИґ (D вЖТ _) ]
        (postcomp D f f' ~ postcomp D g g') вЙГвЯ® ќ£-ap-вЙГ (ќї f' вЖТ ќ£-ap-вЙГ (ќї g' вЖТ funextвЙГ eвБї¬є)) вЯ©
    Pullback (postcomp D f) (postcomp D g)  вЙГвИО


postcomp-cartesian : вИА {рЭУ§ рЭУ• рЭУ¶ рЭУЬ}
  {A : Type рЭУ§} {B : Type рЭУ•} {f : A вЖТ B}
  {C : Type рЭУ¶} {D : Type рЭУЬ} {f' : C вЖТ D}
  (g : Arrow-map f f')
  вЖТ is-cartesian g
  вЖТ вИА {рЭУЫ} {C : Type рЭУЫ}
  вЖТ is-cartesian
        (postcomp-square g C)
postcomp-cartesian {A = A} {f = f} {f' = f'} G@(mk-amap g g' H) eq {_} {C}
  = is-cartesianвЖРis-pullback _
      (is-pullbackвЖРgap (cnвИШ C)
                       (3-for-2
                         {f = _вЙГ_.bwd postcomp-coneвЙГpb}
                         {g = gap (cnвИШ C)}
                         (_вЙГ_.has-is-eqv (postcomp-coneвЙГpb eвБї¬є))
                         (cn-is-pb .is-pullbackѕЙ.has-is-pb C))) where
  cs : Cospan _ _ _
  cs = ConeвЖРArrow-map G .fst

  cn : Cone cs _
  cn = ConeвЖРArrow-map G .snd

  csвИШ : вИА {рЭУ†} (Q : Type рЭУ†) вЖТ Cospan _ _ _
  csвИШ {рЭУ†} Q = ConeвЖРArrow-map (postcomp-square G Q) .fst

  cnвИШ : вИА {рЭУ†} (Q : Type рЭУ†) вЖТ Cone (csвИШ Q) _
  cnвИШ {рЭУ†} Q = ConeвЖРArrow-map (postcomp-square G Q) .snd

  cn-is-pb : is-pullbackѕЙ cs cn
  cn-is-pb = is-pullbackвЖРis-cartesian G eq

  map : вИА {рЭУ†} {Q : Type рЭУ†} вЖТ (Q вЖТ A) вЖТ Cone cs Q
  map {_} {Q} = _вЙГ_.bwd postcomp-coneвЙГpb  вИШ gap (cnвИШ Q)
}
% ```
}
}

%```agda
\agda{
rotate-square : вИА {рЭУ§ рЭУ• рЭУ¶ рЭУЬ} {A : Type рЭУ§} {B : Type рЭУ•}
                  {C : Type рЭУ¶} {D : Type рЭУЬ}
                  {f : A вЖТ B} {g : C вЖТ D}
                вЖТ (F : Arrow-map f g)
                вЖТ Arrow-map (F .Arrow-map.top) (F .Arrow-map.bot)
rotate-square {f = f} {g = g} F
  = mk-amap f g (F .Arrow-map.comm ~вБї¬є)

rotate-is-cartesian
  : вИА {рЭУ§ рЭУ• рЭУ¶ рЭУЬ} {A : Type рЭУ§} {B : Type рЭУ•}
      {C : Type рЭУ¶} {D : Type рЭУЬ}
      {f : A вЖТ B} {g : C вЖТ D}
      (F : Arrow-map f g)
    вЖТ is-cartesian F
    вЖТ is-cartesian (rotate-square F)
rotate-is-cartesian {f = f} {g} F@(mk-amap top bot comm) fcart
  = is-cartesianвЖРgap-is-equiv _
        (is-equiv-вИШ (pullback-swap ._вЙГ_.has-is-eqv)
                    (gap-is-equivвЖРis-pullback _
                      (is-pullbackвЖРis-cartesian _ fcart)))
}
%```

\subtree[stt-00BX]{
\title{The fibre of maps as a cartesian square}
\taxon{Example}

%```agda
\agda{
fibre-square : вИА {рЭУ§ рЭУ•} {A : Type рЭУ§} {B : Type рЭУ•} (f : A вЖТ B) b
             вЖТ Arrow-map (! {A = fibre f b}) f
fibre-square f b .Arrow-map.top = fst
fibre-square f b .Arrow-map.bot = const _ рЭЯЩ b
fibre-square f b .Arrow-map.comm (x , p) = sym p

fibre-square-is-cartesian : вИА {рЭУ§ рЭУ•} {A : Type рЭУ§} {B : Type рЭУ•} (f : A вЖТ B) b
                            вЖТ is-cartesian (fibre-square f b)
fibre-square-is-cartesian f b = is-cartesianвЖРgap-is-equiv _ eq where
  map : fibre f b вЖТ Pullback (const _ рЭЯЩ b) f
  map (x , p) = (tt , x , sym p)

  eq : is-equiv map
  eq = is-equivвЖРqiso ((ќї (_ , x , p) вЖТ (x , sym p))
                     , (ќї where (_ , refl) вЖТ refl)
                     , ќї where (_ , _ , refl) вЖТ refl)
}
%```
}

\subtree[stt-00BR]{
\title{Total squares}
\taxon{Construction}

\p{Given a family of squares, we can define the total square by taking the
sum types and total maps between them.}

%```agda
\agda{
total-square
  : вИА {рЭУШ рЭУ§ рЭУ• рЭУ¶ рЭУЬ} {I : Type рЭУШ}
      {A : I вЖТ Type рЭУ§} {B : I вЖТ Type рЭУ•} {f : (i : I) вЖТ A i вЖТ B i}
      {C : I вЖТ Type рЭУ¶} {D : I вЖТ Type рЭУЬ} {g : (i : I) вЖТ C i вЖТ D i}
    вЖТ (F : (i : I) вЖТ Arrow-map (f i) (g i))
    вЖТ Arrow-map (total-map f) (total-map g)
total-square F .Arrow-map.top = total-map (Arrow-map.top вИШ F)
total-square F .Arrow-map.bot = total-map (Arrow-map.bot вИШ F)
total-square F .Arrow-map.comm (i , a)
  = ќ£-pathвЖТ (refl , Arrow-map.comm (F i) a)
}
%```agda
}

\subtree[stt-00BY]{
\title{Dependent precomposition square}
\taxon{Construction}

\p{Given a family of squares #{F_i : f_i \to g_i}, we can form the product square
#{\Pi_i F_i : \Pi_i f_i \to \Pi_i g_i}}

%```agda
\agda{
ќ†-square
  : вИА {рЭУШ рЭУ§ рЭУ• рЭУ¶ рЭУЬ} {I : Type рЭУШ}
      {A : I вЖТ Type рЭУ§} {B : I вЖТ Type рЭУ•} {f : (i : I) вЖТ A i вЖТ B i}
      {C : I вЖТ Type рЭУ¶} {D : I вЖТ Type рЭУЬ} {g : (i : I) вЖТ C i вЖТ D i}
    вЖТ (F : (i : I) вЖТ Arrow-map (f i) (g i))
    вЖТ Arrow-map (postcomp-ќ† f) (postcomp-ќ† g)
ќ†-square F .Arrow-map.top h i = Arrow-map.top (F i) (h i)
ќ†-square F .Arrow-map.bot h i = Arrow-map.bot (F i) (h i)
ќ†-square F .Arrow-map.comm h  = funextвЖТ (ќї a вЖТ Arrow-map.comm (F a) (h a))
}
%```

\p{#{\Pi_i F_i} is cartesian iff each square #{F_i} is.}

\proof{

\p{We use 3-for-2 in the red triangle of the following diagram:}

\quiver{
\begin{tikzcd}[cramped]
	& {\Pi_i(B_i\times_{D_i}C_i)} \\
	{\Pi_i A_i} &&& {\Pi_iC_i} \\
	& {\Pi_iB_i\times_{\Pi_i D_i}\Pi_i c_i} \\
	\\
	{\Pi_iB_i} &&& {\Pi_iD_i}
	\arrow["\sim"{pos=0.3}, color={rgb,255:red,214;green,92;blue,92}, from=1-2, to=3-2]
	\arrow["{\Pi_i(\textrm{gap})}"{pos=0.3}, color={rgb,255:red,214;green,92;blue,92}, from=2-1, to=1-2]
	\arrow[from=2-1, to=2-4]
	\arrow[color={rgb,255:red,214;green,92;blue,92}, from=2-1, to=3-2]
	\arrow[from=2-1, to=5-1]
	\arrow[from=2-4, to=5-4]
	\arrow[from=3-2, to=2-4]
	\arrow[from=3-2, to=5-1]
	\arrow["\lrcorner"{anchor=center, pos=0.125}, draw=none, from=3-2, to=5-4]
	\arrow[from=5-1, to=5-4]
\end{tikzcd}
}
}

%```agda
\agda{
opaque
  ќ†-square-is-cartesian
    : вИА {рЭУШ рЭУ§ рЭУ• рЭУ¶ рЭУЬ} {I : Type рЭУШ}
        {A : I вЖТ Type рЭУ§} {B : I вЖТ Type рЭУ•} {f : (i : I) вЖТ A i вЖТ B i}
        {C : I вЖТ Type рЭУ¶} {D : I вЖТ Type рЭУЬ} {g : (i : I) вЖТ C i вЖТ D i}
      вЖТ (F : (i : I) вЖТ Arrow-map (f i) (g i))
      вЖТ (вИА i вЖТ is-cartesian (F i))
      вЖТ is-cartesian (ќ†-square F)
  ќ†-square-is-cartesian {I = I} {g = g} F cart
    = is-cartesianвЖРgap-is-equiv _ eq where
    curry-pb : Pullback (Arrow-map.bot (ќ†-square F)) (postcomp-ќ† g)
          вЖТ ќ† I (ќї z вЖТ Pullback (Arrow-map.bot (F z)) (g z))
    curry-pb (f , g , H) i = (f i , g i , happly H i)

    curry-pb-qiso : quasi-iso curry-pb
    curry-pb-qiso .fst f = (pb.ѕАвВБ вИШ f , pb.ѕАвВВ вИШ f , funextвЖТ (pb.filler вИШ f))
    curry-pb-qiso .snd .fst (f , g , p)
      = pullback-pathвЖТ (refl , refl , sym (funext.ќЈ p) вИЩ sym (вИЩ-reflr _))
    curry-pb-qiso .snd .snd = ~refl

    eq : is-equiv (gap (ConeвЖРArrow-map (ќ†-square F) .snd))
    eq = (3-for-2~
            {f = curry-pb}
            {g = gap-mapвЖРsquare (ќ†-square F)}
            {k = postcomp-ќ† (ќї i вЖТ gap-mapвЖРsquare (F i))}
            ~refl
            (is-equivвЖРqiso curry-pb-qiso)
            (postcomp-ќ†-equiv
              (ќї {i} вЖТ gap-is-equivвЖРis-pullback _
                (is-pullbackвЖРis-cartesian _ (cart i)))))
}
%```
}

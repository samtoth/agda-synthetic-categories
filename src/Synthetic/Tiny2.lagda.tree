            (@вҷӯ is-fib : вҲҖ {рқ“Ө рқ“Ҙ} {A : Type рқ“Ө} (B : A вҶ’ Type рқ“Ҙ) вҶ’ Type (Оұ рқ“Ө рқ“Ҙ))
            (@вҷӯ rel-fib : is-relative I is-fib)
            (@вҷӯ prop-is-disc : вҲҖ {@вҷӯ рқ“Ө} {@вҷӯ A : Type рқ“Ө}
                               вҶ’ is-prop A вҶ’ is-вҷӯ-discrete A)
            where
  open DependentвҲҡ I вҲҡ вҲҡОө is-tiny-str types-separate prop-is-disc
  open Tiny I вҲҡ вҲҡОө is-tiny-str types-separate prop-is-disc public
  private
    map : вҲҖ {рқ“Ө} вҶ’ рқҹҷ вҶ’ (Prop-U рқ“Ө)
    map _ = (ULift _ рқҹҷ , trunc!)

  вҲҡ-Path : вҲҖ {@вҷӯ рқ“Ө} {@вҷӯ A : Type рқ“Ө} вҶ’ вҲҡ A вҶ’ вҲҡ A вҶ’ Type (lsuc рқ“Ө)
  вҲҡ-Path {_}{A} a b = вҲҡбөҲ (О» g вҶ’ вҲҡОө (fst вҲҳ g) пјқ вҲҡОө (snd вҲҳ g)) (a , b)

  вҲҡ-Path-refl : вҲҖ {@вҷӯ рқ“Ө} {@вҷӯ A : Type рқ“Ө} (a : вҲҡ A) вҶ’ вҲҡ-Path a a
  вҲҡ-Path-refl {A = A} a = вҲҡбөҲ-naturalityвҶҗ _ (О”Г— (вҲҡ A)) a (П• a) where
    @вҷӯ П• : О  (вҲҡ A) (вҲҡбөҲ (О» x вҶ’ вҲҡОө x пјқ вҲҡОө x))
    П• = Оөвҷӯ (rintro {О“ = вҲҡ A}{A = О» x вҶ’ вҲҡОө x пјқ вҲҡОө x} (modвҷӯ ~refl))

  test : вҲҖ {@вҷӯ рқ“Ө} {@вҷӯ A : Type рқ“Ө}
         вҶ’ вҹЁвҷӯ| О  (вҲҡ A Г— вҲҡ A) (uncurry вҲҡ-Path) вҹ©
         вҶ’ вҹЁвҷӯ| О  (I вҶ’ (вҲҡ A Г— вҲҡ A)) (О» g вҶ’ вҲҡОө (fst вҲҳ g) пјқ вҲҡОө (snd вҲҳ g)) вҹ©
  test = relim

  test2 : вҲҖ {@вҷӯ рқ“Ө} {@вҷӯ A : Type рқ“Ө}
          вҶ’ вҹЁвҷӯ| О  (A Г— A) (О» g вҶ’ fst g пјқ snd g) вҹ©
          вҶ’ вҹЁвҷӯ| О  (вҲҡ A Г— вҲҡ A) (uncurry вҲҡ-Path) вҹ©
  test2
    = rintro
    вҲҳ вҷӯ-map (precomp-О  (О» z вҶ’ fst z пјқ snd z) О» x вҶ’ (вҲҡОө (fst вҲҳ x) , вҲҡОө (snd вҲҳ x)))

  global-ОЈ-presвҶ’
    : вҲҖ {@вҷӯ рқ“Ө рқ“Ҙ рқ“Ұ} {@вҷӯ О“ : Type рқ“Ө} {@вҷӯ A : Type рқ“Ҙ} {@вҷӯ B : A вҶ’ Type рқ“Ұ}
      вҶ’ вҹЁвҷӯ| (О“ вҶ’ вҲҡ (ОЈ A B))вҹ© вүғ вҹЁвҷӯ| (О“ вҶ’ ОЈ (вҲҡ A) (вҲҡбөҲ (B вҲҳ вҲҡОө)))вҹ©
  global-ОЈ-presвҶ’ {О“ = О“}{A}{B}
    = вҹЁвҷӯ| (О“ вҶ’ вҲҡ (ОЈ A B)) вҹ©   вүғвҹЁ expвҠЈвҲҡ eвҒ»В№ вҹ©
      вҹЁвҷӯ| ((I вҶ’ О“) вҶ’ ОЈ A B) вҹ© вүғвҹЁ вҷӯвүғ (ОЈ-О -swapвүғ _ _) вҹ©
      вҹЁвҷӯ| ОЈ ((x : I вҶ’ О“) вҶ’ A) (О» f вҶ’ (x : I вҶ’ О“) вҶ’ B (f x)) вҹ©
                              вүғвҹЁ вҷӯ-commОЈ _ eвҒ»В№ вҹ©
      ОЈвҷӯ ((I вҶ’ О“) вҶ’ A) (О» (@вҷӯ x) вҶ’ вҹЁвҷӯ| ((xвӮҒ : I вҶ’ О“) вҶ’ B (x xвӮҒ)) вҹ©)
                              вүғвҹЁ mkвүғ (map-ОЈ _ (вҷӯ-ind _ (О» x вҶ’ {!!}))) (map-ОЈ-is-equiv
                                {Y = вҷӯ-ind _ (О» f вҶ’ вҹЁвҷӯ| ((x : I вҶ’ О“) вҶ’ B (вҲҡОө (f вҲҳ x))) вҹ©)}
                                (expвҠЈвҲҡ ._вүғ_.has-is-eqv)
                                (вҷӯ-ind _ (О» x вҶ’ {!!}))) вҹ©
      ОЈ вҹЁвҷӯ| ((b : О“) вҶ’ вҲҡ A) вҹ©
       (вҷӯ-ind _
        (О» (@вҷӯ f) вҶ’ вҹЁвҷӯ| ((x : I вҶ’ О“) вҶ’ B (вҲҡОө (f вҲҳ x))) вҹ©))
                              вүғвҹЁ ОЈ-ap-вүғ (вҷӯ-ind _
                                (О» f вҶ’ mkвүғ (вҷӯ-map (postcomp-О 
                                                  (О» g вҶ’ вҲҡбөҲ-naturalityвҶҗ (B вҲҳ вҲҡОө) f g))
                                           вҲҳ rintro {A = B вҲҳ вҲҡОө вҲҳ postcomp _ f})
                                           (is-equiv-вҲҳ (вҷӯ-map-is-equiv
                                             (postcomp-О -equiv (вҲҡбөҲ-naturality-is-equiv' f _)))
                                             rintro-is-equiv))) вҹ©
      ОЈ вҹЁвҷӯ| (О“ вҶ’ вҲҡ A) вҹ© (вҷӯ-ind _
                         (О» (@вҷӯ f) вҶ’
                            вҹЁвҷӯ|
                            (вҲҖ x вҶ’ вҲҡбөҲ (B вҲҳ вҲҡОө) (f x))
                            вҹ©))                       вүғвҹЁ вҷӯ-commОЈ _ вҹ©
      вҹЁвҷӯ| ОЈ[ f вҲ¶ ((x : О“) вҶ’ вҲҡ A)]
           ((x : О“) вҶ’ (вҲҡбөҲ (B вҲҳ вҲҡОө) (f x))) вҹ©               вүғвҹЁ вҷӯвүғ (ОЈ-О -swapвүғ _ _ eвҒ»В№) вҹ©
      вҹЁвҷӯ| (О“ вҶ’ ОЈ (вҲҡ A) (вҲҡбөҲ (B вҲҳ вҲҡОө))) вҹ© вүғвҲҺ

  -- вҲҡ-pres-ОЈвҶ’ : вҲҖ {@вҷӯ рқ“Ө рқ“Ҙ} {@вҷӯ A : Type рқ“Ө} {@вҷӯ B : A вҶ’ Type рқ“Ҙ}
  --             вҶ’ вҲҡ (ОЈ A B) вҶ’ ОЈ (вҲҡ A) (вҲҡбөҲ (B вҲҳ вҲҡОө))

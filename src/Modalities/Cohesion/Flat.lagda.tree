\date{2025-06-06}
\title{The Flat Modalitiy}
\taxon{Module}
\author{samueltoth}
\import{stt-macros}

%```agda
\agda{
module Modalities.Cohesion.Flat where

open import Foundations.Prelude

open import Core.Arrow
open import Core.ArrowEquiv
}

\subtree[stt-004Z]{
\title{The Flat type operator}
\taxon{Definition}

\p{Given a crisp type #{A}, we can form the type #{\modflat{A}}. In agda flat
we can encode this with an inductive datatype generated by a crisp elements
of #{A}. We also note the corresponding induction principle for the inductive
type.}

\agda{
data ⟨♭|_⟩ {@♭ 𝓤} (@♭ A : Type 𝓤) : Type 𝓤 where
  mod♭ : (@♭ _ : A) → ⟨♭| A ⟩

♭-ind : ∀ {@♭ 𝓤} {𝓥} {@♭ A : Type 𝓤} (B : ⟨♭| A ⟩ → Type 𝓥)
          → ((@♭ x : A) → B (mod♭ x))
          → (x : ⟨♭| A ⟩) → B x
♭-ind B f (mod♭ x) = f x
}
%```
}

\subtree[stt-0051]{
\taxon{Theroem}
\title{Flat is a Functor}

\p{Using the rules of [modal type theory](stt-0050) and #{\flat}-induction,
we can define operations making #{\modflat{-}} into a comonad.}

\p{To get a feel for how to reason informally about modal type theory, we
give the definition making #{\modflat{-}} into a functor informally
(in pain-staking detail), and compare it to the agda definition:}

\p{Given crisp types #{A :^\flat \UU} and #{B :^\flat \UV}, and a function
#{f :^\flat A \to B}, we can define a function #{\modflat{A} \to \modflat{B}}.
By crisp induction, it surfices to define a function
#{(a :^\flat A) \to \modflat{B}}. Then by #{\flat}-intro, we can assume a
crisp #{a :^\flat A} and give a crisp term of type #{B}, but now both #{f} and
#{a} were assumed crisp and so #{f(a) :^\flat B}, and we are done.
 }

%```agda
\agda{
♭-map : ∀ {@♭ 𝓤 𝓥} {@♭ A : Type 𝓤} {@♭ B : Type 𝓥}
        → (@♭ f : A → B) → ⟨♭| A ⟩ → ⟨♭| B ⟩
♭-map f (mod♭ x) = mod♭ (f x)

♭-id : ∀ {@♭ 𝓤} {@♭ A : Type 𝓤}
        → ♭-map {A = A} id ~ id
♭-id (mod♭ x) = refl

♭-∘ : ∀ {@♭ 𝓤 𝓥 𝓦} {@♭ A : Type 𝓤} {@♭ B : Type 𝓥} {@♭ C : Type 𝓦}
        → (@♭ f : B → C) (@♭ g : A → B)
        → ♭-map (f ∘ g) ~ ♭-map f ∘ ♭-map g
♭-∘ f g (mod♭ x) = refl
}
%```
}

\subtree[stt-0052]{
\taxon{Theorem}
\title{Flat is a comonad}

\p{Similarly, we can define the counit and comultiplication functions that
make #{\modflat{-}} into a comonad.}

%```agda
\agda{
ε♭ : ∀ {@♭ 𝓤} {@♭ A : Type 𝓤} → ⟨♭| A ⟩ → A
ε♭ (mod♭ x) = x

ε♭:_ : ∀ {@♭ 𝓤} (@♭ A : Type 𝓤) → ⟨♭| A ⟩ → A
ε♭:_ _ = ε♭

ε♭-natural : ∀ {@♭ 𝓤 𝓥} {@♭ A : Type 𝓤} {@♭ B : Type 𝓥} {@♭ f : A → B}
             → ε♭  ∘ ♭-map f ~ f ∘ ε♭
ε♭-natural (mod♭ x) = refl

⟨♭♭|_⟩ : ∀ {@♭ 𝓤} → (@♭ _ : Type 𝓤) → Type 𝓤
⟨♭♭| A ⟩ = ⟨♭| ⟨♭| A ⟩ ⟩

comult : ∀ {@♭ 𝓤} {@♭ A : Type 𝓤} → ⟨♭| A ⟩ → ⟨♭♭| A ⟩
comult (mod♭ x) = mod♭ (mod♭ x)
}
%```
}

\subtree[stt-0054]{
\title{Flat is an idempotent comonad}
\taxon{Theorem}

\p{We show that \code{comult} is an equivalence.}

%```agda
\agda{
μ : ∀ {@♭ 𝓤} {@♭ A : Type 𝓤}
    → ⟨♭♭| A ⟩ → ⟨♭| A ⟩
μ = ε♭

♭-map-ε♭ : ∀ {@♭ 𝓤} {@♭ A : Type 𝓤} → ♭-map ε♭ ~ ε♭: ⟨♭| A ⟩
♭-map-ε♭ (mod♭ (mod♭ x)) = refl

comult-is-equiv : ∀ {@♭ 𝓤} {@♭ A : Type 𝓤} → is-equiv (comult {A = A})
comult-is-equiv .is-equiv.qiso .fst = μ
comult-is-equiv .is-equiv.qiso .snd .fst (mod♭ _) = refl
comult-is-equiv .is-equiv.qiso .snd .snd (mod♭ (mod♭ x)) = refl
comult-is-equiv .is-equiv.coherent (mod♭ x) = refl

♭-idem : ∀ {@♭ 𝓤} {@♭ A : Type 𝓤}
         → ⟨♭♭| A ⟩ ≃ ⟨♭| A ⟩
♭-idem = mk≃ μ (is-equiv⁻¹ comult-is-equiv)
}
%```
}

\subtree[stt-0057]{
\taxon{Definition}
\title{Crisp Identity Induction}
\date{2025-06-10}

\p{We can define an induction principle for crisp identity types, defined for
families #{P : \Pi_{(a :^{\flat} A)} (a = b) \to \UU}}

%```agda
\agda{
J♭ : ∀ {@♭ 𝓤} {𝓥} {@♭ A : Type 𝓤} {@♭ a : A}
       (P : (@♭ b : A) → (p : a ＝ b) → Type 𝓥)
     → P a refl
     → {@♭ b : A} → (@♭ p : a ＝ b)
     → P b p
J♭ P pr refl = pr

_ : ∀ {@♭ 𝓤} {@♭ A : Type 𝓤} {@♭ a b : A}
       → mod♭ a ＝ mod♭ b
       → ⟨♭| a ＝ b ⟩
_ = λ p → J (λ where (mod♭ x) p' → ⟨♭| _ ＝ x ⟩) (mod♭ refl) p
}
%```

\p{This can be used to define the functoriality of functions with respect to
crisp-identity types.}

%```agda
\agda{
ap♭ : ∀ {@♭ 𝓤} {𝓥} {@♭ A : Type 𝓤} {B : Type 𝓥}
      (f : @♭ A → B) → {@♭ x y : A} → @♭ x ＝ y
      → f x ＝ f y
ap♭ f refl = refl

ap♭' : ∀ {@♭ 𝓤 𝓥} {@♭ A : Type 𝓤} {@♭ B : Type 𝓥}
         (@♭ f : @♭ A → B) → {@♭ x y : A}
       → ⟨♭| x ＝ y ⟩
       → ⟨♭| f x ＝ f y ⟩
ap♭' f (mod♭ p) = mod♭ (ap♭ f p)


_ : ∀ {@♭ 𝓤} {𝓥} {@♭ A : Type 𝓤} {B : Type 𝓥}
      (f : @♭ A → B) → {@♭ x y : A} → @♭ x ＝ y
      → f x ＝ f y
_ = λ f → J♭ (λ b _ → f _ ＝ f b) refl
}
%```

\p{We sometimes call the above construction the weak crisp induction principle
in contrast with the following stronger induction principle:
}
%```agda
\agda{
J-crisp-ind : ∀ (@♭ 𝓤 𝓥 : Level) → Type (lsuc (𝓤 ⊔ 𝓥))
J-crisp-ind 𝓤 𝓥 = ∀ {@♭ A : Type 𝓤} {@♭ a : A}
                     (@♭ P : (@♭ b : A) → (@♭ p : a ＝ b) → Type 𝓥)
                    → @♭ P a refl
                    → {@♭ b : A} → (@♭ p : a ＝ b)
                    → P b p
}
%```

\p{With just the flat modality, the full crisp induction principle is
not derivable in base MTT. \citek{DG21} However, as we show in \ref{stt-00J1},
we can use the #{\sharp} modality, and its adjointness with #{\flat} to derive
this stronger crisp induction principle.}
}


\subtree[stt-0055]{
\taxon{Construction}

\p{Using induction on #{\flat} and this (weak) crisp identity induction
principle, we can define a map
#{\modflat{a = b} \to \mod_{\flat}(a) ＝ \mod_{\flat}(b)}. In analogy to function
types, we call this map #{\textsf{mapply}_\flat}.}

%```agda
\agda{
mapply♭ : ∀ {@♭ 𝓤} {@♭ A : Type 𝓤} {@♭ a b : A}
       → ⟨♭| a ＝ b ⟩
       → mod♭ a ＝ mod♭ b
mapply♭ (mod♭ refl) = refl

_ : ∀ {@♭ 𝓤} {@♭ A : Type 𝓤} {@♭ a b : A}
       → ⟨♭| a ＝ b ⟩
       → mod♭ a ＝ mod♭ b
_ = ♭-ind _ (ap♭ mod♭)
}
%```
}


\subtree[stt-00JR]{
\taxon{Lemma}
\title{Equivalences are flat equivalences}

\p{Equivalences #{f : A \toeq B} induce equivalences
#{\flat f : \modflat{A} \toeq \modflat{B}}}

%```agda
\agda{
♭-map-is-equiv
  : ∀ {@♭ 𝓤 𝓥} {@♭ A : Type 𝓤} {@♭ B : Type 𝓥} {@♭ f : A → B}
    → @♭ is-equiv f → is-equiv (♭-map f)
♭-map-is-equiv fe = is-equiv←qiso
  ( ♭-map (bwd fe)
  , (λ where (mod♭ x) → ap♭ mod♭ (η fe x))
  , (λ where (mod♭ x) → ap♭ mod♭ (ε fe x)))
  where open is-equiv

♭≃ : ∀ {@♭ 𝓤 𝓥} {@♭ A : Type 𝓤} {@♭ B : Type 𝓥} (@♭ e : A ≃ B)
     → ⟨♭| A ⟩ ≃ ⟨♭| B ⟩
♭≃ e = mk≃ (♭-map (e ._≃_.fwd)) (♭-map-is-equiv (e ._≃_.has-is-eqv))
}
%```
}

\subtree[stt-0053]{
\title{Flat commutes with #{\Sigma} and #{1}}
\taxon{Theorem}

\p{First we show that #{\flat} commutes with #{1}, or in other words
#{\modflat{1}} is a [singleton](stt-0006). Similarly we can show that
#{\modflat{-}} preserves all singletons.}

%```agda
\agda{
♭𝟙-is-single : is-singleton ⟨♭| 𝟙 ⟩
♭𝟙-is-single = mk-singl (mod♭ tt) λ where (mod♭ tt) → refl

♭-is-single : ∀ {@♭ 𝓤} {@♭ A : Type 𝓤}
              → @♭ is-singleton A → is-singleton ⟨♭| A ⟩
♭-is-single (mk-singl c p) = mk-singl (mod♭ c) λ where
  (mod♭ x) → mapply♭ (mod♭ (p x))
}
%```

%```agda
\agda{
♭-× : ∀ {@♭ 𝓤 𝓥} {@♭ A : Type 𝓤} {@♭ B : Type 𝓥}
      → ⟨♭| A × B ⟩ → ⟨♭| A ⟩ × ⟨♭| B ⟩
♭-× (mod♭ (a , b)) = (mod♭ a , mod♭ b)


♭-×⁻¹ : ∀ {@♭ 𝓤 𝓥} {@♭ A : Type 𝓤} {@♭ B : Type 𝓥}
      → ⟨♭| A ⟩ × ⟨♭| B ⟩ → ⟨♭| A × B ⟩
♭-×⁻¹ (mod♭ a , mod♭ b) = (mod♭ (a , b))

♭-×-is-equiv : ∀ {@♭ 𝓤 𝓥} {@♭ A : Type 𝓤} {@♭ B : Type 𝓥}
           → is-equiv (♭-× {A = A} {B})
♭-×-is-equiv = is-equiv←qiso
  ( ♭-×⁻¹
  , (λ {(mod♭ (a , b)) → refl})
  , λ {(mod♭ a , mod♭ b) → refl})

♭-pres-×
  : ∀ {@♭ 𝓤 𝓥} {@♭ A : Type 𝓤} {@♭ B : Type 𝓥}
    → ⟨♭| A × B ⟩ ≃ ⟨♭| A ⟩ × ⟨♭| B ⟩
♭-pres-× = mk≃ ♭-× ♭-×-is-equiv
}
%```

\p{Given a crisp type #{A},
and a family of types #{B} crisply over #{A}, we can define the
dependent flat-sum, written #{\Sigma_{a :^\flat A} B(a)}. Defined
as #{\Sigma_{x : \modflat{A}}\flat\textrm{-rec}(\_,B,x)}.}

%```agda
\agda{
Σ♭ : ∀ {@♭ 𝓤 𝓥} (@♭ A : Type 𝓤) (B : @♭ A → Type 𝓥)
     → Type (𝓤 ⊔ 𝓥)
Σ♭ A B = Σ ⟨♭| A ⟩ (♭-ind _ B)

syntax Σ♭ A (λ x → B) = Σ[♭ x ∶ A ] B

snd♭ : ∀ {@♭ 𝓤 𝓥} {@♭ A : Type 𝓤} {B : @♭ A → Type 𝓥}
       → (x : Σ♭ A B) → ♭-ind _ B (x .fst)
snd♭ = snd
}
%```

\p{We now show #{\flat} commutes with #{\Sigma} in the sense that
#{\Sigma_{a :^\flat A} \modflat{B(a)}} is equivalent to
#{\modflat{\Sigma_{a : A}B(a)}}}

%```agda
\agda{
♭-Σ : ∀ {@♭ 𝓤 𝓥} {@♭ A : Type 𝓤} (@♭ B : A → Type 𝓥)
      → Σ[♭ x ∶ A ] ⟨♭| B x ⟩
      → ⟨♭| Σ A B ⟩
♭-Σ B (mod♭ a , mod♭ b) = mod♭ (a , b)

♭-Σ' : ∀ {@♭ 𝓤 𝓥} {@♭ A : Type 𝓤} (@♭ B : A → Type 𝓥)
      → ⟨♭| Σ A B ⟩
      → Σ[♭ x ∶ A ] ⟨♭| B x ⟩
♭-Σ' B (mod♭ (a , b)) = (mod♭ a , mod♭ b)

♭-commΣ : ∀ {@♭ 𝓤 𝓥} {@♭ A : Type 𝓤} (@♭ B : A → Type 𝓥)
                 → (Σ[♭ x ∶ A ] ⟨♭| B x ⟩) ≃ ⟨♭| Σ A B ⟩
♭-commΣ P ._≃_.fwd = ♭-Σ P
♭-commΣ P ._≃_.has-is-eqv .is-equiv.qiso .fst = ♭-Σ' P
♭-commΣ P ._≃_.has-is-eqv .is-equiv.qiso .snd .fst (mod♭ a , mod♭ b) = refl
♭-commΣ P ._≃_.has-is-eqv .is-equiv.qiso .snd .snd (mod♭ (a , b)) = refl
♭-commΣ P ._≃_.has-is-eqv .is-equiv.coherent (mod♭ a , mod♭ b) = refl
}
%```
}


\subtree[stt-00K9]{
\taxon{Lemma}

%```agda
\agda{
opaque
  ♭-map-total-is-equiv
    : ∀ {@♭ 𝓤 𝓥 𝓦} {@♭ A : Type 𝓤} {@♭ B : A → Type 𝓥}{@♭ C : A → Type 𝓦}
      → (@♭ f : ∀ a → B a → C a)
    → is-equiv (total-map {B = ♭-ind _ (λ a → ⟨♭| B a ⟩)}
                          {B' = ♭-ind _ (λ a → ⟨♭| C a ⟩)}
                          (♭-ind _ (λ a → ♭-map (f a))))
    → is-equiv (♭-map (total-map f))
  ♭-map-total-is-equiv {B = B} {C = C} f fe
    = is-equiv←Arrow-equiv {F = amap}
        (♭-commΣ _ ._≃_.has-is-eqv , ♭-commΣ _ ._≃_.has-is-eqv)
        fe where
    amap : Arrow-map (total-map {B = ♭-ind _ (λ a → ⟨♭| B a ⟩)}
                                {B' = ♭-ind _ (λ a → ⟨♭| C a ⟩)}
                                (♭-ind _ (λ a → ♭-map (f a))))
                     (♭-map (total-map f))
    amap .Arrow-Π.top = ♭-Σ _
    amap .Arrow-Π.bot = ♭-Σ _
    amap .Arrow-Π.comm (mod♭ a , mod♭ b) = refl
}
%```
}

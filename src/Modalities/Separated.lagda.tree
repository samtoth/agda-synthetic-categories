\subtree[stt-007E]{
\title{Separated types for a subuniverse}
\taxon{Definition}

\p{A type is separated if it's identity types are modal. This forms a
[(global)](stt-007A) [subuniverse](stt-003Z).}


%```agda
\agda{
is-separated : вҲҖ {рқ“Ө рқ“Ұ} (S : SubU рқ“Ө рқ“Ұ) вҶ’ Type рқ“Ө вҶ’ Type (рқ“Ө вҠ” рқ“Ұ)
is-separated S A = вҲҖ (x y : A) вҶ’ (x пјқ y) вҲҲ S

separated-SubU : вҲҖ {рқ“Ө рқ“Ұ} (S : SubU рқ“Ө рқ“Ұ) вҶ’ SubU рқ“Ө (рқ“Ө вҠ” рқ“Ұ)
separated-SubU S .Subtype.family = is-separated S
separated-SubU S .Subtype.has-is-subtype A
  = is-prop-О  О» x вҶ’ is-prop-О  О» y вҶ’ Subtype.has-is-subtype S (x пјқ y)

equiv-separated : вҲҖ {Оұ} (S : GSU Оұ) {рқ“Ө рқ“Ҙ} {A : Type рқ“Ө}
                    {B : Type рқ“Ҙ} (e : A вүғ B)
                  вҶ’ is-separated (SubUвҶҗglobal S) A
                  вҶ’ is-separated (SubUвҶҗglobal S) B
equiv-separated S e sep x y
  = GSU.вҲҲSвҶҗequiv S
       (embeddingвүғ (is-embeddingвҶҗis-equiv
                     (is-equivвҒ»В№ has-is-eqv)) x y)
       (sep (bwd x) (bwd y))
  where
    open _вүғ_ e

separated-GSU : вҲҖ {Оұ} (S : GSU Оұ) вҶ’ GSU  (О» рқ“Ө вҶ’ рқ“Ө вҠ” Оұ рқ“Ө)
separated-GSU S .GSU.S = separated-SubU (SubUвҶҗglobal S)
separated-GSU S .GSU.вҲҲSвҶҗequiv = equiv-separated S


is-separated-SubU-equiv
  : вҲҖ {рқ“Ө рқ“Ҙ рқ“Ҙ'} (S : SubU рқ“Ө рқ“Ҙ) (K : SubU рқ“Ө рқ“Ҙ')
      {A : Type рқ“Ө}
    вҶ’ Subtype-equiv S K
    вҶ’ is-separated S A
    вҶ’ is-separated K A
is-separated-SubU-equiv _ _ eq sep a b = eq _ .fst (sep a b)
}
%```
}


\subtree[stt-007I]{
\title{Local types are separated}
\taxon{Theorem}

\p{Given a reflective subuniverse #{S},
the #{S}-modal types are also #{S}-separated.}

\todo{
Most of the separated stuff
requires the modified join construction which we don't have yet.
}

%```agda
\agda{
is-separatedвҶҗis-local
  : вҲҖ {рқ“ҳ рқ“Ө рқ“Ҙ рқ“Ұ} {I : Type рқ“ҳ}
      {A : I вҶ’ Type рқ“Ө} {B : I вҶ’ Type рқ“Ҙ}
      (f : (i : I) вҶ’ A i вҶ’ B i)
      {X : Type рқ“Ұ}
    вҶ’ is-local f X
    вҶ’ is-separated (Local-SubU f _) X
is-separatedвҶҗis-local f loc x y = пјқ-is-local f loc
}
%```
}

\subtree[stt-007F]{
\title{Separated types and localisations}
\taxon{Theorem}

\p{Given a family of maps #{f_i : A_i \to B_i}, the separated
types with respect to localisation at #{f} are the #{\Sigma(f)}
local types. (Where #{\Sigma(-)} is the functorial action of
the suspension)}


\proof{
\p{We can construct the following commutative diagram:}
\quiver{
\begin{tikzcd}
	{\Sigma_{(x,y : X)} (x = y) ^ {B_i}} && {\Sigma_{(x,y:X)}(x=y)^{A_i}} \\
	\\
	{X^{\Sigma B_i}} && {X^{\Sigma A_i}}
	\arrow["{\textrm{total}((x=y)^f)}", from=1-1, to=1-3]
	\arrow["\sim"', from=1-1, to=3-1]
	\arrow["\sim", from=1-3, to=3-3]
	\arrow["{X^{\Sigma f}}"', from=3-1, to=3-3]
\end{tikzcd}
}

\p{It then follows that precomposition by #{f} at #{x = y} is an
equivalence iff precomposition by #{\Sigma(f)} is at #{X}.}
}

%```agda
\agda{
module _ {рқ“ҳ рқ“Ө рқ“Ҙ} {I : Type рқ“ҳ}
         {A : I вҶ’ Type рқ“Ө} {B : I вҶ’ Type рқ“Ҙ}
         (f : (i : I) вҶ’ A i вҶ’ B i) where

  private
    ОЈf : (i : I) вҶ’ Susp (A i) вҶ’ Susp (B i)
    ОЈf i = Susp-map (f i)

  is-separatedвҮ”is-ОЈ-local
    : вҲҖ {рқ“Ө} {X : Type рқ“Ө}
    вҶ’ is-local ОЈf X
    вҮ” is-separated (Local-SubU f рқ“Ө) X
  is-separatedвҮ”is-ОЈ-local {X = X}
    = ( (О» loc x y i вҶ’ topmapвҮ”botmap-is-equiv i .snd (loc i) (x , y))
       , О» sep i вҶ’ topmapвҮ”botmap-is-equiv i .fst О» (x , y) вҶ’ sep x y i) where
    module _ i where
      topmap : вҲҖ (ab : X Г— X)
          вҶ’ (B i вҶ’ ab .fst пјқ ab .snd)
          вҶ’ (A i вҶ’ ab .fst пјқ ab .snd)
      topmap (x , y) = precomp (x пјқ y) (f i)

      eqvl : (ОЈ[ ab вҲ¶ (X Г— X)] (B i вҶ’ ab .fst пјқ ab .snd))
           вүғ (Susp (B i) вҶ’ X)
      eqvl = ОЈ-assoc вҲҷвүғ (Susp-UPвүғ eвҒ»В№)

      eqvr : (Susp (A i) вҶ’ X)
           вүғ (ОЈ[ ab вҲ¶ (X Г— X)] (A i вҶ’ ab .fst пјқ ab .snd))
      eqvr = Susp-UPвүғ вҲҷвүғ ОЈ-assoc eвҒ»В№

      botmap : (Susp (B i) вҶ’ X) вҶ’ (Susp (A i) вҶ’ X)
      botmap = precomp X (ОЈf i)


      F : Arrow-map (total-map topmap) botmap
      F .Arrow-map.top = eqvl ._вүғ_.fwd
      F .Arrow-map.bot = _вүғ_.bwd eqvr
      F .Arrow-map.comm ((x , y) , H) = funextвҶ’ (pushout-ind _
        (mk-coconeбөҲ
          ~refl
          ~refl
          О» a вҶ’ IdбөҲ-funcвҶҗSquare (glue a) refl refl (mk-square
                 ( вҲҷ-reflr _
                 вҲҷ pushout-rec-apОІ a
                 вҲҷ sym (ap-вҲҳ
                        (pushout-rec (mk-cocone (О» _ вҶ’ x) (О» _ вҶ’ y) H))
                        (pushout-rec (mk-cocone О№вӮҒ О№вӮӮ (glue вҲҳ f i)))
                        (glue a)
                        вҲҷ ap (ap _) (pushout-rec-apОІ a)
                        вҲҷ pushout-rec-apОІ (f i a))))))

      F-is-equiv : is-Arrow-equiv F
      F-is-equiv = ( eqvl ._вүғ_.has-is-eqv
                   , is-equivвҒ»В№ (eqvr ._вүғ_.has-is-eqv))

      topmapвҮ”botmap-is-equiv
        : is-fibrewise-equiv topmap вҮ” is-equiv botmap
      topmapвҮ”botmap-is-equiv
        =    (fibrewiseвҮ”total-is-equiv вҮ”вҒ»В№)
          вҲҷвҮ” topвҮ”bot-is-equivвҶҗArrow-equiv F F-is-equiv

  is-separatedвҶҗis-ОЈ-local
    : вҲҖ {рқ“Ө} {X : Type рқ“Ө}
    вҶ’ is-local ОЈf X
    вҶ’ is-separated (Local-SubU f рқ“Ө) X
  is-separatedвҶҗis-ОЈ-local = is-separatedвҮ”is-ОЈ-local .fst

  is-ОЈ-localвҶҗis-separated
    : вҲҖ {рқ“Ө} {X : Type рқ“Ө}
    вҶ’ is-separated (Local-SubU f рқ“Ө) X
    вҶ’ is-local ОЈf X
  is-ОЈ-localвҶҗis-separated = is-separatedвҮ”is-ОЈ-local .snd
}
%```

\p{Becuase #{\Sigma(-)} [preserves](stt-007J) the unit type, we can
easily derive that #{A}-null separated types are #{\Sigma A}-null.}

%```agda
\agda{
module _ {рқ“ҳ рқ“Ө} {I : Type рқ“ҳ} (A : I вҶ’ Type рқ“Ө) where
  is-separatedвҶҗis-ОЈ-null
    : вҲҖ {рқ“Ө} {X : Type рқ“Ө}
      вҶ’ is-null (Susp вҲҳ A) X
      вҶ’ is-separated (Null-SubU A рқ“Ө) X
  is-separatedвҶҗis-ОЈ-null null
    = is-separated-SubU-equiv (Local-SubU !A _) (Null-SubU A _)
        Nullвүғ!Local
        (is-separatedвҶҗis-ОЈ-local !A
          (is-local-equiv
            (О» i вҶ’ Susp-!вҒ»В№)
            (О» _ вҶ’ ArrowвҒ»В№-is-equiv Susp-! Susp-!-is-equiv)
            (is-localвҶҗis-null null))) where
      !A : (i : I) вҶ’ A i вҶ’ рқҹҷ
      !A i _ = tt

  is-ОЈ-nullвҶҗis-separated
    : вҲҖ {рқ“Ө} {X : Type рқ“Ө}
      вҶ’ is-separated (Null-SubU A рқ“Ө) X
      вҶ’ is-null (Susp вҲҳ A) X
  is-ОЈ-nullвҶҗis-separated sep
    = is-nullвҶҗis-local
       (is-local-equiv
         (О» _ вҶ’ Susp-!)
         (О» _ вҶ’ Susp-!-is-equiv)
         (is-ОЈ-localвҶҗis-separated
           (О» _ _ вҶ’ tt)
           (is-separated-SubU-equiv
             (Null-SubU A _)
             (Local-SubU (О» i _ вҶ’ tt) _)
             (_вҮ”вҒ»В№ вҲҳ Nullвүғ!Local)
             sep)))
}
%```
}

\subtree[stt-007H]{
\title{Iterated separation}
\taxon{Definition}

\p{Because the separated types give a (reflective) subuniverse for
each (reflective) subuniverse, we can consider the result of
repeatedly applying separation.
}

%```agda
\agda{
opaque
  is-n-separated : вҲҖ {рқ“Ө рқ“Ұ} (S : SubU рқ“Ө рқ“Ұ)
                   вҶ’ (n : в„•) вҶ’ Type рқ“Ө
                   вҶ’ Type (рқ“Ө вҠ” рқ“Ұ)
  is-n-separated {рқ“Ө} S zero A = ULift рқ“Ө (A вҲҲ S)
  is-n-separated S (suc n) A
    = вҲҖ (x y : A) вҶ’ is-n-separated S n (x пјқ y)

opaque
  unfolding is-n-separated
  mk-is-separated : вҲҖ {рқ“Ө рқ“Ұ} (S : SubU рқ“Ө рқ“Ұ)
                   вҶ’ (n : в„•) (A : Type рқ“Ө)
                   вҶ’ is-n-separated (separated-SubU S) n A
                   вҶ’ is-n-separated S (suc n) A
  mk-is-separated S zero A (mk-lift sep) x y = mk-lift (sep x y)
  mk-is-separated S (suc n) A sep a b
    = mk-is-separated S n (a пјқ b) (sep a b)


  is-n-separated-is-prop
    : вҲҖ {рқ“Ө рқ“Ұ} (S : SubU рқ“Ө рқ“Ұ)
        (n : в„•) (A : Type рқ“Ө)
      вҶ’ is-prop (is-n-separated S n A)
  is-n-separated-is-prop S zero A
    = is-prop-ULift (S .Subtype.has-is-subtype A)
  is-n-separated-is-prop S (suc n) A
    = is-prop-О  О»
       a вҶ’ is-prop-О  О»
         b вҶ’ is-n-separated-is-prop S n (a пјқ b)

  equiv-n-separated
    : вҲҖ {рқ“Ө рқ“Ҙ Оұ} (S : GSU Оұ)
        (n : в„•)
        {A : Type рқ“Ө} {B : Type рқ“Ҙ}
      вҶ’ A вүғ B
      вҶ’ is-n-separated (SubUвҶҗglobal S) n A
      вҶ’ is-n-separated (SubUвҶҗglobal S) n B
  equiv-n-separated S zero eq (mk-lift sep)
    = mk-lift (S .GSU.вҲҲSвҶҗequiv eq sep)
  equiv-n-separated S (suc n) eq sep b b'
    = equiv-n-separated S n
        (mkвүғ _ (is-embeddingвҶҗis-equiv
                   (is-equivвҒ»В№ has-is-eqv)) eвҒ»В№)
        (sep (bwd b) (bwd b')) where open _вүғ_ eq


n-separated-SubU : вҲҖ {рқ“Ө рқ“Ұ} (S : SubU рқ“Ө рқ“Ұ)
                   вҶ’ (n : в„•) вҶ’ SubU рқ“Ө (рқ“Ө вҠ” рқ“Ұ)
n-separated-SubU S n .Subtype.family = is-n-separated S n
n-separated-SubU S n .Subtype.has-is-subtype
  = is-n-separated-is-prop S n


n-separated-GSU : вҲҖ {Оұ} (S : GSU Оұ)
                  вҶ’ (n : в„•) вҶ’ GSU (О» рқ“Ө вҶ’ рқ“Ө вҠ” Оұ рқ“Ө)
n-separated-GSU S n .GSU.S = n-separated-SubU (SubUвҶҗglobal S) n
n-separated-GSU S n .GSU.вҲҲSвҶҗequiv = equiv-n-separated S n
}
%```
}

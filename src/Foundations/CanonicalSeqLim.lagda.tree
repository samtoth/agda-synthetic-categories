\subtree[fre-2124]{
\date{2026-03-11}
\author{fredrikbakke}
\title{The canonical sequential limit of a tower}
\taxon{Definition}

\p{
Given a [tower](fre-2120) #{A} of types
##{\cdots \to A_{n+1} \xrightarrow{f_n} A_n \to \cdots \xrightarrow{f_0} A_0,}
the canonical sequential limit of #{A}, #{\lim A}, is given by the type of sequences
of elements #{a_i : A_i} such that #{a_i = f_i(a_{i+1})} for every #{i}.
}

%```agda
\agda{
module _ {ūĚď§ : Level} where

  Seq-lim-witness
    : (T : Tower ūĚď§)
    ‚Üí ((n : ‚Ąē) ‚Üí Tower.Point T n)
    ‚Üí Type ūĚď§
  Seq-lim-witness T a = (n : ‚Ąē) ‚Üí a n ÔľĚ Tower.decr T (a (suc n))

  Seq-lim : Tower ūĚď§ ‚Üí Type ūĚď§
  Seq-lim T = ő£[ a ‚ą∂ ((n : ‚Ąē) ‚Üí Tower.Point T n) ] Seq-lim-witness T a

  limit-point : (T : Tower ūĚď§) ‚Üí Seq-lim T ‚Üí Tower.Point T zero
  limit-point T (a , őĪ) = a zero

  shift-Tower : Tower ūĚď§ ‚Üí Tower ūĚď§
  shift-Tower T = mk-tower (Tower.Point T ‚ąė suc) (őĽ {n} ‚Üí Tower.decr T {suc n})

  Seq-lim-tail
    : (T : Tower ūĚď§)
    ‚Üí Seq-lim T
    ‚Üí Seq-lim (shift-Tower T)
  Seq-lim-tail T (a , őĪ) = (őĽ n ‚Üí a (suc n)) , (őĽ n ‚Üí őĪ (suc n))

  Seq-lim-shift-map
    : (T : Tower ūĚď§)
    ‚Üí ((n : ‚Ąē) ‚Üí Tower.Point T n)
    ‚Üí ((n : ‚Ąē) ‚Üí Tower.Point T n)
  Seq-lim-shift-map T a n = Tower.decr T (a (suc n))

}
%```
}

\subtree[fre-2125]{
\date{2026-03-11}
\author{fredrikbakke}
\title{Equality in sequential limits}
\taxon{Theorem}

\p{
Given a tower
##{\cdots \to A_{n+1} \xrightarrow{f_n} A_n \to \cdots \xrightarrow{f_0} A_0}
and two elements of its [canonical sequential limit](fre-2124), i.e., two sequences
of elements #{a} and #{b} equipped with equalities #{\alpha_i : f_i(a_{i+1}) = a_i}
and #{\beta_i : f_i(b_{i+1}) = b_i} respectively, then equality of #{(a , \alpha)}
and #{(b , \beta)} is equivalent to pointwise equality of #{a} and #{b},
#{p_i : a_i = b_i} together with a coherence

\quiver{
\begin{tikzcd}
  a_i && b_i \\
  \\
  f_i(a_{i+1}) && f_i(b_{i+1})
  \arrow[from=1-1, to=1-3, "p_i", equals]
  \arrow[from=1-1, to=3-1, "\alpha_i", equals]
  \arrow[from=1-3, to=3-3, "\beta_i", equals]
  \arrow[from=3-1, to=3-3, "\ap_{f_i}(p_i)", equals]
\end{tikzcd}
}
}

%```agda
\agda{
Seq-lim-htpy
  : {ūĚď§ : Level} (T : Tower ūĚď§)
  ‚Üí Seq-lim T ‚Üí Seq-lim T ‚Üí Type ūĚď§
Seq-lim-htpy T x y
  = ő£[ p ‚ą∂ fst x ~ fst y ]
      ((n : ‚Ąē)
        ‚Üí Square
            (p n)
            (ap (Tower.decr T) (p (suc n)))
            (snd x n)
            (snd y n))

module LimitWithFunExt (FE : FunExt-global) {ūĚď§ : Level} (T : Tower ūĚď§) where
  open WithFunExt-global FE

  Seq-lim-htpy‚ÜźId
    : {x y : Seq-lim T}
    ‚Üí x ÔľĚ y
    ‚Üí Seq-lim-htpy T x y
  Seq-lim-htpy‚ÜźId {x = x} refl = ~refl , (őĽ n ‚Üí Square-drop-j (snd x n))

  Seq-lim-htpy-is-torsorial
    : (x : Seq-lim T)
    ‚Üí is-singleton (ő£ (Seq-lim T) (Seq-lim-htpy T x))
  Seq-lim-htpy-is-torsorial x
    = is-singleton-structure‚Üźparts
        (htpy-is-torsorial FE (fst x))
        (fst x , ~refl)
        (is-single‚Üźequiv-to-single
          (ő£-ő†-swap‚ČÉ _ _)
          (Singleton-ő† FE őĽ n ‚Üí
            is-single‚Üźequiv-to-single
              (ő£-ap-‚ČÉ (őĽ q ‚Üí mk-square‚ČÉSquare))
              Sing'-is-singleton))

  Seq-lim-htpy‚ÜźId-is-equiv
    : {x y : Seq-lim T}
    ‚Üí is-equiv (Seq-lim-htpy‚ÜźId {x} {y})
  Seq-lim-htpy‚ÜźId-is-equiv {x} {y}
    = fundamental-Id
        (Seq-lim-htpy T x)
        (Seq-lim-htpy-is-torsorial x)
        (őĽ y ‚Üí Seq-lim-htpy‚ÜźId)
        (y)

  Id‚ČÉSeq-lim-htpy
    : {x y : Seq-lim T}
    ‚Üí (x ÔľĚ y) ‚ČÉ Seq-lim-htpy T x y
  Id‚ČÉSeq-lim-htpy = mk‚ČÉ Seq-lim-htpy‚ÜźId Seq-lim-htpy‚ÜźId-is-equiv

  Id‚ÜźSeq-lim-htpy
    : {x y : Seq-lim T}
    ‚Üí Seq-lim-htpy T x y
    ‚Üí x ÔľĚ y
  Id‚ÜźSeq-lim-htpy = is-equiv.bwd Seq-lim-htpy‚ÜźId-is-equiv

  ap-limit-point-Id‚ÜźSeq-lim-htpy
    : {x y : Seq-lim T}
    ‚Üí (h : Seq-lim-htpy T x y)
    ‚Üí ap (limit-point T) (Id‚ÜźSeq-lim-htpy h) ÔľĚ fst h zero
  ap-limit-point-Id‚ÜźSeq-lim-htpy {x} h
    = fst-htpy-zero (Id‚ÜźSeq-lim-htpy h)
    ‚ąô ap (őĽ k ‚Üí fst k zero) (is-equiv.őĶ Seq-lim-htpy‚ÜźId-is-equiv h)
    where
      fst-htpy-zero
        : {x y : Seq-lim T}
        ‚Üí (p : x ÔľĚ y)
        ‚Üí ap (limit-point T) p ÔľĚ fst (Seq-lim-htpy‚ÜźId p) zero
      fst-htpy-zero refl = refl
}
%```
}

\subtree[fre-2151]{
\date{2026-03-16}
\author{fredrikbakke}
\title{Sequential limits as equalisers}
\taxon{Theorem}

\p{
The canonical sequential limit of a [tower](fre-2120) #{T} is the
[equaliser](fre-2100) of the identity and the shift map
#{(a,n) \mapsto f_n(a_{n+1})} on the type of sequences
#{\prod_{(n : \mathbb{N})} A_n}.

\quiver{
\begin{tikzcd}
  \lim A_n && \prod_{(n : \mathbb{N})} A_n && \prod_{(n : \mathbb{N})} A_n
	\arrow["\id", from=1-3, to=1-5, shift left]
	\arrow["\textsf{shift}"', from=1-3, to=1-5, shift right]
	\arrow[from=1-1, to=1-3]
\end{tikzcd}
}
}

%```agda
\agda{
module LimitWithFunExt-equaliser (FE : FunExt-global) {ūĚď§ : Level} (T : Tower ūĚď§) where
  open WithFunExt-global FE

  Seq-lim-fork : Fork id (Seq-lim-shift-map T) (Seq-lim T)
  Seq-lim-fork = fst , (funext‚Üí ‚ąė snd)

  Seq-lim-equaliser-gap
    : Seq-lim T ‚Üí Equaliser id (Seq-lim-shift-map T)
  Seq-lim-equaliser-gap
    = Equaliser-gap id (Seq-lim-shift-map T) Seq-lim-fork

  Seq-lim-equaliser-gap-is-equiv
    : is-equiv (Seq-lim-equaliser-gap)
  Seq-lim-equaliser-gap-is-equiv = is-equiv‚Üźqiso qiso where
    qiso : quasi-iso Seq-lim-equaliser-gap
    qiso .fst (a , p) = (a , happly p)
    qiso .snd .fst (a , őĪ) = ő£-path‚Üí (refl , funext.őĶ őĪ)
    qiso .snd .snd (a , p) = ő£-path‚Üí (refl , funext.ő∑ p)

  Seq-lim‚ČÉEqualiser
    : Seq-lim T ‚ČÉ Equaliser id (Seq-lim-shift-map T)
  Seq-lim‚ČÉEqualiser
    = mk‚ČÉ Seq-lim-equaliser-gap Seq-lim-equaliser-gap-is-equiv
}
%```
}

\subtree[fre-2152]{
\date{2026-03-16}
\author{fredrikbakke}
\title{Sequential limits as pullbacks}
\taxon{Theorem}

\p{
The canonical sequential limit of a [tower](fre-2120) #{T} is the
[pullback](fre-200B) of the diagonal
#{\Delta : \prod_{(n : \mathbb{N})} A_n \to (\prod_{(n : \mathbb{N})} A_n)^2}
and the pairing
#{({\id},\textsf{shift}) : \prod_{(n : \mathbb{N})} A_n \to (\prod_{(n : \mathbb{N})} A_n)^2}
of the identity with the [shift map](fre-2124)
#{(a,n) \mapsto f_n(a_{n+1})}.

\quiver{
\begin{tikzcd}
  {\lim A_n} && {\prod_{(n : \mathbb{N})} A_n} \\
  \\
  {\prod_{(n : \mathbb{N})} A_n} && {(\prod_{(n : \mathbb{N})} A_n)^2}
	\arrow["{\pi_1}", from=1-1, to=1-3]
	\arrow["{\pi_2}"', from=1-1, to=3-1]
	\arrow["\Delta", from=1-3, to=3-3]
	\arrow["{(\id, \textsf{shift})}"', from=3-1, to=3-3]
	\arrow["\lrcorner" very near start, draw=none, from=1-1, to=3-3]
\end{tikzcd}
}
}

\p{
The pullback presentation of sequential limits is derived from the
[equaliser presentation](fre-2151) via the general fact that
[equalisers are pullbacks](fre-2102).
}

%```agda
\agda{
module LimitWithFunExt-pullback (FE : FunExt-global) where
  open WithFunExt-global FE
  open LimitWithFunExt-equaliser FE

  module _ {ūĚď§} (T : Tower ūĚď§) where

    Seq-lim‚ČÉPullback
      : Seq-lim T
      ‚ČÉ Pullback
          (őĽ b ‚Üí (b , b))
          (őĽ a ‚Üí (a , Seq-lim-shift-map T a))
    Seq-lim‚ČÉPullback
      = Seq-lim‚ČÉEqualiser T ‚ąô‚ČÉ Equaliser‚ČÉPullback-diagonal
}
%```
}

\subtree[tot-03SD]{
\title{Fibred products}
\taxon{Definition}

%```agda
\agda{
record Bi-fam 𝓤 𝓥 𝓦 : Type (lsuc (𝓤 ⊔ 𝓥 ⊔ 𝓦)) where
  field
    Centre : Type 𝓤
    Left : Centre → Type 𝓥
    Right : Centre → Type 𝓦

fibred-product : ∀ {𝓤 𝓥 𝓦} → Bi-fam 𝓤 𝓥 𝓦 → Type (𝓤 ⊔ 𝓥 ⊔ 𝓦)
fibred-product fc
  = Σ[ a ∶ fc .Bi-fam.Centre ]
      (fc .Bi-fam.Left a × fc .Bi-fam.Right a)

fibred-product-path
  : ∀ {𝓤 𝓥 𝓦} → (X : Bi-fam 𝓤 𝓥 𝓦)
    → fibred-product X → fibred-product X → Type (𝓤 ⊔ 𝓥 ⊔ 𝓦)
fibred-product-path X (a , b , c) (a' , b' , c')
  = Σ[ p ∶ a ＝ a' ]
    ( (b ＝[ ap (Bi-fam.Left X) p ] b')
    ×
      (c ＝[ ap (Bi-fam.Right X) p ] c')
    )

fibred-product-path-refl
  : ∀ {𝓤 𝓥 𝓦} → (X : Bi-fam 𝓤 𝓥 𝓦)
    → (x : fibred-product X) → fibred-product-path X x x
fibred-product-path-refl X x = (refl , refl , refl)

fibred-product-path←Id
  : ∀ {𝓤 𝓥 𝓦} → (X : Bi-fam 𝓤 𝓥 𝓦)
    → {x y : fibred-product X} → (p : x ＝ y)
    → fibred-product-path X x y
fibred-product-path←Id X refl = fibred-product-path-refl X _

opaque
  fibred-product-path-is-torsorial
    : ∀ {𝓤 𝓥 𝓦} → (X : Bi-fam 𝓤 𝓥 𝓦)
      → (x : fibred-product X)
      → is-singleton (Σ _ (fibred-product-path X x))
  fibred-product-path-is-torsorial X x
    = is-singleton-structure←parts
        Sing-is-singleton
        (_ , refl)
        (is-singleton-structure←parts
          Sing-is-singleton
          (_ , refl)
          Sing-is-singleton)

opaque
  fibred-product-path←Id-is-equiv
    : ∀ {𝓤 𝓥 𝓦} → (X : Bi-fam 𝓤 𝓥 𝓦)
      → {x y : fibred-product X}
      → is-equiv (fibred-product-path←Id X {x = x} {y})
  fibred-product-path←Id-is-equiv X {x} {y}
    = fundamental-Id _
        (fibred-product-path-is-torsorial X x)
        (λ _ → fibred-product-path←Id X)
        y

fibred-product-path→
    : ∀ {𝓤 𝓥 𝓦} → (X : Bi-fam 𝓤 𝓥 𝓦)
      → {x y : fibred-product X}
      → fibred-product-path X x y → x ＝ y
fibred-product-path→ X = is-equiv.bwd (fibred-product-path←Id-is-equiv X)

record Bi-fam-map {𝓤 𝓥 𝓦 𝓜 𝓝 𝓛}
                      (S : Bi-fam 𝓤 𝓥 𝓦) (T : Bi-fam 𝓜 𝓝 𝓛)
                      : Type (𝓤 ⊔ 𝓥 ⊔ 𝓦 ⊔ 𝓜 ⊔ 𝓝 ⊔ 𝓛) where
  module S = Bi-fam S
  module T = Bi-fam T
  field
    h₂ : S.Centre → T.Centre
    h₁ : ∀ c → S.Left c → T.Left (h₂ c)
    h₃ : ∀ c → S.Right c → T.Right (h₂ c)

Bi-fam-map-is-equiv
  : ∀ {𝓤 𝓥 𝓦 𝓜 𝓝 𝓛} {S : Bi-fam 𝓤 𝓥 𝓦} {T : Bi-fam 𝓜 𝓝 𝓛}
      (F : Bi-fam-map S T) → Type (𝓤 ⊔ 𝓥 ⊔ 𝓦 ⊔ 𝓜 ⊔ 𝓝 ⊔ 𝓛)
Bi-fam-map-is-equiv F = is-equiv h₂ × is-fibrewise-equiv h₁ × is-fibrewise-equiv h₃
  where open Bi-fam-map F


fibred-product₁
  : ∀ {𝓤 𝓥 𝓦 𝓜 𝓝 𝓛} {S : Bi-fam 𝓤 𝓥 𝓦} {T : Bi-fam 𝓜 𝓝 𝓛}
    → Bi-fam-map S T → fibred-product S → fibred-product T
fibred-product₁ F = map-Σ h₂ λ c → (h₁ c ⊗ h₃ c)
  where open Bi-fam-map F

fibred-product₁-is-equiv
  : ∀ {𝓤 𝓥 𝓦 𝓜 𝓝 𝓛} {S : Bi-fam 𝓤 𝓥 𝓦} {T : Bi-fam 𝓜 𝓝 𝓛}
    → (F : Bi-fam-map S T)
    → Bi-fam-map-is-equiv F
    → is-equiv (fibred-product₁ F)
fibred-product₁-is-equiv F (ec , ea , eb)
  = map-Σ-is-equiv ec λ c → ⊗-is-equiv (ea c) (eb c)

pullback-fam≃
  : ∀ {𝓤 𝓥 𝓦 𝓜 𝓝 𝓛} {S : Bi-fam 𝓤 𝓥 𝓦} {T : Bi-fam 𝓜 𝓝 𝓛}
    → Σ (Bi-fam-map S T) Bi-fam-map-is-equiv
    → fibred-product S ≃ fibred-product T
pullback-fam≃ (F , Fe) = mk≃ (fibred-product₁ F) (fibred-product₁-is-equiv _ Fe)

-- TODO: Naming wrong!!
-- straighten-cospan-fam : ∀ {𝓤 𝓥 𝓦} → Bi-fam 𝓤 𝓥 𝓦 → Cospan 𝓤 (𝓤 ⊔ 𝓥) (𝓤 ⊔ 𝓦)
-- straighten-cospan-fam A .Cospan.Centre = A .Bi-fam.Centre
-- straighten-cospan-fam A .Cospan.Left = Σ _ (A .Bi-fam.Left)
-- straighten-cospan-fam A .Cospan.left = fst
-- straighten-cospan-fam A .Cospan.Right = Σ _ (A .Bi-fam.Right)
-- straighten-cospan-fam A .Cospan.right = fst

-- hor-unstraighten-cospan
--   : ∀ {𝓤 𝓥 𝓦} → Cospan 𝓤 𝓥 𝓦 → Bi-fam 𝓤 (𝓤 ⊔ 𝓥) (𝓤 ⊔ 𝓦)
-- unstraighten-cospan S .Bi-fam.Centre = S .Cospan.Centre
-- unstraighten-cospan S .Bi-fam.Left = fibre (S .Cospan.left)
-- unstraighten-cospan S .Bi-fam.Right = fibre (S .Cospan.right)

-- hor-straighten-unstr-cospan : ∀ {𝓤 𝓥 𝓦} {S : Cospan 𝓤 𝓥 𝓦}
--          → Σ (Cospan-map (straighten-cospan-fam (unstraighten-cospan S)) S)
--              is-cospan-equiv
-- straighten-unstr-cospan .fst = mk-cospan-map (total←total-fibre _) id (total←total-fibre _)
--                             (λ {(_ , _ , refl) → refl}) λ {(_ , _ , refl) → refl}
-- straighten-unstr-cospan .snd = ( total≃total-fibre _ ._≃_.has-is-eqv
--               , id-is-equiv
--               , total≃total-fibre _ ._≃_.has-is-eqv)

-- unstraighten-pullback
--   : ∀ {𝓤 𝓥 𝓦} (F : Cospan 𝓤 𝓥 𝓦)
--     → fibred-product (unstraighten-cospan F)
--     → Pullback-of-cospan F
-- unstraighten-pullback F (c , (l , p) , (r , q)) = (l , r , p ∙ sym q)

-- unstraighten-pullback-is-equiv
--   : ∀ {𝓤 𝓥 𝓦} (F : Cospan 𝓤 𝓥 𝓦)
--     → is-equiv (unstraighten-pullback F)
-- unstraighten-pullback-is-equiv F = is-equiv←qiso
--   ( (λ x → _ , (x .pb.π₁ , x .pb.filler) , (x .pb.π₂ , refl))
--   , (λ where (c , (l , p) , (r , refl)) → fibred-product-path→ _
--                                             (refl
--                                             , fibre-path→

\subtree[stt-00DI]{
\taxon{Lemma}

\p{The map #{\Delta^2 \to ‚ßÖ+^{\Delta^1} 1} is a Segal equivalence.}

\proof{
\p{By associativity of pushouts, #{‚ßÖ +^{\Delta^1} 1} is equivalently
#{X = \Delta^2 +^{\Delta^1} (\Delta^2 +^{\Delta^1} 1)}, where we call the
right hand component #{\Delta^2 +^{\Delta^1} 1} [the walking homotopy](stt-00DK).
By the universal property of pushouts, then #{A^X} is equivalently the pullback
of #{A^{\Delta^2}} with #{A^{\Delta_{\sim}}} along the diagonal. But since
#{A} is Segal, homotopies form an identity system over morphisms, and we
can contract away singletons to get an equivalence to the pullback of
#{A^{\Delta^2}} with the source of the homotopy. So we can contract away
singletons once more to get that the map #{A^{\Delta^2} \toeq A^X} which
picks out the lower right simplex is an equivalence.
}
}

%```agda
\agda{
‚ßÖ-degen-top : Type ūĚďė
‚ßÖ-degen-top = Pushout {A = őĒ¬Ļ} {B = ‚ßÖ} (őĻ‚āā ‚ąė (_, i0)) !

‚ßÖ-degen' : Pushout őĒ¬≤-diagonal src-őĒ~ ‚Üí ‚ßÖ-degen-top
‚ßÖ-degen' = Pushout-assoc‚Üí őĒ¬≤-diagonal őĒ¬≤-diagonal (_, i0) !

‚ßÖ-degen‚ÜźőĒ¬≤ : őĒ¬≤ ‚Üí ‚ßÖ-degen-top
‚ßÖ-degen‚ÜźőĒ¬≤ = őĻ‚āĀ ‚ąė őĻ‚āĀ

_ : ‚ąÄ {ūĚď§} {A : Type ūĚď§}
     ‚Üí precomp A ‚ßÖ-degen‚ÜźőĒ¬≤
       ~ fst ‚ąė _‚ČÖ_.fwd cocone-repr‚ČÖ ‚ąė cocone-map _ pushout ‚ąė precomp A ‚ßÖ-degen'
_ = ~refl

opaque
  ‚ßÖ-degen‚ÜźőĒ¬≤-is-segal-equiv : is-segal-equiv ‚ßÖ-degen‚ÜźőĒ¬≤
  ‚ßÖ-degen‚ÜźőĒ¬≤-is-segal-equiv {Q = Q} qpc
    = is-equiv-‚ąė
        {f = fst}
        {_‚ČÖ_.fwd cocone-repr‚ČÖ ‚ąė cocone-map _ pushout ‚ąė precomp Q ‚ßÖ-degen'}
        (singleton-fst-is-equiv
          (őĽ a ‚Üí
            is-single‚Üźequiv-to-single
              ( (ő£-ap-‚ČÉ-fst {B = őĽ f ‚Üí a ‚ąė őĒ¬≤-diagonal ~ f}
                          (mk‚ČÉ _ (src-is-segal-equiv qpc))
                           e‚ĀĽ¬Ļ) )
              (SingS-is-single _)))
        (is-equiv-‚ąė
          (_‚ČÉ_.has-is-eqv cocone-repr‚ČÉ)
          (is-equiv-‚ąė
            Pushout-is-pushoutŌČ
            (precomp-equiv
              (is-equiv‚Üźqiso
                (Pushout-assoc-is-equiv őĒ¬≤-diagonal őĒ¬≤-diagonal (_, i0) !)))))
}

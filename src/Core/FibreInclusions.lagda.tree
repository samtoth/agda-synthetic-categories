\subtree[tot-0016]{
\title{Equivalences of cospan bundles}
\taxon{Definition}

%```agda
\agda{
Cospan-bundle-equiv
  : вИА {рЭУ§ рЭУ• рЭУ¶ рЭУ§' рЭУ•' рЭУ¶' рЭУ§'' рЭУ•'' рЭУ¶''} (S : Cospan рЭУ§ рЭУ• рЭУ¶)
      (E : Cospan-bundle S рЭУ§' рЭУ•' рЭУ¶') (E' : Cospan-bundle S рЭУ§'' рЭУ•'' рЭУ¶'')
    вЖТ Type (рЭУ§ вКФ рЭУ• вКФ рЭУ¶ вКФ рЭУ§' вКФ рЭУ•' вКФ рЭУ¶' вКФ рЭУ¶'' вКФ рЭУ§'' вКФ рЭУ•'')
Cospan-bundle-equiv S (E , ѕА) (E' , ѕА')
  = ќ£[ e вИґ Cospan-equiv E E' ]
      Cospan-map-homotopy (cospan-map-compose ѕА' (e .fst)) ѕА

Cospan-bundle-equiv-components
  : вИА {рЭУ§ рЭУ• рЭУ¶ рЭУ§' рЭУ•' рЭУ¶' рЭУ§'' рЭУ•'' рЭУ¶''} (S : Cospan рЭУ§ рЭУ• рЭУ¶)
      (E : Cospan-bundle S рЭУ§' рЭУ•' рЭУ¶') (E' : Cospan-bundle S рЭУ§'' рЭУ•'' рЭУ¶'')
    вЖТ Type (рЭУ§ вКФ рЭУ• вКФ рЭУ¶ вКФ рЭУ§' вКФ рЭУ•' вКФ рЭУ¶' вКФ рЭУ¶'' вКФ рЭУ§'' вКФ рЭУ•'')
Cospan-bundle-equiv-components S (E , ѕА) (E' , ѕА')
  = ќ£[ eвВБ вИґ Bundle-equiv L L' ]
    ќ£[ eвВВ вИґ Bundle-equiv C C' ]
    ќ£[ eвВГ вИґ Bundle-equiv R R' ]
    ќ£[ KвВБ вИґ eвВВ .fst .fwd вИШ left E ~ left E' вИШ eвВБ .fst .fwd ]
    ќ£[ KвВВ вИґ eвВВ .fst .fwd вИШ right E ~ right E' вИШ eвВГ .fst .fwd ]
     (  ( (hвВВ ѕА' вЧВ KвВБ ~вИЩ H ѕА' вЦЄ eвВБ .fst .fwd) ~вИЩ left S вЧВ eвВБ .snd
        ~ eвВВ .snd вЦЄ left E ~вИЩ H ѕА)
     √Ч (  (hвВВ ѕА' вЧВ KвВВ ~вИЩ K ѕА' вЦЄ eвВГ .fst .fwd) ~вИЩ right S вЧВ eвВГ .snd
        ~ eвВВ .snd вЦЄ right E ~вИЩ K ѕА)) where
  open Cospan
  open Cospan-map
  open _вЙГ_
  L : Bundle (S .Left) _
  L = (E .Left , ѕА .hвВБ)
  L' : Bundle (S .Left) _
  L' = (E' .Left , ѕА' .hвВБ)

  C : Bundle (S .Centre) _
  C = (E .Centre , ѕА .hвВВ)
  C' : Bundle (S .Centre) _
  C' = (E' .Centre , ѕА' .hвВВ)

  R  : Bundle (S .Right) _
  R = (E .Right , ѕА .hвВГ)
  R'  : Bundle (Right S) _
  R' = (E' .Right , ѕА' .hвВГ)

opaque
  Cospan-bundle-equiv-is-torsorial
    : вИА {рЭУ§ рЭУ• рЭУ¶ рЭУ§' рЭУ•' рЭУ¶'} {S : Cospan рЭУ§ рЭУ• рЭУ¶}
        (E : Cospan-bundle S рЭУ§' рЭУ•' рЭУ¶')
      вЖТ is-singleton (ќ£ (Cospan-bundle S рЭУ§' рЭУ•' рЭУ¶') (Cospan-bundle-equiv S E))
  Cospan-bundle-equiv-is-torsorial {S = S} E
    = is-singleton-structureвЖРparts
        (SingS-is-single _)
        (_ , Cospan-idequiv _)
        (is-singleвЖРequiv-to-single
          (ќ£-ap-вЙГ (ќї a вЖТ coeвЙГ (ap (ќї a вЖТ Cospan-map-homotopy a (E .snd))
                                  (sym (ext! (cospan-map-compose-idr a))))))
          (SingS-is-single' (E .snd)))

Cospan-bundle-idequiv
  : вИА {рЭУ§ рЭУ• рЭУ¶ рЭУ§' рЭУ•' рЭУ¶'} {S : Cospan рЭУ§ рЭУ• рЭУ¶}
      (E : Cospan-bundle S рЭУ§' рЭУ•' рЭУ¶')
    вЖТ Cospan-bundle-equiv S E E
Cospan-bundle-idequiv (E , ѕА) = (Cospan-idequiv E , cospan-map-compose-idr ѕА)

Cospan-bundle-equivвЖРId
  : вИА {рЭУ§ рЭУ• рЭУ¶ рЭУ§' рЭУ•' рЭУ¶'} {S : Cospan рЭУ§ рЭУ• рЭУ¶} {E E' : Cospan-bundle S рЭУ§' рЭУ•' рЭУ¶'}
    вЖТ E пЉЭ E' вЖТ Cospan-bundle-equiv S E E'
Cospan-bundle-equivвЖРId refl = Cospan-bundle-idequiv _

Cospan-bundle-equivвЖРId-is-equiv
  : вИА {рЭУ§ рЭУ• рЭУ¶ рЭУ§' рЭУ•' рЭУ¶'} {S : Cospan рЭУ§ рЭУ• рЭУ¶} {E E' : Cospan-bundle S рЭУ§' рЭУ•' рЭУ¶'}
    вЖТ is-equiv (Cospan-bundle-equivвЖРId {E = E}{E'})
Cospan-bundle-equivвЖРId-is-equiv
  = fundamental-Id _ (Cospan-bundle-equiv-is-torsorial _)
                     (ќї _ вЖТ Cospan-bundle-equivвЖРId) _

instance
  Cospan-bundle-IdS
    : вИА {рЭУ§ рЭУ• рЭУ¶ рЭУ§' рЭУ•' рЭУ¶'} {S : Cospan рЭУ§ рЭУ• рЭУ¶}
      вЖТ Identity-system (Cospan-bundle S рЭУ§' рЭУ•' рЭУ¶') (рЭУ§ вКФ рЭУ• вКФ рЭУ¶ вКФ рЭУ§' вКФ рЭУ•' вКФ рЭУ¶')
  Cospan-bundle-IdS .Identity-system.IdS = Cospan-bundle-equiv _
  Cospan-bundle-IdS .Identity-system.IdSвЖРId = Cospan-bundle-equivвЖРId
  Cospan-bundle-IdS .Identity-system.has-is-ids _ _
    = Cospan-bundle-equivвЖРId-is-equiv

Cospan-bundle-equivвЖРcomponents
  : вИА {рЭУ§ рЭУ• рЭУ¶ рЭУ§' рЭУ•' рЭУ¶' рЭУ§'' рЭУ•'' рЭУ¶''} {S : Cospan рЭУ§ рЭУ• рЭУ¶}
      {E : Cospan-bundle S рЭУ§' рЭУ•' рЭУ¶'} {E' : Cospan-bundle S рЭУ§'' рЭУ•'' рЭУ¶''}
    вЖТ Cospan-bundle-equiv-components S E E' вЖТ Cospan-bundle-equiv S E E'
Cospan-bundle-equivвЖРcomponents ((e1 , H1) , (e2 , H2) , (e3 , H3) , (K1 , K2 , ќ±1 , ќ±2))
  = ( ( mk-cospan-map (e1 .fwd) (e2 .fwd) (e3 .fwd) K1 K2
      , (e1 .has-is-eqv , e2 .has-is-eqv , e3 .has-is-eqv))
    , (H1 , H2 , H3 , ќ±1 , ќ±2))
  where open _вЙГ_
}
%```
}

\subtree[tot-0043]{
\title{Striaghtening for cospans}
\taxon{Lemma}


%```agda
\agda{
straighten-cospan
  : вИА {рЭУ§ рЭУ• рЭУ¶ рЭУ§' рЭУ•' рЭУ¶'} вЖТ (B : Cospan рЭУ§ рЭУ• рЭУ¶)
    вЖТ Cospan-bundle B рЭУ§' рЭУ•' рЭУ¶' вЖТ CospanбµИ B (рЭУ§ вКФ рЭУ§') (рЭУ• вКФ рЭУ•') (рЭУ¶ вКФ рЭУ¶')
straighten-cospan B (E , p) = fibre-cospanбµИ p

unstraighten-cospan
  : вИА {рЭУ§ рЭУ• рЭУ¶ рЭУ§' рЭУ•' рЭУ¶'} (B : Cospan рЭУ§ рЭУ• рЭУ¶)
    вЖТ CospanбµИ B рЭУ§' рЭУ•' рЭУ¶' вЖТ Cospan-bundle B (рЭУ§ вКФ рЭУ§') (рЭУ• вКФ рЭУ•') (рЭУ¶ вКФ рЭУ¶')
unstraighten-cospan B E = (ќ£-cospan E , ѕА-cospanбµИ E)

unstraighten-straighten-cospan-equiv
  : вИА {рЭУ§ рЭУ• рЭУ¶ рЭУ§' рЭУ•' рЭУ¶'} {B : Cospan рЭУ§ рЭУ• рЭУ¶}
      (E : Cospan-bundle B рЭУ§' рЭУ•' рЭУ¶')
    вЖТ Cospan-bundle-equiv B
        (unstraighten-cospan _ (straighten-cospan _ E))
        E
unstraighten-straighten-cospan-equiv E
  = Cospan-bundle-equivвЖРcomponents x where
  x : Cospan-bundle-equiv-components _
        (unstraighten-cospan _ (straighten-cospan _ E)) E
  x .fst = unstraighten-straighten-bundle-equiv _
  x .snd .fst = unstraighten-straighten-bundle-equiv _
  x .snd .snd .fst = unstraighten-straighten-bundle-equiv _
  x .snd .snd .snd .fst = ~refl
  x .snd .snd .snd .snd .fst = ~refl
  x .snd .snd .snd .snd .snd .fst (a , b , p)
    = sym (вИЩ-reflr _ вИЩ ap (_вИЩ ap _ p) sym-sym)
  x .snd .snd .snd .snd .snd .snd (a , b , p)
    = sym (вИЩ-reflr _ вИЩ ap (_вИЩ ap _ p) sym-sym)

straighten-unstraighten-cospan-equiv
  : вИА {рЭУ§ рЭУ• рЭУ¶ рЭУ§' рЭУ•' рЭУ¶'} {B : Cospan рЭУ§ рЭУ• рЭУ¶}
      (E : CospanбµИ B рЭУ§' рЭУ•' рЭУ¶')
    вЖТ CospanбµИ-equiv B (straighten-cospan _ (unstraighten-cospan _ E)) E
straighten-unstraighten-cospan-equiv E .fst = fibre-straighten _
straighten-unstraighten-cospan-equiv E .snd .fst = fibre-straighten _
straighten-unstraighten-cospan-equiv E .snd .snd .fst l (_ , refl) = refl
straighten-unstraighten-cospan-equiv E .snd .snd .snd .fst = fibre-straighten _
straighten-unstraighten-cospan-equiv E .snd .snd .snd .snd _ (_ , refl) = refl

straighten-cospan-is-equiv
  : вИА {рЭУ§ рЭУ• рЭУ¶} {B : Cospan рЭУ§ рЭУ• рЭУ¶}
    вЖТ is-equiv (straighten-cospan {рЭУ§' = рЭУ§}{рЭУ•}{рЭУ¶} B)
straighten-cospan-is-equiv = is-equivвЖРqiso
  ( unstraighten-cospan _
  , (ext! вИШ unstraighten-straighten-cospan-equiv)
  , (ext! вИШ straighten-unstraighten-cospan-equiv))
}
%```
}

\subtree[tot-0HFN]{
%```agda
\agda{
pullback-cospanбµИ
  : вИА {рЭУ§ рЭУ• рЭУ¶ рЭУ§' рЭУ•' рЭУ¶'} {S : Cospan рЭУ§ рЭУ• рЭУ¶}
    вЖТ (C : CospanбµИ S рЭУ§' рЭУ•' рЭУ¶')
    вЖТ Pullback-of-cospan S вЖТ Type (рЭУ§' вКФ рЭУ•' вКФ рЭУ¶')
pullback-cospanбµИ C (l , r , p)
  = ќ£[ a вИґ LeftбµИ l ] ќ£[ b вИґ RightбµИ r ] (leftбµИ l a пЉЭ[ ap CentreбµИ p ] rightбµИ r b)
  where open CospanбµИ C

fibreбµИ-path
  : вИА {рЭУ§ рЭУ•} {A : Type рЭУ§} {B : Type рЭУ•} {f : A вЖТ B} {x y : B} (p : x пЉЭ y)
    вЖТ fibre f x вЖТ fibre f y вЖТ Type (рЭУ§ вКФ рЭУ•)
fibreбµИ-path {f = f} p x' y'
  = ќ£[ q вИґ (x' .fst пЉЭ y' .fst) ] (ap f q вИЩ y' .snd пЉЭ x' .snd вИЩ p)

lemma-fibreбµИ-path
  : вИА {рЭУ§ рЭУ•} {A : Type рЭУ§} {B : Type рЭУ•} {f : A вЖТ B} {x y : B} (p : x пЉЭ y)
      {x' : fibre f x} {y' : fibre f y}
    вЖТ (x' пЉЭ[ ap (fibre f) p ] y')
    вЖТ ќ£[ q вИґ (x' .fst пЉЭ y' .fst) ] (ap f q вИЩ y' .snd пЉЭ x' .snd вИЩ p)
lemma-fibreбµИ-path refl = total-map (ќї a вЖТ _вИЩ sym (вИЩ-reflr _)) вИШ fibre-pathвЖРId

lemma-fibreбµИ-path-is-equiv
  : вИА {рЭУ§ рЭУ•} {A : Type рЭУ§} {B : Type рЭУ•} {f : A вЖТ B} {x y : B} (p : x пЉЭ y)
      {x' : fibre f x} {y' : fibre f y}
    вЖТ is-equiv (lemma-fibreбµИ-path p {x'}{y'})
lemma-fibreбµИ-path-is-equiv refl
  = is-equiv-вИШ
      (is-total-equivвЖРis-fibrewise-equiv ќї a вЖТ вИЩ-is-equiv' (sym (вИЩ-reflr _)))
      (fibre-pathвЙГ ._вЙГ_.has-is-eqv)

-- LEMMA-I
--   : вИА {рЭУ§ рЭУ• рЭУ¶ рЭУ§' рЭУ•' рЭУ¶'} {S : Cospan рЭУ§ рЭУ• рЭУ¶} {T : Cospan рЭУ§' рЭУ•' рЭУ¶'}
--     вЖТ (F : Cospan-map S T)

\subtree[stt-00AT]{
\title{#{\mathcal{S}} is directed univalent}
\taxon{Theorem}

\p{We show that #{\mathcal{S}} is directed univalent. That is, arrows in
#{\mathcal{S}} correspond exactly to pairs of groupoids, together with a function
between them.}

\proof{
\p{We start by noting that there is a canonial map
from #{F : \mathcal{S}^{\Delta^1}} to #{F(0) \to F(1)} given by covariant
transport.}


\p{Now we give an inverse map:}

\agda{
module DUA
  вҰғ _ : вҲҖ {@вҷӯ рқ“Ө} {A : Type рқ“Ө} вҰғ _ : is-acov A вҰ„ вҶ’ (вҲҖ {i} вҶ’ is-acov (i пјқ i0 вҶ’ A)) вҰ„
  (non-triv : i1 пјқ i0 вҶ’ вҲ…)
  (@вҷӯ вҲҡбөҲ-is-prop : вҲҖ {@вҷӯ рқ“Ө рқ“Ҙ} {@вҷӯ О“ : Type рқ“Ө} (@вҷӯ A : (О”В№ вҶ’ О“) вҶ’ Type рқ“Ҙ)
                   вҶ’ (вҲҖ g вҶ’ is-prop (A g)) вҶ’ вҲҖ g вҶ’ is-prop (вҲҡбөҲ A g))
  (open Space)
  where
  open UIdS вҲҡбөҲ-is-prop

  tr-рқ“ўвҶҗhomotopy
    : вҲҖ {@вҷӯ рқ“Ө} (f g : О”В№ вҶ’ Space рқ“Ө) вҶ’ (H : вҲҖ i вҶ’ f i .Space.Carrier вүғ g i .Space.Carrier)
      вҶ’ H i1 ._вүғ_.fwd вҲҳ tr-рқ“ў f ~ tr-рқ“ў g вҲҳ H i0 ._вүғ_.fwd
  tr-рқ“ўвҶҗhomotopy f = IdSJ {a = f} _ ~refl


  Gl : вҲҖ {@вҷӯ рқ“Ө} (A B : Space (рқ“ҳ вҠ” рқ“Ө)) (f : Carrier A вҶ’ Carrier B) вҶ’ (О”В№ вҶ’ Space (рқ“ҳ вҠ” рқ“Ө))
  Gl A B f i
    = mk-ufib (ОЈ[ b вҲ¶ Carrier B ] ((i пјқ i0) вҶ’ fibre f b)) auto! where
    instance
      _ : is-acov (Carrier A)
      _ = A .Carrier-is-afib
      _ : is-acov (Carrier B)
      _ = B .Carrier-is-afib

  GlОЈ
    : вҲҖ {@вҷӯ рқ“Ө} вҶ’ (ОЈ[ A B вҲ¶ Space (рқ“ҳ вҠ” рқ“Ө)] (Carrier A вҶ’ Carrier B))
      вҶ’ (О”В№ вҶ’ Space (рқ“ҳ вҠ” рқ“Ө))
  GlОЈ {рқ“Ө} x = Gl {рқ“Ө} (x .fst) (x .snd .fst) (x .snd .snd)

  Gl-0вүғ
    : вҲҖ {@вҷӯ рқ“Ө} (A B : Space (рқ“ҳ вҠ” рқ“Ө)) (f : Carrier A вҶ’ Carrier B)
      вҶ’ Gl A B f i0 .Carrier вүғ A .Carrier
  Gl-0вүғ A B f =
    mkвүғ (fst вҲҳ ev refl вҲҳ snd)
        (is-equiv-вҲҳ
          {f = totalвҶҗtotal-fibre f}
          {g = total-map (О» _ вҶ’ ev refl)}
          (totalвүғtotal-fibre _ ._вүғ_.fwd-is-equiv)
          (is-total-equivвҶҗis-fibrewise-equiv
            (О» _ вҶ’ sing-ev-is-equiv global-funext (mk-singl refl (J-set! _ refl)))))

  Gl-0
    : вҲҖ {@вҷӯ рқ“Ө} (A B : Space (рқ“ҳ вҠ” рқ“Ө)) (f : Carrier A вҶ’ Carrier B)
      вҶ’ Gl A B f i0 пјқ A
  Gl-0 A B f = ext! (Gl-0вүғ A B f)

  Gl-1вүғ
    : вҲҖ {@вҷӯ рқ“Ө} (A B : Space (рқ“ҳ вҠ” рқ“Ө)) (f : Carrier A вҶ’ Carrier B)
      вҶ’ Gl A B f i1 .Carrier вүғ B .Carrier
  Gl-1вүғ A B f
    = mkвүғ fst (singleton-fst-is-equiv О» _ вҶ’ О -is-single (О» x вҶ’ ВЎ (non-triv x)))

  Gl-1
    : вҲҖ {@вҷӯ рқ“Ө} (A B : Space (рқ“ҳ вҠ” рқ“Ө)) (f : Carrier A вҶ’ Carrier B)
      вҶ’ Gl A B f i1 пјқ B
  Gl-1 A B f = ext! (Gl-1вүғ A B f)

  Gl-hom
    : вҲҖ {@вҷӯ рқ“Ө} (A B : Space (рқ“ҳ вҠ” рқ“Ө)) (f : Carrier A вҶ’ Carrier B)
      вҶ’ Hom (Space (рқ“ҳ вҠ” рқ“Ө)) A B
  Gl-hom A B F = mk-hom (Gl A B F) (Gl-0 A B F) (Gl-1 A B F)
}

\p{In order to show this map is an inverse, it is useful to characterise
the paths in #{\Sigma_{A\ B}(A \to B)} and #{\textrm{Gl}(A,B,f)}:}

\closedScope{
\subtree[stt-00KW]{
\title{Paths in #{\mathcal{S}^вҶ’}}
\taxon{Lemma}

\agda{
  SpaceОЈ-Path
    : вҲҖ {@вҷӯ рқ“Ө} (x y : (ОЈ[ A B вҲ¶ Space рқ“Ө ] (Carrier A вҶ’ Carrier B)))
      вҶ’ Type рқ“Ө
  SpaceОЈ-Path (A , B , f) (X , Y , g)
    = ОЈ[ e вҲ¶ A .Carrier вүғ X .Carrier ] ОЈ[ p вҲ¶ B .Carrier вүғ Y .Carrier ]
        (p ._вүғ_.fwd вҲҳ f ~ g вҲҳ e ._вүғ_.fwd)

  SpaceОЈ-Path-refl
    : вҲҖ {@вҷӯ рқ“Ө} (x : (ОЈ[ A B вҲ¶ Space рқ“Ө ] (Carrier A вҶ’ Carrier B)))
      вҶ’ SpaceОЈ-Path x x
  SpaceОЈ-Path-refl x = (idвүғ , idвүғ , ~refl)

  opaque
    SpaceОЈ-Path-is-torsorial
      : вҲҖ {@вҷӯ рқ“Ө} (x : (ОЈ[ A B вҲ¶ Space рқ“Ө ] (Carrier A вҶ’ Carrier B)))
        вҶ’ is-singleton (ОЈ _ (SpaceОЈ-Path x))
    SpaceОЈ-Path-is-torsorial (A , B , f)
      = is-singleton-structureвҶҗparts
         (SingS-is-single A)
         (A , idвүғ)
         (is-singleton-structureвҶҗparts
           (SingS-is-single B)
           (B , idвүғ)
           (SingS-is-single f))

  instance
    SpaceОЈ-IdS
      : вҲҖ {@вҷӯ рқ“Ө} вҶ’ Identity-system ((ОЈ[ A B вҲ¶ Space рқ“Ө ] (Carrier A вҶ’ Carrier B))) рқ“Ө
    SpaceОЈ-IdS .Identity-system.IdS = SpaceОЈ-Path
    SpaceОЈ-IdS .Identity-system.IdSвҶҗId {a = A} refl = SpaceОЈ-Path-refl A
    SpaceОЈ-IdS .Identity-system.IdSвҶҗId-is-equiv x
      = fundamental-Id _ (SpaceОЈ-Path-is-torsorial x) _
}
}

\subtree[stt-00KF]{
\title{Paths in Glue types}
\taxon{Lemma}

\agda{
  Gl-path
    : вҲҖ {@вҷӯ рқ“Ө} {A B : Space (рқ“ҳ вҠ” рқ“Ө)} {f : Carrier A вҶ’ Carrier B} i
      вҶ’ Gl A B f i .Carrier вҶ’ Gl A B f i .Carrier вҶ’ Type (рқ“ҳ вҠ” рқ“Ө)
  Gl-path {f = f} i x y
    = ОЈ[ p вҲ¶ x .fst пјқ y .fst ]
       (вҲҖ pi вҶ’ ОЈ[ q вҲ¶ x .snd pi .fst пјқ y .snd pi .fst ]
                 (Square (x .snd pi .snd) (y .snd pi .snd) (ap f q) p))

  Gl-path-refl
    : вҲҖ {@вҷӯ рқ“Ө} {A B : Space (рқ“ҳ вҠ” рқ“Ө)} {f : Carrier A вҶ’ Carrier B} i
      вҶ’ (x : Gl A B f i .Carrier) вҶ’ Gl-path {A = A} {B} {f} i x x
  Gl-path-refl i x = (refl , (О» pi вҶ’ refl , Square-degen-hor _ _ refl))

  opaque
    Gl-path-is-torsorial
      : вҲҖ {@вҷӯ рқ“Ө} {A B : Space (рқ“ҳ вҠ” рқ“Ө)} {f : Carrier A вҶ’ Carrier B} i
        вҶ’ (x : Gl A B f i .Carrier) вҶ’ is-singleton (ОЈ _ (Gl-path {A = A} {B} {f} i x))
    Gl-path-is-torsorial i x
      = is-singleton-structureвҶҗparts
          Sing-is-singleton
          (_ , refl)
          (is-singleвҶҗequiv-to-single
            (ОЈ-О -swapвүғ _ О» p y вҶ’ ОЈ[ q вҲ¶ x .snd p .fst пјқ y .fst ]
                                   Square (x .snd p .snd) (y .snd) (ap _ q) refl)
            (О -is-single (О» where
              refl вҶ’ is-singleton-structureвҶҗparts
                       Sing-is-singleton
                       (_ , refl)
                       (Square-degen-hor-is-torsorial
                         (x .snd refl .snd)))))

  IdS-Gl
    : вҲҖ {@вҷӯ рқ“Ө} {A B : Space (рқ“ҳ вҠ” рқ“Ө)} {f : Carrier A вҶ’ Carrier B} i
      вҶ’ Identity-system (Gl A B f i .Carrier) (рқ“ҳ вҠ” рқ“Ө)
  IdS-Gl i .Identity-system.IdS = Gl-path i
  IdS-Gl {A = A} {B} {f} i .Identity-system.IdSвҶҗId refl
    = Gl-path-refl {A = A} {B} {f} i _
  IdS-Gl i .Identity-system.IdSвҶҗId-is-equiv a
    = fundamental-Id _ (Gl-path-is-torsorial i a) _

  Gl-pathвҶ’
    : вҲҖ {@вҷӯ рқ“Ө} {A B : Space (рқ“ҳ вҠ” рқ“Ө)} {f : Carrier A вҶ’ Carrier B} i
      вҶ’ {x y : Gl A B f i .Carrier} вҶ’ Gl-path {A = A} {B} {f} i x y вҶ’ x пјқ y
  Gl-pathвҶ’ {A = A} {B} i = IdвҶҗIdS вҰғ IdS-Gl {A = A} {B} i вҰ„

  opaque
    adj-Gl
      : вҲҖ {@вҷӯ рқ“Ө} {A B C : Space (рқ“ҳ вҠ” рқ“Ө)}
        вҶ’ (e : A .Carrier вүғ B .Carrier)
        вҶ’ {f : Carrier B вҶ’ Carrier C}
        вҶ’ (i : О”В№)
        вҶ’ Gl B C f i .Carrier вүғ Gl A C (f вҲҳ e ._вүғ_.fwd) i .Carrier
    adj-Gl {_}{A}{B}{C} e{f} i = IdSJ {a = A}
                               (О» ((B' , e)) вҶ’
                                  (f : B' .Carrier вҶ’ C .Carrier) вҶ’
                                  Gl B' C f i .Carrier вүғ Gl A C (f вҲҳ e ._вүғ_.fwd) i .Carrier)
                               (О» _ вҶ’ idвүғ) _ e f

    adj-Gl-homotopy
      : вҲҖ {@вҷӯ рқ“Ө} {A B : Space (рқ“ҳ вҠ” рқ“Ө)}
        вҶ’ (f g : Carrier A вҶ’ Carrier B)
        вҶ’ (H : f ~ g)
        вҶ’ (i : О”В№)
        вҶ’ Gl A B f i .Carrier вүғ Gl A B g i .Carrier
    adj-Gl-homotopy f = funext-J _ (О» _ вҶ’ idвүғ)
}
}
}

\p{We first show we have constructed a right inverse. Let #{A\ B : \mathcal{S}}
and #{f : A \to B}, write #{X := \textrm{Gl}(A,B,f) : \Delta^1 \to \mathcal{S}}.
We may easily verify that there are equivalences #{e_1 : X(0) \simeq A},
#{e_2 : X(1) \simeq B} and that these equivalences form a commuting square
#{e_1 X_* \sim F e_2}.}

\agda{
  induced-map
    : вҲҖ {@вҷӯ рқ“Ө} {A B : Space (рқ“ҳ вҠ” рқ“Ө)} (f : Carrier A вҶ’ Carrier B)
      вҶ’ Gl A B f i0 .Carrier вҶ’ Gl A B f i1 .Carrier
  induced-map f (b , p) = (b , ВЎ вҲҳ non-triv)

  tr-Gl-hom
    : вҲҖ {@вҷӯ рқ“Ө} {A B : Space (рқ“ҳ вҠ” рқ“Ө)} (f : Carrier A вҶ’ Carrier B)
      вҶ’ вҲҖ x вҶ’ HomбөҲ (Space.Carrier вҲҳ Gl A B f) x (induced-map {A = A} {B} f x)
  tr-Gl-hom f x .HomбөҲ.hom i = (x .fst , О» p вҶ’ x .snd refl)
  tr-Gl-hom f x .HomбөҲ.hom0 = ОЈ-pathвҶ’ (refl , (funextвҶ’ (J-set! _ refl)))
  tr-Gl-hom f x .HomбөҲ.hom1 = ОЈ-pathвҶ’ (refl , (funextвҶ’ (О» x вҶ’ ВЎ (non-triv x))))

  tr-Gl
    : вҲҖ {@вҷӯ рқ“Ө} {A B : Space (рқ“ҳ вҠ” рқ“Ө)} (f : Carrier A вҶ’ Carrier B)
      вҶ’ tr-рқ“ў (Gl A B f) ~ induced-map f
  tr-Gl f x = tr-рқ“ў-unique (Gl _ _ f) {F = induced-map f} x
                          (tr-Gl-hom f x)

  tr-Gl-lemma
    : вҲҖ {@вҷӯ рқ“Ө} {A B : Space (рқ“ҳ вҠ” рқ“Ө)} (f : Carrier A вҶ’ Carrier B)
      вҶ’ Gl-1вүғ A B f ._вүғ_.fwd вҲҳ tr-рқ“ў (Gl A B f) ~ f вҲҳ Gl-0вүғ A B f ._вүғ_.fwd
  tr-Gl-lemma f x@(b , p)
    = fst (tr-рқ“ў (Gl _ _ f) x)
    пјқвҹЁ ap fst (tr-Gl f x) вҹ©
      b
    пјқвҹЁ sym (p refl .snd) вҹ©
      (f вҲҳ _вүғ_.fwd (Gl-0вүғ _ _ f)) (b , p)
    вҲҺ

  opaque
    dua-section : вҲҖ {@вҷӯ рқ“Ө} x вҶ’ SpaceОЈ-Path {рқ“Ө вҠ” рқ“ҳ} (duaвҶ’ (GlОЈ {рқ“Ө} x)) x
    dua-section (A , B , f) .fst = Gl-0вүғ A B f
    dua-section (A , B , f) .snd .fst = Gl-1вүғ A B f
    dua-section (A , B , f) .snd .snd = tr-Gl-lemma f
}

\p{To show we have a left inverse, we make use of \ref{stt-00K6} so that given a
map #{f : \Delta^1 \to \mathcal{S}}, we can just give a fibrewise map
#{\alpha : F_i \to \textrm{Gl}(f(0),f(1),f_*)(i)} and show that #{\alpha} is an
equivalence when restricted to either endpoint. To construct this map we use
the fact that we can
[transport covariant families over inequalities in #{\Delta^1}](stt-00K3).
Finally, using the properties of covariant transport, it is not too challenging
to verify that this map is an equivalence at each endpoint.}

\agda{
  opaque
    dua-retractвҶ’ : вҲҖ {@вҷӯ рқ“Ө} f i вҶ’ f i .Carrier вҶ’ GlОЈ {рқ“Ө} (duaвҶ’ f) i .Carrier
    dua-retractвҶ’ f i x .fst =  coe-cov (Carrier вҲҳ f) (UFib-is-fib f) 1-top x
    dua-retractвҶ’ f i x .snd refl
      = (x , sym (happly (coe-cov-0вүӨ1 (Carrier вҲҳ f) (UFib-is-fib f) 1-top) x))

    dua-retract : вҲҖ {@вҷӯ рқ“Ө} f i вҶ’ f i .Carrier вүғ GlОЈ {рқ“Ө} (duaвҶ’ f) i .Carrier
    dua-retract f i ._вүғ_.fwd = dua-retractвҶ’ f i
    dua-retract f i ._вүғ_.fwd-is-equiv
      = Cov-Nat-is-equiv
          f (GlОЈ (duaвҶ’ f)) (dua-retractвҶ’ f)
          (вҲӮО”В№-UPвҶ’
            ( is-equivвҶҗqinv fr0
            , is-equivвҶҗqinv fr1))
          i where
      fr0 : quasi-inv (dua-retractвҶ’ f i0)
      fr0 .fst x = x .snd refl .fst
      fr0 .snd .fst = ~refl
      fr0 .snd .snd a = Gl-pathвҶ’ {A = f i0} {f i1} i0
        ( happly ( coe-cov-0вүӨ1 (Carrier вҲҳ f) (UFib-is-fib f) 1-top) (fr0 .fst a)
                 вҲҷ a .snd refl .snd
        , J-set! _
            ( refl
            , mk-square
                (sym'вҲҷ (happly
                         (coe-cov-0вүӨ1 (Carrier вҲҳ f) (UFib-is-fib f) 1-top) (a .snd refl .fst))
                         (a .snd refl .snd))))

      fr1 : quasi-inv (dua-retractвҶ’ f i1)
      fr1 .fst x = x .fst
      fr1 .snd .fst x = coe-cov-id (Carrier вҲҳ f) (UFib-is-fib f) _ x
      fr1 .snd .snd (a , b)
        = ОЈ-pathвҶ’
            ( (coe-cov-id (Carrier вҲҳ f) (UFib-is-fib f) _ a)
            , funextвҶ’ (О» x вҶ’ ВЎ (non-triv x)))

  dua : вҲҖ {@вҷӯ рқ“Ө} вҶ’ is-equiv (duaвҶ’ {рқ“Ө вҠ” рқ“ҳ})
  dua {рқ“Ө} = is-equivвҶҗqinv
    ( GlОЈ {рқ“Ө}
    , (О» a вҶ’ ext! (О» i вҶ’ dua-retract {рқ“Ө} a i eвҒ»В№))
    , (О» a вҶ’ ext! (dua-section a)))
}
}
}

\subtree[tot-SSEG]{
\title{The type of spaces is Segal}
\taxon{Theorem}
\date{2026-06-04}

\agda{
module рқ“ў-is-segal
  вҰғ _ : вҲҖ {@вҷӯ рқ“Ө} {A : Type рқ“Ө} вҰғ _ : is-acov A вҰ„ вҶ’ (вҲҖ {i} вҶ’ is-acov (i пјқ i0 вҶ’ A)) вҰ„
  (non-triv : i1 пјқ i0 вҶ’ вҲ…)
  (@вҷӯ вҲҡбөҲ-is-prop : вҲҖ {@вҷӯ рқ“Ө рқ“Ҙ} {@вҷӯ О“ : Type рқ“Ө} (@вҷӯ A : (О”В№ вҶ’ О“) вҶ’ Type рқ“Ҙ)
                   вҶ’ (вҲҖ g вҶ’ is-prop (A g)) вҶ’ вҲҖ g вҶ’ is-prop (вҲҡбөҲ A g))
  (open Space)
  (open DUA non-triv вҲҡбөҲ-is-prop)
  (open UIdS вҲҡбөҲ-is-prop)
  where

  module _
    {@вҷӯ рқ“Ө}
    (A B C : Space (рқ“ҳ вҠ” рқ“Ө))
    (F : A .Carrier вҶ’ B .Carrier)
    (G : B .Carrier вҶ’ C .Carrier)
    where

    GlО”ВІвӮҖ : О”В№ вҶ’ Space (рқ“ҳ вҠ” рқ“Ө)
    GlО”ВІвӮҖ = Gl A B F

    GlО”ВІвӮҒ : О”В№ вҶ’ О”В№ вҶ’ Space (рқ“ҳ вҠ” рқ“Ө)
    GlО”ВІвӮҒ i = Gl (GlО”ВІвӮҖ i) C (G вҲҳ fst вҲҳ coe-рқ“ў (Gl A B F) {i} {i1} auto!)

    GlО”ВІ : О”ВІ вҶ’ Space (рқ“ҳ вҠ” рқ“Ө)
    GlО”ВІ (i , j) = GlО”ВІвӮҒ i j

    GlО”ВІ-0вүӨ1 : О”В№ вҶ’ Space (рқ“ҳ вҠ” рқ“Ө)
    GlО”ВІ-0вүӨ1 = GlО”ВІ вҲҳ ОҙвӮӮВІ

    GlО”ВІ-1вүӨ2 : О”В№ вҶ’ Space (рқ“ҳ вҠ” рқ“Ө)
    GlО”ВІ-1вүӨ2 = GlО”ВІ вҲҳ ОҙвӮҖВІ

    GlО”ВІ-0вүғ : GlО”ВІ (i0 , i0) .Carrier вүғ A .Carrier
    GlО”ВІ-0вүғ = Gl-0вүғ (GlО”ВІвӮҖ i0) C _ вҲҷe Gl-0вүғ A B F

    GlО”ВІ-1вүғ : GlО”ВІ (i1 , i0) .Carrier вүғ B .Carrier
    GlО”ВІ-1вүғ = Gl-0вүғ (GlО”ВІвӮҖ i1) C _ вҲҷe Gl-1вүғ A B F

    GlО”ВІ-2вүғ : GlО”ВІ (i1 , i1) .Carrier вүғ C .Carrier
    GlО”ВІ-2вүғ = Gl-1вүғ (GlО”ВІвӮҖ i1) C _

    GlО”ВІ-0вүӨ1-is-GlвӮҖ : вҲҖ i вҶ’ GlО”ВІ-0вүӨ1 i .Space.Carrier вүғ GlО”ВІвӮҖ i .Space.Carrier
    GlО”ВІ-0вүӨ1-is-GlвӮҖ i = Gl-0вүғ (GlО”ВІвӮҖ i) C _

    tr-GlО”ВІ-0вүӨ1 : Arrow-map (tr-рқ“ў GlО”ВІ-0вүӨ1) F
    tr-GlО”ВІ-0вүӨ1 .Arrow-О .top = GlО”ВІ-0вүғ ._вүғ_.fwd
    tr-GlО”ВІ-0вүӨ1 .Arrow-О .bot = GlО”ВІ-1вүғ ._вүғ_.fwd
    tr-GlО”ВІ-0вүӨ1 .Arrow-О .comm x
      =  GlО”ВІ-1вүғ ._вүғ_.fwd (tr-рқ“ў GlО”ВІ-0вүӨ1 x)
      пјқвҹЁвҹ©
        Gl-1вүғ A B F ._вүғ_.fwd (Gl-0вүғ (GlО”ВІвӮҖ i1) C _ ._вүғ_.fwd (tr-рқ“ў GlО”ВІ-0вүӨ1 x))
      пјқвҹЁ ap (Gl-1вүғ A B F ._вүғ_.fwd) (tr-рқ“ўвҶҗhomotopy GlО”ВІ-0вүӨ1 GlО”ВІвӮҖ GlО”ВІ-0вүӨ1-is-GlвӮҖ x) вҹ©
        Gl-1вүғ A B F ._вүғ_.fwd (tr-рқ“ў (Gl A B F) (GlО”ВІ-0вүӨ1-is-GlвӮҖ i0 ._вүғ_.fwd x))
      пјқвҹЁ tr-Gl-lemma F (GlО”ВІ-0вүӨ1-is-GlвӮҖ i0 ._вүғ_.fwd x) вҹ©
        F (Arrow-О .top tr-GlО”ВІ-0вүӨ1 x) вҲҺ

    GlО”ВІ-1вүӨ2-is-GlG' : вҲҖ i вҶ’ GlО”ВІ-1вүӨ2 i .Space.Carrier вҶ’ Gl B C G i .Space.Carrier
    GlО”ВІ-1вүӨ2-is-GlG' i
      = total-map (О» a вҶ’ postcomp (i пјқ i0)
          (map-ОЈ
            (Gl-1вүғ A B F ._вүғ_.fwd)
            (О» a вҶ’ ap G (sym (ap fst (coe-рқ“ў-id (Gl A B F) 1-top a))) вҲҷ_)))

    GlО”ВІ-1вүӨ2-is-GlG : вҲҖ i вҶ’ GlО”ВІ-1вүӨ2 i .Space.Carrier вүғ Gl B C G i .Space.Carrier
    GlО”ВІ-1вүӨ2-is-GlG i ._вүғ_.fwd = GlО”ВІ-1вүӨ2-is-GlG' i
    GlО”ВІ-1вүӨ2-is-GlG i ._вүғ_.fwd-is-equiv
      = is-total-equivвҶҗis-fibrewise-equiv (О» a вҶ’
          postcomp-equiv
            (map-ОЈ-is-equiv
              (Gl-1вүғ A B F ._вүғ_.fwd-is-equiv)
              (О» a вҶ’ вҲҷ-is-equiv (ap G (sym (ap fst (coe-рқ“ў-id (Gl A B F) 1-top a)))))))

    tr-GlО”ВІ-1вүӨ2 : Arrow-map (tr-рқ“ў GlО”ВІ-1вүӨ2) G
    tr-GlО”ВІ-1вүӨ2 .Arrow-О .top = GlО”ВІ-1вүғ ._вүғ_.fwd
    tr-GlО”ВІ-1вүӨ2 .Arrow-О .bot = GlО”ВІ-2вүғ ._вүғ_.fwd
    tr-GlО”ВІ-1вүӨ2 .Arrow-О .comm x
      = GlО”ВІ-2вүғ ._вүғ_.fwd (tr-рқ“ў GlО”ВІ-1вүӨ2 x)
      пјқвҹЁвҹ©
        Gl-1вүғ (Gl A B F i1) C _ ._вүғ_.fwd (tr-рқ“ў GlО”ВІ-1вүӨ2 x)
      пјқвҹЁвҹ©
       Gl-1вүғ B C G ._вүғ_.fwd (GlО”ВІ-1вүӨ2-is-GlG i1 ._вүғ_.fwd (tr-рқ“ў GlО”ВІ-1вүӨ2 x))
     пјқвҹЁ ap (Gl-1вүғ B C G ._вүғ_.fwd) (tr-рқ“ўвҶҗhomotopy (GlО”ВІ-1вүӨ2) (Gl B C G) (GlО”ВІ-1вүӨ2-is-GlG) x) вҹ©
     Gl-1вүғ B C G ._вүғ_.fwd (tr-рқ“ў (Gl B C G) (GlО”ВІ-1вүӨ2-is-GlG i0 ._вүғ_.fwd x))
     пјқвҹЁ tr-Gl-lemma G (GlО”ВІ-1вүӨ2-is-GlG i0 ._вүғ_.fwd x) вҹ©
      G (Gl-0вүғ B C G ._вүғ_.fwd (GlО”ВІ-1вүӨ2-is-GlG i0 ._вүғ_.fwd x))
     пјқвҹЁвҹ©
       G (Gl-1вүғ A B F ._вүғ_.fwd (Gl-0вүғ (Gl A B F i1) C _ ._вүғ_.fwd x))
     пјқвҹЁвҹ©
        G (GlО”ВІ-1вүғ ._вүғ_.fwd x) вҲҺ

    GlО”ВІ-0вүӨ2 : О”В№ вҶ’ Space (рқ“ҳ вҠ” рқ“Ө)
    GlО”ВІ-0вүӨ2 = GlО”ВІ вҲҳ ОҙвӮҒВІ

  SpaceО”ВІОЈ : вҲҖ (@вҷӯ рқ“Ө) вҶ’ Type (lsuc (рқ“ҳ вҠ” рқ“Ө))
  SpaceО”ВІОЈ рқ“Ө = ОЈ[ A B C вҲ¶ Space рқ“Ө ]
               ОЈ[ F вҲ¶ (A .Carrier вҶ’ B .Carrier) ]
                 (B .Carrier вҶ’ C .Carrier)

  SpaceО”ВІОЈ-path : вҲҖ {@вҷӯ рқ“Ө} (x y : SpaceО”ВІОЈ рқ“Ө) вҶ’ Type рқ“Ө
  SpaceО”ВІОЈ-path (A , B , C , f , g) (X , Y , Z , h , j)
    = ОЈ[ eвӮҖ вҲ¶ A .Carrier вүғ X .Carrier ]
      ОЈ[ eвӮҒ вҲ¶ B .Carrier вүғ Y .Carrier ]
      ОЈ[ eвӮӮ вҲ¶ C .Carrier вүғ Z .Carrier ]
      ( (eвӮҒ ._вүғ_.fwd вҲҳ f ~ h вҲҳ eвӮҖ ._вүғ_.fwd)
      Г— (eвӮӮ ._вүғ_.fwd вҲҳ g ~ j вҲҳ eвӮҒ ._вүғ_.fwd))

  GlО”ВІОЈ : вҲҖ {@вҷӯ рқ“Ө} вҶ’ SpaceО”ВІОЈ (рқ“ҳ вҠ” рқ“Ө) вҶ’ О”ВІ вҶ’ Space (рқ“ҳ вҠ” рқ“Ө)
  GlО”ВІОЈ (A , B , C , F , G) = GlО”ВІ A B C F G

  module _
    {@вҷӯ рқ“Ө} (A : О”ВІ вҶ’ Space рқ“Ө)
    where

    duaО”ВІОЈ : SpaceО”ВІОЈ рқ“Ө
    duaО”ВІОЈ
      = ( A (i0 , i0)
        , A (i1 , i0)
        , A (i1 , i1)
        , tr-рқ“ў (A вҲҳ ОҙвӮӮВІ)
        , ( tr (Carrier вҲҳ A) О”ВІ-refl
          вҲҳ tr-рқ“ў (A вҲҳ ОҙвӮҖВІ)
          вҲҳ tr (Carrier вҲҳ A) О”ВІ-refl))

  lemma6 : вҲҖ {@вҷӯ рқ“Ө}
           (A : Space (рқ“ҳ вҠ” рқ“Ө)) (B : Space (рқ“ҳ вҠ” рқ“Ө))
           (C : Space (рқ“ҳ вҠ” рқ“Ө))
           (F
            : Space.Carrier A вҶ’
              Space.Carrier B)
           (G
            : Space.Carrier B вҶ’
              Space.Carrier C) вҶ’
         tr-рқ“ў (GlО”ВІ-1вүӨ2 A B C F G) вҲҳ (tr (Space.Carrier вҲҳ GlО”ВІ A B C F G) (О”ВІ-refl {p = 0-init}{q = 1-top}))
         ~
         tr (Space.Carrier вҲҳ GlО”ВІ A B C F G) (sym (О”ВІ-refl {p = 1-top} {q = вүӨ-refl})) вҲҳ tr-рқ“ў (GlО”ВІ-1вүӨ2 A B C F G)
  lemma6 A B C F G x = ap (tr-рқ“ў (GlО”ВІ-1вүӨ2 A B C F G)) {!sym !} вҲҷ {!!}


  duaО”ВІ-section
    : вҲҖ {@вҷӯ рқ“Ө} (a : SpaceО”ВІОЈ (рқ“ҳ вҠ” рқ“Ө)) вҶ’ SpaceО”ВІОЈ-path (duaО”ВІОЈ (GlО”ВІОЈ a)) a
  duaО”ВІ-section (A , B , C , F , G)
    = ( GlО”ВІ-0вүғ A B C F G
      , GlО”ВІ-1вүғ A B C F G
      , GlО”ВІ-2вүғ A B C F G
      , tr-GlО”ВІ-0вүӨ1 A B C F G .Arrow-map.comm
      , (О» x вҶ’
          (GlО”ВІ-2вүғ A B C F G ._вүғ_.fwd вҲҳ tr (Carrier вҲҳ GlО”ВІ A B C F G) О”ВІ-refl вҲҳ tr-рқ“ў (GlО”ВІ-1вүӨ2 A B C F G) вҲҳ tr (Carrier вҲҳ GlО”ВІ A B C F G) О”ВІ-refl) x
        пјқвҹЁ ap (GlО”ВІ-2вүғ A B C F G ._вүғ_.fwd)
               (unap-equiv (tr-is-equiv {B = Carrier вҲҳ GlО”ВІ A B C F G} (sym О”ВІ-refl))
                 ((trвҲҳtr-sym (О”ВІ-refl) (tr-рқ“ў (GlО”ВІ-1вүӨ2 A B C F G) (tr (Carrier вҲҳ GlО”ВІ A B C F G) О”ВІ-refl x))
                 вҲҷ  lemma6 A B C F G x))) вҹ©
          (GlО”ВІ-2вүғ A B C F G ._вүғ_.fwd вҲҳ tr-рқ“ў (GlО”ВІ-1вүӨ2 A B C F G)) x
        пјқвҹЁ tr-GlО”ВІ-1вүӨ2 A B C F G .Arrow-map.comm x вҹ©
          (G вҲҳ GlО”ВІ-1вүғ A B C F G ._вүғ_.fwd) x вҲҺ))

  duaО”ВІ-retractвҶ’
    : вҲҖ {@вҷӯ рқ“Ө} (F : О”ВІ вҶ’ Space (рқ“ҳ вҠ” рқ“Ө)) (ij : О”ВІ)
      вҶ’ F ij .Carrier вҶ’ GlО”ВІОЈ (duaО”ВІОЈ F) ij .Carrier
  duaО”ВІ-retractвҶ’ F (i , j) x .fst = coe-рқ“ў-О”ВІ F (рқ•Җ[x].1-top) x
  duaО”ВІ-retractвҶ’ F (i , j) x .snd refl .fst .fst
    = coe-рқ“ў (F вҲҳ (_, i0)) (1-top {i})
            (tr (Space.Carrier вҲҳ F) (О”ВІ-ext (refl , refl)) x)
  duaО”ВІ-retractвҶ’ F (i , j) x .snd refl .fst .snd refl
    = ( tr (Space.Carrier вҲҳ F) (О”ВІ-ext (refl , refl)) x
      , sym (happly (coe-cov-0вүӨ1 (Carrier вҲҳ F вҲҳ (_, i0)) (UFib-is-fib (F вҲҳ (_, i0))) 1-top )
                                 (tr (Carrier вҲҳ F) (О”ВІ-ext (refl , refl)) x)))
  duaО”ВІ-retractвҶ’ F (i , j) x .snd refl .snd
    = {!happly (coe-cov-0вүӨ1 (Carrier вҲҳ F вҲҳ (i1 ,_)) (UFib-is-fib (F вҲҳ (i1 ,_))) 1-top) ?!}
  -- (Cov-Nat-О”ВІ-is-equiv (GlО”ВІОЈ (duaО”ВІОЈ F)) F ? ?)

  duaО”ВІ-retract-is-equiv
    : вҲҖ {@вҷӯ рқ“Ө} (F : О”ВІ вҶ’ Space (рқ“ҳ вҠ” рқ“Ө)) (ij : О”ВІ)
      вҶ’ is-equiv (duaО”ВІ-retractвҶ’ F ij)
  duaО”ВІ-retract-is-equiv F
    = Cov-Nat-О”ВІ-is-equiv
        F
        (GlО”ВІОЈ (duaО”ВІОЈ F))
        (duaО”ВІ-retractвҶ’ F)
        О» where
          fzero вҶ’ lemma0
          (fsuc fzero) вҶ’ is-equivвҶҗqinv lemma1
          (fsuc (fsuc fzero)) вҶ’ is-equivвҶҗqinv lemma2 where
    lemma0 : вҲҖ {@вҷӯ рқ“Ө} {F : О”ВІ вҶ’ Space (рқ“ҳ вҠ” рқ“Ө)}
             вҶ’ is-equiv (duaО”ВІ-retractвҶ’ F (point-О”ВІ fzero))
    lemma0 {_}{F} = is-equivвҶҗqinv
      ( (О» x вҶ’ x .snd refl .fst .snd refl .fst)
      , (О» a вҶ’ sym (tr-refl (О”ВІ-ext (refl , refl)) a (О”ВІ-is-set _ _ _ _)))
      , {!!})

    lemma1 : вҲҖ {@вҷӯ рқ“Ө} {F : О”ВІ вҶ’ Space (рқ“ҳ вҠ” рқ“Ө)}
             вҶ’ quasi-inv (duaО”ВІ-retractвҶ’ F (point-О”ВІ 1))
    lemma1 .fst x = x .snd refl .fst .fst
    lemma1 {_}{F} .snd .fst a = coe-рқ“ў-id (F вҲҳ ОҙвӮӮВІ) 1-top _
                              вҲҷ sym (tr-refl {P = Carrier вҲҳ F} (О”ВІ-ext (refl , refl)) a (О”ВІ-is-set _ _ _ _))
    lemma1 {_}{F} .snd .snd (a , b) = Gl-pathвҶ’ {A = Gl (F (i0 , i0)) (F (i1 , i0)) _ i1} {B = F (i1 , i1)} i0
      ( {!!} вҲҷ b refl .snd
      , J-set! _
          ( ОЈ-pathвҶ’ ( coe-рқ“ў-id (F вҲҳ (_, i0)) 1-top _
                    вҲҷ sym (tr-refl (О”ВІ-ext (refl , refl)) (b refl .fst .fst) (О”ВІ-is-set _ _ _ _))
                    , (funextвҶ’ (ВЎ вҲҳ non-triv)))
          , {!!}))

    lemma2
      : вҲҖ {@вҷӯ рқ“Ө} {F : О”ВІ вҶ’ Space (рқ“ҳ вҠ” рқ“Ө)}
        вҶ’ quasi-inv (duaО”ВІ-retractвҶ’ F (point-О”ВІ 2))
    lemma2 .fst x = x .fst
    lemma2 {_}{F} .snd .fst = coe-рқ“ў-О”ВІ-id F рқ•Җ[x].1-top
    lemma2 {_}{F} .snd .snd (a , b)
      = ОЈ-pathвҶ’ (coe-рқ“ў-О”ВІ-id F рқ•Җ[x].1-top a , funextвҶ’ (ВЎ вҲҳ non-triv))


  duaО”ВІ-is-equiv : вҲҖ {@вҷӯ рқ“Ө} вҶ’ is-equiv (duaО”ВІОЈ {рқ“ҳ вҠ” рқ“Ө})
  duaО”ВІ-is-equiv = is-equivвҶҗqinv
    ( GlО”ВІОЈ
    , (О» F вҶ’ funextвҶ’
         (О» ij вҶ’ ext!
                   (mkвүғ (duaО”ВІ-retractвҶ’ F ij)
                        (duaО”ВІ-retract-is-equiv F ij) eвҒ»В№)))
    , (О» a вҶ’ {!duaО”ВІ-section!}))


  SpaceHorn : вҲҖ (@вҷӯ рқ“Ө) вҶ’ Type (lsuc (рқ“Ө вҠ” рқ“ҳ))
  SpaceHorn рқ“Ө = ОЈ[ X Y вҲ¶ Space рқ“Ө ] ОЈ[ F вҲ¶ (X .Space.Carrier вҶ’ Y .Space.Carrier)]
                  ОЈ[ Z W вҲ¶ Space рқ“Ө ] ОЈ[ G вҲ¶ (Z .Space.Carrier вҶ’ W .Space.Carrier)]
                   (Y .Space.Carrier вүғ Z .Space.Carrier)

  SpaceHornвҶҗhorn : вҲҖ {@вҷӯ рқ“Ө} вҶ’ (Оӣ[2,1] вҶ’ Space рқ“Ө) вҶ’ SpaceHorn рқ“Ө
  SpaceHornвҶҗhorn f
    = ( f (О№вӮҒ i0)
      , f (О№вӮҒ i1)
      , tr-рқ“ў (f вҲҳ О№вӮҒ)
      , f (О№вӮӮ i0)
      , f (О№вӮӮ i1)
      , tr-рқ“ў (f вҲҳ О№вӮӮ)
      , trвүғ (Space.Carrier вҲҳ f) (glue tt))

  RestrictSpaceО”ВІ : вҲҖ {@вҷӯ рқ“Ө} вҶ’ SpaceО”ВІОЈ рқ“Ө вҶ’ SpaceHorn рқ“Ө
  RestrictSpaceО”ВІ (A , B , C , F , G)
    = ( A
      , B
      , F
      , B
      , C
      , G
      , idвүғ)


  Space-is-segal : вҲҖ {@вҷӯ рқ“Ө} вҶ’ is-segal (Space (рқ“Ө вҠ” рқ“ҳ))
  Space-is-segal {рқ“Ө} tt = src-is-equivвҶҗArrow-equiv arr {!!} where
    fact' : вҲҖ x вҶ’ (SpaceHornвҶҗhorn (precomp (Space (рқ“Ө вҠ” рқ“ҳ)) Оӣ[2,1]-incl x)) пјқ RestrictSpaceО”ВІ (duaО”ВІОЈ x)
    fact' x = {!is-!}
    -- fact' f .fst = idвүғ
    -- fact' f .snd .fst = idвүғ
    -- fact' f .snd .snd .fst = trвүғ (Space.Carrier вҲҳ f) О”ВІ-refl
    -- fact' f .snd .snd .snd .fst = ~refl
    -- fact' f .snd .snd .snd .snd x = ap (tr (Space.Carrier вҲҳ f) О”ВІ-refl)
    --   {!!}

    arr : Arrow-equiv (precomp (Space (рқ“Ө вҠ” рқ“ҳ)) Оӣ[2,1]-incl) (RestrictSpaceО”ВІ {рқ“Ө вҠ” рқ“ҳ})
    arr .fst .Arrow-О .top = duaО”ВІОЈ
    arr .fst .Arrow-О .bot = SpaceHornвҶҗhorn
    arr .fst .Arrow-О .comm = {!!}
    arr .snd .fst = duaО”ВІ-is-equiv
    arr .snd .snd = {!!}

    -- fact : SpaceHornвҶҗhorn вҲҳ precomp (Space (рқ“Ө вҠ” рқ“ҳ)) Оӣ[2,1]-incl ~ duaО”ВІОЈ
    -- fact f = {!SpaceО”ВІОЈ-path!}
}
}

\subtree[stt-00BA]{
\taxon{Warning}
\p{Instantiating this module at a particular type axiomitises that the type
has an amazing right adjoint. There are types for which this is not sound.}
}



%```agda
\agda{
module Synthetic.Tiny2 where

open import Foundations.Prelude
open import ufAxioms

open import Modalities.Cohesion.Flat

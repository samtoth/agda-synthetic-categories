\subtree[stt-005G]{
\date{2025-06-17}
\author{samueltoth}
\taxon{Definition}
\title{Null types}

\p{
Given a family of types #{A_i}, we say a type #{X} is #{A} \em{null} if
it is right orthogonal to each #{A_i}. Or equivalently, if the
obvious maps #{X \to (A_i \to X)} are equivalences for each #{i}.
}

%```agda
\agda{
module _
  {рқ“ҳ рқ“Ө рқ“Ҙ : Level} {I : Type рқ“ҳ}
  where

  is-null : (A : I вҶ’ Type рқ“Ө) вҶ’ Type рқ“Ҙ вҶ’ Type (рқ“ҳ вҠ” рқ“Ө вҠ” рқ“Ҙ)
  is-null A X = (i : I) вҶ’ is-equiv (const X (A i))

  is-null-is-prop
    : {A : I вҶ’ Type рқ“Ө}
    вҶ’ (X : Type рқ“Ҙ) вҶ’ is-prop (is-null A X)
  is-null-is-prop X = is-prop-О  О» a вҶ’ is-equiv-is-prop

  nullвүғ : {A : I вҶ’ Type рқ“Ө}
          {X : Type рқ“Ҙ} (_ : is-null A X) (i : I)
        вҶ’ X вүғ (A i вҶ’ X)
  nullвүғ {A} {X} An i = mkвүғ (const X (A i)) (An i)

  is-null-equiv
    : {A : I вҶ’ Type рқ“Ө}
      {X : Type рқ“Ҙ} {Y : Type рқ“Ҙ}
    вҶ’ X вүғ Y
    вҶ’ is-null A X
    вҶ’ is-null A Y
  is-null-equiv e anull i
    = is-equivвҶҗArrow-equiv
        {F = mk-amap fwd (postcomp _ fwd) ~refl}
        (has-is-eqv , postcomp-equiv has-is-eqv)
        (anull i) where
    open _вүғ_ e

Null-SubU
  : вҲҖ {рқ“ҳ рқ“Ө} {I : Type рқ“ҳ}
      (A : I вҶ’ Type рқ“Ө)
      рқ“Ұ
    вҶ’ SubU рқ“Ұ (рқ“Ұ вҠ” рқ“ҳ вҠ” рқ“Ө)
Null-SubU A рқ“Ұ .Subtype.family = is-null A
Null-SubU A рқ“Ұ .Subtype.has-is-subtype = is-null-is-prop
}
%```
}


\subtree[stt-005H]{
\date{2025-06-17}
\author{samueltoth}
\taxon{Theorem}
\title{Null types are #{!}-local}

\p{A type is #{A_i}-null iff it is #{(! : A_i \to 1)}-local.}

\proof{ \p{A type #{X} is #{!\rm{-local}} when the map #{- \circ\ ! :
(1 \to X) \to (A_i \to X)} is an equivalence.}
}

%```agda
\agda{
is-localвҶҗis-null : вҲҖ {рқ“ҳ рқ“Ө рқ“Ҙ} {I : Type рқ“ҳ} {A : I вҶ’ Type рқ“Ө}
                   вҶ’ {X : Type рқ“Ҙ}
                   вҶ’ is-null A X
                   вҶ’ is-local (О» i вҶ’ !: A i) X
is-localвҶҗis-null eq i = 3-for-2' (point-is-equiv) (eq i)

is-local-singвҶҗis-null : вҲҖ {рқ“ҳ рқ“Ө рқ“Ҙ рқ“Ұ} {I : Type рқ“ҳ}
                          {A : I вҶ’ Type рқ“Ө}
                          {B : I вҶ’ Type рқ“Ҙ}
                          (Bsing : вҲҖ i вҶ’ is-singleton (B i))
                          (f : вҲҖ i вҶ’ A i вҶ’ B i)
                        вҶ’ {X : Type рқ“Ұ}
                        вҶ’ is-null A X
                        вҶ’ is-local f X
is-local-singвҶҗis-null Bsing f null i
  = 3-for-2'
    (is-equivвҒ»В№ (sing-ev-is-equiv global-funext (Bsing i)))
    (null i)

is-nullвҶҗis-local : вҲҖ {рқ“ҳ рқ“Ө рқ“Ҙ} {I : Type рқ“ҳ} {A : I вҶ’ Type рқ“Ө}
                   вҶ’ {X : Type рқ“Ҙ}
                   вҶ’ is-local (О» i вҶ’ !: A i) X
                   вҶ’ is-null A X
is-nullвҶҗis-local eq i = is-equiv-вҲҳ (eq i) point-is-equiv

orthogonal-type-total-map-!вҶҗis-null
  : {рқ“Ө рқ“Ҙ рқ“Ұ : Level}
    {A : Type рқ“Ө}
    {B : A вҶ’ Type рқ“Ҙ}
    {X : Type рқ“Ұ}
  вҶ’ is-null B X
  вҶ’ orthogonal-type (total-map (О» a вҶ’ !: B a)) X
orthogonal-type-total-map-!вҶҗis-null {B = B}
  = orthogonal-type-total-map (О» a вҶ’ !: B a)
  вҲҳ is-localвҶҗis-null

is-nullвҶҗis-local-sing : вҲҖ {рқ“ҳ рқ“Ө рқ“Ҙ рқ“Ұ} {I : Type рқ“ҳ}
                          {A : I вҶ’ Type рқ“Ө}
                          {B : I вҶ’ Type рқ“Ҙ}
                          (Bsing : вҲҖ i вҶ’ is-singleton (B i))
                          (f : вҲҖ i вҶ’ A i вҶ’ B i)
                        вҶ’ {X : Type рқ“Ұ}
                        вҶ’ is-local f X
                        вҶ’ is-null A X
is-nullвҶҗis-local-sing Bs f loc i
  = is-equiv-вҲҳ
      (loc i)
      (is-equivвҒ»В№ (sing-ev-is-equiv global-funext (Bs i)))

Nullвүғ!Local
  : вҲҖ {рқ“ҳ рқ“Ө рқ“Ҙ} {I : Type рқ“ҳ} {A : I вҶ’ Type рқ“Ө}
  вҶ’ Subtype-equiv (Local-SubU (О» i вҶ’ !: A i) рқ“Ҙ)
                  (Null-SubU A рқ“Ҙ)
Nullвүғ!Local A = (is-nullвҶҗis-local , is-localвҶҗis-null)
}
%```
}

\subtree[fre-Q009]{
\date{2026-03-19}
\author{fredrikbakke}
\title{Locality at subtypes}
\taxon{Lemma}

% TODO: diagram

%```agda
\agda{
module _
  {рқ“Ө рқ“Ҙ рқ“Ұ : Level}
  {B : Type рқ“Ө}
  (R : B вҶ’ Type рқ“Ұ)
  (S : B вҶ’ Type рқ“Ҙ)
  (S-prop : (b : B) вҶ’ is-prop (S b))
  (ПҮ : (b : B) вҶ’ R b вҶ’ S b)
  where

  local-at-subtypeвҶҗfamilyвҶҗis-null-over
    : {рқ“ҳ : Level}
      {X : Type рқ“ҳ}
    вҶ’ is-null (family-over-subtype R (mk-subtype S-prop) ПҮ) X
    вҶ’ orthogonal-type (subtypeвҶҗfamily R (mk-subtype S-prop) ПҮ) X
  local-at-subtypeвҶҗfamilyвҶҗis-null-over {X = X}
    = orthogonal-typeвҶҗArrow-equiv
        (compute-over-subtypeвҶҗfamily R (mk-subtype S-prop) ПҮ)
        {X = X}
    вҲҳ orthogonal-type-total-map-!вҶҗis-null

  subtypeвҶҗfamily-localвҶҗfamily-replacement
    : {рқ“Ө' рқ“ң : Level}
      {A : Type рқ“Ө'}
      (f : A вҶ’ B)
      {X : Type рқ“ң}
    вҶ’ orthogonal-type (total-map-fst f {B = R}) X
    вҶ’ orthogonal-type (О» (a , p) вҶ’ (a , ПҮ (f a) p)) X
    вҶ’ orthogonal-type (subtypeвҶҗfamily R (mk-subtype S-prop) ПҮ) X
    вҶ’ orthogonal-type (total-map-fst f {B = S}) X
  subtypeвҶҗfamily-localвҶҗfamily-replacement f repвҠҘ srcвҠҘ tgtвҠҘ
    = orthogonal-type-right-cancel
        (srcвҠҘ)
        (orthogonal-type-вҲҳ
          (subtypeвҶҗfamily R (mk-subtype S-prop) ПҮ)
          (total-map-fst f {B = R})
          (tgtвҠҘ)
          (repвҠҘ))
}
%```
}

\subtree[stt-005K]{
\date{2025-06-17}
\author{samueltoth}
\title{Nullification at a pointed family}
\taxon{Definition}

\p{The nullification of a pointed type can be constructed
using the [free algebraic injection](stt-005I)
higher inductive type. By definition, the free
algebraic injection already gives a section to
the precomposition map. Because any map #{A \to 1}
has a section, then the precomposition by this
map already has a retract, and so the type is not just
algebraically #{A}-injective, but #{A}-null.}

%```agda
\agda{
NullвҲҷ : вҲҖ {рқ“ҳ рқ“Ө рқ“Ҙ} {I : Type рқ“ҳ} (A : I вҶ’ Type рқ“Ө)
         (AвҲҷ : О  _ A) (X : Type рқ“Ҙ)
       вҶ’ Type рқ“Ҙ
NullвҲҷ A _ X = Free-inj
               (О» i вҶ’ !: A i)
                X

NullвҲҷ-is-null : вҲҖ {рқ“ҳ рқ“Ө рқ“Ҙ} {I : Type рқ“ҳ}
                 {A : I вҶ’ Type рқ“Ө} (AвҲҷ : О  _ A)
                 {X : Type рқ“Ҙ}
               вҶ’ is-null A (NullвҲҷ A AвҲҷ X)
NullвҲҷ-is-null a = is-nullвҶҗis-local I where
  I : is-local (О» _ вҶ’ !) _
  I i = is-equivвҶҗqiso О» where
    .fst вҶ’ injector-Free-inj i .fst
    .snd .fst Оұ вҶ’ funextвҶ’ (О» _ вҶ’ Free-inj.is-ext (Оұ вҲҳ !) (a i))
    .snd .snd вҶ’ injector-Free-inj i .snd
}
%```
}

\subtree[stt-0065]{
\date{2025-06-21}
\author{samueltoth}
\title{Nullification is a [reflective subuniverse](stt-0041)}
\taxon{Corollary}


%```agda
\agda{
module _ where
  open is-globally-reflective
  open is-global-reflector

  Null-gSubU : вҲҖ {рқ“ҳ рқ“Ө} {I : Type рқ“ҳ}
               (A : I вҶ’ Type рқ“Ө)
              вҶ’ gSubU (_вҠ” (рқ“ҳ вҠ” рқ“Ө))
  Null-gSubU A .gSubU.S = Null-SubU A _
  Null-gSubU A .gSubU.вҲҲSвҶҗequiv e anull i
    = is-equivвҶҗArrow-equiv
        {F = mk-amap fwd (postcomp _ fwd) ~refl}
        (has-is-eqv , postcomp-equiv has-is-eqv)
        (anull i) where open _вүғ_ e

  Null-globally-reflective
    : вҲҖ {рқ“ҳ рқ“Ө} {I : Type рқ“ҳ} {A : I вҶ’ Type рқ“Ө}
    вҶ’ is-globally-reflective (Null-gSubU A)
  Null-globally-reflective {A = A}
    = is-globally-reflective-subtype-equiv
        (Nullвүғ!Local)
        (Local-global-reflectors (О» i вҶ’ !: A i))

  opaque
    NullвҲҷ-global-reflectors
      : вҲҖ {рқ“ҳ рқ“Ө} {I : Type рқ“ҳ}
          {A : I вҶ’ Type рқ“Ө}
          (aвҲҷ : вҲҖ i вҶ’ A i)
        вҶ’ is-globally-reflective (Null-gSubU A)
    NullвҲҷ-global-reflectors a .в—Ӣ = NullвҲҷ _ a
    NullвҲҷ-global-reflectors a .О· = Free-inj.inc
    NullвҲҷ-global-reflectors a .has-is-reflector
      .в—ӢвҲҲS = NullвҲҷ-is-null a
    NullвҲҷ-global-reflectors a .has-is-reflector
      .reflects cnull = Free-inj-reflects _ (is-localвҶҗis-null cnull)

  NullвҲҷ-reflective
    : вҲҖ {рқ“ҳ рқ“Ө рқ“Ұ} {I : Type рқ“ҳ}
        {A : I вҶ’ Type рқ“Ө}
        (aвҲҷ : вҲҖ i вҶ’ A i)
      вҶ’ is-reflective (Null-SubU A рқ“Ұ)
  NullвҲҷ-reflective a = is-reflectiveвҶҗglobal (NullвҲҷ-global-reflectors a)

  Null-gRSubU
    : вҲҖ {рқ“ҳ рқ“Ө} {I : Type рқ“ҳ} (A : I вҶ’ Type рқ“Ө)
    вҶ’ gRSubU (_вҠ” (рқ“ҳ вҠ” рқ“Ө))
  Null-gRSubU A .gRSubU.GS = Null-gSubU A
  Null-gRSubU A .gRSubU.has-is-globally-reflective = Null-globally-reflective

  NullвҲҷ-gRSubU
    : вҲҖ {рқ“ҳ рқ“Ө} {I : Type рқ“ҳ}
        {A : I вҶ’ Type рқ“Ө}
        (aвҲҷ : вҲҖ i вҶ’ A i)
      вҶ’ gRSubU (_вҠ” (рқ“ҳ вҠ” рқ“Ө))
  NullвҲҷ-gRSubU {A = A} a .gRSubU.GS = Null-gSubU A
  NullвҲҷ-gRSubU a .gRSubU.has-is-globally-reflective = NullвҲҷ-global-reflectors a
}
%```
}

\subtree[stt-006E]{
\date{2025-06-25}
\author{samueltoth}
\taxon{Theorem}
\title{Nullification is a #{\Sigma}-closed reflective subuniverse}

\p{Nullification is a #{\Sigma}-closed reflective subuniverse and so
is also a higher modality.}

\proof{
\p{By calculation:}

##{
\begin{align}
  \Sigma_{(x : X)} Y(x)  &\simeq \Sigma_{(x : X)} A_i \to Y(x) \\
                         &\simeq \Sigma_{(x : A_i \to X)} \Pi_{(a : A_i)} Y(f(a))\\
                         &\simeq A_i \to \Sigma_{(x : X)} Y(x)
\end{align}
}

\p{Where (1) and (2) follow from the fact #{X} and each #{Y(x)} are
#{A}-[null](stt-005G), and (3) is the [type theoretic theorem of
choice](Foundations.TheoremOfChoice).}  }

%```agda
\agda{
ОЈ-is-null : вҲҖ {рқ“ҳ рқ“Ө рқ“Ҙ рқ“Ұ}
              {I : Type рқ“ҳ}
              {P : I вҶ’ Type рқ“Ө}
              {X : Type рқ“Ҙ} {Y : X вҶ’ Type рқ“Ұ}
            вҶ’ is-null P X
            вҶ’ (вҲҖ x вҶ’ is-null P (Y x))
            вҶ’ is-null P (ОЈ X Y)
ОЈ-is-null {P = P} {X = X} {Y} Xnull Ynull i
  = eqv where
  opaque
    I : ОЈ X Y вүғ (P i вҶ’ ОЈ X Y)
    I = ОЈ X Y
          вүғвҹЁ ОЈ-ap-вүғ (О» x вҶ’ nullвүғ (Ynull x) i) вҹ©
        ОЈ X (О» x вҶ’ P i вҶ’ Y x)
          вүғвҹЁ ОЈ-ap-вүғ-fst {B = О» f вҶ’ (a : P i) вҶ’ Y (f a)} (nullвүғ Xnull i) вҹ©
        ОЈ (P i вҶ’ X) (О» f вҶ’ (a : P i) вҶ’ Y (f a))
          вүғвҹЁ ОЈ-О -swapвүғ (О» _ вҶ’ X) (О» _ вҶ’ Y) eвҒ»В№ вҹ©
        (P i вҶ’ ОЈ X Y) вүғвҲҺ

    eqv : is-equiv (const (ОЈ X Y) (P i))
    eqv = I ._вүғ_.has-is-eqv

Null-globally-ОЈ-closed : вҲҖ {рқ“ҳ рқ“Ө} {I : Type рқ“ҳ}
                   {P : I вҶ’ Type рқ“Ө}
                 вҶ’ is-globally-ОЈ-closed (Null-gSubU P)
Null-globally-ОЈ-closed = ОЈ-is-null

Null-gRSubU-ОЈ-closed
  : вҲҖ {рқ“ҳ рқ“Ө} {I : Type рқ“ҳ}
      (P : I вҶ’ Type рқ“Ө)
    вҶ’ is-globally-ОЈ-closed (Null-gRSubU P .gRSubU.GS)
Null-gRSubU-ОЈ-closed P = Null-globally-ОЈ-closed

Null-ОЈ-closed : вҲҖ {рқ“ҳ рқ“Ө рқ“Ұ} {I : Type рқ“ҳ}
                   {A : I вҶ’ Type рқ“Ө}
                 вҶ’ is-ОЈ-closed (Null-SubU A рқ“Ұ)
Null-ОЈ-closed {A = A}
  = is-ОЈ-closedвҶҗglobally (Null-gSubU A) Null-globally-ОЈ-closed

NullвҲҷ-HigherModality
  : вҲҖ {рқ“ҳ рқ“Ө рқ“Ұ} {I : Type рқ“ҳ}
      {A : I вҶ’ Type рқ“Ө}
      (a : О  _ A)
    вҶ’ HigherModality рқ“Ұ
NullвҲҷ-HigherModality a
  = HigherModalityвҶҗSubU (NullвҲҷ-reflective a) (Null-ОЈ-closed)

module _
  {рқ“ҳ рқ“Ө : Level} {I : Type рқ“ҳ}
  (X : I вҶ’ Type рқ“Ө)
  where

  open gSubU (Null-gSubU X) public using () renaming
    ( вҲҲSвҶҗequiv to is-nullвҶҗequiv)

  open ReflectiveClosureбөҚ (Null-gRSubU X) public using () renaming
    ( вҲҲSвҶҗretract to is-nullвҶҗretract
    ; О вҲҲS to О -is-null
    ; ULiftвҲҲS to ULift-is-null
    ; рқҹҷвҲҲS to рқҹҷ-is-null
    ; вҲҲSвҶҗis-singleton to is-nullвҶҗis-singleton
    ; PullbackвҲҲS to Pullback-is-null
    ; fibreвҲҲS to fibre-is-null
    ; Г—вҲҲS to Г—-is-null
    ; пјқвҲҲS to пјқ-is-null
    ; ~вҲҲS to ~-is-null
    ; retractвҲҲS to retract-is-null
    ; biinvвҲҲS to biinv-is-null
    ; вүғвҲҲS to вүғ-is-null
    ; EqualiserвҲҲS to Equaliser-is-null
    ; Seq-limвҲҲS to Seq-lim-is-null
    ; preidempotent-mapвҲҲS to preidempotent-map-is-null
    ; qidempotent-mapвҲҲS to qidempotent-map-is-null
    ; RetractsвҲҲS to Retracts-is-null)

module Null
  {рқ“ҳ рқ“Ө : Level} {I : Type рқ“ҳ}
  (A : I вҶ’ Type рқ“Ө)
  where

  open gRSubUInduction (Null-gRSubU A) (Null-gRSubU-ОЈ-closed A) public
  open gSubU (Null-gSubU A) public
  open gRSubU (Null-gRSubU A) public
  open ReflectiveClosureбөҚ (Null-gRSubU A) public

}
%```
}

\subtree[fre-0003]{
\date{2026-03-18}
\author{fredrikbakke}
\title{Localisations at families of pointed maps are higher modalities}
\taxon{Corollary}

\p{
If each codomain #{B_i} is [contractible](stt-000F), then localisation at
#{f_i : A_i \to B_i} is [\Sigma-closed](stt-006F), and hence determines a
higher modality.
}

%```agda
\agda{
module _ {рқ“ҳ рқ“Ө рқ“Ҙ рқ“Ұ : Level} {I : Type рқ“ҳ}
         {A : I вҶ’ Type рқ“Ө} {B : I вҶ’ Type рқ“Ҙ}
         where

  Local-ОЈ-closed
    : (f : (i : I) вҶ’ A i вҶ’ B i)
    вҶ’ (вҲҖ i вҶ’ is-singleton (B i))
    вҶ’ is-ОЈ-closed (Local-SubU f рқ“Ұ)
  Local-ОЈ-closed f sngl aloc bloc
    = is-local-singвҶҗis-null sngl f
        (Null-ОЈ-closed
          (is-nullвҶҗis-local-sing sngl f aloc)
          О» a вҶ’ is-nullвҶҗis-local-sing sngl f (bloc a))

  Local-HigherModality
    : (f : (i : I) вҶ’ A i вҶ’ B i)
    вҶ’ (вҲҖ i вҶ’ is-singleton (B i))
    вҶ’ HigherModality рқ“Ұ
  Local-HigherModality f s
    = HigherModalityвҶҗSubU
        (Local-reflective f)
        (Local-ОЈ-closed f s)
}
%```
}

\subtree[fre-1234]{
\date{2026-03-10}
\author{fredrikbakke}
\title{Closure of null types under retracts in the exponent}
\taxon{Lemma}

\p{
Given an #{A}-[null](stt-005G) type #{X}, then #{X} is null at any
[retract](fre-2115) of #{A}.
}

%```agda
\agda{
module _
  {рқ“ҳ рқ“Ө рқ“Ҙ : Level} {I : Type рқ“ҳ}
  where

  is-nullвҶҗretract-exponent
    : {A : I вҶ’ Type рқ“Ө}
      {B : I вҶ’ Type рқ“Ө}
      {X : Type рқ“Ҙ}
    вҶ’ ((i : I) вҶ’ retract (A i) (B i))
    вҶ’ is-null B X
    вҶ’ is-null A X
  is-nullвҶҗretract-exponent {A = A} {B} {X} R Bnull i
    = is-equivвҶҗretraction-equiv
        (mk-amap id (precomp X (R i .snd .fst)) ~refl)
        (mk-amap id (precomp X (R i .fst)) ~refl
        , ~refl
        , О» h вҶ’ funextвҶ’ О» a вҶ’ ap h (R i .snd .snd a))
        (Bnull i)
}
%```
}

\subtree[fre-0000]{
\date{2026-03-09}
\author{fredrikbakke}
\title{The universe of null types in a subuniverse at a family of propositions}
\taxon{Theorem}

\p{
Let #{P_i} be a family of propositions, and let #{\mathcal{S}} be a
[global subuniverse](stt-007A) which is closed under dependent products over each
#{P_i}. Then the type of #{P}-null types in #{\mathcal{S}} is again #{P}-null.
}

%```agda
\agda{
Null-in-gSubU
  : {Оұ : Level вҶ’ Level} {рқ“ҳ рқ“Ө : Level} {I : Type рқ“ҳ}
  вҶ’ (P : I вҶ’ Type рқ“Ө)
  вҶ’ gSubU Оұ
  вҶ’ вҲҖ рқ“Ҙ вҶ’ Type (lsuc (рқ“Ө вҠ” рқ“Ҙ) вҠ” Оұ (рқ“Ө вҠ” рқ“Ҙ) вҠ” рқ“ҳ)
Null-in-gSubU {рқ“Ө = рқ“Ө} P S рқ“Ҙ
  = ОЈ[ X вҲ¶ Type (рқ“Ө вҠ” рқ“Ҙ) ] ((X вҲҲ gSubU.S S) Г— is-null P X)

Null-in-gSubU-is-nullвҶҗis-prop
  : {Оұ : Level вҶ’ Level} {рқ“ҳ рқ“Ө рқ“Ҙ : Level} {I : Type рқ“ҳ}
    {P : I вҶ’ Type рқ“Ө} {S : gSubU Оұ}
  вҶ’ ((i : I) вҶ’ is-prop (P i))
  вҶ’ ( {рқ“Ұ : Level} (i : I) {B : P i вҶ’ Type рқ“Ұ}
      вҶ’ (вҲҖ a вҶ’ (B a) вҲҲ gSubU.S S)
      вҶ’ (О  (P i) B) вҲҲ gSubU.S S)
  вҶ’ is-null P (Null-in-gSubU P S рқ“Ҙ)
Null-in-gSubU-is-nullвҶҗis-prop {рқ“Ө = рқ“Ө} {рқ“Ҙ = рқ“Ҙ} {P = P} {S = S} is-prop-P SО  i
  = is-equivвҶҗqiso qiso where
  U = Null-in-gSubU P S рқ“Ҙ
  SU = gSubU.S S

  is-in-SU-and-is-null-is-prop
    : (X : Type (рқ“Ө вҠ” рқ“Ҙ)) вҶ’ is-prop ((X вҲҲ SU) Г— is-null P X)
  is-in-SU-and-is-null-is-prop X
    = is-prop-ОЈ (вҲҲ-is-prop SU X) (О» _ вҶ’ is-null-is-prop X)

  qiso : quasi-iso (const U (P i))
  qiso .fst f
    = ( О  (P i) (fst вҲҳ f)
      , SО  i (О» a вҶ’ snd (f a) .fst)
      , О -is-null P (О» a вҶ’ snd (f a) .snd))
  qiso .snd .fst (X , XвҲҲS , Xnull)
    = ОЈ-pathвҶ’ (ua (nullвүғ Xnull i eвҒ»В№) , is-in-SU-and-is-null-is-prop _ _ _)
  qiso .snd .snd f
    = funextвҶ’ О» a вҶ’ ОЈ-pathвҶ’
      ( ua (mkвүғ (ev a)
                (sing-evбөҲ-is-equiv global-funext (mk-singl a (is-prop-P i a))))
      , is-in-SU-and-is-null-is-prop _ _ _)
}
%```
}

\subtree[fre-0001]{
\date{2026-03-09}
\author{fredrikbakke}
\title{The universe of null types at a family of propositions}
\taxon{Corollary}

\p{
For a family of propositions #{P_i}, the type of #{P}-null types is itself #{P}-null.
}

%```agda
\agda{
Null-U
  : {рқ“ҳ рқ“Ө : Level}
  вҶ’ {I : Type рқ“ҳ}
  вҶ’ (P : I вҶ’ Type рқ“Ө)
  вҶ’ (рқ“Ҙ : Level) вҶ’ Type (рқ“ҳ вҠ” lsuc рқ“Ө вҠ” lsuc рқ“Ҙ)
Null-U P рқ“Ҙ = Null-in-gSubU P Full-gSubU рқ“Ҙ

Null-U-is-nullвҶҗis-prop
  : {рқ“ҳ рқ“Ө рқ“Ҙ : Level}
    {I : Type рқ“ҳ}
    {P : I вҶ’ Type рқ“Ө}
  вҶ’ ((i : I) вҶ’ is-prop (P i))
  вҶ’ is-null P (Null-U P рқ“Ҙ)
Null-U-is-nullвҶҗis-prop {рқ“Ҙ = рқ“Ҙ} {P = P} is-prop-P
  = Null-in-gSubU-is-nullвҶҗis-prop
      {рқ“Ҙ = рқ“Ҙ}
      {P = P}
      {S = Full-gSubU}
      (is-prop-P)
      (О» _ _ вҶ’ tt)
}
%```
}

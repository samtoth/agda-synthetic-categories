\date{2026-04-30}
\title{Associativity of composition in Segal types}
\author{fredrikbakke}
\taxon{Module}
\import{stt-macros}

\p{
We follow RiehlвҖ“Shulman's original proof \citet{Proposition 5.6}{RS17} of
associativity of composition in Segal types. We note that the simplicial axiom, which
they cite as the equivalence
#{\Delta^2 \amalg_{\Delta^1} \Delta^2 \simeq \Delta^1 \times \Delta^1}, is not needed
for the proof to work. All they actually do is restrict along the inclusion
#{\Delta^2 \amalg_{\Delta^1} \Delta^2 \to \Delta^1 \times \Delta^1}, which exists
by the cocone

\quiver{
\begin{tikzcd}
	{\Delta^1} && {\Delta^2} \\
	\\
	{\Delta^2} && {\Delta^1 \times \Delta^1}
	\arrow["{i \mapsto (i \geq i)}", from=1-1, to=1-3]
	\arrow["{i \mapsto (i \geq i)}"', from=1-1, to=3-1]
	\arrow["{(i \ge j)\mapsto(j,i)}", dashed, from=1-3, to=3-3]
	\arrow["{(i \ge j)\mapsto(i,j)}"', dashed, from=3-1, to=3-3]
\end{tikzcd}
}
}

\agda{
{-# OPTIONS --lossy-unification #-}

open import Foundations.Prelude
open import Algebra.Lattice
import Algebra.Lattice.Instances.Polynomial as Poly
open Poly hiding (L[x]; О”ВІ)


module Synthetic.Categories.AssociativitySegal
  {рқ“ҳ} (О”В№ : Type рқ“ҳ) (I : Lattice О”В№) (I-distr : is-distributive I)
  where

private
  О”ВІ = Poly.О”ВІ I

open import Axioms.UF

open Lattice I renaming (0l to i0; 1l to i1)

open import Core.CanonicalPushouts

open import Synthetic.Hom О”В№ i0 i1
open import Synthetic.Horns О”В№ I I-distr
open import Synthetic.Boundaries О”В№ I I-distr
open import Synthetic.Categories.Precategories О”В№ I I-distr
open import Synthetic.Categories.Homotopy О”В№ I I-distr
}

\subtree[fre-9D07]{
\title{The associated naturality square of a composition triangle}
\taxon{Lemma}
\author{fredrikbakke}
\date{2026-05-01}

\p{
A composition triangle determines an arrow from the lower edge to the right edge.
}

\agda{
corner-between-edges
  : вҲҖ {рқ“Ө} {A : Type рқ“Ө} {x l r y z : A}
  вҶ’ (a : x пјқ l) (b : l пјқ y) (m : l пјқ r) (d : r пјқ z) (q : y пјқ z) (c : x пјқ r)
  вҶ’ c пјқ a вҲҷ m
  вҶ’ b вҲҷ q пјқ m вҲҷ d
  вҶ’ sym (a вҲҷ b) вҲҷ (c вҲҷ d) пјқ q
corner-between-edges refl refl refl refl refl refl refl refl = refl
}

\agda{
module _
  {рқ“Ө : Level} {A : Type рқ“Ө} {a b c : A}
  (g : Hom A b c) (f : Hom A a b) {gf : Hom A a c}
  (K : Hom2 g f gf)
  where

  composite-square
    : Hom (О”В№ вҶ’ A) (f .HomбөҲ.hom) (g .HomбөҲ.hom)
  composite-square .HomбөҲ.hom u v
    = K .fst ((u вҲЁ v , u вҲ§ v) вҰғ вҲЁ-вүӨ-introl (вҲ§-вүӨ-eliml вүӨ-refl) вҰ„)
  composite-square .HomбөҲ.hom0
    = funextвҶ’ О» v
        вҶ’ ap (K .fst) (О”ВІ-ext (вҲЁ-comm вҲҷ 0-bottom , 0-init))
        вҲҷ K .snd (О№вӮҒ (О№вӮҒ v))
  composite-square .HomбөҲ.hom1
    = funextвҶ’ О» v
        вҶ’ ap (K .fst) (О”ВІ-ext (вҲЁ-comm вҲҷ 1-coinit , вҲ§-comm вҲҷ 1-top))
        вҲҷ K .snd (О№вӮҒ (О№вӮӮ v))

  composite-square-bottom
    : (u : О”В№) вҶ’ composite-square .HomбөҲ.hom u i0 пјқ f .HomбөҲ.hom u
  composite-square-bottom u
    = ap (K .fst) (О”ВІ-ext (0-bottom , вҲ§-comm вҲҷ 0-init))
    вҲҷ K .snd (О№вӮҒ (О№вӮҒ u))

  composite-square-right
    : (u : О”В№) вҶ’ composite-square .HomбөҲ.hom u i1 пјқ g .HomбөҲ.hom u
  composite-square-right u
    = ap (K .fst) (О”ВІ-ext (1-coinit , 1-top))
    вҲҷ K .snd (О№вӮҒ (О№вӮӮ u))

  composite-square-diagonal
    : (u : О”В№) вҶ’ composite-square .HomбөҲ.hom u u пјқ gf .HomбөҲ.hom u
  composite-square-diagonal u
    = ap (K .fst) (О”ВІ-ext (вҲЁ-idem , вҲ§-idem))
    вҲҷ K .snd (О№вӮӮ u)

  composite-square-source
    : (u : О”В№) вҶ’ composite-square .HomбөҲ.hom i0 u пјқ f .HomбөҲ.hom u
  composite-square-source u
    = ap (K .fst) (О”ВІ-ext (вҲЁ-comm вҲҷ 0-bottom , 0-init))
    вҲҷ K .snd (О№вӮҒ (О№вӮҒ u))

  composite-square-target
    : (u : О”В№) вҶ’ composite-square .HomбөҲ.hom i1 u пјқ g .HomбөҲ.hom u
  composite-square-target u
    = ap (K .fst) (О”ВІ-ext (вҲЁ-comm вҲҷ 1-coinit , вҲ§-comm вҲҷ 1-top))
    вҲҷ K .snd (О№вӮҒ (О№вӮӮ u))

  Hom2-boundary-natural
    : {u v : вҲӮО”ВІ}
    вҶ’ (Оі : u пјқ v)
    вҶ’ {q : make-вҲӮО”ВІ g f gf u пјқ make-вҲӮО”ВІ g f gf v}
    вҶ’ ap (make-вҲӮО”ВІ g f gf) Оі пјқ q
    вҶ’ K .snd u вҲҷ q пјқ ap (K .fst вҲҳ вҲӮО”ВІ-incl) Оі вҲҷ K .snd v
  Hom2-boundary-natural {u = u} Оі filler-path
    = ap (K .snd u вҲҷ_) (sym filler-path)
    вҲҷ homotopy-natural (K .snd) Оі

  Hom2-boundary-ap-path
    : {u v : вҲӮО”ВІ}
    вҶ’ (Оі : u пјқ v)
    вҶ’ {Пғ : Poly.О”ВІ I}
    вҶ’ (p : Пғ пјқ вҲӮО”ВІ-incl v)
    вҶ’ (q : Пғ пјқ вҲӮО”ВІ-incl u)
    вҶ’ ap (K .fst) p пјқ ap (K .fst) q вҲҷ ap (K .fst вҲҳ вҲӮО”ВІ-incl) Оі
  Hom2-boundary-ap-path Оі p q
    = ap (ap (K .fst)) (О”ВІ-is-set _ _ p (q вҲҷ ap вҲӮО”ВІ-incl Оі))
    вҲҷ ap-вҲҷ (K .fst) q (ap вҲӮО”ВІ-incl Оі)
    вҲҷ ap (ap (K .fst) q вҲҷ_) (sym (ap-вҲҳ (K .fst) вҲӮО”ВІ-incl Оі))

  composite-square-lower-left
    : sym (composite-square-source i0)
    вҲҷ composite-square-diagonal i0
    пјқ f .HomбөҲ.hom0 вҲҷ sym (gf .HomбөҲ.hom0)
  composite-square-lower-left
    = corner-between-edges
        (ap (K .fst) p-src)
        (K .snd (О№вӮҒ (О№вӮҒ i0)))
        (ap (K .fst вҲҳ вҲӮО”ВІ-incl) (glue вҲӮО”В№-0))
        (K .snd (О№вӮӮ i0))
        (f .HomбөҲ.hom0 вҲҷ sym (gf .HomбөҲ.hom0))
        (ap (K .fst) p-diag)
        (Hom2-boundary-ap-path (glue вҲӮО”В№-0) p-diag p-src)
        (Hom2-boundary-natural (glue вҲӮО”В№-0) (pushout-rec-apОІ вҲӮО”В№-0))
    where
      p-src = О”ВІ-ext (вҲЁ-comm вҲҷ 0-bottom , 0-init)
      p-diag = О”ВІ-ext (вҲЁ-idem , вҲ§-idem)

  composite-square-upper-right
    : composite-square-target i1 вҲҷ g .HomбөҲ.hom1
    пјқ composite-square-diagonal i1 вҲҷ gf .HomбөҲ.hom1
  composite-square-upper-right
    = sym
      (un-square
        (coe
          (Square-squeeze-botr refl)
          (Square-paste-horizontal
            (mk-square
              ( вҲҷ-reflr (ap (K .fst) p-diag)
              вҲҷ Hom2-boundary-ap-path (glue вҲӮО”В№-1) p-diag p-tgt))
            (mk-square
              (sym (Hom2-boundary-natural (glue вҲӮО”В№-1) (pushout-rec-apОІ вҲӮО”В№-1)))))))
    вҲҷ sym (вҲҷ-assoc (ap (K .fst) p-diag) (K .snd (О№вӮӮ i1)) (gf .HomбөҲ.hom1))
    where
      p-tgt = О”ВІ-ext (вҲЁ-comm вҲҷ 1-coinit , вҲ§-comm вҲҷ 1-top)
      p-diag = О”ВІ-ext (вҲЁ-idem , вҲ§-idem)

  composite-square-upper-left
    : sym (composite-square-source i1)
    вҲҷ composite-square-right i0
    пјқ f .HomбөҲ.hom1 вҲҷ sym (g .HomбөҲ.hom0)
  composite-square-upper-left
    = corner-between-edges
        ( ap (K .fst) p-src)
        ( K .snd (О№вӮҒ (О№вӮҒ i1)))
        ( ap (K .fst вҲҳ вҲӮО”ВІ-incl) (ap О№вӮҒ Оӣ[2,1]-glue))
        ( K .snd (О№вӮҒ (О№вӮӮ i0)))
        ( f .HomбөҲ.hom1 вҲҷ sym (g .HomбөҲ.hom0))
        ( ap (K .fst) p-right)
        ( Hom2-boundary-ap-path (ap О№вӮҒ Оӣ[2,1]-glue) p-right p-src)
        ( Hom2-boundary-natural
          ( ap О№вӮҒ Оӣ[2,1]-glue)
          ( sym (ap-вҲҳ (make-вҲӮО”ВІ g f gf) О№вӮҒ Оӣ[2,1]-glue)
          вҲҷ horn-glue g f))
    where
      p-src = О”ВІ-ext (вҲЁ-comm вҲҷ 0-bottom , 0-init)
      p-right = О”ВІ-ext (1-coinit , 1-top)

  composite-square-lower-right
    : composite-square-target i0 вҲҷ g .HomбөҲ.hom0
    пјқ composite-square-bottom i1 вҲҷ f .HomбөҲ.hom1
  composite-square-lower-right
    = composite-square-target i0 вҲҷ g .HomбөҲ.hom0
        пјқвҹЁ ap ( О» q вҶ’ (q вҲҷ K .snd (О№вӮҒ (О№вӮӮ i0))) вҲҷ g .HomбөҲ.hom0)
              ( Hom2-boundary-ap-path (ap О№вӮҒ Оӣ[2,1]-glue) p-tgt p-bot) вҹ©
      ( ( ap (K .fst) p-bot вҲҷ ap (K .fst вҲҳ вҲӮО”ВІ-incl) (ap О№вӮҒ Оӣ[2,1]-glue))
        вҲҷ K .snd (О№вӮҒ (О№вӮӮ i0))) вҲҷ g .HomбөҲ.hom0
        пјқвҹЁ ap (_вҲҷ g .HomбөҲ.hom0) (вҲҷ-assoc _ _ _) вҹ©
      ( ap (K .fst) p-bot
      вҲҷ ap (K .fst вҲҳ вҲӮО”ВІ-incl) (ap О№вӮҒ Оӣ[2,1]-glue)
      вҲҷ K .snd (О№вӮҒ (О№вӮӮ i0)))
      вҲҷ g .HomбөҲ.hom0
        пјқвҹЁ ap ( О» q вҶ’ (ap (K .fst) p-bot вҲҷ q) вҲҷ g .HomбөҲ.hom0)
               ( sym
                 ( Hom2-boundary-natural (ap О№вӮҒ Оӣ[2,1]-glue)
                   ( sym (ap-вҲҳ (make-вҲӮО”ВІ g f gf) О№вӮҒ Оӣ[2,1]-glue) вҲҷ horn-glue g f))) вҹ©
      ( ap (K .fst) p-bot
      вҲҷ K .snd (О№вӮҒ (О№вӮҒ i1)) вҲҷ (f .HomбөҲ.hom1 вҲҷ sym (g .HomбөҲ.hom0)))
      вҲҷ g .HomбөҲ.hom0
        пјқвҹЁ ap (_вҲҷ g .HomбөҲ.hom0) (sym (вҲҷ-assoc _ _ _)) вҹ©
      ( ( ap (K .fst) p-bot вҲҷ K .snd (О№вӮҒ (О№вӮҒ i1)))
      вҲҷ ( f .HomбөҲ.hom1 вҲҷ sym (g .HomбөҲ.hom0)))
      вҲҷ g .HomбөҲ.hom0
        пјқвҹЁ вҲҷ-assoc _ _ _ вҹ©
      ( ap (K .fst) p-bot вҲҷ K .snd (О№вӮҒ (О№вӮҒ i1)))
      вҲҷ (f .HomбөҲ.hom1 вҲҷ sym (g .HomбөҲ.hom0)) вҲҷ g .HomбөҲ.hom0
        пјқвҹЁ ap ((ap (K .fst) p-bot вҲҷ K .snd (О№вӮҒ (О№вӮҒ i1))) вҲҷ_)

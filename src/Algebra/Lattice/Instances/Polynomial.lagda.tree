\subtree[stt-00A5]{
\title{Idea}

\p{We use our intuition for rings to define the free algebras of distributive
lattices as the polynomials. For a first approximation then, we  write a polynomial
as a sequence of terms (where #{x^n} is the n-fold meet of x):}

##{
a_n \land x^n \lor a_{n-1}\land x^{n-1} \lor ... \lor a_0
}

\p{In this setting we have idempotence of meet and join, so all terms #{a_n x^n} with
#{n \ge 2} reduce to #{a_n \land x}.}

\p{Finally, we note that for any #{x,a,b} in the lattice,
##{a \land x \lor b = (a \lor b) \land x \lor b} With these two observations,
we can now see that polynomials in one variable (#{x}) can be represented
uniquely as #{a \land x \lor b} with #{a \ge b}. }
}

\subtree[stt-009X]{
\taxon{Definition}
\title{The 2-simplex}

\p{We give a geometrically-suggestive name to the underlying set of the [free
distributive lattice algebra](stt-009W)}

\agda{
record О”ВІ {рқ“Ө} {A : Type рқ“Ө} (L : Lattice A) : Type рқ“Ө where
  constructor _,_
  open Lattice L
  field
    s t : A
    вҰғ mono вҰ„ : t вүӨ s

module _ {рқ“Ө} {A : Type рқ“Ө} {L : Lattice A} where
  open Lattice L

  unquoteDecl О”ВІ-reprвүҠ О”ВІ-reprвүғ = make-record-repr О”ВІ-reprвүҠ О”ВІ-reprвүғ (quote О”ВІ)

  О”ВІ-is-0-truncated : is-truncated 0 (О”ВІ L)
  О”ВІ-is-0-truncated = is-truncatedвҶҗequiv (О”ВІ-reprвүғ eвҒ»В№) trunc!

  О”ВІ-is-set : is-set (О”ВІ L)
  О”ВІ-is-set = is-setвҶҗis-truncated О”ВІ-is-0-truncated

  opaque
    О”ВІ-ext : вҲҖ {a b : О”ВІ L} вҶ’ ((a .О”ВІ.s пјқ b .О”ВІ.s) Г— (a .О”ВІ.t пјқ b .О”ВІ.t)) вҶ’ a пјқ b
    О”ВІ-ext {x@((a , b) вҰғ m вҰ„)} {y@(a , b)} (refl , refl)
      = unap-equiv (О”ВІ-reprвүғ ._вүғ_.fwd-is-equiv)
         (ОЈ-pathвҶ’ (refl
                  , (ОЈ-pathвҶ’ (refl
                  , ((is-setвҶҗis-truncated carrier-is-0-truncated _ _ _ _))))))

  О”ВІ-ext-is-equiv : вҲҖ {a b : О”ВІ L} вҶ’ is-equiv (О”ВІ-ext {a} {b})
  О”ВІ-ext-is-equiv = is-equivвҶҗinverse
                      (Г—-is-prop (carrier-is-set _ _) (carrier-is-set _ _))
                      (О”ВІ-is-set _ _)
                      О» where refl вҶ’ (refl , refl)

  О”ВІ-refl : вҲҖ {i j : A} { p q : j вүӨ i } вҶ’ Id (О”ВІ L) ((i , j) вҰғ p вҰ„) ((i , j) вҰғ q вҰ„)
  О”ВІ-refl = О”ВІ-ext (refl , refl)

  opaque
    О”ВІ-ext-ap-s
      : вҲҖ {a b : О”ВІ L} (p : a .О”ВІ.s пјқ b .О”ВІ.s) (q : a .О”ВІ.t пјқ b .О”ВІ.t)
        вҶ’ ap О”ВІ.s (О”ВІ-ext {a = a} {b = b} (p , q)) пјқ p
    О”ВІ-ext-ap-s {a} {b} refl refl = is-setвҶҗis-truncated carrier-is-0-truncated _ _ _ _

    О”ВІ-ext-ap-t
      : вҲҖ {a b : О”ВІ L} (p : a .О”ВІ.s пјқ b .О”ВІ.s) (q : a .О”ВІ.t пјқ b .О”ВІ.t)
        вҶ’ ap О”ВІ.t (О”ВІ-ext {a = a} {b = b} (p , q)) пјқ q
    О”ВІ-ext-ap-t {a} {b} refl refl = is-setвҶҗis-truncated carrier-is-0-truncated _ _ _ _

  О№-const : A вҶ’ О”ВІ L
  О№-const x = (x , x)
}
}


\subtree[stt-009W]{
\title{The algebra of polynomials over a distributive lattice}
\taxon{Construction}

\p{Fixing a lattice #{L}, we now construct the free [distributive](stt-00A3)
[lattice](stt-009T) [algebra](stt-009Z) over #{L} in one variable, denoted
#{L[x]}.}


\agda{
module _ {рқ“Ө} {A : Type рқ“Ө} (L : Lattice A) (distr : is-distributive L) where
  open Lattice L
  open is-distributive distr
}

\subtree{
\taxon{Notation}

\p{In this construction we will write meet (#{\land}) by juxtaposition.}
}

\p{The lattice structure #{L[x]} on [#{\Delta^2}](stt-009X) has:}

\ul{
\li{#{0 = 0x \lor 0}}
\li{#{1 = 1x \lor 1}}
\li{#{(ax \lor b) \lor (cx \lor d) = (a \lor c)x \lor (b \lor d)}}
\li{#{(ax \lor b) \land (cx \lor d) = ((bc \lor ad \lor ac)x \lor (bd))}}
}

\agda{
  Free-Lattice : Lattice (О”ВІ L) -- a вҲ§ x вҲЁ b вҲҲ L[x]
  Free-Lattice .Lattice.0l = (0l , 0l)
  Free-Lattice .Lattice.1l = (1l , 1l)
  Free-Lattice .Lattice._вҲЁ_ (aвӮҖ , aвӮҒ) (bвӮҖ , bвӮҒ)
    = (aвӮҖ вҲЁ bвӮҖ , aвӮҒ вҲЁ bвӮҒ)
  Free-Lattice .Lattice._вҲ§_ (aвӮҖ , aвӮҒ) (bвӮҖ , bвӮҒ)
    = (aвӮҖ вҲ§ bвӮҖ , aвӮҒ вҲ§ bвӮҒ)
  Free-Lattice .Lattice.str-is-lattice = l where
}

\p{Showing that these operations form a lattice follows from some slightly
tedious algebra:}

\details{
\agda{
    l : is-lattice (Lattice.0l Free-Lattice) (Lattice.1l Free-Lattice)
                   (Lattice._вҲ§_ Free-Lattice) (Lattice._вҲЁ_ Free-Lattice)
    l .is-lattice.carrier-is-0-truncated = О”ВІ-is-0-truncated
    l .is-lattice.вҲ§-assoc = О”ВІ-ext (вҲ§-assoc , вҲ§-assoc)
    l .is-lattice.вҲЁ-assoc = О”ВІ-ext (вҲЁ-assoc , вҲЁ-assoc)
    l .is-lattice.вҲ§-comm = О”ВІ-ext (вҲ§-comm , вҲ§-comm)
    l .is-lattice.вҲЁ-comm = О”ВІ-ext (вҲЁ-comm , вҲЁ-comm)
    l .is-lattice.вҲЁ-вҲ§-abs = О”ВІ-ext (вҲЁ-вҲ§-abs , вҲЁ-вҲ§-abs)
    l .is-lattice.вҲ§-вҲЁ-abs = О”ВІ-ext (вҲ§-вҲЁ-abs , вҲ§-вҲЁ-abs)
    l .is-lattice.0-bottom = О”ВІ-ext (0-bottom , 0-bottom)
    l .is-lattice.1-top = О”ВІ-ext (1-top , 1-top)
}
}

\subtree[stt-00A6]{
\taxon{Lemma}
\title{#{L[x]} is an #{L}-algebra}

\p{The inclusion #{\iota : L \to L[x]} that takes an #{a : L} to #{ax \lor a}
exhibits #{L[x]} as an #{L}-algebra.}

\p{The only part of the proof which does not hold definitionally is showing:
##{\iota(x) \land \iota(y) = \iota(x \land y)}

Extensionality for the 2-simplex says that we can just compare coefficients. The
constant terms are definitionally equal, for the linear terms we need:
#{xy \lor yy \lox xy = xy}, but this follows from the idempotence and
commutativity of #{\lor}.}

\agda{
  Free-Lattice-is-lattice-algebra
    : is-lattice-hom L Free-Lattice (О№-const {L = L})
  Free-Lattice-is-lattice-algebra .is-lattice-hom.pres-вҲЁ
    = О”ВІ-ext (refl , refl)
  Free-Lattice-is-lattice-algebra .is-lattice-hom.pres-вҲ§
    = О”ВІ-ext (refl , refl)
  Free-Lattice-is-lattice-algebra .is-lattice-hom.pres-0
    = О”ВІ-ext (refl , refl)
  Free-Lattice-is-lattice-algebra .is-lattice-hom.pres-1
    = О”ВІ-ext (refl , refl)

  Free-Algebra : Algebra L (О”ВІ L)
  Free-Algebra .Algebra.str-Lattice = Free-Lattice
  Free-Algebra .Algebra.О№ = О№-const
  Free-Algebra .Algebra.О№-alg = Free-Lattice-is-lattice-algebra
}
}
}

\subtree[stt-00A7]{
\taxon{Theorem}
\title{[#{L[x]}](stt-009W) is the free #{L}-algebra on 1 generator}

\p{Let #{M} be some other #{L}-algebra. For each #{m : M}, there is an evident
map #{L[x] \to M} given by #{(ax \lor b) \mapsto \iota(a)m \lor \iota(b)};
we show this map is a [morphism of lattice algebras](stt-009Z).}

\agda{
  eval-polynomial : вҲҖ {рқ“Ө} {B : Type рқ“Ө} (M : Algebra L B)
                    вҶ’ B вҶ’ Coslice-map (Algebra.О№ Free-Algebra) (Algebra.О№ M)
  eval-polynomial M x .fst (aвӮҖ , aвӮҒ) = (M.О№ aвӮҖ M.вҲ§ x) M.вҲЁ M.О№ aвӮҒ
    where module M = Algebra M
  eval-polynomial M x .snd a = M.вҲЁ-comm вҲҷ M.вҲЁ-вҲ§-abs
    where module M = Algebra M

  eval-polynomial-is-alg-hom
    : вҲҖ {рқ“Ө} {B : Type рқ“Ө} (M : Algebra L B) (Md : is-distributive-algebra M )
    вҶ’ (b : B)
    вҶ’ is-lattice-alg-hom Free-Algebra M (eval-polynomial M b)
  eval-polynomial-is-alg-hom M Md x
    = mk-is-lattice-alg-hom l where
    module M = Algebra M
    module Md = is-distributive Md
    open is-lattice-hom


    l : is-lattice-hom Free-Lattice M.str-Lattice (fst (eval-polynomial M x))
    l .pres-0 =  M.вҲЁ-comm вҲҷ M.вҲЁ-вҲ§-abs вҲҷ M.О№-alg .pres-0
    l .pres-1 =  M.вҲЁ-comm вҲҷ M.вҲЁ-вҲ§-abs вҲҷ M.О№-alg .pres-1
    l .pres-вҲЁ {(aвӮҖ , aвӮҒ)} {(bвӮҖ , bвӮҒ)}
      = (вҢң M.О№ (aвӮҖ вҲЁ bвӮҖ)вҢқ M.вҲ§ x M.вҲЁ M.О№ (aвӮҒ вҲЁ bвӮҒ))
         пјқвҹЁ  apвӮӮ M._вҲЁ_ (ap! (M.О№-alg .pres-вҲЁ) вҲҷ Md.distrib-вҲ§-вҲЁ') (M.О№-alg .pres-вҲЁ)  вҹ©
        ((M.О№ aвӮҖ M.вҲ§ x M.вҲЁ M.О№ bвӮҖ M.вҲ§ x) M.вҲЁ M.О№ aвӮҒ M.вҲЁ M.О№ bвӮҒ)
          пјқвҹЁ sym M.вҲЁ-assoc вҹ©
        (M.О№ aвӮҖ M.вҲ§ x M.вҲЁ вҢң M.О№ bвӮҖ M.вҲ§ x M.вҲЁ M.О№ aвӮҒ M.вҲЁ M.О№ bвӮҒ вҢқ)
          пјқвҹЁ  ap! (M.вҲЁ-assoc вҲҷ apвӮӮ M._вҲЁ_ M.вҲЁ-comm refl вҲҷ sym M.вҲЁ-assoc) вҲҷ M.вҲЁ-assoc вҹ©
        ((M.О№ aвӮҖ M.вҲ§ x M.вҲЁ M.О№ aвӮҒ) M.вҲЁ M.О№ bвӮҖ M.вҲ§ x M.вҲЁ M.О№ bвӮҒ) вҲҺ
    l .pres-вҲ§ {(aвӮҖ , aвӮҒ)} {(bвӮҖ , bвӮҒ)}
      = apвӮӮ M._вҲЁ_ (ap (M._вҲ§ x) (M.О№-alg .pres-вҲ§)) (M.О№-alg .pres-вҲ§)
        вҲҷ sym (Md.polynomial-mult'-вүӨ x)
      where
      open is-lattice-hom M.О№-alg
}

\p{We exhibit #{L[x]} as the free algebra by showing that every
morphism of algebras arises this way. Or more formally, that the bundled map
from elements of #{M} to algebra morphisms #{L[x] \to M} is an equivalence.}

\agda{
  Free-Algebra-ev-algebra-hom
    : вҲҖ {рқ“Ө} {B : Type рқ“Ө} (M : Algebra L B) (Md : is-distributive-algebra M)
      вҶ’ B вҶ’ LatticeAlgHom Free-Algebra M
  Free-Algebra-ev-algebra-hom M Md b
    = (eval-polynomial M b , eval-polynomial-is-alg-hom M Md b)

  Free-Algebra-is-free-algebra
    : вҲҖ {рқ“Ө} {B : Type рқ“Ө} (A : Algebra L B) (Ad : is-distributive-algebra A)
      вҶ’ is-equiv (Free-Algebra-ev-algebra-hom A Ad )
  Free-Algebra-is-free-algebra M Md = is-equivвҶҗqinv qinv where
    module M = Algebra M
    module Md = is-distributive Md
    module L[x] = Lattice Free-Lattice
    open is-lattice-hom

    qinv : quasi-inv (Free-Algebra-ev-algebra-hom M Md)
    qinv .fst (map , ishom) = map .fst (1l , 0l) -- f вҶҰ f(1)
    qinv .snd .fst b = ap ((M.О№ 1l M.вҲ§ _) M.вҲЁ_) (M.О№-alg .pres-0)
                     вҲҷ M.0-bottom вҲҷ M.вҲ§-comm вҲҷ ap (b M.вҲ§_) (M.О№-alg .pres-1)
                     вҲҷ M.1-top
    qinv .snd .snd ((f , K) , isalghom) = ext! H
      where
        ishom : is-lattice-hom (Algebra.str-Lattice Free-Algebra) M.str-Lattice f
        ishom = un-is-lattice-alg-hom isalghom

        H : ((a , b) : О”ВІ L)
          вҶ’ M.О№ a M.вҲ§ f (1l , 0l) M.вҲЁ M.О№ b пјқ f (a , b)
        H ((a , b) вҰғ p вҰ„)
          = (M.О№ a M.вҲ§ f (1l , 0l) M.вҲЁ M.О№ b)
              пјқвҹЁ apвӮӮ M._вҲЁ_ (ap (M._вҲ§ _) (sym (K a))) (sym (K b)) вҹ©
            f (a , a) M.вҲ§ f (1l , 0l) M.вҲЁ f (b , b)
              пјқвҹЁ ap (M._вҲЁ _) (sym (ishom .pres-вҲ§)) вҹ©
            (f вҢң (a , a) L[x].вҲ§ (1l , 0l) вҢқ M.вҲЁ f (b , b))
              пјқвҹЁ ap! (О”ВІ-ext (auto! , вҲ§-comm вҲҷ 0-init)) вҹ©
            (f (a , 0l) M.вҲЁ f (b , b))
              пјқвҹЁ sym (ishom .pres-вҲЁ) вҹ©
            (f ((a , 0l) L[x].вҲЁ (b , b)))
              пјқвҹЁвҹ©
            f ((a вҲЁ b) , (0l вҲЁ b))
              пјқвҹЁ ap f (О”ВІ-ext ((вҲЁ-comm вҲҷ вүӨ-max p) , вҲЁ-comm вҲҷ 0-bottom)) вҹ©
            f (a , b) вҲҺ
}
}

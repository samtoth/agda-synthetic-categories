\date{2026-04-24}
\title{Integers}
\author{fredrikbakke}
\taxon{Module}

\import{stt-macros}

\agda{
module Foundations.Int where

open import Foundations.Universes
open import Foundations.Nat
}

\subtree[stt-00N8]{
\date{2026-04-24}
\author{fredrikbakke}
\title{Integers}
\taxon{Definition}

\agda{
data ℤ : Type where
  pos    : ℕ → ℤ
  negsuc : ℕ → ℤ

{-# BUILTIN INTEGER       ℤ      #-}
{-# BUILTIN INTEGERPOS    pos    #-}
{-# BUILTIN INTEGERNEGSUC negsuc #-}
}
}

\subtree[stt-00NO]{
\title{Negation of natural numbers}
\taxon{Definition}
\author{fredrikbakke}
\date{2026-04-24}

\agda{
neg-ℕ : ℕ → ℤ
neg-ℕ zero = pos zero
neg-ℕ (suc n) = negsuc n
}
}

\subtree[stt-00ET]{
\taxon{Theorem}
\title{The equivalence of straightened pullback powers}
\author{fredrikbakke}


\p{Given families #{B : A \to \UU} and #{Y : (a : A) \to X a \to \UV}, their
fibrewise dependent pullback power is equivalent, as a family, to the straightening
of the dependent pullback power of total space projections.

##{\pulldpow^{\mathrm f} B\ Y \simeq \pulldpow_{\text{straight}} B\ Y}
}

%```agda
\agda{
module _
  {ً‌“¤1 ً‌“¤2 ً‌“¤3 ً‌“¤4}
  (B'@(A , B) : Fam ً‌“¤1 ً‌“¤2)
  (Y'@(X , Y) : DepFam ً‌“¤3 ً‌“¤4 B')
  (let fلµک = fst {A = A} {B = B})
  (let gلµک = خ» a â†’ fst {A = X a} {B = Y a})
  (let Bلµکث¢ = fibre-fam fلµک)
  (let Yلµکث¢ = fibre-depfam gلµک)
  where

  خ ج‚-straight
    : Fam (ً‌“¤1 âٹ” ً‌“¤2 âٹ” ً‌“¤3 âٹ” ً‌“¤4) (ً‌“¤1 âٹ” ً‌“¤2 âٹ” ً‌“¤3 âٹ” ً‌“¤4)
  خ ج‚-straight = خ ج‚-fibre-fam fلµک gلµک

  خ ج‚ل¶ -fibre-fam-unstraight
    : Fam (ً‌“¤1 âٹ” ً‌“¤2 âٹ” ً‌“¤3 âٹ” ً‌“¤4) (ً‌“¤1 âٹ” ً‌“¤2 âٹ” ً‌“¤4)
  خ ج‚ل¶ -fibre-fam-unstraight = خ ج‚ل¶  Bلµکث¢ Y'

  خ ج‚ل¶ -unstraight-fibre-famâ‰ƒخ ج‚ل¶ -fibre-fam-unstraight
    : خ ج‚ل¶ -unstraight-fibre-fam fلµک gلµک â‰ƒل¶  خ ج‚ل¶ -fibre-fam-unstraight
  خ ج‚ل¶ -unstraight-fibre-famâ‰ƒخ ج‚ل¶ -fibre-fam-unstraight
    = خ ج‚ل¶ -ap-â‰ƒلµˆل¶  Bلµکث¢ Yلµکث¢ Y' (خ» a â†’ (idequiv , fibre-straighten (Y a)))

  خ ج‚ل¶ -fibre-fam-unstraightâ‰ƒخ ج‚ل¶ 
    : خ ج‚ل¶ -fibre-fam-unstraight â‰ƒل¶  خ ج‚ل¶  B' Y'
  خ ج‚ل¶ -fibre-fam-unstraightâ‰ƒخ ج‚ل¶ 
    = خ ج‚ل¶ -ap-base-fam Y' (fibre-straighten B)

  خ ج‚ل¶ -unstraight-fibre-famâ‰ƒخ ج‚ل¶ 
    : خ ج‚ل¶ -unstraight-fibre-fam fلµک gلµک â‰ƒل¶  خ ج‚ل¶  B' Y'
  خ ج‚ل¶ -unstraight-fibre-famâ‰ƒخ ج‚ل¶ 
    = concatâ‰ƒل¶ 
        (خ ج‚ل¶  B' Y')
        (خ ج‚ل¶ -unstraight-fibre-famâ‰ƒخ ج‚ل¶ -fibre-fam-unstraight)
        (خ ج‚ل¶ -fibre-fam-unstraightâ‰ƒخ ج‚ل¶ )

  خ ج‚-straightâ‰ƒخ ج‚ل¶ -unstraight-fibre-fam : خ ج‚-straight â‰ƒل¶  خ ج‚ل¶ -unstraight-fibre-fam fلµک gلµک
  خ ج‚-straightâ‰ƒخ ج‚ل¶ -unstraight-fibre-fam
    = concatâ‰ƒل¶ 
        (خ ج‚ل¶ -unstraight-fibre-fam fلµک gلµک)
        (خ ج‚-unstraightenâ‰ƒل¶  fلµک gلµک)
        (خ ج‚-unstraight-fibre-famâ‰ƒخ ج‚ل¶ -unstraight-fibre-fam fلµک gلµک)

  خ ج‚-straightenâ‰ƒل¶  : خ ج‚-straight â‰ƒل¶  خ ج‚ل¶  B' Y'
  خ ج‚-straightenâ‰ƒل¶ 
    = concatâ‰ƒل¶ 
        (خ ج‚ل¶  B' Y')
        (خ ج‚-straightâ‰ƒخ ج‚ل¶ -unstraight-fibre-fam)

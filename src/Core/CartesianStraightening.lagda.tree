\subtree[stt-008N]{
\date{2025-08-03}
\title{Cartesian maps of spans}
\taxon{Definition}

\p{A map between spans is said to be cartesian when each square
is [cartesian](stt-003V) (i.e. a pullback square).}

%```agda
\agda{
is-cartesian-span-map
  : вҲҖ {рқ“Ө рқ“Ҙ рқ“Ұ} {S : Span рқ“Ө рқ“Ҙ рқ“Ұ}
      {рқ“Ө' рқ“Ҙ' рқ“Ұ'} {S' : Span рқ“Ө' рқ“Ҙ' рқ“Ұ'}
    вҶ’ Span-map S S' вҶ’ Type (рқ“Ө вҠ” рқ“Ҙ вҠ” рқ“Ұ вҠ” рқ“Ө' вҠ” рқ“Ҙ' вҠ” рқ“Ұ')
is-cartesian-span-map F = is-cartesian amap-l Г— is-cartesian amap-r
  where open Span-map F

is-cartesian-span-map-is-prop
  : вҲҖ {рқ“Ө рқ“Ҙ рқ“Ұ} {S : Span рқ“Ө рқ“Ҙ рқ“Ұ}
      {рқ“Ө' рқ“Ҙ' рқ“Ұ'} {S' : Span рқ“Ө' рқ“Ҙ' рқ“Ұ'}
      {F : Span-map S S'}
    вҶ’ is-prop (is-cartesian-span-map F)
is-cartesian-span-map-is-prop
  = is-prop-ОЈ
      is-cartesian-is-prop
      (О» _ вҶ’ is-cartesian-is-prop)
}
%```
}


\subtree[stt-008Q]{
\title{Maps in #{\rm{Cart}(S)}}

%```agda
\agda{
record Cart {рқ“Ө рқ“Ҙ рқ“Ұ} (Sp : Span рқ“Ө рқ“Ҙ рқ“Ұ) рқ“Ө' рқ“Ҙ' рқ“Ұ'
         : Type (lsuc (рқ“Ө вҠ” рқ“Ҙ вҠ” рқ“Ұ вҠ” рқ“Ө' вҠ” рқ“Ҙ' вҠ” рқ“Ұ')) where
   constructor mk-cart
   field
     S' : Span рқ“Ө' рқ“Ҙ' рқ“Ұ'
     proj : Span-map S' Sp
     has-is-cartesian : is-cartesian-span-map proj

   open Span S' public
   open Span-map proj public


unquoteDecl Cart-reprвү… Cart-reprвүғ
  = make-record-repr Cart-reprвү… Cart-reprвүғ (quote Cart)
}
%```

\p{Given a span #{S} and a pair of cartesian span maps #{S'} and #{S''}
over #{S}, we define the type of maps between #{S'} and #{S''}.
In other words we consider the full subcategory of the slice category
of #{\rm{Span}} consisting of [cartesian span maps](stt-008N).}

\quiver{
\begin{tikzcd}
	&&&& {B'} \\
	&&&&&&&& {B''} \\
	&& {S'} &&&& B \\
	&&&&&& {S''} \\
	{A'} &&&& S \\
	&&&& {A''} \\
	&& A
	\arrow[from=1-5, to=2-9]
	\arrow[from=1-5, to=3-7]
	\arrow[from=2-9, to=3-7]
	\arrow[from=3-3, to=1-5]
	\arrow[from=3-3, to=4-7]
	\arrow[from=3-3, to=5-1]
	\arrow[from=3-3, to=5-5]
	\arrow[from=4-7, to=2-9]
	\arrow[from=4-7, to=5-5]
	\arrow[from=4-7, to=6-5]
	\arrow[from=5-1, to=6-5]
	\arrow[from=5-1, to=7-3]
	\arrow[from=5-5, to=3-7]
	\arrow[from=5-5, to=7-3]
	\arrow[from=6-5, to=7-3]
\end{tikzcd}
}

%```agda
\agda{
module _ {рқ“Ө рқ“Ҙ рқ“Ұ} {S : Span рқ“Ө рқ“Ҙ рқ“Ұ} where
  Cart-pathвҶ’ : вҲҖ {рқ“Ө' рқ“Ҙ' рқ“Ұ'}
              вҶ’ {C C' : Cart S рқ“Ө' рқ“Ҙ' рқ“Ұ'}
              вҶ’ (p : C .Cart.S' пјқ C' .Cart.S')
              вҶ’ IdбөҲ (ap (О» p вҶ’ Span-map p S) p)
                    (C .Cart.proj)
                    (C' .Cart.proj)
              вҶ’ C пјқ C'
  Cart-pathвҶ’ {C = C} {mk-cart S' proj cart} refl refl
    = ap (mk-cart S' proj) (is-cartesian-span-map-is-prop _ _)


  record Cart-map {рқ“Ө' рқ“Ҙ' рқ“Ұ' рқ“Ө'' рқ“Ҙ'' рқ“Ұ''}
                  (S' : Cart S рқ“Ө' рқ“Ҙ' рқ“Ұ')
                  (S'' : Cart S рқ“Ө'' рқ“Ҙ'' рқ“Ұ'')
                  : Type (рқ“Ө вҠ” рқ“Ҙ вҠ” рқ“Ұ вҠ” рқ“Ө' вҠ” рқ“Ҙ' вҠ” рқ“Ұ' вҠ” рқ“Ө'' вҠ” рқ“Ҙ'' вҠ” рқ“Ұ'') where
    constructor mk-cart-map
    no-eta-equality
    module S' = Cart S'
    module S'' = Cart S''
    field
      map : Span-map (S'.S') (S''.S')

    module map = Span-map map

    field
      hвӮҒ-comm : S'.hвӮҒ ~ S''.hвӮҒ вҲҳ map.hвӮҒ
      hвӮӮ-comm : S'.hвӮӮ ~ S''.hвӮӮ вҲҳ map.hвӮӮ
      hвӮғ-comm : S'.hвӮғ ~ S''.hвӮғ вҲҳ map.hвӮғ

  Cart-map-is-equiv
    : вҲҖ {рқ“Ө' рқ“Ҙ' рқ“Ұ' рқ“Ө'' рқ“Ҙ'' рқ“Ұ''}
        {S' : Cart S рқ“Ө' рқ“Ҙ' рқ“Ұ'} {S'' : Cart S рқ“Ө'' рқ“Ҙ'' рқ“Ұ''}
      вҶ’ Cart-map S' S'' вҶ’ Type (рқ“Ө' вҠ” рқ“Ҙ' вҠ” рқ“Ұ' вҠ” рқ“Ө'' вҠ” рқ“Ҙ'' вҠ” рқ“Ұ'')
  Cart-map-is-equiv F = is-Span-equiv map where open Cart-map F

  -- Cart-uaвҶ’ F (feq , geq , heq)
  --   = Cart-pathвҶ’ (Span-pathвҶ’ (ua (mkвүғ _ geq)) (ua (mkвүғ _ feq)) (ua (mkвүғ _ heq))
  --                (ap (_вҲҳ _) coe-ua вҲҷ funextвҶ’ map.K вҲҷ  sym (ap (map.S'.right вҲҳ_) coe-ua))
  --                (ap (_вҲҳ _) coe-ua вҲҷ funextвҶ’ map.H вҲҷ sym (ap (map.S'.left вҲҳ_) coe-ua)))
  --                (span-map-pathPвҶ’ (ua (mkвүғ _ geq)) (ua (mkвүғ _ feq)) _ _ _
  --                  (funextвҶ’ (О» a вҶ’ hвӮҒ-comm a вҲҷ sym (ap S''.hвӮҒ (happly coe-ua a))))
  --                  (funextвҶ’ (О» a вҶ’ hвӮӮ-comm a вҲҷ sym (ap S''.hвӮӮ (happly coe-ua a))))
  --                  (funextвҶ’ (О» a вҶ’ hвӮғ-comm a вҲҷ sym (ap S''.hвӮғ (happly coe-ua a))))
  --                  (funextвҶ’ (О» a вҶ’ {!!}))
  --                  {!!}) where
  -- open Cart-map F
}
%```

\p{By the pullback pasting property the span map at the top is
cartesian when the two side maps are.}
}

\subtree[stt-008P]{
\title{Straightening cartesian span maps}
\taxon{Lemma}
\citet{2.2.7}{rijke-2018}

\p{Given a span #{S}, we can define a map #{\rm{Cocone}(C,\UU) \to
\rm{Cart}(S)} - where #{\rm{Cart}(S)} is the type of spans #{S'}
together with a cartesian span map down into #{S}.}

%```agda
\agda{
module _ {рқ“Ө рқ“Ҙ рқ“Ұ} {Sp : Span рқ“Ө рқ“Ҙ рқ“Ұ}  where
  open Span Sp renaming (Centre to S;
                         left to f;
                         right to g;
                         Left to A;
                         Right to B) using ()


  cartвҶҗcocone : вҲҖ {рқ“ң} вҶ’ Cocone Sp (Type рқ“ң) вҶ’ Cart Sp (рқ“Ө вҠ” рқ“ң) (рқ“Ҙ вҠ” рқ“ң) (рқ“Ұ вҠ” рқ“ң)
  cartвҶҗcocone cc = mk-cart span proj cart where
    open Cocone cc renaming (p to Pa; q to Pb)

    span : Span _ _ _
    span .Span.Centre = ОЈ[ s вҲ¶ S ] Pb (g s)
    span .Span.Left = ОЈ A Pa
    span .Span.left a = (f (fst a) , coe (sym (filler (a .fst))) (a .snd) )
    span .Span.Right = ОЈ B Pb
    span .Span.right x = (g (fst x) , snd x)

    proj : Span-map span Sp
    proj .Span-map.hвӮҒ = fst
    proj .Span-map.hвӮӮ = fst
    proj .Span-map.hвӮғ = fst
    proj .Span-map.H = ~refl
    proj .Span-map.K = ~refl

    pbl : is-equiv (gap (mk-cone fst (span .Span.left) ~refl))
    pbl = is-equivвҶҗqiso qiso where
      qiso : quasi-iso (gap _)
      qiso .fst (s , (a , pa) , refl) = s , coe (filler s) pa
      qiso .snd .fst (s , pb) = ОЈ-pathвҶ’ (refl , (coe-sym (filler s)))
      qiso .snd .snd (s , (a , pa) , refl)
        = ОЈ-pathвҶ’ (refl
        , (ОЈ-pathвҶ’ (
        (ОЈ-pathвҶ’ (refl , (coe-sym' (filler s))))
        ,  IdбөҲ-funcвҶҗSquare
            {f = О» y вҶ’ f s} {fst}
            (ОЈ-pathвҶ’ (refl , coe-sym' (filler s))) refl refl
            (mk-square (вҲҷ-reflr _ вҲҷ ap-const _ вҲҷ sym ОЈ-path-ap-fst) ))))

    pbr : is-equiv (gap (mk-cone fst (span .Span.right) ~refl))
    pbr = is-equivвҶҗqiso qiso where
      qiso : quasi-iso (gap _)
      qiso .fst (s , (b , pb) , refl) = s , pb
      qiso .snd .fst = ~refl
      qiso .snd .snd (s , (b , pb) , refl) = refl


    opaque
      cart : is-cartesian-span-map proj
      cart .fst = is-cartesianвҶҗis-pullback _ (is-pullbackвҶҗgap _ pbl)
      cart .snd = is-cartesianвҶҗis-pullback _ (is-pullbackвҶҗgap _ pbr)
}
%```

\p{If the types in the span all live in a univalent unvirse #{\UU},
then this map is an equivalence.}

\proof{
\p{The type #{\rm{Cart}(S)} consists of the data:}

\ul{
\li{A span #{A' \xleftarrow{f} S' \xrightarrow{g} B'}}
\li{Maps #{h_A}, #{h_S}, #{h_B}}
\li{Homotopies #{H} and #{K}, witnessing the two squares involved commute}
\li{Proofs #{p_f} and #{p_g} witnessing that the squares are cartesian}
}

\p{We first note that the tuples #{f, H, p_f} and #{g,K,p_g} are
equivalent to fibrewise equivalences
#{\Pi_{(x : S)} \fibre{h_s}{x} \simeq \fibre{h_A}{f(x)}} (and
respectively for #{g}). We then also pass #{(A', h_A)}, #{(S', h_S)}
and #{(B',h_B)} across the straightning/unstraitening equivalences.
Resulting in the following data:}

\ul{
\li{#{Q : S \to \UU}}
\li{#{P_A : A \to \UU}}
\li{#{P_B : B \to \UU}}
\li{#{\Pi_{(x : S)} Q(x) \simeq P_A(f(x))}}
\li{#{\Pi_{(x : S)} Q(x) \simeq P_B(g(x))}}
}

\p{Now, by univalence, the first and last data together are
contractible, and so this is equivalent to the #{S} cocones at #{\UU}.
All that remains is to show that the map underlying this equivalence
is homotopic to the map we had preveously constructed.}
}

%```agda
\agda{
module _ {рқ“Ө} {Sp : Span рқ“Ө рқ“Ө рқ“Ө}  where
  bundle-map : вҲҖ {A B : Type рқ“Ө} (f : A вҶ’ B)
                    вҶ’ Bundle A вҶ’ Bundle B вҶ’ Type рқ“Ө
  bundle-map f (A' , pa) (B' , pb)
    = ОЈ[ f' вҲ¶ (A' вҶ’ B') ] (pb вҲҳ f' ~ f вҲҳ pa)

  amapвҶҗbmap : вҲҖ {A B : Type рқ“Ө} (f : A вҶ’ B)
                    (A' : Bundle A) (B' : Bundle B)
                  вҶ’ bundle-map f A' B'
                  вҶ’ Arrow-map
                      (A' .snd)
                      (B' .snd)
  amapвҶҗbmap f (A' , pa) (B' , pb) (f' , H)
      = mk-amap f' f (H ~вҒ»В№)

  is-cartesian-bmap
    : вҲҖ {A B : Type рқ“Ө} {f : A вҶ’ B} {A' : Bundle A} {B' : Bundle B}
      вҶ’ bundle-map f A' B' вҶ’ Type рқ“Ө
  is-cartesian-bmap {f = f} {(_ , pa)} {(_ , pb)} bmap
    = is-cartesian {f = pa} {f' = pb} (amapвҶҗbmap f _ _ bmap)

  tofib : вҲҖ {A B : Type рқ“Ө} {f : A вҶ’ B} {A' : Bundle A} {B' : Bundle B}
          вҶ’ (bundle-map f A' B')
          вүғ (вҲҖ b вҶ’ fibre (A' .snd) b вҶ’ fibre (B' .snd) (f b))
  tofib {A} {B}{f} {(A' , pa)} {(B' , pb)}
    = equivвҶҗqiso (mk-iso to (from , ret , sec)) where
    to : _ вҶ’ _
    to F = arrow-fibre (amapвҶҗbmap _ _ _ F)

    from : _ вҶ’ _
    from feq = ОЈ-О -swap {X = A'} (О» _ вҶ’ B')
                        (О» a fa вҶ’ pb fa пјқ f (pa a))
                        (О» x вҶ’ feq (pa x) (x , refl))

    ret : (a : bundle-map f _ (B' , pb)) вҶ’ (from вҲҳ to) a пјқ a
    ret (f , H) = ОЈ-pathвҶ’ (refl , (funextвҶ’ (О» a вҶ’ вҲҷ-reflr _ вҲҷ sym-sym)))

    sec : _
    sec f = funextвҶ’ (О» a вҶ’ funextвҶ’ (О» where
      (a , refl) вҶ’ ОЈ-pathвҶ’ (refl , (вҲҷ-reflr _ вҲҷ sym-sym))))

  tofibeq : вҲҖ {A B : Type рқ“Ө} {f : A вҶ’ B} {A' : Bundle A} {B' : Bundle B}
           вҶ’ (вҲҖ b вҶ’ fibre (A' .snd) b вүғ fibre (B' .snd) (f b))
           вҶ’ (ОЈ[ F вҲ¶ bundle-map f A' B' ] is-cartesian-bmap {f = f}{A'}{B'} F)
  tofibeq {f = f}{A'}{B'} fmap
    = (_вүғ_.bwd tofib (fmap.fwd) , eq' fmap.has-is-eqv) module tofibeq' where
    module fmap a = _вүғ_ (fmap a)

    from-fmap : (вҲҖ b вҶ’ fibre (A' .snd) b вҶ’ fibre (B' .snd) (f b))
              вҶ’ bundle-map f A' B'
    from-fmap = _вүғ_.bwd tofib

    lem : вҲҖ f' a вҶ’ f' a ~ arrow-fibre (amapвҶҗbmap f A' B' (from-fmap f')) a
    lem f' a = happly (happly (_вүғ_.Оө tofib f') a) ~вҒ»В№

    opaque
      eq' : {f' : вҲҖ b вҶ’ fibre (A' .snd) b вҶ’ fibre (B' .snd) (f b)}
          вҶ’ is-fibrewise-equiv f'
          вҶ’ is-cartesian-bmap {f = f}{A'}{B'} (from-fmap f')
      eq' {f'} feq a = homotopy-is-equiv (lem f' a) (feq a)

  tofibeqвүғ : вҲҖ {A B : Type рқ“Ө} {f : A вҶ’ B} {A' : Bundle A} {B' : Bundle B}
          вҶ’ (ОЈ[ F вҲ¶ bundle-map f A' B' ] is-cartesian-bmap {f = f}{A'}{B'} F)
          вүғ (вҲҖ b вҶ’ fibre (A' .snd) b вүғ fibre (B' .snd) (f b))
  tofibeqвүғ {A}{B}{f}{(A' , pa)}{(B' , pb)}
    = ОЈ (bundle-map f _ (B' , pb)) (is-cartesian-bmap {f = f}{_}{B' , pb})
        вүғвҹЁ ОЈ-ap-вүғ-fst tofib вҹ©
      (ОЈ[ f' вҲ¶ (вҲҖ b вҶ’ fibre pa b вҶ’ fibre pb (f b))] is-fibrewise-equiv f')
        вүғвҹЁ fibrewise-equivвүғ вҹ©
      ((b : A) вҶ’ fibre pa b вүғ fibre pb (f b)) вүғвҲҺ

  tofibeq-is-equiv : вҲҖ {A B : Type рқ“Ө} {f : A вҶ’ B} {A' : Bundle A}
                       {B' : Bundle B}
                     вҶ’ is-equiv (tofibeq {f = f} {A'}{B'})
  tofibeq-is-equiv = homotopy-is-equiv tofibeq~ (is-equivвҒ»В№ (tofibeqвүғ ._вүғ_.has-is-eqv)) where

    tofibeq~ : вҲҖ {A B : Type рқ“Ө} {f : A вҶ’ B} {A' : Bundle A} {B' : Bundle B}
              вҶ’ _вүғ_.bwd (tofibeqвүғ {f = f}{A'}{B'}) ~ tofibeq
    tofibeq~ fmap = ОЈ-pathвҶ’ (refl , (is-cartesian-is-prop _ _))

  strait-bundle
    : вҲҖ {A B} {f : A вҶ’ B} (A' : Bundle A)
    вҶ’ (ОЈ[ B' вҲ¶ Bundle B ] ОЈ (bundle-map f A' B') (is-cartesian-bmap {f = f}{A'} {B'}))
    вүғ (ОЈ[ Q вҲ¶ (B вҶ’ Type рқ“Ө)] (вҲҖ a вҶ’ fibre (A' . snd) a пјқ Q (f a)))
  strait-bundle {A}{B}{f} Ab@(A' , pa)
    = (ОЈ[ B' вҲ¶ (Bundle B) ]
        ОЈ (bundle-map f Ab B') (is-cartesian-bmap {f = f}{Ab}{B'}))
        вүғвҹЁ ОЈ-ap-вүғ (О» bun вҶ’ tofibeqвүғ) вҹ©
      (ОЈ[ B' вҲ¶ (Bundle B)] (вҲҖ a вҶ’ fibre pa a вүғ fibre (B' .snd) (f a)))
        вүғвҹЁ ОЈ-ap-вүғ-fst {B = О» Q вҶ’ вҲҖ a вҶ’ fibre pa a вүғ Q (f a)} straightenвүғ вҹ©
      (ОЈ[ Q вҲ¶ (B вҶ’ Type рқ“Ө)] ((a : A) вҶ’ fibre pa a вүғ Q (f a)))
        вүғвҹЁ ОЈ-ap-вүғ (О» Q вҶ’ postcomp-О -вүғ (О» c вҶ’ uaвүғ)) вҹ©
      ОЈ (B вҶ’ Type рқ“Ө) (О» Q вҶ’ (a : A) вҶ’ fibre pa a пјқ Q (f a)) вүғвҲҺ

  strait-bundle-map : вҲҖ {A B} {f : A вҶ’ B} (A' : Bundle A)
                    вҶ’ (ОЈ[ B' вҲ¶ Bundle B ] ОЈ (bundle-map f A' B') (is-cartesian-bmap {f = f}{A'}{B'}))
                    вҶ’ ОЈ[ Q вҲ¶ (B вҶ’ Type рқ“Ө)] ((a : A) вҶ’ fibre (A' .snd) a пјқ Q (f a))
  strait-bundle-map {f = f} A' (B' , bm , cart)
    = (straighten B' , О» a вҶ’ ua (mkвүғ _ (cart a)))


  strait-bundle-map' : вҲҖ {A B} {f : A вҶ’ B} (A' : Bundle A)
                    вҶ’ ОЈ[ Q вҲ¶ (B вҶ’ Type рқ“Ө)] ((a : A) вҶ’ fibre (A' .snd) a пјқ Q (f a))
                    вҶ’ ОЈ[ B' вҲ¶ Bundle B ] ОЈ (bundle-map f A' B') (is-cartesian-bmap {f = f}{A'}{B'})
  strait-bundle-map' {f = f} A' (Q , fmap)
    = (unstraighten Q)
    , tofibeq О» a вҶ’ coeвүғ (fmap a) вҲҷвүғ (fibre-straighten Q (f a)) eвҒ»В№
    where module fmap a = _вүғ_ (coeвүғ (fmap a))

  strait-bundle-map-is-equiv : вҲҖ {A B} {f : A вҶ’ B}
                                 (A' : Bundle A)
                               вҶ’ is-equiv (strait-bundle-map' {f = f} A')
  strait-bundle-map-is-equiv {f = f} A' = is-equiv-вҲҳ (total-is-equivвҶҗfst-is-equiv (is-equivвҒ»В№ straighten-is-equiv))
                                          (is-total-equivвҶҗis-fibrewise-equiv (О» Pb
                                            вҶ’ is-equiv-вҲҳ
                                                tofibeq-is-equiv
                                                (lem Pb))) where
      map' : вҲҖ Pb вҶ’ (вҲҖ a вҶ’ fibre (A' .snd) a пјқ Pb (f a)) вҶ’ (вҲҖ b вҶ’ fibre (A' .snd) b вүғ fibre fst (f b))
      map' Pb fmap a = coeвүғ (fmap a) вҲҷвүғ (fibre-straighten Pb (f a)) eвҒ»В№

      mapinv : вҲҖ Pb вҶ’ (вҲҖ b вҶ’ fibre (A' .snd) b вүғ fibre fst (f b)) вҶ’ (вҲҖ a вҶ’ fibre (A' .snd) a пјқ Pb (f a))
      mapinv Pb feq a = ua (feq a вҲҷвүғ (fibre-straighten Pb (f a)))
      abstract
        lem : вҲҖ Pb вҶ’ is-equiv (map' Pb)
        lem Pb = is-equivвҶҗqiso О» where
          .fst вҶ’ mapinv Pb
          .snd .fst feq вҶ’ funextвҶ’ О» a вҶ’ ap ua (вҲҷвүғ-sym' (coeвүғ (feq a)) (fibre-straighten Pb (f a))) вҲҷ ua-coeвүғ
          .snd .snd feqv вҶ’ funextвҶ’ О» a вҶ’ ap (_вҲҷвүғ (fibre-straighten Pb (f a)) eвҒ»В№) coeвүғ-ua
                           вҲҷ вҲҷвүғ-sym (feqv a) (fibre-straighten Pb (f a))



  cartвҶҗcocone-is-equiv : is-equiv (cartвҶҗcocone {Sp = Sp} {рқ“Ө})
  cartвҶҗcocone-is-equiv = homotopy-is-equiv H cartвҶҗcocone'-is-equiv where
    open Span Sp renaming (Centre to S;
                           left to f;
                           right to g;
                           Left to A;
                           Right to B) using ()

    shuffle : Cart Sp рқ“Ө рқ“Ө рқ“Ө
            вүғ (ОЈ[ S' вҲ¶ Bundle S ] (
                 (ОЈ[ A' вҲ¶ Bundle A ] ОЈ (bundle-map f S' A') (is-cartesian-bmap {f = f}{S'} {A'}))
                 Г—
                 (ОЈ[ B' вҲ¶ Bundle B ] ОЈ (bundle-map g S' B') (is-cartesian-bmap {f = g}{S'}{B'}))))
    shuffle = mkвүғ map (is-equivвҶҗqiso map-qiso) where
      map : Cart Sp рқ“Ө рқ“Ө рқ“Ө вҶ’ _
      map (mk-cart
            (mk-span S' f' g')
            (mk-span-map hвӮҒ hвӮӮ hвӮғ H K)
            (pf , pg))
        = (S' , hвӮӮ)
        , ((_ , hвӮҒ) , ((f' , H) , pf))
        , ((_ , hвӮғ) , ((g' , K) , pg))

      bwd : _ вҶ’ Cart Sp рқ“Ө рқ“Ө рқ“Ө
      bwd ((S' , hвӮӮ)
          , ((A' , hвӮҒ) , ((f' , H) , pf))
          , ((B' , hвӮғ) , ((g' , K) , pg)))
          = mk-cart (mk-span S' f' g')
                    (mk-span-map hвӮҒ hвӮӮ hвӮғ H K)
                    (pf , pg)

      map-qiso : quasi-iso map
      map-qiso .fst = bwd
      map-qiso .snd .fst = ~refl
      map-qiso .snd .snd = ~refl

    unshuffle
      : (ОЈ[ Q вҲ¶ (S вҶ’ Type рқ“Ө)]
          ((ОЈ[ Pa вҲ¶ (A вҶ’ Type рқ“Ө)] (Q ~ Pa вҲҳ f))
           Г—
          (ОЈ[ Pb вҲ¶ (B вҶ’ Type рқ“Ө)] (Q пјқ Pb вҲҳ g))))
      вүғ Cocone Sp (Type рқ“Ө)
    unshuffle = mkвүғ map (is-equivвҶҗqiso qiso) where
      map : _ вҶ’ Cocone Sp (Type рқ“Ө)
      map (_ , ((Pa , H) , (Pb , refl)))
        = mk-cocone Pa Pb (sym вҲҳ H)

      unmap : Cocone Sp (Type рқ“Ө) вҶ’ _
      unmap (mk-cocone p q filler)
        = q вҲҳ g , ((p , sym вҲҳ filler) , (q , refl))

      ret : retraction-witness map unmap
      ret (S' , (Pb , H) , Pa , refl)
        = ОЈ-pathвҶ’ (refl , Г—-pathвҶ’ ( ОЈ-pathвҶ’ (refl
                                            , (funextвҶ’ (О» _ вҶ’ sym-sym)))
                                  , refl))

      qiso : quasi-iso map
      qiso .fst = unmap
      qiso .snd .fst = ret
      qiso .snd .snd (mk-cocone p q filler)
        = ap (mk-cocone p q) (funextвҶ’ (О» _ вҶ’ sym-sym))



    intermap : ОЈ[ Q вҲ¶ (S вҶ’ Type рқ“Ө)]
            ((ОЈ[ Pa вҲ¶ (A вҶ’ Type рқ“Ө)] (Q ~ Pa вҲҳ f))
              Г—
            (ОЈ[ Pb вҲ¶ (B вҶ’ Type рқ“Ө)] (Q пјқ Pb вҲҳ g)))
        вҶ’ ОЈ[ S' вҲ¶ Bundle S ]
           (ОЈ[ Pa вҲ¶ (A вҶ’ Type рқ“Ө)] (fibre (S' .snd) ~ Pa вҲҳ f)
             Г—
           ОЈ[ Pb вҲ¶ (B вҶ’ Type рқ“Ө)] (fibre (S' .snd) пјқ Pb вҲҳ g))
    intermap (Q , (Pa , H) , (Pb , K))
      = (unstraighten Q) , (Pa , (ua вҲҳ fibre-straighten Q ~вҲҷ H)) , (Pb ,  funextвҶ’ (ua вҲҳ fibre-straighten Q) вҲҷ K)

    intermap-is-equiv : is-equiv intermap
    intermap-is-equiv
      = is-equiv-вҲҳ
         (total-is-equivвҶҗfst-is-equiv (is-equivвҒ»В№ straighten-is-equiv))
         (is-total-equivвҶҗis-fibrewise-equiv (О»
           Q вҶ’ Г—вӮҒ-is-equiv
                 (is-total-equivвҶҗis-fibrewise-equiv О» Pa вҶ’ ~вҲҷ-is-equiv _)
                 (is-total-equivвҶҗis-fibrewise-equiv (О» Pb вҶ’ вҲҷ-is-equiv _)))) where
      intermap' : _ вҶ’ _
      intermap' = total-map-fst unstraighten {B = О» S' вҶ’
        (ОЈ[ Pa вҲ¶ (A вҶ’ Type рқ“Ө)] (fibre (S' .snd) ~ Pa вҲҳ f)
          Г—
         ОЈ[ Pb вҲ¶ (B вҶ’ Type рқ“Ө)] (fibre (S' .snd) пјқ Pb вҲҳ g))}
       вҲҳ total-map (О» Q вҶ’ total-map (О» Pa вҶ’ ua вҲҳ fibre-straighten Q ~вҲҷ_)
                        вҠ— total-map (О» Pb вҶ’ funextвҶ’ (ua вҲҳ fibre-straighten Q) вҲҷ_))


    intermap2 : ОЈ[ S' вҲ¶ Bundle S ]
                  (ОЈ[ Pa вҲ¶ (A вҶ’ Type рқ“Ө)] (fibre (S' .snd) ~ Pa вҲҳ f)
                    Г—
                   ОЈ[ Pb вҲ¶ (B вҶ’ Type рқ“Ө)] (fibre (S' .snd) пјқ Pb вҲҳ g))
           вҶ’ ОЈ[ S' вҲ¶ (Bundle S)]
                 ((ОЈ[ A' вҲ¶ Bundle A ] ОЈ (bundle-map f S' A') (is-cartesian-bmap {f = f}{S'}{A'}))
                 Г—
                 ((ОЈ[ B' вҲ¶ Bundle B ] ОЈ (bundle-map g S' B') (is-cartesian-bmap{f = g}{S'}{B'}))))
    intermap2 = total-map (О» bs вҶ’ strait-bundle-map' bs вҠ— (strait-bundle-map' bs вҲҳ total-map (О» _ вҶ’ happly)))

    intermap2-is-equiv : is-equiv intermap2
    intermap2-is-equiv = is-total-equivвҶҗis-fibrewise-equiv
      О» a вҶ’ Г—вӮҒ-is-equiv (strait-bundle-map-is-equiv a)
              (is-equiv-вҲҳ (strait-bundle-map-is-equiv a)
                          (is-total-equivвҶҗis-fibrewise-equiv (О» _ вҶ’ global-funext)))

    cartвҶҗcocone' : Cocone Sp (Type рқ“Ө) вҶ’ Cart Sp рқ“Ө рқ“Ө рқ“Ө
    cartвҶҗcocone' = _вүғ_.bwd shuffle
                 вҲҳ intermap2
                 вҲҳ intermap
                 вҲҳ _вүғ_.bwd unshuffle

    cartвҶҗcocone'-is-equiv : is-equiv cartвҶҗcocone'
    cartвҶҗcocone'-is-equiv
      =  is-equiv-вҲҳ (is-equivвҒ»В№ (shuffle ._вүғ_.has-is-eqv))
        (is-equiv-вҲҳ  intermap2-is-equiv
        (is-equiv-вҲҳ  intermap-is-equiv
                    (is-equivвҒ»В№ (unshuffle ._вүғ_.has-is-eqv))))

    H : cartвҶҗcocone' ~ cartвҶҗcocone
    H (mk-cocone Pa Pb filler)
      = cartвҶҗcocone' (mk-cocone Pa Pb filler) пјқвҹЁвҹ©
        (_вүғ_.bwd shuffle (intermap2 (intermap ((Pb вҲҳ g , ((Pa , filler ~вҒ»В№) , (Pb , refl)))))))   пјқвҹЁвҹ©
        (_вүғ_.bwd shuffle (intermap2 (((ОЈ _ (Pb вҲҳ g) , fst) , (Pa , (ua вҲҳ fibre-straighten (Pb вҲҳ g)) ~вҲҷ (filler ~вҒ»В№))
                            , (Pb , (funextвҶ’ (ua вҲҳ fibre-straighten (Pb вҲҳ g)) вҲҷ refl))))))
            пјқвҹЁ ap (О» p вҶ’ (_вүғ_.bwd shuffle (intermap2 (((ОЈ _ (Pb вҲҳ g) , fst) , (Pa , (ua вҲҳ fibre-straighten (Pb вҲҳ g)) ~вҲҷ (filler ~вҒ»В№))
                            , (Pb , p)))))) (вҲҷ-reflr (funextвҶ’ (ua вҲҳ fibre-straighten (Pb вҲҳ g)))) вҹ©

        (_вүғ_.bwd shuffle (intermap2 ((ОЈ _ (Pb вҲҳ g) , fst) , (Pa , (ua вҲҳ fibre-straighten (Pb вҲҳ g)) ~вҲҷ (filler ~вҒ»В№))
                                                          , (Pb , funextвҶ’ (ua вҲҳ fibre-straighten (Pb вҲҳ g))))))
            пјқвҹЁ ap (_вүғ_.bwd shuffle) lem5' вҹ©
        _вүғ_.bwd shuffle ((ОЈ _ (Pb вҲҳ g) , fst) ,
                             ((ОЈ _ Pa , fst) , (((О» a вҶ’ f (fst a) , coe (sym (filler (fst a))) (snd a)) , ~refl)) , PACART)
                             ,(ОЈ _ Pb , fst) , ((О» a вҶ’ g (fst a) , snd a) , ~refl) , _) пјқвҹЁ Cart-pathвҶ’ refl refl вҹ©
        cartвҶҗcocone (mk-cocone Pa Pb filler) вҲҺ where
      -- lem1 : strait-bundle-map' (ОЈ _ (Pb вҲҳ g) , fst) (Pa , (ua вҲҳ fibre-straighten (Pb вҲҳ g)) ~вҲҷ (filler ~вҒ»В№))
      --        пјқ ((ОЈ _ Pa , fst) , tofibeq' О» a вҶ’ coeвүғ (ua (fibre-straighten (Pb вҲҳ g) a) вҲҷ (sym (filler a))) вҲҷвүғ (fibre-straighten Pa (f a)) eвҒ»В№)
      -- lem1 = refl


      lem2 : вҲҖ a вҶ’ coeвүғ (ua (fibre-straighten (Pb вҲҳ g) a) вҲҷ (sym (filler a))) вҲҷвүғ (fibre-straighten Pa (f a)) eвҒ»В№
                 пјқ fibre-straighten (Pb вҲҳ g) a вҲҷвүғ coeвүғ (sym (filler a)) вҲҷвүғ (fibre-straighten Pa (f a)) eвҒ»В№
      lem2 a = ap (_вҲҷвүғ (fibre-straighten Pa (f a)) eвҒ»В№)
                 (вүғ-pathвҶ’ {e1 = coeвүғ (ua (fibre-straighten (Pb вҲҳ g) a) вҲҷ (sym (filler a)))}
                          {fibre-straighten (Pb вҲҳ g) a вҲҷвүғ coeвүғ (sym (filler a))}
                   (funextвҶ’ О» aвӮҒ
                     вҶ’ sym (coeвҲҷcoe (ua (fibre-straighten (Pb вҲҳ g) a)) (sym (filler a)) aвӮҒ) вҲҷ ap (coe (sym (filler a))) (happly coe-ua aвӮҒ)))

      -- lem3 : fst (tofibeq' (О» a вҶ’ fibre-straighten (Pb вҲҳ g) a вҲҷвүғ coeвүғ (sym (filler a)) вҲҷвүғ (fibre-straighten Pa (f a)) eвҒ»В№))
      --      пјқ (((О» a вҶ’ f (fst a) , coe (sym (filler (fst a))) (snd a)) , ~refl))
      -- lem3 = refl

      -- lem3' : happly (funextвҶ’ (ua вҲҳ fibre-straighten (Pb вҲҳ g))) пјқ ua вҲҳ fibre-straighten (Pb вҲҳ g)
      -- lem3' = refl

      -- lem4 : strait-bundle-map' (ОЈ _ (Pb вҲҳ g) , fst) (Pb , happly (funextвҶ’ (ua вҲҳ fibre-straighten (Pb вҲҳ g))))
      --        пјқ ((ОЈ _ Pb , fst) , tofibeq' О» a вҶ’ coeвүғ (ua (fibre-straighten (Pb вҲҳ g) a)) вҲҷвүғ (fibre-straighten Pb (g a)) eвҒ»В№)
      -- lem4 = refl

      lem4' : вҲҖ a вҶ’ coeвүғ (ua (fibre-straighten (Pb вҲҳ g) a)) вҲҷвүғ (fibre-straighten Pb (g a)) eвҒ»В№
                  пјқ (fibre-straighten (Pb вҲҳ g) a) вҲҷвүғ (fibre-straighten Pb (g a)) eвҒ»В№
      lem4' a = ap (_вҲҷвүғ (fibre-straighten Pb (g a)) eвҒ»В№) coeвүғ-ua

      lem4'' : вҲҖ a
               вҶ’ coeвүғ (happly (funextвҶ’ (ua вҲҳ fibre-straighten (Pb вҲҳ g))) a)
                 вҲҷвүғ (fibre-straighten Pb (g a)) eвҒ»В№
               пјқ (fibre-straighten (Pb вҲҳ g) a) вҲҷвүғ (fibre-straighten Pb (g a)) eвҒ»В№
      lem4'' a
        = ap (О» p вҶ’ coeвүғ p вҲҷвүғ (fibre-straighten Pb (g a)) eвҒ»В№)
             (happly funext-redex a)
        вҲҷ lem4' a

      -- lem5 : fst (tofibeq' О» a вҶ’ (fibre-straighten (Pb вҲҳ g) a) вҲҷвүғ (fibre-straighten Pb (g a)) eвҒ»В№)
      --        пјқ ((О» a вҶ’ (g (fst a)) , a .snd) , ~refl)
      -- lem5 = refl

      PACART : is-cartesian-bmap _
      PACART = tofibeq'.eq'
                    (О» a вҶ’
                      fibre-straighten (Pb вҲҳ g) a вҲҷвүғ coeвүғ (sym (filler a)) вҲҷвүғ fibre-straighten Pa (f a) eвҒ»В№)
                    (О» a вҶ’
                      _вүғ_.has-is-eqv (fibre-straighten (Pb вҲҳ g) a вҲҷвүғ coeвүғ (sym (filler a)) вҲҷвүғ fibre-straighten Pa (f a) eвҒ»В№))

      PBCART : is-cartesian-bmap _
      PBCART = tofibeq'.eq'
                  (О» aвӮҒ вҶ’
                     fibre-straighten (Pb вҲҳ g) aвӮҒ вҲҷвүғ fibre-straighten Pb (g aвӮҒ) eвҒ»В№)
                  (О» aвӮҒ вҶ’
                     _вүғ_.has-is-eqv
                     (fibre-straighten (Pb вҲҳ g) aвӮҒ вҲҷвүғ fibre-straighten Pb (g aвӮҒ) eвҒ»В№))

      lem5'' : strait-bundle-map' (ОЈ _ (Pb вҲҳ g) , fst)
                                  (Pa , (ua вҲҳ fibre-straighten (Pb вҲҳ g)) ~вҲҷ (filler ~вҒ»В№))
             пјқ ((ОЈ _ Pa , fst) , (((О» a вҶ’ f (fst a) , coe (sym (filler (fst a))) (snd a)) , ~refl)) , PACART)
      lem5'' = ОЈ-pathвҶ’ (refl , ap tofibeq (funextвҶ’ lem2))

      lem5''' : strait-bundle-map'
                  (ОЈ _ (Pb вҲҳ g) , fst)
                  (Pb , happly (funextвҶ’ (ua вҲҳ fibre-straighten (Pb вҲҳ g))))
              пјқ ((ОЈ _ Pb , fst) , ((О» a вҶ’ g (fst a) , snd a) , ~refl) , PBCART)
      lem5''' = ОЈ-pathвҶ’ (refl , (ap tofibeq (funextвҶ’ lem4'')))


      lem5' : intermap2 ( (ОЈ _ (Pb вҲҳ g) , fst)
                        , (Pa , (ua вҲҳ fibre-straighten (Pb вҲҳ g)) ~вҲҷ (filler ~вҒ»В№))
                        , (Pb , funextвҶ’ (ua вҲҳ fibre-straighten (Pb вҲҳ g))))
            пјқ ((ОЈ _ (Pb вҲҳ g) , fst)
               , ((ОЈ _ Pa , fst) , (((О» a вҶ’ f (fst a) , coe (sym (filler (fst a))) (snd a)) , ~refl)) , PACART)
               , (ОЈ _ Pb , fst) , ((О» a вҶ’ g (fst a) , snd a) , ~refl) , PBCART)
      lem5' = ОЈ-pathвҶ’ (refl , (Г—-pathвҶ’ (lem5'' , lem5''')))
}
%```
}



\subtree[stt-008O]{
\date{2025-08-03}
\title{Pulling back squares}
\taxon{Construction}

\p{Given span #{S}, and a cocone over #{S} centred at #{X}, we can
\em{'pull this square back'} along any map #{X' \to X}, to obtain a
span #{S'}, a cocone over #{S'} at #{X'} as well as a cartesian map
of spans #{S' \to S}.
}

%```agda
\agda{
module SquarePB {рқ“Ө рқ“Ҙ рқ“Ұ рқ“ң рқ“ӣ} {S : Span рқ“Ө рқ“Ҙ рқ“Ұ} {X : Type рқ“ң}
                (C : Cocone S X) {X' : Type рқ“ӣ} (f : X' вҶ’ X)
                where
  open Span S
  open Cocone C

  S' : Span (рқ“Ө вҠ” рқ“Ҙ вҠ” рқ“ң вҠ” рқ“ӣ) (рқ“Ҙ вҠ” рқ“ң вҠ” рқ“ӣ) (рқ“Ұ вҠ” рқ“ң вҠ” рқ“ӣ)
  S' .Span.Centre = Pullback {B = Pullback p f} fst left
  S' .Span.Left = Pullback p f
  S' .Span.left  = fst
  S' .Span.Right = Pullback q f
  S' .Span.right ((r , x , H) , c , K) = (right c  , x , sym (sym H вҲҷ ap p K вҲҷ filler c) )

  C' : Cocone S' X'
  C' .Cocone.p = pb.ПҖвӮӮ
  C' .Cocone.q = pb.ПҖвӮӮ
  C' .Cocone.filler _ = refl

  proj : Span-map S' S
  proj .Span-map.hвӮҒ = pb.ПҖвӮҒ
  proj .Span-map.hвӮӮ = pb.ПҖвӮӮ
  proj .Span-map.hвӮғ = pb.ПҖвӮҒ
  proj .Span-map.H  = pb.filler
  proj .Span-map.K _ = refl

  front-left : Arrow-map pb.ПҖвӮҒ f
  front-left = mk-amap pb.ПҖвӮӮ p pb.filler

  front-right : Arrow-map pb.ПҖвӮҒ f
  front-right = mk-amap pb.ПҖвӮӮ q pb.filler

  front-right-is-cart : is-cartesian (front-right)
  front-right-is-cart = is-cartesianвҶҗis-pullback _ pullback-is-pullback

  front-left-is-cart : is-cartesian front-left
  front-left-is-cart = is-cartesianвҶҗis-pullback _ pullback-is-pullback

  amap-lвҶ“-is-cart : is-cartesian (Span-map.amap-lвҶ“ proj)
  amap-lвҶ“-is-cart = is-cartesianвҶҗis-pullback _ pullback-is-pullback

  amap-l-is-cart : is-cartesian (Span-map.amap-l proj)
  amap-l-is-cart = rotate-is-cartesian _ amap-lвҶ“-is-cart

  square~ : Arrow-map-path
              (paste-squares front-left (Span-map.amap-l proj))
              (paste-squares front-right (Span-map.amap-r proj))
  square~ .fst = ~refl
  square~ .snd .fst = filler
  square~ .snd .snd ((l , x' , H) , c , refl)
    = вҲҷ-reflr _
    вҲҷ sym (ap (filler c вҲҷ_) (вҲҷ-symsym (sym H) (filler c))
          вҲҷ symвҲҷ (filler c) (sym (sym H))
          вҲҷ sym-sym)

  proj-is-cartesian : is-cartesian-span-map proj
  proj-is-cartesian .fst = amap-l-is-cart
  proj-is-cartesian .snd = 3-for-2-cartesian square~
    (compose-cartesian front-left-is-cart amap-l-is-cart)
    front-right-is-cart
}
%```
}

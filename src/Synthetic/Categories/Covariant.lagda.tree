\subtree[stt-00AY]{
\taxon{Definition}
\title{Covariant families}

\p{We say that a type family #{P : A \to \UU} is covariant if for any arrow #{f}
in #{A}, and term #{x_0} at #{P_{f(0)}}, the type of homs over #{f} which extend
#{x_0} is a singleton type.}

\p{Covariant families admit a directed transport.}

%```agda
\agda{
is-covariant : вҲҖ {рқ“Ө рқ“Ҙ} {A : Type рқ“Ө} (B : A вҶ’ Type рқ“Ҙ)
               вҶ’ Type (рқ“ҳ вҠ” рқ“Ө вҠ” рқ“Ҙ)
is-covariant {A = A} B
    = вҲҖ (x : О”В№ вҶ’ A) (xвӮҖ : B (x i0))
      вҶ’ is-singleton (ОЈ[ xвӮҒ вҲ¶ B (x i1)] HomбөҲ (B вҲҳ x) xвӮҖ xвӮҒ)

{-# INJECTIVE_FOR_INFERENCE is-covariant #-}

is-covariant-hom
  : вҲҖ {рқ“Ө рқ“Ҙ} {A : Type рқ“Ө} (B : A вҶ’ Type рқ“Ҙ)
    вҶ’ Type (рқ“ҳ вҠ” рқ“Ө вҠ” рқ“Ҙ)
is-covariant-hom {A = A} B
  = вҲҖ {x y} (f : Hom A x y) (x' : B x)
    вҶ’ is-singleton (ОЈ[ y' вҲ¶ B y ] Hom-over f x' y')

is-covariant-homвҶҗis-covariant
  : вҲҖ {рқ“Ө рқ“Ҙ} {A : Type рқ“Ө} (B : A вҶ’ Type рқ“Ҙ)
    вҶ’ is-covariant B вҶ’ is-covariant-hom B
is-covariant-homвҶҗis-covariant B cov (mk-hom f refl refl) x' = cov f x'

is-covariantвҶҗis-covariant-hom
  : вҲҖ {рқ“Ө рқ“Ҙ} {A : Type рқ“Ө} (B : A вҶ’ Type рқ“Ҙ)
    вҶ’ is-covariant-hom B вҶ’ is-covariant B
is-covariantвҶҗis-covariant-hom B cov f x' = cov (О»hom f) x'

tr-cov : вҲҖ {рқ“Ө рқ“Ҙ} {A : Type рқ“Ө} {P : A вҶ’ Type рқ“Ҙ}
       вҶ’ is-covariant P вҶ’ (h : О”В№ вҶ’ A) вҶ’ P (h i0) вҶ’ P (h i1)
tr-cov cov h = fst вҲҳ centre вҲҳ cov h

tr-cov-filler
  : вҲҖ {рқ“Ө рқ“Ҙ} {A : Type рқ“Ө} {P : A вҶ’ Type рқ“Ҙ}
    вҶ’ (Pc : is-covariant P) вҶ’ (h : О”В№ вҶ’ A)
    вҶ’ вҲҖ p вҶ’ HomбөҲ (P вҲҳ h) p (tr-cov {P = P} Pc h p)
tr-cov-filler cov h = snd вҲҳ centre вҲҳ cov h

tr-cov-hom
  : вҲҖ {рқ“Ө рқ“Ҙ} {A : Type рқ“Ө} {P : A вҶ’ Type рқ“Ҙ}
    вҶ’ is-covariant P
    вҶ’ вҲҖ {x y} (h : Hom A x y) вҶ’ P x вҶ’ P y
tr-cov-hom cov h = fst вҲҳ centre вҲҳ is-covariant-homвҶҗis-covariant _ cov h

tr-cov-over
  : вҲҖ {рқ“Ө рқ“Ҙ} {A : Type рқ“Ө} {P : A вҶ’ Type рқ“Ҙ}
    вҶ’ (cov : is-covariant P)
    вҶ’ вҲҖ {x y} (h : Hom A x y) вҶ’ (x' : P x) вҶ’ Hom-over h x' (tr-cov-hom cov h x')
tr-cov-over cov h = snd вҲҳ centre вҲҳ is-covariant-homвҶҗis-covariant _ cov h
}
%```
}


\subtree[stt-00AV]{
\title{Left fibrations}
\taxon{Definition}

\p{A map is a left (right) fibration if it is [right orthogonal](stt-0048) to the
left (right) endpoint of #{\Delta^1}.}

%```agda
\agda{
is-left-fibration : вҲҖ {рқ“Ө рқ“Ҙ} {A : Type рқ“Ө} {B : Type рқ“Ҙ} вҶ’ (A вҶ’ B)
                    вҶ’ Type (рқ“Ө вҠ” рқ“Ҙ вҠ” рқ“ҳ)
is-left-fibration f = (point i0) вҠҘ f

is-right-fibration : вҲҖ {рқ“Ө рқ“Ҙ} {A : Type рқ“Ө} {B : Type рқ“Ҙ} вҶ’ (A вҶ’ B)
                    вҶ’ Type (рқ“Ө вҠ” рқ“Ҙ вҠ” рқ“ҳ)
is-right-fibration f = (point i1) вҠҘ f
}
%```
}


\subtree[stt-00AW]{
\taxon{Lemma}

\p{Given some family #{B : A \to \UU}, an arrow #{f} in #{A} and a point over the
base #{x_0 : B(f(0))}, the type of dependent homs over #{f} based an #{x_0} is
equivalent to the type of lifts of the following square:}


\quiver{
\begin{tikzcd}
	1 && {\tilde{B}} \\
	\\
	{\Delta^1} && A
	\arrow["{x_0}", from=1-1, to=1-3]
	\arrow["0"', from=1-1, to=3-1]
	\arrow["\pi", from=1-3, to=3-3]
	\arrow["f"', from=3-1, to=3-3]
\end{tikzcd}
}


%```agda
\agda{
lifts-of-based-arrow : вҲҖ {рқ“Ө рқ“Ҙ} {A : Type рқ“Ө} {B : A вҶ’ Type рқ“Ҙ}
          (f : О”В№ вҶ’ A) (xвӮҖ : B (f i0))
        вҶ’ let F = mk-amap {f = point i0}
                          (О» _ вҶ’ f i0 , xвӮҖ) f ~refl
        in ОЈ (B (f i1)) (HomбөҲ (B вҲҳ f) xвӮҖ)
        вүғ Lift F
lifts-of-based-arrow {A = A} {B} f xвӮҖ = eqv where
  F : Arrow-map (point i0) (fst {B = B})
  F = mk-amap (О» _ вҶ’ f i0 , xвӮҖ) f ~refl

  open Arrow-map F
  open HomбөҲ
}
%```

\closedScope{
\subtree[stt-00AX]{
\title{Details}
%```agda
\agda{
  by-contracting-singletons : (ОЈ[ xвӮҒ вҲ¶  (B (f i1)) ] ОЈ[ h вҲ¶ О  О”В№ (B вҲҳ f)]
            ((h i0 пјқ xвӮҖ) Г— (h i1 пјқ xвӮҒ)))
          вү… (ОЈ[ h вҲ¶ О  О”В№ (B вҲҳ f)] (h i0 пјқ xвӮҖ))
  by-contracting-singletons ._вү…_.fwd (_ , h , p , refl) = (h , p)
  by-contracting-singletons ._вү…_.fwd-iso .fst (h , p) = (h i1 , h , p , refl)
  by-contracting-singletons ._вү…_.fwd-iso .snd .fst (_ , h , p , refl) = refl
  by-contracting-singletons ._вү…_.fwd-iso .snd .snd = ~refl

  because-pi-types-are-extensions
    : (ОЈ[ h вҲ¶ О  О”В№ (B вҲҳ f)] (h i0 пјқ xвӮҖ))
       вүғ
      (ОЈ[ (f , p) вҲ¶ fibre (postcomp О”В№ (О» r вҶ’ fst r)) f ]
       (tr B (happly p i0) (snd (f i0)) пјқ xвӮҖ))
  because-pi-types-are-extensions
    = ОЈ-ap-вүғ-fst
        {B = О» where (f , p) вҶ’ tr B (happly p i0) (snd (f i0)) пјқ xвӮҖ}
        (mkвүғ (extensionвҶҗО  {B = B} f) (extensionвҶҗО -is-equiv f))

  by-funext
    : ОЈ[ f' вҲ¶ (О”В№ вҶ’ ОЈ A B) ] ОЈ[ H вҲ¶ (fst вҲҳ f' пјқ f) ]
          (tr B (happly H i0) (snd (f' i0)) пјқ xвӮҖ)
    вүғ ОЈ[ f' вҲ¶ (О”В№ вҶ’ ОЈ A B) ] ОЈ[ H вҲ¶ (fst вҲҳ f' ~ f) ]
          (tr B (H i0) (snd (f' i0)) пјқ xвӮҖ)
  by-funext
    = ОЈ-ap-вүғ
       (О» f' вҶ’ ОЈ-ap-вүғ-fst
                {B = О» H вҶ’ tr B (H i0) (snd (f' i0)) пјқ xвӮҖ}
                funextвүғ)

  inserting-singleton
    :   ОЈ[ f' вҲ¶ (О”В№ вҶ’ ОЈ A B) ] ОЈ[ H вҲ¶ (fst вҲҳ f' ~ f) ]
          (tr B (H i0) (snd (f' i0)) пјқ xвӮҖ)
     вүғ  ОЈ[ f' вҲ¶ (О”В№ вҶ’ ОЈ A B) ] ОЈ[ H вҲ¶ (fst вҲҳ f' ~ f) ]
        ОЈ[ K1 вҲ¶ fst (f' i0) пјқ _ ] ОЈ[ K2 вҲ¶ IdбөҲ (ap B K1) (snd (f' i0)) xвӮҖ ]
          (K1 пјқ H i0)
  inserting-singleton
    = ОЈ-ap-вүғ
       (О» f' вҶ’ ОЈ-ap-вүғ
         (О» H вҶ’ ОЈ-singl
                  {B = О» (K , _) вҶ’ tr B K (snd (f' i0)) пјқ xвӮҖ }
                  Sing-is-singleton
                  (H i0 , refl) eвҒ»В№
                вҲҷвүғ ОЈ-assoc вҲҷвүғ ОЈ-ap-вүғ (О» K вҶ’ Г—-swap вҲҷвүғ ОЈ-ap-вүғ (О» _ вҶ’ symвүғ) )))

  by-characterising-ОЈ-path
    : ОЈ[ f' вҲ¶ (О”В№ вҶ’ ОЈ A B) ] ОЈ[ H вҲ¶ (fst вҲҳ f' ~ f) ]
        ОЈ[ K вҲ¶ f' i0 пјқ (_ , xвӮҖ) ] (ap fst K пјқ H i0)
      вүғ
        ОЈ[ f' вҲ¶ (О”В№ вҶ’ ОЈ A B) ] ОЈ[ H вҲ¶ (fst вҲҳ f' ~ f) ]
          ОЈ[ K1 вҲ¶ fst (f' i0) пјқ _ ] ОЈ[ K2 вҲ¶ IdбөҲ (ap B K1) (snd (f' i0)) xвӮҖ ]
           (K1 пјқ H i0)
  by-characterising-ОЈ-path
    = ОЈ-ap-вүғ
       (О» f' вҶ’ ОЈ-ap-вүғ
         (О» H вҶ’ ОЈ-ap-вүғ-fst
                {B = О» (K , _) вҶ’ K пјқ H i0}
                (  ОЈ-path {x = f' i0} {y = _ , xвӮҖ} eвҒ»В№)
                вҲҷвүғ ОЈ-assoc))


  by-UP-of-unit
    :  ОЈ[ f' вҲ¶ (О”В№ вҶ’ ОЈ A B) ] ОЈ[ H вҲ¶ (fst вҲҳ f' ~ f) ]
        ОЈ[ K вҲ¶ f' i0 пјқ (_ , xвӮҖ) ] (ap fst K пјқ H i0)
      вүғ
       ОЈ[ f' вҲ¶ (О”В№ вҶ’ ОЈ A B) ] ОЈ[ K вҲ¶ f' вҲҳ const _ _ i0 ~ const _ _ (_ , xвӮҖ) ]
         ОЈ[ H вҲ¶ (fst вҲҳ f' ~ f) ] (fst в—Ӯ K ~ (H в–ё const _ _ i0))
  by-UP-of-unit
    = ОЈ-ap-вүғ
       (О» f' вҶ’ ОЈ-ap-вүғ
                (О» H вҶ’ ОЈ-ap-вүғ-fst {B = О» K вҶ’ ap fst K пјқ H i0} (unit-UPвүғ) eвҒ»В№
                       вҲҷвүғ ОЈ-ap-вүғ (О» K вҶ’ unit-UPвүғ eвҒ»В№))
               вҲҷвүғ ОЈ-comm)

  postcomposing-reflr-is-equiv
    : ОЈ[ f' вҲ¶ (О”В№ вҶ’ ОЈ A B) ] ОЈ[ K вҲ¶ f' вҲҳ const _ _ i0 ~ const _ _ (_ , xвӮҖ) ]
         ОЈ[ H вҲ¶ (fst вҲҳ f' ~ f) ] (fst в—Ӯ K ~ (H в–ё const _ _ i0))
      вүғ
      ОЈ[ f' вҲ¶ (О”В№ вҶ’ ОЈ A B) ] ОЈ[ K вҲ¶ f' вҲҳ const _ _ i0 ~ const _ _ (_ , xвӮҖ) ]
         ОЈ[ H вҲ¶ (fst вҲҳ f' ~ f) ] (fst в—Ӯ K ~ (H в–ё const _ _ i0) ~вҲҷ ~refl )
  postcomposing-reflr-is-equiv
    = ОЈ-ap-вүғ
       (О» f' вҶ’ ОЈ-ap-вүғ
         (О» K вҶ’ ОЈ-ap-вүғ (О» H вҶ’ ~reflrвүғ {f = const _ _ (f i0)} _ _)))
}
%```
}
}

\proof{
%```agda
\agda{
  opaque
    eqv : ОЈ (B (f i1)) (HomбөҲ (B вҲҳ f) xвӮҖ) вүғ Lift F
    eqv
      = ОЈ (B (f i1)) (HomбөҲ (B вҲҳ f) xвӮҖ) вүғвҹЁ ОЈ-ap-вүғ (О» _ вҶ’ HomбөҲ-reprвүғ) вҹ©

        ОЈ[ xвӮҒ вҲ¶  (B (f i1)) ] ОЈ[ h вҲ¶ О  О”В№ (B вҲҳ f)]
          ((h i0 пјқ xвӮҖ) Г— (h i1 пјқ xвӮҒ))
                                       вүғвҹЁ equivвҶҗqiso by-contracting-singletons вҹ©

        (ОЈ[ h вҲ¶ О  О”В№ (B вҲҳ f)] (h i0 пјқ xвӮҖ))
                                       вүғвҹЁ because-pi-types-are-extensions вҹ©

        (ОЈ[ (f , p) вҲ¶ fibre (postcomp О”В№ (О» r вҶ’ fst r)) f ]
         (tr B (happly p i0) (snd (f i0)) пјқ xвӮҖ))
                                       вүғвҹЁ ОЈ-assoc вҹ©

        ОЈ[ f' вҲ¶ (О”В№ вҶ’ ОЈ A B) ] ОЈ[ H вҲ¶ (fst вҲҳ f' пјқ f) ]
            (tr B (happly H i0) (snd (f' i0)) пјқ xвӮҖ)
                                       вүғвҹЁ by-funext вҹ©

        ОЈ[ f' вҲ¶ (О”В№ вҶ’ ОЈ A B) ] ОЈ[ H вҲ¶ (fst вҲҳ f' ~ f) ]
            (tr B (H i0) (snd (f' i0)) пјқ xвӮҖ)
                                       вүғвҹЁ inserting-singleton вҹ©

        ОЈ[ f' вҲ¶ (О”В№ вҶ’ ОЈ A B) ] ОЈ[ H вҲ¶ (fst вҲҳ f' ~ f) ]
          ОЈ[ K1 вҲ¶ fst (f' i0) пјқ f i0 ] ОЈ[ K2 вҲ¶ IdбөҲ (ap B K1) (snd (f' i0)) xвӮҖ ]
            (K1 пјқ H i0)
                                       вүғвҹЁ by-characterising-ОЈ-path eвҒ»В№ вҹ©

        ОЈ[ f' вҲ¶ (О”В№ вҶ’ ОЈ A B) ] ОЈ[ H вҲ¶ (fst вҲҳ f' ~ f) ]
          ОЈ[ K вҲ¶ f' i0 пјқ (_ , xвӮҖ) ] (ap fst K пјқ H i0)
                                       вүғвҹЁ by-UP-of-unit вҹ©

        ОЈ[ f' вҲ¶ (О”В№ вҶ’ ОЈ A B) ] ОЈ[ K вҲ¶ f' вҲҳ const _ _ i0 ~ const _ _ (_ , xвӮҖ) ]
           ОЈ[ H вҲ¶ (fst вҲҳ f' ~ f) ] (fst в—Ӯ K ~ (H в–ё const _ _ i0))
                                       вүғвҹЁ postcomposing-reflr-is-equiv вҹ©

        ОЈ[ f' вҲ¶ (О”В№ вҶ’ ОЈ A B) ] ОЈ[ K вҲ¶ f' вҲҳ const _ _ i0 ~ const _ _ (_ , xвӮҖ) ]
           ОЈ[ H вҲ¶ (fst вҲҳ f' ~ f) ] (fst в—Ӯ K ~ (H в–ё const _ _ i0) ~вҲҷ ~refl )
                                       вүғвҹЁ Lift-reprвүғ F eвҒ»В№ вҹ©

        Lift F                         вүғвҲҺ
}
%```
}
}

\subtree[stt-00AR]{
\title{Covariant families straighten to left fibrations}
\taxon{Corollary}

\p{We show that some family #{P : A \to \UU} is [covariant](stt-00AO) iff the map
#{\pi : \tilde{P} \to A} is a [left fibration](stt-00AV).}

%```agda
\agda{
opaque
  is-covariantвҮ”is-left-fibration
    : вҲҖ {рқ“Ө рқ“Ҙ} {A : Type рқ“Ө} (B : A вҶ’ Type рқ“Ҙ)
      вҶ’ is-covariant B вҮ” is-left-fibration (fst {B = B})
  is-covariantвҮ”is-left-fibration {A = A} B
    = (fwd , bwd) where
      arrow-map-snd : (F : Arrow-map (point i0) (fst {B = B}))
                      вҶ’ B (F .Arrow-map.bot i0)
      arrow-map-snd (mk-amap top bot comm) = tr B (sym (comm tt)) (top tt .snd)

      ОЈвҶҗarrow-map : Arrow-map (point i0) (fst {B = B})
                  вҶ’ ОЈ[ f вҲ¶ (О”В№ вҶ’ A)] (B (f i0))
      ОЈвҶҗarrow-map F = F .bot , arrow-map-snd F where open Arrow-map

      fwd : is-covariant B вҶ’ is-left-fibration (fst {B = B})
      fwd cov a@(mk-amap top bot comm)
        = is-singleвҶҗequiv-to-single
            ( lifts-of-based-arrow bot (tr B (sym (comm tt)) (snd (top tt)))
            вҲҷвүғ coeвүғ (ap Lift
                (Arrow-map-pathвҶ’
                  ((О» aвӮҒ вҶ’ ОЈ-pathвҶ’ ((comm tt)
                                   , trвҲҷtr-sym' (comm tt) (snd (top tt))))
                  , (~refl , (О» _ вҶ’ ОЈ-path-ap-fst))))))
            (cov bot (arrow-map-snd a))

      bwd : is-left-fibration (fst {B = B}) вҶ’ is-covariant B
      bwd lfib f xвӮҖ = is-singleвҶҗequiv-to-single
           (lifts-of-based-arrow f xвӮҖ  eвҒ»В№)
           (lfib (mk-amap (О» _ вҶ’ (f i0 , xвӮҖ)) f ~refl))
}
%```
}

\subtree[stt-00C7]{
\title{Left and right fibrations are inner}
\taxon{Lemma}

\proof{
\p{We use the fact that left orthogonal maps [are closed under pushout products
and embeddings](stt-00BV). In particular we take the pushout product:
#{\underset{\Delta^1}{\overset{\{0\}}{\downarrow}} \pushprod
\underset{\Delta^1}{\overset{\{1\}}{\downarrow}}}, which modulo some contracting
away singletons, is the [inner horn](stt-00AD) inclusion into the square. Now
the following retract square completes the proof:}

\quiver{
\begin{tikzcd}
	{\Lambda^2_1} && {\Lambda^2_1} && {\Lambda^2_1} \\
	\\
	{\Delta^2} && {\square^2} && {\Delta^2}
	\arrow["\id", from=1-1, to=1-3]
	\arrow[hook, from=1-1, to=3-1]
	\arrow["\id", from=1-3, to=1-5]
	\arrow[hook, from=1-3, to=3-3]
	\arrow[hook, from=1-5, to=3-5]
	\arrow["{(x,y)\mapsto(x,y)}"', from=3-1, to=3-3]
	\arrow["{(x,y)\mapsto(x,x\land y)}"', from=3-3, to=3-5]
\end{tikzcd}
}
}

%```agda
\agda{
в–Ў-retraction : retraction {A = О”ВІ} {B = О”В№ Г— О”В№} (О» (x , y) вҶ’ (x , y))
в–Ў-retraction .fst (x , y) = (x , y вҲ§ x) вҰғ вҲ§-вүӨ-elimr auto! вҰ„
в–Ў-retraction .snd (x , y) = О”ВІ-ext (refl , auto!)

Оӣ[2,1]вҶӘв–Ў-section : Arrow-map Оӣ[2,1]-incl (pushout-product (point i1) (point i0))
Оӣ[2,1]вҶӘв–Ў-section .Arrow-map.top = PushoutвӮҒ
                       (mk-span-map (_, _) _ (_ ,_) ~refl ~refl)
Оӣ[2,1]вҶӘв–Ў-section .Arrow-map.bot (x , y) = (x , y)
Оӣ[2,1]вҶӘв–Ў-section .Arrow-map.comm
  = pushout-ind _ (mk-coconeбөҲ ~refl ~refl
                    О» _ вҶ’ is-setвҶҗis-truncated (в–Ў-is-set car-is-set) _ _ _ _)

Оӣ[2,1]вҶӘв–Ў-ret : retraction-arrow-map Оӣ[2,1]вҶӘв–Ў-section
Оӣ[2,1]вҶӘв–Ў-ret .fst .Arrow-map.top
  = PushoutвӮҒ (mk-span-map fst _ snd ~refl ~refl)
Оӣ[2,1]вҶӘв–Ў-ret .fst .Arrow-map.bot = в–Ў-retraction .fst
Оӣ[2,1]вҶӘв–Ў-ret .fst .Arrow-map.comm
  = pushout-ind _
      (mk-coconeбөҲ
        (О» l вҶ’ О”ВІ-ext (refl , 0-init))
        (О» l вҶ’ О”ВІ-ext (refl , 1-top))
        О» _ вҶ’ О”ВІ-is-set _ _ _ _)
Оӣ[2,1]вҶӘв–Ў-ret .snd .fst
  = pushout-ind _ (mk-coconeбөҲ ~refl ~refl
                    (О» _ вҶ’ is-setвҶҗis-truncated Оӣ[2,1]-is-set _ _ _ _))
Оӣ[2,1]вҶӘв–Ў-ret .snd .snd .fst   = в–Ў-retraction .snd
Оӣ[2,1]вҶӘв–Ў-ret .snd .snd .snd x = О”ВІ-is-set _ _ _ _

is-innerвҶҗis-left-fibration
  : вҲҖ {рқ“Ө рқ“Ҙ} {A : Type рқ“Ө} {B : Type рқ“Ҙ} {f : A вҶ’ B}
    вҶ’ is-left-fibration f вҶ’ is-inner f
is-innerвҶҗis-left-fibration {f = f} lf
  = left-orthogonal-retraction
      Оӣ[2,1]-incl (pushout-product (О» _ вҶ’ i1) (О» _ вҶ’ i0))
      Оӣ[2,1]вҶӘв–Ў-section Оӣ[2,1]вҶӘв–Ў-ret _
      (left-orthogonal-pushout-product'
        (point i0) f
        lf (point i1))

is-innerвҶҗis-right-fibration
  : вҲҖ {рқ“Ө рқ“Ҙ} {A : Type рқ“Ө} {B : Type рқ“Ҙ} {f : A вҶ’ B}
    вҶ’ is-right-fibration f вҶ’ is-inner f
is-innerвҶҗis-right-fibration {f = f} rf
  = left-orthogonal-retraction
      Оӣ[2,1]-incl (pushout-product (О» _ вҶ’ i1) (О» _ вҶ’ i0))
      Оӣ[2,1]вҶӘв–Ў-section Оӣ[2,1]вҶӘв–Ў-ret _
      (left-orthogonal-pushout-product
        (point i1) f
        rf (point i0))
}
%```
}

\subtree[stt-00C8]{
\taxon{Corollary}

\p{The total type of a covariant family over a Segal type is itself Segal.}

%```agda
\agda{
is-inner-familyвҶҗis-covariant
  : вҲҖ {рқ“Ө рқ“Ҙ} {A : Type рқ“Ө} {B : A вҶ’ Type рқ“Ҙ}
    вҶ’ is-covariant B вҶ’ is-inner-family B
is-inner-familyвҶҗis-covariant
  = is-innerвҶҗis-left-fibration вҲҳ (is-covariantвҮ”is-left-fibration _ .fst)

is-inner-familyвҶҗis-covariant-hom
  : вҲҖ {рқ“Ө рқ“Ҙ} {A : Type рқ“Ө} {B : A вҶ’ Type рқ“Ҙ}
    вҶ’ is-covariant-hom B вҶ’ is-inner-family B
is-inner-familyвҶҗis-covariant-hom
  = is-inner-familyвҶҗis-covariant вҲҳ is-covariantвҶҗis-covariant-hom _

ОЈ-cov-is-segal
  : вҲҖ {рқ“Ө рқ“Ҙ} {A : Type рқ“Ө} {B : A вҶ’ Type рқ“Ҙ}
    вҶ’ is-segal A вҶ’ is-covariant B вҶ’ is-segal (ОЈ A B)
ОЈ-cov-is-segal apc cov
  = ОЈ-is-segal apc
      (is-innerвҶҗis-left-fibration
        (is-covariantвҮ”is-left-fibration _ .fst  cov))
}
%```
}

\subtree[stt-00DH]{
\title{Morphisms in Hom types}
\taxon{Lemma}

\p{We show that for a covariant family #{P}, given any #{f : \Hom_A(x,y)},
the type of dependent morphisms #{\Hom_{Pf}(x',y')} is equivalent to
#{f^*(x') = y'}.}

\proof{
\p{We first give a map #{f^*(x') = y'}, by identity induction, it suffices to give
a morphism #{\Hom_{Pf}(x', f^*(x'))} for each #{x'}, but this is just the
coherence you get from covariant transport.
Now since #{\Sigma_{y' : P(f(1))} \Hom_{Pf}(x',y')} is a singleton by the
definition of transport, the fundamental theorem of identity types gives us that
this map is an equivalence.}
}

%```agda
\agda{
Hom-cov : вҲҖ {рқ“Ө рқ“Ҙ} {A : Type рқ“Ө} (P : A вҶ’ Type рқ“Ҙ) (cov : is-covariant P)
            (f : О”В№ вҶ’ A) x' y'
          вҶ’ tr-cov {P = P} cov f x' пјқ y' вҶ’ HomбөҲ (P вҲҳ f) x' y'
Hom-cov _ Pc f x' y' refl = Pc f x' .centre .snd

Hom-cov-is-equiv
  : вҲҖ {рқ“Ө рқ“Ҙ} {A : Type рқ“Ө} (P : A вҶ’ Type рқ“Ҙ) (cov : is-covariant P)
      (f : О”В№ вҶ’ A) x' y'
    вҶ’ is-equiv (Hom-cov P cov f x' y')
Hom-cov-is-equiv P Pc f x' = fundamental-Id _ (Pc f x') (Hom-cov P Pc f x')

Hom-cov'
  : вҲҖ {рқ“Ө рқ“Ҙ} {A : Type рқ“Ө} (P : A вҶ’ Type рқ“Ҙ) (cov : is-covariant P)
      {x y} (f : Hom A x y) x' y'
    вҶ’ tr-cov-hom {P = P} cov f x' пјқ y' вҶ’ Hom-over f x' y'
Hom-cov' P cov f x' y' refl
  = is-covariant-homвҶҗis-covariant _ cov f x' .centre .snd

Hom-cov'-is-equiv
  : вҲҖ {рқ“Ө рқ“Ҙ} {A : Type рқ“Ө} (P : A вҶ’ Type рқ“Ҙ) (cov : is-covariant P)
      {x y} (f : Hom A x y) x' y'
    вҶ’ is-equiv (Hom-cov' P cov f x' y')
Hom-cov'-is-equiv P Pc f x'
  = fundamental-Id
      _
      (is-covariant-homвҶҗis-covariant _ Pc f x')
      (Hom-cov' P Pc f x')
}
%```
}

\subtree[stt-00DQ]{
\title{Covariant transport is functorial}
\taxon{Theorem}

\citet{8.16}{RS17}

\p{Given a covariant family #{P}, we show the transport operation is functorial,
in the sense that #{P(\id) \sim \id} and
#{P(f \circ g) \sim P(f) \circ P(g)}.}

%```agda
\agda{
tr-cov-id
  : вҲҖ {рқ“Ө рқ“Ҙ} {A : Type рқ“Ө} (P : A вҶ’ Type рқ“Ҙ) (cov : is-covariant P) {x}
    вҶ’ tr-cov {P = P} cov (О» _ вҶ’ x) ~ id
tr-cov-id P cov {x} x' = ap fst (cov (О» _ вҶ’ x) x' .central (x' , idH x') )

tr-cov-idH
  : вҲҖ {рқ“Ө рқ“Ҙ} {A : Type рқ“Ө} (P : A вҶ’ Type рқ“Ҙ) (cov : is-covariant P) {x}
    вҶ’ tr-cov-hom {P = P} cov (idH x) ~ id
tr-cov-idH P cov {x} x' = ap fst
  (is-covariant-homвҶҗis-covariant _ cov (idH x) x' .central (x' , idH x'))

tr-cov-вҲҳ
  : вҲҖ {рқ“Ө рқ“Ҙ} {A : Type рқ“Ө} (Apc : is-segal A) (P : A вҶ’ Type рқ“Ҙ)
      (cov : is-covariant P) {x y z} (g : Hom A y z) (f : Hom A x y)
      (x' : P x)
      вҶ’  tr-cov-hom cov (g вҲҳ[ Apc ] f) x'
      пјқ tr-cov-hom cov g (tr-cov-hom cov f x')
tr-cov-вҲҳ apc P cov g f x'
  = ap fst
      (is-covariant-homвҶҗis-covariant _ cov (g вҲҳ[ apc ] f) x' .central
        ( tr-cov-hom cov g (tr-cov-hom cov f x')
        , CompбөҲ apc P (is-inner-familyвҶҗis-covariant cov) g f
                (tr-cov-over cov g _) (tr-cov-over cov f _)))
}
%```
}

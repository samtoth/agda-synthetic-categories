\title{Fully faithful maps}
\taxon{Module}
\import{stt-macros}

%```agda
\agda{
open import Foundations.Prelude
open import Algebra.Lattice

module Synthetic.Categories.FullyFaithful
  {рқ“ҳ} (О”В№ : Type рқ“ҳ) (I : Lattice О”В№) (I-distr : is-distributive I)
  where

open import ufAxioms

open Lattice I renaming (0l to i0; 1l to i1)

open import Foundations.Embedding

open import Synthetic.Categories.Boundaries О”В№ I I-distr
open import Synthetic.Hom О”В№ i0 i1

open import Data.Bool

open import Core.Arrow
open import Core.ArrowEquiv
open import Core.Cube
open import Core.Orthogonal
open import Core.OrthogonalClosure
open import Core.Postwhisker
open import Core.PullbackPower
}
%```

\subtree[stt-00G3]{
\taxon{Definition}
\title{Fully faithful maps in terms of the action on morphisms}
\date{2026-03-11}
\author{samueltoth}

\p{A map #{F : A \to B} is called \em{fully faithful} if its action on synthetic
morphisms #{\Hom_A(a,b) \to \Hom_B(F(a), F(b))} is an equivalence.
}

%```agda
\agda{
is-ff'
  : вҲҖ {рқ“Ө рқ“Ҙ} {A : Type рқ“Ө} {B : Type рқ“Ҙ}
    вҶ’ (A вҶ’ B) вҶ’ Type (рқ“ҳ вҠ” рқ“Ө вҠ” рқ“Ҙ)
is-ff' f = вҲҖ {x y} вҶ’ is-equiv (ap-hom f {x} {y})
}
%```
}

\subtree[fre-4000]{
\title{Fully faithful maps as a right orthogonal class}
\taxon{Definition}

\p{
A map of types is \em{fully faithful} if it is right orthogonal to the boundary
inclusion of the interval #{\partial\Delta^1 \hookrightarrow \Delta^1}.
}

%```agda
\agda{
module FF = RightOrthogonalClassClosure (point вҲӮО”В№-incl)

is-ff : {рқ“Ө рқ“Ҙ : Level} {A : Type рқ“Ө} {B : Type рқ“Ҙ} вҶ’ (A вҶ’ B) вҶ’ Type (рқ“ҳ вҠ” рқ“Ө вҠ” рқ“Ҙ)
is-ff = FF.вҲҲR

ff-map : {рқ“Ө рқ“Ҙ : Level} вҶ’ Type рқ“Ө вҶ’ Type рқ“Ҙ вҶ’ Type (рқ“ҳ вҠ” рқ“Ө вҠ” рқ“Ҙ)
ff-map A B = ОЈ[ f вҲ¶ (A вҶ’ B)] is-ff f

open FF public using () renaming
  ( вҲҲRвҶҗbase-change to is-ffвҶҗbase-change
  ; вҲҲRвҶҗequiv to is-ffвҶҗequiv
  ; вҲҲRвҶҗequiv' to is-ffвҶҗequiv'
  ; вҲҲRвҶҗis-equiv to is-ffвҶҗis-equiv
  ; вҲҲR-iffвҶҗequiv to is-ff-iffвҶҗequiv
  ; вҲҲRвҶҗretraction to is-ffвҶҗretraction
  ; вҲҲR-вҲҳ to is-ff-вҲҳ
  ; вҲҲR-left-cancel to is-ff-left-cancel
  ; вҲҲRвҶҗhomotopy to is-ff-homotopy
  ; вҲҲR-вҲҳ~ to is-ff-вҲҳ~
  ; вҲҲR-left-cancel~ to is-ff-left-cancel~)
}
%```
}

\subtree[stt-00G4]{
\title{Equivalences are fully faithful}
\taxon{Lemma}
\date{2026-03-11}
\author{samueltoth}

\p{If #{F} is a family of equivalences, then so is the induced map on total-homs
#{\Sigma_{a,b}\Hom_A(a,b) \to \Sigma_{a',b'}\Hom_B(a',b')}. Since this map
is given by #{\Sigma_F \Sigma_F \textsf{ap-hom}(F)}, by the relevant 3 for 2
theorem, we have that the total is an equivalence, each #{F} is an equivalence so
#{\textsf{ap-hom}(F)} is also an euivalence.}


%```agda
\agda{
is-ff'вҶҗis-equiv
  : вҲҖ {рқ“Ө рқ“Ҙ} {A : Type рқ“Ө} {B : Type рқ“Ҙ}
    вҶ’ {f : A вҶ’ B}
    вҶ’ is-equiv f вҶ’ is-ff' f
is-ff'вҶҗis-equiv {f = F} Fe {x} {y}
  = is-fibrewise-equivвҶҗis-total-equiv (eq2 x) y where
  eq1 : is-equiv (total-map О» a вҶ’ map-ОЈ F О» _ вҶ’ ap-hom F)
  eq1 = 3-for-2
          {f = total-map-fst F}
          (total-is-equivвҶҗfst-is-equiv Fe)
          (ap-total-hom-is-equiv Fe)

  eq2 : вҲҖ a вҶ’ is-equiv (total-map О» b вҶ’ ap-hom F {a} {b})
  eq2 a = 3-for-2 {f = total-map-fst F}
            (total-is-equivвҶҗfst-is-equiv Fe)
            (is-fibrewise-equivвҶҗis-total-equiv eq1 a)
}
%```
}

\subtree[fre-4004]{
\title{Equivalence of definitions of fully faithful maps}
\taxon{Theorem}
\author{fredrikbakke}
\date{2026-04-05}

\p{
The orthogonality-based and action-on-homs based predicates are equivalent.
}
\proof{
\p{
Let #{\iota : \partial\Delta^1 \hookrightarrow \Delta^1} be the boundary inclusion.
Given a map #{f : A \to B}, then we have an equivalence of arrows

\quiver{
\begin{tikzcd}
(\Delta^1 \to A) && \Sigma_{(x\ y : A)\Hom_A(x,y)} \\
\\
\Hom(\iota , f) && \Sigma_{(x\ y : A)\Hom_B(f(x),f(y))}
\arrow["\sim", from=1-1, to=1-3]
\arrow["\pullpow{\iota}{f}", from=1-1, to=3-1]
\arrow["\sim", from=3-1, to=3-3]
\arrow["\Sigma\Sigma{\mathrm{ap\text{-}hom}_f}", from=1-3, to=3-3]
\end{tikzcd}
}

The left map is an equivalence iff #{f} is right orthogonal to the boundary inclusion
of #{\Delta^1}, and, since total maps are equivalences if and only if they're
fibrewise equivalences, the right map is an equivalence iff #{f}'s action on homs is
an equivalence.
}
}

%```agda
\agda{
module CompareFF {рқ“Ө рқ“Ҙ : Level} {A : Type рқ“Ө} {B : Type рқ“Ҙ} (f : A вҶ’ B) where

  arr-map-вҲӮО”В№-inclвҶ’ОЈОЈHom
    : Arrow-map вҲӮО”В№-incl f
    вҶ’ ОЈ[ x вҲ¶ A ] ОЈ[ y вҲ¶ A ] Hom B (f x) (f y)
  arr-map-вҲӮО”В№-inclвҶ’ОЈОЈHom F
    = ( F .Arrow-map.top вҲӮО”В№-0
      , F .Arrow-map.top вҲӮО”В№-1
      , mk-hom
          (F .Arrow-map.bot)
          (F .Arrow-map.comm вҲӮО”В№-0)
          (F .Arrow-map.comm вҲӮО”В№-1))

  ОЈОЈHomвҶ’arr-map-вҲӮО”В№-incl
    : ОЈ[ x вҲ¶ A ] ОЈ[ y вҲ¶ A ] Hom B (f x) (f y)
    вҶ’ Arrow-map вҲӮО”В№-incl f
  ОЈОЈHomвҶ’arr-map-вҲӮО”В№-incl (x , y , h)
    = mk-amap (вҲӮО”В№-UPвҶ’ (x , y)) (ext .fst) ext-comm
    where
    ext : Ext вҲӮО”В№-incl (make-вҲӮО”В№ (f y) (f x))
    ext = HomвүғExt-вҲӮО”В№-incl ._вүғ_.fwd h

    ext-comm
      : precomp-О  (О» _ вҶ’ B) вҲӮО”В№-incl (ext .fst)
      ~ postcomp-О  (О» a вҶ’ f) (вҲӮО”В№-UPвҶ’ (x , y))
    ext-comm a = ext .snd a вҲҷ sym (happly (fвҲҳвҲӮО”В№-UPвҶ’пјқmake-вҲӮО”В№ f x y) a)

  ОЈОЈHomвҶ’arr-map-вҲӮО”В№-incl-sec
    : вҲҖ (x y : A) (h : Hom B (f x) (f y))
    вҶ’ (x , y , h) пјқ arr-map-вҲӮО”В№-inclвҶ’ОЈОЈHom (ОЈОЈHomвҶ’arr-map-вҲӮО”В№-incl (x , y , h))
  ОЈОЈHomвҶ’arr-map-вҲӮО”В№-incl-sec x y h@(mk-hom hh p0 p1)
    = ОЈ-pathвҶ’
        ( refl
        , ОЈ-pathвҶ’
            ( refl
            , Hom-extвҶ’
                ( ~refl
                , ap (О» q вҶ’ p0 вҲҷ sym q) (happly funext-redex вҲӮО”В№-0) вҲҷ вҲҷ-reflr _
                , ap (О» q вҶ’ p1 вҲҷ sym q) (happly funext-redex вҲӮО”В№-1) вҲҷ вҲҷ-reflr _)))

  arr-map-вҲӮО”В№-inclвүғОЈОЈHom
    : Arrow-map вҲӮО”В№-incl f
    вүғ ОЈ[ x вҲ¶ A ] ОЈ[ y вҲ¶ A ] Hom B (f x) (f y)
  arr-map-вҲӮО”В№-inclвүғОЈОЈHom = equivвҶҗqiso qiso where
    qiso : Arrow-map вҲӮО”В№-incl f вү… (ОЈ[ x вҲ¶ A ] ОЈ[ y вҲ¶ A ] Hom B (f x) (f y))
    qiso ._вү…_.fwd = arr-map-вҲӮО”В№-inclвҶ’ОЈОЈHom
    qiso ._вү…_.fwd-iso .fst = ОЈОЈHomвҶ’arr-map-вҲӮО”В№-incl
    qiso ._вү…_.fwd-iso .snd .fst F
      = Arrow-map-pathвҶ’
          ( happly (вҲӮО”В№-UP-О· (F .Arrow-map.top))
          , ~refl
          , О» where
              (mk-lift false)
                вҶ’ ap (О» p вҶ’ (Arrow-О .comm F вҲӮО”В№-0 вҲҷ sym p)
                          вҲҷ ap f (happly (вҲӮО”В№-UP-О· (Arrow-О .top F)) вҲӮО”В№-0))
                     (happly funext-redex вҲӮО”В№-0)
                вҲҷ ap (О» p вҶ’ (Arrow-О .comm F вҲӮО”В№-0 вҲҷ refl) вҲҷ ap f p)
                     (happly funext-redex вҲӮО”В№-0)
                вҲҷ вҲҷ-reflr _
                вҲҷ вҲҷ-reflr _
              (mk-lift true)
                вҶ’ ap (О» p вҶ’ (Arrow-О .comm F вҲӮО”В№-1 вҲҷ sym p)
                          вҲҷ ap f (happly (вҲӮО”В№-UP-О· (Arrow-О .top F)) вҲӮО”В№-1))
                     (happly funext-redex вҲӮО”В№-1)
                вҲҷ ap (О» p вҶ’ (Arrow-О .comm F вҲӮО”В№-1 вҲҷ refl) вҲҷ ap f p)
                     (happly funext-redex вҲӮО”В№-1)
                вҲҷ вҲҷ-reflr _
                вҲҷ вҲҷ-reflr _)
    qiso ._вү…_.fwd-iso .snd .snd (x , y , h) = sym (ОЈОЈHomвҶ’arr-map-вҲӮО”В№-incl-sec x y h)

  total-ap-hom
    : ОЈ[ x вҲ¶ A ] ОЈ[ y вҲ¶ A ] Hom A x y
    вҶ’ ОЈ[ x вҲ¶ A ] ОЈ[ y вҲ¶ A ] Hom B (f x) (f y)
  total-ap-hom = total-map О» x вҶ’ total-map О» y вҶ’ ap-hom f {x} {y}

  total-ap-hom-square
    : Arrow-map (pullback-power вҲӮО”В№-incl f) total-ap-hom
  total-ap-hom-square .Arrow-map.top = total-hom ._вүғ_.fwd
  total-ap-hom-square .Arrow-map.bot = arr-map-вҲӮО”В№-inclвҶ’ОЈОЈHom
  total-ap-hom-square .Arrow-map.comm l = refl

  total-ap-hom-square-is-equiv : is-Arrow-equiv total-ap-hom-square
  total-ap-hom-square-is-equiv
    = total-hom ._вүғ_.has-is-eqv
    , arr-map-вҲӮО”В№-inclвүғОЈОЈHom ._вүғ_.has-is-eqv

module _ {рқ“Ө рқ“Ҙ : Level} {A : Type рқ“Ө} {B : Type рқ“Ҙ} {f : A вҶ’ B} where

  is-ff'вҶҗis-ff : is-ff f вҶ’ is-ff' f
  is-ff'вҶҗis-ff О№вҠҘf {x} {y}
    = is-fibrewise-equivвҶҗis-total-equiv
        (is-fibrewise-equivвҶҗis-total-equiv
            (is-equivвҶҗArrow-equiv
              {F = CompareFF.total-ap-hom-square f}
              (CompareFF.total-ap-hom-square-is-equiv f)
              (pb-power-is-equivвҶҗorthogonal (О№вҠҘf tt)))
          (x))
        (y)

  is-ffвҶҗis-ff' : is-ff' f вҶ’ is-ff f
  is-ffвҶҗis-ff' ap-hom-is-eqv _
    = orthogonalвҶҗpb-power-is-equiv
        (is-equivвҶҗArrow-equivвҒ»В№
          {F = CompareFF.total-ap-hom-square f}
          (CompareFF.total-ap-hom-square-is-equiv f)
          (is-total-equivвҶҗis-fibrewise-equiv О» x вҶ’
             is-total-equivвҶҗis-fibrewise-equiv О» y вҶ’ ap-hom-is-eqv {x} {y}))

  is-ffвҮ”is-ff' : is-ff f вҮ” is-ff' f
  is-ffвҮ”is-ff' = (is-ff'вҶҗis-ff , is-ffвҶҗis-ff')
}
%```
}

\subtree[fre-4006]{
\title{Computing the source-target transformation associated to a map}
\taxon{Lemma}
\author{fredrikbakke}
\date{2026-04-13}

\p{
For any map #{f : A \to B}, the induced square between the source-target maps
#{A^{\Delta^1} \to A \times A} and #{B^{\Delta^1} \to B \times B} is equivalent to
the square obtained from precomposition along the boundary inclusion
#{\partial\Delta^1 \hookrightarrow \Delta^1}.
}

%```agda
\agda{
srcГ—tgt : вҲҖ {рқ“Ө} {A : Type рқ“Ө} вҶ’ (О”В№ вҶ’ A) вҶ’ A Г— A
srcГ—tgt u = (u i0 , u i1)

srcГ—tgt:_ : вҲҖ {рқ“Ө} (A : Type рқ“Ө) вҶ’ (О”В№ вҶ’ A) вҶ’ A Г— A
srcГ—tgt: A = srcГ—tgt

srcГ—tgt-homotopy
  : вҲҖ {рқ“Ө} {A : Type рқ“Ө} (u : О”В№ вҶ’ A)
  вҶ’ вҲӮО”В№-UPвҶ’ (srcГ—tgt u) ~ precomp A вҲӮО”В№-incl u
srcГ—tgt-homotopy u (mk-lift false) = refl
srcГ—tgt-homotopy u (mk-lift true) = refl

srcГ—tgtвүғboundary-square
  : вҲҖ {рқ“Ө} {A : Type рқ“Ө}
  вҶ’ Arrow-equiv (srcГ—tgt: A) (precomp A вҲӮО”В№-incl)
srcГ—tgtвүғboundary-square
  = (mk-amap id (вҲӮО”В№-UP ._вүғ_.fwd) (funextвҶ’ вҲҳ srcГ—tgt-homotopy))
  , id-is-equiv
  , вҲӮО”В№-UP ._вүғ_.has-is-eqv

module _ {рқ“Ө рқ“Ҙ : Level} {A : Type рқ“Ө} {B : Type рқ“Ҙ} (f : A вҶ’ B) where

  srcГ—tgt-square
    : Arrow-map (postcomp О”В№ f) (f вҠ— f)
  srcГ—tgt-square .Arrow-map.top = srcГ—tgt
  srcГ—tgt-square .Arrow-map.bot = srcГ—tgt
  srcГ—tgt-square .Arrow-map.comm = ~refl

  srcГ—tgt-natural-pair
    : (xy : A Г— A)
    вҶ’ postcomp вҲӮО”В№ f (вҲӮО”В№-UPвҶ’ xy)
    ~ вҲӮО”В№-UPвҶ’ ((f вҠ— f) xy)
  srcГ—tgt-natural-pair (x , y) (mk-lift false) = refl
  srcГ—tgt-natural-pair (x , y) (mk-lift true) = refl

  srcГ—tgt-squareвүғpower-hom
    : Cube (transpose-square srcГ—tgt-square) (transpose-square (power-hom вҲӮО”В№-incl f))
  srcГ—tgt-squareвүғpower-hom
    = mk-cube
        (srcГ—tgtвүғboundary-square .fst)
        (srcГ—tgtвүғboundary-square .fst)
        ( ~refl
        , funextвҶ’ вҲҳ srcГ—tgt-natural-pair
        , О» u
          вҶ’ вҲҷ-reflr _
          вҲҷ вҲҷ-reflr _
          вҲҷ sym (commutes-postwhisker-funext {h = f} (srcГ—tgt-homotopy u))
          вҲҷ ap funextвҶ’
              (funextвҶ’ О» where
                (mk-lift false) вҶ’ sym (вҲҷ-reflr _)
                (mk-lift true) вҶ’ sym (вҲҷ-reflr _))
          вҲҷ funext-вҲҷ
              (srcГ—tgt-natural-pair (srcГ—tgt u))
              (srcГ—tgt-homotopy (postcomp О”В№ f u)))

  srcГ—tgt-squareвүғpower-hom-is-equiv : is-Cube-equiv srcГ—tgt-squareвүғpower-hom
  srcГ—tgt-squareвүғpower-hom-is-equiv
    = srcГ—tgtвүғboundary-square .snd
    , srcГ—tgtвүғboundary-square .snd
}
%```
}

\subtree[fre-4007]{
\title{Fully faithful maps induce cartesian transformations of source-target maps}
\taxon{Proposition}
\author{fredrikbakke}
\date{2026-04-13}

\p{
A map #{f : A \to B} is fully faithful if and only if the induced square between
source-target maps #{A^{\Delta^1} \to A \times A} and
#{B^{\Delta^1} \to B \times B} is cartesian.
}

\proof{
\p{
By \ref{fre-4006}, this source-target square is equivalent to the square
#{\mathrm{Exp}(\partial\Delta^1\text{-}\mathrm{incl}, f)}, and that square is
cartesian if and only if the pullback power with the boundary inclusion of
#{\Delta^1} is an equivalence, which in turn is the orthogonality condition for fully
faithful maps.
}
}

%```agda
\agda{
module _ {рқ“Ө рқ“Ҙ : Level} {A : Type рқ“Ө} {B : Type рқ“Ҙ} {f : A вҶ’ B} where

  is-ffвҶ’is-cartesian-srcГ—tgt-square
    : is-ff f вҶ’ is-cartesian (srcГ—tgt-square f)
  is-ffвҶ’is-cartesian-srcГ—tgt-square ff
    = front-cartesianвҶҗequiv-transpose-cube
        (srcГ—tgt-squareвүғpower-hom f)
        (srcГ—tgt-squareвүғpower-hom-is-equiv f)
        (power-hom-cartesianвҶҗpullback-power
          вҲӮО”В№-incl f
          (pb-power-is-equivвҶҗorthogonal (ff tt)))

  is-ffвҶҗis-cartesian-srcГ—tgt-square
    : is-cartesian (srcГ—tgt-square f) вҶ’ is-ff f
  is-ffвҶҗis-cartesian-srcГ—tgt-square cart _
    = orthogonalвҶҗpb-power-is-equiv
        (pullback-powerвҶҗpower-hom-cartesian
          вҲӮО”В№-incl f
          (back-cartesianвҶҗequiv-transpose-cube
            (srcГ—tgt-squareвүғpower-hom f)
            (srcГ—tgt-squareвүғpower-hom-is-equiv f)
            (cart)))

  is-ffвҮ”is-cartesian-srcГ—tgt-square
    : is-ff f вҮ” is-cartesian (srcГ—tgt-square f)
  is-ffвҮ”is-cartesian-srcГ—tgt-square
    = ( is-ffвҶ’is-cartesian-srcГ—tgt-square
      , is-ffвҶҗis-cartesian-srcГ—tgt-square)
}
%```
}


\subtree[fre-16AF]{
\title{Fully faithful maps between Segal types are conservative}
\taxon{Theorem}
\author{fredrikbakke}
\date{2026-04-13}

\p{
Any fully faithful map between Segal types is conservative.
}

\proof{
\p{
Let #{F : \mathcal{C} \to \mathcal{D}} be a map of Segal types. It is conservative if
and only if every morphism #{f : \Hom_\mathcal{C}(x,y)} that is sent to an
isomorphism via #{F} is itself an isomorphism. Recall that a morphism is an
isomorphism if and only if it satisfies the covariant universal property of
isomorphisms: for all #{u : \mathcal{C}} the postcomposition map
#{f \circ {-} : \Hom_\mathcal{C}(u,x) \to \Hom_\mathcal{C}(u,y)} is an equivalence.
By definition we have a commuting square

\quiver{
\begin{tikzcd}
 \Hom_\mathcal{C}(u,x) && \Hom_\mathcal{D}(F(u),F(x)) \\
 \\
 \Hom_\mathcal{C}(u,y) && \Hom_\mathcal{D}(F(u),F(y))
\arrow[from=1-1, to=1-3, "\sim"]
\arrow[from=3-1, to=3-3, "\sim"]
\arrow[from=1-1, to=3-1, "f\circ {-}"']
\arrow[from=1-3, to=3-3, "F(f)\circ {-}"]
\end{tikzcd}
}
and so if #{F(f)} is an isomorphism then #{f} is as well.
}
}

\p{
This remains to be formalised.
[Issue#88](https://github.com/samtoth/agda-synthetic-categories/issues/88)
}
}

\subtree[stt-00AF]{
\title{The Root type former}
\taxon{Definition}

\agda{
\Keyword{open} \Module{[LFNotation](stt-00AG)}
}

\p{We also expose notation for exponentiating a context by #{I}, and show that
this has a functorial action by substution, as well as the unit and counit of
the adjunction #{-;I \dashv \mathcal{P}(-)}.}

\agda{
\Keyword{private}
  \Function{[𝓟](stt-00AG)} \Symbol{:} \Symbol{∀} \Symbol{\lbrace{}}\Bound{[𝓤](stt-00AG)}\Symbol{\rbrace{}} \Symbol{\lpar{}}\Bound{[A](stt-00AG)} \Symbol{:} \Primitive{[Type](Foundations.Universes)} \Bound{[𝓤](stt-00AG)}\Symbol{\rpar{}} \Symbol{→} \Primitive{[Type](Foundations.Universes)} \Symbol{\lpar{}}\Bound{[𝓤](stt-00AG)} \Primitive{\Operator{[⊔](/html/Agda.Primitive.html#961)}} \Bound{[𝓘](Archive.Synthetic.Tiny)}\Symbol{\rpar{}}
  \Function{[𝓟](stt-00AG)} \Bound{[A](stt-00AF)} \Symbol{=} \Bound{[I](Archive.Synthetic.Tiny)} \Symbol{→} \Bound{[A](stt-00AF)}

  \Function{[𝓟₁](stt-00AF)} \Symbol{:} \Symbol{∀} \Symbol{\lbrace{}}\Bound{[𝓤](stt-00AF)} \Bound{[𝓥](stt-00AF)}\Symbol{\rbrace{}} \Symbol{\lbrace{}}\Bound{[Γ](stt-00AF)} \Symbol{:} \Primitive{[Type](Foundations.Universes)} \Bound{[𝓤](stt-00AF)}\Symbol{\rbrace{}} \Symbol{\lbrace{}}\Bound{[Δ](stt-00AF)} \Symbol{:} \Primitive{[Type](Foundations.Universes)} \Bound{[𝓥](stt-00AF)}\Symbol{\rbrace{}}

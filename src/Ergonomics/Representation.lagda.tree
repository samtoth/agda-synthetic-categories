\agda{
ќ£вЖРfield-names : вИА {рЭУ§} {A : Type рЭУ§} вЖТ List A вЖТ Term
ќ£вЖРfield-names [] = def (quote рЭЯЩ) []
ќ£вЖРfield-names (_ вИЈ []) = unknown
ќ£вЖРfield-names (_ вИЈ xs) =
  def (quote ќ£) (lam visible (abs "_" (ќ£вЖРfield-names xs)) vвИЈ [])

Fields : Type
Fields = List (Name √Ч List Name)

-- an accessor is a term like fst (snd (snd (snd x)))
FieldsвЖРField-names : List (Arg Name) вЖТ Fields
FieldsвЖРField-names [] = []
FieldsвЖРField-names ((arg _ x) вИЈ []) = (x , []) вИЈ []
FieldsвЖРField-names (arg ai x вИЈ y вИЈ ys) with FieldsвЖРField-names (y вИЈ ys)
... | flds = (x , (quote fst вИЈ [])) вИЈ List-map (ќї (nm , p) вЖТ nm , quote snd вИЈ p) flds

iso-typeвЖРrecord : Name вЖТ Name вЖТ (List (Arg Term) вЖТ TC Term) вЖТ TC Term
iso-typeвЖРrecord eqty namen unfolded = go [] =<< normalise =<< infer-type (def namen []) where
  open DoTC

  go : List ArgInfo вЖТ Term вЖТ TC Term
  go acc (pi argu@(arg i argTy) (abs s ty)) = do
    r вЖР extend-context "arg" argu (go (i вИЈ acc) ty)
    returnTC (pi (argH argTy) (abs s r))
  go acc (agda-sort _) = do
    let orig = def namen (reverse (map-up (ќї n ai вЖТ arg ai (var n [])) 0 acc))
    repr     вЖР unfolded (reverse (map-up (ќї n _ вЖТ argH (var n [])) 0 acc))
    returnTC (def eqty (orig vвИЈ repr vвИЈ []))
  go acc t = typeError (strErr "Not a record type " вИЈ nameErr namen вИЈ [])


-- repr ._вЙК_.fwd a .snd .snd .fst = field2 a
fwd-clause : Name √Ч List Name вЖТ Clause
fwd-clause (field-nm , sel) = clause (("rec" , argN unknown) вИЈ [])
           (argN (proj (quote _вЙК_.fwd)) вИЈ
            argN (var 0) вИЈ
            List-map (argN вИШ proj) sel)
           (def field-nm (var 0 [] vвИЈ []))

-- repr ._вЙК_.fwd-qinv .fst x .fieldNm = fst (snd (snd ...))
bwd-clause : Name √Ч List Name вЖТ Clause
bwd-clause (field-nm , sel)
  = clause (("sig" , argN unknown) вИЈ [])
           (argN (proj (quote _вЙК_.fwd-qinv)) вИЈ
            argN (proj (quote fst)) вИЈ
            argN (var 0) вИЈ
            argN (proj field-nm)  вИЈ
            [])
           (foldr (ќї nm p вЖТ def nm (p vвИЈ [])) (var 0 []) (reverse sel))

fwd-bwd-clause : Clause
fwd-bwd-clause
  = clause (("rec" , (argN unknown)) вИЈ [])
           (argN (proj (quote _вЙК_.fwd-qinv)) вИЈ
            argN (proj (quote snd)) вИЈ
            argN (proj (quote fst)) вИЈ
            argN (var 0) вИЈ [])
           (con (quote refl) (unknown hвИЈ unknown hвИЈ unknown hвИЈ []))

bwd-fwd-clause : Clause
bwd-fwd-clause
  = clause (("sig" , (argN unknown)) вИЈ [])
           (argN (proj (quote _вЙК_.fwd-qinv)) вИЈ
            argN (proj (quote snd)) вИЈ
            argN (proj (quote snd)) вИЈ
            argN (var 0) вИЈ [])
           (con (quote refl) (unknown hвИЈ unknown hвИЈ unknown hвИЈ []))

-- Look up a record type definition in the signature.
get-record-type : Name вЖТ TC (Name √Ч List (Arg Name))
get-record-type n = get-definition n >>= ќї where
  (record-type conm fields) вЖТ returnTC (conm , fields)
  _ вЖТ typeError (
                strErr "get-record-type: definition " вИЈ
                nameErr n вИЈ
                strErr " is not a record type." вИЈ
                []) where
  open DoTC

private
  instantiate' : Term вЖТ Term вЖТ Term
  instantiate' (pi _ (abs _ xs)) (pi _ (abs _ b)) = instantiate' xs b
  instantiate' (agda-sort _) tm = tm
  instantiate' _ tm = tm

  sigmaвЖРpi-term : Term вЖТ TC Term
  sigmaвЖРpi-term (pi (arg _ x) (abs n (def n' _))) = returnTC x
  sigmaвЖРpi-term (pi (arg _ x) (abs n y)) = do
    sig вЖР sigmaвЖРpi-term y
    returnTC (def (quote ќ£) (x vвИЈ lam visible (abs n sig) vвИЈ []))
    where open DoTC
  sigmaвЖРpi-term _ = typeError (strErr "Not a record type constructor! " вИЈ [])


make-record-repr : Name вЖТ Name вЖТ Name вЖТ TC рЭЯЩ
make-record-repr iso eqv rec = do
  R-con , fields вЖР get-record-type rec
  let fields = FieldsвЖРField-names fields

  R-ty вЖР get-type rec
  con-ty вЖР get-type R-con

  let fun args = do
    let tm = instantiate' R-ty con-ty
    sigmaвЖРpi-term tm
  iso-type вЖР iso-typeвЖРrecord (quote _вЙК_) rec fun
  eqv-type вЖР iso-typeвЖРrecord (quote _вЙГ_) rec fun

  declare-def (argN iso) iso-type
  declare-def (argN eqv) eqv-type

  define-fun iso (List-map fwd-clause fields ++
                 (List-map bwd-clause fields ++
                 (fwd-bwd-clause вИЈ bwd-fwd-clause вИЈ [])))

  define-fun eqv (clause [] [] (def (quote equivвЖРqequiv) (def iso [] vвИЈ [])) вИЈ [])
  where open DoTC
}

\subtree[stt-0035]{
\taxon{Test}

\agda{
private module _ where
  record Test {рЭУ§} (A B : Type рЭУ§) : Type (lsuc рЭУ§) where
    constructor boo
    field
      f : A вЖТ B
      g : B вЖТ A
      h : f вИШ g ~ id

  record NoCtx : Type where
    field
      b : Bool
      s : String

  unquoteDecl test-reprвЙК' test-reprвЙГ' = make-record-repr test-reprвЙК' test-reprвЙГ' (quote Test)

  unquoteDecl noctx-reprвЙК noctx-reprвЙГ = make-record-repr noctx-reprвЙК noctx-reprвЙГ (quote NoCtx)

  _ : NoCtx вЙГ (Bool √Ч String)
  _ = noctx-reprвЙГ
}
}

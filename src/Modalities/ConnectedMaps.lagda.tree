\subtree[stt-00MQ]{
\taxon{Definition}
\title{Universal property of #{K}-connected maps}

\p{
Given a global subuniverse #{K} and a map #{f : A \to B}, then #{f} satisfies the
\em{universal property of #{K}-connected maps} if for every #{K}-valued family of
types #{U} over #{B}, the dependent precomposition map
#{\prod_{b : B} U(b) \to \prod_{a : A} U(f(a))} is an equivalence.
}

\p{
We use the abbreviation \code{up} for "universal property".
}

% ```agda
\agda{
up-connected-map : ‚ąÄ {őĪ ūĚď§ ūĚď•} (K : gSubU őĪ)
                    ‚Üí {A : Type ūĚď§} {B : Type ūĚď•}
                    ‚Üí (A ‚Üí B)
                    ‚Üí TypeŌČ
up-connected-map K f
  = ‚ąÄ {ūĚďö} {U : _ ‚Üí Type ūĚďö}
  ‚Üí (‚ąÄ b ‚Üí U b ‚ąą gSubU.S K)
  ‚Üí is-equiv (precomp-ő† U f)

up-connected-!-fibre
  : ‚ąÄ {őĪ ūĚď§ ūĚď•} (K : gSubU őĪ)
      {A : Type ūĚď§} {B : Type ūĚď•}
      (f : A ‚Üí B)
  ‚Üí TypeŌČ
up-connected-!-fibre K f
  = ‚ąÄ b ‚Üí up-modal-equiv K (!: fibre f b)

up-connected-fibres
  : ‚ąÄ {őĪ ūĚď§ ūĚď•} (K : gSubU őĪ)
      {A : Type ūĚď§} {B : Type ūĚď•}
      (f : A ‚Üí B)
  ‚Üí TypeŌČ
up-connected-fibres K f
  = ‚ąÄ b {ūĚďö} {U : Type ūĚďö}
    ‚Üí U ‚ąą gSubU.S K
    ‚Üí is-equiv (const U (fibre f b))
}
%```
}

\subtree[stt-00MC]{
\date{2026-03-19}
\author{fredrikbakke}
\taxon{Definition}
\title{#{K}-Connected maps}

\p{
If #{K} is a reflective subuniverse, a map is \em{#{K}-connected} if all of its
fibres have contractible reflections.
}

\agda{
is-connected-map
  : ‚ąÄ {őĪ ūĚď§ ūĚď•} (RS : gRSubU őĪ) {A : Type ūĚď§} {B : Type ūĚď•}
  ‚Üí (A ‚Üí B) ‚Üí Type (ūĚď§ ‚äĒ ūĚď•)
is-connected-map RS {B = B} f = (b : B) ‚Üí is-connected RS (fibre f b)

is-connected-map' : ‚ąÄ {ūĚď§ ūĚď• ūĚďú} {A : Type ūĚď§} {B : Type ūĚď•}
                     {S : SubU (ūĚď§ ‚äĒ ūĚď•) ūĚďú}
                   ‚Üí is-reflective S
                   ‚Üí (A ‚Üí B) ‚Üí Type (ūĚď§ ‚äĒ ūĚď•)
is-connected-map' {B = B} rfl f = (b : B) ‚Üí is-connected' rfl (fibre f b)
}
%```
}

\subtree[stt-0A2A]{
\title{Modal units are connected iff the modality is #{ő£}-closed}
\taxon{Lemma}
\author{samueltoth}

%```agda
\agda{
ő∑-is-connected
  : ‚ąÄ {őĪ} (RS : gRSubU őĪ)
  ‚Üí is-globally-ő£-closed (gRSubU.GS RS)
  ‚Üí ‚ąÄ {ūĚď§}{A : Type ūĚď§}
  ‚Üí is-connected-map RS (gRSubU.ő∑ RS {A = A})
ő∑-is-connected RS Gő£ {_} {A} x
  = mk-singl
      (ind {P = őĽ x ‚Üí ‚óč (fibre ő∑ x)}
           (őĽ _ ‚Üí ‚óč‚ąąS) (őĽ a ‚Üí ő∑ (a , refl)) x)
      (ind (őĽ _ ‚Üí ÔľĚ‚ąąS ‚óč‚ąąS) őĽ where (y , refl) ‚Üí ind-ő≤ _ _ y) where
  open gRSubU RS
  open gReflectiveClosure RS
  open gRSubUInduction RS Gő£
}
%```
}

\subtree[stt-0A2B]{
\title{Connected maps are closed under composition and are right cancellable}
\taxon{Lemma}
\author{samueltoth}
\author{fredrikbakke}

% ```agda
\agda{
up-connected-map-‚ąė
  : ‚ąÄ {őĪ ūĚď§ ūĚď• ūĚď¶}
      (K : gSubU őĪ)
      {A : Type ūĚď§} {B : Type ūĚď•} {C : Type ūĚď¶}
      (f : A ‚Üí B) (g : B ‚Üí C)
  ‚Üí up-connected-map K f
  ‚Üí up-connected-map K g
  ‚Üí up-connected-map K (g ‚ąė f)
up-connected-map-‚ąė K f g fconn gconn U‚ąąK
  = is-equiv-‚ąė (fconn (U‚ąąK ‚ąė g)) (gconn U‚ąąK)

up-connected-map-right-cancel
  : ‚ąÄ {őĪ ūĚď§ ūĚď• ūĚď¶}
      (K : gSubU őĪ)
      {A : Type ūĚď§} {B : Type ūĚď•} {C : Type ūĚď¶}
      (f : A ‚Üí B) (g : B ‚Üí C)
  ‚Üí up-connected-map K f
  ‚Üí up-connected-map K (g ‚ąė f)
  ‚Üí up-connected-map K g
up-connected-map-right-cancel K f g fconn gfconn U‚ąąK
  = 3-for-2 (fconn (U‚ąąK ‚ąė g)) (gfconn U‚ąąK)
}
%```

%```agda
\agda{
module _ {őĪ} (RS : gRSubU őĪ)
         where
  open gRSubU RS
  open gReflectiveClosure RS

  is-connected-map'-~
    : ‚ąÄ {ūĚď§ ūĚď•} {A : Type ūĚď§} {B : Type ūĚď•} {f g : A ‚Üí B} ‚Üí f ~ g
      ‚Üí is-connected-map RS f ‚Üí is-connected-map RS g
  is-connected-map'-~ = funext-rec _ őĽ where refl ‚Üí id

  is-connected-map‚Üźis-equiv
    : ‚ąÄ {ūĚď§ ūĚď•} {A : Type ūĚď§} {B : Type ūĚď•} {f : A ‚Üí B}
      ‚Üí is-equiv f ‚Üí is-connected-map RS f
  is-connected-map‚Üźis-equiv feq b = ‚óč-is-singleton (has-singleton-fibres‚Üźis-equiv feq b)


module _ {őĪ} (RS : gRSubU őĪ)
         (Ső£ : is-globally-ő£-closed (gRSubU.GS RS))
         where
  open gRSubU RS
  open gReflectiveReasoning RS
  open gRSubUInduction RS Ső£

  is-connected-map‚áĒ‚ąė
    : ‚ąÄ {ūĚď§ ūĚď• ūĚď¶} {A : Type ūĚď§} {B : Type ūĚď•} {C : Type ūĚď¶} {f : B ‚Üí C}
        {g : A ‚Üí B}
      ‚Üí is-connected-map RS g
      ‚Üí is-connected-map RS f
      ‚áĒ is-connected-map RS (f ‚ąė g)
  is-connected-map‚áĒ‚ąė {f = f}{g} gconn
    = ( (őĽ fc c ‚Üí is-single‚Üźequiv-to-single (eqv c e‚ĀĽ¬Ļ) (fc c))
       , őĽ fgc c ‚Üí is-single‚Üźequiv-to-single (eqv c) (fgc c)) where
    eqv : ‚ąÄ z ‚Üí ‚óč (fibre (f ‚ąė g) z) ‚ČÉ ‚óč (fibre f z)
    eqv z
      = ‚óč (fibre (f ‚ąė g) z) ‚ČÉ‚ü® ‚óč-‚ČÉ (fibre-‚ąė z) ‚ü©
        ‚óč (ő£ (fibre f z) (őĽ x ‚Üí fibre g (fst x)))
                            ‚ČÉ‚ü® mk‚ČÉ _ (ő£‚óč-is-equiv RS _) ‚ü©
        ‚óč (ő£ (fibre f z) (őĽ x ‚Üí ‚óč (fibre g (fst x))))
                            ‚ČÉ‚ü® ‚óč-‚ČÉ (ő£-singleton (őĽ x ‚Üí gconn (fst x))) ‚ü©
        ‚óč (fibre f z)       ‚ČÉ‚ąé

  is-connected-map-‚ąė
    : ‚ąÄ {ūĚď§ ūĚď• ūĚď¶} {A : Type ūĚď§} {B : Type ūĚď•} {C : Type ūĚď¶} {f : B ‚Üí C}
        {g : A ‚Üí B}
      ‚Üí is-connected-map RS g
      ‚Üí is-connected-map RS f
      ‚Üí is-connected-map RS (f ‚ąė g)
  is-connected-map-‚ąė gc = is-connected-map‚áĒ‚ąė gc .fst

  is-connected-map‚Üźis-arrow-equiv
    : ‚ąÄ {ūĚď§ ūĚď• ūĚď¶ ūĚďú} {A : Type ūĚď§} {B : Type ūĚď•} {X : Type ūĚď¶} {Y : Type ūĚďú}
        {f : A ‚Üí B} {g : X ‚Üí Y}
      ‚Üí (F : Arrow-map f g)
      ‚Üí is-Arrow-equiv F
      ‚Üí is-connected-map RS f
      ‚Üí is-connected-map RS g
  is-connected-map‚Üźis-arrow-equiv {f = f} {g = g} F fe fconn
    = is-connected-map‚áĒ‚ąė
        {f = g} {F .Arrow-map.top}
        (is-connected-map‚Üźis-equiv RS (fe .fst)) .snd
        (is-connected-map'-~ RS
          (F .Arrow-map.comm)
          (is-connected-map-‚ąė fconn (is-connected-map‚Üźis-equiv RS (fe .snd))))

  is-connected-map‚Üźis-arrow-equiv‚ĀĽ¬Ļ
    : ‚ąÄ {ūĚď§ ūĚď• ūĚď¶ ūĚďú} {A : Type ūĚď§} {B : Type ūĚď•} {X : Type ūĚď¶} {Y : Type ūĚďú}
        {f : A ‚Üí B} {g : X ‚Üí Y}
      ‚Üí (F : Arrow-map f g)
      ‚Üí (let module F = Arrow-map F)
      ‚Üí is-Arrow-equiv F
      ‚Üí is-connected-map RS g
      ‚Üí is-connected-map RS f
  is-connected-map‚Üźis-arrow-equiv‚ĀĽ¬Ļ F fe
    = is-connected-map‚Üźis-arrow-equiv
        (Arrow‚ĀĽ¬Ļ‚Üźis-Arrow-equiv F fe)
        (Arrow‚ĀĽ¬Ļ-is-equiv F fe)
}
%```
}

\subtree[stt-02AE]{
\author{fredrikbakke}
\author{samueltoth}
\taxon{Theorem}
\title{Connected maps are left orthogonal to modal maps}

% ```agda
\agda{
up-connected‚ä•modal
  : ‚ąÄ {őĪ ūĚď§ ūĚď•} (K : gSubU őĪ)
      {A : Type ūĚď§} {B : Type ūĚď•}
      (f : A ‚Üí B)
  ‚Üí up-connected-map K f
  ‚Üí {ūĚď¶ ūĚďõ : Level} {C : Type ūĚď¶} {D : Type ūĚďõ}
    (g : C ‚Üí D)
  ‚Üí is-modal-map K g
  ‚Üí are-orthogonal f g
up-connected‚ä•modal K f fconn g g‚ąąK
  = orthogonal‚Üźprecomp-ő† őĽ h ‚Üí fconn (őĽ b ‚Üí g‚ąąK (h b))

up-connected-map‚Üź‚ä•modal
  : ‚ąÄ {őĪ ūĚď§ ūĚď•} (K : gSubU őĪ)
      {A : Type ūĚď§} {B : Type ūĚď•}
      (f : A ‚Üí B)
    ‚Üí (‚ąÄ {ūĚď¶ ūĚďõ} {C : Type ūĚď¶} {D : Type ūĚďõ}
        (g : C ‚Üí D)
        ‚Üí is-modal-map K g
        ‚Üí are-orthogonal f g)
    ‚Üí up-connected-map K f
up-connected-map‚Üź‚ä•modal K f orth {U = U} U‚ąąK
  = is-equiv‚ÜźArrow-equiv‚ĀĽ¬Ļ {F = eq .fst} (eq .snd)
      (precomp-ő†‚Üźorthogonal id (orth fst fst‚ąąK)) where

  fst‚ąąK : is-modal-map K (fst {B = U})
  fst‚ąąK b = gSubU.‚ąąS‚Üźequiv K (fibre-straighten U b e‚ĀĽ¬Ļ) (U‚ąąK b)

  eq = precomp-ő†-straighten-Arrow-equiv U f
}
%```
}

\subtree[stt-00MD]{
\date{2026-03-20}
\author{fredrikbakke}
\taxon{Proposition}
\title{Closure properties of #{K}-connected maps}

\p{
Connected maps are stable under homotopies, retracts of arrows, and cobase change.
}

% ```agda
\agda{
up-connected-map-homotopy
  : ‚ąÄ {őĪ ūĚď§ ūĚď•}
      (K : gSubU őĪ)
      {A : Type ūĚď§} {B : Type ūĚď•}
      {f g : A ‚Üí B}
    ‚Üí f ~ g
    ‚Üí up-connected-map K f
    ‚Üí up-connected-map K g
up-connected-map-homotopy K {f = f} {g = g} H fconn
  = up-connected-map‚Üź‚ä•modal K g őĽ h hmodal
      ‚Üí left-orthogonal-homotopy h H
          (up-connected‚ä•modal K f fconn h hmodal)

up-connected-map-‚ąė~
  : ‚ąÄ {őĪ ūĚď§ ūĚď• ūĚď¶}
      (K : gSubU őĪ)
      {A : Type ūĚď§} {B : Type ūĚď•} {C : Type ūĚď¶}
      {h : A ‚Üí C}
      (f : A ‚Üí B) (g : B ‚Üí C)
    ‚Üí h ~ g ‚ąė f
    ‚Üí up-connected-map K f
    ‚Üí up-connected-map K g
    ‚Üí up-connected-map K h
up-connected-map-‚ąė~ K f g H fconn gconn
  = up-connected-map-homotopy K (H ~‚ĀĽ¬Ļ)
      (up-connected-map-‚ąė K f g fconn gconn)

up-connected-map-right-cancel~
  : ‚ąÄ {őĪ ūĚď§ ūĚď• ūĚď¶}
      (K : gSubU őĪ)
      {A : Type ūĚď§} {B : Type ūĚď•} {C : Type ūĚď¶}
      {h : A ‚Üí C}
      (f : A ‚Üí B) (g : B ‚Üí C)
    ‚Üí h ~ g ‚ąė f
    ‚Üí up-connected-map K f
    ‚Üí up-connected-map K h
    ‚Üí up-connected-map K g
up-connected-map-right-cancel~ K f g H fconn hconn
  = up-connected-map-right-cancel K f g fconn
      (up-connected-map-homotopy K H hconn)

up-connected-map‚Üźretraction-arrow-map
  : ‚ąÄ {őĪ ūĚď§ ūĚď• ūĚď¶ ūĚďõ}
      (K : gSubU őĪ)
      {A : Type ūĚď§} {B : Type ūĚď•} {f : A ‚Üí B}
      {X : Type ūĚď¶} {Y : Type ūĚďõ} {g : X ‚Üí Y}
      (F : Arrow-map f g)
    ‚Üí retraction-arrow-map F
    ‚Üí up-connected-map K g
    ‚Üí up-connected-map K f
up-connected-map‚Üźretraction-arrow-map K {f = f} {g = g} F R gconn
  = up-connected-map‚Üź‚ä•modal K f őĽ h hmodal
      ‚Üí left-orthogonal-retraction f g F R h
          (up-connected‚ä•modal K g gconn h hmodal)

up-connected-map‚Üźcocartesian
  : ‚ąÄ {őĪ ūĚď§ ūĚď• ūĚď¶ ūĚďõ}
      (K : gSubU őĪ)
      {A : Type ūĚď§} {B : Type ūĚď•} {f : A ‚Üí B}
      {X : Type ūĚď¶} {Y : Type ūĚďõ} {g : X ‚Üí Y}
      (F : Arrow-map f g)
    ‚Üí is-cocartesianŌČ F
    ‚Üí up-connected-map K f
    ‚Üí up-connected-map K g
up-connected-map‚Üźcocartesian K {f = f} {g = g} F cocart fconn
  = up-connected-map‚Üź‚ä•modal K g őĽ h hmodal
      ‚Üí left-orthogonal-pushout F cocart h
          (up-connected‚ä•modal K f fconn h hmodal)

up-connected-map-őĻ‚āā
  : ‚ąÄ {őĪ ūĚď§ ūĚď• ūĚď¶}
      (K : gSubU őĪ)
      {A : Type ūĚď§} {B : Type ūĚď•} {C : Type ūĚď¶}
      (f : A ‚Üí B) (g : A ‚Üí C)
    ‚Üí up-connected-map K f
    ‚Üí up-connected-map K (őĻ‚āā {f = f} {g = g})
up-connected-map-őĻ‚āā K f g
  = up-connected-map‚Üźcocartesian K
      (Pushout-square (mk-span _ f g))
      (Pushout-square-is-cocartesian (mk-span _ f g))
}
%```
}

\subtree[stt-00ME]{
\date{2026-03-19}

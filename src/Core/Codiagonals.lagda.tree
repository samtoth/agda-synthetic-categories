\subtree[stt-005M]{
  \taxon{Definition}
  \title{The codiagonal map}
  \p{Given a map #{f : B \to C}, we can define the map #{\nabla_f : B +^A B \to C}
  called the codiagonal map.}

\agda{
вИЗ : вИА {рЭУ§ рЭУ•} {A : Type рЭУ§} {B : Type рЭУ•}
      (f : A вЖТ B)
    вЖТ Pushout f f вЖТ B
вИЗ f = pushout-rec (mk-cocone id id ~refl)
}
}


\subtree[stt-0064]{
\title{Pullback of postcomposition is a cocone}

\agda{
CoconeвЖРPullback
  : вИА {рЭУ§ рЭУ• рЭУ¶ рЭУЬ} {A : Type рЭУ§} {B : Type рЭУ•}
      {C : Type рЭУ¶} {f : A вЖТ B} {g : A вЖТ C}
      {X : Type рЭУЬ}
    вЖТ Pullback (precomp X f) (precomp X g)
    вЖТ Cocone (mk-span A f g) X
CoconeвЖРPullback (p , q , H) =  mk-cocone p q (happly H)

CoconeвЖРPullback-is-equiv
  : вИА {рЭУ§ рЭУ• рЭУ¶ рЭУЬ} {A : Type рЭУ§} {B : Type рЭУ•}
      {C : Type рЭУ¶} {f : A вЖТ B} {g : A вЖТ C}
      {X : Type рЭУЬ}
    вЖТ is-equiv (CoconeвЖРPullback {f = f} {g} {X})
CoconeвЖРPullback-is-equiv = is-equivвЖРqinv ќї where
  .fst (mk-cocone p q H) вЖТ (p , q , funextвЖТ H)
  .snd .fst (p , q , H) вЖТ ap (ќї H вЖТ (p , q , H)) (funext.ќЈ _)
  .snd .snd (mk-cocone p q H) вЖТ ap (mk-cocone p q) (funext-redex {p = H})
}
}

\subtree[stt-0063]{
\title{Connection between diagonal and codiagonal}
\taxon{Theorem}
\citet{2.11}{RSS2020}

\p{We can construct a map in the [coslice category](stt-0062)
from postcomposition by the [codiagonal](stt-005M) of #{f : A \to B}
to the [diagonal](stt-005X) of postcomposition by #{f}. This map
is an equivalence.}

\quiver{
\begin{tikzcd}
	&& {X^A} \\
	\\
	{B +^A B \to X} &&&& {X^B \times_{X^A} X^B}
	\arrow["{{-}\circ \nabla_f}"', from=1-3, to=3-1]
	\arrow["{\Delta_{{-}\circ f}}", from=1-3, to=3-5]
	\arrow["\sim"', from=3-1, to=3-5]
\end{tikzcd}
}

\agda{
ќФвЖРвИЗ
  : вИА {рЭУ§ рЭУ• рЭУ¶} {A : Type рЭУ§} {B : Type рЭУ•}
      (f : A вЖТ B) (X : Type рЭУ¶)
    вЖТ Coslice-map (diagonal (precomp X f)) (precomp X (вИЗ f))
ќФвЖРвИЗ f X .fst = cogap вИШ CoconeвЖРPullback
ќФвЖРвИЗ f X .snd g = funextвЖТ (pushout-ind _ (mk-coconeбµИ ~refl ~refl
    ќї a вЖТ IdбµИ-funcвЖРSquare (glue a) refl refl
      (mk-square
        (вИЩ-reflr _
        вИЩ pushout-rec-apќ≤ a
        вИЩ sym ( ap-вИШ g _ _
              вИЩ ap (ap g) (pushout-rec-apќ≤ a))))))

ќФвЖРвИЗ-is-equiv
  : вИА {рЭУ§ рЭУ• рЭУ¶} {A : Type рЭУ§} {B : Type рЭУ•}
      {f : A вЖТ B} {X : Type рЭУ¶}
    вЖТ is-coslice-equiv (ќФвЖРвИЗ f X)
ќФвЖРвИЗ-is-equiv = is-equiv-вИШ pushout-rec-is-equiv CoconeвЖРPullback-is-equiv
}
}

\title{Nullification}
\taxon{Module}
\import{stt-macros}

%```agda
\agda{
module Modalities.Instances.Nullification where

open import ufAxioms
open import Axioms.FreeAlgInj
open import Foundations.Prelude
open import Core.Arrow
open import Core.ArrowEquiv
open import Core.ArrowRetract
open import Modalities.Instances.Localisation
open import Modalities.HigherModality
open import Modalities.Subuniverses
open import Modalities.GlobalSubuniverses
open import Modalities.GlobalReflectiveSubuniverses
}
%```

\subtree[stt-005G]{
\date{2025-06-17}
\author{samueltoth}
\taxon{Definition}
\title{Null types}

\p{
Given a family of types #{A_i}, we say a type #{X} is #{A} \em{null} if
it is right orthogonal to each #{A_i}. Or equivalently, if the
obvious maps #{X \to (A_i \to X)} are equivalences for each #{i}.
}

%```agda
\agda{
module _
  {ЁЭУШ ЁЭУд ЁЭУе : Level} {I : Type ЁЭУШ}
  where

  is-null : (A : I тЖТ Type ЁЭУд) тЖТ Type ЁЭУе тЖТ Type (ЁЭУШ тКФ ЁЭУд тКФ ЁЭУе)
  is-null A X = (i : I) тЖТ is-equiv (const X (A i))

  is-null-is-prop
    : {A : I тЖТ Type ЁЭУд}
    тЖТ (X : Type ЁЭУе) тЖТ is-prop (is-null A X)
  is-null-is-prop X = is-prop-╬а ╬╗ a тЖТ is-equiv-is-prop

  nullтЙГ : {A : I тЖТ Type ЁЭУд}
          {X : Type ЁЭУе} (_ : is-null A X) (i : I)
        тЖТ X тЙГ (A i тЖТ X)
  nullтЙГ {A} {X} An i = mkтЙГ (const X (A i)) (An i)

  is-null-equiv
    : {A : I тЖТ Type ЁЭУд}
      {X : Type ЁЭУе} {Y : Type ЁЭУе}
    тЖТ X тЙГ Y
    тЖТ is-null A X
    тЖТ is-null A Y
  is-null-equiv e anull i
    = is-equivтЖРArrow-equiv
        {F = mk-amap fwd (postcomp _ fwd) ~refl}
        (has-is-eqv , postcomp-equiv has-is-eqv)
        (anull i) where
    open _тЙГ_ e

Null-SubU
  : тИА {ЁЭУШ ЁЭУд} {I : Type ЁЭУШ}
      (A : I тЖТ Type ЁЭУд)
      ЁЭУж
    тЖТ SubU ЁЭУж (ЁЭУж тКФ ЁЭУШ тКФ ЁЭУд)
Null-SubU A ЁЭУж .Subtype.family = is-null A
Null-SubU A ЁЭУж .Subtype.has-is-subtype = is-null-is-prop
}
%```
}


\subtree[stt-005H]{
\date{2025-06-17}
\author{samueltoth}
\taxon{Theorem}
\title{Null types are #{!}-local}

\p{A type is #{A_i}-null iff it is #{(! : A_i \to 1)}-local.}

\proof{ \p{A type #{X} is #{!\rm{-local}} when the map #{- \circ\ ! :
(1 \to X) \to (A_i \to X)} is an equivalence.}
}

%```agda
\agda{
is-localтЖРis-null : тИА {ЁЭУШ ЁЭУд ЁЭУе} {I : Type ЁЭУШ} {A : I тЖТ Type ЁЭУд}
                   тЖТ {X : Type ЁЭУе}
                   тЖТ is-null A X
                   тЖТ is-local (╬╗ i тЖТ !: A i) X
is-localтЖРis-null eq i = 3-for-2' (point-is-equiv) (eq i)

is-local-singтЖРis-null : тИА {ЁЭУШ ЁЭУд ЁЭУе ЁЭУж} {I : Type ЁЭУШ}
                          {A : I тЖТ Type ЁЭУд}
                          {B : I тЖТ Type ЁЭУе}
                          (Bsing : тИА i тЖТ is-singleton (B i))
                          (f : тИА i тЖТ A i тЖТ B i)
                        тЖТ {X : Type ЁЭУж}
                        тЖТ is-null A X
                        тЖТ is-local f X
is-local-singтЖРis-null Bsing f null i
  = 3-for-2'
    (is-equivтБ╗┬╣ (sing-ev-is-equiv global-funext (Bsing i)))
    (null i)

is-nullтЖРis-local : тИА {ЁЭУШ ЁЭУд ЁЭУе} {I : Type ЁЭУШ} {A : I тЖТ Type ЁЭУд}
                   тЖТ {X : Type ЁЭУе}
                   тЖТ is-local (╬╗ i тЖТ !: A i) X
                   тЖТ is-null A X
is-nullтЖРis-local eq i = is-equiv-тИШ (eq i) point-is-equiv

is-nullтЖРis-local-sing : тИА {ЁЭУШ ЁЭУд ЁЭУе ЁЭУж} {I : Type ЁЭУШ}
                          {A : I тЖТ Type ЁЭУд}
                          {B : I тЖТ Type ЁЭУе}
                          (Bsing : тИА i тЖТ is-singleton (B i))
                          (f : тИА i тЖТ A i тЖТ B i)
                        тЖТ {X : Type ЁЭУж}
                        тЖТ is-local f X
                        тЖТ is-null A X
is-nullтЖРis-local-sing Bs f loc i
  = is-equiv-тИШ
      (loc i)
      (is-equivтБ╗┬╣ (sing-ev-is-equiv global-funext (Bs i)))

NullтЙГ!Local
  : тИА {ЁЭУШ ЁЭУд ЁЭУе} {I : Type ЁЭУШ} {A : I тЖТ Type ЁЭУд}
  тЖТ Subtype-equiv (Local-SubU (╬╗ i тЖТ !: A i) ЁЭУе)
                  (Null-SubU A ЁЭУе)
NullтЙГ!Local A = (is-nullтЖРis-local , is-localтЖРis-null)
}
%```
}

\subtree[stt-005K]{
\date{2025-06-17}
\author{samueltoth}
\title{Nullification at a pointed family}
\taxon{Definition}

\p{The nullification of a pointed type can be constructed
using the [free algebraic injection](stt-005I)
higher inductive type. By definition, the free
algebraic injection already gives a section to
the precomposition map. Because any map #{A \to 1}
has a section, then the precomposition by this
map already has a retract, and so the type is not just
algebraically #{A}-injective, but #{A}-null.}

%```agda
\agda{
NullтИЩ : тИА {ЁЭУШ ЁЭУд ЁЭУе} {I : Type ЁЭУШ} (A : I тЖТ Type ЁЭУд)
         (AтИЩ : ╬а _ A) (X : Type ЁЭУе)
       тЖТ Type ЁЭУе
NullтИЩ A _ X = Free-inj
               (╬╗ i тЖТ !: A i)
                X

NullтИЩ-is-null : тИА {ЁЭУШ ЁЭУд ЁЭУе} {I : Type ЁЭУШ}
                 {A : I тЖТ Type ЁЭУд} (AтИЩ : ╬а _ A)
                 {X : Type ЁЭУе}
               тЖТ is-null A (NullтИЩ A AтИЩ X)
NullтИЩ-is-null a = is-nullтЖРis-local I where
  I : is-local (╬╗ _ тЖТ !) _
  I i = is-equivтЖРqiso ╬╗ where
    .fst тЖТ injector-Free-inj i .fst
    .snd .fst ╬▒ тЖТ funextтЖТ (╬╗ _ тЖТ Free-inj.is-ext (╬▒ тИШ !) (a i))
    .snd .snd тЖТ injector-Free-inj i .snd
}
%```
}

\subtree[stt-0065]{
\date{2025-06-21}
\author{samueltoth}
\title{Nullification is a [reflective subuniverse](stt-0041)}
\taxon{Corollary}


%```agda
\agda{
module _ where
  open is-globally-reflective
  open is-global-reflector

  Null-gSubU : тИА {ЁЭУШ ЁЭУд} {I : Type ЁЭУШ}
               (A : I тЖТ Type ЁЭУд)
              тЖТ gSubU (_тКФ (ЁЭУШ тКФ ЁЭУд))
  Null-gSubU A .gSubU.S = Null-SubU A _
  Null-gSubU A .gSubU.тИИSтЖРequiv e anull i
    = is-equivтЖРArrow-equiv
        {F = mk-amap fwd (postcomp _ fwd) ~refl}
        (has-is-eqv , postcomp-equiv has-is-eqv)
        (anull i) where open _тЙГ_ e

  Null-globally-reflective
    : тИА {ЁЭУШ ЁЭУд} {I : Type ЁЭУШ} {A : I тЖТ Type ЁЭУд}
    тЖТ is-globally-reflective (Null-gSubU A)
  Null-globally-reflective {A = A}
    = is-globally-reflective-subtype-equiv
        (NullтЙГ!Local)
        (Local-global-reflectors (╬╗ i тЖТ !: A i))

  opaque
    NullтИЩ-global-reflectors
      : тИА {ЁЭУШ ЁЭУд} {I : Type ЁЭУШ}
          {A : I тЖТ Type ЁЭУд}
          (aтИЩ : тИА i тЖТ A i)
        тЖТ is-globally-reflective (Null-gSubU A)
    NullтИЩ-global-reflectors a .тЧЛ = NullтИЩ _ a
    NullтИЩ-global-reflectors a .╬╖ = Free-inj.inc
    NullтИЩ-global-reflectors a .has-is-reflector
      .тЧЛтИИS = NullтИЩ-is-null a
    NullтИЩ-global-reflectors a .has-is-reflector
      .reflects cnull = Free-inj-reflects _ (is-localтЖРis-null cnull)

  NullтИЩ-reflective
    : тИА {ЁЭУШ ЁЭУд ЁЭУж} {I : Type ЁЭУШ}
        {A : I тЖТ Type ЁЭУд}
        (aтИЩ : тИА i тЖТ A i)
      тЖТ is-reflective (Null-SubU A ЁЭУж)
  NullтИЩ-reflective a = is-reflectiveтЖРglobal (NullтИЩ-global-reflectors a)

  Null-gRSubU
    : тИА {ЁЭУШ ЁЭУд} {I : Type ЁЭУШ} (A : I тЖТ Type ЁЭУд)
    тЖТ gRSubU (_тКФ (ЁЭУШ тКФ ЁЭУд))
  Null-gRSubU A .gRSubU.GS = Null-gSubU A
  Null-gRSubU A .gRSubU.has-is-globally-reflective = Null-globally-reflective

  NullтИЩ-gRSubU
    : тИА {ЁЭУШ ЁЭУд} {I : Type ЁЭУШ}
        {A : I тЖТ Type ЁЭУд}
        (aтИЩ : тИА i тЖТ A i)
      тЖТ gRSubU (_тКФ (ЁЭУШ тКФ ЁЭУд))
  NullтИЩ-gRSubU {A = A} a .gRSubU.GS = Null-gSubU A
  NullтИЩ-gRSubU a .gRSubU.has-is-globally-reflective = NullтИЩ-global-reflectors a
}
%```
}

\subtree[stt-006E]{
\date{2025-06-25}
\author{samueltoth}
\taxon{Theorem}
\title{Nullification is a #{\Sigma}-closed reflective subuniverse}

\p{Nullification is a #{\Sigma}-closed reflective subuniverse and so
is also a higher modality.}

\proof{
\p{By calculation:}

##{
\begin{align}
  \Sigma_{(x : X)} Y(x)  &\simeq \Sigma_{(x : X)} A_i \to Y(x) \\
                         &\simeq \Sigma_{(x : A_i \to X)} \Pi_{(a : A_i)} Y(f(a))\\
                         &\simeq A_i \to \Sigma_{(x : X)} Y(x)
\end{align}
}

\p{Where (1) and (2) follow from the fact #{X} and each #{Y(x)} are
#{A}-[null](stt-005G), and (3) is the [type theoretic theorem of
choice](Foundations.TheoremOfChoice).}  }

%```agda
\agda{
╬г-is-null : тИА {ЁЭУШ ЁЭУд ЁЭУе ЁЭУж}
              {I : Type ЁЭУШ}
              {P : I тЖТ Type ЁЭУд}
              {X : Type ЁЭУе} {Y : X тЖТ Type ЁЭУж}
            тЖТ is-null P X
            тЖТ (тИА x тЖТ is-null P (Y x))
            тЖТ is-null P (╬г X Y)
╬г-is-null {P = P} {X = X} {Y} Xnull Ynull i
  = eqv where
  opaque
    I : ╬г X Y тЙГ (P i тЖТ ╬г X Y)
    I = ╬г X Y
          тЙГтЯи ╬г-ap-тЙГ (╬╗ x тЖТ nullтЙГ (Ynull x) i) тЯй
        ╬г X (╬╗ x тЖТ P i тЖТ Y x)
          тЙГтЯи ╬г-ap-тЙГ-fst {B = ╬╗ f тЖТ (a : P i) тЖТ Y (f a)} (nullтЙГ Xnull i) тЯй
        ╬г (P i тЖТ X) (╬╗ f тЖТ (a : P i) тЖТ Y (f a))
          тЙГтЯи ╬г-╬а-swapтЙГ (╬╗ _ тЖТ X) (╬╗ _ тЖТ Y) eтБ╗┬╣ тЯй
        (P i тЖТ ╬г X Y) тЙГтИО

    eqv : is-equiv (const (╬г X Y) (P i))
    eqv = I ._тЙГ_.has-is-eqv

Null-globally-╬г-closed : тИА {ЁЭУШ ЁЭУд} {I : Type ЁЭУШ}
                   {P : I тЖТ Type ЁЭУд}
                 тЖТ is-globally-╬г-closed (Null-gSubU P)
Null-globally-╬г-closed = ╬г-is-null

Null-gRSubU-╬г-closed
  : тИА {ЁЭУШ ЁЭУд} {I : Type ЁЭУШ}
      (P : I тЖТ Type ЁЭУд)
    тЖТ is-globally-╬г-closed (Null-gRSubU P .gRSubU.GS)
Null-gRSubU-╬г-closed P = Null-globally-╬г-closed

Null-╬г-closed : тИА {ЁЭУШ ЁЭУд ЁЭУж} {I : Type ЁЭУШ}
                   {A : I тЖТ Type ЁЭУд}
                 тЖТ is-╬г-closed (Null-SubU A ЁЭУж)
Null-╬г-closed {A = A}
  = is-╬г-closedтЖРglobally (Null-gSubU A) Null-globally-╬г-closed

NullтИЩ-HigherModality
  : тИА {ЁЭУШ ЁЭУд ЁЭУж} {I : Type ЁЭУШ}
      {A : I тЖТ Type ЁЭУд}
      (a : ╬а _ A)
    тЖТ HigherModality ЁЭУж
NullтИЩ-HigherModality a
  = HigherModalityтЖРSubU (NullтИЩ-reflective a) (Null-╬г-closed)

module _
  {ЁЭУШ ЁЭУд : Level} {I : Type ЁЭУШ}
  (X : I тЖТ Type ЁЭУд)
  where

  open gSubU (Null-gSubU X) public using () renaming
    ( тИИSтЖРequiv to is-nullтЖРequiv)

  open gReflectiveClosure (Null-gRSubU X) public using () renaming
    ( тИИSтЖРretract to is-nullтЖРretract
    ; ╬атИИS to ╬а-is-null
    ; ULiftтИИS to ULift-is-null
    ; ЁЭЯЩтИИS to ЁЭЯЩ-is-null
    ; тИИSтЖРis-singleton to is-nullтЖРis-singleton
    ; PullbackтИИS to Pullback-is-null
    ; fibreтИИS to fibre-is-null
    ; ├ЧтИИS to ├Ч-is-null
    ; я╝ЭтИИS to я╝Э-is-null
    ; ~тИИS to ~-is-null
    ; retractтИИS to retract-is-null
    ; biinvтИИS to biinv-is-null
    ; тЙГтИИS to тЙГ-is-null
    ; EqualiserтИИS to Equaliser-is-null
    ; Seq-limтИИS to Seq-lim-is-null
    ; preidempotent-mapтИИS to preidempotent-map-is-null
    ; qidempotent-mapтИИS to qidempotent-map-is-null
    ; RetractsтИИS to Retracts-is-null)

module Null
  {ЁЭУШ ЁЭУд : Level} {I : Type ЁЭУШ}
  (A : I тЖТ Type ЁЭУд)
  where

  open gRSubUInduction (Null-gRSubU A) (Null-gRSubU-╬г-closed A) public
  open gSubU (Null-gSubU A) public
  open gRSubU (Null-gRSubU A) public
  open gReflectiveClosure (Null-gRSubU A) public

}
%```
}

\subtree[stt-00GG]{
\date{2026-03-18}
\author{fredrikbakke}
\title{Localisations at families of maps into contractible types are higher modalities}
\taxon{Corollary}

\p{
If each codomain #{B_i} is [contractible](stt-000F), then localisation at
#{f_i : A_i \to B_i} is [\Sigma-closed](stt-006F), and hence determines a
higher modality.
}

%```agda
\agda{
module _ {ЁЭУШ ЁЭУд ЁЭУе ЁЭУж : Level} {I : Type ЁЭУШ}
         {A : I тЖТ Type ЁЭУд} {B : I тЖТ Type ЁЭУе}
         where

  Local-╬г-closed
    : (f : (i : I) тЖТ A i тЖТ B i)
    тЖТ (тИА i тЖТ is-singleton (B i))
    тЖТ is-╬г-closed (Local-SubU f ЁЭУж)
  Local-╬г-closed f sngl aloc bloc
    = is-local-singтЖРis-null sngl f
        (Null-╬г-closed
          (is-nullтЖРis-local-sing sngl f aloc)
          ╬╗ a тЖТ is-nullтЖРis-local-sing sngl f (bloc a))

  Local-HigherModality
    : (f : (i : I) тЖТ A i тЖТ B i)
    тЖТ (тИА i тЖТ is-singleton (B i))
    тЖТ HigherModality ЁЭУж
  Local-HigherModality f s
    = HigherModalityтЖРSubU
        (Local-reflective f)
        (Local-╬г-closed f s)
}
%```
}

\subtree[stt-00GY]{
\date{2026-03-10}
\author{fredrikbakke}
\title{Closure of null types under retracts in the exponent}
\taxon{Lemma}

\p{
Given an #{A}-[null](stt-005G) type #{X}, then #{X} is null at any
[retract](stt-00HE) of #{A}.
}

%```agda
\agda{
module _
  {ЁЭУШ ЁЭУд ЁЭУе : Level} {I : Type ЁЭУШ}
  where

  is-nullтЖРretract-exponent
    : {A : I тЖТ Type ЁЭУд}
      {B : I тЖТ Type ЁЭУд}
      {X : Type ЁЭУе}
    тЖТ ((i : I) тЖТ retract (A i) (B i))
    тЖТ is-null B X
    тЖТ is-null A X
  is-nullтЖРretract-exponent {A = A} {B} {X} R Bnull i
    = is-equivтЖРincoherent-retraction-equiv
        (mk-amap id (precomp X (R i .snd .fst)) ~refl)
        (mk-amap id (precomp X (R i .fst)) ~refl
        , ~refl
        , ╬╗ h тЖТ funextтЖТ ╬╗ a тЖТ ap h (R i .snd .snd a))
        (Bnull i)
}
%```
}

\subtree[stt-00GD]{
\date{2026-03-09}
\author{fredrikbakke}
\title{The universe of null types in a subuniverse at a family of propositions}
\taxon{Theorem}

\p{
Let #{P_i} be a family of propositions, and let #{\mathcal{S}} be a
[global subuniverse](stt-007A) which is closed under dependent products over each
#{P_i}. Then the type of #{P}-null types in #{\mathcal{S}} is again #{P}-null.
}

%```agda
\agda{
Null-in-gSubU
  : {╬▒ : Level тЖТ Level} {ЁЭУШ ЁЭУд : Level} {I : Type ЁЭУШ}
  тЖТ (P : I тЖТ Type ЁЭУд)
  тЖТ gSubU ╬▒
  тЖТ тИА ЁЭУе тЖТ Type (lsuc (ЁЭУд тКФ ЁЭУе) тКФ ╬▒ (ЁЭУд тКФ ЁЭУе) тКФ ЁЭУШ)
Null-in-gSubU {ЁЭУд = ЁЭУд} P S ЁЭУе
  = ╬г[ X тИ╢ Type (ЁЭУд тКФ ЁЭУе) ] ((X тИИ gSubU.S S) ├Ч is-null P X)

Null-in-gSubU-is-nullтЖРis-prop
  : {╬▒ : Level тЖТ Level} {ЁЭУШ ЁЭУд ЁЭУе : Level} {I : Type ЁЭУШ}
    {P : I тЖТ Type ЁЭУд} {S : gSubU ╬▒}
  тЖТ ((i : I) тЖТ is-prop (P i))
  тЖТ ( {ЁЭУж : Level} (i : I) {B : P i тЖТ Type ЁЭУж}
      тЖТ (тИА a тЖТ (B a) тИИ gSubU.S S)
      тЖТ (╬а (P i) B) тИИ gSubU.S S)
  тЖТ is-null P (Null-in-gSubU P S ЁЭУе)
Null-in-gSubU-is-nullтЖРis-prop {ЁЭУд = ЁЭУд} {ЁЭУе = ЁЭУе} {P = P} {S = S} is-prop-P S╬а i
  = is-equivтЖРqiso qiso where
  U = Null-in-gSubU P S ЁЭУе
  SU = gSubU.S S

  is-in-SU-and-is-null-is-prop
    : (X : Type (ЁЭУд тКФ ЁЭУе)) тЖТ is-prop ((X тИИ SU) ├Ч is-null P X)
  is-in-SU-and-is-null-is-prop X
    = is-prop-╬г (тИИ-is-prop SU X) (╬╗ _ тЖТ is-null-is-prop X)

  qiso : quasi-iso (const U (P i))
  qiso .fst f
    = ( ╬а (P i) (fst тИШ f)
      , S╬а i (╬╗ a тЖТ snd (f a) .fst)
      , ╬а-is-null P (╬╗ a тЖТ snd (f a) .snd))
  qiso .snd .fst (X , XтИИS , Xnull)
    = ╬г-pathтЖТ (ua (nullтЙГ Xnull i eтБ╗┬╣) , is-in-SU-and-is-null-is-prop _ _ _)
  qiso .snd .snd f
    = funextтЖТ ╬╗ a тЖТ ╬г-pathтЖТ
      ( ua (mkтЙГ (ev a)
                (sing-evс╡И-is-equiv global-funext (mk-singl a (is-prop-P i a))))
      , is-in-SU-and-is-null-is-prop _ _ _)
}
%```
}

\subtree[stt-00IS]{
\date{2026-03-09}
\author{fredrikbakke}
\title{The universe of null types at a family of propositions}
\taxon{Corollary}

\p{
For a family of propositions #{P_i}, the type of #{P}-null types is itself #{P}-null.
}

%```agda
\agda{
Null-U
  : {ЁЭУШ ЁЭУд : Level}
  тЖТ {I : Type ЁЭУШ}
  тЖТ (P : I тЖТ Type ЁЭУд)
  тЖТ (ЁЭУе : Level) тЖТ Type (ЁЭУШ тКФ lsuc ЁЭУд тКФ lsuc ЁЭУе)
Null-U P ЁЭУе = Null-in-gSubU P Full-gSubU ЁЭУе

Null-U-is-nullтЖРis-prop
  : {ЁЭУШ ЁЭУд ЁЭУе : Level}
    {I : Type ЁЭУШ}
    {P : I тЖТ Type ЁЭУд}
  тЖТ ((i : I) тЖТ is-prop (P i))
  тЖТ is-null P (Null-U P ЁЭУе)
Null-U-is-nullтЖРis-prop {ЁЭУе = ЁЭУе} {P = P} is-prop-P
  = Null-in-gSubU-is-nullтЖРis-prop
      {ЁЭУе = ЁЭУе}
      {P = P}
      {S = Full-gSubU}
      (is-prop-P)
      (╬╗ _ _ тЖТ tt)
}

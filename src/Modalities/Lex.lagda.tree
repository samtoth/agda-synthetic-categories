\title{Lex modalities}
\author{samueltoth}
\date{2026-03-04}
\taxon{Module}
\import{stt-macros}

%```agda
\agda{
module Modalities.Lex where

open import Foundations.Prelude

open import ufAxioms

open import Modalities.Subuniverses
open import Modalities.GlobalSubuniverses
open import Modalities.ModalMaps

open import Core.Arrow
open import Core.ArrowEquiv
open import Core.Orthogonal
}
%```

\subtree[tot-42GB]{
\taxon{Construction}

\p{For any reflective subuniverse, we can construct a map
#{\circ (a =_A b) \to \eta(a) =_{\circ A} \eta(b)}.}

%```agda
\agda{
module _ {α} {S : GSU α}
             (Srfl : is-globally-reflective S)
             (let Srfl' = is-reflective←global Srfl)
             (Σ-is-modal : is-globally-Σ-closed S)
             where
  open is-globally-reflective Srfl
  open GPiClosure Srfl
  open GRSUInduction Srfl Σ-is-modal

  opaque
    mapply-○ : ∀ {𝓤} {A : Type 𝓤} {a b : A} → ○ (a ＝ b) → η a ＝ η b
    mapply-○ = ○-rec (＝∈S ○∈S) (ap η)

    mapply-refl
      : ∀ {𝓤} {A : Type 𝓤} {a : A} → mapply-○ (η (refl)) ＝ refl {a = η a}
    mapply-refl = ○-rec-β (＝∈S ○∈S) (ap η) refl
}
%```
}

\subtree{
\taxon{Construction}
\title{Modal naturalilty square}

\p{We construct the square witnessing the naturality of the modal unit:}

\quiver{
\begin{tikzcd}
	A && {\circ A} \\
	\\
	B && {\circ B}
	\arrow["{\eta_a}", from=1-1, to=1-3]
	\arrow["f"', from=1-1, to=3-1]
	\arrow["{\circ f}", from=1-3, to=3-3]
	\arrow["{\eta_B}"', from=3-1, to=3-3]
\end{tikzcd}
}

%```agda
\agda{
  η-square
    : ∀ {𝓤 𝓥} {A : Type 𝓤} {B : Type 𝓥} (f : A → B)
      → Arrow-map f (○-map (η f))
  η-square f .Arrow-map.top = η
  η-square f .Arrow-map.bot = η
  η-square f .Arrow-map.comm _ = sym ○-map-β

  η-fibre-map
    : ∀ {𝓤 𝓥} {A : Type 𝓤} {B : Type 𝓥} (f : A → B)
      → ∀ b → fibre f b → fibre (○-map (η f)) (η b)
  η-fibre-map f = arrow-fibre (η-square f)
}
%```
}

\subtree{
\title{Lex modalities}

\p{In \citek{RSS2020}, there are a number of equivalent conditions for when we
call a modality \em{lex}. In this formalisation we take the following as
our default:}


\subtree[tot-034A]{
\taxon{Definition}
\title{Modal extensionality}

\p{In analogy to function types, we say that a modalitiy satisfies modal
extensionality if the [canonical map](tot-42GB)
#{\circ (a =_A b) \to \eta(a) =_{\circ A} \eta(b)} is an equivalence.}

%```agda
\agda{
module _ {α} {S : GSU α}
             (Srfl : is-globally-reflective S)
             (let Srfl' = is-reflective←global Srfl)
             (Σ-is-modal : is-globally-Σ-closed S)
             (mapply-○ : ∀ {𝓤} {A : Type 𝓤} {a b : A}
                         → let open is-globally-reflective Srfl
                         in ○ (a ＝ b)
                         → η a ＝ η b)
             where
  open is-globally-reflective Srfl
  open GPiClosure Srfl
  open GRSUInduction Srfl Σ-is-modal

  is-lex : Typeω
  is-lex = ∀ {𝓤} {A : Type 𝓤} {a b : A} → is-equiv (mapply-○ {a = a}{b})
}
%```
}

%```agda
\agda{
  module Lex (lex : is-lex) where
    ○-modext→ : ∀ {𝓤} {A : Type 𝓤} {a b : A} → η a ＝ η b → ○ (a ＝ b)
    ○-modext→ = is-equiv.bwd lex
}
%```

\p{We now fomrmalise a small subset of \citet{RSS2020}{Thm 3.1},
in particular, we show the following facts are implied by the lexness of a
modality:}

\subtree{
\title{Equality types are connected}
\taxon{Lemma}

%```agda
\agda{
    ＝-is-connected
      : ∀ {𝓤} {A : Type 𝓤} {a b : A}
        → is-connected Srfl' A → is-connected Srfl' (a ＝ b)
    ＝-is-connected Ac
      = is-single←equiv-to-single
          ((mk≃ _ lex) e⁻¹)
          (＝-singleton←is-prop (is-prop←is-single Ac) (η _) (η _))
}
%```
}

\subtree{
\title{Maps between connected types are connected}
\taxon{Lemma}

%```agda
\agda{
    is-connected←cod+dom-is-connected
      : ∀ {𝓤 𝓥} {A : Type 𝓤} {B : Type 𝓥}
        → is-connected Srfl' A → is-connected Srfl' B
        → ∀ (f : A → B) → is-connected-map Srfl' f
    is-connected←cod+dom-is-connected Ac Bc f b
      = Σ-is-connected Ac λ _ → ＝-is-connected Bc

}
%```
}

\subtree{
\title{Connected maps are left cancellative}
\taxon{Lemma}

%```agda
\agda{
    is-connected-left-cancel
      : ∀ {𝓤 𝓥 𝓦} {A : Type 𝓤} {B : Type 𝓥} {C : Type 𝓦}
          {f : A → B} {g : B → C}
        → is-connected-map Srfl' g → is-connected-map Srfl' (g ∘ f)
        → is-connected-map Srfl' f
    is-connected-left-cancel {f = f}{g} fconn gfconn b
      = is-single←equiv-to-single
          (○-≃ (fibre-unstable-octagon {f = g} {f} b e⁻¹))
          (is-connected←cod+dom-is-connected
            (gfconn (g b))
            (fconn  (g b))
            _
            (b , refl))

    opaque
      is-connected←is-arrow-equiv⁻¹
        : ∀ {𝓤 𝓥 𝓦 𝓜} {A : Type 𝓤} {B : Type 𝓥} {X : Type 𝓦} {Y : Type 𝓜}
            {f : A → B} {g : X → Y}
          → (F : Arrow-map f g)
          → (let module F = Arrow-map F)
          → is-Arrow-equiv F
          → is-connected-map Srfl' g
          → is-connected-map Srfl' f
      is-connected←is-arrow-equiv⁻¹ {f = f} {g = g} F fe fconn
        = is-connected-left-cancel
            (is-connected←is-equiv Srfl (fe .snd))
            (is-connected-~ Srfl (sym ∘ F .Arrow-map.comm)
               (is-connected-∘ Srfl Σ-is-modal
                 (is-connected←is-equiv Srfl (fe .fst)) fconn))
}
%```
}

\subtree{
\title{Modal equivalences are connected maps}
\taxon{Lemma}

\p{Note that the converse holds regardless of the lexness.}

%```agda
\agda{
    is-connected←is-modal-equiv
      : ∀ {𝓤 𝓥} {A : Type 𝓤} {B : Type 𝓥} {f : A → B}
        → is-modal-equiv Srfl f
        → is-connected-map (is-reflective←global Srfl) f
    is-connected←is-modal-equiv {A = A} {B} {f} feq
      = is-connected-left-cancel {f = f} {g = η}
          (η-is-connected Srfl Σ-is-modal)
          (is-connected-~
            Srfl
            (sym ∘ η-square Srfl Σ-is-modal f .Arrow-map.comm)
            (is-connected-∘ Srfl Σ-is-modal
              {f = ○-map (η f)} {η}
              (η-is-connected Srfl Σ-is-modal)
              (is-connected←is-equiv Srfl feq)))
}
%```
}

\subtree{
\title{Maps are fibrewise connected if the total map is connected}
\taxon{Lemma}

%```agda
\agda{
    is-fibrewise-connected←is-total-connected
      : ∀ {𝓤 𝓥 𝓦 𝓜} {A : Type 𝓤} {B : Type 𝓥} (f : A → B)
          {P : A → Type 𝓦} {Q : B → Type 𝓜}
        → (g : (a : A) → P a → Q (f a))
        → is-connected-map Srfl' f
        → is-connected-map {A = Σ A P} {B = Σ B Q} Srfl' (map-Σ f g)
        → ∀ a → is-connected-map Srfl' (g a)
    is-fibrewise-connected←is-total-connected f {P} {Q} g fconn Σconn a q
      = is-single←equiv-to-single
          ((mk≃ (○-map (η lemma)) (○-map-is-equiv {!!})) e⁻¹)
          (is-connected←cod+dom-is-connected
            (Σconn (f a , q))
            (fconn (f a))
            π-fibre (a , refl)) where
      π-fibre : fibre (map-Σ {Y = Q} f g) (f a , q) → fibre f (f a)
      π-fibre ((a' , p) , h) = (a' , ap fst h)

      lemma : fibre (g a) q → fibre π-fibre (a , refl)
      lemma (x , refl) = (((a , x) , refl) , refl)

      lemma-inv : fibre π-fibre (a , refl) → fibre (g a) q
      lemma-inv = {!!}
}
%```
}

\subtree{
\tile{Fibre maps of connected arrow maps are connected}
\taxon{Lemma}

\p{Given a connected map of arrows #{f \to g}, the induced map on fibres is
connected.}

%```agda
\agda{

    fibre-map-is-connected
      : ∀ {𝓤 𝓥 𝓦 𝓜} {A : Type 𝓤} {B : Type 𝓥} {X : Type 𝓦} {Y : Type 𝓜}
          {f : A → B} {g : X → Y}
        → (F : Arrow-map f g)
        → (let module F = Arrow-map F)
        → is-connected-map Srfl' F.bot
        → is-connected-map Srfl' F.top
        → ∀ a → is-connected-map Srfl' (arrow-fibre F a)
    fibre-map-is-connected {A = A}{B}{X}{Y}{f = f}{g} F bconn tconn b
      = is-fibrewise-connected←is-total-connected
          (F .Arrow-map.bot)
          {P = fibre f} {Q = fibre g}
          (arrow-fibre F)
          bconn
          (is-connected←is-arrow-equiv⁻¹ amap amap-is-equiv tconn)
          b where
      module F = Arrow-map F
      amap : Arrow-map {A = Σ B (fibre f)} {Σ Y (fibre g)}
                       (map-Σ F.bot (arrow-fibre F)) F.top
      amap .Arrow-map.top = total←total-fibre f
      amap .Arrow-map.bot = total←total-fibre g
      amap .Arrow-map.comm = ~refl

      amap-is-equiv : is-Arrow-equiv amap
      amap-is-equiv .fst = total≃total-fibre f ._≃_.has-is-eqv
      amap-is-equiv .snd = total≃total-fibre g ._≃_.has-is-eqv
}
%```
}

\subtree{
\title{The modal unit naturality square is a connected arrow map}
\taxon{Lemma}

%```agda
\agda{
    η-fibre-map-is-equiv
      : ∀ {𝓤 𝓥} {A : Type 𝓤} {B : Type 𝓥} {f : A → B}
        → ∀ a → is-connected-map Srfl' (η-fibre-map Srfl Σ-is-modal f a)
    η-fibre-map-is-equiv {A = A} {B} {f} b
      = fibre-map-is-connected amap
          (η-is-connected Srfl Σ-is-modal)
          (η-is-connected Srfl Σ-is-modal) b where
      amap : Arrow-map f (○-map (η f))
      amap .Arrow-map.top = η
      amap .Arrow-map.bot = η
      amap .Arrow-map.comm _ = sym ○-map-β
}
%```
}

  reflected-fibres-singletonтЖРup-connected-!-fibre fibterm b
    = is-singleтЖРequiv-to-single
        (mkтЙГ (gReflectorMap.тЧЛтВБ (Rf b) RЁЭЯЩ (!: fibre f b))
          (gReflectorModalEquivalences.is-modal-equiv-reflectorsтЖРup-modal-equiv
            (Rf b) RЁЭЯЩ (!: fibre f b) (fibterm b))
          eтБ╗┬╣)
        тЧЛЁЭЯЩ-singleton

  up-connected-!-fibreтЖРreflected-fibres-singleton
    : ((b : B) тЖТ is-singleton (gReflector.тЧЛ (Rf b)))

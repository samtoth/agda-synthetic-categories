\subtree[stt-00E8]{
\title{Wedge sum}
\taxon{Definition}

\p{Given a pair of pointed types, #{A} and #{B}, their wedge sum, written #{A
\vee B} is the pushout of #{A \leftarrow 1 \rightarrow B} given by the points of
#{A} and #{B}. By convention we point the wedge at #{\iota_1(A_{\bullet})}
(although we just as well could have chosen #{\iota_2(B_{\bullet})}).}

\agda{
Wedge : ‚ąÄ {ūĚď§ ūĚď•} {A : Type ūĚď§} {B : Type ūĚď•} ‚Üí A ‚Üí B ‚Üí Type (ūĚď§ ‚äĒ ūĚď•)
Wedge a b = Pushout (point a) (point b)
{-# NOINLINE Wedge #-}

Wedge‚ąô : ‚ąÄ {ūĚď§ ūĚď•} {A : Type ūĚď§} {B : Type ūĚď•} (a : A) (b : B) ‚Üí Wedge a b
Wedge‚ąô a b = őĻ‚āĀ a

}
}

\subtree[fre-0009]{
\title{Associativity}
\taxon{Lemma}

\agda{
module _
  {ūĚď§ ūĚď• ūĚď¶} {A : Type ūĚď§} {B : Type ūĚď•} {C : Type ūĚď¶}
  (a : A) (b‚āÄ b‚āĀ : B) (c : C)
  where

  Wedge-assoc‚Üí
    : Wedge a (őĻ‚āĀ {f = point b‚āĀ} {g = point c} b‚āÄ)
    ‚Üí Wedge (őĻ‚āā {f = point a} {g = point b‚āÄ} b‚āĀ) c
  Wedge-assoc‚Üí
    = Pushout-assoc‚Üí (point a) (point b‚āÄ) (point b‚āĀ) (point c)

  Wedge-assoc‚Üź
    : Wedge (őĻ‚āā {f = point a} {g = point b‚āÄ} b‚āĀ) c
    ‚Üí Wedge a (őĻ‚āĀ {f = point b‚āĀ} {g = point c} b‚āÄ)
  Wedge-assoc‚Üź
    = Pushout-assoc‚Üź (point a) (point b‚āÄ) (point b‚āĀ) (point c)

  Wedge-assoc‚Üí-is-equiv : is-equiv Wedge-assoc‚Üí
  Wedge-assoc‚Üí-is-equiv
    = Pushout-assoc‚Üí-is-equiv (point a) (point b‚āÄ) (point b‚āĀ) (point c)

  Wedge-assoc‚Üź-is-equiv : is-equiv Wedge-assoc‚Üź
  Wedge-assoc‚Üź-is-equiv
    = Pushout-assoc‚Üź-is-equiv (point a) (point b‚āÄ) (point b‚āĀ) (point c)
}
}

\subtree[stt-00E9]{
\taxon{Lemma}

\p{There is a canonical (pointed) inclusion of the wedge sum into the product.
The fibre of this map at some #{(x,y) : A \times B} is the join
#{A_\bullet = x * B_\bullet = y}.}

\agda{
Wedge-embed
  : ‚ąÄ {ūĚď§ ūĚď•} {A : Type ūĚď§} {B : Type ūĚď•} {a : A} {b : B}
    ‚Üí Wedge a b ‚Üí A √ó B
Wedge-embed {a = a} {b = b}
  = cogap (mk-cocone
      (őĽ a' ‚Üí (a' , b))
      (őĽ b' ‚Üí (a , b'))
      ~refl)

opaque
  Wedge-fibre
    : ‚ąÄ {ūĚď§ ūĚď•} {A : Type ūĚď§} {B : Type ūĚď•} {a : A} {b : B}
      ‚Üí ‚ąÄ x y ‚Üí fibre (Wedge-embed {a = a} {b}) (x , y) ‚ČÉ ((b ÔľĚ y) * (a ÔľĚ x))
  Wedge-fibre {ūĚď§} {ūĚď•} {a = a} {b} x y
    = fibre Wedge-embed (x , y) ‚ČÉ‚ü® cogap-fibre _ (x , y) ‚ü©
      Pushout‚āÄ total-fibre-span ‚ČÉ‚ü® coe‚ČÉ (ap Pushout‚āÄ
                                        (sym (ext! (span-map , span-map-eqv)))) ‚ü©
      Pushout‚āÄ intended-span    ‚ČÉ‚ü®‚ü©
      (ULift ūĚď§ (b ÔľĚ y) * ULift ūĚď• (a ÔľĚ x))
                                ‚ČÉ‚ü® mk‚ČÉ _
                                    (is-equiv‚Üźqinv
                                      (Pushout-qinv span-qeqv‚Üí span-qinv)) ‚ü©
      ((b ÔľĚ y) * (a ÔľĚ x))     ‚ČÉ‚ąé where

    total-fibre-span : Span (ūĚď§ ‚äĒ ūĚď•) (ūĚď§ ‚äĒ ūĚď•) (ūĚď§ ‚äĒ ūĚď•)
    total-fibre-span = total-span (point a) (point b)
                         (Fibre-family _ (x , y))

    intended-span : Span (ūĚď§ ‚äĒ ūĚď•) (ūĚď§ ‚äĒ ūĚď•) (ūĚď§ ‚äĒ ūĚď•)
    intended-span .Span.Centre = ULift ūĚď§ (b ÔľĚ y) √ó ULift ūĚď• (a ÔľĚ x)
    intended-span .Span.Left = ULift ūĚď§ (b ÔľĚ y)
    intended-span .Span.left = fst
    intended-span .Span.Right = ULift ūĚď• (a ÔľĚ x)
    intended-span .Span.right = snd

    span-qeqv‚Üí : Span-map intended-span (mk-span ((b ÔľĚ y) √ó (a ÔľĚ x)) fst snd)
    span-qeqv‚Üí .Span-map.h‚āĀ = unlift
    span-qeqv‚Üí .Span-map.h‚āā = unlift ‚äó unlift
    span-qeqv‚Üí .Span-map.h‚āÉ = unlift
    span-qeqv‚Üí .Span-map.H = ~refl
    span-qeqv‚Üí .Span-map.K = ~refl

    span-qinv : Span-quasi-inv span-qeqv‚Üí
    span-qinv .Span-quasi-inv.bwd .Span-map.h‚āĀ = mk-lift
    span-qinv .Span-quasi-inv.bwd .Span-map.h‚āā = mk-lift ‚äó mk-lift
    span-qinv .Span-quasi-inv.bwd .Span-map.h‚āÉ = mk-lift
    span-qinv .Span-quasi-inv.bwd .Span-map.H = ~refl
    span-qinv .Span-quasi-inv.bwd .Span-map.K = ~refl
    span-qinv .Span-quasi-inv.őĶ = Span-map-homotopy-refl _
    span-qinv .Span-quasi-inv.ő∑ = Span-map-homotopy-refl _

    span-map : Span-map intended-span total-fibre-span
    span-map .Span-map.h‚āĀ p = (x , √ó-path‚Üí (refl , unlift p))
    span-map .Span-map.h‚āā p = (tt , √ó-path‚Üí (√ó-swap‚Üí ((unlift ‚äó unlift) p)))
    span-map .Span-map.h‚āÉ p = (y , √ó-path‚Üí (unlift p , refl))
    span-map .Span-map.H (mk-lift refl , mk-lift refl)
      = ő£-path‚Üí (refl , sym (IdŠĶą-func‚ÜźSquare (sym (glue tt)) refl refl
          (Square-degen-hor _ _
            ( ap-sym Wedge-embed (glue tt)
            ‚ąô ap sym (pushout-rec-apő≤ _)
            ‚ąô sym (ap-const (sym (glue tt)))))))
    span-map .Span-map.K (mk-lift refl , mk-lift refl) = refl

    span-map-eqv : is-Span-equiv span-map
    span-map-eqv .fst
      = is-equiv-‚ąė
          (is-total-equiv‚Üźis-fibrewise-equiv (őĽ x ‚Üí √ó-path ._‚ČÉ_.fwd-is-equiv))
          ((unlift‚ČÉ ‚ąô‚ČÉ ő£-ÔľĚsingl e‚ĀĽ¬Ļ) ._‚ČÉ_.fwd-is-equiv)
    span-map-eqv .snd .fst
      = (√ó-swap ‚ąô‚ČÉ mk‚ČÉ _ (is-equiv‚ĀĽ¬Ļ (‚äó-is-equiv lift-is-equiv lift-is-equiv))
        ‚ąô‚ČÉ √ó-path ‚ąô‚ČÉ ő£-singl ūĚüô-is-singleton tt e‚ĀĽ¬Ļ)._‚ČÉ_.fwd-is-equiv
    span-map-eqv .snd .snd
      = is-equiv-‚ąė
          (is-total-equiv‚Üźis-fibrewise-equiv (őĽ x ‚Üí √ó-path ._‚ČÉ_.fwd-is-equiv))
          ((unlift‚ČÉ ‚ąô‚ČÉ ő£-ÔľĚsingl e‚ĀĽ¬Ļ ‚ąô‚ČÉ ő£-snd-‚ČÉ (őĽ a‚āĀ ‚Üí √ó-swap)) ._‚ČÉ_.fwd-is-equiv)

}
}

\subtree[stt-00EA]{
\title{The Wedge of sets is a set}
\taxon{Corollary}

\proof{
\p{By \ref{stt-00E9}, the fibre of the inclusion is a join of paths in #{A} and
#{B}. If #{A} and #{B} are both sets, then this fibre is a proposition. Hence,
the wedge is a subset of the product of #{A} and #{B} which is itself a set.}
}

\agda{
opaque
  Wedge-is-0-truncated
    : ‚ąÄ {ūĚď§ ūĚď•} {A : Type ūĚď§} {B : Type ūĚď•} {a : A} {b : B}
      ‚Üí is-truncated 0 A ‚Üí is-truncated 0 B ‚Üí is-truncated 0 (Wedge a b)
  Wedge-is-0-truncated {A = A} {B} {a} {b} as bs = is-truncated‚Üźequiv
    ((ő£[ (x , y) ‚ą∂ A √ó B ] ((b ÔľĚ y) * (a ÔľĚ x)))
        ‚ČÉ‚ü® ő£-snd-‚ČÉ (_e‚ĀĽ¬Ļ ‚ąė uncurry Wedge-fibre) ‚ü©
     (ő£[ x ‚ą∂ A √ó B ] fibre Wedge-embed x) ‚ČÉ‚ü®‚ü©
     total-fibre Wedge-embed ‚ČÉ‚ü® total‚ČÉtotal-fibre Wedge-embed ‚ü©
     Wedge a b ‚ČÉ‚ąé)
    (ő£-is-truncated
      trunc!
      (őĽ _ ‚Üí suc-is-truncated -1
              (is-truncated‚Üźis-prop
                (*-is-prop
                  (is-prop‚Üźis-truncated trunc!)
                  (is-prop‚Üźis-truncated trunc!)))))
    where instance
      at : Is-truncated 0 A
      at .Is-truncated.carrier-is-truncated = as
      bt : Is-truncated 0 B
      bt .Is-truncated.carrier-is-truncated = bs

instance
  Wedge-Is-2-truncated
    : ‚ąÄ {ūĚď§ ūĚď•} {A : Type ūĚď§} {B : Type ūĚď•} {a : A} {b : B}
        ‚¶É _ : Is-truncated 0 A ‚¶Ą ‚¶É _ : Is-truncated 0 B ‚¶Ą
      ‚Üí Is-truncated 0 (Wedge a b)
  Wedge-Is-2-truncated .Is-truncated.carrier-is-truncated = Wedge-is-0-truncated trunc! trunc!
}
}

           , (О» y вҶ’ is-propвҶҗis-single рқҹҷ-is-singleton _ _)
           , (О» x вҶ’ is-propвҶҗis-single (пјқ-singletonвҶҗis-single рқҹҷ-is-singleton _ _) _ _)))

\subtree[fre-1001]{
\date{2026-03-19}
\author{fredrikbakke}
\taxon{Definition}
\title{Universal property of #{K}-connected types}

\p{
A type #{X} satisfies the universal property of #{K}-connected types when constant
maps at #{X} into every #{K}-type is an equivalence.
}

% ```agda
\agda{
up-connected
  : ‚ąÄ {őĪ ūĚď§} (K : gSubU őĪ)
      (A : Type ūĚď§)
  ‚Üí TypeŌČ
up-connected K A
  = {ūĚď• : Level} {U : Type ūĚď•}
  ‚Üí U ‚ąą gSubU.S K
  ‚Üí is-equiv (const U A)
}
%```
}

\subtree[fre-1002]{
\date{2025-08-05}
\author{samueltoth}
\date{2026-03-19}
\author{fredrikbakke}
\taxon{Module}
\title{Connected types}

\p{
A type is #{K}-\em{connected} at a reflective subuniverse if its reflection is
contractible.
}

% ```agda
\agda{
is-connected
  : ‚ąÄ {őĪ ūĚď§} ‚Üí gRSubU őĪ ‚Üí Type ūĚď§ ‚Üí Type ūĚď§
is-connected K A = is-singleton (gRSubU.‚óč K A)

is-connected' : ‚ąÄ {ūĚď§ ūĚď•} {S : SubU ūĚď§ ūĚď•} ‚Üí is-reflective S
               ‚Üí Type ūĚď§ ‚Üí Type ūĚď§
is-connected' {S = S} Sref A = is-singleton (‚óč A) where
  open is-reflective Sref
}
% ```
}

\subtree[fre-ABAB]{
\date{2026-03-28}
\author{fredrikbakke}
\taxon{Definition}
\title{Universal property of pointed connected types}

\p{
A pointed type satisfies the \em{Universal property of pointed #{K}-connected types}
if for every type #{Y} in #{K} and any choice of basepoint #{y : Y}, the type of
pointed maps into #{Y} is contractible.
}

% ```agda
\agda{
up-connected‚ąó
  : ‚ąÄ {őĪ ūĚď§} (K : gSubU őĪ) (X‚ąó : Type‚ąó ūĚď§) ‚Üí TypeŌČ
up-connected‚ąó K X‚ąó
  = {ūĚď• : Level} {Y : Type ūĚď•}
  ‚Üí Y ‚ąą gSubU.S K
  ‚Üí (y : Y)
  ‚Üí is-singleton (Hom‚ąó X‚ąó (mk-type‚ąó Y y))
}
%```
}

\subtree[fre-ABAD]{
\date{2026-03-28}
\author{fredrikbakke}
\taxon{Theorem}
\title{Pointed criterion for connected types}

\p{
Given a pointed type #{X}, then the pointed universal property of #{K}-connected
types is equivalent to the universal property of #{K}-connected types.
}

\proof{
\p{
Fix a point #{x : X}. For any #{K}-type #{Y}, evaluation at #{x} fits into the
triangle
\quiver{
\begin{tikzcd}
  & (X \to Y) \\
  Y && Y
  \arrow[equals, from=2-1, to=2-3]
  \arrow["\const", from=2-1, to=1-2]
  \arrow["\ev_x", from=1-2, to=2-3]
\end{tikzcd}
}
Hence by the 3-for-2 property of equivalences the constant map is an equivalence iff
evaluation at #{x} is.
}

% ```agda
\agda{
module _ {őĪ ūĚď§} (K : gSubU őĪ) {A : Type ūĚď§} (a : A) where

  ev-is-equiv‚Üźup-connected
    : up-connected K A
    ‚Üí {ūĚď• : Level} {Y : Type ūĚď•}
    ‚Üí Y ‚ąą gSubU.S K
    ‚Üí is-equiv (ev: Y a)
  ev-is-equiv‚Üźup-connected conn U‚ąąK
    = 3-for-2' (conn U‚ąąK) id-is-equiv

  up-connected‚Üźev-is-equiv
    : ( {ūĚď• : Level} {Y : Type ūĚď•}
      ‚Üí Y ‚ąą gSubU.S K
      ‚Üí is-equiv (ev: Y a))
    ‚Üí up-connected K A
  up-connected‚Üźev-is-equiv ev-eq U‚ąąK
    = 3-for-2 (ev-eq U‚ąąK) id-is-equiv
}
%```

\p{
Now the fibre of #{\mathrm{ev}_x} over a point #{y : Y} is exactly the type of
pointed maps #{(X,x) \to_* (Y,y)}. Therefore evaluation at #{x} is an equivalence iff
each such pointed mapping type is contractible. This is exactly the connectedness
criterion for pointed types.
}

%```agda
\agda{
module _ {őĪ ūĚď§} (K : gSubU őĪ) (X‚ąó : Type‚ąó ūĚď§) where

  up-connected‚ąó‚Üźup-connected
    : up-connected K (X‚ąó .carrier)
    ‚Üí up-connected‚ąó K X‚ąó
  up-connected‚ąó‚Üźup-connected conn U‚ąąK y
    = is-single‚Üźequiv-to-single
        (Hom‚ąó‚ČÉfibre-ev X‚ąó y e‚ĀĽ¬Ļ)
        (is-contr-map‚Üźis-equiv (ev-is-equiv‚Üźup-connected K (X‚ąó .pt) conn U‚ąąK) y)

  up-connected‚Üźup-connected‚ąó
    : up-connected‚ąó K X‚ąó
    ‚Üí up-connected K (X‚ąó .carrier)
  up-connected‚Üźup-connected‚ąó pconn
    = up-connected‚Üźev-is-equiv K (X‚ąó .pt) őĽ U‚ąąK
      ‚Üí is-equiv‚Üźis-contr-map őĽ y
        ‚Üí is-single‚Üźequiv-to-single (Hom‚ąó‚ČÉfibre-ev X‚ąó y) (pconn U‚ąąK y)
}
%```
}
}

\subtree[fre-83D3]{
\title{#{K}-Connected #{K}-types are contractible}
\taxon{Lemma}
\author{fredrikbakke}
\date{2026-03-30}

%```agda
\agda{
module _ {őĪ ūĚď§} (K : gSubU őĪ) where

  is-singleton‚Üźup-connected‚Üźin-SubU
    : {A : Type ūĚď§}
    ‚Üí up-connected K A
    ‚Üí A ‚ąą gSubU.S K
    ‚Üí is-singleton A
  is-singleton‚Üźup-connected‚Üźin-SubU {A = A} conn A‚ąąK
    = mk-singl (is-equiv.bwd (conn A‚ąąK) id) (happly (is-equiv.őĶ (conn A‚ąąK) id))
}
%```
}

\subtree[fre-ACAB]{
\date{2026-03-19}
\author{fredrikbakke}
\taxon{Lemma}
\title{Terminal projection characterisation of #{K}-connected types}

\p{
For a type #{A}, being #{K}-connected is equivalent to asking that
the terminal projection #{!_A} is a #{K}-equivalence.
}

% ```agda
\agda{
module _ {őĪ ūĚď§} (K : gSubU őĪ) where

  up-modal-equiv-!‚Üźconnected
    : (A : Type ūĚď§)
    ‚Üí up-connected K A
    ‚Üí up-modal-equiv K (!: A)
  up-modal-equiv-!‚Üźconnected A const-eq U‚ąąK
    = is-equiv-precomp-!‚Üźconst (const-eq U‚ąąK)

  up-connected‚Üźterminal-equiv
    : (A : Type ūĚď§)
    ‚Üí up-modal-equiv K (!: A)
    ‚Üí up-connected K A
  up-connected‚Üźterminal-equiv A term-eq U‚ąąK
    = is-equiv-const‚Üźprecomp-! (term-eq U‚ąąK)
}
%```
}

\subtree[fre-00J2]{
\date{2026-03-28}
\author{fredrikbakke}
\taxon{Corollary}
\title{Pointed criterion via terminal projections}

\p{
Equivalently, the pointed criterion is the same as asking that the terminal
projection of the underlying type be a #{K}-equivalence.
}

% ```agda
\agda{
module _ {őĪ ūĚď§} (K : gSubU őĪ) (X‚ąó : Type‚ąó ūĚď§) where

  up-modal-equiv-!‚Üźup-connected‚ąó
    : up-connected‚ąó K X‚ąó
    ‚Üí up-modal-equiv K (!: X‚ąó .carrier)
  up-modal-equiv-!‚Üźup-connected‚ąó pconn
    = up-modal-equiv-!‚Üźconnected K (X‚ąó .carrier)
        (up-connected‚Üźup-connected‚ąó K X‚ąó pconn)

  up-connected‚ąó‚Üźup-modal-equiv-!
    : up-modal-equiv K (!: X‚ąó .carrier)
    ‚Üí up-connected‚ąó K X‚ąó
  up-connected‚ąó‚Üźup-modal-equiv-! teq
    = up-connected‚ąó‚Üźup-connected K X‚ąó
        (up-connected‚Üźterminal-equiv K (X‚ąó .carrier) teq)
}
%```
}


\subtree[fre-D700]{
\title{#{\Sigma}-closure of connected types}
\author{samueltoth}
\date{2026-03-30}
\author{fredrikbakke}
\taxon{Lemma}

%```agda
\agda{
module _ {őĪ} (K : gSubU őĪ) where

  ő£-up-connected
    : ‚ąÄ {ūĚď§ ūĚď•} {A : Type ūĚď§} {B : A ‚Üí Type ūĚď•}
      ‚Üí up-connected K A
      ‚Üí ((a : A) ‚Üí up-connected K (B a))
      ‚Üí up-connected K (ő£ A B)
  ő£-up-connected {A = A} {B} Ac Bc {U = U} U‚ąąK
    = (is-equiv-‚ąė
        (uncurry-is-equiv)
        (is-equiv-‚ąė (postcomp-ő†-equiv őĽ {a} ‚Üí Bc a U‚ąąK) (Ac U‚ąąK)))

module _ {őĪ} (RS : gRSubU őĪ) where

  open gRSubU RS
  open gReflectiveReasoning RS
  open gReflectiveClosure RS

  ő£-is-connected
    : ‚ąÄ {ūĚď§ ūĚď•} {A : Type ūĚď§} {B : A ‚Üí Type ūĚď•}
      ‚Üí is-connected RS A
      ‚Üí ((a : A) ‚Üí is-connected RS (B a))
      ‚Üí is-connected RS (ő£ A B)
  ő£-is-connected {A = A}{B} Ac Bc
    = is-single‚Üźequiv-to-single
        ((‚óč (ő£ A B)       ‚ČÉ‚ü® ő£‚óč‚ČÉ RS B ‚ü©
          ‚óč (ő£ A (‚óč ‚ąė B)) ‚ČÉ‚ü® ‚óč-‚ČÉ (ő£-singleton Bc) ‚ü©
          ‚óč A             ‚ČÉ‚ąé) e‚ĀĽ¬Ļ)
        Ac
}
%```
}

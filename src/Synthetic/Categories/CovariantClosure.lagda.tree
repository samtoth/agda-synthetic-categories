\subtree[stt-00FU]{
\title{Base change of covariant families}
\taxon{Lemma}

%```agda
\agda{
covariant-base-change
  : ‚ąÄ {ūĚď§ ūĚď• ūĚď¶} {A : Type ūĚď§} {B : Type ūĚď•} {P : B ‚Üí Type ūĚď¶}
    ‚Üí (f : A ‚Üí B)
    ‚Üí is-covariant P ‚Üí is-covariant (P ‚ąė f)
covariant-base-change F Pc f x‚āÄ = Pc (F ‚ąė f) x‚āÄ

is-covariant-is-őĒ¬Ļ-relative
  : ‚ąÄ {ūĚď§ ūĚď•} {A : Type ūĚď§} {P : A ‚Üí Type ūĚď•}
    ‚Üí is-covariant P ‚áĒ (‚ąÄ (f : őĒ¬Ļ ‚Üí A) ‚Üí is-covariant (P ‚ąė f))
is-covariant-is-őĒ¬Ļ-relative {A = A} {P} .fst Pc f
  = covariant-base-change {P = P} f Pc
is-covariant-is-őĒ¬Ļ-relative {A = A} {P} .snd Pfc h = Pfc h id
}
%```
}

\subtree[stt-00FV]{
\title{Products of Covariant families}
\taxon{Lemma}

%```agda
\agda{
√ó-is-covariant
  : ‚ąÄ {ūĚď§ ūĚď• ūĚď¶} {A : Type ūĚď§} {P : A ‚Üí Type ūĚď•} {Q : A ‚Üí Type ūĚď¶}
      (Pc : is-covariant P) (Qc : is-covariant Q)
    ‚Üí is-covariant (őĽ a ‚Üí P a √ó Q a)
√ó-is-covariant {P = P}{Q} Pc Qc f (Px‚āÄ , Qx‚āÄ)
  = is-single‚Üźequiv-to-single
      (ő£-ap-‚ČÉ (őĽ _ ‚Üí HomŠĶą-√ó‚ČÉ {P = P}{Q} f e‚ĀĽ¬Ļ))
      (is-singleton-structure‚Üźparts
        (Pc f Px‚āÄ)
        (Pc f Px‚āÄ .centre)
        (Qc f Qx‚āÄ))
}
%```
}



\subtree{
\title{Sums of covariant families}

%```agda
\agda{
opaque
  ő£-is-covariant
    : ‚ąÄ {ūĚď§ ūĚď• ūĚď¶} {A : Type ūĚď§} {B : A ‚Üí Type ūĚď•} ‚Üí {C : (a : A) ‚Üí B a ‚Üí Type ūĚď¶}
      ‚Üí is-covariant B ‚Üí is-covariant (uncurry C)
      ‚Üí is-covariant (őĽ a ‚Üí ő£ (B a) (C a))
  ő£-is-covariant {A = A} {B}{C} Bc Cc
    = is-covariant‚áĒis-left-fibration _ .snd is-left where

    is-left : is-left-fibration (fst {B = őĽ a ‚Üí ő£ (B a) (C a)})
    is-left
      = right-orthogonal-‚ąė (const _ ūĚüô i0)
          {g = fst} {fst ‚ąė _‚ČÉ_.bwd ő£-assoc}
          (is-covariant‚áĒis-left-fibration B .fst Bc)
          (right-orthogonal-‚ąė (const _ ūĚüô i0)
            (is-covariant‚áĒis-left-fibration (uncurry C) .fst Cc)
            (‚ä•equiv (const _ ūĚüô i0) _ (is-equiv‚ĀĽ¬Ļ (ő£-assoc ._‚ČÉ_.has-is-eqv))))
}
%```
}


\subtree[stt-00AI]{
\title{Segal types}
\taxon{Definition}


\p{We say that a type is \strong{Segal} if it is local with respect to
the inclusion of the [#{(2,1)} horn](stt-00AD) into the 2-simplex. We
can use the fact that [being local with respect to some class of maps
forms a global reflective subuniverse](stt-0066) to bootstrap some
useful notions, such as preservation under identity and #{\Pi}-types as
well as the localisation operation. Note that unlike in the case of
[simplicial types](stt-00AC) this subuniverse is neither
#{\Sigma}-closed nor lex.}

\p{We call maps which are local to the inner horn inclusion \strong{inner maps}.}

\agda{
open Subtype

is-segal : ‚ąÄ {ūĚď§} (C : Type ūĚď§) ‚Üí Type (ūĚď§ ‚äĒ ūĚďė)
is-segal = is-local (point őõ[2,1]-incl)

Segal-SubU : ‚ąÄ {ūĚď§} ‚Üí SubU ūĚď§ (ūĚď§ ‚äĒ ūĚďė)
Segal-SubU = Local-SubU (point őõ[2,1]-incl) _

Segal-gSubU : gSubU (_‚äĒ ūĚďė)
Segal-gSubU = Local-gSubU (point őõ[2,1]-incl)

Segal-is-globally-reflective
  : is-globally-reflective Segal-gSubU
Segal-is-globally-reflective
  = Local-global-reflectors (point őõ[2,1]-incl)

Segal-gRSubU : gRSubU (_‚äĒ ūĚďė)
Segal-gRSubU .gRSubU.GS = Segal-gSubU
Segal-gRSubU .gRSubU.GS-is-globally-reflective = Segal-is-globally-reflective

open gSubU Segal-gSubU public using () renaming
  ( ‚ąąS‚Üźequiv to is-segal‚Üźequiv)

open gReflectiveClosure Segal-gRSubU public using () renaming
  ( ő†‚ąąS to ő†-is-segal
  ; ULift‚ąąS to ULift-is-segal
  ; ūĚüô‚ąąS to ūĚüô-is-segal
  ; ‚ąąS‚Üźis-singleton to is-segal‚Üźis-singleton
  ; ‚ąąS‚Üźretract to is-segal‚Üźretract
  ; Pullback‚ąąS to Pullback-is-segal
  ; ÔľĚ‚ąąS to ÔľĚ-is-segal
  ; ~‚ąąS to ~-is-segal
  ; fibre‚ąąS to fibre-is-segal
  ; Ext‚ąąS to Ext-is-segal
  ; √ó‚ąąS to √ó-is-segal
  ; retract‚ąąS to retract-is-segal
  ; biinv‚ąąS to biinv-is-segal
  ; ‚ČÉ‚ąąS to ‚ČÉ-is-segal
  ; Equaliser‚ąąS to Equaliser-is-segal
  ; Seq-lim‚ąąS to Seq-lim-is-segal
  ; preidempotent-map‚ąąS to preidempotent-map-is-segal
  ; qidempotent-map‚ąąS to qidempotent-map-is-segal
  ; idempotent-map‚ąąS to idempotent-map-is-segal
  ; Retracts‚ąąS to Retracts-is-segal)
open gRSubUHomClosure Segal-gRSubU public using () renaming
  ( Hom‚ąąS to Hom-is-segal)

module Segal where
  open gRSubU Segal-gRSubU public
  open gReflectiveClosure Segal-gRSubU public
  open gRSubUHomClosure Segal-gRSubU public
}

\agda{
is-fibrewise-inner : ‚ąÄ {ūĚď§ ūĚď•} {A : Type ūĚď§} {B : Type ūĚď•} ‚Üí (A ‚Üí B) ‚Üí Type (ūĚďė ‚äĒ ūĚď§ ‚äĒ ūĚď•)
is-fibrewise-inner = is-modal-map' Segal-SubU

is-inner : ‚ąÄ {ūĚď§ ūĚď•} {A : Type ūĚď§} {B : Type ūĚď•} ‚Üí (A ‚Üí B) ‚Üí Type (ūĚďė ‚äĒ ūĚď§ ‚äĒ ūĚď•)
is-inner f = őõ[2,1]-incl ‚ä• f

is-inner-anodyne : ‚ąÄ {ūĚď§ ūĚď•} {A : Type ūĚď§} {B : Type ūĚď•} (f : A ‚Üí B) ‚Üí TypeŌČ
is-inner-anodyne f = is-anodyne f őõ[2,1]-incl

{-# NOINLINE is-inner-anodyne #-}

is-segal-equiv
  : ‚ąÄ {ūĚď§ ūĚď•} {A : Type ūĚď§} {B : Type ūĚď•}
    ‚Üí (f : A ‚Üí B) ‚Üí TypeŌČ
is-segal-equiv f
  = ‚ąÄ {ūĚď†} {Q : Type ūĚď†} ‚Üí is-segal Q ‚Üí is-equiv (precomp Q f)

is-segal-equiv-‚ąė
  : ‚ąÄ {ūĚď§ ūĚď• ūĚď¶} {A : Type ūĚď§} {B : Type ūĚď•} {C : Type ūĚď¶}
      {f : B ‚Üí C} {g : A ‚Üí B} ‚Üí is-segal-equiv f
    ‚Üí is-segal-equiv g ‚Üí is-segal-equiv (f ‚ąė g)
is-segal-equiv-‚ąė sf sg qpc = is-equiv-‚ąė (sg qpc) (sf qpc)

is-segal‚Üźis-prop
  : ‚ąÄ {ūĚď§} {A : Type ūĚď§}
    ‚Üí is-prop A
    ‚Üí is-segal A
is-segal‚Üźis-prop
  = is-local‚Üźis-prop‚Üźsection-domain
      (point őõ[2,1]-incl)
      (őĽ _ ‚Üí őĻ‚āĀ i0)

‚ąÖ-is-segal : is-segal ‚ąÖ
‚ąÖ-is-segal = ‚ąÖ-is-local (point őõ[2,1]-incl) (őĽ _ őĪ ‚Üí őĪ (őĻ‚āĀ i0))
}
}

\subtree[stt-00GH]{
\date{2026-03-09}
\author{fredrikbakke}
\title{Precategories}
\taxon{Definition}

\p{
A \em{precategory} is a [simplicial](stt-00AC) [Segal type](stt-00AI).
}

\agda{
fam-is-precategory
  : ‚®Ą‚āĀŠ∂†-carrier (point őõ[2,1]-incl) (!Šīł: ūĚďė ‚ąė fam-is-simplicial)
fam-is-precategory = point őõ[2,1]-incl ‚®Ą‚āĀŠ∂† (!Šīł: ūĚďė ‚ąė fam-is-simplicial)

is-precategory : ‚ąÄ {ūĚď§} ‚Üí Type ūĚď§ ‚Üí Type (ūĚďė ‚äĒ ūĚď§)
is-precategory = is-local fam-is-precategory

Precat-SubU : ‚ąÄ {ūĚď§} ‚Üí SubU ūĚď§ (ūĚď§ ‚äĒ ūĚďė)
Precat-SubU = Local-SubU fam-is-precategory _

Precat-gSubU : gSubU (_‚äĒ ūĚďė)
Precat-gSubU = Local-gSubU fam-is-precategory

Precat-is-globally-reflective
  : is-globally-reflective Precat-gSubU
Precat-is-globally-reflective = Local-global-reflectors fam-is-precategory

Precat-gRSubU : gRSubU (_‚äĒ ūĚďė)
Precat-gRSubU .gRSubU.GS = Precat-gSubU
Precat-gRSubU .gRSubU.GS-is-globally-reflective = Precat-is-globally-reflective

open gSubU Precat-gSubU public using () renaming
  ( ‚ąąS‚Üźequiv to is-precategory‚Üźequiv)

open gReflectiveClosure Precat-gRSubU public using () renaming
  ( ő†‚ąąS to ő†-is-precategory
  ; ULift‚ąąS to ULift-is-precategory
  ; ūĚüô‚ąąS to ūĚüô-is-precategory
  ; ‚ąąS‚Üźis-singleton to is-precategory‚Üźis-singleton
  ; ‚ąąS‚Üźretract to is-precategory‚Üźretract
  ; Pullback‚ąąS to Pullback-is-precategory
  ; fibre‚ąąS to fibre-is-precategory
  ; Ext‚ąąS to Ext-is-precategory
  ; √ó‚ąąS to √ó-is-precategory
  ; ÔľĚ‚ąąS to ÔľĚ-is-precategory
  ; ~‚ąąS to ~-is-precategory
  ; retract‚ąąS to retract-is-precategory
  ; biinv‚ąąS to biinv-is-precategory
  ; ‚ČÉ‚ąąS to ‚ČÉ-is-precategory
  ; Equaliser‚ąąS to Equaliser-is-precategory
  ; Seq-lim‚ąąS to Seq-lim-is-precategory
  ; preidempotent-map‚ąąS to preidempotent-map-is-precategory
  ; qidempotent-map‚ąąS to qidempotent-map-is-precategory
  ; idempotent-map‚ąąS to idempotent-map-is-precategory
  ; Retracts‚ąąS to Retracts-is-precategory)
open gRSubUHomClosure Precat-gRSubU public using () renaming
  ( Hom‚ąąS to Hom-is-precategory)

module Precat where
  open gRSubU Precat-gRSubU public
  open gReflectiveClosure Precat-gRSubU public
  open gRSubUHomClosure Precat-gRSubU public

is-precategory-equiv
  : ‚ąÄ {ūĚď§ ūĚď•} {A : Type ūĚď§} {B : Type ūĚď•}
    ‚Üí (f : A ‚Üí B) ‚Üí TypeŌČ
is-precategory-equiv f
  = ‚ąÄ {ūĚď†} {Q : Type ūĚď†} ‚Üí is-precategory Q ‚Üí is-equiv (precomp Q f)

is-precategory‚Üźis-segal‚Üźis-simplicial
  : ‚ąÄ {ūĚď§} {A : Type ūĚď§}
    ‚Üí is-segal A
    ‚Üí is-simplicial A
    ‚Üí is-precategory A
is-precategory‚Üźis-segal‚Üźis-simplicial apc simp
  = is-local-‚®Ą‚āĀŠ∂†‚Üźis-local
      (apc)
      (is-local-sing‚Üźis-null (őĽ _ ‚Üí ūĚüôŠīł-is-singleton) (őĽ _ ‚Üí !Šīł) simp)

is-segal‚Üźis-precategory
  : ‚ąÄ {ūĚď§} {A : Type ūĚď§} ‚Üí is-precategory A ‚Üí is-segal A
is-segal‚Üźis-precategory pcat
  = √ó-is-local‚Üźis-local-‚®Ą‚āĀŠ∂† pcat .fst

is-simplicial‚Üźis-precategory
  : ‚ąÄ {ūĚď§} {A : Type ūĚď§} ‚Üí is-precategory A ‚Üí is-simplicial A
is-simplicial‚Üźis-precategory {A = X} pcat
  = is-null‚Üźis-localŠīł (√ó-is-local‚Üźis-local-‚®Ą‚āĀŠ∂† pcat .snd)

is-segal√óis-simplicial‚Üźis-precategory
  : ‚ąÄ {ūĚď§} {A : Type ūĚď§}
    ‚Üí is-precategory A
    ‚Üí is-segal A √ó is-simplicial A
is-segal√óis-simplicial‚Üźis-precategory pcat
  = (is-segal‚Üźis-precategory pcat , is-simplicial‚Üźis-precategory pcat)

is-local-fam-is-simplicial‚ČÉis-simplicial
  : ‚ąÄ {ūĚď§} {A : Type ūĚď§}
    ‚Üí is-local (!Šīł: ūĚďė ‚ąė fam-is-simplicial) A ‚ČÉ is-simplicial A
is-local-fam-is-simplicial‚ČÉis-simplicial {A = A}
  = equiv‚Üźlogical
      (is-local-is-prop A)
      (is-null-is-prop A)
      (is-null‚Üźis-localŠīł , is-localŠīł‚Üźis-null)

is-triangulated‚Üźis-precategory
  : ‚ąÄ {ūĚď§} {A : Type ūĚď§} ‚Üí is-precategory A ‚Üí is-triangulated A
is-triangulated‚Üźis-precategory pcat
  = simp-is-triangulated (is-simplicial‚Üźis-precategory pcat)

Precategory-U : (ūĚď§ : Level) ‚Üí Type (lsuc (ūĚďė ‚äĒ ūĚď§))
Precategory-U ūĚď§ = ő£[ A ‚ą∂ Type (ūĚďė ‚äĒ ūĚď§) ] is-precategory A

Precategory-U-is-simplicial
  : {ūĚď§ : Level} ‚Üí is-simplicial (Precategory-U ūĚď§)
Precategory-U-is-simplicial {ūĚď§}
  = is-simplicial‚Üźequiv
      ((ő£-ap-‚ČÉ őĽ A ‚Üí
        is-local-‚®Ą‚āĀŠ∂†‚ČÉ√ó-is-local
        ‚ąô‚ČÉ (id‚ČÉ √ó‚ČÉ is-local-fam-is-simplicial‚ČÉis-simplicial {A = A}))
        e‚ĀĽ¬Ļ)
      (Null-in-gSubU-is-null‚Üźis-prop
        {ūĚď§ = ūĚďė} {ūĚď• = ūĚď§}
        {P = fam-is-simplicial}
        {S = Segal-gSubU}
        (fam-is-simplicial-is-prop)
        (őĽ _ ‚Üí ő†-is-segal))
}
}

\subtree[stt-00C5]{
\title{Inner families}
\taxon{Definition}

\p{ A family #{P : A \to \UU} is an inner family if it's unstraightening is
an inner fibration. The total type of an inner family over a Segal type is
itself Segal.}

\agda{
is-inner-family : ‚ąÄ {ūĚď§ ūĚď•} {A : Type ūĚď§} (B : A ‚Üí Type ūĚď•) ‚Üí Type (ūĚďė ‚äĒ ūĚď§ ‚äĒ ūĚď•)
is-inner-family B = őõ[2,1]-incl ‚ä• fst {B = B}

opaque
  ő£-is-segal
    : ‚ąÄ {ūĚď§ ūĚď•} {A : Type ūĚď§} {B : A ‚Üí Type ūĚď•}
      ‚Üí is-segal A ‚Üí is-inner-family B ‚Üí is-segal (ő£ A B)
  ő£-is-segal apc bin tt
    = is-orthogonal‚áĒorthogonal-! .fst
        (right-orthogonal-‚ąė
          őõ[2,1]-incl
          (is-orthogonal‚áĒorthogonal-! .snd (apc tt))
          bin)
}
}

\subtree[stt-00AK]{
\title{Composite morphisms}
\taxon{Definition}

\p{Given the data of the boundary of a 2-simplex:}

\quiver{
\begin{tikzcd}
        x && y \\
	\\
	&& z
	\arrow["g", from=1-1, to=1-3]
	\arrow["h"', from=1-1, to=3-3]
	\arrow["f", from=1-3, to=3-3]
\end{tikzcd}
}

\p{We define the type of fillers, written #{\Hom 2(f,g;h)}, which we say witnesses
that #{fg \sim h}.}

\agda{
Hom2
  : ‚ąÄ {ūĚď§} {A : Type ūĚď§} {x y z : A}
      (f : Hom _ y z) (g : Hom _ x y) (h : Hom _ x z)
    ‚Üí Type (ūĚďė ‚äĒ ūĚď§)
Hom2 {A = A} f g h = Ext ‚ąāőĒ¬≤-incl (make-‚ąāőĒ¬≤ f g h)

idH-Hom2
  : ‚ąÄ {ūĚď§} {A : Type ūĚď§}
  ‚Üí (a : A)
  ‚Üí Hom2 (idH a) (idH a) (idH a)
idH-Hom2 a .fst = őĽ _ ‚Üí a
idH-Hom2 a .snd
  = pushout-rec-unique _ (őĽ _ ‚Üí a) (horn-const a)
      ~refl
      őĽ where
        (mk-lift false) ‚Üí ‚ąô-reflr _ ‚ąô ap-const (glue ‚ąāőĒ¬Ļ-0)
        (mk-lift true) ‚Üí ‚ąô-reflr _ ‚ąô ap-const (glue ‚ąāőĒ¬Ļ-1)
}

\p{We show functions have actions on 2-simplices.}

\agda{
opaque
  ap-‚ąāőĒ¬≤
    : ‚ąÄ {ūĚď§ ūĚď•} {A : Type ūĚď§} {B : Type ūĚď•} (F : A ‚Üí B)
        {x y z} {f : Hom A y z} {g : Hom A x y} {h : Hom A x z}
      ‚Üí F ‚ąė make-‚ąāőĒ¬≤ f g h ~ make-‚ąāőĒ¬≤ (ap-hom F f) (ap-hom F g) (ap-hom F h)
  ap-‚ąāőĒ¬≤ F {f = f} {g} {h}
    = pushout-rec-unique _ _
        (pushout-rec-unique _ _
          ~refl
          ~refl
          (őĽ _ ‚Üí ‚ąô-reflr _ ‚ąô ap-‚ąė F _ őõ[2,1]-glue ‚ąô ap (ap F) (pushout-rec-apő≤ _)
               ‚ąô ap-‚ąô F (g .HomŠĶą.hom1) _
               ‚ąô ap (ap F (g .HomŠĶą.hom1) ‚ąô_) (ap-sym F _)))
        ~refl
        őĽ { (mk-lift true)  ‚Üí ‚ąô-reflr _ ‚ąô ap-‚ąė F (make-‚ąāőĒ¬≤ f g h) (glue ‚ąāőĒ¬Ļ-1)
                            ‚ąô ap (ap F) (pushout-rec-apő≤ _)
                            ‚ąô ap-‚ąô F  (f .HomŠĶą.hom1) _
                            ‚ąô ap (ap F (f .HomŠĶą.hom1) ‚ąô_) (ap-sym F _)
          ; (mk-lift false) ‚Üí ‚ąô-reflr _ ‚ąô ap-‚ąė F (make-‚ąāőĒ¬≤ f g h) (glue ‚ąāőĒ¬Ļ-0)
                            ‚ąô ap (ap F) (pushout-rec-apő≤ _)
                            ‚ąô ap-‚ąô F  (g .HomŠĶą.hom0) _
                            ‚ąô ap (ap F (g .HomŠĶą.hom0) ‚ąô_) (ap-sym F _)}

  ap-‚ąāőĒ¬≤-diagonal
    : ‚ąÄ {ūĚď§ ūĚď•} {A : Type ūĚď§} {B : Type ūĚď•} (F : A ‚Üí B)
        {x y z} {f : Hom A y z} {g : Hom A x y} {h : Hom A x z}
      ‚Üí (i : őĒ¬Ļ)
      ‚Üí ap-‚ąāőĒ¬≤ F {f = f} {g} {h} (őĻ‚āā i) ÔľĚ refl
  ap-‚ąāőĒ¬≤-diagonal F i = refl

ap-hom2
  : ‚ąÄ {ūĚď§ ūĚď•} {A : Type ūĚď§} {B : Type ūĚď•} (F : A ‚Üí B)
      {x y z : A} (f : Hom A y z) (g : Hom A x y) (h : Hom A x z)
    ‚Üí Hom2 f g h ‚Üí Hom2 (ap-hom F f) (ap-hom F g) (ap-hom F h)
ap-hom2 F f g h K .fst = F ‚ąė K .fst
ap-hom2 F f g h K .snd a = ap F (K .snd a) ‚ąô ap-‚ąāőĒ¬≤ F a

Hom2-ő£-fst
  : ‚ąÄ {ūĚď§ ūĚď•} {A : Type ūĚď§} {P : A ‚Üí Type ūĚď•}
      {x y z} (g : Hom (ő£ A P) y z) (f : Hom (ő£ A P) x y) (h : Hom (ő£ A P) x z)
    ‚Üí Hom2 g f h
    ‚Üí Hom2 (Hom-ő£-fst g) (Hom-ő£-fst f) (Hom-ő£-fst h)
Hom2-ő£-fst f g h K
  = coe
     (ap‚āÉ Hom2
          (Hom-ő£-ap-fst f)
          (Hom-ő£-ap-fst g)
          (Hom-ő£-ap-fst h))
     (ap-hom2 fst f g h K)
}
}


\subtree[stt-00AL]{
\title{Morphisms in a Segal type have unique composites}
\taxon{Theorem}

\p{Given a pair of composable morphisms, we can naturally define a map
#{\Lambda^2_1 \to C}. We show that there is a unique 2-simplex that extends
#{f} and #{g}.}


\proof{
\p{[Segal types](stt-00AI) are defined to be those types which are local
with respect to the inclusion #{i : \Lambda^2_1 \hookrightarrow \Delta^2}. The
fibres of #{i^* : (\Delta^2 \to C) \to (\Lambda^2_1 \to C)} are exactly the maps
#{\Delta^2 \to C} which extend the boundary #{f,g}.}
}

\agda{
opaque
  segal-unique-composite
    : ‚ąÄ {ūĚď§} {A : Type ūĚď§} {x y z} ‚Üí is-segal A
      ‚Üí (f : Hom A y z) (g : Hom A x y)
      ‚Üí is-singleton (ő£[ H ‚ą∂ (őĒ¬≤ ‚Üí A)] (H ‚ąė őõ[2,1]-incl ÔľĚ make-horn f g))
  segal-unique-composite ūĚźī f g
    = has-singleton-fibres‚Üźis-equiv (ūĚźī tt) (make-horn f g)


ext-őõ[2,1]
  : ‚ąÄ {ūĚď§} {A : Type ūĚď§} (fg : őõ[2,1] ‚Üí A)
    ‚Üí Hom A (fg (őĻ‚āĀ i0)) (fg (őĻ‚āā i1)) ‚Üí Ext ‚ąāőĒ¬≤‚Üźőõ[2,1] {őĽ _ ‚Üí A} fg
ext-őõ[2,1] {A = A} fg
  = total-map-fst cogap ‚ąė map1 module ext-őõ[2,1] where
  map1
    : Hom A (fg (őĻ‚āĀ i0)) (fg (őĻ‚āā i1))
    ‚Üí ő£[ cc ‚ą∂ Cocone (mk-span ‚ąāőĒ¬Ļ ‚ąāőõ[2,1]-incl ‚ąāőĒ¬Ļ-incl) A ]
        (cc .Cocone.p ~ fg)
  map1 h@(mk-hom hh h0 h1)
    = (mk-cocone fg hh (‚ąāőĒ¬Ļ-UP‚Üí (sym h0 , sym h1)) , ~refl)

  map1=
    : Hom A (fg (őĻ‚āĀ i0)) (fg (őĻ‚āā i1))
    ‚Üí ő£[ cc ‚ą∂ Cocone (mk-span ‚ąāőĒ¬Ļ ‚ąāőõ[2,1]-incl ‚ąāőĒ¬Ļ-incl) A ]
        (cc .Cocone.p ÔľĚ fg)
  map1= h@(mk-hom hh h0 h1)
    = (mk-cocone fg hh (‚ąāőĒ¬Ļ-UP‚Üí (sym h0 , sym h1)) , refl)

  map1=-is-equiv : is-equiv map1=
  map1=-is-equiv
    = is-equiv-‚ąė
        (total-is-equiv‚Üźfst-is-equiv
          (is-equiv‚ĀĽ¬Ļ (_‚ČÉ_.fwd-is-equiv cocone-repr‚ČÉ)))
        (is-equiv-‚ąė
          (is-equiv‚ĀĽ¬Ļ (_‚ČÉ_.fwd-is-equiv
            (remove-singleton-structure Sing'-is-singleton (_ , refl))))
          (is-equiv-‚ąė
            (is-total-equiv‚Üźis-fibrewise-equiv
              (őĽ a ‚Üí is-equiv-‚ąė (‚ąāőĒ¬Ļ-UP ._‚ČÉ_.fwd-is-equiv)
                                (‚äó-is-equiv sym-is-equiv sym-is-equiv)))
            (HomŠĶą-repr‚ČÉ ._‚ČÉ_.fwd-is-equiv)))

  map1-is-equiv : is-equiv map1
  map1-is-equiv
    = is-equiv-‚ąė
        (is-total-equiv‚Üźis-fibrewise-equiv (őĽ _ ‚Üí funext‚ČÉ ._‚ČÉ_.fwd-is-equiv))
        map1=-is-equiv

ext-őõ[2,1]-is-equiv
  : ‚ąÄ {ūĚď§} {A : Type ūĚď§} (fg : őõ[2,1] ‚Üí A)
    ‚Üí is-equiv (ext-őõ[2,1] fg)
ext-őõ[2,1]-is-equiv fg
  = is-equiv-‚ąė
      (total-is-equiv‚Üźfst-is-equiv pushout-rec-is-equiv)
      (ext-őõ[2,1].map1-is-equiv fg)


ext-mk-horn
  : ‚ąÄ {ūĚď§} {A : Type ūĚď§} {x y z} (f : Hom A y z) (g : Hom A x y)
    ‚Üí Hom A x z ‚Üí Ext ‚ąāőĒ¬≤‚Üźőõ[2,1] {őĽ _ ‚Üí A} (make-horn f g)
ext-mk-horn {A = A} {x} {y} {z} f g
  = total-map (őĽ _ ‚Üí happly) ‚ąė ext=-mk-horn where
  ext=-mk-horn
    : Hom A x z
    ‚Üí ő£[ H ‚ą∂ (‚ąāőĒ¬≤ ‚Üí A)] (H ‚ąė ‚ąāőĒ¬≤‚Üźőõ[2,1] ÔľĚ make-horn f g)
  ext=-mk-horn h = (make-‚ąāőĒ¬≤ f g h , refl)

opaque
  ext-mk-horn-is-equiv
    : ‚ąÄ {ūĚď§} {A : Type ūĚď§} {x y z} (f : Hom A y z) (g : Hom A x y)
      ‚Üí is-equiv (ext-mk-horn f g)
  ext-mk-horn-is-equiv {A = A} {x} {y} {z} f g
    = is-equiv-‚ąė
        (is-total-equiv‚Üźis-fibrewise-equiv (őĽ _ ‚Üí funext‚ČÉ ._‚ČÉ_.fwd-is-equiv))
        ext=-mk-horn-is-equiv where
    ext=-őõ[2,1]
      : Hom A (make-horn f g (őĻ‚āĀ i0)) (make-horn f g (őĻ‚āā i1))
      ‚Üí ő£[ H ‚ą∂ (‚ąāőĒ¬≤ ‚Üí A)] (H ‚ąė ‚ąāőĒ¬≤‚Üźőõ[2,1] ÔľĚ make-horn f g)
    ext=-őõ[2,1] = total-map-fst cogap ‚ąė ext-őõ[2,1].map1= (make-horn f g)

    ext=-őõ[2,1]-is-equiv : is-equiv ext=-őõ[2,1]
    ext=-őõ[2,1]-is-equiv
      = is-equiv-‚ąė
          (total-is-equiv‚Üźfst-is-equiv pushout-rec-is-equiv)
          (ext-őõ[2,1].map1=-is-equiv (make-horn f g))

    ext=-mk-horn
      : Hom A x z
      ‚Üí ő£[ H ‚ą∂ (‚ąāőĒ¬≤ ‚Üí A)] (H ‚ąė ‚ąāőĒ¬≤‚Üźőõ[2,1] ÔľĚ make-horn f g)
    ext=-mk-horn h = (make-‚ąāőĒ¬≤ f g h , refl)

    ext=-mk-horn-is-equiv : is-equiv ext=-mk-horn
    ext=-mk-horn-is-equiv
      = homotopy-is-equiv
         (őĽ where
            h@(mk-hom hh refl refl) ‚Üí fibre-path‚Üí
              ( funext‚Üí (pushout-rec-unique _ _ ~refl ~refl
                          (~‚ąô-reflr _ ~‚ąô pushout-rec-apő≤
                          ~‚ąô ‚ąāőĒ¬Ļ-UP‚Üí ( sym-sym ‚ąô sym (‚ąô-reflr _)
                                     , sym-sym ‚ąô sym (‚ąô-reflr _))))
              , ‚ąô-reflr _ ‚ąô sym (commutes-prewhisker-funext _) ‚ąô funext-refl))
         (is-equiv-‚ąė ext=-őõ[2,1]-is-equiv
                     (adjust-hom-is-equiv (sym (g .HomŠĶą.hom0)) (sym (f .HomŠĶą.hom1))))

ext-mk-horn-compute-diagonal
  : ‚ąÄ {ūĚď§} {A : Type ūĚď§} {x y z} (f : Hom A y z) (g : Hom A x y)
    ‚Üí HomŠĶą.hom ‚ąė is-equiv.bwd (ext-mk-horn-is-equiv f g) ~ precomp A őĻ‚āā ‚ąė fst
ext-mk-horn-compute-diagonal f g
  = (HomŠĶą.hom ‚óā is-equiv.ő∑ (ext-mk-horn-is-equiv f g))
    ‚Ėłeqv (ext-mk-horn-is-equiv f g)

opaque
  composite‚Üźhorn-extension
    : ‚ąÄ {ūĚď§} {A : Type ūĚď§} {x y z} (f : Hom A y z) (g : Hom A x y)
      ‚Üí ő£[ H ‚ą∂ (őĒ¬≤ ‚Üí A)] (H ‚ąė őõ[2,1]-incl ÔľĚ make-horn f g)
      ‚Üí ő£[ h ‚ą∂ Hom A x z ] (Hom2 f g h)
  composite‚Üźhorn-extension {A = A} {x} {y} {z} f g
    = total-map-fst (is-equiv.bwd (ext-mk-horn-is-equiv f g))
    ‚ąė total-map (őĽ a ‚Üí tr (Ext ‚ąāőĒ¬≤-incl)
                          (sym (ap fst (is-equiv.őĶ (ext-mk-horn-is-equiv f g) a))))
    ‚ąė Ext-compose global-funext ‚ąāőĒ¬≤-incl ‚ąāőĒ¬≤‚Üźőõ[2,1] (make-horn f g) ._‚ČÉ_.fwd
    ‚ąė total-map (őĽ _ ‚Üí happly)

  composite‚Üźhorn-extension-is-equiv
    : ‚ąÄ {ūĚď§} {A : Type ūĚď§} {x y z} (f : Hom A y z) (g : Hom A x y)
      ‚Üí is-equiv (composite‚Üźhorn-extension f g)
  composite‚Üźhorn-extension-is-equiv f g
    = is-equiv-‚ąė
       (total-is-equiv‚Üźfst-is-equiv (is-equiv‚ĀĽ¬Ļ (ext-mk-horn-is-equiv f g)))
       (is-equiv-‚ąė
         (is-total-equiv‚Üźis-fibrewise-equiv (őĽ a ‚Üí
           tr-is-equiv {B = Ext ‚ąāőĒ¬≤-incl}
             (sym (ap fst (is-equiv.őĶ (ext-mk-horn-is-equiv f g) a)))))
         (is-equiv-‚ąė
           (Ext-compose global-funext _ _ (make-horn f g) ._‚ČÉ_.fwd-is-equiv)
           (is-total-equiv‚Üźis-fibrewise-equiv (őĽ _ ‚Üí funext‚ČÉ ._‚ČÉ_.fwd-is-equiv))))

  composite‚Üźhorn-extension-diagonal
    : ‚ąÄ {ūĚď§} {A : Type ūĚď§} {x y z} (f : Hom A y z) (g : Hom A x y)
      ‚Üí HomŠĶą.hom ‚ąė fst ‚ąė composite‚Üźhorn-extension f g
      ~ precomp A őĒ¬≤-diagonal ‚ąė fst
  composite‚Üźhorn-extension-diagonal f g x
    = ext-mk-horn-compute-diagonal f g _

_‚ąė[_]_
  : ‚ąÄ {ūĚď§} {A : Type ūĚď§} {x y z} ‚Üí Hom A y z ‚Üí is-segal A
    ‚Üí Hom A x y ‚Üí Hom A x z
f ‚ąė[ ūĚźī ] g = fst (composite‚Üźhorn-extension f g
                    (centre (segal-unique-composite ūĚźī f g)))

‚ąė[_]-is-composite
  : ‚ąÄ {ūĚď§} {A : Type ūĚď§} {x y z} (ūĚźī : is-segal A)
    ‚Üí {f : Hom A y z} {g : Hom A x y}
    ‚Üí Hom2 f g (f ‚ąė[ ūĚźī ] g)
‚ąė[ ūĚźī ]-is-composite {f} {g}
  = snd (composite‚Üźhorn-extension _ _
          (centre (segal-unique-composite ūĚźī f g)))

opaque
  composite-is-prop
    : ‚ąÄ {ūĚď§} {A : Type ūĚď§} (ūĚźī : is-segal A)
        {x y z} (f : Hom A y z) (g : Hom A x y)
      ‚Üí is-prop (ő£ (Hom A x z) (Hom2 f g))
  composite-is-prop ūĚźī f g
    = is-prop‚Üźequiv-to-prop
        (mk‚ČÉ _ (composite‚Üźhorn-extension-is-equiv f g))
        (is-prop‚Üźis-single (segal-unique-composite ūĚźī f g))

  unique-composite
    : ‚ąÄ {ūĚď§} {A : Type ūĚď§} (ūĚźī : is-segal A)
        {x y z} (f : Hom A y z) (g : Hom A x y)
      ‚Üí (h : Hom A x z) ‚Üí Hom2 f g h ‚Üí h ÔľĚ (f ‚ąė[ ūĚźī ] g)
  unique-composite ūĚźī f g h K
    = sym (ap fst
             ((is-single‚Üźequiv-to-single
                (mk‚ČÉ (composite‚Üźhorn-extension f g)
                     (composite‚Üźhorn-extension-is-equiv f g))
                (segal-unique-composite ūĚźī f g)) .central (h , K)))
}
}

\subtree[fre-7B5C]{
\title{2-simplices are composition triangles}
\taxon{Proposition}
\author{fredrikbakke}
\date{2026-04-30}

\agda{
Hom2‚ČÉ‚ąėÔľĚ
  : ‚ąÄ {ūĚď§} {A : Type ūĚď§}
    ‚Üí (ūĚźī : is-segal A)
    ‚Üí {a b c : A}
    ‚Üí {f : Hom A b c} {g : Hom A a b} {h : Hom A a c}
    ‚Üí Hom2 f g h ‚ČÉ (f ‚ąė[ ūĚźī ] g ÔľĚ h)
Hom2‚ČÉ‚ąėÔľĚ ūĚźī {f = f} {g} {h} = mk‚ČÉ fwd (is-equiv‚Üźqinv qinv) where
  fwd : Hom2 f g h ‚Üí f ‚ąė[ ūĚźī ] g ÔľĚ h
  fwd K = ap fst (composite-is-prop ūĚźī f g _ _)

  bwd : f ‚ąė[ ūĚźī ] g ÔľĚ h ‚Üí Hom2 f g h
  bwd p = tr (Hom2 f g) p ‚ąė[ ūĚźī ]-is-composite

  qinv : quasi-inv fwd
  qinv .fst = bwd
  qinv .snd .fst K = ő£-path-snd (composite-is-prop ūĚźī f g _ _)
  qinv .snd .snd refl
    = ap (ap fst)
         (is-prop‚Üźis-single
           (ÔľĚ-is-single‚Üźis-prop (composite-is-prop ūĚźī f g) _ _)
           (composite-is-prop ūĚźī f g _ _)
           (refl))
}
}

\subtree[stt-00DP]{
\title{Dependent composition}
\taxon{Construction}

\p{Given a [Segal type](stt-00AI) #{A} together with #{P : A \to \UU}, an
[inner family](stt-00C5) over it, given a pair of composable morphisms #{f,g}
in #{A},
we can define a composition operator on morphisms over #{f} and #{g} which
lives over the composite #{f \circ g}.}

\proof{
Follows from the fact the the total type is Segal, and thus admits a composition
operator, which agrees (by uniqueness of composites) with the base composition.
}

\agda{
Hom-ő£-fst-‚ąė
  : ‚ąÄ {ūĚď§ ūĚď•} {A : Type ūĚď§} (ūĚźī : is-segal A)
      {P : A ‚Üí Type ūĚď•} (inn : is-inner-family P)
      {x y z} {x' : P x} {y' : P y} {z' : P z}
      (g : Hom _ (y , y') (z , z')) (f : Hom _ (x , x') (y , y'))
    ‚Üí Hom-ő£-fst (g ‚ąė[ ő£-is-segal ūĚźī inn ] f)
    ÔľĚ (Hom-ő£-fst g ‚ąė[ ūĚźī ] Hom-ő£-fst f)
Hom-ő£-fst-‚ąė ūĚźī inn f g
  = unique-composite ūĚźī (Hom-ő£-fst f) (Hom-ő£-fst g)
      (Hom-ő£-fst (f ‚ąė[ ő£-is-segal ūĚźī inn ] g))
      (Hom2-ő£-fst _ _ _ ‚ąė[ ő£-is-segal ūĚźī inn ]-is-composite)

opaque
  CompŠĶą
    : ‚ąÄ {ūĚď§ ūĚď•} {A : Type ūĚď§} (ūĚźī : is-segal A) (P : A ‚Üí Type ūĚď•)
        (inn : is-inner-family P) {x y z} (g : Hom A y z) (f : Hom A x y)
        {x' : P x} {y' : P y} {z' : P z}
        (g' : Hom-over g y' z') (f' : Hom-over f x' y')
      ‚Üí Hom-over (g ‚ąė[ ūĚźī ] f) x' z'
  CompŠĶą ūĚźī P inn {x} {y} {z} g f {x'} {y'} {z'} g' f'
    = tr (őĽ p ‚Üí Hom-over {x = x} {y = z} p x' z')
         {Hom-ő£-fst (Hom-ő£ (g , g') ‚ąė[ ő£-is-segal ūĚźī inn ] Hom-ő£ (f , f'))}
         {g ‚ąė[ ūĚźī ] f}
         (Hom-ő£-fst-‚ąė ūĚźī inn (Hom-ő£ (g , g')) (Hom-ő£ (f , f'))
          ‚ąô ap‚āā (_‚ąė[ ūĚźī ]_) (Hom-ő£-fst-ő≤ _ _) (Hom-ő£-fst-ő≤ _ _))
         (Hom-ő£-snd ((Hom-ő£ (g , g')) ‚ąė[ ő£-is-segal ūĚźī inn ] (Hom-ő£ (f , f'))))
}
}

\subtree[fre-00MY]{
\title{Precomposition and postcompositio of morphisms}
\author{fredrikbakke}
\taxon{Definition}

\agda{
module _ {ūĚď§ : Level} {A : Type ūĚď§} (ūĚźī : is-segal A) where

  postcomp-hom
    : {a b : A} (c : A)
    ‚Üí Hom A a b ‚Üí Hom A c a ‚Üí Hom A c b
  postcomp-hom c f = f ‚ąė[ ūĚźī ]_

  precomp-hom
    : {a b : A} (c : A)
    ‚Üí Hom A a b ‚Üí Hom A b c ‚Üí Hom A a c
  precomp-hom c f = _‚ąė[ ūĚźī ] f
}
}

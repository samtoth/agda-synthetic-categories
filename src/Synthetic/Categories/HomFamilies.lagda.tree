‚ßÖ-degen' : Pushout Œî¬≤-diagonal src-Œî~‚ñµ ‚Üí ‚ßÖ-degen-top
‚ßÖ-degen' = Pushout-assoc‚Üí Œî¬≤-diagonal Œî¬≤-diagonal (_, i0) !

‚ßÖ-degen‚ÜêŒî¬≤ : Œî¬≤ ‚Üí ‚ßÖ-degen-top
‚ßÖ-degen‚ÜêŒî¬≤ = Œπ‚ÇÅ ‚àò Œπ‚ÇÅ

_ : ‚àÄ {ùì§} {A : Type ùì§}
     ‚Üí precomp A ‚ßÖ-degen‚ÜêŒî¬≤
       ~ fst ‚àò _‚âÖ_.fwd cocone-repr‚âÖ ‚àò cocone-map _ pushout ‚àò precomp A ‚ßÖ-degen'
_ = ~refl

opaque
  ‚ßÖ-degen‚ÜêŒî¬≤-is-segal-equiv : is-segal-equiv ‚ßÖ-degen‚ÜêŒî¬≤
  ‚ßÖ-degen‚ÜêŒî¬≤-is-segal-equiv {Q = Q} qpc
    = is-equiv-‚àò
        {f = fst}
        {_‚âÖ_.fwd cocone-repr‚âÖ ‚àò cocone-map _ pushout ‚àò precomp Q ‚ßÖ-degen'}
        (singleton-fst-is-equiv
          (Œª a ‚Üí
            is-single‚Üêequiv-to-single
              ( (Œ£-ap-‚âÉ-fst {B = Œª f ‚Üí a ‚àò Œî¬≤-diagonal ~ f}
                          (mk‚âÉ _ (src-is-segal-equiv qpc))
                           e‚Åª¬π) )
              (SingS-is-single _)))
        (is-equiv-‚àò
          (_‚âÉ_.has-is-eqv cocone-repr‚âÉ)
          (is-equiv-‚àò
            Pushout-is-pushoutœâ
            (precomp-equiv
              (is-equiv‚Üêqiso
                (Pushout-assoc-is-equiv Œî¬≤-diagonal Œî¬≤-diagonal (_, i0) !)))))
}

\subtree[stt-00D0]{
\title{Natural transformations}
\taxon{Definition}

\p{Given a pair of (dependent) functions #{f, g : \Pi_{a : A} B}, we the
type of natural transformations is nothing but the fibrewise morphisms
#{\Pi_{a : A} \Hom_{B(a)}(f(a), g(a))}.}

%```agda
\agda{
_‚áí_ : ‚ąÄ {ūĚď§ ūĚď•} {A : Type ūĚď§} {B : A ‚Üí Type ūĚď•} (f g : ő† A B)
    ‚Üí Type (ūĚďė ‚äĒ ūĚď§ ‚äĒ ūĚď•)
f ‚áí g = ‚ąÄ a ‚Üí Hom _ (f a) (g a)
}
%```
}

\subtree[stt-00C6]{
\title{Homs in #{\Pi}-types are natural transformations}
\taxon{Theorem}

\p{This is function extensionality for hom types, except unlike for Identity
types, since Hom types are corepresented by an interval, this is a trivial theorem
and not an axiom.}

%```agda
\agda{
Hom‚ÜźNT : ‚ąÄ {ūĚď§ ūĚď•} {A : Type ūĚď§}{B : A ‚Üí Type ūĚď•} {f g : ő† A B}
         ‚Üí f ‚áí g ‚Üí Hom (ő† A B) f g
Hom‚ÜźNT őĪ .HomŠĶą.hom i a = őĪ a .HomŠĶą.hom i
Hom‚ÜźNT őĪ .HomŠĶą.hom0 = funext‚Üí (őĽ a ‚Üí őĪ a .HomŠĶą.hom0)
Hom‚ÜźNT őĪ .HomŠĶą.hom1 = funext‚Üí (őĽ a ‚Üí őĪ a .HomŠĶą.hom1)

NT‚ÜźHom : ‚ąÄ {ūĚď§ ūĚď•} {A : Type ūĚď§}{B : A ‚Üí Type ūĚď•} {f g : ő† A B}
         ‚Üí Hom (ő† A B) f g
         ‚Üí f ‚áí g
NT‚ÜźHom őĪ a .HomŠĶą.hom i = őĪ .HomŠĶą.hom i a
NT‚ÜźHom őĪ a .HomŠĶą.hom0 = happly (őĪ .HomŠĶą.hom0) a
NT‚ÜźHom őĪ a .HomŠĶą.hom1 = happly (őĪ .HomŠĶą.hom1) a

NT‚ČÉHom : ‚ąÄ {ūĚď§ ūĚď•} {A : Type ūĚď§}{B : A ‚Üí Type ūĚď•}
           {f g : ő† A B}
         ‚Üí Hom (ő† A B) f g ‚ČÉ (f ‚áí g)
NT‚ČÉHom = mk‚ČÉ NT‚ÜźHom (is-equiv‚Üźqinv qinv) where
  qinv : quasi-inv NT‚ÜźHom
  qinv .fst = Hom‚ÜźNT
  qinv .snd .fst (mk-hom hom hom0 hom1)
    = Hom-ext‚Üí (~refl , sym (funext.ő∑ hom0) , sym (funext.ő∑ hom1))
  qinv .snd .snd őĪ = funext‚Üí őĽ a ‚Üí Hom-ext‚Üí
    ( ~refl
    , sym (happly funext-redex a)
    , sym (happly funext-redex a))
}
%```
}

\subtree[stt-00FR]{
\title{Natural transformations are natural w.r.t covariant transport}
\taxon{Lemma}

\citet{Prop 8.17.}{RS17}

%```agda
\agda{
tr-naturality
  : ‚ąÄ {ūĚď§ ūĚď• ūĚď¶} {A : Type ūĚď§} {F : A ‚Üí Type ūĚď•} {G : A ‚Üí Type ūĚď¶}
      (Fc : is-covariant F)
      (Gc : is-covariant G)
      (őĪ : ‚ąÄ a ‚Üí F a ‚Üí G a)
      {x y} (f : Hom A x y)
    ‚Üí tr-cov-hom Gc f ‚ąė őĪ x ~ őĪ y ‚ąė tr-cov-hom Fc f
tr-naturality Fc Gc őĪ f x'
  = ap fst
      (is-covariant-hom‚Üźis-covariant _ Gc f (őĪ _ x') .central
        ( őĪ _ (tr-cov-hom Fc f x')
        , help f x')) where
  help : ‚ąÄ {x y} (f : Hom _ x y) x'
       ‚Üí Hom-over f (őĪ x x') (őĪ y (tr-cov-hom Fc f x'))
  help (mk-hom f refl refl) x'
    = mk-hom (őĽ i ‚Üí őĪ (f i) ((Fc f x') .centre .snd .HomŠĶą.hom i))
             (ap (őĪ (f i0)) ((Fc f x') .centre .snd .HomŠĶą.hom0))
             (ap (őĪ (f i1)) ((Fc f x') .centre .snd .HomŠĶą.hom1))
}
%```
}

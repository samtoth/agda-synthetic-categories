\date{2025-06-02}
\author{samueltoth}
\title{Fibres of maps given by pre/post-composition}
\taxon{Module}

\import{stt-macros}

%```agda
\agda{
open import Foundations.FunExt

module Foundations.CompositionFibres (FE : FunExt-global) where

open import Foundations.Universes
open import Foundations.QuasiIsomorphism
open import Foundations.CoherentIsomorphism
open import Foundations.Functions
open import Foundations.Sigma
open import Foundations.SigmaPath
open import Foundations.Identity

open WithFunExt-global FE
}
%```

\subtree[stt-004P]{
\title{Fibres of the postcomposition map}
\taxon{Theorem}

%```agda
\agda{
fibre-postcomp≃
  : ∀ {𝓤 𝓥 𝓦} {A : Type 𝓤} {B : Type 𝓥}
      {C : Type 𝓦} (f : A → B) (h : C → B)
    → fibre (postcomp C f) h ≃  Π C (fibre f ∘ h)
fibre-postcomp≃ f h = mk≃ fwd (is-equiv←qiso fwd-qiso) where
  fwd : fibre (postcomp _ f) h → Π _ (fibre f ∘ h)
  fwd (g , p) c = (g c , happly p c)

  fwd-qiso : quasi-iso fwd
  fwd-qiso .fst g = (fst ∘ g , funext→ (snd ∘ g))
  fwd-qiso .snd .fst (h , p) = Σ-path→ (refl , (_≃_.η funext≃ p))
  fwd-qiso .snd .snd g
    = funext→ (λ a → Σ-path→ ( refl
                             , happly (_≃_.ε funext≃ (snd ∘ g)) a)
                             )
}
%```
}

\subtree{
\title{Fibres of the composition of maps}
\taxon{Lemma}

%```agda
\agda{
fibre-∘
  : ∀ {𝓤 𝓥 𝓦} {A : Type 𝓤} {B : Type 𝓥} {C : Type 𝓦}
      {f : B → C} {g : A → B}
    → ∀ a → fibre (f ∘ g) a ≃ Σ[ x ∶ fibre f a ] fibre g (fst x)
fibre-∘ {f = f} {g = g} c = equiv←qiso qiso where
  qiso : fibre (f ∘ g) c ≅ Σ (fibre f c) (λ x → fibre g (fst x))
  qiso ._≅_.fwd (x , p) = ((g x , p) , (x , refl))
  qiso ._≅_.fwd-iso .fst ((x , p) , (y , refl)) = (y , p)
  qiso ._≅_.fwd-iso .snd .fst (a , refl) = refl
  qiso ._≅_.fwd-iso .snd .snd ((x , p) , (y , refl)) = refl
}
%```
}

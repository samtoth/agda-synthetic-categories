open import Foundations.CoherentIsomorphism
}
% ```

\subtree[fre-0001]{
\date{2026-03-28}
\author{fredrikbakke}
\taxon{Definition}
\title{Pointed types}

\p{
A \em{pointed type} is a type #{X} together with a chosen element #{x : X}.
}

% ```agda
\agda{
record Type‚ąó (ūĚď§ : Level) : Type (lsuc ūĚď§) where
  constructor mk-type‚ąó
  field
    carrier : Type ūĚď§
    pt : carrier

open Type‚ąó public
}
% ```
}

\subtree[fre-0002]{
\date{2026-03-28}
\author{fredrikbakke}
\taxon{Definition}
\title{Pointed maps}

\p{
A \em{pointed map} between [pointed types](fre-0001) #{\Hom_*((X,x), (Y,y))} is a
function #{f : X \to Y} together with a proof that it preserves the base point:
#{f(x) = y}.
}

% ```agda
\agda{
record map‚ąó {ūĚď§ ūĚď• : Level} (A : Type‚ąó ūĚď§) (B : Type‚ąó ūĚď•) : Type (ūĚď§ ‚äĒ ūĚď•) where
  constructor mk-map‚ąó
  field
    hom : carrier A ‚Üí carrier B
    pres-pt : hom (pt A) ÔľĚ pt B

open map‚ąó public

const‚ąó : {ūĚď§ ūĚď• : Level} (A : Type‚ąó ūĚď§) (B : Type‚ąó ūĚď•) ‚Üí map‚ąó A B
const‚ąó A B = mk-map‚ąó (őĽ _ ‚Üí pt B) refl

infixr -1 _‚Üí‚ąó_
_‚Üí‚ąó_ : {ūĚď§ ūĚď• : Level} ‚Üí Type‚ąó ūĚď§ ‚Üí Type‚ąó ūĚď• ‚Üí Type‚ąó (ūĚď§ ‚äĒ ūĚď•)
A ‚Üí‚ąó B = mk-type‚ąó (map‚ąó A B) (const‚ąó A B)
}
% ```
}

\subtree[fre-00J0]{
\date{2026-03-28}
\author{fredrikbakke}
\taxon{Lemma}
\title{Pointed maps as fibres of the evaluation map}

\p{
For a pair of pointed types #{(X, x)} and #{(Y, y)}, pointed maps from #{X} to {Y}
are equivalent to the fibre over #{y} of the evaluation map at #{x}.
}

% ```agda
\agda{
map‚ąó‚ČÉfibre-ev
  : {ūĚď§ ūĚď• : Level}
    (X‚ąó : Type‚ąó ūĚď§)
    {Y : Type ūĚď•}
    (y : Y)
  ‚Üí map‚ąó X‚ąó (mk-type‚ąó Y y) ‚ČÉ fibre (ev (pt X‚ąó)) y
map‚ąó‚ČÉfibre-ev X‚ąó y
  = mk‚ČÉ to (mk-eqv (from , ~refl , ~refl) ~refl) where

  to : map‚ąó X‚ąó (mk-type‚ąó _ y) ‚Üí fibre (ev (pt X‚ąó)) y
  to F = (map‚ąó.hom F , map‚ąó.pres-pt F)

  from : fibre (ev (pt X‚ąó)) y ‚Üí map‚ąó X‚ąó (mk-type‚ąó _ y)
  from (f , p) = mk-map‚ąó f p
}
%```
}

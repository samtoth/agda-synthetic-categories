\date{2026-05-01}
\title{Contravariant type families}
\taxon{Module}
\import{stt-macros}

\agda{
open import Foundations.Universes
open import Algebra.Lattice

module Synthetic.Categories.ContravariantFamilies
  {𝓘} (Δ¹ : Type 𝓘) (I : Lattice Δ¹)
  where

open Lattice I renaming (0l to i0; 1l to i1)

open import Axioms.UF
}

\agda-imports{
\agda{
open import Foundations.Prelude

open import Core.Orthogonal
open import Core.OrthogonalClosure
open import Core.PullbackPowers
open import Core.Arrows
open import Core.ArrowEquiv
open import Core.CartesianSquares
open import Core.PushoutSums

open import Ergonomics.Notations.Orthogonality
open Core.Orthogonal.notation

open import Synthetic.Hom Δ¹ i0 i1
open import Synthetic.Horns Δ¹ I
open import Synthetic.Categories.Precategories Δ¹ I
open import Synthetic.Categories.Comma Δ¹ I
}
}

\subtree[stt-00OD]{
\title{Contravariant families}
\taxon{Definition}

\p{A type family #{P : A \to \UU} is said to be \em{contravariant} if for any arrow
#{f : \Delta^1 \to A}, and lift #{x_1 : P(f(1))} over the right endpoint,
the type of morphisms over #{f} which extend #{x_1} forms a singleton.}

\agda{
is-contravariant
  : ∀ {𝓤 𝓥} {A : Type 𝓤} (P : A → Type 𝓥)
    → Type (𝓘 ⊔ 𝓤 ⊔ 𝓥)
is-contravariant {A = A} P
  = ∀ f (x₁ : P (f i1)) → is-singleton (Σ[ x₀ ∶ P (f i0) ] Homᵈ (P ∘ f) x₀ x₁)

{-# INJECTIVE_FOR_INFERENCE is-contravariant #-}

is-contravariant-is-prop
  : ∀ {𝓤 𝓥} {A : Type 𝓤} (P : A → Type 𝓥) → is-prop (is-contravariant P)
is-contravariant-is-prop _
  = Π-is-prop (λ _ → Π-is-prop (λ _ → is-single-is-prop))

is-contravariant-hom
  : ∀ {𝓤 𝓥} {A : Type 𝓤} (P : A → Type 𝓥)
    → Type (𝓘 ⊔ 𝓤 ⊔ 𝓥)
is-contravariant-hom {A = A} P
  = ∀ {x y} (f : Hom A x y) (y' : P y)
    → is-singleton (Σ[ x' ∶ P x ] Hom-over f x' y')

module _ {𝓤 𝓥} {A : Type 𝓤} {B : A → Type 𝓥} where
  is-contravariant-hom←is-contravariant
    : is-contravariant B → is-contravariant-hom B
  is-contravariant-hom←is-contravariant contrav (mk-hom f refl refl) x'
    = contrav f x'

  is-contravariant←is-contravariant-hom
    : is-contravariant-hom B → is-contravariant B
  is-contravariant←is-contravariant-hom contrav f x'
    = contrav (λhom f) x'
}
}


\subtree[stt-00OF]{
\title{Contravariant type families admit directed transport}
\taxon{Lemma}

\agda{
tr-contrav
  : ∀ {𝓤 𝓥} {A : Type 𝓤} {P : A → Type 𝓥}
    → is-contravariant P → (h : Δ¹ → A) → P (h i1) → P (h i0)
tr-contrav contrav h = fst ∘ centre ∘ contrav h

tr-contrav-filler
  : ∀ {𝓤 𝓥} {A : Type 𝓤} {P : A → Type 𝓥}
    → (Pc : is-contravariant P) → (h : Δ¹ → A)
    → ∀ p → Homᵈ (P ∘ h) (tr-contrav {P = P} Pc h p) p
tr-contrav-filler cov h = snd ∘ centre ∘ cov h

tr-contrav-hom
  : ∀ {𝓤 𝓥} {A : Type 𝓤} {P : A → Type 𝓥}
    → is-contravariant P
    → ∀ {x y} (h : Hom A x y) → P y → P x
tr-contrav-hom contrav h
  = fst ∘ centre ∘ is-contravariant-hom←is-contravariant contrav h

tr-contrav-over
  : ∀ {𝓤 𝓥} {A : Type 𝓤} {P : A → Type 𝓥}
    → (cov : is-contravariant P)
    → ∀ {x y} (h : Hom A x y) → (y' : P y)
    → Hom-over h (tr-contrav-hom cov h y') y'
tr-contrav-over contrav h
  = snd ∘ centre ∘ is-contravariant-hom←is-contravariant contrav h
}
}

\subtree[stt-00OE]{
\title{Right type families}
\taxon{Definition}

\p{We say that a type family is a \em{right family} if, as a type family, it is right orthogonal to
the right endpoint inclusion.}

\agda{
is-right-family
  : ∀ {𝓤 𝓥} {A : Type 𝓤} (B : A → Type 𝓥) → Type (𝓘 ⊔ 𝓤 ⊔ 𝓥)
is-right-family = are-orthogonal-fam (point i1)
}
}

\subtree[stt-00OG]{
\title{Right families are contravariant}

\agda{
module _ {𝓤 𝓥} {A : Type 𝓤} (P : A → Type 𝓥) where

  contrav-lift-is-extension
    : ∀ (σ : Δ¹ → A) (x₁ : P (σ i1))
      → (Σ[ x₀ ∶ P (σ i0) ] Homᵈ (P ∘ σ) x₀ x₁)
      ≃ Extᵈ (point i1) (P ∘ σ) (point x₁)
  contrav-lift-is-extension σ x₁
    =  Σ[ x₀ ∶ P (σ i0) ] Homᵈ (P ∘ σ) x₀ x₁
    ≃⟨ Σ-snd-≃ (λ x → Homᵈ-repr≃) ⟩
       Σ[ x₀ ∶ P (σ i0) ] Σ[ f ∶ Π _ (P ∘ σ)] ((f i0 ＝ x₀) × (f i1 ＝ x₁))
    ≃⟨ Σ-comm ⟩
       Σ[ f ∶ Π _ (P ∘ σ)] Σ[ x₀ ∶ P (σ i0) ] ((f i0 ＝ x₀) × (f i1 ＝ x₁))
    ≃⟨ Σ-snd-≃ (λ f → Σ-assoc e⁻¹ ∙e ×-swap ∙e Σ-singleton (λ _ → Sing-is-singleton)) ⟩
       Σ (Π Δ¹ (P ∘ σ)) (λ z → z i1 ＝ x₁)
    ≃⟨ Σ-snd-≃ (λ f → unit-UP≃ e⁻¹) ⟩
       Extᵈ (point i1) (P ∘ σ) (point x₁)
    ≃∎

  opaque
    is-contravariant←has-unique-extensions
      : has-unique-extensions (point i1) P → is-contravariant P
    is-contravariant←has-unique-extensions ext σ x₁
      = is-single←equiv-to-single
          (contrav-lift-is-extension σ x₁ e⁻¹)
          (ext (mk-afmap σ (point x₁)))

    has-unique-extensions←is-contravariant
      : is-contravariant P → has-unique-extensions (point i1) P
    has-unique-extensions←is-contravariant contrav (mk-afmap σ f)
      = is-single←equiv-to-single
          (contrav-lift-is-extension σ (f tt))
          (contrav σ (f tt))

  has-unique-extensions↔is-contravariant
    : has-unique-extensions (point i1) P ↔ is-contravariant P
  has-unique-extensions↔is-contravariant
    = ( is-contravariant←has-unique-extensions
      , has-unique-extensions←is-contravariant)

  is-right-family↔is-covariant
    : is-right-family P ↔ is-contravariant P
  is-right-family↔is-covariant
    =  are-orthogonal-fam↔has-unique-extensions
    ∙iff has-unique-extensions↔is-contravariant
}
}

\subtree[stt-00OH]{
\title{Right fibrations}
\taxon{Definition}

\p{A map is a \em{right fibration} if it is [right orthogonal](stt-0048) to the right
endpoint inclusion of #{\Delta^1}.}

\p{See [[stt-00AV]] for the dual notion.}

\agda{
is-right-fibration
  : ∀ {𝓤 𝓥} {A : Type 𝓤} {B : Type 𝓥} → (A → B)
    → Type (𝓤 ⊔ 𝓥 ⊔ 𝓘)
is-right-fibration f = (point i1) ⊥ f
}
}

\subtree[stt-00OI]{
\title{Contravariant type families straighten to right fibrations}
\taxon{Corollary}

\p{We show that some family #{P : A \to \UU} is [contravariant](stt-00OD) iff
the map #{\pi : \tilde{P} \to A} is a [right fibration](stt-00OH).}

\agda{
module _ {𝓤 𝓥} {A : Type 𝓤} (P : A → Type 𝓥) where opaque
  is-contravariant↔is-right-fibration
    : is-contravariant P ↔ is-right-fibration (fst: P)
  is-contravariant↔is-right-fibration
    = (is-right-family↔is-covariant P iff⁻¹)
    ∙iff are-orthogonal-fam↔are-orthogonal-fst

  is-right-fibration←is-contravariant
    : is-contravariant P → is-right-fibration (fst: P)
  is-right-fibration←is-contravariant = is-contravariant↔is-right-fibration .fst

  is-contravariant←is-right-fibration
    : is-right-fibration (fst: P) → is-contravariant P
  is-contravariant←is-right-fibration = is-contravariant↔is-right-fibration .snd
}
}

\subtree[tot-R0A2]{
\title{Right fibrations are maps which induce equivalences on coslices}
\taxon{Lemma}

\p{#{p : E \to B} is a right fibration iff for each #{x : E}, the induced map
#{E_{x/} \to B_{x/}} is an equivalence.}

\agda{
module _ {𝓤 𝓥} {E : Type 𝓤} {B : Type 𝓥} (p : E → B) where
  arrow-fibre-right-fibration-is-slice-map
    : ∀ (e : E)
      → Arrow-equiv
          (postcompose-slice (point e) p)
          (arrow-fibre (transpose-square (power-hom (point i1) p)) (point e))
  arrow-fibre-right-fibration-is-slice-map e .fst .Arrow-Π.top
    = total-map (λ a → ap point) ∘ Slice-object-repr≃ e ._≃_.fwd
  arrow-fibre-right-fibration-is-slice-map e .fst .Arrow-Π.bot
    = total-map (λ a → ap point) ∘ Slice-object-repr≃ (p e) ._≃_.fwd
  arrow-fibre-right-fibration-is-slice-map e .fst .Arrow-Π.comm (e' , f)
    = fibre-path→ (refl , sym (ap-∘ (p ∘_) (λ a _ → a) (Homᵈ.hom1 (f tt)))
                        ∙ ap-∘ (λ a _ → a) p (Homᵈ.hom1 (f tt)))
  arrow-fibre-right-fibration-is-slice-map e .snd .fst
    = is-equiv-∘
        (is-total-equiv←is-fibrewise-equiv
          (λ a → is-embedding←is-equiv (point-is-equiv)))
        (Slice-object-repr≃ e ._≃_.fwd-is-equiv)
  arrow-fibre-right-fibration-is-slice-map e .snd .snd
    = is-equiv-∘
        (is-total-equiv←is-fibrewise-equiv
          (λ a → is-embedding←is-equiv (point-is-equiv)))
        (Slice-object-repr≃ (p e) ._≃_.fwd-is-equiv)

  slice-map-is-equiv←is-right-fibration
    : is-right-fibration p → (∀ e → is-equiv (postcompose-slice (point e) p))
  slice-map-is-equiv←is-right-fibration lfib e
    = src-is-equiv←Arrow-equiv
        (arrow-fibre-right-fibration-is-slice-map e)
        (transpose-is-cartesian _ (is-cartesian←are-orthogonal lfib) (point e))


  is-right-fibration←slice-map-is-equiv
    : (∀ e → is-equiv (postcompose-slice (point e) p)) → is-right-fibration p
  is-right-fibration←slice-map-is-equiv eqv
    = are-orthogonal←is-cartesian
        (transpose-is-cartesian _
          λ e → tgt-is-equiv←Arrow-equiv
                  (arrow-fibre-right-fibration-is-slice-map (e tt))
                  (eqv (e tt)))

}
}

\subtree[stt-00OJ]{
\title{Right fibrations are inner}
\taxon{Lemma}

\proof{
\p{We use the fact that left orthogonal maps [are closed under pushout products
and embeddings](stt-00BV). In particular we take the pushout product:
#{\underset{\Delta^1}{\overset{\{0\}}{\downarrow}} \pushprod
\underset{\Delta^1}{\overset{\{1\}}{\downarrow}}}, which modulo contracting away
some singletons, is the [inner horn](stt-00AD) inclusion into the square. Now
the following retract square completes the proof:}
\transclude{stt-00LC}
}

\remark{
We may use a perfectly symmetric proof for [left fibrations](stt-00AV)
(\ref{stt-00C7})
}

\agda{
is-inner←is-right-fibration
  : ∀ {𝓤 𝓥} {A : Type 𝓤} {B : Type 𝓥} {f : A → B}
    → is-right-fibration f → is-inner f
is-inner←is-right-fibration {f = f} rf
  = left-orthogonal-retraction
      Λ[2,1]-incl (pushout-product (point i1) (point i0))
      Λ[2,1]↪□-section Λ[2,1]↪□-ret _
      (left-orthogonal-pushout-product (point i1) f rf (point i0))
}
}

\subtree[stt-00OL]{
\taxon{Corollary}

\p{The total type of a contravariant type family over a Segal type is itself Segal.}

\agda{
is-inner-family←is-contravariant
  : ∀ {𝓤 𝓥} {A : Type 𝓤} {B : A → Type 𝓥}
    → is-contravariant B → is-inner-family B
is-inner-family←is-contravariant
  = is-inner←is-right-fibration ∘ (is-contravariant↔is-right-fibration _ .fst)

is-inner-family←is-contravariant-hom
  : ∀ {𝓤 𝓥} {A : Type 𝓤} {B : A → Type 𝓥}
    → is-contravariant-hom B → is-inner-family B
is-inner-family←is-contravariant-hom
  = is-inner-family←is-contravariant ∘ is-contravariant←is-contravariant-hom

Σ-contrav-is-segal
  : ∀ {𝓤 𝓥} {A : Type 𝓤} {B : A → Type 𝓥}
    → is-segal A → is-contravariant B → is-segal (Σ A B)
Σ-contrav-is-segal apc contrav
  = Σ-is-segal apc
      (is-inner←is-right-fibration
        (is-contravariant↔is-right-fibration _ .fst  contrav))
}
}

\subtree[stt-00OK]{
\title{Contravariant transport is functorial}
\taxon{Theorem}


\p{Given a contravariant type family #{P}, we show the transport operation is
functorial, in the sense that #{P(\id) \sim \id} and
#{P(f \circ g) \sim P(g) \circ P(f)}.}

\agda{
tr-contrav-id
  : ∀ {𝓤 𝓥} {A : Type 𝓤} (P : A → Type 𝓥) (Pc : is-contravariant P) {x}
    → tr-contrav Pc (λ _ → x) ~ id
tr-contrav-id P contrav {x} x' = ap fst (contrav (λ _ → x) x' .central (x' , idH x'))

tr-contrav-idH
  : ∀ {𝓤 𝓥} {A : Type 𝓤} (P : A → Type 𝓥) (Pc : is-contravariant P) {x}
    → tr-contrav-hom {P = P} Pc (idH x) ~ id
tr-contrav-idH P contrav {x} x' = ap fst
  (is-contravariant-hom←is-contravariant contrav (idH x) x' .central (x' , idH x'))

tr-contrav-∘
  : ∀ {𝓤 𝓥} {A : Type 𝓤} (Apc : is-segal A) (P : A → Type 𝓥)
      (contrav : is-contravariant P) {x y z} (g : Hom A y z) (f : Hom A x y)
      (z' : P z)
    → tr-contrav-hom contrav (g ∘[ Apc ] f) z'
    ＝ tr-contrav-hom contrav f (tr-contrav-hom contrav g z')
tr-contrav-∘ apc P contrav g f z'
  = ap fst
      (is-contravariant-hom←is-contravariant contrav (g ∘[ apc ] f) z' .central
        ( tr-contrav-hom contrav f (tr-contrav-hom contrav g z')
        , Compᵈ apc P (is-inner-family←is-contravariant contrav) g f
                (tr-contrav-over contrav g _) (tr-contrav-over contrav f _)))
}
}

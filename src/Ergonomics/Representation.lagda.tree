\taxon{Module}
\date{2025-04-18}
\title{Sigma representations for records}

\import{stt-macros}

% ```agda
\agda{
module Ergonomics.Representation where

open import Foundations.Prelude
open import Ergonomics.Builtins
open import Ergonomics.TCM
}
% ```

% ```agda
\agda{
╬БРєљfield-names : Рѕђ {­ЮЊц} {A : Type ­ЮЊц} Рєњ List A Рєњ Term
╬БРєљfield-names [] = def (quote ­ЮЪЎ) []
╬БРєљfield-names (_ Рѕи []) = unknown
╬БРєљfield-names (_ Рѕи xs) =
  def (quote ╬Б) (lam visible (abs "_" (╬БРєљfield-names xs)) vРѕи [])

Fields : Type
Fields = List (Name ├Ќ List Name)

-- an accessor is a term like fst (snd (snd (snd x)))
FieldsРєљField-names : List (Arg Name) Рєњ Fields
FieldsРєљField-names [] = []
FieldsРєљField-names ((arg _ x) Рѕи []) = (x , []) Рѕи []
FieldsРєљField-names (arg ai x Рѕи y Рѕи ys) with FieldsРєљField-names (y Рѕи ys)
... | flds = (x , (quote fst Рѕи [])) Рѕи List-map (╬╗ (nm , p) Рєњ nm , quote snd Рѕи p) flds

iso-typeРєљrecord : Name Рєњ Name Рєњ (List (Arg Term) Рєњ TC Term) Рєњ TC Term
iso-typeРєљrecord eqty namen unfolded = go [] =<< normalise =<< infer-type (def namen []) where
  open DoTC

  go : List ArgInfo Рєњ Term Рєњ TC Term
  go acc (pi argu@(arg i argTy) (abs s ty)) = do
    r Рєљ extend-context "arg" argu (go (i Рѕи acc) ty)
    returnTC (pi (argH argTy) (abs s r))
  go acc (agda-sort _) = do
    let orig = def namen (reverse (map-up (╬╗ n ai Рєњ arg ai (var n [])) 0 acc))
    repr     Рєљ unfolded (reverse (map-up (╬╗ n _ Рєњ argH (var n [])) 0 acc))
    returnTC (def eqty (orig vРѕи repr vРѕи []))
  go acc t = typeError (strErr "Not a record type " Рѕи nameErr namen Рѕи [])


-- repr ._РЅі_.fwd a .snd .snd .fst = field2 a
fwd-clause : Name ├Ќ List Name Рєњ Clause
fwd-clause (field-nm , sel) = clause (("rec" , argN unknown) Рѕи [])
           (argN (proj (quote _РЅі_.fwd)) Рѕи
            argN (var 0) Рѕи
            List-map (argN Рѕў proj) sel)
           (def field-nm (var 0 [] vРѕи []))

-- repr ._РЅі_.fwd-qiso .fst x .fieldNm = fst (snd (snd ...))
bwd-clause : Name ├Ќ List Name Рєњ Clause
bwd-clause (field-nm , sel)
  = clause (("sig" , argN unknown) Рѕи [])
           (argN (proj (quote _РЅі_.fwd-qiso)) Рѕи
            argN (proj (quote fst)) Рѕи
            argN (var 0) Рѕи
            argN (proj field-nm)  Рѕи
            [])
           (foldr (╬╗ nm p Рєњ def nm (p vРѕи [])) (var 0 []) (reverse sel))

fwd-bwd-clause : Clause
fwd-bwd-clause
  = clause (("rec" , (argN unknown)) Рѕи [])
           (argN (proj (quote _РЅі_.fwd-qiso)) Рѕи
            argN (proj (quote snd)) Рѕи
            argN (proj (quote fst)) Рѕи
            argN (var 0) Рѕи [])
           (con (quote refl) (unknown hРѕи unknown hРѕи unknown hРѕи []))

bwd-fwd-clause : Clause
bwd-fwd-clause
  = clause (("sig" , (argN unknown)) Рѕи [])
           (argN (proj (quote _РЅі_.fwd-qiso)) Рѕи
            argN (proj (quote snd)) Рѕи
            argN (proj (quote snd)) Рѕи
            argN (var 0) Рѕи [])
           (con (quote refl) (unknown hРѕи unknown hРѕи unknown hРѕи []))

-- Look up a record type definition in the signature.
get-record-type : Name Рєњ TC (Name ├Ќ List (Arg Name))
get-record-type n = get-definition n >>= ╬╗ where
  (record-type conm fields) Рєњ returnTC (conm , fields)
  _ Рєњ typeError (
                strErr "get-record-type: definition " Рѕи
                nameErr n Рѕи
                strErr " is not a record type." Рѕи
                []) where
  open DoTC

private
  instantiate' : Term Рєњ Term Рєњ Term
  instantiate' (pi _ (abs _ xs)) (pi _ (abs _ b)) = instantiate' xs b
  instantiate' (agda-sort _) tm = tm
  instantiate' _ tm = tm

  sigmaРєљpi-term : Term Рєњ TC Term
  sigmaРєљpi-term (pi (arg _ x) (abs n (def n' _))) = returnTC x
  sigmaРєљpi-term (pi (arg _ x) (abs n y)) = do
    sig Рєљ sigmaРєљpi-term y
    returnTC (def (quote ╬Б) (x vРѕи lam visible (abs n sig) vРѕи []))
    where open DoTC
  sigmaРєљpi-term _ = typeError (strErr "Not a record type constructor! " Рѕи [])


make-record-repr : Name Рєњ Name Рєњ Name Рєњ TC ­ЮЪЎ
make-record-repr iso eqv rec = do
  R-con , fields Рєљ get-record-type rec
  let fields = FieldsРєљField-names fields

  R-ty Рєљ get-type rec
  con-ty Рєљ get-type R-con

  let fun args = do
    let tm = instantiate' R-ty con-ty
    sigmaРєљpi-term tm
  iso-type Рєљ iso-typeРєљrecord (quote _РЅі_) rec fun
  eqv-type Рєљ iso-typeРєљrecord (quote _РЅЃ_) rec fun

  declare-def (argN iso) iso-type
  declare-def (argN eqv) eqv-type

  define-fun iso (List-map fwd-clause fields ++
                 (List-map bwd-clause fields ++
                 (fwd-bwd-clause Рѕи bwd-fwd-clause Рѕи [])))

  define-fun eqv (clause [] [] (def (quote equivРєљqiso) (def iso [] vРѕи [])) Рѕи [])
  where open DoTC
}
% ```

\subtree[stt-0035]{
\taxon{Test}

% ```agda
\agda{
private module _ where
  record Test {­ЮЊц} (A B : Type ­ЮЊц) : Type (lsuc ­ЮЊц) where
    constructor boo
    field
      f : A Рєњ B
      g : B Рєњ A
      h : f Рѕў g ~ id

  record NoCtx : Type where
    field
      b : Bool
      s : String

  unquoteDecl test-reprРЅі' test-reprРЅЃ' = make-record-repr test-reprРЅі' test-reprРЅЃ' (quote Test)

  unquoteDecl noctx-reprРЅі noctx-reprРЅЃ = make-record-repr noctx-reprРЅі noctx-reprРЅЃ (quote NoCtx)

  _ : NoCtx РЅЃ (Bool ├Ќ String)
  _ = noctx-reprРЅЃ
}
% ```
}

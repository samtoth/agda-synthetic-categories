\subtree{
\title{The dependent amazing right adjoint}

%```agda
\agda{
module DependentвҲҡ {@вҷӯ рқ“ҳ} (@вҷӯ I : Type рқ“ҳ)
            (@вҷӯ вҲҡ : вҲҖ {@вҷӯ рқ“Ө} вҶ’ @вҷӯ Type рқ“Ө вҶ’ Type рқ“Ө)
            (@вҷӯ вҲҡОө : вҲҖ {@вҷӯ рқ“Ө} {@вҷӯ A : Type рқ“Ө} вҶ’ (I вҶ’ вҲҡ A) вҶ’ A)
            (@вҷӯ is-tiny-str : вҲҖ {@вҷӯ рқ“Ө} {@вҷӯ A : Type рқ“Ө}
                              вҶ’ is-tiny-structure I A (вҲҡ A) вҲҡОө)
            (@вҷӯ types-separate : вҲҖ {@вҷӯ рқ“Ө рқ“Ҙ} {@вҷӯ A : Type рқ“Ө} {@вҷӯ B : Type рқ“Ҙ}
                                   {@вҷӯ f : A вҶ’ B} вҶ’ Types-separate f)
            (@вҷӯ prop-is-disc : вҲҖ {@вҷӯ рқ“Ө} {@вҷӯ A : Type рқ“Ө}
                               вҶ’ is-prop A вҶ’ is-вҷӯ-discrete A) where
  open Tiny I вҲҡ вҲҡОө is-tiny-str types-separate prop-is-disc

  private
    вҲҡTypeвҲҷ-ПҖ : вҲҖ {@вҷӯ рқ“Ө} вҶ’ вҹЁвҷӯ| (вҲҡ(ОЈ (Type рқ“Ө) id) вҶ’ вҲҡ(Type рқ“Ө)) вҹ©
    вҲҡTypeвҲҷ-ПҖ = вҲҡвӮҒ (modвҷӯ (TypeвҲҷ-ПҖ _))

  classify-вҲҡ : вҲҖ {@вҷӯ рқ“Ө} вҶ’ вҲҡ(Type рқ“Ө) вҶ’ Type (lsuc рқ“Ө)
  classify-вҲҡ
    = Type-is-universal.arrow-map {f = Оөвҷӯ (вҲҡTypeвҲҷ-ПҖ)}
                                  (О» _ вҶ’ self-is-small) .Arrow-map.bot

  вҲҡбөҲ : вҲҖ {@вҷӯ рқ“Ө рқ“Ҙ} {@вҷӯ О“ : Type рқ“Ө} вҶ’ @вҷӯ ((I вҶ’ О“) вҶ’ Type рқ“Ҙ) вҶ’ О“ вҶ’ Type (lsuc рқ“Ҙ)
  вҲҡбөҲ A = classify-вҲҡ вҲҳ Оөвҷӯ (transpose (modвҷӯ A))

  {-# INLINE вҲҡбөҲ #-}

  opaque
    transpose-liftвҷӯ : вҲҖ {@вҷӯ рқ“Ө рқ“Ҙ} {@вҷӯ О“ : Type рқ“Ө} {@вҷӯ A : (I вҶ’ О“) вҶ’ Type рқ“Ҙ}
           вҶ’ вҹЁвҷӯ| Lift (TypeвҲҷ-ПҖ рқ“Ҙ) A вҹ©
           вүғ вҹЁвҷӯ| Lift (Оөвҷӯ (вҲҡTypeвҲҷ-ПҖ {рқ“Ҙ})) (Оөвҷӯ (transpose (modвҷӯ A))) вҹ©
    transpose-liftвҷӯ {рқ“Ө}{рқ“Ҙ}{О“}{A}
      =   вҹЁвҷӯ| Lift (TypeвҲҷ-ПҖ рқ“Ҙ) A вҹ©
      вүғвҹЁ вҷӯ-commОЈ _ eвҒ»В№ вҹ©
          (ОЈ[вҷӯ l вҲ¶ ((I вҶ’ О“) вҶ’ TypeвҲҷ рқ“Ҙ) ] вҹЁвҷӯ| fst вҲҳ l пјқ A  вҹ©)
      вүғвҹЁ ОЈ-ap-вүғ-fst-bwd expвҠЈвҲҡ eвҒ»В№ вҹ©
         ОЈ вҹЁвҷӯ| (О“ вҶ’ вҲҡ (TypeвҲҷ рқ“Ҙ)) вҹ©
          (вҷӯ-ind _ (О» (@вҷӯ l) вҶ’ вҹЁвҷӯ| fst вҲҳ l пјқ A вҹ©) вҲҳ вҷӯ-map untranspose)
      вүғвҹЁ ОЈ-ap-вүғ (О» {(modвҷӯ l) вҶ’ idequiv}) вҹ©
          (ОЈ[вҷӯ l вҲ¶ (О“ вҶ’ вҲҡ (TypeвҲҷ рқ“Ҙ)) ] вҹЁвҷӯ| fst вҲҳ untranspose l пјқ A вҹ©)
      вүғвҹЁ ОЈ-ap-вүғ (О» {(modвҷӯ l) вҶ’ mkвүғ (f l) (feq l)}) вҹ©
          (ОЈ[вҷӯ l вҲ¶ (О“ вҶ’ вҲҡ (TypeвҲҷ рқ“Ҙ)) ]
             вҹЁвҷӯ| (Оөвҷӯ вҲҡTypeвҲҷ-ПҖ) вҲҳ l пјқ Оөвҷӯ (transpose (modвҷӯ A)) вҹ©)
      вүғвҹЁ вҷӯ-commОЈ _ вҹ©
          вҹЁвҷӯ| Lift (Оөвҷӯ вҲҡTypeвҲҷ-ПҖ) (Оөвҷӯ (transpose (modвҷӯ A))) вҹ©
      вүғвҲҺ where
      @вҷӯ f : вҲҖ (@вҷӯ l : О“ вҶ’ вҲҡ (TypeвҲҷ рқ“Ҙ))
             вҶ’ вҹЁвҷӯ| fst вҲҳ untranspose l пјқ A вҹ©
             вҶ’ вҹЁвҷӯ| Оөвҷӯ вҲҡTypeвҲҷ-ПҖ вҲҳ l пјқ Оөвҷӯ (transpose (modвҷӯ A)) вҹ©
      f l  = transpose-unique вҲҳ вҷӯ-map ((happly (вҲҡвӮҒ-nat (modвҷӯ fst)) l вҲҷ_))

      @вҷӯ feq : вҲҖ (@вҷӯ l) вҶ’ is-equiv (f l)
      feq l = is-equiv-вҲҳ
        transpose-unique-is-equiv
        (вҷӯ-map-is-equiv (вҲҷ-is-equiv (happly (вҲҡвӮҒ-nat (modвҷӯ fst)) l)))

  О вҶҗlift : вҲҖ {@вҷӯ рқ“Ө рқ“Ҙ} {@вҷӯ О“ : Type рқ“Ө} {@вҷӯ A : (I вҶ’ О“) вҶ’ Type рқ“Ҙ}
         вҶ’ Lift (Оөвҷӯ (вҲҡTypeвҲҷ-ПҖ {рқ“Ҙ})) (Оөвҷӯ (transpose (modвҷӯ A)))
         вҶ’ О  О“ (вҲҡбөҲ A)
  О вҶҗlift {A = A} = universal-section (Оөвҷӯ (transpose (modвҷӯ A)))
                                     (О» _ вҶ’ self-is-small)

  opaque
    rintro
      : вҲҖ {@вҷӯ рқ“Ө рқ“Ҙ} {@вҷӯ О“ : Type рқ“Ө} {@вҷӯ A : (I вҶ’ О“) вҶ’ Type рқ“Ҙ}
        вҶ’ вҹЁвҷӯ| О  (I вҶ’ О“) A вҹ©
        вҶ’ вҹЁвҷӯ| О  О“ (вҲҡбөҲ A) вҹ©
    rintro {A = A}
      = вҷӯ-map О вҶҗlift вҲҳ transpose-liftвҷӯ ._вүғ_.fwd вҲҳ вҷӯ-map (extensionвҶҗО  A)

    rintro-is-equiv
      : вҲҖ {@вҷӯ рқ“Ө рқ“Ҙ} {@вҷӯ О“ : Type рқ“Ө} {@вҷӯ A : (I вҶ’ О“) вҶ’ Type рқ“Ҙ}
        вҶ’ is-equiv (rintro {A = A})
    rintro-is-equiv
      = is-equiv-вҲҳ
          (вҷӯ-map-is-equiv (universal-section-is-equiv _ (О» _ вҶ’ self-is-small)))
          (is-equiv-вҲҳ
            (transpose-liftвҷӯ ._вүғ_.has-is-eqv)
            (вҷӯ-map-is-equiv (extensionвҶҗО -is-equiv _)))


    relim
      : вҲҖ {@вҷӯ рқ“Ө рқ“Ҙ} {@вҷӯ О“ : Type рқ“Ө} {@вҷӯ A : (I вҶ’ О“) вҶ’ Type рқ“Ҙ}
        вҶ’ вҹЁвҷӯ| О  О“ (вҲҡбөҲ A) вҹ©
        вҶ’ вҹЁвҷӯ| О  (I вҶ’ О“) A вҹ©
    relim = is-equiv.bwd rintro-is-equiv

    вҲҡбөҲ-naturalityвҶ’
      : вҲҖ {@вҷӯ рқ“Ө рқ“Ө' рқ“Ҙ} {@вҷӯ О“ : Type рқ“Ө} {@вҷӯ О” : Type рқ“Ө'}
          (@вҷӯ A : (I вҶ’ О“) вҶ’ Type рқ“Ҙ)
        вҶ’ (@вҷӯ Пғ : О” вҶ’ О“)
        вҶ’ вҲҖ x вҶ’ (вҲҡбөҲ A вҲҳ Пғ) x вҶ’ (вҲҡбөҲ (A вҲҳ postcomp I Пғ)) x
    вҲҡбөҲ-naturalityвҶ’ A Пғ x a = tr
      classify-вҲҡ
      (sym (happly (ap Оөвҷӯ (transpose-naturality (modвҷӯ A) Пғ)
                   вҲҷ Оөвҷӯ-natural (transpose (modвҷӯ A)))
                   x))
      a

    вҲҡбөҲ-naturalityвҶҗ
      : вҲҖ {@вҷӯ рқ“Ө рқ“Ө' рқ“Ҙ} {@вҷӯ О“ : Type рқ“Ө} {@вҷӯ О” : Type рқ“Ө'}
          (@вҷӯ A : (I вҶ’ О“) вҶ’ Type рқ“Ҙ)
        вҶ’ (@вҷӯ Пғ : О” вҶ’ О“)
        вҶ’ вҲҖ x вҶ’ (вҲҡбөҲ (A вҲҳ postcomp I Пғ)) x вҶ’ (вҲҡбөҲ A вҲҳ Пғ) x
    вҲҡбөҲ-naturalityвҶҗ A Пғ x a = tr
      classify-вҲҡ
      (happly (ap Оөвҷӯ (transpose-naturality (modвҷӯ A) Пғ)
                   вҲҷ Оөвҷӯ-natural (transpose (modвҷӯ A)))
                   x)
      a

    вҲҡбөҲ-naturality-is-equiv
      : вҲҖ {@вҷӯ рқ“Ө рқ“Ө' рқ“Ҙ} {@вҷӯ О“ : Type рқ“Ө} {@вҷӯ О” : Type рқ“Ө'} {@вҷӯ A : (I вҶ’ О“) вҶ’ Type рқ“Ҙ}
        вҶ’ (@вҷӯ Пғ : О” вҶ’ О“)
        вҶ’ is-fibrewise-equiv (вҲҡбөҲ-naturalityвҶ’ A Пғ)
    вҲҡбөҲ-naturality-is-equiv Пғ a = tr-is-equiv _

}
%```


%```agda
\agda{
module Amazingly {@вҷӯ рқ“ҳ} (@вҷӯ I : Type рқ“ҳ)
            (@вҷӯ вҲҡ : вҲҖ {@вҷӯ рқ“Ө} вҶ’ @вҷӯ Type рқ“Ө вҶ’ Type рқ“Ө)
            (@вҷӯ вҲҡОө : вҲҖ {@вҷӯ рқ“Ө} {@вҷӯ A : Type рқ“Ө} вҶ’ (I вҶ’ вҲҡ A) вҶ’ A)
            (@вҷӯ is-tiny-str : вҲҖ {@вҷӯ рқ“Ө} {@вҷӯ A : Type рқ“Ө}
                              вҶ’ is-tiny-structure I A (вҲҡ A) вҲҡОө)
            (@вҷӯ types-separate : вҲҖ {@вҷӯ рқ“Ө рқ“Ҙ} {@вҷӯ A : Type рқ“Ө} {@вҷӯ B : Type рқ“Ҙ}
                                   {@вҷӯ f : A вҶ’ B} вҶ’ Types-separate f)
            {@вҷӯ Оұ : Level вҶ’ Level вҶ’ Level}
            (@вҷӯ is-fib : вҲҖ {рқ“Ө рқ“Ҙ} {A : Type рқ“Ө} (B : A вҶ’ Type рқ“Ҙ) вҶ’ Type (Оұ рқ“Ө рқ“Ҙ))
            (@вҷӯ rel-fib : is-relative I is-fib)
            (@вҷӯ prop-is-disc : вҲҖ {@вҷӯ рқ“Ө} {@вҷӯ A : Type рқ“Ө}
                               вҶ’ is-prop A вҶ’ is-вҷӯ-discrete A)
            where
  open DependentвҲҡ I вҲҡ вҲҡОө is-tiny-str types-separate prop-is-disc
  open Tiny I вҲҡ вҲҡОө is-tiny-str types-separate prop-is-disc public
  private
    map : вҲҖ {рқ“Ө} вҶ’ рқҹҷ вҶ’ (Prop-U рқ“Ө)
    map _ = (ULift _ рқҹҷ , trunc!)

  -- class-вҠӨ-large : вҲҖ {@вҷӯ рқ“Ө} вҶ’ вҲҡ(PropU рқ“Ө) вҶ’ PropU (lsuc рқ“Ө)
  -- class-вҠӨ-large x = (fibre вҲҡmap x , {!trunc!!})

  -- вҲҡ-pres-ОЈвҶ’ : вҲҖ {@вҷӯ рқ“Ө рқ“Ҙ} {@вҷӯ A : Type рқ“Ө} {@вҷӯ B : A вҶ’ Type рқ“Ҙ}
  --             вҶ’ вҲҡ (ОЈ A B) вҶ’ ОЈ (вҲҡ A) (вҲҡбөҲ (B вҲҳ вҲҡОө))
  -- вҲҡ-pres-ОЈвҶ’ x .fst = Оөвҷӯ (transpose (modвҷӯ (О» g вҶ’ fst (вҲҡОө g)))) x
  -- вҲҡ-pres-ОЈвҶ’ {B = B} x .snd
  --   =  вҲҡбөҲ-naturalityвҶҗ
  --        (B вҲҳ вҲҡОө) (Оөвҷӯ (вҲҡвӮҒ (modвҷӯ fst))) x
  --        (tr classify-вҲҡ
  --            (happly (ap (Оөвҷӯ вҲҳ transpose) (mapplyвҷӯ (modвҷӯ {!!}))) x)
  --            (Оөвҷӯ (rintro (modвҷӯ (О» g вҶ’ snd (вҲҡОө g)))) x))

  -- вҲҡ-pres-ОЈ-is-equiv
  --   : вҲҖ {@вҷӯ рқ“Ө рқ“Ҙ} {@вҷӯ A : Type рқ“Ө} {@вҷӯ B : A вҶ’ Type рқ“Ҙ}
  --     вҶ’ is-equiv (вҲҡ-pres-ОЈвҶ’ {B = B})
  -- вҲҡ-pres-ОЈ-is-equiv {A = A}{B} = is-equivвҶҗqiso
  --   ( Оөвҷӯ ( transpose (modвҷӯ О» g вҶ’ вҲҡОө (fst вҲҳ g)
  --        , (Оөвҷӯ (relim (modвҷӯ О» g вҶ’ вҲҡбөҲ-naturalityвҶ’ (B вҲҳ вҲҡОө) fst g (g .snd))) g)))
  --   , (О» a вҶ’ {!!})
  --   , {!!})


  вҲҡ-Path : вҲҖ {@вҷӯ рқ“Ө} {@вҷӯ A : Type рқ“Ө} вҶ’ вҲҡ A вҶ’ вҲҡ A вҶ’ Type (lsuc рқ“Ө)
  вҲҡ-Path {_}{A} a b = вҲҡбөҲ (О» g вҶ’ вҲҡОө (fst вҲҳ g) пјқ вҲҡОө (snd вҲҳ g)) (a , b)

  вҲҡ-Path-refl : вҲҖ {@вҷӯ рқ“Ө} {@вҷӯ A : Type рқ“Ө} (a : вҲҡ A) вҶ’ вҲҡ-Path a a
  вҲҡ-Path-refl {A = A} a = вҲҡбөҲ-naturalityвҶҗ _ (О”Г— (вҲҡ A)) a (П• a) where
    @вҷӯ П• : О  (вҲҡ A) (вҲҡбөҲ (О» x вҶ’ вҲҡОө x пјқ вҲҡОө x))
    П• = Оөвҷӯ (rintro {О“ = вҲҡ A}{A = О» x вҶ’ вҲҡОө x пјқ вҲҡОө x} (modвҷӯ ~refl))

  -- вҲҡ-Path-is-torsorial
  --   : вҲҖ {@вҷӯ рқ“Ө} {@вҷӯ A : Type рқ“Ө} (a : вҲҡ A) вҶ’ is-singleton (ОЈ _ (вҲҡ-Path a))
  -- вҲҡ-Path-is-torsorial {A = A} a
  --   = {!!}

  is-afib : вҲҖ {@вҷӯ рқ“Ө} вҶ’ Type рқ“Ө вҶ’ Type (lsuc (Оұ рқ“ҳ рқ“Ө))
  is-afib = вҲҡбөҲ is-fib

  is-afib-is-prop : вҲҖ {@вҷӯ рқ“Ө} {A : Type рқ“Ө} вҶ’ is-prop (is-afib A)
  is-afib-is-prop = {!!}

  record UFib (@вҷӯ рқ“Ө) : Type (lsuc (Оұ рқ“ҳ рқ“Ө вҠ” рқ“Ө)) where
    constructor mk-ufib
    field
      Car : Type рқ“Ө
      has-is-afib : is-afib Car

  UFibвҲҷ : вҲҖ (@вҷӯ рқ“Ө) вҶ’ Type (lsuc (Оұ рқ“ҳ рқ“Ө вҠ” рқ“Ө))
  UFibвҲҷ рқ“Ө = ОЈ (UFib рқ“Ө) UFib.Car

  UFib-ПҖ : вҲҖ {@вҷӯ рқ“Ө} вҶ’ UFibвҲҷ рқ“Ө вҶ’ UFib рқ“Ө
  UFib-ПҖ = fst

  UFib-ПҖ-is-fib : вҲҖ {@вҷӯ рқ“Ө} вҶ’ is-fib (UFib.Car {рқ“Ө})
  UFib-ПҖ-is-fib = rel-fib _ .snd
    (Оөвҷӯ (is-equiv.bwd (rintro-is-equiv)
          (modвҷӯ (О» a вҶ’ tr classify-вҲҡ
                          (sym (happly
                            ( ap Оөвҷӯ (transpose-naturality (modвҷӯ is-fib) UFib.Car)
                            вҲҷ Оөвҷӯ-natural (transpose (modвҷӯ is-fib)))
                            a))
                          (a .UFib.has-is-afib)))))

  UFib-is-fib : вҲҖ {@вҷӯ рқ“Ө рқ“Ҙ} {A : Type рқ“Ө} (P : A вҶ’ UFib рқ“Ҙ)
                вҶ’ is-fib (UFib.Car вҲҳ P)
  UFib-is-fib P
    = is-pullback-stableвҶҗis-relative
        I is-fib rel-fib UFib.Car P
        UFib-ПҖ-is-fib

  liftFib : вҲҖ {@вҷӯ рқ“Ө рқ“Ҙ} {@вҷӯ A : Type рқ“Ө} {@вҷӯ P : A вҶ’ Type рқ“Ҙ}
              вҶ’ вҹЁвҷӯ| is-fib P вҹ© вҮ” вҹЁвҷӯ| (вҲҖ a вҶ’ is-afib (P a)) вҹ©
  liftFib {A = A} {P = P} .fst fib
    = вҷӯ-map (postcomp-О  (вҲҡбөҲ-naturalityвҶҗ _ _))
            (rintro (вҷӯ-map (rel-fib P .fst) fib))
  liftFib {A = A} {P = P} .snd
    = вҷӯ-map (UFib-is-fib вҲҳ (О» af a вҶ’ (mk-ufib (P a) (af a))))

  Car-is-emb : вҲҖ {@вҷӯ рқ“Ө} вҶ’ is-prop-map (UFib.Car {рқ“Ө})
  Car-is-emb X = is-propвҶҗequiv-to-prop
    (equivвҶҗqiso
      (mk-iso
       (О» a вҶ’ (mk-ufib X a , refl))
       ( (О» where (a , refl) вҶ’ a .UFib.has-is-afib)
       , ~refl
       , О» where (a , refl) вҶ’ refl)))
    (is-afib-is-prop {A = X})

  instance
    UFib-IdS : вҲҖ {@вҷӯ рқ“Ө} вҶ’ Identity-system (UFib рқ“Ө) рқ“Ө
    UFib-IdS {рқ“Ө} = IdSвҶҗEmbedding {f = UFib.Car} Car-is-emb (IdS-ua {рқ“Ө})
}
%```
}

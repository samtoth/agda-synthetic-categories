\date{2025-06-21}
\title{Closure properties of propsitions}
\taxon{Module}
\author{samueltoth}
\import{stt-macros}

%```agda
\agda{
module Foundations.PropClosure where

open import Foundations.Universes
open import Foundations.Functions
open import Foundations.FunctionInverses
open import Foundations.Singletons
open import Foundations.Sigma
open import Foundations.SigmaIdentity
open import Foundations.Identity
open import Foundations.DependentIdentity
open import Foundations.FunExt
open import Foundations.UniverseLifts
}
%```


\subtree[stt-006M]{
\taxon{Theorem}
\title{Prop is closed under #{\Pi} and #{\Sigma}}

\p{Prop is closed under #{\Sigma} and, under the assumption
of [function extensionality](stt-0024), #{\Pi}.}

%```agda
\agda{
Σ-is-prop : ∀ {𝓤 𝓥} {A : Type 𝓤} {B : A → Type 𝓥}
            → is-prop A
            → (∀ a → is-prop (B a))
            → is-prop (Σ A B)
Σ-is-prop {B = B} sa sb (a , x) (b , y) = Σ-path→ (sa a b  , sb b _ y)

Π-is-prop : ∀ {𝓤 𝓥} {A : Type 𝓤} {B : A → Type 𝓥}
            → FunExtω 𝓥
            → (∀ a → is-prop (B a))
            → is-prop (Π A B)
Π-is-prop FE pb x y = WithFunExtω.funext→ FE λ a → pb a (x a) (y a)

×-is-prop : ∀ {𝓤 𝓥} {A : Type 𝓤} {B : Type 𝓥}
            → is-prop A
            → is-prop B
            → is-prop (A × B)
×-is-prop aprop bprop = Σ-is-prop aprop (λ _ → bprop)

ULift-is-prop : ∀ {𝓤 𝓥} {A : Type 𝓤}
                → is-prop A
                → is-prop (ULift 𝓥 A)
ULift-is-prop prp (mk-lift a) (mk-lift b) = ap mk-lift (prp a b)
}
%```
}

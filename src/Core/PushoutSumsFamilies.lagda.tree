\subtree[stt-00EW]{
\taxon{Definition}
\title{Pushout sums}

\p{
Given a type family #{B : A \to \UU} and a dependent type family over #{B},
#{Y : (a : A) \to X(a) \to \UV}, then the \em{pushout sum family} #{\pushsum_B Y} is
the family

##{\pushsum_B Y \coloneqq ((a , x) : \Sigma_A X) \mapsto B(a) * Y(a, x).}
}

\p{
This is precisely the straightening of the [pushout sum of arrows](stt-00EX). I.e.,
given families as above, then their pushout sum is precisely the fibre family of the
cogap map #{\varphi}:

\quiver{
\begin{tikzcd}
	(\Sigma_{((a , b) : \Sigma_{(a : A)} B(a))} \Sigma_{(x : X(a))}{Y(a , x)}) && (\Sigma_{((a , b) : \Sigma_{(a : A)} B(a))} X(a))\\
	& \bullet \\
	(\Sigma_{(a : A)} \Sigma_{(x : X(a))}{Y(a, x)}) && (\Sigma_{(a : A)} X(a))
	\arrow[from=1-1, to=1-3]
	\arrow[from=1-1, to=3-1]
	\arrow[from=1-3, to=3-3]
	\arrow[from=3-1, to=3-3]
	\arrow[from=1-3, to=2-2]
	\arrow[from=3-1, to=2-2]
	\arrow[dashed, from=2-2, to=3-3, "{\varphi}"]
	\arrow[phantom, from=1-1, to=2-2, "\ulcorner" very near end]
\end{tikzcd}
}

This equivalence is formalised in [[stt-00F2]].
}

\agda{
module _ {рқ“Ө1 рқ“Ө2 рқ“Ө3 рқ“Ө4 : Level}
         (F@(A , B) : Fam рқ“Ө1 рқ“Ө2)
         (G@(X , Y) : DepFam рқ“Ө3 рқ“Ө4 F) where

  base-ОЈМӮб¶  : Type (рқ“Ө1 вҠ” рқ“Ө3)
  base-ОЈМӮб¶  = ОЈ A X

  fam-ОЈМӮб¶  : base-ОЈМӮб¶  вҶ’ Type (рқ“Ө2 вҠ” рқ“Ө4)
  fam-ОЈМӮб¶  (a , x) = B a * Y a x

  ОЈМӮб¶  : Fam (рқ“Ө1 вҠ” рқ“Ө3) (рқ“Ө2 вҠ” рқ“Ө4)
  ОЈМӮб¶  = (base-ОЈМӮб¶  , fam-ОЈМӮб¶ )

module _
  {рқ“Ө1 рқ“Ө2 рқ“Ө3 рқ“Ө4 рқ“Ө5 рқ“Ө6 : Level}
  (F@(A , B) : Fam рқ“Ө1 рқ“Ө2)
  (G@(X , Y) : DepFam рқ“Ө3 рқ“Ө4 F)
  (H@(U , V) : DepВІFam рқ“Ө5 рқ“Ө6 F G)
  where

  ОЈМӮбөҲб¶  : DepFam рқ“Ө5 рқ“Ө6 (ОЈМӮб¶  F G)
  ОЈМӮбөҲб¶ 
    = (О» (a , x) вҶ’ U a x)
    , (О» (a , x) вҶ’ V a x)
}
}

\subtree[stt-00EV]{
\taxon{Definition}
\title{Pushout products}

\p{
Given type families #{B : A \to \UU} and  #{Y : X \to \UV}, then the
\em{pushout product family} #{B \pushprod Y} is the family

##{B \pushprod Y \coloneqq ((a , x) : A \times X) \mapsto B(a) * Y(x).}
}

\p{
The pushout product is a special case of pushout sums where #{X} and #{Y} are not
dependent over #{A}.
}

\agda{
pushout-productб¶ 
  : {рқ“Ө1 рқ“Ө2 рқ“Ө3 рқ“Ө4 : Level}
  вҶ’ Fam рқ“Ө1 рқ“Ө2
  вҶ’ Fam рқ“Ө3 рқ“Ө4
  вҶ’ Fam (рқ“Ө1 вҠ” рқ“Ө3) (рқ“Ө2 вҠ” рқ“Ө4)
pushout-productб¶  F G = ОЈМӮб¶  F (FamвҶ’DepFam F G)

infixl 41 _в–Ўб¶ _
_в–Ўб¶ _ = pushout-productб¶ 
}
}

\subtree[stt-00EZ]{
\taxon{Lemma}
\title{#{\pushsum} preserves equivalences of dependent type families over a fixed base family}

\agda{
module _ {рқ“Ө1 рқ“Ө2 рқ“Ө3 рқ“Ө4 рқ“Ө5 рқ“Ө6 : Level}
         (F@(A , B) : Fam рқ“Ө1 рқ“Ө2)
         (G@(X , Y) : DepFam рқ“Ө3 рқ“Ө4 F)
         (H@(U , V) : DepFam рқ“Ө5 рқ“Ө6 F)
         (e : G вүғбөҲб¶ вҹҰ F вҹ§ H) where

  ОЈМӮб¶ -ap-вүғбөҲб¶ -base
    : base-ОЈМӮб¶  F G вүғ base-ОЈМӮб¶  F H
  ОЈМӮб¶ -ap-вүғбөҲб¶ -base
    = ОЈ-ap-вүғ (О» a вҶ’ e a .fst)

  ОЈМӮб¶ -ap-вүғбөҲб¶ -family
    : (fp : base-ОЈМӮб¶  F G)
    вҶ’ fam-ОЈМӮб¶  F G fp вүғ fam-ОЈМӮб¶  F H (ОЈМӮб¶ -ap-вүғбөҲб¶ -base ._вүғ_.fwd fp)
  ОЈМӮб¶ -ap-вүғбөҲб¶ -family (a , x)
    = *-вүғ idвүғ (e a .snd x)

  ОЈМӮб¶ -ap-вүғбөҲб¶  : ОЈМӮб¶  F G вүғб¶  ОЈМӮб¶  F H
  ОЈМӮб¶ -ap-вүғбөҲб¶  = ОЈМӮб¶ -ap-вүғбөҲб¶ -base , ОЈМӮб¶ -ap-вүғбөҲб¶ -family
}
}

\subtree[stt-00F1]{
\taxon{Lemma}
\title{Changing the family in the base of #{\pushsum^\rm{f}}}

\agda{
module _ {рқ“Ө1 рқ“Ө2 рқ“Ө3 рқ“Ө4 рқ“Ө5 : Level}
         {A : Type рқ“Ө1} {B : A вҶ’ Type рқ“Ө2} {C : A вҶ’ Type рқ“Ө3}
         (G : DepFam рқ“Ө4 рқ“Ө5 (A , B)) (e : (a : A) вҶ’ B a вүғ C a) where

  ОЈМӮб¶ -ap-base-fam-base
    : base-ОЈМӮб¶  (A , B) G вүғ base-ОЈМӮб¶  (A , C) G
  ОЈМӮб¶ -ap-base-fam-base = idвүғ

  ОЈМӮб¶ -ap-base-fam-family
    : (fp : base-ОЈМӮб¶  (A , B) G)
    вҶ’ fam-ОЈМӮб¶  (A , B) G fp
    вүғ fam-ОЈМӮб¶  (A , C) G (ОЈМӮб¶ -ap-base-fam-base ._вүғ_.fwd fp)
  ОЈМӮб¶ -ap-base-fam-family (a , x) = *-вүғ (e a) idвүғ

  ОЈМӮб¶ -ap-base-fam : ОЈМӮб¶  (A , B) G вүғб¶  ОЈМӮб¶  (A , C) G
  ОЈМӮб¶ -ap-base-fam = ОЈМӮб¶ -ap-base-fam-base , ОЈМӮб¶ -ap-base-fam-family
}
}

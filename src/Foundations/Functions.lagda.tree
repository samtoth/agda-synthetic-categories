\date{2025-02-20}
\title{Function types}
\taxon{Module}
\import{stt-macros}

\agda{
module Foundations.Functions where

open import Foundations.Universes
open import Foundations.Sigma
open import Foundations.Identity
open import Foundations.Singletons
}


\agda{
ќ† : вИА {рЭУ§ рЭУ•} (A : Type рЭУ§) (B : A вЖТ Type рЭУ•) вЖТ Type (рЭУ§ вКФ рЭУ•)
ќ† A B = (a : A) вЖТ B a

id : вИА {рЭУ§} {A : Type рЭУ§} вЖТ A вЖТ A
id a = a
{-# INLINE id #-}

infix 30 id:_
id:_ : вИА {рЭУ§} (A : Type рЭУ§) вЖТ A вЖТ A
id: A = id

ev : вИА {рЭУ§ рЭУ•} {A : Type рЭУ§} {B : A вЖТ Type рЭУ•} вЖТ (a : A) вЖТ ќ† A B вЖТ B a
ev a f = f a

evбµИ: : вИА {рЭУ§ рЭУ•} {A : Type рЭУ§} (B : A вЖТ Type рЭУ•) вЖТ (a : A) вЖТ ќ† A B вЖТ B a
evбµИ: B = ev

ev: : вИА {рЭУ§ рЭУ•} {A : Type рЭУ§} (B : Type рЭУ•) вЖТ A вЖТ (A вЖТ B) вЖТ B
ev: B = evбµИ: (ќї _ вЖТ B)

const : вИА {рЭУ§ рЭУ•} (A : Type рЭУ§) (B : Type рЭУ•) вЖТ A вЖТ B вЖТ A
const _ _ a _ = a

infixr 40 _вИШ_
_вИШ_
  : вИА {рЭУ§ рЭУ• рЭУ¶} {A : Type рЭУ§} {B : A вЖТ Type рЭУ•} {C : {a : A} вЖТ B a вЖТ Type рЭУ¶}
    вЖТ (f : {a : A} вЖТ (b : B a) вЖТ C b) вЖТ (g : (a : A) вЖТ B a) вЖТ (a : A) вЖТ C (g a)
f вИШ g = ќї a вЖТ f (g a)

happly
  : вИА {рЭУ§ рЭУ•} {A : Type рЭУ§} {B : A вЖТ Type рЭУ•} {f g : (a : A) вЖТ B a}
    вЖТ f пЉЭ g вЖТ (a : A) вЖТ f a пЉЭ g a
happly p a = ap (ev a) p

happlyбµҐ
  : вИА {рЭУ§ рЭУ•} {A : Type рЭУ§} {B : A вЖТ Type рЭУ•} {f g : {a : A} вЖТ B a}
    вЖТ Id ({a : A} вЖТ B a) f g вЖТ {a : A} вЖТ f {a} пЉЭ g {a}
happlyбµҐ p {a} = ap (ќї f вЖТ f {a}) p

happly-sym
  : вИА {рЭУ§ рЭУ•} {A : Type рЭУ§} {B : A вЖТ Type рЭУ•} {f g : (a : A) вЖТ B a}
    вЖТ (p : f пЉЭ g) вЖТ (a : A) вЖТ happly (sym p) пЉЭ sym вИШ happly p
happly-sym refl a = refl

happly-sym-at
  : вИА {рЭУ§ рЭУ•} {A : Type рЭУ§} {B : Type рЭУ•} {f g : A вЖТ B}
  вЖТ (p : f пЉЭ g)
  вЖТ (a : A)
  вЖТ happly (sym p) a пЉЭ sym (happly p a)
happly-sym-at p a = happly (happly-sym p a) a

ap-ev
  : вИА {рЭУ§ рЭУ•} {A : Type рЭУ§} {B : A вЖТ Type рЭУ•}
      {f g : (a : A) вЖТ B a}
    вЖТ (p : f пЉЭ g) вЖТ (a : A)
    вЖТ ap (ev a) p пЉЭ happly p a
ap-ev p a = refl
}

\subtree[stt-003Y]{
\taxon{Definition}
\title{Explicit function composition}
\p{It is convenient to define post and pre composition functions
   that take the non-fixed type argument explicitly}

\agda{
precomp
  : вИА {рЭУ§ рЭУ•} {A : Type рЭУ§} {B : Type рЭУ•}
      {рЭУ¶} (C : Type рЭУ¶) вЖТ (f : A вЖТ B)
    вЖТ (B вЖТ C) вЖТ (A вЖТ C)
precomp C f = _вИШ f

postcomp
  : вИА {рЭУ§ рЭУ•} {A : Type рЭУ§} {B : Type рЭУ•}
      {рЭУ¶} (C : Type рЭУ¶) вЖТ (f : A вЖТ B)
    вЖТ (C вЖТ A) вЖТ (C вЖТ B)
postcomp C f = f вИШ_

comp-pair
  : вИА {рЭУ§ рЭУ• рЭУ¶}
      {A : Type рЭУ§} {B : Type рЭУ•} {C : B вЖТ Type рЭУ¶}
    вЖТ (fg@(f , g) : (A вЖТ B) √Ч ((b : B) вЖТ C b))
    вЖТ (a : A) вЖТ (C (f a))
comp-pair (f , g) = g вИШ f
}
}

\subtree[stt-0071]{
\title{Functoriality of function composition}
\taxon{Theorem}
\date{2025-07-13}
\agda{
precomp-вИШ
  : вИА {рЭУ§ рЭУ•} {A : Type рЭУ§} {B : Type рЭУ•}
      {рЭУ¶} (X : Type рЭУ¶) (f : A вЖТ B)
      {рЭУЬ} {Q : Type рЭУЬ} (g : Q вЖТ A)
    вЖТ вИА h вЖТ precomp X (f вИШ g) h пЉЭ (precomp X g вИШ precomp X f) h
precomp-вИШ X f g h = refl

postcomp-вИШ
  : вИА {рЭУ§ рЭУ•} {A : Type рЭУ§} {B : Type рЭУ•}
      {рЭУ¶} (X : Type рЭУ¶) (f : A вЖТ B)
      {рЭУЬ} {Q : Type рЭУЬ} (g : Q вЖТ A)
    вЖТ вИА h вЖТ postcomp X (f вИШ g) h пЉЭ (postcomp X f вИШ postcomp X g) h
postcomp-вИШ X f g h = refl
}
}


\subtree[stt-004M]{
\taxon{Definition}
\title{Dependent function composition}
\p{We can define a dependent version of [function postcomposition](stt-003Y),
that takes a family of types.}

\agda{
precomp-ќ†
  : вИА {рЭУ§ рЭУ•} {A : Type рЭУ§} {B : Type рЭУ•}
      {рЭУ¶} (C : B вЖТ Type рЭУ¶) вЖТ (f : A вЖТ B)
    вЖТ (ќ† B C) вЖТ (ќ† A (C вИШ f))
precomp-ќ† C f = _вИШ f

precomp-ќ†-вИШ
  : вИА {рЭУ§ рЭУ• рЭУ¶} {A : Type рЭУ§} {B : Type рЭУ•} {C : Type рЭУ¶}
      {рЭУЬ} (X : C вЖТ Type рЭУЬ) (f : B вЖТ C) (g : A вЖТ B)
    вЖТ вИА h вЖТ precomp-ќ† X (f вИШ g) h пЉЭ (precomp-ќ† (X вИШ f) g вИШ precomp-ќ† X f) h
precomp-ќ†-вИШ X f g h = refl

postcomp-ќ†
  : вИА {рЭУШ рЭУ§ рЭУ•} {I : Type рЭУШ} {A : I вЖТ Type рЭУ§} {B : I вЖТ Type рЭУ•}
      (f : (i : I) вЖТ A i вЖТ B i)
    вЖТ ќ† I A вЖТ ќ† I B
postcomp-ќ† f g i = f i (g i)

postcomp-ќ†бµҐ
  : вИА {рЭУШ рЭУ§ рЭУ•} {I : Type рЭУШ} {A : I вЖТ Type рЭУ§} {B : I вЖТ Type рЭУ•}
      (f : {i : I} вЖТ A i вЖТ B i)
    вЖТ (вИА {i} вЖТ A i) вЖТ (вИА {i} вЖТ B i)
postcomp-ќ†бµҐ f x = f x
}
}

\subtree[stt-001F]{
\title{Functions are functors}

\agda{
ap-refl : вИА {рЭУ§ рЭУ•} {A : Type рЭУ§} {B : Type рЭУ•} {x : A} вЖТ (f : A вЖТ B) вЖТ ap f (refl {a = x}) пЉЭ refl
ap-refl f = refl

ap-sym : вИА {рЭУ§ рЭУ•} {A : Type рЭУ§} {B : Type рЭУ•}  (f : A вЖТ B) вЖТ {x y : A} вЖТ (p : x пЉЭ y) вЖТ ap f (sym p) пЉЭ sym (ap f p)
ap-sym f refl = refl

ap-вИЩ : вИА {рЭУ§ рЭУ•} {A : Type рЭУ§} {B : Type рЭУ•} {x y z : A} вЖТ (f : A вЖТ B) вЖТ (p : x пЉЭ y) вЖТ (q : y пЉЭ z) вЖТ ap f (p вИЩ q) пЉЭ ap f p вИЩ ap f q
ap-вИЩ f refl p = refl

happly-вИЩ
  : вИА {рЭУ§ рЭУ•} {A : Type рЭУ§} {B : Type рЭУ•} {f g h : A вЖТ B}
  вЖТ (p : f пЉЭ g)
  вЖТ (q : g пЉЭ h)
  вЖТ (a : A)
  вЖТ happly (p вИЩ q) a пЉЭ happly p a вИЩ happly q a
happly-вИЩ p q a = ap-вИЩ (ev a) p q

ap-вИЩвИЩ
  : вИА {рЭУ§ рЭУ•} {A : Type рЭУ§} {B : Type рЭУ•} {x y z w : A} вЖТ (f : A вЖТ B)
    вЖТ (p : x пЉЭ y) вЖТ (q : y пЉЭ z) вЖТ (r : z пЉЭ w)
    вЖТ ap f (p вИЩ q вИЩ r) пЉЭ ap f p вИЩ ap f q вИЩ ap f r
ap-вИЩвИЩ f refl q r = ap-вИЩ f q r

ap-const
  : вИА {рЭУ§ рЭУ•} {A : Type рЭУ§} {B : Type рЭУ•} {x y : A} {b}
    вЖТ (p : x пЉЭ y) вЖТ ap (ќї _ вЖТ b) p пЉЭ refl {_} {B}
ap-const refl = refl

tr-const
  : вИА {рЭУ§ рЭУ•} {A : Type рЭУ§} {B : Type рЭУ•} {x y : A}
    вЖТ (p : x пЉЭ y)
    вЖТ {b : B}
    вЖТ tr (ќї _ вЖТ B) p b пЉЭ b
tr-const refl = refl


ap-id : вИА {рЭУ§} {A : Type рЭУ§} {x y : A} (p : x пЉЭ y) вЖТ ap id p пЉЭ p
ap-id refl = refl

ap-вИШ : вИА {рЭУ§ рЭУ• рЭУ¶}  {A : Type рЭУ§} {B : Type рЭУ•} {C : Type рЭУ¶} {x y : A}
          (f : B вЖТ C) (g : A вЖТ B) (p : x пЉЭ y) вЖТ ap (f вИШ g) p пЉЭ ap f (ap g p)
ap-вИШ f g refl = refl

ap-вИШвИШ
  : вИА {рЭУ§ рЭУ• рЭУ¶ рЭУЬ}  {A : Type рЭУ§} {B : Type рЭУ•} {C : Type рЭУ¶} {D : Type рЭУЬ}
      {x y : A}
      (f : C вЖТ D) (g : B вЖТ C) (h : A вЖТ B) (p : x пЉЭ y)
    вЖТ ap (f вИШ g вИШ h) p пЉЭ ap f (ap g (ap h p))
ap-вИШвИШ f g h refl = refl

apвВВ
  : вИА {рЭУ§ рЭУ• рЭУ¶} {A : Type рЭУ§} {B : Type рЭУ•} {C : Type рЭУ¶} {x y : A} {u v : B}
    вЖТ (f : A вЖТ B вЖТ C) вЖТ x пЉЭ y вЖТ u пЉЭ v вЖТ f x u пЉЭ f y v
apвВВ f refl refl = refl

apвВГ
  : вИА {рЭУ§ рЭУ• рЭУ¶ рЭУЫ} {A : Type рЭУ§} {B : Type рЭУ•} {C : Type рЭУ¶} {D : Type рЭУЫ}
      {x y : A} {u v : B} {a b : C}
    вЖТ (f : A вЖТ B вЖТ C вЖТ D)
    вЖТ x пЉЭ y вЖТ u пЉЭ v вЖТ a пЉЭ b
    вЖТ f x u a пЉЭ f y v b
apвВГ f refl refl refl = refl

trвВВ : вИА {рЭУ§ рЭУ• рЭУ¶} {A : Type рЭУ§} {B : Type рЭУ•} (P : A вЖТ B вЖТ Type рЭУ¶)
    вЖТ вИА {a a' b b'} вЖТ a пЉЭ a' вЖТ b пЉЭ b' вЖТ P a b вЖТ P a' b'
trвВВ P p q = coe (apвВВ P p q)
{-# NOINLINE trвВВ #-}

trвВГ : вИА {рЭУ§ рЭУ• рЭУ¶ рЭУІ} {A : Type рЭУ§} {B : Type рЭУ•} {C : Type рЭУ¶} (P : A вЖТ B вЖТ C вЖТ Type рЭУІ)
    вЖТ вИА {a a' b b' c c'} вЖТ a пЉЭ a' вЖТ b пЉЭ b' вЖТ  c пЉЭ c' вЖТ P a b c вЖТ P a' b' c'
trвВГ P p q r = coe (apвВГ P p q r)
{-# NOINLINE trвВГ #-}

trвИШ
  : вИА {рЭУ§ рЭУ• рЭУ¶}  {A : Type рЭУ§} (P : A вЖТ Type рЭУ•)
      {C : Type рЭУ¶} (f : C вЖТ A)
      {x y} (p : x пЉЭ y) {b : P (f x)}
    вЖТ tr (P вИШ f) p b пЉЭ tr P (ap f p) b
trвИШ P f refl = refl

ap-diag-ev
  : вИА {рЭУ§ рЭУ• рЭУ¶}
    {A : Type рЭУ§} {B : Type рЭУ•} {C : Type рЭУ¶}
    (F : A вЖТ B вЖТ C)
    (e : A вЖТ B)
    {x y : A}
  вЖТ (p : x пЉЭ y)
  вЖТ ap (ќї z вЖТ F z (e z)) p пЉЭ happly (ap F p) (e x) вИЩ ap (F y) (ap e p)
ap-diag-ev F e refl = refl
}
}

\subtree[stt-000M]{
\taxon{Definition}
\title{Fibres}

\p{Given a function #{f : A \to B}, we define the fibre of #{f} at #{b : B}, notated #{\fibre{f}{a}} to be the type
#{\Sigma_{a : A}{f(a) = b}}. }

\p{Note that this is subtly different to the preimage, as we can show that #{\Sigma_{(b : B)} \fibre{f}{b}} is equivalent to #{A} itself.}

\agda{
fibre : вИА {рЭУ§ рЭУ•} {A : Type рЭУ§} {B : Type рЭУ•} (f : A вЖТ B) вЖТ B вЖТ Type (рЭУ§ вКФ рЭУ•)
fibre f b = ќ£ _ ќї a вЖТ f a пЉЭ b

fibre'
  : вИА {рЭУ§ рЭУ•} {A : Type рЭУ§} {B : Type рЭУ•}
    вЖТ (A вЖТ B) вЖТ B вЖТ Type (рЭУ§ вКФ рЭУ•)
fibre' f b = ќ£ _ ќї a вЖТ b пЉЭ f a

total-fibre : вИА {рЭУ§ рЭУ•} {A : Type рЭУ§} {B : Type рЭУ•} (f : A вЖТ B) вЖТ Type (рЭУ§ вКФ рЭУ•)
total-fibre f = ќ£ _ (fibre f)

fibre-fam
  : вИА {рЭУ§ рЭУ•}
      {A : Type рЭУ§}
      {B : Type рЭУ•}
      (f : A вЖТ B)
    вЖТ ќ£ (Type рЭУ•) (ќї X вЖТ X вЖТ Type (рЭУ§ вКФ рЭУ•))
fibre-fam {B = B} f = B , fibre f

fibre-depfam
  : вИА {рЭУ§ рЭУ• рЭУ¶}
      {B : Type рЭУ§}
      {X : B вЖТ Type рЭУ•}
      {Y : B вЖТ Type рЭУ¶}
      (g : (b : B) вЖТ X b вЖТ Y b)
    вЖТ ќ£ (B вЖТ Type рЭУ¶) (ќї Y' вЖТ (b : B) вЖТ Y' b вЖТ Type (рЭУ• вКФ рЭУ¶))
fibre-depfam {Y = Y} g = Y , ќї b вЖТ fibre (g b)

fibre-dep¬≤fam
  : вИА {рЭУ§ рЭУ• рЭУ¶ рЭУЬ}
      {B : Type рЭУ§}
      {Y : B вЖТ Type рЭУ•}
      {U : (b : B) вЖТ Y b вЖТ Type рЭУ¶}
      {V : (b : B) вЖТ Y b вЖТ Type рЭУЬ}
      (h : (b : B) (y : Y b) вЖТ U b y вЖТ V b y)
    вЖТ ќ£ ((b : B) вЖТ Y b вЖТ Type рЭУЬ)
        (ќї V' вЖТ (b : B) (y : Y b) вЖТ V' b y вЖТ Type (рЭУ¶ вКФ рЭУЬ))
fibre-dep¬≤fam {V = V} h = (V , (ќї b y вЖТ fibre (h b y)))
}
}

\p{The fibre type gives us a useful tool for talking about properties of maps. Generally if we have a property of types for example being #{n}-connected, we reuse the same terminology on maps to mean all fibres of the map have the corresponding property.}


\subtree[stt-001G]{
\taxon{Definition}
\title{Propositional maps}

\p{We call a map propositional if the fibres are all sub-singletons. We will learn later that this is equivalent to the property of a map being an embedding.
This notion is a generalisation of injective set functions, in fact if we - for a moment - imagine fibre to mean preimage, then a function of sets is injective if each preimage is either empty or has a unique inhabitant.}

\agda{
is-prop-map : вИА {рЭУ§ рЭУ•} {A : Type рЭУ§} {B : Type рЭУ•} (f : A вЖТ B) вЖТ Type (рЭУ§ вКФ рЭУ•)
is-prop-map f = вИА b вЖТ is-prop (fibre f b)
}
}


\subtree[stt-001H]{
\taxon{Definition}
\title{Contractible maps}

\p{A map is said to be contractible if each of its fibres is a singleton (is contractible). We will see later that this is one of many notions of an equivalence of maps.}

\agda{
has-singleton-fibres : вИА {рЭУ§ рЭУ•} {A : Type рЭУ§} {B : Type рЭУ•} (f : A вЖТ B) вЖТ Type (рЭУ§ вКФ рЭУ•)
has-singleton-fibres f = вИА b вЖТ is-singleton (fibre f b)
}
}


\subtree[stt-001I]{
\taxon{Theorem}
\title{Contractible maps are propositional maps}

\agda{
is-prop-mapвЖРhas-singleton-fibres
  : вИА {рЭУ§ рЭУ•} {A : Type рЭУ§} {B : Type рЭУ•} {f : A вЖТ B}
    вЖТ has-singleton-fibres f вЖТ is-prop-map f
is-prop-mapвЖРhas-singleton-fibres ctr b = is-propвЖРis-single (ctr b)
}
}

\subtree[stt-007O]{
\title{Logical equivalence}
\taxon{Definition}

\p{Given types #{P} and #{Q}, we say they are logically
equivalent when there are functions #{P \to Q} and #{Q \to P}.
We write #{P \iff Q} for the type of pairs #{(f : P \to Q,g : Q \to P)}.}

\remark{
Logical equivalence is also known as bi-implication as well as just equivalence.
We avoid bi-implication, but use equivalence when it is understood that the types
involved are [propositions](stt-0009).
}

\agda{
infixl 29 _вИЩвЗФ_

_вЗФ_ : вИА {рЭУ§ рЭУ•} вЖТ Type рЭУ§ вЖТ Type рЭУ• вЖТ Type (рЭУ§ вКФ рЭУ•)
P вЗФ Q = (P вЖТ Q) √Ч (Q вЖТ P)

_вИЩвЗФ_
  : вИА {рЭУ§ рЭУ• рЭУ¶} {A : Type рЭУ§} {B : Type рЭУ•} {C : Type рЭУ¶}
    вЖТ A вЗФ B вЖТ B вЗФ C вЖТ A вЗФ C
p вИЩвЗФ q = (q .fst вИШ p .fst , p .snd вИШ q .snd)

_вЗФвБї¬є : вИА {рЭУ§ рЭУ•} {A : Type рЭУ§} {B : Type рЭУ•} вЖТ A вЗФ B вЖТ B вЗФ A
(f , g) вЗФвБї¬є = (g , f)
}
}

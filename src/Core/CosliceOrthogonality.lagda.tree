\subtree[stt-00DM]{
\title{Orthogonality with respect to coslice maps}
\taxon{Definition}

\p{Given a map in the coslice #{f : p \to_X q}, and some element #{x} in the
coslice under #{X}, we say that #{f} is orthogonal to #{x} (or #{f \perp x})
when coslice precomposition by #{f} at #{x} is an equivalence.}

%```agda
\agda{
are-orthogonal-coslice
  : ‚ąÄ {ūĚďß ūĚď§ ūĚď• ūĚď¶} {X : Type ūĚďß} {A : Type ūĚď§} {B : Type ūĚď•} {p : X ‚Üí A} {q : X ‚Üí B}
      {Y : Type ūĚď¶}
    ‚Üí (F : Coslice-map p q) ‚Üí (X ‚Üí Y) ‚Üí Type (ūĚďß ‚äĒ ūĚď§ ‚äĒ ūĚď• ‚äĒ ūĚď¶)
are-orthogonal-coslice F k = is-equiv (Coslice-map-precompose k F)

instance
  Orthogonal-coslice-notation
    : ‚ąÄ {ūĚďß ūĚď§ ūĚď• ūĚď¶} {X : Type ūĚďß} {A : Type ūĚď§} {B : Type ūĚď•} {p : X ‚Üí A} {q : X ‚Üí B}
        {Y : Type ūĚď¶}
      ‚Üí Orthogonality (Coslice-map p q) (X ‚Üí Y)
  Orthogonal-coslice-notation {ūĚďß} {ūĚď§} {ūĚď•} {ūĚď¶}.Orthogonality.ūĚď¶
    = ūĚďß ‚äĒ ūĚď§ ‚äĒ ūĚď• ‚äĒ ūĚď¶
  Orthogonal-coslice-notation .Orthogonality._‚ä•_ = are-orthogonal-coslice
}
%```
}


\subtree[stt-00DC]{
\title{Coslice orthogonality is orthogonaliy of the underlying map}
\taxon{Lemma}

\p{Given a map #{f} in the [coslice](stt-0062) #{p \to_X q}, #{f} is orthogonal
to every map #{X \to Y} iff #{f} is left orthogonal to #{Y}.
}

%```agda
\agda{
coslice-orthogonality
  : ‚ąÄ {ūĚď§ ūĚď• ūĚď¶ ūĚďú} {A : Type ūĚď§} {B : Type ūĚď•} {X : Type ūĚď¶} {Y : Type ūĚďú}
      {p : X ‚Üí A} {q : X ‚Üí B} (f : Coslice-map p q)
    ‚Üí (f .fst ‚ä• Y)
    ‚áĒ (‚ąÄ (x : X ‚Üí Y) ‚Üí f ‚ä• x)
coslice-orthogonality {A = A}{B}{X}{Y}{p}{q} (f , H)
  = tr
      (őĽ (h : f ‚ąė p ~ q)
         ‚Üí orthogonal-type f Y
         ‚áĒ ((x : X ‚Üí Y) ‚Üí are-orthogonal-coslice (f , h) x))
      (funext-redex {p = H})
      (top‚áĒbot-is-equiv‚ÜźArrow-equiv (amap (funext‚Üí H)) eq
      ‚ąô‚áĒ fibrewise‚áĒtotal-is-equiv) where

  add-singleton : ‚ąÄ {ūĚď†} {Q : Type ūĚď†} (p : X ‚Üí Q) (g : Q ‚Üí Y)
                  ‚Üí ő£[ x ‚ą∂ (X ‚Üí Y) ] ő£[ f' ‚ą∂ (Q ‚Üí Y) ] (f' ‚ąė p ~ x)
  add-singleton f g = (g ‚ąė f , g , ~refl)

  add-singleton-eq : ‚ąÄ {ūĚď†} {Q : Type ūĚď†} (p : X ‚Üí Q)
                     ‚Üí quasi-iso (add-singleton p)
  add-singleton-eq p .fst (a , f , H) = f
  add-singleton-eq p .snd .fst x = refl
  add-singleton-eq p .snd .snd (a , f , H)
    = funext-rec
        (őĽ H ‚Üí ((f ‚ąė p) , (f , ~refl)) ÔľĚ (a , (f , H)))
        (őĽ where refl ‚Üí refl)
        H

  amap : ‚ąÄ (H : f ‚ąė p ÔľĚ q)
         ‚Üí Arrow-map (precomp Y f)
                     (total-map (őĽ a ‚Üí Coslice-map-precompose a (f , happly H)))
  amap H .Arrow-map.top = add-singleton q
  amap H .Arrow-map.bot =  add-singleton p
  amap refl .Arrow-map.comm x = refl

  eq : is-Arrow-equiv (amap (funext‚Üí H))
  eq .fst = is-equiv‚Üźqiso (add-singleton-eq q)
  eq .snd = is-equiv‚Üźqiso (add-singleton-eq p)
}
%```
}

\subtree[stt-00DN]{
\taxon{Lemma}

\p{Given a diagram as follows:}

\quiver{
\begin{tikzcd}
	A \\
	&& B && C \\
	{A'}
	\arrow["F"', from=1-1, to=3-1]
	\arrow["f"', from=2-3, to=1-1]
	\arrow["g", from=2-3, to=2-5]
	\arrow["{f'}", from=2-3, to=3-1]
\end{tikzcd}
}

\p{We can take the pushout of the top span, and the bottom span, and by
functoriality, the coslice map #{F} gives us a map of pushouts. We give an
equivalence of arrows between precomposition of the pushout map and
the map between the pullbacks associated to the corresponding precomposition
cospans. As an easy corrolary we get the result that #{F} is orthogonal
to #{qg} for all maps #{q : C \to Q} iff the pushout map induced by
#{F} is orthogonal to #{Q}.}

%```agda
\agda{

Pushout-map-left
  : ‚ąÄ {ūĚď§ ūĚď§' ūĚď• ūĚď¶} {A : Type ūĚď§} {A' : Type ūĚď§'} {B : Type ūĚď•} {C : Type ūĚď¶}
      (f : B ‚Üí A) (f' : B ‚Üí A') (g : B ‚Üí C) ‚Üí (F : Coslice-map f f')
    ‚Üí Pushout f g ‚Üí Pushout f' g
Pushout-map-left f f' g F = Pushout‚āĀ (mk-span-map (F .fst) id id (F .snd) ~refl)

precomp-pullback
  : ‚ąÄ {ūĚď§ ūĚď§' ūĚď• ūĚď¶ ūĚď†} {A : Type ūĚď§} {A' : Type ūĚď§'} {B : Type ūĚď•} {C : Type ūĚď¶}
      (f : B ‚Üí A) (f' : B ‚Üí A') (g : B ‚Üí C) ‚Üí (F : Coslice-map f f')
    ‚Üí (Q : Type ūĚď†)
    ‚Üí Cospan-map (mk-cospan _ (precomp Q g) (precomp Q f'))
                 (mk-cospan _ (precomp Q g) (precomp Q f))
precomp-pullback f f' g F Q .Cospan-map.h‚āĀ = id
precomp-pullback f f' g F Q .Cospan-map.h‚āā = id
precomp-pullback f f' g F Q .Cospan-map.h‚āÉ = precomp Q (F .fst)
precomp-pullback f f' g F Q .Cospan-map.H = ~refl
precomp-pullback f f' g F Q .Cospan-map.K a
  = funext‚Üí (postwhisker a _ _ (sym ‚ąė F .snd))

pushout-arrow-UP
    : ‚ąÄ {ūĚď§ ūĚď§' ūĚď• ūĚď¶ ūĚď†} {A : Type ūĚď§} {A' : Type ūĚď§'} {B : Type ūĚď•} {C : Type ūĚď¶}
        (f : B ‚Üí A) (f' : B ‚Üí A') (g : B ‚Üí C) ‚Üí (F : Coslice-map f f')
        {Q : Type ūĚď†}
      ‚Üí Arrow-map
         (precomp Q (Pushout-map-left f f' g F))
         (Pullback‚āĀ (precomp-pullback f f' g F Q))
pushout-arrow-UP f f' g F .Arrow-map.top
  = precomp-cocone‚ČÉpb ._‚ČÉ_.fwd ‚ąė cocone-map _ pushout
pushout-arrow-UP f f' g F .Arrow-map.bot
  = precomp-cocone‚ČÉpb ._‚ČÉ_.fwd ‚ąė cocone-map _ pushout
pushout-arrow-UP f f' g F .Arrow-map.comm a = pullback-path‚Üí
  ( refl
  , refl
  , sym (‚ąô-reflr _
    ‚ąô ap (funext‚Üí)
      (funext‚Üí (őĽ b ‚Üí ap sym (ap-‚ąė a _ (glue b)
                             ‚ąô ap (ap a) (pushout-rec-apő≤ b
                             ‚ąô ap (ap őĻ‚āĀ (F .snd b) ‚ąô_) (‚ąô-reflr _)))))
      ‚ąô sym (ap (_‚ąô funext‚Üí (ap (a ‚ąė őĻ‚āĀ) ‚ąė sym ‚ąė F .snd))
                (ap-id (funext‚Üí (sym ‚ąė ap a ‚ąė glue)))
      ‚ąô sym (funext-‚ąô (sym ‚ąė ap a ‚ąė glue) (ap (a ‚ąė őĻ‚āĀ) ‚ąė sym ‚ąė F .snd))
      ‚ąô ap funext‚Üí (funext‚Üí (őĽ b
          ‚Üí ap (sym (ap a (glue b)) ‚ąô_)
               (ap-sym (a ‚ąė őĻ‚āĀ) (F .snd b) ‚ąô ap sym (ap-‚ąė a őĻ‚āĀ (F .snd b)))
               ‚ąô sym (‚ąô-symsym (ap a (ap őĻ‚āĀ (F .snd b))) (ap a (glue b)))
               ‚ąô ap sym (sym (ap-‚ąô a (ap őĻ‚āĀ (F .snd b)) (glue b))))))))

pushout-arrow-UP-is-equiv
    : ‚ąÄ {ūĚď§ ūĚď§' ūĚď• ūĚď¶ ūĚď†} {A : Type ūĚď§} {A' : Type ūĚď§'} {B : Type ūĚď•} {C : Type ūĚď¶}
        (f : B ‚Üí A) (f' : B ‚Üí A') (g : B ‚Üí C) ‚Üí (F : Coslice-map f f')
        {Q : Type ūĚď†}
      ‚Üí is-Arrow-equiv (pushout-arrow-UP f f' g F {Q})
pushout-arrow-UP-is-equiv f f' g F .fst
  = is-equiv-‚ąė (precomp-cocone‚ČÉpb ._‚ČÉ_.has-is-eqv) Pushout-is-pushoutŌČ
pushout-arrow-UP-is-equiv f f' g F .snd
  = is-equiv-‚ąė (precomp-cocone‚ČÉpb ._‚ČÉ_.has-is-eqv) Pushout-is-pushoutŌČ

opaque
  left-orthogonal-type-pushout‚āĀ
    : ‚ąÄ {ūĚď§ ūĚď§' ūĚď• ūĚď¶ ūĚď†} {A : Type ūĚď§} {A' : Type ūĚď§'} {B : Type ūĚď•} {C : Type ūĚď¶}
        {f : B ‚Üí A} {f' : B ‚Üí A'} {g : B ‚Üí C} ‚Üí (F : Coslice-map f f')
        {Q : Type ūĚď†}
      ‚Üí ((Pushout‚āĀ {S = mk-span _ f g}
          (mk-span-map (F .fst) id id (F .snd) ~refl)) ‚ä• Q)
      ‚áĒ (‚ąÄ (q : C ‚Üí Q) ‚Üí F ‚ä• (q ‚ąė g))
  left-orthogonal-type-pushout‚āĀ {A = A}{A'}{C = C} {f} {f'} {g} F {Q}
    =  top‚áĒbot-is-equiv‚ÜźArrow-equiv
        (pushout-arrow-UP f f' g F)
        (pushout-arrow-UP-is-equiv f f' g F)
        ‚ąô‚áĒ fibrewise‚áĒtotal-is-equiv
        ‚ąô‚áĒ (postcomp-ő†-‚áĒ
             őĽ q ‚Üí top‚áĒbot-is-equiv‚ÜźArrow-equiv
                    (hom q)
                    ( is-total-equiv‚Üźis-fibrewise-equiv
                        (őĽ a ‚Üí is-equiv-‚ąė sym-is-equiv (is-equiv‚ĀĽ¬Ļ global-funext))
                    , is-total-equiv‚Üźis-fibrewise-equiv
                        (őĽ a ‚Üí is-equiv-‚ąė sym-is-equiv (is-equiv‚ĀĽ¬Ļ global-funext)))
                    ‚áĒ‚ĀĽ¬Ļ)   where

    hom : ‚ąÄ (q : C ‚Üí Q)
          ‚Üí Arrow-map {A = Coslice-map f' (q ‚ąė g)}
                      {B = Coslice-map f (q ‚ąė g)}
                      (Coslice-map-precompose (q ‚ąė g) F)
                      {C = ő£[ x ‚ą∂ (A' ‚Üí Q) ] (precomp Q g q ÔľĚ precomp Q f' x)}
                      {D = ő£[ x ‚ą∂ (A ‚Üí Q) ] (precomp Q g q ÔľĚ precomp Q f x)}
                      (őĽ G ‚Üí
                          precomp Q (F .fst) (G .fst)
                        , ap id (G .snd) ‚ąô funext‚Üí (ap (G .fst) ‚ąė sym ‚ąė F .snd))
    hom q .Arrow-map.top = total-map (őĽ a ‚Üí sym ‚ąė funext‚Üí)
    hom q .Arrow-map.bot = total-map (őĽ a ‚Üí sym ‚ąė funext‚Üí)
    hom q .Arrow-map.comm (x , p)
      = ő£-path‚Üí (refl , sym (ap‚āā _‚ąô_
                              (ap-id (sym (funext‚Üí p)))
                              (ap funext‚Üí (funext‚Üí őĽ b ‚Üí ap-sym x (F .snd b))
                                ‚ąô funext-sym _)
                       ‚ąô sym (‚ąô-symsym _ (funext‚Üí p))
                       ‚ąô ap sym (sym (funext-‚ąô _ _))))
}
%```
}

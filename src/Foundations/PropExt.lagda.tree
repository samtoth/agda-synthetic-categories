\subtree[stt-007P]{
\title{Weak propositional extensionality}
\taxon{Definition}

\p{Weak propositional extensionality says that for propositions
#{P} and #{Q}, the projection from #{P \simeq Q} to #{P \iff Q}
is an equivalence. Functional extensionality implies weak-PropExt}

\agda{
logical‚Üźequiv : ‚ąÄ {ūĚď§ ūĚď•} {A : Type ūĚď§} {B : Type ūĚď•} ‚Üí A ‚ČÉ B ‚Üí A ‚áĒ B
logical‚Üźequiv e = (fwd , bwd) where open _‚ČÉ_ e

is-equiv‚Üźinverse
  : ‚ąÄ {ūĚď§ ūĚď•} {A : Type ūĚď§} {B : Type ūĚď•}
    ‚Üí is-prop A ‚Üí is-prop B ‚Üí {f : A ‚Üí B}
    ‚Üí (g : B ‚Üí A) ‚Üí is-equiv f
is-equiv‚Üźinverse aprp bprp g
  = is-equiv‚Üźqinv (g , (őĽ a ‚Üí aprp _ _) , (őĽ _ ‚Üí bprp _ _))

equiv‚Üźlogical
  : ‚ąÄ {ūĚď§ ūĚď•} {A : Type ūĚď§} {B : Type ūĚď•}
    ‚Üí is-prop A ‚Üí is-prop B
    ‚Üí A ‚áĒ B ‚Üí A ‚ČÉ B
equiv‚Üźlogical aprp bprp (f , g) = mk‚ČÉ f (is-equiv‚Üźinverse aprp bprp g)

weak-PropExt : (ūĚď§ ūĚď• : Level) ‚Üí Type (lsuc (ūĚď§ ‚äĒ ūĚď•))
weak-PropExt ūĚď§ ūĚď• = ‚ąÄ {A : Type ūĚď§} {B : Type ūĚď•}
                       (ap : is-prop A) (bp : is-prop B)
                     ‚Üí is-equiv (logical‚Üźequiv {A = A} {B})

weak-PropExt‚ÜźFunExt : ‚ąÄ {ūĚď§ ūĚď•} ‚Üí FunExt-global ‚Üí weak-PropExt ūĚď§ ūĚď•
weak-PropExt‚ÜźFunExt FE aprp bprp = is-equiv‚Üźqinv lem where
  lem : quasi-inv logical‚Üźequiv
  lem .fst = equiv‚Üźlogical aprp bprp
  lem .snd .snd (f , g) = refl
  lem .snd .fst e = ‚ČÉ-path‚Üí FE refl
}
}

\subtree[stt-007Q]{
\title{Propositional extensionality}
\taxon{Definition}

\p{By path induction, we can define a function
#{P = Q \to P \iff Q}. Propositional extensionality
says that this map is an equivalence when #{P} and #{Q}
are propositions.}

\p{Since logical equivalences are equivalent to equivalences
(under the assumption of funext), propositional extensionality
can be seen as #{(-1)}-univalence, where the #{-1} refers to
truncation levels. As such full univalence implies prop-ext.}

\todo{Get rid of assumption of global funext here. We have
formalised univalence implies funext for a particular universe,
but certain modules rely needlessly on global funext, which doesn't
follow from univalence. I would like to do a big refactor of how
axioms work which should address this.}

\agda{
logical‚ÜźId
  : ‚ąÄ {ūĚď§} {P Q : Type ūĚď§}
    ‚Üí P ÔľĚ Q ‚Üí P ‚áĒ Q
logical‚ÜźId refl = (id , id)

PropExt : (ūĚď§ : Level) ‚Üí Type (lsuc ūĚď§)
PropExt ūĚď§ = ‚ąÄ {P Q : Type ūĚď§}
             ‚Üí is-prop P ‚Üí is-prop Q
             ‚Üí is-equiv (logical‚ÜźId {ūĚď§} {P} {Q})

PropExt‚ÜźUnivalence : ‚ąÄ {ūĚď§} ‚Üí FunExt-global ‚Üí is-univalent ūĚď§ ‚Üí PropExt ūĚď§
PropExt‚ÜźUnivalence {ūĚď§} FE uu pp qq = is-equiv-~‚ąė
                                       (őĽ where refl ‚Üí refl)
                                       (weak-PropExt‚ÜźFunExt FE pp qq)
                                       uu
}
}

\subtree[stt-007R]{
\title{Logical equivalence is an identity system for propositions}
\taxon{Corollary}

\agda{
Prop : (ūĚď§ : Level) ‚Üí Type (lsuc ūĚď§)
Prop ūĚď§ = ő£[ A ‚ą∂ Type ūĚď§ ] is-prop A

module PropExt (FE : FunExt-global) (UA : Univalence) where
  Prop-IdS : ‚ąÄ {ūĚď§} ‚Üí Identity-system (Prop ūĚď§) ūĚď§
  Prop-IdS .Identity-system.IdS (P , _) (Q , _) = P ‚áĒ Q
  Prop-IdS .Identity-system.IdS‚ÜźId refl = (id , id)
  Prop-IdS {ūĚď§} .Identity-system.IdS‚ÜźId-is-equiv (A , ap)
    = fundamental-Id _ lem _ where
    lem : is-singleton (ő£ (ő£ (Type ūĚď§) is-prop) ((A ‚áĒ_) ‚ąė fst))
    lem = is-single‚Üźequiv-to-single
             ((  ő£-assoc
              ‚ąô‚ČÉ ő£-ap-‚ČÉ (őĽ
                B ‚Üí ő£-ap-‚ČÉ őĽ
                 bp ‚Üí mk‚ČÉ _ (PropExt‚ÜźUnivalence FE UA ap bp) e‚ĀĽ¬Ļ)
              ‚ąô‚ČÉ ő£-ap-‚ČÉ (őĽ a ‚Üí √ó-swap)
              ‚ąô‚ČÉ  ő£-ÔľĚsingl'
             ) e‚ĀĽ¬Ļ)
             (mk-singl ap (is-prop-is-prop FE ap))
}
}


\subtree[stt-00N6]{
\date{2026-04-24}
\author{fredrikbakke}
\title{Booleans as propositions}
\taxon{Definition}

\p{
We define the canonical interpretation of booleans into propositions, sending
#{\true} to the unit proposition and #{\false} to the empty proposition.
}

\agda{
Prop‚ÜźBool : Bool ‚Üí Prop lzero
Prop‚ÜźBool true = (ūĚüô , is-prop‚Üźis-single ūĚüô-is-singleton)
Prop‚ÜźBool false = (‚ąÖ , őĽ ())
}
}

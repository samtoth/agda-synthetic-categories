\subtree[fre-LMAB]{
\taxon{Definition}
\title{Universal property of #{K}-connected maps}

\p{
Given a global subuniverse #{K} and a map #{f : A \to B}, then #{f} satisfies the
\em{universal property of #{K}-connected maps} if for every #{K}-valued family of
types #{U} over #{B}, the dependent precomposition map
#{\prod_{b : B} U(b) \to \prod_{a : A} U(f(a))} is an equivalence.
}

% ```agda
\agda{
up-gconnected-map : вИА {ќ± рЭУ§ рЭУ•} (K : gSubU ќ±)
                    вЖТ {A : Type рЭУ§} {B : Type рЭУ•}
                    вЖТ (A вЖТ B)
                    вЖТ TypeѕЙ
up-gconnected-map K f
  = вИА {рЭУЪ} {U : _ вЖТ Type рЭУЪ}
  вЖТ (вИА b вЖТ U b вИИ gSubU.S K)
  вЖТ is-equiv (precomp-ќ† U f)

gconnected-map-!-fibre
  : вИА {ќ± рЭУ§ рЭУ•} (K : gSubU ќ±)
      {A : Type рЭУ§} {B : Type рЭУ•}
      (f : A вЖТ B)
  вЖТ TypeѕЙ
gconnected-map-!-fibre K f
  = вИА b вЖТ up-gmodal-equiv K (!: fibre f b)

gconnected-fibres
  : вИА {ќ± рЭУ§ рЭУ•} (K : gSubU ќ±)
      {A : Type рЭУ§} {B : Type рЭУ•}
      (f : A вЖТ B)
  вЖТ TypeѕЙ
gconnected-fibres K f
  = вИА b {рЭУЪ} {U : Type рЭУЪ}
    вЖТ U вИИ gSubU.S K
    вЖТ is-equiv (const U (fibre f b))
}
%```
}


\subtree{
\date{2026-03-19}
\author{fredrikbakke}
\taxon{Definition}
\title{#{K}-Connected maps}

\p{
If #{K} is a reflective subuniverse, a map is \em{#{K}-connected} if all of its
fibres have contractible reflections.
}

\agda{
module _ {ќ±} (RS : gRSubU ќ±) where
  open gRSubU RS

  is-gconnected-map
    : вИА {рЭУ§ рЭУ•} {A : Type рЭУ§} {B : Type рЭУ•}
    вЖТ (A вЖТ B) вЖТ Type _
  is-gconnected-map {B = B} f = (b : B) вЖТ is-singleton (вЧЛ (fibre f b))

is-connected-map : вИА {рЭУ§ рЭУ• рЭУЬ} {A : Type рЭУ§} {B : Type рЭУ•}
                     {S : SubU (рЭУ§ вКФ рЭУ•) рЭУЬ}
                   вЖТ is-reflective S
                   вЖТ (A вЖТ B) вЖТ Type (рЭУ§ вКФ рЭУ•)
is-connected-map rfl f = вИА b вЖТ is-connected rfl (fibre f b)
}
%```
}

\subtree{
\date{2026-03-19}
\author{fredrikbakke}
\taxon{Lemma}
\title{Closure of #{K}-connected maps under composition}

% ```agda
\agda{
up-gconnected-map-вИШ
  : вИА {ќ± рЭУ§ рЭУ• рЭУ¶}
      (K : gSubU ќ±)
      {A : Type рЭУ§} {B : Type рЭУ•} {C : Type рЭУ¶}
      (f : A вЖТ B) (g : B вЖТ C)
  вЖТ up-gconnected-map K f
  вЖТ up-gconnected-map K g
  вЖТ up-gconnected-map K (g вИШ f)
up-gconnected-map-вИШ K f g fconn gconn UвИИK
  = is-equiv-вИШ (fconn (UвИИK вИШ g)) (gconn UвИИK)

up-gconnected-map-right-cancel
  : вИА {ќ± рЭУ§ рЭУ• рЭУ¶}
      (K : gSubU ќ±)
      {A : Type рЭУ§} {B : Type рЭУ•} {C : Type рЭУ¶}
      (f : A вЖТ B) (g : B вЖТ C)
  вЖТ up-gconnected-map K f
  вЖТ up-gconnected-map K (g вИШ f)
  вЖТ up-gconnected-map K g
up-gconnected-map-right-cancel K f g fconn gfconn UвИИK
  = 3-for-2 (fconn (UвИИK вИШ g)) (gfconn UвИИK)
}
%```
}

\subtree{
\date{2026-03-19}
\author{fredrikbakke}
\taxon{Theorem}
\title{Connected maps are left orthogonal to modal maps}

% ```agda
\agda{
up-gconnected-mapвЗФorthogonal-map
  : вИА {ќ± рЭУ§ рЭУ•} (K : gSubU ќ±)
      {A : Type рЭУ§} {B : Type рЭУ•}
      (f : A вЖТ B)
  вЖТ up-gconnected-map K f
  вЖТ {рЭУ¶ рЭУЫ : Level} {C : Type рЭУ¶} {D : Type рЭУЫ}
    (g : C вЖТ D)
  вЖТ is-gmodal-map K g
  вЖТ are-orthogonal f g
up-gconnected-mapвЗФorthogonal-map K f fconn g gвИИK
  = orthogonalвЖРprecomp-ќ† ќї h вЖТ fconn (ќї b вЖТ gвИИK (h b))

up-gconnected-mapвЖРorthogonal-map
  : вИА {ќ± рЭУ§ рЭУ•} (K : gSubU ќ±)
      {A : Type рЭУ§} {B : Type рЭУ•}
      (f : A вЖТ B)
    вЖТ (вИА {рЭУ¶ рЭУЫ} {C : Type рЭУ¶} {D : Type рЭУЫ}
        (g : C вЖТ D)
        вЖТ is-gmodal-map K g
        вЖТ are-orthogonal f g)
    вЖТ up-gconnected-map K f
up-gconnected-mapвЖРorthogonal-map K f orth {U = U} UвИИK
  = is-equivвЖРArrow-equivвБї¬є {F = eq .fst} (eq .snd)
      (precomp-ќ†вЖРorthogonal id (orth fst fstвИИK)) where

  fstвИИK : is-gmodal-map K (fst {B = U})
  fstвИИK b = gSubU.вИИSвЖРequiv K (fibre-straighten U b eвБї¬є) (UвИИK b)

  eq = precomp-ќ†-straighten-Arrow-equiv U f
}
%```
}

\subtree{
\date{2026-03-20}
\author{fredrikbakke}
\taxon{Proposition}
\title{Closure properties of #{K}-connected maps}

\p{
Connected maps are stable under homotopies, retracts of arrows, and cobase change.
}

% ```agda
\agda{
up-gconnected-map-homotopy
  : вИА {ќ± рЭУ§ рЭУ•}
      (K : gSubU ќ±)
      {A : Type рЭУ§} {B : Type рЭУ•}
      {f g : A вЖТ B}
    вЖТ f ~ g
    вЖТ up-gconnected-map K f
    вЖТ up-gconnected-map K g
up-gconnected-map-homotopy K {f = f} {g = g} H fconn
  = up-gconnected-mapвЖРorthogonal-map K g ќї h hmodal
      вЖТ left-orthogonal-homotopy h H
          (up-gconnected-mapвЗФorthogonal-map K f fconn h hmodal)

up-gconnected-map-вИШ~
  : вИА {ќ± рЭУ§ рЭУ• рЭУ¶}
      (K : gSubU ќ±)
      {A : Type рЭУ§} {B : Type рЭУ•} {C : Type рЭУ¶}
      {h : A вЖТ C}
      (f : A вЖТ B) (g : B вЖТ C)
    вЖТ h ~ g вИШ f
    вЖТ up-gconnected-map K f
    вЖТ up-gconnected-map K g
    вЖТ up-gconnected-map K h
up-gconnected-map-вИШ~ K f g H fconn gconn
  = up-gconnected-map-homotopy K (H ~вБї¬є)
      (up-gconnected-map-вИШ K f g fconn gconn)

up-gconnected-map-right-cancel~
  : вИА {ќ± рЭУ§ рЭУ• рЭУ¶}
      (K : gSubU ќ±)
      {A : Type рЭУ§} {B : Type рЭУ•} {C : Type рЭУ¶}
      {h : A вЖТ C}
      (f : A вЖТ B) (g : B вЖТ C)
    вЖТ h ~ g вИШ f
    вЖТ up-gconnected-map K f
    вЖТ up-gconnected-map K h
    вЖТ up-gconnected-map K g
up-gconnected-map-right-cancel~ K f g H fconn hconn
  = up-gconnected-map-right-cancel K f g fconn
      (up-gconnected-map-homotopy K H hconn)

up-gconnected-mapвЖРretraction-arrow-map
  : вИА {ќ± рЭУ§ рЭУ• рЭУ¶ рЭУЫ}
      (K : gSubU ќ±)
      {A : Type рЭУ§} {B : Type рЭУ•} {f : A вЖТ B}
      {X : Type рЭУ¶} {Y : Type рЭУЫ} {g : X вЖТ Y}
      (F : Arrow-map f g)
    вЖТ retraction-arrow-map F
    вЖТ up-gconnected-map K g
    вЖТ up-gconnected-map K f
up-gconnected-mapвЖРretraction-arrow-map K {f = f} {g = g} F R gconn
  = up-gconnected-mapвЖРorthogonal-map K f ќї h hmodal
      вЖТ left-orthogonal-retraction f g F R h
          (up-gconnected-mapвЗФorthogonal-map K g gconn h hmodal)

up-gconnected-mapвЖРcocartesian
  : вИА {ќ± рЭУ§ рЭУ• рЭУ¶ рЭУЫ}
      (K : gSubU ќ±)
      {A : Type рЭУ§} {B : Type рЭУ•} {f : A вЖТ B}
      {X : Type рЭУ¶} {Y : Type рЭУЫ} {g : X вЖТ Y}
      (F : Arrow-map f g)
    вЖТ is-cocartesianѕЙ F
    вЖТ up-gconnected-map K f
    вЖТ up-gconnected-map K g
up-gconnected-mapвЖРcocartesian K {f = f} {g = g} F cocart fconn
  = up-gconnected-mapвЖРorthogonal-map K g ќї h hmodal
      вЖТ left-orthogonal-pushout F cocart h
          (up-gconnected-mapвЗФorthogonal-map K f fconn h hmodal)

up-gconnected-map-ќєвВВ
  : вИА {ќ± рЭУ§ рЭУ• рЭУ¶}
      (K : gSubU ќ±)
      {A : Type рЭУ§} {B : Type рЭУ•} {C : Type рЭУ¶}
      (f : A вЖТ B) (g : A вЖТ C)
    вЖТ up-gconnected-map K f
    вЖТ up-gconnected-map K (ќєвВВ {f = f} {g = g})
up-gconnected-map-ќєвВВ K f g
  = up-gconnected-mapвЖРcocartesian K
      (Pushout-square (mk-span _ f g))
      (Pushout-square-is-cocartesian (mk-span _ f g))
}
%```
}

\subtree{
\date{2026-03-19}
\author{fredrikbakke}
\taxon{Lemma}
\title{#{K}-connected maps are #{K}-equivalences}

% ```agda
\agda{
up-gmodal-equivвЖРup-gconnected-map
  : вИА {ќ± рЭУ§ рЭУ•} (K : gSubU ќ±)
      {A : Type рЭУ§} {B : Type рЭУ•}
      (f : A вЖТ B)
  вЖТ up-gconnected-map K f
  вЖТ up-gmodal-equiv K f
up-gmodal-equivвЖРup-gconnected-map K f fconn UвИИK = fconn (ќї _ вЖТ UвИИK)

module gRSubUConnectedModalEquivalences {ќ±} (RS : gRSubU ќ±) where
  open gRSubU RS
  open gRSubUModalEquivalences RS

}
%```
}


\subtree{
\date{2026-03-19}
\author{fredrikbakke}
\taxon{Theorem}
\title{Unique dependent extension property of #{K}-connected maps}

\p{
#{K}-Connectedness is equivalent to saying every section of a #{K}-valued
family over the domain uniquely extends along the map.
}

% ```agda
\agda{
up-gconnected-mapвЗФunique-extensions
  : вИА {ќ± рЭУ§ рЭУ•} (K : gSubU ќ±)
      {A : Type рЭУ§} {B : Type рЭУ•}
      (f : A вЖТ B)
    вЖТ up-gconnected-map K f
    вЖТ вИА {рЭУЪ} {U : B вЖТ Type рЭУЪ}
    вЖТ (вИА b вЖТ U b вИИ gSubU.S K)
    вЖТ (h : ќ† A (U вИШ f))
    вЖТ is-singleton (Ext f h)
up-gconnected-mapвЗФunique-extensions K f fconn UвИИK h
  = is-contr-mapвЖРis-equiv (fconn UвИИK) h

up-gconnected-mapвЖРunique-extensions
  : вИА {ќ± рЭУ§ рЭУ•} (K : gSubU ќ±)
      {A : Type рЭУ§} {B : Type рЭУ•}
      (f : A вЖТ B)
    вЖТ (вИА {рЭУЪ} {U : B вЖТ Type рЭУЪ}
        вЖТ (вИА b вЖТ U b вИИ gSubU.S K)
        вЖТ (h : ќ† A (U вИШ f))
        вЖТ is-singleton (Ext f h))
  вЖТ up-gconnected-map K f
up-gconnected-mapвЖРunique-extensions K f ext {U = U} UвИИK
  = is-equivвЖРis-contr-map ќї h вЖТ ext UвИИK h
}
%```
}

\subtree{
\date{2026-03-19}
\author{fredrikbakke}
\taxon{Lemma}
\title{Terminal projection and constant-map criteria on fibres}

\p{
For the fibres of a map, asking that the terminal projections be #{K}-equivalences is
equivalent to asking that the fibres satisfy the universal property of
#{K}-connected types.
}

% ```agda
\agda{
gconnected-map-!-fibresвЗФgconnected-fibres
  : вИА {ќ± рЭУ§ рЭУ•} (K : gSubU ќ±)
      {A : Type рЭУ§} {B : Type рЭУ•}
      (f : A вЖТ B)
  вЖТ gconnected-map-!-fibre K f
  вЖТ gconnected-fibres K f
gconnected-map-!-fibresвЗФgconnected-fibres K f fib-eq b UвИИK
  = is-equiv-constвЖРprecomp-! (fib-eq b UвИИK)

gconnected-map-!-fibresвЖРgconnected-fibres
  : вИА {ќ± рЭУ§ рЭУ•} (K : gSubU ќ±)
      {A : Type рЭУ§} {B : Type рЭУ•}
      (f : A вЖТ B)
  вЖТ gconnected-fibres K f
  вЖТ gconnected-map-!-fibre K f
gconnected-map-!-fibresвЖРgconnected-fibres K f fib-const b UвИИK
  = is-equiv-precomp-!вЖРconst (fib-const b UвИИK)
}
%```
}

\subtree{
\date{2026-03-19}
\author{fredrikbakke}
\taxon{Theorem}
\title{Fibrewise connected maps are connected}

\p{
If each fibre of #{f} is #{K}-connected, i.e., for each #{b} and each #{K}-type #{U},
the constant map #{U \to (\fibre{f}{b} \to U)} is an equivalence, then #{f} is
#{K}-connected.
}

% ```agda
\agda{
up-gconnected-mapвЖРgconnected-fibres
  : вИА {ќ± рЭУ§ рЭУ•} (K : gSubU ќ±)
      {A : Type рЭУ§} {B : Type рЭУ•}
      (f : A вЖТ B)
  вЖТ gconnected-fibres K f
  вЖТ up-gconnected-map K f
up-gconnected-mapвЖРgconnected-fibres K f fibre-const {U = U} UвИИK
  = is-equivвЖРArrow-equivвБї¬є {F = eq .fst} (eq .snd)
      (postcomp-ќ†-equiv ќї {b} вЖТ fibre-const b (UвИИK b)) where
  eq = precomp-ќ†-fibre-const-Arrow-equiv U f

up-gconnected-mapвЖРfibre-terminal-equiv
  : вИА {ќ± рЭУ§ рЭУ•} (K : gSubU ќ±)
      {A : Type рЭУ§} {B : Type рЭУ•}
      (f : A вЖТ B)
  вЖТ gconnected-map-!-fibre K f
  вЖТ up-gconnected-map K f
up-gconnected-mapвЖРfibre-terminal-equiv K f fibterm
  = up-gconnected-mapвЖРgconnected-fibres K f
      (gconnected-map-!-fibresвЗФgconnected-fibres K f fibterm)
}
%```
}


\subtree[fre-0315]{
\date{2026-03-19}
\author{fredrikbakke}
\title{#{K}-Connected maps, given reflections of fibres}

\agda{
module gReflectorConnectedMaps
    {ќ± рЭУ§ рЭУ•} {GS : gSubU ќ±}
    {A : Type рЭУ§} {B : Type рЭУ•}
    (f : A вЖТ B)
    (RрЭЯЩ : gReflector GS рЭЯЩ)
    (вЧЛрЭЯЩ-singleton : is-singleton (gReflector.вЧЛ RрЭЯЩ))
    (Rf : (b : B) вЖТ gReflector GS (fibre f b)) where
  module One = gReflector RрЭЯЩ

  reflected-fibres-singleton
    : Type _
  reflected-fibres-singleton = вИА b вЖТ is-singleton (gReflector.вЧЛ (Rf b))

  reflected-fibres-singletonвЖРgconnected-map-!-fibre
    : gconnected-map-!-fibre GS f
    вЖТ reflected-fibres-singleton
  reflected-fibres-singletonвЖРgconnected-map-!-fibre fibterm b
    = is-singleвЖРequiv-to-single
        (mkвЙГ (gReflectorMap.вЧЛвВБ (Rf b) RрЭЯЩ (! {A = fibre f b}))
          (gReflectorModalEquivalences.is-gmodal-equivвЖРup-gmodal-equiv
            (Rf b) RрЭЯЩ (! {A = fibre f b}) (fibterm b))
          eвБї¬є)
        вЧЛрЭЯЩ-singleton

  gconnected-map-!-fibreвЖРreflected-fibres-singleton
    : reflected-fibres-singleton
    вЖТ gconnected-map-!-fibre GS f
  gconnected-map-!-fibreвЖРreflected-fibres-singleton sing b
    = gReflectorModalEquivalences.up-gmodal-equivвЖРis-gmodal-equiv
        (Rf b) RрЭЯЩ (! {A = fibre f b})
        (is-equivвЖРsingle-to-prop
          (sing b)
          (is-propвЖРis-single вЧЛрЭЯЩ-singleton)
          (gReflectorMap.вЧЛвВБ (Rf b) RрЭЯЩ (! {A = fibre f b})))
}
%```
}

\subtree[fre-0316]{
\date{2026-03-19}
\author{fredrikbakke}
\taxon{Theorem}
\title{Reflectors of #{\Sigma}-closed reflective global subuniverses are connected}

\agda{
module gRSubUReflectorConnected {ќ±}
    (RS : gRSubU ќ±)
    (Sќ£ : is-globally-ќ£-closed (RS .gRSubU.GS)) where
  open gRSubU RS
  open ReflectiveClosureбµН RS
  open gRSubUEquivMap RS
  open gRSubUInduction RS Sќ£
  open gRSubUModalEquivalences RS

  ќЈ-connected-map
    : вИА {рЭУ§} {A : Type рЭУ§}
    вЖТ up-gconnected-map GS (ќЈ {A = A})
  ќЈ-connected-map {A = A} {U = U} UвИИS
    = is-equivвБї¬є (ind-is-equiv UвИИS)

  ќЈвИШ-connected-mapвЖРup-gmodal-equiv
    : вИА {рЭУ§ рЭУ•} {A : Type рЭУ§} {B : Type рЭУ•}
      (f : A вЖТ B)
    вЖТ up-gmodal-equiv GS f
    вЖТ up-gconnected-map GS (ќЈ {A = B} вИШ f)
  ќЈвИШ-connected-mapвЖРup-gmodal-equiv {A = A} {B = B} f feq {U = U} UвИИS
    = homotopy-is-equiv {f = rhs} {g = precomp-ќ† U (ќЈ вИШ f)}
        (comm ~вБї¬є) rhs-is-equiv where
    mid
      : ќ† (вЧЛ B) U
      вЖТ ќ† A (ќї a вЖТ U (вЧЛвВБ f (ќЈ a)))
    mid = precomp-ќ† (U вИШ вЧЛвВБ f) ќЈ вИШ precomp-ќ† U (вЧЛвВБ f)

    rhs
      : ќ† (вЧЛ B) U вЖТ ќ† A (U вИШ ќЈ вИШ f)
    rhs = postcomp-ќ† (ќї a вЖТ tr U (вЧЛвВБ-ќ≤ f a)) вИШ mid

    rhs-is-equiv
      : is-equiv rhs
    rhs-is-equiv
      = is-equiv-вИШ
          (postcomp-ќ†-equiv ќї {a} вЖТ coe-is-equiv (ap U (вЧЛвВБ-ќ≤ f a)))
          (is-equiv-вИШ
            (ќЈ-connected-map (UвИИS вИШ вЧЛвВБ f))
            (precomp-ќ†-is-equiv (is-gmodal-equivвЖРup-gmodal-equiv f feq)))

    comm
      : precomp-ќ† U (ќЈ вИШ f)
      ~ rhs
    comm h = funextвЖТ ќї a вЖТ sym (apбµИ h (вЧЛвВБ-ќ≤ f a))

  is-gmodal-equivвЖРup-gconnected-map
    : вИА {рЭУ§ рЭУ•} {A : Type рЭУ§} {B : Type рЭУ•}
      (f : A вЖТ B)
    вЖТ up-gconnected-map GS f
    вЖТ is-gmodal-equiv f
  is-gmodal-equivвЖРup-gconnected-map f fconn
    = is-gmodal-equivвЖРup-gmodal-equiv f
        (up-gmodal-equivвЖРup-gconnected-map GS f fconn)
}
%```
}

\subtree{
\date{2026-03-19}
\author{fredrikbakke}
\taxon{Lemma}
\title{Connections between certain fibre conditions on a map with #{K}-reflections}

%```agda
\agda{
module gReflectorFibres
    {ќ± рЭУ§ рЭУ•} {GS : gSubU ќ±}
    {A : Type рЭУ§} {B : Type рЭУ•}
    (f : A вЖТ B)
    (Rf : (b : B) вЖТ gReflector GS (fibre f b)) where

  ќЈ-fibre-section
    : ќ† A (ќї a вЖТ gReflector.вЧЛ (Rf (f a)))
  ќЈ-fibre-section a = gReflector.ќЈ (Rf (f a)) (a , refl)

  fibre-local-centreвЖРover
    : (b : B)
    вЖТ null-homotopy
        (precomp-ќ†-over-fibres (ќї b вЖТ gReflector.вЧЛ (Rf b)) f ќЈ-fibre-section b)
    вЖТ ќ£[ u вИґ gReflector.вЧЛ (Rf b) ]
        ((x : fibre f b) вЖТ u пЉЭ gReflector.ќЈ (Rf b) x)
  fibre-local-centreвЖРover b (u , H)
    = u , ќї where (a , refl) вЖТ H (a , refl)

  reflected-fibre-singletonвЖРlocal-centre
    : {b : B}
    вЖТ ќ£[ u вИґ gReflector.вЧЛ (Rf b) ]
        ((x : fibre f b) вЖТ u пЉЭ gReflector.ќЈ (Rf b) x)
    вЖТ is-singleton (gReflector.вЧЛ (Rf b))
  reflected-fibre-singletonвЖРlocal-centre {b} (u , H)
    = mk-singl u (happly p) where
    module Fb = gReflector (Rf b)

    p : const Fb.вЧЛ Fb.вЧЛ u пЉЭ id
    p = unap
          (is-embeddingвЖРis-equiv (Fb.reflects Fb.вЧЛвИИS))
          (funextвЖТ H)

  fibre-precomp-ќ†-ќЈ-fibreвЙГќ†-local-centre-over
    : fibre (precomp-ќ† (ќї b вЖТ gReflector.вЧЛ (Rf b)) f) ќЈ-fibre-section
      вЙГ ((b : B)
        вЖТ null-homotopy
            (precomp-ќ†-over-fibres (ќї b вЖТ gReflector.вЧЛ (Rf b)) f
              ќЈ-fibre-section b))
  fibre-precomp-ќ†-ќЈ-fibreвЙГќ†-local-centre-over
    = fibre-precomp-ќ†-null-homotopyвЙГ
        (ќї b вЖТ gReflector.вЧЛ (Rf b)) f ќЈ-fibre-section

  merely-fibre-local-centreвЖРsurjective-precomp-ќ†
    : (вИА {рЭУЪ} {U : B вЖТ Type рЭУЪ}
        вЖТ ((b : B) вЖТ U b вИИ gSubU.S GS)
        вЖТ is-surjective (precomp-ќ† U f))
    вЖТ ((b : B)
      вЖТ вХС ќ£[ u вИґ gReflector.вЧЛ (Rf b) ]
            ((x : fibre f b) вЖТ u пЉЭ gReflector.ќЈ (Rf b) x) вХС)
  merely-fibre-local-centreвЖРsurjective-precomp-ќ† surj b
    = Trunc.вЧЛ-rec Trunc.вЧЛвИИS
        (Trunc.ќЈ вИШ fibre-local-centreвЖРover b вИШ ev b)
        (Trunc.вЧЛ-rec Trunc.вЧЛвИИS
          (Trunc.ќЈ вИШ fibre-precomp-ќ†-ќЈ-fibreвЙГќ†-local-centre-over ._вЙГ_.fwd)
          (surj (ќї b вЖТ gReflector.вЧЛвИИS (Rf b)) ќЈ-fibre-section))
}
%```
}

\subtree{
\date{2026-03-19}
\author{fredrikbakke}
\taxon{Theorem}
\title{Fibre reflection conditions for #{K}-connected maps}

%```agda
\agda{
module gReflectorConnectedCharacterisation
    {ќ± рЭУ§ рЭУ•} {GS : gSubU ќ±}
    {A : Type рЭУ§} {B : Type рЭУ•}
    (f : A вЖТ B)
    (RрЭЯЩ : gReflector GS рЭЯЩ)
    (вЧЛрЭЯЩ-singleton : is-singleton (gReflector.вЧЛ RрЭЯЩ))
    (Rf : (b : B) вЖТ gReflector GS (fibre f b)) where
  open gReflectorConnectedMaps f RрЭЯЩ вЧЛрЭЯЩ-singleton Rf
  open gReflectorFibres f Rf

  reflected-fibres-singletonвЖРmerely-local-centre
    : ((b : B)
      вЖТ вХС ќ£[ u вИґ gReflector.вЧЛ (Rf b) ]
            ((x : fibre f b) вЖТ u пЉЭ gReflector.ќЈ (Rf b) x) вХС)
    вЖТ reflected-fibres-singleton
  reflected-fibres-singletonвЖРmerely-local-centre mere b
    = Trunc.вЧЛ-rec
        (is-truncatedвЖРis-prop is-single-is-prop)
        reflected-fibre-singletonвЖРlocal-centre
        (mere b)

  gconnected-map-!-fibreвЖРmerely-local-centre
    : ((b : B)
      вЖТ вХС ќ£[ u вИґ gReflector.вЧЛ (Rf b) ]
            ((x : fibre f b) вЖТ u пЉЭ gReflector.ќЈ (Rf b) x) вХС)
    вЖТ gconnected-map-!-fibre GS f
  gconnected-map-!-fibreвЖРmerely-local-centre mere
    = gconnected-map-!-fibreвЖРreflected-fibres-singleton
        (reflected-fibres-singletonвЖРmerely-local-centre mere)

  up-gconnected-mapвЖРmerely-local-centre
    : ((b : B)
      вЖТ вХС ќ£[ u вИґ gReflector.вЧЛ (Rf b) ]
           ((x : fibre f b) вЖТ u пЉЭ gReflector.ќЈ (Rf b) x) вХС)
    вЖТ up-gconnected-map GS f
  up-gconnected-mapвЖРmerely-local-centre mere
    = up-gconnected-mapвЖРfibre-terminal-equiv GS f
        (gconnected-map-!-fibreвЖРmerely-local-centre mere)
}
%```
}

\subtree[fre-0319]{
\date{2026-03-19}
\author{fredrikbakke}
\taxon{Corollary}
\title{Equivalent conditions for connected maps in reflective global subuniverses}

%```agda
\agda{
module gRSubUConnectedCharacterisation {ќ±} (RS : gRSubU ќ±) where
  open gRSubU RS
  open gRSubUEquivMap RS
  open gRSubUModalEquivalences RS

  module _ {рЭУ§ рЭУ•} {A : Type рЭУ§} {B : Type рЭУ•} (f : A вЖТ B) where
    module Ch = gReflectorConnectedCharacterisation
      f
      (gReflectorвЖРgRSubU RS рЭЯЩ)
      (вЧЛрЭЯЩ-is-single RS)
      (ќї b вЖТ gReflectorвЖРgRSubU RS (fibre f b))
    open Ch
    module LC = gReflectorFibres f (ќї b вЖТ gReflectorвЖРgRSubU RS (fibre f b))

    gconnected-map-!-fibreвЖРfibre-connected
      : is-gconnected-map RS f
      вЖТ gconnected-map-!-fibre GS f
    gconnected-map-!-fibreвЖРfibre-connected fconn
      = gconnected-map-!-fibresвЖРgconnected-fibres GS f fib-const where

      fib-const : gconnected-fibres GS f
      fib-const b UвИИS
        = (is-equiv-вИШ
            (reflects {A = fibre f b} UвИИS)
            (sing-const-is-equiv global-funext (fconn b)))

    is-gconnected-mapвЖРgconnected-map-!-fibre
      : gconnected-map-!-fibre GS f
      вЖТ is-gconnected-map RS f
    is-gconnected-mapвЖРgconnected-map-!-fibre fibterm b
      = is-singleвЖРequiv-to-single
          (mkвЙГ (вЧЛвВБ (! {A = fibre f b}))
            (is-gmodal-equivвЖРup-gmodal-equiv (! {A = fibre f b}) (fibterm b))
            eвБї¬є)
          (вЧЛрЭЯЩ-is-single RS)

    is-gconnected-mapвЖРup-gconnected-map
      : up-gconnected-map GS f
      вЖТ is-gconnected-map RS f
    is-gconnected-mapвЖРup-gconnected-map fconn
      = reflected-fibres-singletonвЖРmerely-local-centre
          (LC.merely-fibre-local-centreвЖРsurjective-precomp-ќ†
            (ќї UвИИK вЖТ is-surjectiveвЖРis-equiv (fconn UвИИK)))

    up-gconnected-mapвЖРis-gconnected-map
      : is-gconnected-map RS f
      вЖТ up-gconnected-map GS f
    up-gconnected-mapвЖРis-gconnected-map fconn
      = up-gconnected-mapвЖРfibre-terminal-equiv GS f
          (gconnected-map-!-fibreвЖРfibre-connected fconn)
}
%```
}

\subtree[stt-00MH]{
\date{2026-03-19}
\author{fredrikbakke}
\taxon{Theorem}
\title{Fibrewise connected maps are connected}

\p{
If each fibre of #{f} is #{K}-connected, i.e., for each #{b} and each #{K}-type #{U},
the constant map #{U \to (\fibre{f}{b} \to U)} is an equivalence, then #{f} is
#{K}-connected.
}

\agda{
up-connected-mapтЖРup-connected-fibres
  : тИА {╬▒ ЁЭУд ЁЭУе} (K : gSubU ╬▒)
      {A : Type ЁЭУд} {B : Type ЁЭУе}
      (f : A тЖТ B)
    тЖТ up-connected-fibres K f
    тЖТ up-connected-map K f
up-connected-mapтЖРup-connected-fibres K f fibre-const {U = U} UтИИK
  = is-equivтЖРArrow-equivтБ╗┬╣ {F = eq .fst} (eq .snd)
      (postcomp-╬а-equiv ╬╗ {b} тЖТ fibre-const b (UтИИK b)) where
  eq = precomp-╬а-fibre-const-Arrow-equiv U f

up-connected-mapтЖРfibre-terminal-equiv
  : тИА {╬▒ ЁЭУд ЁЭУе} (K : gSubU ╬▒)
      {A : Type ЁЭУд} {B : Type ЁЭУе}
      (f : A тЖТ B)
    тЖТ up-connected-!-fibre K f
    тЖТ up-connected-map K f
up-connected-mapтЖРfibre-terminal-equiv K f fibterm
  = up-connected-mapтЖРup-connected-fibres K f
      (up-connected-fibresтЖРup-connected-!-fibres K f fibterm)
}
}


\subtree[stt-00M6]{
\date{2026-03-19}
\author{fredrikbakke}
\title{#{K}-Connected maps, given reflections of fibres}

\agda{
module gReflectorConnectedMaps
    {╬▒ ЁЭУд ЁЭУе} {GS : gSubU ╬▒}
    {A : Type ЁЭУд} {B : Type ЁЭУе}

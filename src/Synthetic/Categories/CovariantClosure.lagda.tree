\subtree[stt-00FU]{
\title{Base change of covariant families}
\taxon{Lemma}

%```agda
\agda{
covariant-base-change
  : ‚ąÄ {ūĚď§ ūĚď• ūĚď¶} {A : Type ūĚď§} {B : Type ūĚď•} {P : B ‚Üí Type ūĚď¶}
    ‚Üí (f : A ‚Üí B)
    ‚Üí is-covariant P ‚Üí is-covariant (P ‚ąė f)
covariant-base-change F Pc f x‚āÄ = Pc (F ‚ąė f) x‚āÄ

is-covariant-is-őĒ¬Ļ-relative
  : ‚ąÄ {ūĚď§ ūĚď•} {A : Type ūĚď§} {P : A ‚Üí Type ūĚď•}
    ‚Üí is-covariant P ‚áĒ (‚ąÄ (f : őĒ¬Ļ ‚Üí A) ‚Üí is-covariant (P ‚ąė f))
is-covariant-is-őĒ¬Ļ-relative {A = A} {P} .fst Pc f
  = covariant-base-change {P = P} f Pc
is-covariant-is-őĒ¬Ļ-relative {A = A} {P} .snd Pfc h = Pfc h id
}
%```
}

\subtree[stt-00FV]{
\title{Products of Covariant families}
\taxon{Lemma}

%```agda
\agda{
√ó-is-covariant
  : ‚ąÄ {ūĚď§ ūĚď• ūĚď¶} {A : Type ūĚď§} {P : A ‚Üí Type ūĚď•} {Q : A ‚Üí Type ūĚď¶}
      (Pc : is-covariant P) (Qc : is-covariant Q)
    ‚Üí is-covariant (őĽ a ‚Üí P a √ó Q a)
√ó-is-covariant {P = P}{Q} Pc Qc f (Px‚āÄ , Qx‚āÄ)
  = is-single‚Üźequiv-to-single
      (ő£-ap-‚ČÉ (őĽ _ ‚Üí HomŠĶą-√ó‚ČÉ {P = P}{Q} f e‚ĀĽ¬Ļ))
      (is-singleton-structure‚Üźparts
        (Pc f Px‚āÄ)
        (Pc f Px‚āÄ .centre)
        (Qc f Qx‚āÄ))
}
%```
}



\subtree{
\title{Sums of covariant families}

%```agda
\agda{
opaque
  ő£-is-covariant
    : ‚ąÄ {ūĚď§ ūĚď• ūĚď¶} {A : Type ūĚď§} {B : A ‚Üí Type ūĚď•} ‚Üí {C : (a : A) ‚Üí B a ‚Üí Type ūĚď¶}
      ‚Üí is-covariant B ‚Üí is-covariant (uncurry C)
      ‚Üí is-covariant (őĽ a ‚Üí ő£ (B a) (C a))
  ő£-is-covariant {A = A} {B}{C} Bc Cc
    = is-covariant‚áĒis-left-fibration _ .snd is-left where

    is-left : is-left-fibration (fst {B = őĽ a ‚Üí ő£ (B a) (C a)})
    is-left
      = right-orthogonal-‚ąė (const _ ūĚüô i0)
          {g = fst} {fst ‚ąė _‚ČÉ_.bwd ő£-assoc}
          (is-covariant‚áĒis-left-fibration B .fst Bc)
          (right-orthogonal-‚ąė (const _ ūĚüô i0)
            (is-covariant‚áĒis-left-fibration (uncurry C) .fst Cc)
            (‚ä•equiv (const _ ūĚüô i0) _ (is-equiv‚ĀĽ¬Ļ (ő£-assoc ._‚ČÉ_.has-is-eqv))))
}
%```
}

\subtree{
\title{Paths in covariant families}

%```agda
\agda{
opaque
  ÔľĚ-is-covariant
    : ‚ąÄ {ūĚď§ ūĚď•} {A : Type ūĚď§} {B : A ‚Üí Type ūĚď•} (x y : ő† A B)
      ‚Üí is-covariant B
      ‚Üí is-covariant (őĽ a ‚Üí x a ÔľĚ y a)
  ÔľĚ-is-covariant {A = A} {B} x y Bc
    = is-covariant‚áĒis-left-fibration _ .snd lf where
    is-left : is-left-fibration {A = A} {B = ő£ A B} (őĽ a ‚Üí a , y a)
    is-left = right-orthogonal-left-cancel (point i0)
                (is-covariant‚áĒis-left-fibration _ .fst Bc)
                (point i0 ‚ä•id)

    pb : Arrow-map (fst: őĽ a ‚Üí x a ÔľĚ y a) {D = ő£ A B} (őĽ a ‚Üí a , y a)
    pb .Arrow-ő†.top = fst
    pb .Arrow-ő†.bot a = (a , x a)
    pb .Arrow-ő†.comm (a , p) = ő£-path‚Üí (refl , p)

    pb-is-cart : is-cartesian pb
    pb-is-cart = is-cartesian‚Üźgap-is-equiv pb
      (is-equiv-‚ąė
        {f = total-map őĽ a ‚Üí total-map őĽ b ‚Üí ő£-path‚Üí}
        {őĽ (a , b) ‚Üí a , a , refl , b }
        (is-total-equiv‚Üźis-fibrewise-equiv
          (őĽ a ‚Üí is-total-equiv‚Üźis-fibrewise-equiv
            (őĽ b ‚Üí ő£-path ._‚ČÉ_.has-is-eqv)))
        (is-equiv‚Üźqiso
          ( (őĽ where (a , b , refl , p) ‚Üí a , p )
          , ~refl
          , őĽ where (a , b , refl , p) ‚Üí refl)))

    lf : is-left-fibration (fst: őĽ a ‚Üí x a ÔľĚ y a)
    lf = orthogonal‚Üźpullback (point i0) pb pb-is-cart is-left
}
%```
}

\subtree{
\title{Functions from contravariant families to covariant families}

%```agda
\agda{
is-contravariant : ‚ąÄ {ūĚď§ ūĚď•} {A : Type ūĚď§} (B : A ‚Üí Type ūĚď•)
               ‚Üí Type (ūĚďė ‚äĒ ūĚď§ ‚äĒ ūĚď•)
is-contravariant {A = A} B
    = ‚ąÄ (x : őĒ¬Ļ ‚Üí A) (x‚āĀ : B (x i1))
      ‚Üí is-singleton (ő£[ x‚āÄ ‚ą∂ B (x i0)] HomŠĶą (B ‚ąė x) x‚āÄ x‚āĀ)

tr-contra
  : ‚ąÄ {ūĚď§ ūĚď•} {A : Type ūĚď§} {P : A ‚Üí Type ūĚď•}
    ‚Üí is-contravariant P ‚Üí (h : őĒ¬Ļ ‚Üí A) ‚Üí P (h i1) ‚Üí P (h i0)
tr-contra pc h x‚āĀ = pc h x‚āĀ .centre .fst

coe-cov : ‚ąÄ {ūĚď§} {B : őĒ¬Ļ ‚Üí Type ūĚď§} {i j} ‚Üí is-covariant B ‚Üí i ‚Č§ j ‚Üí B i ‚Üí B j
coe-cov {_} {B}{i}{j} Bc p
   = tr B (ap‚āā _‚ąß_ (‚ą®-comm ‚ąô 1-coinit) (‚Č§-max p) ‚ąô ‚ąß-comm ‚ąô 1-top)
   ‚ąė tr-cov {P = B} Bc (őĽ l ‚Üí (l ‚ą® i) ‚ąß (i ‚ą® j))
   ‚ąė tr B (sym (ap‚āā _‚ąß_ (‚ą®-comm ‚ąô 0-bottom) (‚Č§-max p) ‚ąô p))

opaque
  coe-cov-id : ‚ąÄ {ūĚď§} {B : őĒ¬Ļ ‚Üí Type ūĚď§} (bc : is-covariant B)
                 {i} (p : i ‚Č§ i) ‚Üí coe-cov {B = B} bc p ~ id
  coe-cov-id {B = B} bc {i} p x
    = unap-equiv
        {f = tr B (sym (ap‚āā _‚ąß_ (‚ą®-comm ‚ąô 1-coinit) (‚Č§-max p) ‚ąô ‚ąß-comm ‚ąô 1-top))}
        (tr-is-equiv _)
        ( tr‚ąôtr-sym (ap‚āā _‚ąß_ (‚ą®-comm ‚ąô 1-coinit) (‚Č§-max p) ‚ąô ‚ąß-comm ‚ąô 1-top) _
        ‚ąô _‚Ėłeqv_
            {f = tr B (ap‚āā _‚ąß_ (‚ą®-comm ‚ąô 0-bottom) (‚Č§-max p) ‚ąô p)}
            {g = tr-cov {P = B} bc (őĽ l ‚Üí (l ‚ą® i) ‚ąß (i ‚ą® i))
               ‚ąė tr B (sym (ap‚āā _‚ąß_ (‚ą®-comm ‚ąô 0-bottom) (‚Č§-max p) ‚ąô p))}
            {h = tr B (sym (ap‚āā _‚ąß_ (‚ą®-comm ‚ąô 1-coinit) (‚Č§-max p) ‚ąô ‚ąß-comm ‚ąô 1-top))}
            ( tr-cov {P = B} bc (őĽ l ‚Üí (l ‚ą® i) ‚ąß (i ‚ą® i))
               ‚óā (tr‚ąôtr-sym (ap‚āā _‚ąß_ (‚ą®-comm ‚ąô 0-bottom) (‚Č§-max p) ‚ąô p))
            ~‚ąô őĽ b ‚Üí lemma (őĽ l ‚Üí (l ‚ą® i) ‚ąß (i ‚ą® i)) pp' b
                 ‚ąô ap (őĽ n ‚Üí tr B n b) prop!
                 ‚ąô sym (tr‚ąôtr (ap‚āā _‚ąß_ (‚ą®-comm ‚ąô 0-bottom) (‚Č§-max p) ‚ąô p)
                              ( sym (ap‚āā _‚ąß_ (‚ą®-comm ‚ąô 1-coinit) (‚Č§-max p)
                              ‚ąô ‚ąß-comm ‚ąô 1-top)) b))
            (tr-is-equiv _)
            x) where

    pp : (i0 ‚ą® i) ‚ąß (i ‚ą® i) ÔľĚ (i1 ‚ą® i) ‚ąß (i ‚ą® i)
    pp = ap‚āā _‚ąß_ (‚ą®-comm ‚ąô 0-bottom) (‚Č§-max p)
       ‚ąô p
       ‚ąô sym (ap‚āā _‚ąß_ (‚ą®-comm ‚ąô 1-coinit) (‚Č§-max p) ‚ąô ‚ąß-comm ‚ąô 1-top)

    pp' : ‚ąÄ l ‚Üí (l ‚ą® i) ‚ąß (i ‚ą® i) ÔľĚ (i1 ‚ą® i) ‚ąß (i ‚ą® i)
    pp' l = ap ((l ‚ą® i) ‚ąß_) ‚ą®-idem ‚ąô ‚ą®-‚ąß-abs'
          ‚ąô sym (ap ((i1 ‚ą® i) ‚ąß_) ‚ą®-idem
          ‚ąô ‚ą®-‚ąß-abs')

    lemma : ‚ąÄ (p : őĒ¬Ļ ‚Üí őĒ¬Ļ) (q : ‚ąÄ i ‚Üí p i ÔľĚ p i1)
            ‚Üí tr-cov {P = B} bc p ~ tr B (q i0)
    lemma p q x = ap fst (bc p x .central (tr B (q i0) x , őĽ where
      .HomŠĶą.hom j ‚Üí tr B (q i0 ‚ąô sym (q j)) x
      .HomŠĶą.hom0  ‚Üí ap (őĽ K ‚Üí tr B K x) prop!
      .HomŠĶą.hom1  ‚Üí ap (őĽ K ‚Üí tr B K x) prop!))


opaque
  coe-cov-0‚Č§1 : ‚ąÄ {ūĚď§} {B : őĒ¬Ļ ‚Üí Type ūĚď§} (bc : is-covariant B)
                  (p : i0 ‚Č§ i1) ‚Üí coe-cov {B = B} bc p ~ tr-cov bc id
  coe-cov-0‚Č§1 {B = B} bc p a = sym (ap fst (bc id a .central
      ( coe-cov bc p a
      , őĽ where .HomŠĶą.hom ‚Üí őĽ i ‚Üí coe-cov {B = B} bc 0-init a
                .HomŠĶą.hom0 ‚Üí coe-cov-id bc 0-init a
                .HomŠĶą.hom1 ‚Üí ap (őĽ x ‚Üí coe-cov bc x a) prop!)) )


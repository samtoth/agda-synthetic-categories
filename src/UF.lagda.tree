weak-funext
  : вИА {рЭУ§ рЭУ•} {A : Type рЭУ§} {B : A вЖТ Type рЭУ•}
    вЖТ (вИА a вЖТ is-singleton (B a))
    вЖТ is-singleton ((a : A) вЖТ B a)
weak-funext sb = mk-singl (centre вИШ sb) (ќї x вЖТ funextвЖТ (ќї a вЖТ sb a .central (x a)))

ќ†-is-single = weak-funext

ќ†-implicitвЙГ
  : {рЭУ§ рЭУ• : Level} {A : Type рЭУ§} {B : A вЖТ Type рЭУ•}
  вЖТ ќ† A B вЙГ ({a : A} вЖТ B a)
ќ†-implicitвЙГ ._вЙГ_.fwd f {a} = f a
ќ†-implicitвЙГ ._вЙГ_.has-is-eqv .is-equiv.qinv .fst f a = f {a}
ќ†-implicitвЙГ ._вЙГ_.has-is-eqv .is-equiv.qinv .snd .fst = ~refl
ќ†-implicitвЙГ ._вЙГ_.has-is-eqv .is-equiv.qinv .snd .snd = ~refl
ќ†-implicitвЙГ ._вЙГ_.has-is-eqv .is-equiv.coherent = ~refl

ќ†бµҐ-is-single
  : {рЭУ§ рЭУ• : Level} {A : Type рЭУ§} {B : A вЖТ Type рЭУ•}
  вЖТ ({a : A} вЖТ is-singleton (B a)) вЖТ is-singleton ({a : A} вЖТ B a)
ќ†бµҐ-is-single {A = A} {B} sa
  = is-singleвЖРequiv-to-single ќ†-implicitвЙГ (ќ†-is-single (ќї _ вЖТ sa))

ќ†-is-prop
  : вИА {рЭУ§ рЭУ• : Level} {A : Type рЭУ§} {B : A вЖТ Type рЭУ•}
    вЖТ ((a : A) вЖТ is-prop (B a))
    вЖТ is-prop (ќ† A B)
ќ†-is-prop = Foundations.PropClosure.ќ†-is-prop global-funext

ќ†бµҐ-is-prop
  : вИА {рЭУ§ рЭУ•} {A : Type рЭУ§} {B : A вЖТ Type рЭУ•}
    вЖТ (вИА {a} вЖТ is-prop (B a))
    вЖТ is-prop (вИА {a} вЖТ B a)
ќ†бµҐ-is-prop ap = is-propвЖРis-single-if-inhabited
                  (ќї f вЖТ ќ†бµҐ-is-single
                   (ќї {a} вЖТ mk-singl (f {a}) (ap f)))

funext-redex
  : вИА {рЭУ§ рЭУ•} {A : Type рЭУ§} {B : A вЖТ Type рЭУ•}
      {f g : (a : A) вЖТ B a } вЖТ {p : f ~ g}
    вЖТ happly (funextвЖТ p) пЉЭ p
funext-redex {p = p} = is-equiv.ќµ global-funext p

open import Foundations.Univalence


\subtree[stt-00F3]{
\title{Null-homotopies}
\taxon{Definition}

\p{
Given a map #{f : A \to B} then its type of \em{null-homotopies} is the collection of
elements #{b} of #{B} such that for all #{a} in #{A} we have #{b = f(a)}.
##{\nullhtpy{f} \coloneqq \Sigma_{(b : B)}(\Pi_{(a : A)} b = f(a)).}
}

%```agda
\agda{
module _ {𝓤1 𝓤2} {A : Type 𝓤1} {B : Type 𝓤2} where

  fam-null-homotopy : (A → B) → B → Type (𝓤1 ⊔ 𝓤2)
  fam-null-homotopy f b = (a : A) → b ＝ f a

  null-homotopy : (A → B) → Type (𝓤1 ⊔ 𝓤2)
  null-homotopy f = Σ[ b ∶ B ] (fam-null-homotopy f b)

  null-homotopy-path-Idᵈ≃pointwise
    : {f : A → B}
      {c l : B}
      (h : fam-null-homotopy f c)
      (r : fam-null-homotopy f l)
      (t : c ＝ l)
    → Idᵈ (ap (fam-null-homotopy f) t) h r ≃ ((a : A) → t ∙ r a ＝ h a)
  null-homotopy-path-Idᵈ≃pointwise {f = f} h r t
    = Idᵈ (ap (fam-null-homotopy f) t) h r
        ≃⟨ ＝-postcomp-≃
            ( J (λ l' t' → (λ a → sym t' ∙ h a) ＝ coe (ap (fam-null-homotopy f) t') h)
                (funext→ (λ a → ∙-refll (h a)))
                (t) ) ⟩
      ((λ a → sym t ∙ h a) ＝ r)
        ≃⟨ funext≃ ⟩
      ((a : A) → sym t ∙ h a ＝ r a)
        ≃⟨ Π-ap-≃
              (λ a
              → J
                  (λ l' t' → (r' : l' ＝ f a)
                    → (sym t' ∙ h a ＝ r') ≃ (t' ∙ r' ＝ h a))
                  (λ _ → sym≃)
                  t
                  (r a)) ⟩
      ((a : A) → t ∙ r a ＝ h a)
        ≃∎

  null-homotopy-path≃
    : {f : A → B}
      {c l : B}
      (h : const B A c ~ f)
      (r : const B A l ~ f)
    → ((c , h) ＝ (l , r))
    ≃ (Σ[ t ∶ c ＝ l ] ((a : A) → t ∙ r a ＝ h a))
  null-homotopy-path≃ {f = f} {c} {l} h r
    = ((c , h) ＝ (l , r))
        ≃⟨ Σ-path e⁻¹ ⟩
      (Σ[ t ∶ c ＝ l ] Idᵈ (ap (fam-null-homotopy f) t) h r)
        ≃⟨ Σ-ap-≃ (null-homotopy-path-Idᵈ≃pointwise h r) ⟩
      (Σ[ t ∶ c ＝ l ] ((a : A) → t ∙ r a ＝ h a))
        ≃∎
}
%```
}

\subtree[stt-00F4]{
\title{The action on identifications of null-homotopic maps is null-homotopic}
\taxon{Proposition}

\p{
If #{f : A \to B} is null-homotopic, then for any #{x,y : A}, the induced map on paths
#{\ap f : (x = y) \to (f(x) = f(y))} is null-homotopic.
}

%```agda
\agda{
ap-null-homotopy
  : ∀ {𝓤 𝓥}
      {A : Type 𝓤}
      {B : Type 𝓥}
      {f : A → B}
    → null-homotopy f
    → (x y : A)
    → null-homotopy (ap f {x} {y})
ap-null-homotopy {f = f} (b , h) x y
  = sym (h x) ∙ h y
  , J (λ y p → sym (h x) ∙ h y ＝ ap f p) (∙-sym' (h x))
}
%```
}

\subtree[stt-00F5]{
\title{A null-homotopy presentation of domains of maps}
\taxon{Construction}

\p{
Given a map #{g : X \to Y} and any type #{A}, then #{X} is equivalent to the data
consisting of a point #{y : Y}, a map #{j : A \to \fibre{g}{y}}, and a null-homotopy of #{j}.
##{X \;\simeq\; \Sigma_{(y : Y)}\Sigma_{(j : A \to \fibre{g}{y})}\nullhtpy(j)}
}

%```agda
\agda{
module _ {𝓤 𝓥 𝓦} (A : Type 𝓤) {X : Type 𝓥} {Y : Type 𝓦} (g : X → Y) where

  fibre-pointed-total : Type (𝓤 ⊔ 𝓥 ⊔ 𝓦)
  fibre-pointed-total
    = Σ[ y ∶ Y ] Σ[ j ∶ (A → fibre g y) ] null-homotopy j

  fibre-pointed-total←domain : X → fibre-pointed-total
  fibre-pointed-total←domain x
    = g x , const (fibre g (g x)) A (x , refl) , (x , refl) , ~refl

  domain←fibre-pointed-total : fibre-pointed-total → X
  domain←fibre-pointed-total (_ , _ , y , _) = fst y

  domain←fibre-pointed-total-qiso : quasi-iso domain←fibre-pointed-total
  domain←fibre-pointed-total-qiso .fst = fibre-pointed-total←domain
  domain←fibre-pointed-total-qiso .snd .fst (.(g x) , j , (x , refl) , H)
    = funext-rec
        (λ H' → fibre-pointed-total←domain x ＝ (g x , j , (x , refl) , H'))
        (λ where refl → refl)
        H
  domain←fibre-pointed-total-qiso .snd .snd x = refl

  fibre-pointed-total≃domain : fibre-pointed-total ≃ X
  fibre-pointed-total≃domain
    = mk≃ domain←fibre-pointed-total
          (is-equiv←qiso domain←fibre-pointed-total-qiso)
}
%```
}

\subtree[stt-00F6]{
\title{Postcomposition preserves null-homotopies}
\taxon{Proposition}

% ```agda
\agda{
module _ {𝓤1 𝓤2 𝓤3} {A : Type 𝓤1} {B : Type 𝓤2} {C : Type 𝓤3}
         (e : A ≃ B) (j : A → C) where

  homotopy-const-postcomp-≃
    : (y : C)
    → (const C A y ~ j)
    ≃ (const C B y ~ ((precomp-≃ (e e⁻¹)) ._≃_.fwd j))
  homotopy-const-postcomp-≃ y
    = precomp-Π-≃ (λ a → y ＝ j a) (e e⁻¹)

  null-homotopy-postcomp-≃
    : null-homotopy j
    ≃ null-homotopy ((precomp-≃ (e e⁻¹)) ._≃_.fwd j)
  null-homotopy-postcomp-≃
    = Σ-ap-≃ homotopy-const-postcomp-≃
}
% ```
}


\subtree[fre-LMAS]{
\date{2026-03-19}
\author{fredrikbakke}
\taxon{Lemma}
\title{Fibres of constant maps are null-homotopies}

%```agda
\agda{
module _ {𝓤 𝓥 : Level} {A : Type 𝓤} {B : Type 𝓥} (h : A → B) where

  fibre-const≃null-homotopy
    : fibre (const B A) h ≃ null-homotopy h
  fibre-const≃null-homotopy
    = Σ-ap-≃ (λ _ → funext≃)
}
%```
}

\subtree[fre-LMAT]{
\date{2026-03-19}
\author{fredrikbakke}
\taxon{Theorem}
\title{Fibres of dependent precomposition via fibrewise null-homotopies}

%```agda
\agda{
module _
  {𝓤 𝓥 𝓦}
  {A : Type 𝓤} {B : Type 𝓥}
  (U : B → Type 𝓦)
  (f : A → B)
  (h : Π A (U ∘ f))
  where

  fibre-precomp-Π-null-homotopy≃
    : fibre (precomp-Π U f) h
      ≃ Π B (λ b → null-homotopy (precomp-Π-over-fibres U f h b))
  fibre-precomp-Π-null-homotopy≃
    = fibre (precomp-Π U f) h
        ≃⟨ Σ-ap-≃ (λ _ → funext≃) ⟩
      (Σ[ g ∶ Π B U ] ((a : A) → g (f a) ＝ h a))
        ≃⟨ Σ-ap-≃ step ⟩
      (Σ[ g ∶ Π B U ]
        ((b : B) → (x : fibre f b) → g b ＝ precomp-Π-over-fibres U f h b x))
        ≃⟨ (Σ-Π-swap≃
              U
              (λ b g → (x : fibre f b) → g ＝ precomp-Π-over-fibres U f h b x)) e⁻¹ ⟩
      (Π B (λ b → null-homotopy (precomp-Π-over-fibres U f h b)))
        ≃∎ where
    step
      : (g : Π B U)
      → ((a : A) → g (f a) ＝ h a)
        ≃ ((b : B) → (x : fibre f b) → g b ＝ precomp-Π-over-fibres U f h b x)
    step g
      = Π-ap-≃ step₀
      ∙≃ ((precomp-Π-≃
              (λ z → g (z .fst) ＝ precomp-Π-over-fibres U f h (z .fst) (z .snd))
              ((total≃total-fibre f) e⁻¹)) e⁻¹)
      ∙≃ curry≃
      where
      step₀
        : (a : A)
        → (g (f a) ＝ h a)
          ≃ (g (f a) ＝ precomp-Π-over-fibres U f h (f a) (a , refl))
      step₀ a = mk≃ map (∙-is-equiv' r) where
        r : h a ＝ precomp-Π-over-fibres U f h (f a) (a , refl)
        r = tr-refl {P = U} refl (h a) refl

        map
          : g (f a) ＝ h a
          → g (f a) ＝ precomp-Π-over-fibres U f h (f a) (a , refl)
        map q = q ∙ r
}
%```
}

\subtree[stt-00F7]{
\title{Equivalences on codomains preserve null-homotopies}
\taxon{Proposition}

% ```agda
\agda{
module _ {𝓤1 𝓤2 𝓤3} {A : Type 𝓤1} {B : Type 𝓤2} {C : Type 𝓤3}
         (e : B ≃ C) (j : A → B) where

  null-homotopy-map-codomain-≃
    : null-homotopy j
    ≃ null-homotopy (e ._≃_.fwd ∘ j)
  null-homotopy-map-codomain-≃
    = null-homotopy j
        ≃⟨ Σ-ap-≃ (λ y → Π-ap-≃ (λ a → ＝-equiv e)) ⟩
      (Σ[ y ∶ B ] ((a : A) → e ._≃_.fwd y ＝ e ._≃_.fwd (j a)))
        ≃⟨ Σ-ap-≃-fst e ⟩
      null-homotopy (e ._≃_.fwd ∘ j)
        ≃∎
}
% ```
}

\subtree[stt-00FI]{
\title{Currying null-homotopies}
\taxon{Proposition}

% ```agda
\agda{
module _ {𝓤1 𝓤2 𝓤3}
         {A : Type 𝓤1}
         {X : Type 𝓤2}
         {Y : X → Type 𝓤3}
         (f : (x : X) → A → Y x) where

  null-homotopy-curry≃
    : ((x : X) → null-homotopy (f x))
    ≃ null-homotopy (λ a x → f x a)
  null-homotopy-curry≃
    = ((x : X) → null-homotopy (f x))
        ≃⟨ Σ-Π-swap≃
              (λ x → Y x)
              (λ x y → (a : A) → y ＝ f x a) ⟩
      (Σ[ y ∶ ((x : X) → Y x) ] ((x : X) → (a : A) → y x ＝ f x a))
        ≃⟨ Σ-ap-≃ (λ _ → flip≃) ⟩
      (Σ[ y ∶ ((x : X) → Y x) ] ((a : A) (x : X) → y x ＝ f x a))
        ≃⟨ Σ-ap-≃ (λ _ → Π-ap-≃ (λ _ → funext≃ e⁻¹)) ⟩
      null-homotopy (λ a x → f x a)
        ≃∎
}
% ```
}

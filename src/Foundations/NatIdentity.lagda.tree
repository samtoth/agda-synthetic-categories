\subtree[fre-3304]{
\date{2026-04-24}
\author{fredrikbakke}
\title{Observational equality of natural numbers}
\taxon{Definition}

% ```agda
\agda{
infix 30 _Ôºù·¥Æ‚Ñï_  _Ôºù‚Ñï_

_Ôºù·¥Æ‚Ñï_ : ‚Ñï ‚Üí ‚Ñï ‚Üí Bool
zero Ôºù·¥Æ‚Ñï zero = true
suc n Ôºù·¥Æ‚Ñï suc m = n Ôºù·¥Æ‚Ñï m
_ Ôºù·¥Æ‚Ñï _ = false

{-# BUILTIN NATEQUALS _Ôºù·¥Æ‚Ñï_ #-}

_Ôºù‚Ñï_ : ‚Ñï ‚Üí ‚Ñï ‚Üí Type
n Ôºù‚Ñï m = Prop‚ÜêBool (n Ôºù·¥Æ‚Ñï m) .fst

Ôºù‚Ñï-is-prop : ‚àÄ n m ‚Üí is-prop (n Ôºù‚Ñï m)
Ôºù‚Ñï-is-prop n m = Prop‚ÜêBool (n Ôºù·¥Æ‚Ñï m) .snd

Ôºù‚Ñï-refl : ‚àÄ n ‚Üí n Ôºù‚Ñï n
Ôºù‚Ñï-refl zero = tt
Ôºù‚Ñï-refl (suc n) = Ôºù‚Ñï-refl n
}
% ```
}

\subtree[fre-3313]{
\date{2026-04-24}
\author{fredrikbakke}
\title{The observational equality predicate characterises equality}
\taxon{Theorem}

% ```agda
\agda{
Ôºù‚Ñï‚Üí : ‚àÄ {n m} ‚Üí n Ôºù‚Ñï m ‚Üí n Ôºù m
Ôºù‚Ñï‚Üí {zero} {zero} tt = refl
Ôºù‚Ñï‚Üí {zero} {suc m} ()
Ôºù‚Ñï‚Üí {suc n} {zero} ()
Ôºù‚Ñï‚Üí {suc n} {suc m} p = ap suc (Ôºù‚Ñï‚Üí p)

Ôºù‚Ñï‚Üê : ‚àÄ {n m} ‚Üí n Ôºù m ‚Üí n Ôºù‚Ñï m
Ôºù‚Ñï‚Üê {n} refl = Ôºù‚Ñï-refl n

‚Ñï-is-set : is-set ‚Ñï
‚Ñï-is-set = is-set‚Üêprop-in-Id Ôºù‚Ñï-is-prop Ôºù‚Ñï-refl (Œª n m ‚Üí Ôºù‚Ñï‚Üí {n} {m})
}
% ```
}

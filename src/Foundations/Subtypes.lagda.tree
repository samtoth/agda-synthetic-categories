\date{2025-05-09}
\title{Subtypes}
\author{samueltoth}
\taxon{Module}
\import{stt-macros}

\agda{
module Foundations.Subtypes where
}

\agda-imports{
\agda{
open import Foundations.Universes
open import Foundations.Sigma
open import Foundations.Functions
open import Foundations.QuasiEquivalences
open import Foundations.Equivalences
open import Foundations.Identity
open import Foundations.Singletons
open import Foundations.SingletonFibres
open import Foundations.FibreIdentity
open import Foundations.EquivSingleton
open import Foundations.SigmaIdentity
open import Foundations.SigmaProperties
open import Foundations.FunExtFromUnivalence
open import Foundations.PropExt
open import Foundations.PropClosure
open import Foundations.Unit
open import Foundations.Empty
open import Foundations.UniverseLifts
open import Foundations.Embeddings
open import Foundations.PropMapEmbedding
}
}

\agda{
is-subtype : ∀ {𝓤 𝓥} {A : Type 𝓤} (P : A → Type 𝓥) → Type (𝓤 ⊔ 𝓥)
is-subtype P = ∀ x → is-prop (P x)

record Subtype {𝓤} (A : Type 𝓤) 𝓥 : Type (𝓤 ⊔ lsuc 𝓥) where
  constructor mk-subtype
  field
    {family} : A → Type 𝓥
    family-is-subtype : is-subtype family

  Σ̃ : Type (𝓤 ⊔ 𝓥)
  Σ̃ = Σ A family

  Σ̃-π : Σ̃ → A
  Σ̃-π = fst

  Σ̃-π-is-prop-map : is-prop-map Σ̃-π
  Σ̃-π-is-prop-map a = is-prop←equiv-to-prop
               (fibre-straighten _ _ e⁻¹)
               (family-is-subtype a)

  Σ̃-π-is-embedding : is-embedding Σ̃-π
  Σ̃-π-is-embedding = is-embedding←is-prop-map Σ̃-π-is-prop-map

  subtype-path : ∀ {x y : Σ̃} → (Σ̃-π x ＝ Σ̃-π y) → x ＝ y
  subtype-path = is-equiv.bwd Σ̃-π-is-embedding

infix 6 _∈_

_∈_ : ∀ {𝓤 𝓥} {A : Type 𝓤} → A → Subtype A 𝓥 → Type 𝓥
a ∈ S = S .Subtype.family a

∈-is-prop
  : ∀ {𝓤 𝓥} {A : Type 𝓤} → (S : Subtype A 𝓥)
    → is-subtype (_∈ S)
∈-is-prop S = S .Subtype.family-is-subtype
}

\agda{
module _ {𝓤} {A : Type 𝓤} {𝓥} (P : Subtype A 𝓥) where
  open Subtype P
}

\subtree[stt-007N]{
\title{Equivalent subtypes}
\taxon{Definition}

\p{We say two subtypes #{S} and #{K} are \em{equal}, or \em{equivalent}, if they
contain the same types, that is: #{\forall x, x \in S \iff x \in K}.}


\agda{
Subtype-equiv
  : ∀ {𝓤 𝓥 𝓥'} {A : Type 𝓤}
      (S : Subtype A 𝓥) (K : Subtype A 𝓥')
    → Type (𝓤 ⊔ 𝓥 ⊔ 𝓥')
Subtype-equiv S K = ∀ a → ((a ∈ S) ↔ (a ∈ K))

Subtype-equiv←Id
  : ∀ {𝓤 𝓥} {A : Type 𝓤}
      {S : Subtype A 𝓥} {K : Subtype A 𝓥}
    → S ＝ K → Subtype-equiv S K
Subtype-equiv←Id = (logical←Id ∘_) ∘ happly ∘ ap Subtype.family
}
}

\subtree[stt-00S9]{
\title{Join semi-lattice structure on subtypes}
\taxon{Construction}
\p{We can construct minimal and maximal subtypes as well as
 intersection of subtypes. In order to construct the union of
 subtypes, we will require a propositional truncation, so leave this
 for later.}

\agda{
ULift-subtype
  : ∀ {𝓤 𝓥} 𝓦 {A : Type 𝓤}
    → Subtype A 𝓥 → Subtype A (𝓥 ⊔ 𝓦)
ULift-subtype 𝓦 {A} S .Subtype.family a = ULift 𝓦 (a ∈ S)
ULift-subtype 𝓦 {A} S .Subtype.family-is-subtype a
  = ULift-is-prop (∈-is-prop S a)

module SubtypeLattice {𝓤} (A : Type 𝓤) where
   _∩_ : ∀ {𝓥 𝓦} → Subtype A 𝓥 → Subtype A 𝓦 → Subtype A _
   (P ∩ Q) .Subtype.family a = (a ∈ P) × (a ∈ Q)
   (P ∩ Q) .Subtype.family-is-subtype a
     = ×-is-prop (∈-is-prop P a) (∈-is-prop Q a)

   ⊤ : Subtype A lzero
   ⊤ .Subtype.family _ = 𝟙
   ⊤ .Subtype.family-is-subtype x _ _ = refl

   ⊥ : Subtype A lzero
   ⊥ .Subtype.family _ = ∅
   ⊥ .Subtype.family-is-subtype a ()
}
}


\subtree[rie-1619]{
\title{Restriction of subtypes}
\taxon{Construction}
\p{By substitution, a subtype may be restricted along an arbitrary map into the base type.}

\agda{
module _ {𝓤 𝓥 𝓦} {A : Type 𝓤} (S : Subtype A 𝓥) {X : Type 𝓦} (f : X → A) where

  Subtype-restriction : Subtype X 𝓥
  Subtype-restriction .Subtype.family x = f x ∈ S
  Subtype-restriction .Subtype.family-is-subtype = S .Subtype.family-is-subtype ∘ f

  eq-fib-subtype-restriction : (x : X) → (x ∈ Subtype-restriction) ＝ (f x ∈ S)
  eq-fib-subtype-restriction x = refl

}
}

\subtree[stt-00FX]{
\title{Universal elements}
\taxon{Definition}

\p{Given a covariant family #{F : A \to \UU}, we call the category #{\Sigma_A F}
the category of elements. Sometimes the integral notation is used (#{\int F}).
We remark that the morphisms in the category of elements are just morphisms in
#{A} such which 'respect' covariant transport.}

##{\Hom_{\int F}((a, x), (b, y)) \simeq \Sigma_{f : \Hom(a, b)}(f^*(x) = y)}

%```agda
\agda{
Hom-вҲ«
  : вҲҖ {рқ“Ө рқ“Ҙ} {A : Type рқ“Ө} {B : A вҶ’ Type рқ“Ҙ} (Bc : is-covariant B)
      {x} (x' : B x) {y} (y' : B y)
    вҶ’ Hom (ОЈ A B) (x , x') (y , y')
    вүғ ОЈ[ f вҲ¶ Hom A x y ]
        (tr-cov-hom Bc f x' пјқ y')
Hom-вҲ« {B = B} Bc x' y'
  = Hom-ОЈвүғ вҲҷвүғ ОЈ-ap-вүғ (О» a вҶ’ Hom-cov'вүғ B Bc a x' y' eвҒ»В№)
}
%```

\p{Now fixing a family #{F}, we say that an element #{(a , x)} of #{F} is
universal if the map #{\Pi_b \Hom(a,b) \to F(b)} induced by covariant
transport at #{x : F(a)} is a fibrewise equivalence.}

%```agda
\agda{
yo
  : вҲҖ {рқ“Ө рқ“Ҙ} {A : Type рқ“Ө} {F : A вҶ’ Type рқ“Ҙ}
    вҶ’ is-covariant F
    вҶ’ вҲҖ b (x : F b) вҶ’ вҲҖ a вҶ’ Hom _ b a вҶ’ F a
yo Fc b x a f = tr-cov-hom Fc f x

is-universal
  : вҲҖ {рқ“Ө рқ“Ҙ} {A : Type рқ“Ө} {F : A вҶ’ Type рқ“Ҙ}
      вҶ’ is-covariant F
      вҶ’ ОЈ A F вҶ’ Type (рқ“ҳ вҠ” рқ“Ө вҠ” рқ“Ҙ)
is-universal {F = F} Fcov (a , x)
  = is-fibrewise-equiv (yo Fcov a x)

universal-rec
  : вҲҖ {рқ“Ө рқ“Ҙ} {A : Type рқ“Ө} {F : A вҶ’ Type рқ“Ҙ}
    вҶ’ (Fc : is-covariant F)
    вҶ’ {x : ОЈ A F}
    вҶ’ is-universal Fc x
    вҶ’ вҲҖ {b} вҶ’ F b
    вҶ’ Hom _ (x .fst) b
universal-rec Fc un = is-equiv.bwd (un _)
}
%```
}

\subtree[stt-00FY]{
\title{Universal elements are universal}
\taxon{Lemma}

\p{We show that an element is universal iff it is initial in the category of
elements.}

\proof{
\p{First, suppose that we have an initial element #{(a,x)} of #{F}. We want to show
that the map induced by covariant transport #{\phi : \Pi_b \Hom(a,b) \to F(b)} is a
fibrewise equivalence. Consider the fibre of #{\phi_b} at some #{x' : F(b)}:
##{
\begin{align*}
\fibre{\phi_b}{x'} &\simeq \Sigma_{f : \Hom(a,b)} f^*(x) = x' \\
                  &\simeq \Hom((a,x), (b, x'))
\end{align*}
}}

\p{Then this fibre is contractible precisely because #{(a,x)} is initial.}


\p{In the converse direction suppose that the transport map #{\Pi_b \Hom(a,b) \to F(b)}
is a fibrewise equivalence. Then we have that the total map which we will denote
#{\bar\phi} is an equivalence
#{A_{a/} = \Sigma_b \Hom(a,b) \simeq \Sigma_b F(b)}. First we remark that #{\bar\phi}
takes #{(a, \id)} to #{(a,x)} since [covariant transport over the
identity is the identity](stt-00DQ). Then by \ref{stt-00G0} we know that, because
#{\bar\phi} is an equivalence and #{(a, \id)} is [initial in the coslice category](stt-00FQ),
#{\bar\phi(a, \id) = (a , x)} is also an initial object.
}
}

%```agda
\agda{
universalвҶҗinitial
  : вҲҖ {рқ“Ө рқ“Ҙ} {A : Type рқ“Ө} {F : A вҶ’ Type рқ“Ҙ}
    вҶ’ (Fc : is-covariant F)
    вҶ’ {x : ОЈ A F}
    вҶ’ is-initial x
    вҶ’ is-universal Fc x
universalвҶҗinitial {F = F} Fc {x} init a
  = is-equivвҶҗis-contr-map О»
      b вҶ’ is-singleвҶҗequiv-to-single
           (Hom-вҲ« Fc (x .snd) b)
           (init (a , b))

initialвҶҗuniversal
  : вҲҖ {рқ“Ө рқ“Ҙ} {A : Type рқ“Ө} {F : A вҶ’ Type рқ“Ҙ}
    вҶ’ (Ase : is-left-segal A)
    вҶ’ (Fc : is-covariant F)
    вҶ’ {x : ОЈ A F}
    вҶ’ is-universal Fc x
    вҶ’ is-initial x
initialвҶҗuniversal {A = A}{F} Ase Fc {x , x'} univ
  = tr is-initial
       lem-id
       (is-initialвҶҗladj (total-map (yo Fc x x')) _
         (is-left-adjointвҶҗis-equiv (is-total-equivвҶҗis-fibrewise-equiv univ))
         (coslice-init'-left-segal Ase x)) where
  lem : ОЈ[ z вҲ¶ A ] (Hom _ x z) вүғ ОЈ A F
  lem = mkвүғ _ (is-total-equivвҶҗis-fibrewise-equiv univ)

  lem-id : total-map (yo Fc x x') (x , idH _) пјқ (x , x')
  lem-id = ОЈ-pathвҶ’ (refl , tr-cov-idH F Fc x')
}
%```
}

\subtree[stt-00FW]{
\title{Colimits}
\taxon{Example}

\p{Given a pair of objects #{X, Y : A}, coproducts of #{X} and #{Y} in a category
are defined as universal objects of the covariant family
#{\Hom(X,{-}) \times \Hom(Y,{-})}.}

%```agda
\agda{
Coproduct-cocone : вҲҖ {рқ“Ө} {A : Type рқ“Ө} вҶ’ A вҶ’ A вҶ’ A вҶ’ Type (рқ“ҳ вҠ” рқ“Ө)
Coproduct-cocone X Y X+Y = (Hom _ X X+Y) Г— (Hom _ Y X+Y)

module Coproduct {рқ“Ө} {A : Type рқ“Ө} (Asi : is-simplicial A) (Ase : is-segal A)
         (X Y : A)
         (let cov : вҲҖ a вҶ’ is-covariant (Hom _ a)
              cov = hom-fam-is-covвҮ”is-segalвҶҗtriangulated
                      (simp-is-triangulated Asi) .fst Ase) where

  Coproduct-cocone-is-covariant : is-covariant (Coproduct-cocone X Y)
  Coproduct-cocone-is-covariant
    = Г—-is-covariant {P = Hom _ X} {Hom _ Y} (cov X) (cov Y)

  is-coproduct : вҲҖ X+Y (cc : Coproduct-cocone X Y X+Y) вҶ’ Type (рқ“ҳ вҠ” рқ“Ө)
  is-coproduct X+Y cc
    = is-universal Coproduct-cocone-is-covariant (X+Y , cc)

  module _ X+Y (cc : Coproduct-cocone X Y X+Y) (X+Y-is-cp : is-coproduct X+Y cc)
    where
    [_] : вҲҖ {Z} вҶ’ Hom _ X Z Г— Hom _ Y Z вҶ’ Hom _ X+Y Z
    [_] = is-equiv.bwd (X+Y-is-cp _)
}
%```

\p{More generally, given diagram #{D : \mathcal{K} \to A}, colimits of #{D} are
defined to be universal objects of the covariant family
#{\Hom(D,\Delta_{-})}.}

%```agda
\agda{
Colimit-cocone : вҲҖ {рқ“Ө рқ“Ҙ} {A : Type рқ“Ө} {рқ’Ұ : Type рқ“Ҙ}
  (D : рқ’Ұ вҶ’ A) вҶ’ A вҶ’ Type (рқ“Ө вҠ” рқ“Ҙ вҠ” рқ“ҳ)
Colimit-cocone D apex = Hom _ D (const _ _ apex)

module Colimit {рқ“Ө рқ“Ҙ} {A : Type рқ“Ө} (Asi : is-simplicial A) (Ase : is-segal A)
         {рқ’Ұ : Type рқ“Ҙ} (D : рқ’Ұ вҶ’ A)
         (let cov : вҲҖ a вҶ’ is-covariant (Hom (рқ’Ұ вҶ’ A) a)
              cov = hom-fam-is-covвҮ”is-segalвҶҗtriangulated
                      (О -is-triangulated (О» _ вҶ’ simp-is-triangulated Asi)) .fst
                      (О -is-segal (О» _ вҶ’ Ase))) where
  Colimit-cocone-is-covariant : is-covariant (Colimit-cocone D)
  Colimit-cocone-is-covariant
    = covariant-base-change {P = Hom _ D} (const _ рқ’Ұ) (cov D)

  is-colimit : вҲҖ colimD (cc : Colimit-cocone D colimD) вҶ’ Type (рқ“ҳ вҠ” рқ“Ө вҠ” рқ“Ҙ)
  is-colimit colimD cc
    = is-universal Colimit-cocone-is-covariant (colimD , cc)

}
%```
}

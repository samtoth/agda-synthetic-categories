}
%```

\subtree[stt-009C]{
\title{Pushouts of homotopic maps are equivalent}
\taxon{Lemma}
\date{2025-08}

\p{Given a diagram as follows (with homotopies #{H : f \sim f'} and
#{K : g \sim g'} witnessing the commutativity): }

\quiver{
\begin{tikzcd}
	&& {S'} \\
	A && S && B
	\arrow["{f'}"', from=1-3, to=2-1]
	\arrow[equals, from=1-3, to=2-3]
	\arrow["{g'}", from=1-3, to=2-5]
	\arrow["f", from=2-3, to=2-1]
	\arrow["g"', from=2-3, to=2-5]
\end{tikzcd}
}

\p{
We have that a cocone is a pushout of #{S} iff it is a pushout of
#{S'}.
}

\proof{
\p{We first note that cocones over #{S} are equivalent to cocones over
#{S'}. Then the statement follows by applying the 3-for-2 property
on the following diagram:}

\quiver{
\begin{tikzcd}
	{X^Q} && {\rm{cocone}(S',Q)} \\
	\\
	& {\rm{cocone}(S,Q)}
	\arrow[from=1-1, to=1-3]
	\arrow[from=1-1, to=3-2]
	\arrow["\sim"', from=3-2, to=1-3]
\end{tikzcd}
}
}

%```agda
\agda{
module _ {ЁЭУд ЁЭУе ЁЭУж} {A : Type ЁЭУд} {B : Type ЁЭУе} {C : Type ЁЭУж}
         {f f' : A тЖТ B} {g g' : A тЖТ C} (H : f ~ f') (K : g ~ g')
         where
  private
    S = mk-span _ f g
    S' = mk-span _ f' g'

  open Span

  CoconeтЙГтЖРhomotopy : тИА {ЁЭУа} {Q : Type ЁЭУа} тЖТ Cocone S Q тЙГ Cocone S' Q
  CoconeтЙГтЖРhomotopy {_} {Q}
    = Cocone S _  тЙГтЯи cocone-reprтЙГ тЯй
      (╬г[ p тИ╢ (B тЖТ Q)] ╬г[ q тИ╢ (C тЖТ Q)] (p тИШ f ~ q тИШ g))
                  тЙГтЯи ╬г-ap-тЙГ (╬╗ p тЖТ ╬г-ap-тЙГ (╬╗ q тЖТ mkтЙГ _
                      (is-equiv-тИШ (~тИЩ-is-equiv (p тЧВ (H ~тБ╗┬╣)))
                      (~тИЩ-is-equiv' (q тЧВ K))))) тЯй
      ((╬г[ p тИ╢ (B тЖТ Q)] ╬г[ q тИ╢ (C тЖТ Q)] (p тИШ f' ~ q тИШ g')))
                  тЙГтЯи cocone-reprтЙГ eтБ╗┬╣ тЯй
      Cocone S' _ тЙГтИО

  Cocone-mapтЖРhomotopy : тИА {ЁЭУа} {Q : Type ЁЭУа} тЖТ Cocone S Q тЖТ Cocone S' Q
  Cocone-mapтЖРhomotopy cc = mk-cocone p q ((p тЧВ (H ~тБ╗┬╣)) ~тИЩ filler ~тИЩ q тЧВ K)
    where open Cocone cc

  is-pushoutтЖРhomotopy
    : тИА {ЁЭУЬ} {X : Type ЁЭУЬ} (cc : Cocone S X)
      тЖТ is-pushout╧Й S cc тЖТ is-pushout╧Й S' (Cocone-mapтЖРhomotopy cc)
  is-pushoutтЖРhomotopy cc po {ЁЭУа}{Q}
    = is-equiv~тИШ comm
                 (CoconeтЙГтЖРhomotopy ._тЙГ_.has-is-eqv)
                 (po {ЁЭУа}{Q}) where
    comm : cocone-map S' (Cocone-mapтЖРhomotopy cc) ~
            Cocone-mapтЖРhomotopy тИШ cocone-map S cc
    comm f = Cocone-pathтЖТ _ _ refl refl (
      Cocone.filler (cocone-map S' (Cocone-mapтЖРhomotopy cc) f) ~тИЩ ~refl
                  ~тЯи ~тИЩ-reflr _ тЯй
      Cocone.filler (cocone-map S' (Cocone-mapтЖРhomotopy cc) f)
                  ~тЯитЯй
      f тЧВ ((p тЧВ (H ~тБ╗┬╣)) ~тИЩ filler ~тИЩ q тЧВ K)
                  ~тЯи тЧВтИЩтИЩ f (p тЧВ (H ~тБ╗┬╣)) filler (q тЧВ K) тЯй
      (f тЧВ (p тЧВ (H ~тБ╗┬╣))) ~тИЩ f тЧВ filler ~тИЩ f тЧВ q тЧВ K
                  ~тЯи (тЧВтИШ f p (H ~тБ╗┬╣) ~тБ╗┬╣) тЯй~тИЩтЯи ~refl тЯй~тИЩтЯи (тЧВтИШ f q K ~тБ╗┬╣) тЯй
      (f тИШ p тЧВ (H ~тБ╗┬╣)) ~тИЩ f тЧВ filler ~тИЩ f тИШ q тЧВ K ~тИО) where open Cocone cc

  PushoutтЙГтЖРhomotopy : Pushout f' g' тЙГ Pushout f g
  PushoutтЙГтЖРhomotopy = mkтЙГ (cogap (Cocone-mapтЖРhomotopy pushout))
                          (cogap-is-equivтЖРis-pushout _
                           (is-pushoutтЖРhomotopy _ Pushout-is-pushout╧Й))
}
%```
}

\subtree[stt-0083]{
\date{2025-07-30}
\title{Adjusting Pushouts by equivalences}
\taxon{Lemma}

\p{Given #{A \simeq B}, a pushout under #{C \xleftarrow{} B
\xrightarrow{} D}, gives rise to a pushout under the induced span #{C
\xleftarrow{} A \xrightarrow{} D}.}

\p{As a corollary, we also have that the canonical pushout of the span
is equivalent to the pushout of the induced span.}

%```agda
\agda{
precomp-span : тИА {ЁЭУд ЁЭУе ЁЭУж ЁЭУЬ} {A : Type ЁЭУЬ} (S : Span ЁЭУд ЁЭУе ЁЭУж)
               тЖТ (A тЖТ S .Span.Centre) тЖТ Span ЁЭУЬ ЁЭУе ЁЭУж
precomp-span {A = A} S f = mk-span A (S.left тИШ f) (S.right тИШ f) where
  module S = Span S

precomp-cocone : тИА {ЁЭУд ЁЭУе ЁЭУж ЁЭУЬ ЁЭУЫ} {A : Type ЁЭУЬ}  {S : Span ЁЭУд ЁЭУе ЁЭУж}
                   (f : A тЖТ Span.Centre S) {D : Type ЁЭУЫ}
                 тЖТ Cocone S D
                 тЖТ Cocone (precomp-span S f) D
precomp-cocone f cc
  = mk-cocone p q (filler тЦ╕ f) where open Cocone cc

precomp-cocone-is-equiv
  : тИА {ЁЭУд ЁЭУе ЁЭУж ЁЭУЬ ЁЭУЫ} {A : Type ЁЭУЬ}  {S : Span ЁЭУд ЁЭУе ЁЭУж}
      (f : A тЖТ Span.Centre S) {D : Type ЁЭУЫ}
    тЖТ is-equiv f
    тЖТ is-equiv (precomp-cocone {S = S} f {D})
precomp-cocone-is-equiv {S = S} f feq = is-equivтЖРqiso qiso where
  module тЦ╕f {ЁЭУа}{C : Type ЁЭУа}{g}{h} =
    is-equiv (prewhisker-equiv-is-equiv feq {C} {g} {h})

  qiso : quasi-iso (precomp-cocone f)
  qiso .fst (mk-cocone p q filler)
    = mk-cocone p q (тЦ╕f.bwd filler)
  qiso .snd .fst (mk-cocone p q filler)
    = ap (mk-cocone p q) (тЦ╕f.╬╖ filler)
  qiso .snd .snd (mk-cocone p q filler)
    = ap (mk-cocone p q) (тЦ╕f.╬╡ filler)

precomp-cocone-is-pushout
  : тИА {ЁЭУд ЁЭУе ЁЭУж ЁЭУЬ ЁЭУЫ} {A : Type ЁЭУЬ}  {S : Span ЁЭУд ЁЭУе ЁЭУж}
      (f : A тЖТ Span.Centre S) {D : Type ЁЭУЫ}
      (feq : is-equiv f)
      {C : Cocone S D}
     тЖТ is-pushout╧Й _ C
     тЖТ is-pushout╧Й _ (precomp-cocone f C)
precomp-cocone-is-pushout {S = S} f feq {C = C} po
  = is-equiv-тИШ (precomp-cocone-is-equiv f feq) po

Pushout-adjust-equiv : тИА {ЁЭУд ЁЭУе ЁЭУж ЁЭУЬ} {S : Type ЁЭУд} {B : Type ЁЭУе} {C : Type ЁЭУж}
                  {f : S тЖТ B} {g : S тЖТ C} {S' : Type ЁЭУЬ}
                тЖТ (e : S' тЙГ S)
                тЖТ Pushout (f тИШ e ._тЙГ_.fwd) (g тИШ e ._тЙГ_.fwd)
                тЙГ Pushout f g
Pushout-adjust-equiv {f = f} {g} e = mkтЙГ map map-is-eq where
  module e = _тЙГ_ e

  map : Pushout _ _ тЖТ Pushout f g
  map = cogap (precomp-cocone e.fwd (pushout {f = f} {g}))

  map-is-eq : is-equiv map
  map-is-eq = cogap-is-equivтЖРis-pushout _
                (precomp-cocone-is-pushout
                   e.fwd
                   e.has-is-eqv
                   Pushout-is-pushout╧Й)

Pushout-adjust-equiv~ : тИА {ЁЭУд ЁЭУе ЁЭУж ЁЭУЬ} {S : Type ЁЭУд} {B : Type ЁЭУе} {C : Type ЁЭУж}
                  {f : S тЖТ B} {g : S тЖТ C} {S' : Type ЁЭУЬ}
                  {f' : S' тЖТ B} {g' : S' тЖТ C}
                тЖТ (e : S' тЙГ S)
                тЖТ f тИШ e ._тЙГ_.fwd ~ f'
                тЖТ g тИШ e ._тЙГ_.fwd ~ g'
                тЖТ Pushout f' g'
                тЙГ Pushout f  g
Pushout-adjust-equiv~ {f = f}{g}{S'}{f'}{g'} e H K
  = Pushout f' g' тЙГтЯи PushoutтЙГтЖРhomotopy H K тЯй
    Pushout (f тИШ _тЙГ_.fwd e) (g тИШ _тЙГ_.fwd e)
                  тЙГтЯи Pushout-adjust-equiv e тЯй
    Pushout f g тЙГтИО
}
%```
}

\subtree[stt-009E]{
\title{Extending pullbacks by equivalences}
\taxon{Proposition}

\p{Let #{S} be a span #{A \xleftarrow{f} S \xrightarrow{g} B} and #{e}
be an equivalence #{A \to A'}. Then the pushout of #{ef} against #{g}
is equivalent to the pushout of #{f} against #{g}.}
}

\subtree[stt-009F]{
\title{Pushing out equivalences}
\taxon{Lemma}

\p{Pushing out an equivalence #{e : A \toeq B} against
any map #{f : A \to C} gives an equivalence #{C \toeq B +^A C}.}

\proof{
This follows immediately from the [analogous theorem for cocartesian
squares](stt-008O)
}

%```agda
\agda{
╬╣тВВ-is-equivтЖРpushout-equiv : тИА {ЁЭУд ЁЭУе ЁЭУж} {S : Type ЁЭУд} {A : Type ЁЭУе} {B : Type ЁЭУж}
                  {f : S тЖТ A} (fe : is-equiv f)
                  (g : S тЖТ B) тЖТ is-equiv (╬╣тВВ {f = f} {g})
╬╣тВВ-is-equivтЖРpushout-equiv {f = f} fe g
 = dom-is-equivтЖРcocartesian (mk-amap g ╬╣тВБ glue) fe
     (is-cocartesianтЖРis-pushout Pushout-is-pushout╧Й)

Pushout-equiv : тИА {ЁЭУд ЁЭУе ЁЭУж} {S : Type ЁЭУд} {A : Type ЁЭУе} {B : Type ЁЭУж}
                  {f : S тЖТ A} (fe : is-equiv f) (g : S тЖТ B)
                тЖТ B тЙГ Pushout f g
Pushout-equiv fe g = mkтЙГ _ (╬╣тВВ-is-equivтЖРpushout-equiv fe g)
}
%```
}

\subtree[stt-009G]{
\title{Vertical pasting of pushouts}
\taxon{Lemma}

\p{Given squares arranged vertically like so:}

\quiver{
\begin{tikzcd}
	A && C \\
	\\
	{B} && \bullet \\
	\\
	{B'} && \bullet
	\arrow[from=1-1, to=1-3]
	\arrow["g", from=1-1, to=3-1]
	\arrow["fg"', curve={height=12pt}, from=1-1, to=5-1]
	\arrow[from=1-3, to=3-3]
	\arrow[from=3-1, to=3-3]
	\arrow["f", from=3-1, to=5-1]
	\arrow["\lrcorner"{anchor=center, pos=0.125, rotate=180}, draw=none, from=3-3, to=1-1]
	\arrow[from=3-3, to=5-3]
	\arrow[from=5-1, to=5-3]
	\arrow["\lrcorner"{anchor=center, pos=0.125, rotate=180}, draw=none, from=5-3, to=3-1]
\end{tikzcd}
}

\p{The result of pushing out the top span followed by the bottom span
is equivalent to pushing out the outer span all at once. In symbols,
#{B' +^B (B +^A + C) \simeq B' +^A C}.}

%```
\agda{
module _ {ЁЭУд ЁЭУе ЁЭУж ЁЭУЬ} {A : Type ЁЭУд} {B : Type ЁЭУе} {B' : Type ЁЭУж}
         {C : Type ЁЭУЬ} (f : B тЖТ B') (g : A тЖТ B) (h : A тЖТ C) where

  private
    US : Span ЁЭУд ЁЭУе ЁЭУЬ
    US = mk-span A g h

    LS : Span ЁЭУе ЁЭУж  (ЁЭУд тКФ ЁЭУе тКФ ЁЭУЬ)
    LS = mk-span B f (╬╣тВБ {f = g} {h})

    TS : Span ЁЭУд ЁЭУж ЁЭУЬ
    TS = mk-span A (f тИШ g) h

    lemma : тИА {ЁЭУа}{Q : Type ЁЭУа}(p : B' тЖТ Q)
            тЖТ (╬г[ cc тИ╢ Cocone US Q ] (p тИШ f ~ Cocone.p cc))
            тЙГ ╬г[ q тИ╢ (C тЖТ Q) ] (p тИШ f тИШ g ~ q тИШ h)
    lemma {ЁЭУа}{Q}p = ╬г-ap-тЙГ (╬╗ cc тЖТ funextтЙГ eтБ╗┬╣) тИЩтЙГ equivтЖРqiso iso where
      open _тЙЕ_

      iso : _ тЙЕ _
      iso .fwd (mk-cocone q r H , K) = r , happly K тЦ╕ g ~тИЩ H
      iso .fwd-iso .fst (q , H) = (mk-cocone (p тИШ f) q H) , refl
      iso .fwd-iso .snd .fst cc@(mk-cocone p q filler , refl) = refl
      iso .fwd-iso .snd .snd (p , H) = refl

  extend-cocone : тИА {ЁЭУа}{Q : Type ЁЭУа} тЖТ Cocone LS Q тЙГ Cocone TS Q
  extend-cocone {ЁЭУа}{Q}
    = Cocone LS _ тЙГтЯи cocone-reprтЙГ тЯй
      ╬г[ p тИ╢ (B' тЖТ Q) ]
       ╬г[ q тИ╢ (Pushout g h тЖТ Q)] (p тИШ f ~ q тИШ ╬╣тВБ)
                  тЙГтЯи ╬г-ap-тЙГ (╬╗ p тЖТ ╬г-ap-тЙГ-fst (Pushout-UPтЙГ)) тЯй
      (╬г[ p тИ╢ (B' тЖТ Q) ] ╬г[ q тИ╢ Cocone US Q ] (p тИШ f ~ q .Cocone.p))
                  тЙГтЯи ╬г-ap-тЙГ lemma тЯй
      (╬г[ p тИ╢ (B' тЖТ Q) ]
        ╬г[ q тИ╢ (C тЖТ Q)] (p тИШ f тИШ g ~ q тИШ h))
                  тЙГтЯи cocone-reprтЙГ eтБ╗┬╣ тЯй
      Cocone TS _ тЙГтИО

  Pushout-vert-тИШ : Pushout (f тИШ g) h тЙГ Pushout f (╬╣тВБ {f = g} {h})
  Pushout-vert-тИШ = mkтЙГ map (cogap-is-equivтЖРis-pushout cc ╬╗
    {ЁЭУа}{Q} тЖТ is-equiv~тИШ (H Q)
                        (extend-cocone ._тЙГ_.has-is-eqv)
                        (Pushout-is-pushout╧Й)) where
    cc = (extend-cocone ._тЙГ_.fwd pushout)
    map : Pushout (f тИШ g) h тЖТ Pushout f (╬╣тВБ {f = g} {h})
    map = cogap cc

    H : тИА {ЁЭУа}(Q : Type ЁЭУа)
        тЖТ cocone-map (mk-span A (f тИШ g) h) cc
        ~ _тЙГ_.fwd extend-cocone тИШ cocone-map (mk-span B f ╬╣тВБ) pushout
    H Q f = Cocone-pathтЖТ _ _ refl refl
      ( f тЧВ (glue тИШ g ~тИЩ ╬╣тВВ тЧВ glue) ~тИЩ ~refl
                                   ~тЯи ~тИЩ-reflr _ тЯй
       f тЧВ (glue тЦ╕ g ~тИЩ ╬╣тВВ тЧВ glue) ~тЯи тЧВтИЩ f (glue тЦ╕ g) _ тЯй
       (f тЧВ glue тЦ╕ g) ~тИЩ (f тЧВ ╬╣тВВ тЧВ glue)
                                   ~тЯи ~refl тЯй~тИЩтЯи (тЧВтИШ f ╬╣тВВ glue ~тБ╗┬╣) тЯй
       f тЧВ (glue тЦ╕ g) ~тИЩ f тИШ ╬╣тВВ тЧВ glue ~тИО)
}
%```
}

\subtree[stt-009H]{
\title{Proof of \ref{stt-009F}}
\taxon{Proof}

\p{
Consider the following diagram:
}
\quiver{
\begin{tikzcd}
	A && C \\
	\\
	{A'} && {A' +^A C} \\
	\\
	{A''} && \bullet \\
	{A''} &&& {A'' +^A C}
	\arrow[from=1-1, to=1-3]
	\arrow["g", from=1-1, to=3-1]
	\arrow["fg"', curve={height=12pt}, from=1-1, to=6-1]
	\arrow[from=1-3, to=3-3]
	\arrow[from=3-1, to=3-3]
	\arrow["f", from=3-1, to=5-1]
	\arrow["\lrcorner"{anchor=center, pos=0.125, rotate=180}, draw=none, from=3-3, to=1-1]
	\arrow["\sim"', from=3-3, to=5-3]
	\arrow[from=3-3, to=6-4]
	\arrow[from=5-1, to=5-3]
	\arrow[equals, from=5-1, to=6-1]
	\arrow["\lrcorner"{anchor=center, pos=0.125, rotate=180}, draw=none, from=5-3, to=3-1]
	\arrow["\sim"', from=5-3, to=6-4]
	\arrow[from=6-1, to=6-4]
\end{tikzcd}
}

\p{By \ref{stt-009G}, the cogap map at the bottom right is an
equivalence, and by \ref{stt-009E}, so is the map opposite #{f}.
Then the 3-for-2 property for equivalences completes our proof.}

%```agda
\agda{
module _ {ЁЭУд ЁЭУе ЁЭУж ЁЭУЬ} {A : Type ЁЭУд} {B : Type ЁЭУе} {B' : Type ЁЭУж}
         {C : Type ЁЭУЬ} {f : B тЖТ B'} (fe : is-equiv f)
         (g : A тЖТ B) (h : A тЖТ C) where
  Pushout-vert-extendтЙГ : Pushout g h тЙГ Pushout (f тИШ g) h
  Pushout-vert-extendтЙГ = Pushout-equiv fe (╬╣тВБ {f = g} {h})
                      тИЩтЙГ Pushout-vert-тИШ f g h eтБ╗┬╣
}
%```
}

\subtree[stt-00EU]{
\date{2026-02-24}
\title{The functorial action of pushouts on equivalences of span diagrams}
\author{fredrikbakke}
\taxon{Lemma}

%```agda
\agda{
module _ {ЁЭУд ЁЭУе ЁЭУж ЁЭУд' ЁЭУе' ЁЭУж'} {S : Span ЁЭУд ЁЭУе ЁЭУж} {S' : Span ЁЭУд' ЁЭУе' ЁЭУж'} where

  PushoutтЙГтЖРSpan-equiv'
    : Span-equiv' S' S
    тЖТ Pushout (S' .Span.left) (S' .Span.right)
    тЙГ Pushout (S .Span.left) (S .Span.right)
  PushoutтЙГтЖРSpan-equiv' (centreтЙГ , leftтЙГ , left-comm , rightтЙГ , right-comm)
    = Pushout (Span.left S') (Span.right S')
      тЙГтЯи Pushout-adjust-equiv~ centreтЙГ left-comm' right-comm' тЯй
      Pushout (_тЙГ_.bwd leftтЙГ тИШ Span.left S) (_тЙГ_.bwd rightтЙГ тИШ Span.right S)
      тЙГтЯи Pushout-vert-extendтЙГ
            ((leftтЙГ eтБ╗┬╣) ._тЙГ_.has-is-eqv)
            (Span.left S)
            (_тЙГ_.bwd rightтЙГ тИШ Span.right S) eтБ╗┬╣
        тИЩтЙГ pushout-comm
        тИЩтЙГ Pushout-vert-extendтЙГ
              ((rightтЙГ eтБ╗┬╣) ._тЙГ_.has-is-eqv)
              (Span.right S)
              (Span.left S) eтБ╗┬╣
        тИЩтЙГ pushout-comm тЯй
      Pushout (Span.left S) (Span.right S)
      тЙГтИО
    where
    left-comm'
      : _тЙГ_.bwd leftтЙГ тИШ Span.left S тИШ _тЙГ_.fwd centreтЙГ ~ Span.left S'
    left-comm' p
      = sym (ap (_тЙГ_.bwd leftтЙГ) (left-comm p))
      тИЩ _тЙГ_.╬╖ leftтЙГ (Span.left S' p)

    right-comm'
      : _тЙГ_.bwd rightтЙГ тИШ Span.right S тИШ _тЙГ_.fwd centreтЙГ ~ Span.right S'
    right-comm' p
      = sym (ap (_тЙГ_.bwd rightтЙГ) (right-comm p))
      тИЩ _тЙГ_.╬╖ rightтЙГ (Span.right S' p)

  PushoutтЙГтЖРSpan-equiv
    : (e : Span-equiv S S')
    тЖТ Pushout (S' .Span.left) (S' .Span.right)
    тЙГ Pushout (S .Span.left) (S .Span.right)
  PushoutтЙГтЖРSpan-equiv e
    = PushoutтЙГтЖРSpan-equiv' (inverse-componentsтЖРSpan-equiv e)
}
%```
}

\subtree[tot-023F]{
\title{Fibre inclusion}
\taxon{Definition}



%```agda
\agda{

null-htpy-fibre-map
  : ∀ {𝓤 𝓥 𝓦} {A : Type 𝓤} {B : Type 𝓥} {Q : Type 𝓦}
      (f : A → B) (g : Q → A) → (x : null-homotopy (f ∘ g))
    → Q → fibre f (x .fst)
null-htpy-fibre-map f g x q = g q , sym (x .snd q)

is-fibre-incl
  : ∀ {𝓤 𝓥 𝓦} {A : Type 𝓤} {B : Type 𝓥} {Q : Type 𝓦}
      (f : A → B) (g : Q → A) → null-homotopy (f ∘ g)
    → Type (𝓤 ⊔ 𝓥 ⊔ 𝓦)
is-fibre-incl f g n = is-equiv (null-htpy-fibre-map f g n)

record fibre-inclusion
         {𝓤 𝓥} {A : Type 𝓤} {B : Type 𝓥} (f : A → B) 𝓦
         : Type (𝓤 ⊔ 𝓥 ⊔ lsuc 𝓦)
         where
  field
    { Fib } : Type 𝓦
    incl : Fib → A
    null-htpy : null-homotopy (f ∘ incl)
    has-is-fibre-incl : is-fibre-incl f incl null-htpy

  * : B
  * = null-htpy .fst

  to-fib : Fib → fibre f *
  to-fib x = (incl x , sym (null-htpy .snd x))
}
%```
}

\subtree[tot-0395]{

%```agda
\agda{
module semi-straight-3x3 {𝓤1 𝓤2 𝓤3 𝓥1 𝓥2 𝓥3 𝓦1 𝓦2 𝓦3}
         (B : Cospan 𝓤2 𝓤1 𝓤3)
         (A : Cospanᵈ B 𝓥2 𝓥1 𝓥3)
         (C : Cospanᵈ B 𝓦2 𝓦1 𝓦3)
         where
  open Cospanᵈ

  private
    open Bi-fam
    X : Bi-fam 𝓤1 𝓥1 𝓦1
    X .Centre = Cospan.Left B
    X .Left = Leftᵈ A
    X .Right = Leftᵈ C

    Y : Bi-fam 𝓤2 𝓥2 𝓦2
    Y .Centre = Cospan.Centre B
    Y .Left = Centreᵈ A
    Y .Right = Centreᵈ C

    Z : Bi-fam 𝓤3 𝓥3 𝓦3
    Z .Centre = Cospan.Right B
    Z .Left = Rightᵈ A
    Z .Right = Rightᵈ C

    XY : Bi-fam-map X Y
    XY .Bi-fam-map.h₂ = Cospan.left B
    XY .Bi-fam-map.h₁ = A .leftᵈ
    XY .Bi-fam-map.h₃ = C .leftᵈ

    ZY : Bi-fam-map Z Y
    ZY .Bi-fam-map.h₂ = Cospan.right B
    ZY .Bi-fam-map.h₁ = A .rightᵈ
    ZY .Bi-fam-map.h₃ = C .rightᵈ

  hor-cospan : Cospan (𝓤2 ⊔ 𝓥2 ⊔ 𝓦2) (𝓤1 ⊔ 𝓥1 ⊔ 𝓦1) (𝓤3 ⊔ 𝓥3 ⊔ 𝓦3)
  hor-cospan .Cospan.Centre = fibred-product Y
  hor-cospan .Cospan.Left = fibred-product X
  hor-cospan .Cospan.left = fibred-product₁ XY
  hor-cospan .Cospan.Right = fibred-product Z
  hor-cospan .Cospan.right = fibred-product₁ ZY

  vert-cospan : Bi-fam (𝓤1 ⊔ 𝓤2 ⊔ 𝓤3) (𝓥1 ⊔ 𝓥2 ⊔ 𝓥3) (𝓦1 ⊔ 𝓦2 ⊔ 𝓦3)
  vert-cospan .Centre = Pullback-of-cospan B
  vert-cospan .Left = pullback-cospanᵈ A
  vert-cospan .Right = pullback-cospanᵈ C


  private
    repr : Type (𝓤1 ⊔ 𝓤2 ⊔ 𝓤3 ⊔ 𝓥1 ⊔ 𝓥2 ⊔ 𝓥3 ⊔ 𝓦1 ⊔ 𝓦2 ⊔ 𝓦3)
    repr = Σ[ a ∶ fibred-product X ] Σ[ b ∶ fibred-product Z ]
             fibred-product-path Y (fibred-product₁ XY a) (fibred-product₁ ZY b)

    hor-cospan-repr→ : Pullback-of-cospan hor-cospan → repr
    hor-cospan-repr→ = total-map (λ a → total-map λ b → fibred-product-path←Id Y)

    lemma : fibred-product vert-cospan ≃ repr
    lemma ._≃_.fwd ((x , x' , p) , (y , y' , q) , (z , z' , r))
       = ((x , y , z) , (x' , y' , z') , (p , q , r))
    lemma ._≃_.has-is-eqv .is-equiv.qiso .fst
      ((x , y , z) , (x' , y' , z') , (p , q , r))
      = ((x , x' , p) , (y , y' , q) , (z , z' , r))
    lemma ._≃_.has-is-eqv .is-equiv.qiso .snd .fst = ~refl
    lemma ._≃_.has-is-eqv .is-equiv.qiso .snd .snd = ~refl
    lemma ._≃_.has-is-eqv .is-equiv.coherent = ~refl

  comparison-map : Pullback-of-cospan hor-cospan → fibred-product vert-cospan
  comparison-map = _≃_.bwd lemma ∘ hor-cospan-repr→

  comparison-map-is-equiv : is-equiv comparison-map
  comparison-map-is-equiv
    = is-equiv-∘
        (is-equiv⁻¹ (_≃_.has-is-eqv lemma))
        ((is-total-equiv←is-fibrewise-equiv
            (λ a → is-total-equiv←is-fibrewise-equiv
              (λ b → fibred-product-path←Id-is-equiv _))))

  3×3 : Pullback-of-cospan hor-cospan ≃ fibred-product vert-cospan
  3×3 = mk≃ comparison-map comparison-map-is-equiv

-- module _ {𝓤1 𝓤2 𝓤3 𝓥1 𝓥2 𝓥3 𝓦1 𝓦2 𝓦3}
--          (A : Cospan 𝓥2 𝓥1 𝓥3)
--          (B : Cospan 𝓤2 𝓤1 𝓤3)
--          (C : Cospan 𝓦2 𝓦1 𝓦3)
--          (F : Cospan-map A B)
--          (G : Cospan-map C B)
--          where
--   open Cospan
--   open Cospan-map

--   private
--     X : Cospan 𝓤1 𝓥1 𝓦1
--     X .Centre = B .Left
--     X .Left = A .Left
--     X .left = Cospan-map.h₁ F
--     X .Right = C .Left
--     X .right = Cospan-map.h₁ G

--     Y : Cospan 𝓤2 𝓥2 𝓦2
--     Y .Centre = B .Centre
--     Y .Left = A .Centre
--     Y .left = Cospan-map.h₂ F
--     Y .Right = C .Centre
--     Y .right = Cospan-map.h₂ G

--     Z : Cospan 𝓤3 𝓥3 𝓦3
--     Z .Centre = B .Right
--     Z .Left = A .Right
--     Z .left = h₃ F
--     Z .Right = C .Right
--     Z .right = h₃ G

--     P : Cospan-map X Y
--     P .h₁ = left A
--     P .h₂ = left B
--     P .h₃ = left C
--     P .H = sym ∘ H F
--     P .K = sym ∘ H G

--     Q : Cospan-map Z Y
--     Q .h₁ = right A
--     Q .h₂ = right B
--     Q .h₃ = right C
--     Q .H = sym ∘ K F
--     Q .K = sym ∘ K G

--   Aᵈ : Cospanᵈ B (𝓥2 ⊔ 𝓤2) (𝓥1 ⊔ 𝓤1) (𝓥3 ⊔ 𝓤3)
--   Aᵈ = fibre-cospanᵈ F

--   Cᵈ : Cospanᵈ B (𝓦2 ⊔ 𝓤2) (𝓦1 ⊔ 𝓤1) (𝓦3 ⊔ 𝓤3)

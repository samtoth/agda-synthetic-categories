\subtree[tot-023F]{
\title{Fibre inclusion}
\taxon{Definition}



%```agda
\agda{

null-htpy-fibre-map
  : вИА {рЭУ§ рЭУ• рЭУ¶} {A : Type рЭУ§} {B : Type рЭУ•} {Q : Type рЭУ¶}
      (f : A вЖТ B) (g : Q вЖТ A) вЖТ (x : null-homotopy (f вИШ g))
    вЖТ Q вЖТ fibre f (x .fst)
null-htpy-fibre-map f g x q = g q , sym (x .snd q)

is-fibre-incl
  : вИА {рЭУ§ рЭУ• рЭУ¶} {A : Type рЭУ§} {B : Type рЭУ•} {Q : Type рЭУ¶}
      (f : A вЖТ B) (g : Q вЖТ A) вЖТ null-homotopy (f вИШ g)
    вЖТ Type (рЭУ§ вКФ рЭУ• вКФ рЭУ¶)
is-fibre-incl f g n = is-equiv (null-htpy-fibre-map f g n)

record fibre-inclusion
         {рЭУ§ рЭУ•} {A : Type рЭУ§} {B : Type рЭУ•} (f : A вЖТ B) рЭУ¶
         : Type (рЭУ§ вКФ рЭУ• вКФ lsuc рЭУ¶)
         where
  field
    { Fib } : Type рЭУ¶
    incl : Fib вЖТ A
    null-htpy : null-homotopy (f вИШ incl)
    has-is-fibre-incl : is-fibre-incl f incl null-htpy

  * : B
  * = null-htpy .fst

  to-fib : Fib вЖТ fibre f *
  to-fib x = (incl x , sym (null-htpy .snd x))


module semi-straight-3x3 {рЭУ§1 рЭУ§2 рЭУ§3 рЭУ•1 рЭУ•2 рЭУ•3 рЭУ¶1 рЭУ¶2 рЭУ¶3}
         (B : Cospan рЭУ§2 рЭУ§1 рЭУ§3)
         (A : CospanбµИ B рЭУ•2 рЭУ•1 рЭУ•3)
         (C : CospanбµИ B рЭУ¶2 рЭУ¶1 рЭУ¶3)
         where
  open CospanбµИ

  private
    open Fam-cospan
    X : Fam-cospan рЭУ§1¬†рЭУ•1 рЭУ¶1
    X .Centre = Cospan.Left B
    X .Left = LeftбµИ A
    X .Right = LeftбµИ C

    Y : Fam-cospan рЭУ§2 рЭУ•2 рЭУ¶2
    Y .Centre = Cospan.Centre B
    Y .Left = CentreбµИ A
    Y .Right = CentreбµИ C

    Z : Fam-cospan рЭУ§3 рЭУ•3 рЭУ¶3
    Z .Centre = Cospan.Right B
    Z .Left = RightбµИ A
    Z .Right = RightбµИ C

    XY : Fam-cospan-map X Y
    XY .Fam-cospan-map.hвВВ = Cospan.left B
    XY .Fam-cospan-map.hвВБ = A .leftбµИ
    XY .Fam-cospan-map.hвВГ = C .leftбµИ

    ZY : Fam-cospan-map Z Y
    ZY .Fam-cospan-map.hвВВ = Cospan.right B
    ZY .Fam-cospan-map.hвВБ = A .rightбµИ
    ZY .Fam-cospan-map.hвВГ = C .rightбµИ

  hor-cospan : Cospan (рЭУ§2 вКФ рЭУ•2 вКФ рЭУ¶2) (рЭУ§1 вКФ рЭУ•1 вКФ рЭУ¶1) (рЭУ§3 вКФ рЭУ•3 вКФ рЭУ¶3)
  hor-cospan .Cospan.Centre = pullbackвВА-fam Y
  hor-cospan .Cospan.Left = pullbackвВА-fam X
  hor-cospan .Cospan.left = pullbackвВБ-fam XY
  hor-cospan .Cospan.Right = pullbackвВА-fam Z
  hor-cospan .Cospan.right = pullbackвВБ-fam ZY

  vert-cospan : Fam-cospan (рЭУ§1 вКФ рЭУ§2 вКФ рЭУ§3) (рЭУ•1 вКФ рЭУ•2 вКФ рЭУ•3) (рЭУ¶1 вКФ рЭУ¶2 вКФ рЭУ¶3)
  vert-cospan .Centre = Pullback-of-cospan B
  vert-cospan .Left = pullback-cospanбµИ A
  vert-cospan .Right = pullback-cospanбµИ C


  private
    repr : Type (рЭУ§1 вКФ рЭУ§2 вКФ рЭУ§3 вКФ рЭУ•1 вКФ рЭУ•2 вКФ рЭУ•3 вКФ рЭУ¶1 вКФ рЭУ¶2 вКФ рЭУ¶3)
    repr = ќ£[ a вИґ pullbackвВА-fam X ] ќ£[ b вИґ pullbackвВА-fam Z ]
             pullbackвВА-fam-path Y (pullbackвВБ-fam XY a) (pullbackвВБ-fam ZY b)

    hor-cospan-reprвЖТ : Pullback-of-cospan hor-cospan вЖТ repr
    hor-cospan-reprвЖТ = total-map (ќї a вЖТ total-map ќї b вЖТ pullbackвВА-fam-pathвЖРId Y)

    lemma : pullbackвВА-fam vert-cospan вЙГ repr
    lemma ._вЙГ_.fwd ((x , x' , p) , (y , y' , q) , (z , z' , r))
       = ((x , y , z) , (x' , y' , z') , (p , q , r))
    lemma ._вЙГ_.has-is-eqv .is-equiv.qiso .fst
      ((x , y , z) , (x' , y' , z') , (p , q , r))
      = ((x , x' , p) , (y , y' , q) , (z , z' , r))
    lemma ._вЙГ_.has-is-eqv .is-equiv.qiso .snd .fst = ~refl
    lemma ._вЙГ_.has-is-eqv .is-equiv.qiso .snd .snd = ~refl
    lemma ._вЙГ_.has-is-eqv .is-equiv.coherent = ~refl

  3√Ч3 : pullbackвВА-fam vert-cospan вЙГ Pullback-of-cospan hor-cospan
  3√Ч3 = lemma
      вИЩвЙГ (mkвЙГ hor-cospan-reprвЖТ
                (is-total-equivвЖРis-fibrewise-equiv
                  (ќї a вЖТ is-total-equivвЖРis-fibrewise-equiv
                    (ќї b вЖТ pullbackвВА-fam-pathвЖРId-is-equiv _))) eвБї¬є)



\subtree[stt-00B6]{
\title{Groupoids}
\taxon{Definition}

\p{A type is a \em{groupoid}, or \em{simplicially discrete}, if it is local with
respect to #{\Delta^1}. This forms a sigma closed reflective subuniverse.}

%```agda
\agda{
is-groupoid : ∀ {𝓤} (A : Type 𝓤) → Type (𝓘 ⊔ 𝓤)
is-groupoid = is-null (point Δ¹)

Grpd-SubU : ∀ {𝓤} → SubU 𝓤 (𝓤 ⊔ 𝓘)
Grpd-SubU = Null-SubU (point Δ¹) _

Grpd-gSubU : gSubU (_⊔ 𝓘)
Grpd-gSubU = Null-gSubU (point Δ¹)

Grpd-is-globally-reflective
  : is-globally-reflective Grpd-gSubU
Grpd-is-globally-reflective = Null-globally-reflective

Grpd-gRSubU : gRSubU (_⊔ 𝓘)
Grpd-gRSubU .gRSubU.GS = Grpd-gSubU
Grpd-gRSubU .gRSubU.has-is-globally-reflective = Grpd-is-globally-reflective

open gSubU Grpd-gSubU public using () renaming
  ( ∈S←equiv to is-groupoid←equiv)

open gReflectiveClosure Grpd-gRSubU public using () renaming
  ( Π∈S to Π-is-groupoid
  ; ULift∈S to ULift-is-groupoid
  ; 𝟙∈S to 𝟙-is-groupoid
  ; ∈S←is-singleton to is-groupoid←is-singleton
  ; ∈S←retract to is-groupoid←retract
  ; Pullback∈S to Pullback-is-groupoid
  ; fibre∈S to fibre-is-groupoid
  ; ×∈S to ×-is-groupoid
  ; ＝∈S to ＝-is-groupoid
  ; ~∈S to ~-is-groupoid
  ; retract∈S to retract-is-groupoid
  ; biinv∈S to biinv-is-groupoid
  ; ≃∈S to ≃-is-groupoid
  ; Equaliser∈S to Equaliser-is-groupoid
  ; Seq-lim∈S to Seq-lim-is-groupoid
  ; preidempotent-map∈S to preidempotent-map-is-groupoid
  ; qidempotent-map∈S to qidempotent-map-is-groupoid
  ; Retracts∈S to Retracts-is-groupoid)

Σ-is-groupoid : is-globally-Σ-closed Grpd-gSubU
Σ-is-groupoid = Null-globally-Σ-closed

module Grpd where

  open gSubU Grpd-gSubU public using ()
  open gRSubUInduction Grpd-gRSubU Σ-is-groupoid public
  open gReflectiveClosure Grpd-gRSubU public
  open gRSubU Grpd-gRSubU public
}
%```

%```agda
\agda{
Hom←Id
  : ∀ {𝓤} {A : Type 𝓤} → ∀ {a b} → a ＝ b → Hom A a b
Hom←Id refl = idH _

Hom-gpd
  : ∀ {𝓤} {A : Type 𝓤} → is-groupoid A
  → ∀ {a b} → is-equiv (Hom←Id {_}{A}{a}{b})
Hom-gpd gpd {a} {b}
  = is-equiv~∘ {f = _≃_.bwd Homᵈ-repr≃} {g = g ∘ f}
      (λ where refl → refl)
      (is-equiv⁻¹ (_≃_.has-is-eqv Homᵈ-repr≃))
      (is-equiv-∘ {f = g} {g = f}
        (total-is-equiv←fst-is-equiv (gpd tt))
        (is-equiv⁻¹ (Σ-＝singl ._≃_.has-is-eqv))) where
  f : a ＝ b → Σ[ c ∶ _ ] ((c ＝ a) × (c ＝ b))
  f = _≃_.bwd Σ-＝singl
  g : Σ[ c ∶ _ ] ((c ＝ a) × (c ＝ b))
    → Σ[ g ∶ (Δ¹ → _) ] Σ (g i0 ＝ a) (λ hom2 → g i1 ＝ b)
  g (a , p , q) = (const _ _ a , p , q)
}
%```
}


\subtree[stt-00B7]{
\title{Groupoids are left(right)-local types}
\taxon{Theorem}

\p{A type is a groupoid iff it is local with respect to the map #{1 \to \Delta^1}
which picks out the left endpoint iff it is local to the map that picks out the
right endpoint.}

%```agda
\agda{
is-left-local : ∀ {𝓤} (A : Type 𝓤) → Type (𝓘 ⊔ 𝓤)
is-left-local = is-local (λ (_ _ : 𝟙) → i0)

is-groupoid←is-left : ∀ {𝓤} {A : Type 𝓤} → is-left-local A → is-groupoid A
is-groupoid←is-left {_}{A} il x
  = is-equiv~∘ lem (is-equiv⁻¹ (il x))
                   point-is-equiv where
  open is-equiv (il x)

  lem : const A Δ¹ ~ bwd ∘ point
  lem = il x ◂eqv ((ε ▸ point) ~⁻¹)


is-left←is-groupoid : ∀ {𝓤} {A : Type 𝓤} → is-groupoid A → is-left-local A
is-left←is-groupoid {_} {A} gp x
  =  is-equiv~∘ H point-is-equiv (is-equiv⁻¹ (gp x)) where
  open is-equiv (gp x)

  H : precomp A (point i0) ~ point ∘ bwd
  H = ((point ◂ η) ~⁻¹) ▸eqv (gp x)
}
%```
}

\subtree[fre-1337]{
\title{The Hom types of a Segal type are groupoids}
\date{2026-03-28}
\author{fredrikbakke}
\taxon{Theorem}

\p{
If #{A} is a [Segal type](stt-00AI), then every hom type #{\Hom_A(a,b)} is a
[groupoid](stt-00B6). In fact, any type whose left and right homotopies characterise
equality have groupoid Hom-types.
}

%```agda
\agda{
is-groupoid←Id←Hom
  : {𝓤 : Level} {A : Type 𝓤}
  → ({a b : A} → Hom A a b → a ＝ b)
  → is-groupoid A
is-groupoid←Id←Hom {A = A} hom→id
  = is-groupoid←is-left λ _ → precomp-i0-is-equiv where

    restrict : (h : Δ¹ → A) (t : Δ¹) → Hom A (h i0) (h t)
    restrict h t .Homᵈ.hom j = h (j ∧ t)
    restrict h t .Homᵈ.hom0 = ap h 0-init
    restrict h t .Homᵈ.hom1 = ap h (∧-comm ∙ 1-top)

    precomp-i0-is-equiv : is-equiv (precomp A (point i0))
    precomp-i0-is-equiv
      = is-equiv←qiso
          ( const A Δ¹ ∘ ev tt
          , (λ h → funext→ λ t → hom→id (restrict h t))
          , ~refl)

module HomGroupoid
  {𝓤 : Level} {A : Type 𝓤} {a b : A} {f g : Hom A a b} (α : Hom (Hom A a b) f g)
  where

  right-square : Δ² → A
  right-square p = α .Homᵈ.hom (p .Poly.Δ².t) .Homᵈ.hom (p .Poly.Δ².s)

  left-square : Δ² → A
  left-square p = α .Homᵈ.hom (p .Poly.Δ².s) .Homᵈ.hom (p .Poly.Δ².t)

  α0-path : Hom-path (α .Homᵈ.hom i0) f
  α0-path = IdS←Id ⦃ IdS-Hom ⦄ (α .Homᵈ.hom0)

  α1-path : Hom-path (α .Homᵈ.hom i1) g
  α1-path = IdS←Id ⦃ IdS-Hom ⦄ (α .Homᵈ.hom1)

  diag-hom : Hom A a b
  diag-hom .Homᵈ.hom i = α .Homᵈ.hom i .Homᵈ.hom i
  diag-hom .Homᵈ.hom0 = α0-path .fst i0 ∙ f .Homᵈ.hom0
  diag-hom .Homᵈ.hom1 = α1-path .fst i1 ∙ g .Homᵈ.hom1

  right-proof-ap
    : {i j : Δ¹} {p q : j ≤ i}
      → ap right-square Δ²-refl ＝ refl
  right-proof-ap {i} {j} {p} {q}
    = ap (ap right-square) (Δ²-is-set _ _ _ _)
    ∙ sym (ap-∘ right-square (λ m → (i , j) ⦃ m ⦄) (is-prop-separated _ _ p q))
    ∙ sym (∙-reflr _)
    ∙ ∙-reflr (ap (λ m → right-square ((i , j) ⦃ m ⦄)) (is-prop-separated _ _ p q))
    ∙ ap-const (is-prop-separated _ _ p q)

  left-proof-ap
    : {i j : Δ¹} {p q : j ≤ i}
    → ap left-square Δ²-refl ＝ refl
  left-proof-ap {i} {j} {p} {q}
    = ap (ap left-square) (Δ²-is-set _ _ _ _)
    ∙ sym (ap-∘ left-square (λ m → (i , j) ⦃ m ⦄) (is-prop-separated _ _ p q))
    ∙ sym (∙-reflr _)
    ∙ ∙-reflr (ap (λ m → left-square ((i , j) ⦃ m ⦄)) (is-prop-separated _ _ p q))
    ∙ ap-const (is-prop-separated _ _ p q)

  right-horn~ : right-square ∘ Λ[2,1]-incl ~ make-horn (idH b) f
  right-horn~ =
    pushout-rec-unique
      (mk-cocone (f .Homᵈ.hom) (idH b .Homᵈ.hom) (λ _ → f .Homᵈ.hom1 ∙ refl))
      (right-square ∘ Λ[2,1]-incl)
      (α0-path .fst)
      (λ i → α .Homᵈ.hom i .Homᵈ.hom1)
      ( λ _ →
        ap (_∙ α .Homᵈ.hom i0 .Homᵈ.hom1)
            ( ap-∘ right-square Λ[2,1]-incl (glue tt)
            ∙ ap (ap right-square) (pushout-rec-apβ {c = Λ[2,1]-Δ²-cocone} tt)
            ∙ right-proof-ap)
      ∙ sym (α0-path .snd .snd)
      ∙ ap (α0-path .fst i1 ∙_) (sym (∙-reflr (f .Homᵈ.hom1))))

  left-horn~ : left-square ∘ Λ[2,1]-incl ~ make-horn g (idH a)
  left-horn~ =
    pushout-rec-unique
      (mk-cocone (idH a .Homᵈ.hom) (g .Homᵈ.hom) (λ _ → sym (g .Homᵈ.hom0)))
      (left-square ∘ Λ[2,1]-incl)
      (λ i → α .Homᵈ.hom i .Homᵈ.hom0)
      (α1-path .fst)
      λ _ →
        ap (_∙ α1-path .fst i0)
          (ap-∘ left-square Λ[2,1]-incl (glue tt)
          ∙ ap (ap left-square) (pushout-rec-apβ {c = Λ[2,1]-Δ²-cocone} tt)
          ∙ left-proof-ap)
        ∙ sym (∙-reflr _)
        ∙ ap (α1-path .fst i0 ∙_) (sym (∙-sym (g .Homᵈ.hom0)))
        ∙ sym (∙-assoc (α1-path .fst i0) (g .Homᵈ.hom0) (sym (g .Homᵈ.hom0)))
        ∙ ap (_∙ sym (g .Homᵈ.hom0)) (α1-path .snd .fst)

  right-bd
    : make-horn (idH b) f ∘ ∂Λ[2,1]-incl ~ diag-hom .Homᵈ.hom ∘ ∂Δ¹-incl
  right-bd (mk-lift false) = f .Homᵈ.hom0 ∙ sym (diag-hom .Homᵈ.hom0)
  right-bd (mk-lift true) = idH b .Homᵈ.hom1 ∙ sym (diag-hom .Homᵈ.hom1)

  right-make-∂Δ² : ∂Δ² → A
  right-make-∂Δ² = pushout-rec (mk-cocone (make-horn (idH b) f)
                                      (diag-hom .Homᵈ.hom) right-bd)

  right-make-∂Δ²-path : right-make-∂Δ² ＝ make-∂Δ² (idH b) f diag-hom
  right-make-∂Δ²-path = funext→
    (pushout-rec-unique _ _ ~refl ~refl λ where
      (mk-lift false) → ∙-reflr _ ∙ pushout-rec-apβ (mk-lift false)
      (mk-lift true) → ∙-reflr _ ∙ pushout-rec-apβ (mk-lift true))

  left-bd
    : make-horn g (idH a) ∘ ∂Λ[2,1]-incl ~ diag-hom .Homᵈ.hom ∘ ∂Δ¹-incl
  left-bd (mk-lift false) = idH a .Homᵈ.hom0 ∙ sym (diag-hom .Homᵈ.hom0)
  left-bd (mk-lift true) = g .Homᵈ.hom1 ∙ sym (diag-hom .Homᵈ.hom1)

  left-make-∂Δ² : ∂Δ² → A
  left-make-∂Δ²
    = pushout-rec (mk-cocone (make-horn g (idH a)) (diag-hom .Homᵈ.hom) left-bd)

  left-make-∂Δ²-path : left-make-∂Δ² ＝ make-∂Δ² g (idH a) diag-hom
  left-make-∂Δ²-path = funext→
    (pushout-rec-unique _ _ ~refl ~refl λ where
      (mk-lift false) → ∙-reflr _ ∙ pushout-rec-apβ (mk-lift false)
      (mk-lift true) → ∙-reflr _ ∙ pushout-rec-apβ (mk-lift true))

  diag-hom←Hom-Hom : Hom A a b
  diag-hom←Hom-Hom = diag-hom

  right-homotopy←Hom-Hom : f ▵~ diag-hom←Hom-Hom
  right-homotopy←Hom-Hom .fst = right-square
  right-homotopy←Hom-Hom .snd
    = funext→
        (pushout-rec-unique
          (mk-cocone (make-horn (idH b) f) (diag-hom .Homᵈ.hom) right-bd)
          (right-square ∘ ∂Δ²-incl)
          right-horn~
          ~refl
          λ where
            (mk-lift false)
              → ap (_∙ refl)
                  (ap-∘ right-square ∂Δ²-incl (glue ∂Δ¹-0)
                  ∙ ap (ap right-square) (pushout-rec-apβ ∂Δ¹-0)
                  ∙ right-proof-ap)
              ∙ sym (∙-sym (diag-hom .Homᵈ.hom0))
              ∙ ∙-assoc (α0-path .fst i0) (f .Homᵈ.hom0) (sym (diag-hom .Homᵈ.hom0))
            (mk-lift true)
              → ap (_∙ refl)
                  (ap-∘ right-square ∂Δ²-incl (glue ∂Δ¹-1)
                  ∙ ap (ap right-square) (pushout-rec-apβ ∂Δ¹-1)
                  ∙ right-proof-ap)
              ∙ sym (∙-sym (diag-hom .Homᵈ.hom1))
              ∙ ap (_∙ sym (diag-hom .Homᵈ.hom1)) (α1-path .snd .snd))
    ∙ right-make-∂Δ²-path

  left-homotopy←Hom-Hom : g ~▵ diag-hom←Hom-Hom
  left-homotopy←Hom-Hom .fst
    = left-square
  left-homotopy←Hom-Hom .snd
    = funext→
        (pushout-rec-unique
          (mk-cocone (make-horn g (idH a)) (diag-hom .Homᵈ.hom) left-bd)
          (left-square ∘ ∂Δ²-incl)
          (left-horn~)
          (~refl)
          (λ where
            (mk-lift false)
              → ap (_∙ refl)
                  ( ap-∘ left-square ∂Δ²-incl (glue ∂Δ¹-0)
                  ∙ ap (ap left-square) (pushout-rec-apβ ∂Δ¹-0)
                  ∙ left-proof-ap)
              ∙ sym (∙-sym (diag-hom .Homᵈ.hom0))
              ∙ ap (_∙ sym (diag-hom .Homᵈ.hom0)) (α0-path .snd .fst)
            (mk-lift true)
              → ap (_∙ refl)
                  (ap-∘ left-square ∂Δ²-incl (glue ∂Δ¹-1)
                  ∙ ap (ap left-square) (pushout-rec-apβ ∂Δ¹-1)
                  ∙ left-proof-ap)
              ∙ sym (∙-sym (diag-hom .Homᵈ.hom1))
              ∙ ∙-assoc (α1-path .fst i1)
                        (g .Homᵈ.hom1)
                        (sym (diag-hom .Homᵈ.hom1))))
    ∙ left-make-∂Δ²-path

Id←Hom-Hom
  : {𝓤 : Level} {A : Type 𝓤} {a b : A}
  → ({f g : Hom A a b} → f ~▵ g → f ＝ g)
  → ({f g : Hom A a b} → f ▵~ g → f ＝ g)
  → {f g : Hom A a b}
  → Hom (Hom A a b) f g
  → f ＝ g
Id←Hom-Hom left→id right→id α
  = right→id (HomGroupoid.right-homotopy←Hom-Hom α)
  ∙ sym (left→id (HomGroupoid.left-homotopy←Hom-Hom α))

Hom-is-groupoid
  : {𝓤 : Level} {A : Type 𝓤} {a b : A}
  → ((f : Hom A a b) → is-singleton (Σ[ g ∶ Hom A a b ] (f ~▵ g)))
  → ((f : Hom A a b) → is-singleton (Σ[ g ∶ Hom A a b ] (f ▵~ g)))
  → is-groupoid (Hom A a b)
Hom-is-groupoid {𝓤} {A} {a} {b} left-tors right-tors
  = is-groupoid←Id←Hom (Id←Hom-Hom left→id right→id) where
  left→id : {f g : Hom A a b} → f ~▵ g → f ＝ g
  left→id {f} = fundamental-Id⁻¹ (f ~▵_) (left-tors f) (λ _ → ~▵←＝)

  right→id : {f g : Hom A a b} → f ▵~ g → f ＝ g
  right→id {f} = fundamental-Id⁻¹ (f ▵~_) (right-tors f) (λ _ → ▵~←＝)

Hom-is-groupoid←is-segal
  : {𝓤 : Level} {A : Type 𝓤}
  → is-segal A
  → {a b : A} → is-groupoid (Hom A a b)
Hom-is-groupoid←is-segal 𝐴
  = Hom-is-groupoid (~▵-is-torsorial 𝐴) (▵~-is-torsorial 𝐴)
}
%```
}

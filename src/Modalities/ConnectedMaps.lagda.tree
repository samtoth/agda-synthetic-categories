\taxon{Lemma}
\title{#{K}-connected maps are #{K}-equivalences}

% ```agda
\agda{
up-modal-equiv‚Üźup-connected-map
  : ‚ąÄ {őĪ ūĚď§ ūĚď•} (K : gSubU őĪ)
      {A : Type ūĚď§} {B : Type ūĚď•}
      (f : A ‚Üí B)
  ‚Üí up-connected-map K f
  ‚Üí up-modal-equiv K f
up-modal-equiv‚Üźup-connected-map K f fconn U‚ąąK = fconn (őĽ _ ‚Üí U‚ąąK)

module gRSubUConnectedModalEquivalences {őĪ} (RS : gRSubU őĪ) where
  open gRSubU RS

}

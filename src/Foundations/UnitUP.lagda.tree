\date{2025-04-17}
\taxon{Module}
\title{Universal property of the [unit type](Foundations.Unit)}
\import{stt-macros}



\agda{
module Foundations.UnitUP where

open import Foundations.Universes
open import Foundations.Unit
open import Foundations.Identity
open import Foundations.QuasiEquivalences
open import Foundations.CoherentEquivalences
open import Foundations.EquivHomotopy
open import Foundations.Sigma
open import Foundations.Functions
open import Foundations.Singletons
open import Foundations.DependentIdentity
open import Foundations.FunExt
}

\subtree[stt-002Q]{
\taxon{Theorem}

\agda{
unit-ev-is-equiv : ‚ąÄ {ūĚď§} {A : ūĚüô ‚Üí Type ūĚď§} ‚Üí is-equiv (evŠĶą: A tt)
unit-ev-is-equiv = is-equiv‚Üźqinv qinv where
  qinv : quasi-inv (ev tt)
  qinv .fst a _ = a
  qinv .snd .fst _ = refl
  qinv .snd .snd _ = refl

unit-UP‚ČÉ : ‚ąÄ {ūĚď§} {A : ūĚüô ‚Üí Type ūĚď§} ‚Üí ((a : ūĚüô) ‚Üí A a) ‚ČÉ A tt
unit-UP‚ČÉ = mk‚ČÉ (ev tt) unit-ev-is-equiv

point-is-equiv : ‚ąÄ {ūĚď§} {A : Type ūĚď§} ‚Üí is-equiv (point: A)
point-is-equiv = is-equiv‚ĀĽ¬Ļ unit-ev-is-equiv
}
}

\subtree[stt-00D8]{
\taxon{Remark}

\p{The fact that unit has definitional eta allows us to do without
  funext in the above theorem. When generalising to arbitrary singletons
  (or if we were to disable unit-eta) we require funext.
}
}

\subtree[stt-006S]{
\date{2025-06-27}
\author{samueltoth}
\date{2025-03-09}
\author{fredrikbakke}
\title{Universal property for singleton types}
\taxon{Theorem}

\agda{
sing-evŠĶą-is-equiv
  : ‚ąÄ {ūĚď§ ūĚď•} {A : Type ūĚď§} {B : A ‚Üí Type ūĚď•}
    ‚Üí FunExtŌČ ūĚď•
    ‚Üí (s : is-singleton A)
    ‚Üí is-equiv (ev {B = B} (centre s))
sing-evŠĶą-is-equiv {B = B} FE s = is-equiv‚Üźqinv qinv where
  qinv : quasi-inv (ev {B = B} (centre s))
  qinv .fst x a = tr B (central s a) x
  qinv .snd .fst f = WithFunExtŌČ.funext‚Üí FE (őĽ a ‚Üí apŠ∂† f (central s a))
  qinv .snd .snd x
    = ap (őĽ q ‚Üí tr B q x)
         (is-set‚Üźis-single s (centre s) (centre s)
           (central s (centre s))
           (refl))

sing-ev-is-equiv
  : ‚ąÄ {ūĚď§ ūĚď•} {A : Type ūĚď§} {B : Type ūĚď•}
    ‚Üí FunExtŌČ ūĚď•
    ‚Üí (s : is-singleton A)
    ‚Üí is-equiv (ev: B (centre s))
sing-ev-is-equiv FE s = is-equiv‚Üźqinv qinv where
  qinv : quasi-inv (ev (centre s))
  qinv .fst a _ = a
  qinv .snd .fst f = WithFunExtŌČ.funext‚Üí FE (őĽ a ‚Üí ap f (central s a))
  qinv .snd .snd _ = refl

sing-UP‚ČÉ
  : ‚ąÄ {ūĚď§ ūĚď•} {A : Type ūĚď§} {B : Type ūĚď•}
    ‚Üí FunExtŌČ ūĚď•
    ‚Üí (s : is-singleton A)
    ‚Üí (A ‚Üí B) ‚ČÉ B
sing-UP‚ČÉ FE sing = mk‚ČÉ (ev (sing .centre)) (sing-ev-is-equiv FE sing)

sing-const-is-equiv
  : ‚ąÄ {ūĚď§ ūĚď•} {A : Type ūĚď§} {B : Type ūĚď•}
    ‚Üí FunExtŌČ ūĚď•
    ‚Üí (s : is-singleton A)
    ‚Üí is-equiv (const B A)
sing-const-is-equiv FE s = is-equiv‚ĀĽ¬Ļ (sing-ev-is-equiv FE s)

sing-!-is-equiv : ‚ąÄ {ūĚď§} {A : Type ūĚď§} ‚Üí is-singleton A ‚Üí is-equiv (!: A)
sing-!-is-equiv as .is-equiv.qinv .fst = const _ _ (as .centre)
sing-!-is-equiv as .is-equiv.qinv .snd .fst = as .central
sing-!-is-equiv as .is-equiv.qinv .snd .snd _ = refl
sing-!-is-equiv as .is-equiv.coherent x
  = is-prop‚Üźis-single (ÔľĚ-singleton‚Üźis-single (ūĚüô-is-singleton) _ _) _  _

sing‚ČÉūĚüô : ‚ąÄ {ūĚď§} {A : Type ūĚď§} ‚Üí is-singleton A ‚Üí A ‚ČÉ ūĚüô
sing‚ČÉūĚüô as ._‚ČÉ_.fwd = !
sing‚ČÉūĚüô as ._‚ČÉ_.fwd-is-equiv = sing-!-is-equiv as
}
}

\subtree[stt-00LI]{
\title{#{\Delta^2} is a retract of #{\Delta^1\times\Delta^1}}
\taxon{Lemma}
\author{fredrikbakke}
\date{2026-04-08}

%```agda
\agda{
О”ВІ-retract-О”В№Г—О”В№ : retract О”ВІ (О”В№ Г— О”В№)
О”ВІ-retract-О”В№Г—О”В№
  = (О» x вҶ’ (x .Poly.О”ВІ.s , x .Poly.О”ВІ.t))
  , (О» { (i , j) вҶ’ (i вҲЁ j , j) вҰғ вҲЁ-вүӨ-intror вүӨ-refl вҰ„ })
  , О» ((i , j) вҰғ p вҰ„) вҶ’ О”ВІ-ext (вҲЁ-comm вҲҷ вүӨ-max p , refl)

О”ВІ-retract-О”В№Г—О”В№' : retract О”ВІ (О”В№ Г— О”В№)
О”ВІ-retract-О”В№Г—О”В№'
  = (О» x вҶ’ (x .Poly.О”ВІ.s , x .Poly.О”ВІ.t))
  , (О» { (i , j) вҶ’ (i , i вҲ§ j) вҰғ вҲ§-вүӨ-eliml вүӨ-refl вҰ„ })
  , О» ((i , j) вҰғ p вҰ„) вҶ’ О”ВІ-ext (refl , вҲ§-comm вҲҷ p)
}
%```
}

\subtree[stt-00LC]{
\title{The inner horn inclusion is a retract of pushout product of the endpoint inclusions of the interval}
\taxon{Lemma}
\author{samueltoth}
\date{2025-11-24}
\contributor{fredrikbakke}

\p{
We can display the inner horn inclusion #{\Lambda^2_1 \hookrightarrow \Delta^2} as a
retract of arrows of the pushout product #{\point(0) \pushprod \point(1)}.

\quiver{
\begin{tikzcd}
	{\Lambda^2_1} && {\Lambda^2_1} && {\Lambda^2_1} \\
	\\
	{\Delta^2} && {\square^2} && {\Delta^2}
	\arrow["\id", from=1-1, to=1-3]
	\arrow[hook, from=1-1, to=3-1]
	\arrow["\id", from=1-3, to=1-5]
	\arrow[hook, from=1-3, to=3-3]
	\arrow[hook, from=1-5, to=3-5]
	\arrow["{(x,y)\mapsto(x,y)}"', from=3-1, to=3-3]
	\arrow["{(x,y)\mapsto(x,x\land y)}"', from=3-3, to=3-5]
\end{tikzcd}
}
}

%```agda
\agda{
Оӣ[2,1]вҶӘв–Ў-section : Arrow-map Оӣ[2,1]-incl (pushout-product (point i1) (point i0))
Оӣ[2,1]вҶӘв–Ў-section .Arrow-map.top = PushoutвӮҒ (mk-span-map (_, _) _ (_ ,_) ~refl ~refl)
Оӣ[2,1]вҶӘв–Ў-section .Arrow-map.bot (x , y) = (x , y)
Оӣ[2,1]вҶӘв–Ў-section .Arrow-map.comm
  = pushout-ind _ (mk-coconeбөҲ ~refl ~refl
                    О» _ вҶ’ is-setвҶҗis-truncated (в–Ў-is-truncated car-is-2-truncated) _ _ _ _)

Оӣ[2,1]вҶӘв–Ў-ret : retraction-arrow-map Оӣ[2,1]вҶӘв–Ў-section
Оӣ[2,1]вҶӘв–Ў-ret .fst .Arrow-map.top
  = PushoutвӮҒ (mk-span-map fst _ snd ~refl ~refl)
Оӣ[2,1]вҶӘв–Ў-ret .fst .Arrow-map.bot = О”ВІ-retract-О”В№Г—О”В№' .snd .fst
Оӣ[2,1]вҶӘв–Ў-ret .fst .Arrow-map.comm
  = pushout-ind _
      (mk-coconeбөҲ
        (О» l вҶ’ О”ВІ-ext (refl , вҲ§-comm вҲҷ 0-init))
        (О» l вҶ’ О”ВІ-ext (refl , вҲ§-comm вҲҷ 1-top))
        (О» _ вҶ’ О”ВІ-is-set _ _ _ _))
Оӣ[2,1]вҶӘв–Ў-ret .snd .fst
  = pushout-ind _ (mk-coconeбөҲ ~refl ~refl (О» _ вҶ’ Оӣ[2,1]-is-set _ _ _ _))
Оӣ[2,1]вҶӘв–Ў-ret .snd .snd .fst   = О”ВІ-retract-О”В№Г—О”В№' .snd .snd
Оӣ[2,1]вҶӘв–Ў-ret .snd .snd .snd x = О”ВІ-is-set _ _ _ _
}
%```
}

\subtree[fre-0AA4]{
\title{#{\Delta^2} is a retract of the endomaps on #{\Delta^1}}
\taxon{Lemma}
\author{fredrikbakke}

  (@вҷӯ О”В№-is-segal : is-segal О”В№)
  (let @вҷӯ О”ВІ = Algebra.Lattice.Instances.Polynomial.О”ВІ I)
  (open Synthetic.Hom О”В№ i0 i1)
  (@вҷӯ О”ВІ-is-coskeletal : вҲҖ {x y} вҶ’ is-prop (Hom О”ВІ x y))
  where

module О”ВІ = Algebra.Lattice.Instances.Polynomial.О”ВІ
module I[x] = Lattice (Free-Lattice I I-distr)

open import Axioms.UF
}


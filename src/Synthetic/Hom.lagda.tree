\date{2025-09-11}
\title{Synthetic Hom Types}
\taxon{Module}
\author{samueltoth}
\import{stt-macros}


\agda{
open import Foundations.Prelude

module Synthetic.Hom {рқ“ҳ} (I : Type рқ“ҳ) (i0 i1 : I) where

open import Foundations.IdentitySystem

open import UF

open import Core.Arrows
open import Core.ArrowEquiv

open import Ergonomics.Representation
open import Ergonomics.Extensionality
}

\subtree[stt-00A9]{
\title{Hom types}
\taxon{Definition}

\p{For any bi-pointed type #{I}, we can define the type of synthetic
homomorphisms, which are just (possibly-dependent) functions with specified
end-points.}

\remark{
\p{In this generality, there is not a lot of motivation to call these types
\strong{hom} types. They admit identity homs, but in general not composition.
The idea is that this module will be instantiated with an interval for which
certain types have a notion of fibrancy, and for those fibrant types, the hom
type will deserve it's name.}
}

\agda{
record HomбөҲ {рқ“Ө} (A : I вҶ’ Type рқ“Ө) (a : A i0) (b : A i1) : Type (рқ“Ө вҠ” рқ“ҳ) where
  constructor mk-hom
  field
    hom  : О  I A
    hom0 : hom i0 пјқ a
    hom1 : hom i1 пјқ b


unquoteDecl HomбөҲ-reprвүҠ HomбөҲ-reprвүғ
  = make-record-repr HomбөҲ-reprвүҠ HomбөҲ-reprвүғ (quote HomбөҲ)

О»hom : вҲҖ {рқ“Ө} {A : I вҶ’ Type рқ“Ө} (f : О  I A) вҶ’ HomбөҲ A (f i0) (f i1)
О»hom f = mk-hom f refl refl

Hom : вҲҖ {рқ“Ө} (A : Type рқ“Ө) (a b : A) вҶ’ Type (рқ“Ө вҠ” рқ“ҳ)
Hom A a b = HomбөҲ (О» _ вҶ’ A) a b

{-# NOINLINE Hom #-}

idH : вҲҖ {рқ“Ө} {A : Type рқ“Ө} вҶ’ (a : A) вҶ’ Hom A a a
idH a = О»hom О» _ вҶ’ a

Hom-over
  : вҲҖ {рқ“Ө рқ“Ҙ} {A : Type рқ“Ө} {B : A вҶ’ Type рқ“Ҙ} {x y}
    вҶ’ Hom A x y вҶ’ B x вҶ’ B y вҶ’ Type (рқ“ҳ вҠ” рқ“Ҙ)
Hom-over {A = A} {B} f x' y'
  = HomбөҲ (B вҲҳ f .HomбөҲ.hom)
         (tr B (sym (f .HomбөҲ.hom0)) x')
         (tr B (sym (f .HomбөҲ.hom1)) y')


0вүӨ1 : Hom I i0 i1
0вүӨ1 .HomбөҲ.hom = id
0вүӨ1 .HomбөҲ.hom0 = refl
0вүӨ1 .HomбөҲ.hom1 = refl

total-hom : вҲҖ {рқ“Ө} {A : Type рқ“Ө} вҶ’ (I вҶ’ A) вүғ (ОЈ[ x вҲ¶ A ] ОЈ[ y вҲ¶ A ] Hom A x y)
total-hom {A = A} = equivвҶҗqequiv
  (mkвүҠ
    (О» f вҶ’ (f i0 , f i1 , О»hom f))
    ((О» {(a , b , mk-hom f refl refl) вҶ’ f})
    , ~refl
    , (О» { (a , b , mk-hom f refl refl) вҶ’ refl})))
}

\remark{
\p{Unlike in [Cubical Agda](https://agda.readthedocs.io/en/latest/language/cubical.html)
or the [Rzk proof assistant](https://rzk-lang.github.io/rzk/en/latest/),
these hom types do not require their endpoints to be definitionally equal, but only
equal up to a path. It is possible to simulate the \em{definitional} path types
with an indexed-inductive type but this pushes Agda's elaboration beyond what it
is really designed for, and the usability suffers.
}
}
}

\subtree[stt-00AN]{
\title{Extensionality for homs}
\taxon{Theorem}

\p{A homorphism #{\Hom_A(x,y)} consist of the data of a map #{C^{\Delta^2}}
together with a pair of identifications. To define a path in #{\Hom_A(x,y)}
between #{f} and #{g}, we need a homotopy #{H} of the underlying maps, but also
coherence data: #{H_{0} \sim g_0 \sim f_0} for #{i = 0,1}.}

\agda{
Hom-path
  : вҲҖ {рқ“Ө} {A : Type рқ“Ө} {x y : A} (f g : Hom A x y)
    вҶ’ Type (рқ“ҳ вҠ” рқ“Ө)
Hom-path (mk-hom f p q) (mk-hom g r s)
  = ОЈ[ H вҲ¶ f ~ g ] ((H i0 вҲҷ r пјқ p) Г— (H i1 вҲҷ s пјқ q))

opaque
  Hom-path-is-torsorial
    : вҲҖ {рқ“Ө} {A : Type рқ“Ө} {x y : A} (f : Hom A x y)
      вҶ’ is-singleton (ОЈ[ g вҲ¶ Hom A x y ] Hom-path f g)
  Hom-path-is-torsorial f
    = is-singleвҶҗequiv-to-single (ОЈ-ap-вүғ-fst (HomбөҲ-reprвүғ eвҒ»В№))
        (is-singleton-structureвҶҗparts
          (SingS-is-single (f .HomбөҲ.hom))
          (f .HomбөҲ.hom , ~refl)
          (is-singleton-structureвҶҗparts
            Sing'-is-singleton
            (_ , refl)
            Sing'-is-singleton))

Hom-path-refl
  : вҲҖ {рқ“Ө} {A : Type рқ“Ө} {x y} {f : Hom A x y} вҶ’ Hom-path f f
Hom-path-refl = (~refl , refl , refl)

instance
  IdS-Hom : вҲҖ {рқ“Ө} {A : Type рқ“Ө} {x y : A} вҶ’ Identity-system (Hom A x y) (рқ“ҳ вҠ” рқ“Ө)
  IdS-Hom .Identity-system.IdS = Hom-path
  IdS-Hom .Identity-system.IdSвҶҗId refl = Hom-path-refl
  IdS-Hom .Identity-system.has-is-ids f
    = fundamental-Id (Hom-path f) (Hom-path-is-torsorial f) _


Hom-extвҶ’
  : вҲҖ {рқ“Ө} {A : Type рқ“Ө} {x y : A} {f g : Hom A x y}
    вҶ’ Hom-path f g вҶ’ f пјқ g
Hom-extвҶ’ = ext!

adjust-hom
  : вҲҖ {рқ“Ө} {A : Type рқ“Ө} {x y x' y'} (p : x пјқ x') (q : y пјқ y')
    вҶ’ Hom A x y вҶ’ Hom A x' y'
adjust-hom p q (mk-hom fh f0 f1) = mk-hom fh (f0 вҲҷ p) (f1 вҲҷ q)

adjust-hom-is-equiv
  : вҲҖ {рқ“Ө} {A : Type рқ“Ө} {x y x' y' : A} (p : x пјқ x') (q : y пјқ y')
    вҶ’ is-equiv (adjust-hom p q)
adjust-hom-is-equiv refl refl
  = homotopy-is-equiv (О» _ вҶ’ Hom-extвҶ’ (~refl , вҲҷ-reflr _ , вҲҷ-reflr _))
                      id-is-equiv

Hom-pathбөҲ
  : вҲҖ {рқ“Ө} {A : Type рқ“Ө} {x y z w : A} (p : x пјқ z) (q : y пјқ w)
      (f : Hom A x y) (g : Hom A z w) вҶ’ Type (рқ“ҳ вҠ” рқ“Ө)
Hom-pathбөҲ p q (mk-hom f f0 f1) (mk-hom g g0 g1)
  = ОЈ[ H вҲ¶ (f ~ g) ] (Square (H i0) p f0 g0 Г— Square (H i1) q f1 g1)

Hom-pathвҶҗpathбөҲ
  : вҲҖ {рқ“Ө} {A : Type рқ“Ө} {x y  : A}
      {f g : Hom A x y} вҶ’ Hom-pathбөҲ refl refl f g вҶ’ Hom-path f g
Hom-pathвҶҗpathбөҲ (H , K , R)
  = (H , un-square K вҲҷ вҲҷ-reflr _ , un-square R вҲҷ вҲҷ-reflr _)

Hom-pathбөҲвҶҗpath
  : вҲҖ {рқ“Ө} {A : Type рқ“Ө} {x y  : A}
      {f g : Hom A x y} вҶ’ Hom-path f g вҶ’ Hom-pathбөҲ refl refl f g
Hom-pathбөҲвҶҗpath (H , K , R)
  = (H , mk-square (K вҲҷ sym (вҲҷ-reflr _)) , mk-square (R вҲҷ sym (вҲҷ-reflr _)))

Hom-pathбөҲвүҠpath
  : вҲҖ {рқ“Ө} {A : Type рқ“Ө} {x y  : A}
      {f g : Hom A x y} вҶ’ Hom-path f g вүҠ Hom-pathбөҲ refl refl f g
Hom-pathбөҲвүҠpath ._вүҠ_.fwd = Hom-pathбөҲвҶҗpath
Hom-pathбөҲвүҠpath ._вүҠ_.fwd-qinv .fst = Hom-pathвҶҗpathбөҲ
Hom-pathбөҲвүҠpath ._вүҠ_.fwd-qinv .snd .fst (H , p , q)
  = ОЈ-pathвҶ’ (refl , Г—-pathвҶ’
      ( ap (_вҲҷ вҲҷ-reflr _) (un-mk-square (p вҲҷ sym (вҲҷ-reflr _)))
        вҲҷ (вҲҷ-assoc p _ _) вҲҷ ap (p вҲҷ_) (вҲҷ-sym' (вҲҷ-reflr _)) вҲҷ вҲҷ-reflr _
      , ap (_вҲҷ вҲҷ-reflr _) (un-mk-square (q вҲҷ sym (вҲҷ-reflr _)))
        вҲҷ (вҲҷ-assoc q _ _) вҲҷ ap (q вҲҷ_) (вҲҷ-sym' (вҲҷ-reflr _)) вҲҷ вҲҷ-reflr _))
Hom-pathбөҲвүҠpath ._вүҠ_.fwd-qinv .snd .snd (J , p , q)
  = ОЈ-pathвҶ’ (refl , Г—-pathвҶ’
     ( ap mk-square (вҲҷ-assoc (un-square p) _ _
       вҲҷ ap (un-square p вҲҷ_) (вҲҷ-sym (вҲҷ-reflr _)) вҲҷ вҲҷ-reflr _) вҲҷ mk-un-square p
     , ap mk-square (вҲҷ-assoc (un-square q) _ _
       вҲҷ ap (un-square q вҲҷ_) (вҲҷ-sym (вҲҷ-reflr _)) вҲҷ вҲҷ-reflr _) вҲҷ mk-un-square q))

Hom-pathбөҲвүғpath
  : вҲҖ {рқ“Ө} {A : Type рқ“Ө} {x y  : A}
      {f g : Hom A x y} вҶ’ Hom-path f g вүғ Hom-pathбөҲ refl refl f g
Hom-pathбөҲвүғpath = equivвҶҗqequiv Hom-pathбөҲвүҠpath

Hom-pathбөҲ-is-torsorial
  : вҲҖ {рқ“Ө} {A : Type рқ“Ө} {x y : A}
      {f : Hom A x y} вҶ’ is-singleton (ОЈ _ (Hom-pathбөҲ refl refl f))
Hom-pathбөҲ-is-torsorial
  = is-singleвҶҗequiv-to-single (ОЈ-ap-вүғ (О» _ вҶ’ Hom-pathбөҲвүғpath))
      (Hom-path-is-torsorial _)

Hom-pathбөҲ-refl
  : вҲҖ {рқ“Ө} {A : Type рқ“Ө} {x y : A} {f : Hom A x y} вҶ’ Hom-pathбөҲ refl refl f f
Hom-pathбөҲ-refl = Hom-pathбөҲвҶҗpath Hom-path-refl

Hom-extбөҲвҶ’
  : вҲҖ {рқ“Ө} {A : Type рқ“Ө} {x y z w : A} (p : x пјқ z) (q : y пјқ w)
    вҶ’ {f : Hom A x y} {g : Hom A z w}
    вҶ’ Hom-pathбөҲ p q f g вҶ’ IdбөҲ (apвӮӮ (Hom A) p q) f g
Hom-extбөҲвҶ’ refl refl = Hom-extвҶ’ вҲҳ Hom-pathвҶҗpathбөҲ

Hom-IdSбөҲ
  : вҲҖ {рқ“Ө} {A : Type рқ“Ө} {x y : A}
    вҶ’ Identity-system (Hom A x y) (рқ“ҳ вҠ” рқ“Ө)
Hom-IdSбөҲ .Identity-system.IdS = Hom-pathбөҲ refl refl
Hom-IdSбөҲ .Identity-system.IdSвҶҗId refl = Hom-pathбөҲ-refl
Hom-IdSбөҲ .Identity-system.has-is-ids a
  = fundamental-Id _ Hom-pathбөҲ-is-torsorial _
}
}

\subtree[stt-00CE]{
\title{Functions have an action on synthetic morphisms}

\agda{
ap-hom
  : вҲҖ {рқ“Ө рқ“Ҙ} {A : Type рқ“Ө} {B : Type рқ“Ҙ} (f : A вҶ’ B) {x y}
    вҶ’ Hom A x y вҶ’ Hom B (f x) (f y)
ap-hom f (mk-hom hom hom0 hom1)
  = mk-hom (f вҲҳ hom) (ap f hom0) (ap f hom1)

ap-hom-over
  : вҲҖ {рқ“Ө} {рқ“Ҙ} {A : Type рқ“Ө} {B : A вҶ’ Type рқ“Ҙ} (f : О  A B)
      {x y} (h : Hom A x y)
    вҶ’ Hom-over h (f x) (f y)
ap-hom-over F (mk-hom f hom0 hom1) .HomбөҲ.hom = F вҲҳ f
ap-hom-over F (mk-hom f refl hom1) .HomбөҲ.hom0 = refl
ap-hom-over F (mk-hom f hom0 refl) .HomбөҲ.hom1 = refl

ap-total-hom
  : вҲҖ {рқ“Ө рқ“Ҙ} {A : Type рқ“Ө} {B : Type рқ“Ҙ}
    вҶ’ (A вҶ’ B)
    вҶ’ (ОЈ[ x вҲ¶ A ] ОЈ[ y вҲ¶ A ] Hom _ x y) вҶ’ ОЈ[ x' вҲ¶ B ] ОЈ[ y' вҲ¶ B ] Hom _ x' y'
ap-total-hom F = map-ОЈ F (О» a вҶ’ map-ОЈ F О» b вҶ’ ap-hom F)

ap-total-hom-is-equiv
  : вҲҖ {рқ“Ө рқ“Ҙ} {A : Type рқ“Ө} {B : Type рқ“Ҙ} {f : A вҶ’ B}
    вҶ’ is-equiv f вҶ’ is-equiv (ap-total-hom f)
ap-total-hom-is-equiv {f = F} Fe
  = is-equivвҶҗArrow-equiv {F = fact}
        (total-hom ._вүғ_.fwd-is-equiv , (total-hom ._вүғ_.fwd-is-equiv))
        (postcomp-equiv Fe) where
  fact : Arrow-map (postcomp I F) (ap-total-hom F)
  fact .Arrow-map.top = total-hom ._вүғ_.fwd
  fact .Arrow-map.bot = total-hom ._вүғ_.fwd
  fact .Arrow-map.comm = ~refl
}
}


\subtree[stt-00DO]{
\title{Morphisms in #{ОЈ}-types}
\taxon{Remark}

\p{We can characterise morphisms in #{\Sigma} types as a pairs of a morphism,
and a dependent morphism.
#[\Hom_{\Sigma_A B}((x,x'), (y, y')) \simeq \Sigma_{f : \Hom_A(x,y)} \Hom_f(x',y')]}

\agda{
Hom-ОЈ
  : вҲҖ {рқ“Ө рқ“Ҙ} {A : Type рқ“Ө} {P : A вҶ’ Type рқ“Ҙ} {x y} {x' : P x} {y' : P y}
    вҶ’ (ОЈ[ f вҲ¶ Hom A x y ] Hom-over f x' y') вҶ’ Hom (ОЈ A P) (x , x') (y , y')
Hom-ОЈ (mk-hom f refl refl , mk-hom f' refl refl) = О»hom (О» i вҶ’ f i , f' i)

Hom-ОЈ-fst
  : вҲҖ {рқ“Ө рқ“Ҙ} {A : Type рқ“Ө} {P : A вҶ’ Type рқ“Ҙ} {x y} {x' : P x} {y' : P y}
    вҶ’ Hom (ОЈ A P) (x , x') (y , y') вҶ’ Hom A x y
Hom-ОЈ-fst (mk-hom f refl refl) = О»hom (fst вҲҳ f)

Hom-ОЈ-snd
  : вҲҖ {рқ“Ө рқ“Ҙ} {A : Type рқ“Ө} {P : A вҶ’ Type рқ“Ҙ} {x y} {x' : P x} {y' : P y}
    вҶ’ (f : Hom (ОЈ A P) (x , x') (y , y'))
    вҶ’ Hom-over (Hom-ОЈ-fst f) x' y'
Hom-ОЈ-snd (mk-hom f refl refl) = О»hom (snd вҲҳ f)

Hom-ОЈ-fst-ОІ
  : вҲҖ {рқ“Ө рқ“Ҙ} {A : Type рқ“Ө} {P : A вҶ’ Type рқ“Ҙ}
      {x y} {x' : P x} {y' : P y} (f : Hom A x y) (f' : Hom-over f x' y')
    вҶ’ Hom-ОЈ-fst (Hom-ОЈ (f , f')) пјқ f
Hom-ОЈ-fst-ОІ (mk-hom f refl refl) (mk-hom f' refl refl) = refl

Hom-ОЈ-ap-fst
  : вҲҖ {рқ“Ө рқ“Ҙ} {A : Type рқ“Ө} {P : A вҶ’ Type рқ“Ҙ} {x y : ОЈ A P}
    вҶ’ ap-hom fst {x = x} {y} ~ Hom-ОЈ-fst
Hom-ОЈ-ap-fst (mk-hom f refl refl) = refl

Hom-ОЈ-ap-fst-ОІ
  : вҲҖ {рқ“Ө рқ“Ҙ} {A : Type рқ“Ө} {P : A вҶ’ Type рқ“Ҙ}
      {x y} {x' : P x} {y' : P y} (f : Hom A x y) (f' : Hom-over f x' y')
    вҶ’ ap-hom fst (Hom-ОЈ (f , f')) пјқ f
Hom-ОЈ-ap-fst-ОІ (mk-hom f refl refl) (mk-hom f' refl refl) = refl

Hom-ОЈ-snd-ОІ
  : вҲҖ {рқ“Ө рқ“Ҙ} {A : Type рқ“Ө} {P : A вҶ’ Type рқ“Ҙ}
      {x y} {x' : P x} {y' : P y} (f : Hom A x y) (f' : Hom-over f x' y')
    вҶ’ IdбөҲ (ap (О» f вҶ’ Hom-over f x' y') (Hom-ОЈ-fst-ОІ f f'))
      (Hom-ОЈ-snd (Hom-ОЈ (f , f'))) f'
Hom-ОЈ-snd-ОІ (mk-hom f refl refl) (mk-hom f' refl refl) = refl

Hom-ОЈ-is-equiv
  : вҲҖ {рқ“Ө рқ“Ҙ} {A : Type рқ“Ө} {P : A вҶ’ Type рқ“Ҙ} {x y} {x' : P x} {y' : P y}
    вҶ’ is-equiv (Hom-ОЈ {P = P} {x' = x'} {y'})
Hom-ОЈ-is-equiv = is-equivвҶҗqinv
  ( (О» h вҶ’ Hom-ОЈ-fst h , Hom-ОЈ-snd h)
  , (О» where (a , b) вҶ’ ОЈ-pathвҶ’ (Hom-ОЈ-fst-ОІ a b , Hom-ОЈ-snd-ОІ a b))
  , О» where (mk-hom h refl refl) вҶ’ refl)

Hom-ОЈвүғ
  : вҲҖ {рқ“Ө рқ“Ҙ} {A : Type рқ“Ө} {P : A вҶ’ Type рқ“Ҙ} {x y} {x' : P x} {y' : P y}
    вҶ’ Hom (ОЈ A P) (_ , x') (_ , y') вүғ ОЈ[ f вҲ¶ Hom A x y ] (Hom-over f x' y')
Hom-ОЈвүғ = mkвүғ Hom-ОЈ Hom-ОЈ-is-equiv eвҒ»В№

Hom-Г—вүҠ
  : вҲҖ {рқ“Ө рқ“Ҙ} {A : Type рқ“Ө} {B : Type рқ“Ҙ} {x y a b}
    вҶ’ (Hom (A Г— B) (x , a) (y , b)) вүҠ ((Hom A x y) Г— (Hom B a b))
Hom-Г—вүҠ ._вүҠ_.fwd (mk-hom f refl refl) = (О»hom (fst вҲҳ f)) , (О»hom (snd вҲҳ f))
Hom-Г—вүҠ ._вүҠ_.fwd-qinv .fst (mk-hom f refl refl , mk-hom g refl refl)
  = О»hom (О» i вҶ’ f i , g i)
Hom-Г—вүҠ ._вүҠ_.fwd-qinv .snd .fst (mk-hom f refl refl) = refl
Hom-Г—вүҠ ._вүҠ_.fwd-qinv .snd .snd (mk-hom f refl refl , mk-hom g refl refl) = refl

Hom-Г—вүғ
  : вҲҖ {рқ“Ө рқ“Ҙ} {A : Type рқ“Ө} {B : Type рқ“Ҙ} {x y a b}
    вҶ’ (Hom (A Г— B) (x , a) (y , b)) вүғ ((Hom A x y) Г— (Hom B a b))
Hom-Г—вүғ = equivвҶҗqequiv Hom-Г—вүҠ

HomбөҲ-Г—вүҠ
  : вҲҖ {рқ“Ө рқ“Ҙ рқ“Ұ} {A : Type рқ“Ө} {P : A вҶ’ Type рқ“Ҙ} {Q : A вҶ’ Type рқ“Ұ}
      (f : I вҶ’ A)
      {x} {y} {a} {b}
    вҶ’ (HomбөҲ (О» i вҶ’ P (f i) Г— Q (f i)) (x , a) (y , b))
    вүҠ ((HomбөҲ (P вҲҳ f) x y) Г— (HomбөҲ (Q вҲҳ f) a b))
HomбөҲ-Г—вүҠ _ ._вүҠ_.fwd (mk-hom f refl refl) = (О»hom (fst вҲҳ f)) , (О»hom (snd вҲҳ f))
HomбөҲ-Г—вүҠ _ ._вүҠ_.fwd-qinv .fst (mk-hom f refl refl , mk-hom g refl refl)
  = О»hom (О» i вҶ’ f i , g i)
HomбөҲ-Г—вүҠ _ ._вүҠ_.fwd-qinv .snd .fst (mk-hom f refl refl) = refl
HomбөҲ-Г—вүҠ _ ._вүҠ_.fwd-qinv .snd .snd (mk-hom f refl refl , mk-hom g refl refl) = refl

HomбөҲ-Г—вүғ
  : вҲҖ {рқ“Ө рқ“Ҙ рқ“Ұ} {A : Type рқ“Ө} {P : A вҶ’ Type рқ“Ҙ} {Q : A вҶ’ Type рқ“Ұ}
      (f : I вҶ’ A)
      {x} {y} {a} {b}
    вҶ’ (HomбөҲ (О» i вҶ’ P (f i) Г— Q (f i)) (x , a) (y , b))
    вүғ ((HomбөҲ (P вҲҳ f) x y) Г— (HomбөҲ (Q вҲҳ f) a b))
HomбөҲ-Г—вүғ {P = P} {Q} f = equivвҶҗqequiv (HomбөҲ-Г—вүҠ {P = P} {Q} f)

Homрқҹҷ-is-single : is-singleton (Hom рқҹҷ tt tt)
Homрқҹҷ-is-single = is-singleвҶҗequiv-to-single
  (total-hom вҲҷвүғ ОЈ-singl рқҹҷ-is-singleton tt вҲҷвүғ ОЈ-singl рқҹҷ-is-singleton tt)
  (О -is-single {A = I} {B = О» _ вҶ’ рқҹҷ} О» _ вҶ’ рқҹҷ-is-singleton)
}

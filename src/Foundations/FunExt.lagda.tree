\date{2025-02-26}
\title{Function extensionality}
\taxon{Module}

\import{stt-macros}


\subtree[stt-0023]{
\title{Idea}

\p{
Function extensionality says that any homotopy between functions can be made into an equality between functions.

Or equivalently, that #{\textrm{happly} : (f = g) \to (f \sim g)} is an equivalence.
}
}

\agda{
module Foundations.FunExt where

open import Foundations.Universes
open import Foundations.Functions
open import Foundations.Equivalences
open import Foundations.Identity
open import Foundations.DependentIdentity
open import Foundations.Homotopy
open import Foundations.Sigma
open import Foundations.DependentHomotopy
}


\subtree[stt-0024]{
\title{Function extensionality}
\taxon{Definition}

\p{Because function extensionality is a property of universes, we build up our definition in stages:
We first define function extensionality relative to a single universe, so that the predicate lives in the successor universe.

In order to account for maps from different universe levels, we also define a predicate on a single universe, which says that paths in maps
with domain type in any universe are characterised by homotopies - this quantifies over universes so must live in #{\UU^\omega}.

Finally we define global function extensionality,
which says that all (canonical) universes satisfy function extensionality in the above sense, with this final definition of course also
living in #{\UU^\omega}.}

\agda{
FunExt : (рЭУ§ : Level) вЖТ Type (lsuc рЭУ§)
FunExt рЭУ§ = вИА {A : Type рЭУ§} {B : A вЖТ Type рЭУ§} {f g : (a : A) вЖТ B a}
           вЖТ is-equiv (happly {f = f} {g})

FunExtѕЙ : Level вЖТ TypeѕЙ
FunExtѕЙ рЭУ• = вИА {рЭУ§} вЖТ вИА {A : Type рЭУ§} {B : A вЖТ Type рЭУ•} {f g : (a : A) вЖТ B a}
                   вЖТ is-equiv (happly {f = f} {g})

FunExt-global : TypeѕЙ
FunExt-global = вИА {рЭУ•} вЖТ FunExtѕЙ рЭУ•
}
}

\agda{
module WithFunExt {рЭУ•} (fe : FunExt рЭУ•) where
  funextвЙГ : вИА {A : Type рЭУ•} {B : A вЖТ Type рЭУ•} {f g : (a : A) вЖТ B a} вЖТ (f пЉЭ g) вЙГ (f ~ g)
  funextвЙГ {рЭУ§} = mkвЙГ happly fe

  funextвЖТ : вИА {A : Type рЭУ•} {B : A вЖТ Type рЭУ•} {f g : (a : A) вЖТ B a} вЖТ f ~ g вЖТ f пЉЭ g
  funextвЖТ p = is-equiv.bwd fe p

  funext-J
    : вИА {рЭУ¶} {A : Type рЭУ•} {B : A вЖТ Type рЭУ•} {f : (a : A) вЖТ B a}
      вЖТ (M : (g : (a : A) вЖТ B a) вЖТ f ~ g вЖТ Type рЭУ¶) вЖТ M f ~refl
      вЖТ вИА (g : (a : A) вЖТ B a) (h : f ~ g) вЖТ M g h
  funext-J M mrfl g h = tr (M g) (is-equiv.ќµ fe h) (J (ќї g p вЖТ M g (happly p)) mrfl (funextвЖТ h))

  funext-rec
    : вИА {рЭУ¶} {A : Type рЭУ•} {B : A вЖТ Type рЭУ•} {f g : (a : A) вЖТ B a}
        (M : f ~ g вЖТ Type рЭУ¶)
      вЖТ (вИА p вЖТ M (happly p))
      вЖТ вИА h вЖТ M h
  funext-rec M p h = tr M (is-equiv.ќµ fe h) (p (funextвЖТ h))

  funext-refl : вИА {A : Type рЭУ•} {B : A вЖТ Type рЭУ•} {f : ќ† A B} вЖТ funextвЖТ (~refl) пЉЭ refl {a = f}
  funext-refl = is-equiv.ќЈ fe refl

module WithFunExtѕЙ {рЭУ•} (fe : FunExtѕЙ рЭУ•) where
  funextвЙГ : вИА {рЭУ§} {A : Type рЭУ§} {B : A вЖТ Type рЭУ•} {f g : (a : A) вЖТ B a} вЖТ (f пЉЭ g) вЙГ (f ~ g)
  funextвЙГ {рЭУ§} = mkвЙГ happly fe

  module funext {рЭУ§} {A : Type рЭУ§} {B : A вЖТ Type рЭУ•}
                {f g : ќ† A B} = _вЙГ_ (funextвЙГ {_} {A} {B} {f} {g})

  funextвЖТ : вИА {рЭУ§} {A : Type рЭУ§} {B : A вЖТ Type рЭУ•} {f g : (a : A) вЖТ B a} вЖТ f ~ g вЖТ f пЉЭ g
  funextвЖТ p = is-equiv.bwd fe p

  funext-J
    : вИА {рЭУ§ рЭУ¶} {A : Type рЭУ§} {B : A вЖТ Type рЭУ•} {f : (a : A) вЖТ B a}
      вЖТ (M : (g : (a : A) вЖТ B a) вЖТ f ~ g вЖТ Type рЭУ¶) вЖТ M f ~refl
      вЖТ вИА (g : (a : A) вЖТ B a) (h : f ~ g) вЖТ M g h
  funext-J M mrfl g h = tr (M g) (is-equiv.ќµ fe h) (J (ќї g p вЖТ M g (happly p)) mrfl (funextвЖТ h))


  funext-refl
    : вИА {рЭУ§} {A : Type рЭУ§} {B : A вЖТ Type рЭУ•} {f : ќ† A B}
      вЖТ funextвЖТ (~refl) пЉЭ refl {a = f}
  funext-refl = is-equiv.ќЈ fe refl

  funext-вИЩ
    : вИА {рЭУ§} {A : Type рЭУ§} {B : A вЖТ Type рЭУ•}
        {f g h : ќ† A B} (p : f ~ g) (q : g ~ h)
      вЖТ funextвЖТ (p вИЩh q) пЉЭ funextвЖТ p вИЩ funextвЖТ q
  funext-вИЩ p = funext-J (ќї f' H вЖТ вИА q вЖТ funextвЖТ (H вИЩh q) пЉЭ funextвЖТ H вИЩ funextвЖТ q)
                 (ќї q вЖТ sym (ap (_вИЩ funextвЖТ q) funext-refl)) _ p

  funext-вИЩвИЩ
    : вИА {рЭУ§} {A : Type рЭУ§} {B : A вЖТ Type рЭУ•}
        {f g : ќ† A B} (p : f ~ g) {h} (q : g ~ h) {k} (r : h ~ k)
      вЖТ funextвЖТ (p вИЩh q вИЩh r) пЉЭ funextвЖТ p вИЩ funextвЖТ q вИЩ funextвЖТ r
  funext-вИЩвИЩ
    = funext-J (ќї f' H вЖТ вИА {h'} q {k'} r
                   вЖТ funextвЖТ (H вИЩh q вИЩh r) пЉЭ funextвЖТ H вИЩ funextвЖТ q вИЩ funextвЖТ r)
       (funext-J (ќї g' K вЖТ вИА {k'} (r : g' ~ k')
                     вЖТ funextвЖТ (K вИЩh r) пЉЭ funextвЖТ ~refl вИЩ funextвЖТ K вИЩ funextвЖТ r)
         (ќї r вЖТ sym (ap (_вИЩ (funextвЖТ ~refl вИЩ funextвЖТ r)) funext-refl
                      вИЩ ap (_вИЩ funextвЖТ r) funext-refl)) _) _

  funext-sym
    : вИА {рЭУ§} {A : Type рЭУ§} {B : A вЖТ Type рЭУ•}
        {f g : ќ† A B} (p : f ~ g)
      вЖТ funextвЖТ (p hвБї¬є) пЉЭ sym (funextвЖТ p)
  funext-sym = funext-J (ќї g H вЖТ funextвЖТ (H hвБї¬є) пЉЭ sym (funextвЖТ H))
                        (funext-refl вИЩ ap sym (sym funext-refl)) _

  opaque
    funext-rec
      : вИА {рЭУ§ рЭУ¶} {A : Type рЭУ§} {B : A вЖТ Type рЭУ•} {f g : (a : A) вЖТ B a}
          (M : f ~ g вЖТ Type рЭУ¶)
        вЖТ (вИА p вЖТ M (happly p))
        вЖТ вИА h вЖТ M h
    funext-rec M p h =  tr M (funext.ќµ h) (p (funextвЖТ h))

    funext-rec-~refl
      : вИА {рЭУ§ рЭУ¶} {A : Type рЭУ§} {B : A вЖТ Type рЭУ•} {f : (a : A) вЖТ B a}
          (M : f ~ f вЖТ Type рЭУ¶)
        вЖТ (f : вИА p вЖТ M (happly p))
        вЖТ funext-rec M f ~refl пЉЭ f refl
    funext-rec-~refl M f =
      tr
        (ќї a вЖТ IdбµИ a (f (funextвЖТ ~refl)) (f refl))
        (ap-вИШ M happly _ вИЩ ap (ap M) (funext.coherent refl))
        (apбґ† f funext-refl)


module WithFunExt-global (fe : FunExt-global) where
  module FE {рЭУ•} = WithFunExtѕЙ {рЭУ•} fe
  open FE public


  ќ†-path
    : вИА {рЭУ§ рЭУ•} {A : Type рЭУ§} {B C : A вЖТ Type рЭУ•}
      вЖТ B пЉЭ C вЖТ ((a : A) вЖТ B a) пЉЭ ((a : A) вЖТ C a)
  ќ†-path p = ap (ќї f вЖТ (a : _) вЖТ f a) p

  funextбµИвЖТ
    : вИА {рЭУ§ рЭУ•} {A : Type рЭУ§} {B C : A вЖТ Type рЭУ•}
        {P : B ~ C}
        {f : (a : A) вЖТ B a}
        {g : (a : A) вЖТ C a}
      вЖТ f ~[ P ] g вЖТ f пЉЭ[ ap (ќї f вЖТ (a : A) вЖТ f a) (funextвЖТ P) ] g
  funextбµИвЖТ {A = A} {P = P} {f}
    = funext-J
        (ќї C P вЖТ вИА {g : (a : A) вЖТ C a} вЖТ f ~[ P ] g вЖТ f пЉЭ[  ќ†-path (funextвЖТ P) ] g)
        (funext-J
          (ќї g h вЖТ f пЉЭ[ ќ†-path (funextвЖТ ~refl) ] g)
          (reflбµИ (ap ќ†-path funext-refl)) _) _ P
}

\subtree[stt-00AY]{
\taxon{Definition}
\title{Covariant families}

\p{We say that a type family #{P : A \to \UU} is covariant if for any arrow #{f}
in #{A}, and term #{x_0} at #{P_{f(0)}}, the type of homs over #{f} which extend
#{x_0} is a singleton type.}

\p{Covariant families admit a directed transport.}

\agda{
is-covariant
  : ∀ {𝓤 𝓥} {A : Type 𝓤} (B : A → Type 𝓥)
    → Type (𝓘 ⊔ 𝓤 ⊔ 𝓥)
is-covariant {A = A} B
    = ∀ (x : Δ¹ → A) (x₀ : B (x i0))
      → is-singleton (Σ[ x₁ ∶ B (x i1)] Homᵈ (B ∘ x) x₀ x₁)

{-# INJECTIVE_FOR_INFERENCE is-covariant #-}

is-covariant-is-prop
  : ∀ {𝓤 𝓥} {A : Type 𝓤} (B : A → Type 𝓥) → is-prop (is-covariant B)
is-covariant-is-prop B
  = Π-is-prop (λ a → Π-is-prop (λ b → is-single-is-prop))

is-covariant-hom
  : ∀ {𝓤 𝓥} {A : Type 𝓤} (B : A → Type 𝓥)
    → Type (𝓘 ⊔ 𝓤 ⊔ 𝓥)
is-covariant-hom {A = A} B
  = ∀ {x y} (f : Hom A x y) (x' : B x)
    → is-singleton (Σ[ y' ∶ B y ] Hom-over f x' y')

is-covariant-hom←is-covariant
  : ∀ {𝓤 𝓥} {A : Type 𝓤} (B : A → Type 𝓥)
    → is-covariant B → is-covariant-hom B
is-covariant-hom←is-covariant B cov (mk-hom f refl refl) x' = cov f x'

is-covariant←is-covariant-hom
  : ∀ {𝓤 𝓥} {A : Type 𝓤} (B : A → Type 𝓥)
    → is-covariant-hom B → is-covariant B
is-covariant←is-covariant-hom B cov f x' = cov (λhom f) x'

}
}

\subtree[stt-00O8]{
\title{Covariant type families admit directed transport}
\taxon{Lemma}

\agda{
tr-cov
  : ∀ {𝓤 𝓥} {A : Type 𝓤} {P : A → Type 𝓥}
    → is-covariant P → (h : Δ¹ → A) → P (h i0) → P (h i1)
tr-cov cov h = fst ∘ centre ∘ cov h

tr-cov-filler
  : ∀ {𝓤 𝓥} {A : Type 𝓤} {P : A → Type 𝓥}
    → (Pc : is-covariant P) → (h : Δ¹ → A)
    → ∀ p → Homᵈ (P ∘ h) p (tr-cov {P = P} Pc h p)
tr-cov-filler cov h = snd ∘ centre ∘ cov h

tr-cov-unique
  : ∀ {𝓤 𝓥} {A : Type 𝓤} {P : A → Type 𝓥}
      (Pc : is-covariant P) (h : Δ¹ → A)
      (f : P (h i0) → P (h i1))
    → ∀ p
    → Homᵈ (P ∘ h) p (f p)
    → tr-cov {P = P} Pc h p ＝ f p
tr-cov-unique Pc h f p x = ap fst (central (Pc h p) (f p , x))

opaque
  tr-cov-hom
    : ∀ {𝓤 𝓥} {A : Type 𝓤} {P : A → Type 𝓥}
      → is-covariant P
      → ∀ {x y} (h : Hom A x y) → P x → P y
  tr-cov-hom cov h = fst ∘ centre ∘ is-covariant-hom←is-covariant _ cov h

  tr-cov-over
    : ∀ {𝓤 𝓥} {A : Type 𝓤} {P : A → Type 𝓥}
      → (cov : is-covariant P)
      → ∀ {x y} (h : Hom A x y) → (x' : P x) → Hom-over h x' (tr-cov-hom cov h x')
  tr-cov-over cov h = snd ∘ centre ∘ is-covariant-hom←is-covariant _ cov h

  tr-cov-hom-unique
    : ∀ {𝓤 𝓥} {A : Type 𝓤} (P : A → Type 𝓥) (cov : is-covariant P)
        {x y} (f : Hom A x y) x' y'
      → (Hom-over f x' y') → tr-cov-hom {P = P} cov f x' ＝ y'
  tr-cov-hom-unique P Pc f x' y' p
    = ap fst
        (central
          (is-covariant-hom←is-covariant _ Pc f x')
          (y' , p))

  tr-cov-equal-hom
    : ∀ {𝓤 𝓥} {A : Type 𝓤} {P : A → Type 𝓥}
        (Pc : is-covariant P)
        {x y} (h h' : Hom A x y)
        (H : h ＝ h')
      → tr-cov-hom {P = P} Pc h ~ tr-cov-hom {P = P} Pc h'
  tr-cov-equal-hom Pc h .h refl = ~refl
}
}

\subtree[stt-00O5]{
\title{Left families}
\taxon{Definition}

\p{We say that a type family is \em{a left family} if, as a family, it is right orthogonal
to the left endpoint inclusion.}

\agda{
is-left-family
  : ∀ {𝓤 𝓥} {A : Type 𝓤} (B : A → Type 𝓥) → Type (𝓘 ⊔ 𝓤 ⊔ 𝓥)
is-left-family = are-orthogonal-fam (point i0)
}
}

\subtree[stt-00O6]{
\title{Left families are covariant}
\taxon{Lemma}

\proof{
\p{
Left families are equivalently those type families #{B} for which each
#{B_{\sigma(0)}} admits a unique extension along #{0 \to \Delta^1}.
We have already characterised orthogonal families as those who admit
unique extensions.
}
}

\agda{
module _ {𝓤 𝓥} {A : Type 𝓤} (B : A → Type 𝓥) where
  cov-lift-is-extension
    : ∀ (σ : Δ¹ → A) (x₀ : B (σ i0))
      → Σ (B (σ i1)) (Homᵈ (B ∘ σ) x₀) ≃ Extᵈ (point i0) (B ∘ σ) (point x₀)
  cov-lift-is-extension σ x₀
    =  Σ (B (σ i1)) (Homᵈ (B ∘ σ) x₀)
    ≃⟨ Σ-snd-≃ (λ b → Homᵈ-repr≃) ⟩
       (Σ[ x₁ ∶ B (σ i1) ] Σ[ f ∶ Π Δ¹ (B ∘ σ) ] ((f i0 ＝ x₀) × (f i1 ＝ x₁)))
    ≃⟨ Σ-comm ∙e Σ-snd-≃ (λ f → Σ-comm) ⟩
       (Σ[ f ∶ Π Δ¹ (B ∘ σ) ] ((f i0 ＝ x₀) × Σ[ x₁ ∶ B (σ i1) ] (f i1 ＝ x₁)))
    ≃⟨ Σ-snd-≃ (λ f → Σ-singleton (λ _ → Sing-is-singleton)) ⟩
       (Σ[ f ∶ Π Δ¹ (B ∘ σ)] (f i0 ＝ x₀))
    ≃⟨ Σ-snd-≃ (λ f → unit-UP≃ e⁻¹) ⟩
       Extᵈ (point i0) (B ∘ σ) (point x₀)
    ≃∎

  opaque
    is-covariant←has-unique-extensions
      : has-unique-extensions (point i0) B → is-covariant B
    is-covariant←has-unique-extensions ext σ x₀
      = is-single←equiv-to-single
          (cov-lift-is-extension σ x₀ e⁻¹)
          (ext (mk-afmap σ (point x₀)))

    has-unique-extensions←is-covariant
      : is-covariant B → has-unique-extensions (point i0) B
    has-unique-extensions←is-covariant cov (mk-afmap σ f)
      = is-single←equiv-to-single
          (cov-lift-is-extension σ (f tt))
          (cov σ (f tt))

  has-unique-extensions↔is-covariant
    : has-unique-extensions (point i0) B ↔ is-covariant B
  has-unique-extensions↔is-covariant
    = ( is-covariant←has-unique-extensions
      , has-unique-extensions←is-covariant)

  is-left-family↔is-covariant
    : is-left-family B ↔ is-covariant B
  is-left-family↔is-covariant
    =  are-orthogonal-fam↔has-unique-extensions
    ∙iff has-unique-extensions↔is-covariant
}
}

\subtree[stt-00AV]{
\title{Left fibrations}
\taxon{Definition}

\p{A map is a left fibration if it is [right orthogonal](stt-0048) to the left
endpoint of #{\Delta^1}.}

\p{See [[stt-00OH]] for the dual notion.}

\agda{
is-left-fibration
  : ∀ {𝓤 𝓥} {A : Type 𝓤} {B : Type 𝓥} → (A → B)
    → Type (𝓤 ⊔ 𝓥 ⊔ 𝓘)
is-left-fibration f = (point i0) ⊥ f

is-left-anodyne
  : ∀ {𝓤 𝓥} {A : Type 𝓤} {B : Type 𝓥} → (A → B) → Typeω
is-left-anodyne f = is-anodyne f (point i0)
}
}


\subtree[stt-00AR]{
\title{Covariant families straighten to left fibrations}
\taxon{Corollary}

\p{We show that some family #{P : A \to \UU} is [covariant](stt-00AO) iff the map
#{\pi : \tilde{P} \to A} is a [left fibration](stt-00AV).}

\agda{
opaque
  is-covariant↔is-left-fibration
    : ∀ {𝓤 𝓥} {A : Type 𝓤} (B : A → Type 𝓥)
      → is-covariant B ↔ is-left-fibration (fst: B)
  is-covariant↔is-left-fibration {A = A} B
    = (is-left-family↔is-covariant B iff⁻¹) ∙iff are-orthogonal-fam↔are-orthogonal-fst
}
}

\subtree[stt-00TN]{
\title{Left fibrations are maps which induce equivalences on coslices}
\taxon{Lemma}

\p{#{p : E \to B} is a left fibration iff for each #{e : E}, the induced map
#{E_{e/} \to B_{p(e)/}} is an equivalence.}

\agda{
module _ {𝓤 𝓥} {E : Type 𝓤} {B : Type 𝓥} (p : E → B) where

  arrow-fibre-left-fibration-is-coslice-map
    : ∀ (e : E)
      → Arrow-equiv
          (postcompose-coslice (point e) p)
          (arrow-fibre (transpose-square (power-hom (point i0) p)) (point e))
  arrow-fibre-left-fibration-is-coslice-map e .fst .Arrow-Π.top
    = total-map (λ a → ap point) ∘ Coslice-object-repr≃ e ._≃_.fwd
  arrow-fibre-left-fibration-is-coslice-map e .fst .Arrow-Π.bot
    = total-map (λ a → ap point) ∘ Coslice-object-repr≃ (p e) ._≃_.fwd
  arrow-fibre-left-fibration-is-coslice-map e .fst .Arrow-Π.comm (e' , f)
    = fibre-path→ (refl , sym (ap-∘ (p ∘_) (λ a _ → a) (Homᵈ.hom0 (f tt)))
                        ∙ ap-∘ (λ a _ → a) p (Homᵈ.hom0 (f tt)))
  arrow-fibre-left-fibration-is-coslice-map e .snd = (lemma e , lemma (p e)) where
    lemma
      : ∀ {𝓤} {A : Type 𝓤} (x : A)
        → is-equiv (total-map (λ _ → ap point) ∘ Coslice-object-repr≃ x ._≃_.fwd)
    lemma x
      = is-equiv-∘
          (is-total-equiv←is-fibrewise-equiv λ a → is-embedding←is-equiv point-is-equiv)
          (Coslice-object-repr≃ x ._≃_.fwd-is-equiv )

  coslice-map-is-equiv←is-left-fibration
    : is-left-fibration p → (∀ e → is-equiv (postcompose-coslice (point e) p))
  coslice-map-is-equiv←is-left-fibration lfib e
    = src-is-equiv←Arrow-equiv
        (arrow-fibre-left-fibration-is-coslice-map e)
        (transpose-is-cartesian _ (is-cartesian←are-orthogonal lfib) (point e))


  is-left-fibration←coslice-map-is-equiv
    : (∀ e → is-equiv (postcompose-coslice (point e) p)) → is-left-fibration p
  is-left-fibration←coslice-map-is-equiv eqv
    = are-orthogonal←is-cartesian
        (transpose-is-cartesian _
          λ e
          → tgt-is-equiv←Arrow-equiv
              (arrow-fibre-left-fibration-is-coslice-map (e tt))
              (eqv (e tt)))
}
}

\subtree[stt-00C7]{
\title{Left fibrations are inner}
\taxon{Lemma}

\proof{
\p{We use the fact that left orthogonal maps [are closed under pushout products
and embeddings](stt-00BV). In particular we take the pushout product:
#{\underset{\Delta^1}{\overset{\{0\}}{\downarrow}} \pushprod
\underset{\Delta^1}{\overset{\{1\}}{\downarrow}}}, which modulo some contracting
away singletons, is the [inner horn](stt-00AD) inclusion into the square. Now
the following retract square completes the proof:}
\transclude{stt-00LC}
}


\remark{
We may use the dual proof for [right fibrations](stt-00OJ)
(\ref{stt-00C7})
}

\agda{
is-inner←is-left-fibration
  : ∀ {𝓤 𝓥} {A : Type 𝓤} {B : Type 𝓥} {f : A → B}
    → is-left-fibration f → is-inner f
is-inner←is-left-fibration {f = f} lf
  = left-orthogonal-retraction
      Λ[2,1]-incl (pushout-product (point i1) (point i0))
      Λ[2,1]↪□-section Λ[2,1]↪□-ret _
      (left-orthogonal-pushout-product' (point i0) f lf (point i1))
}
}

\subtree[stt-00C8]{
\taxon{Corollary}

\p{The total type of a covariant family over a Segal type is itself Segal.}

\agda{
is-inner-family←is-covariant
  : ∀ {𝓤 𝓥} {A : Type 𝓤} {B : A → Type 𝓥}
    → is-covariant B → is-inner-family B
is-inner-family←is-covariant
  = is-inner←is-left-fibration ∘ (is-covariant↔is-left-fibration _ .fst)

is-inner-family←is-covariant-hom
  : ∀ {𝓤 𝓥} {A : Type 𝓤} {B : A → Type 𝓥}
    → is-covariant-hom B → is-inner-family B
is-inner-family←is-covariant-hom
  = is-inner-family←is-covariant ∘ is-covariant←is-covariant-hom _

Σ-cov-is-segal
  : ∀ {𝓤 𝓥} {A : Type 𝓤} {B : A → Type 𝓥}
    → is-segal A → is-covariant B → is-segal (Σ A B)
Σ-cov-is-segal apc cov
  = Σ-is-segal apc
      (is-inner←is-left-fibration
        (is-covariant↔is-left-fibration _ .fst  cov))
}
}

\subtree[stt-00DH]{
\title{Morphisms in Hom types}
\taxon{Lemma}

\p{We show that for a covariant family #{P}, given any #{f : \Hom_A(x,y)},
the type of dependent morphisms #{\Hom_{Pf}(x',y')} is equivalent to
#{f^*(x') = y'}.}

\proof{
\p{We first give a map #{f^*(x') = y'}, by identity induction, it suffices to give
a morphism #{\Hom_{Pf}(x', f^*(x'))} for each #{x'}, but this is just the
coherence you get from covariant transport.
Now since #{\Sigma_{y' : P(f(1))} \Hom_{Pf}(x',y')} is a singleton by the
definition of transport, the fundamental theorem of identity types gives us that
this map is an equivalence.}
}

\agda{
Hom-cov
  : ∀ {𝓤 𝓥} {A : Type 𝓤} (P : A → Type 𝓥) (cov : is-covariant P)
      (f : Δ¹ → A) x' y'
    → tr-cov {P = P} cov f x' ＝ y' → Homᵈ (P ∘ f) x' y'
Hom-cov _ Pc f x' y' refl = Pc f x' .centre .snd

Hom-cov-is-equiv
  : ∀ {𝓤 𝓥} {A : Type 𝓤} (P : A → Type 𝓥) (cov : is-covariant P)
      (f : Δ¹ → A) x' y'
    → is-equiv (Hom-cov P cov f x' y')
Hom-cov-is-equiv P Pc f x' = fundamental-Id _ (Pc f x') (Hom-cov P Pc f x')

opaque
  unfolding tr-cov-hom
  Hom-cov'
    : ∀ {𝓤 𝓥} {A : Type 𝓤} (P : A → Type 𝓥) (cov : is-covariant P)
        {x y} (f : Hom A x y) x' y'
      → tr-cov-hom {P = P} cov f x' ＝ y' → Hom-over f x' y'
  Hom-cov' P cov f x' y' refl
    = is-covariant-hom←is-covariant _ cov f x' .centre .snd

Hom-cov'-is-equiv
  : ∀ {𝓤 𝓥} {A : Type 𝓤} (P : A → Type 𝓥) (cov : is-covariant P)
      {x y} (f : Hom A x y) x' y'
    → is-equiv (Hom-cov' P cov f x' y')
Hom-cov'-is-equiv P Pc f x'
  = fundamental-Id
      _
      (is-covariant-hom←is-covariant _ Pc f x')
      (Hom-cov' P Pc f x')

Hom-cov'≃
  : ∀ {𝓤 𝓥} {A : Type 𝓤} (P : A → Type 𝓥) (cov : is-covariant P)
      {x y} (f : Hom A x y) x' y'
    → (tr-cov-hom {P = P} cov f x' ＝ y') ≃ (Hom-over f x' y')
Hom-cov'≃  P Pc f x' y'
  = mk≃ (Hom-cov' P Pc f x' y') (Hom-cov'-is-equiv P Pc f x' y')
}
}

\subtree[stt-00DQ]{
\title{Covariant transport is functorial}
\taxon{Theorem}

\citet{8.16}{RS17}

\p{Given a covariant family #{P}, we show the transport operation is functorial,
in the sense that #{P(\id) \sim \id} and
#{P(f \circ g) \sim P(f) \circ P(g)}.}

\agda{
opaque
  tr-cov-id
    : ∀ {𝓤 𝓥} {A : Type 𝓤} (P : A → Type 𝓥) (cov : is-covariant P) {x}
      → tr-cov {P = P} cov (λ _ → x) ~ id
  tr-cov-id P cov {x} x' = ap fst (cov (λ _ → x) x' .central (x' , idH x'))

opaque
  unfolding tr-cov-hom
  tr-cov-idH
    : ∀ {𝓤 𝓥} {A : Type 𝓤} (P : A → Type 𝓥) (cov : is-covariant P) {x}
      → tr-cov-hom {P = P} cov (idH x) ~ id
  tr-cov-idH P cov {x} x' = ap fst
    (is-covariant-hom←is-covariant _ cov (idH x) x' .central (x' , idH x'))

  tr-cov-idH~
    : ∀ {𝓤 𝓥} {A : Type 𝓤} (P : A → Type 𝓥) (cov : is-covariant P) {x}
        (f : Hom A x x)
      → f ＝ idH x
      → tr-cov-hom {P = P} cov f ~ id
  tr-cov-idH~ P cov _ refl = tr-cov-idH P cov

  tr-cov-∘
    : ∀ {𝓤 𝓥} {A : Type 𝓤} (Apc : is-segal A) (P : A → Type 𝓥)
        (cov : is-covariant P) {x y z} (g : Hom A y z) (f : Hom A x y)
        (x' : P x)
      → tr-cov-hom cov (g ∘[ Apc ] f) x'
      ＝ tr-cov-hom cov g (tr-cov-hom cov f x')
  tr-cov-∘ apc P cov g f x'
    = ap fst
        (is-covariant-hom←is-covariant _ cov (g ∘[ apc ] f) x' .central
          ( tr-cov-hom cov g (tr-cov-hom cov f x')
          , Compᵈ apc P (is-inner-family←is-covariant cov) g f
                  (tr-cov-over cov g _) (tr-cov-over cov f _)))
}
}

\subtree[stt-00K3]{
\title{Covariant transport along inequalities in #{Δ¹}}
\taxon{Lemma}

\p{Each #{i \le j} in #{\Delta^1} induces a morphism #{\Hom_{\Delta^1}(i,j)}.
consequently, for covariant families over #{\Delta^1}, we may coerce along
#{i \le j}. Since #{i \le j} is a proposition, we have the coercing along
#{i \le i} for any #{i} is the identity and coercing along #{0 \le 1} is the
same as covariant transport over the canonical morphisms from #{0} to #{1} given
by #{id : \Delta^1 \to \Delta^1}.}

\agda{
module _ {𝓤} (B : Δ¹ → Type 𝓤) (bc : is-covariant B) where

  coe-cov : {i j : Δ¹} → i ≤ j → B i → B j
  coe-cov p = tr-cov-hom bc (Δ¹-hom←≤ p)

  opaque
    unfolding tr-cov-hom
    coe-cov-id : {i  : Δ¹} (p : i ≤ i) → coe-cov p ~ id
    coe-cov-id {i} p
      =  happly (ap (tr-cov-hom bc) (Δ¹-hom-≤-refl p))
      ∙h tr-cov-idH B bc

    coe-cov-＝ : {i j : Δ¹} (p : i ＝ j) (q : i ≤ j) → coe-cov q ~ tr B p
    coe-cov-＝ refl = coe-cov-id

    coe-cov-0≤1 : (p : i0 ≤ i1) → coe-cov p ＝ tr-cov bc id
    coe-cov-0≤1 p = ap (tr-cov-hom bc) (Δ¹-hom-0≤1 p)
}
}

\subtree[stt-00FR]{
\title{Natural transformations are natural with respect to covariant transport}
\taxon{Lemma}

\citet{Proposition 8.17}{RS17}

\agda{
module _
  {𝓤 𝓥 𝓦} {A : Type 𝓤} {F : A → Type 𝓥} {G : A → Type 𝓦}
  (Fc : is-covariant F)
  (Gc : is-covariant G)
  (α : ∀ a → F a → G a)
  where

  tr-cov-hom-naturality
    : ∀ {x y} (f : Hom A x y)
      → tr-cov-hom Gc f ∘ α x ~ α y ∘ tr-cov-hom Fc f
  tr-cov-hom-naturality f x'
    = tr-cov-hom-unique G Gc f
        (α _ x')
        (α _ (tr-cov-hom Fc f x'))
        (filler f x') where
    filler
      : ∀ {x y} (f : Hom _ x y) x'
        → Hom-over f (α x x') (α y (tr-cov-hom Fc f x'))
    filler {x}{y} hh@(mk-hom h refl refl) x'
      = apᵈ-hom (λ {i} → α (h i)) (tr-cov-over Fc hh x')

  adjust-tr-cov-hom
    : is-fibrewise-equiv α
    → ∀ {x}{y} (f : Hom A x y)
    → Arrow-equiv (tr-cov-hom {P = F} Fc f) (tr-cov-hom {P = G} Gc f)
  adjust-tr-cov-hom e f .fst .Arrow-Π.top = α _
  adjust-tr-cov-hom e f .fst .Arrow-Π.bot = α _
  adjust-tr-cov-hom e f .fst .Arrow-Π.comm = tr-cov-hom-naturality f h⁻¹
  adjust-tr-cov-hom e f .snd .fst = e _
  adjust-tr-cov-hom e f .snd .snd = e _

  opaque
    tr-cov-naturality
      : ∀ (f : Δ¹ → A)
        → tr-cov {P = G} Gc f ∘ α (f i0) ~ α (f i1) ∘ tr-cov {P = F} Fc f
    tr-cov-naturality f x'
      = ap fst (central (Gc f (α (f i0) x'))
           ( (α (f i1) (tr-cov {P = F} Fc f x'))
           , apᵈ-hom (λ {i} → α (f i)) (tr-cov-filler {P = F} Fc f x')))

  adjust-tr-cov
    : is-fibrewise-equiv α
    → (f : Δ¹ → A)
    → Arrow-equiv (tr-cov {P = F} Fc f) (tr-cov {P = G} Gc f)
  adjust-tr-cov e f .fst .Arrow-Π.top = α (f i0)
  adjust-tr-cov e f .fst .Arrow-Π.bot = α (f i1)
  adjust-tr-cov e f .fst .Arrow-Π.comm = tr-cov-naturality f h⁻¹
  adjust-tr-cov e f .snd .fst = e (f i0)
  adjust-tr-cov e f .snd .snd = e (f i1)
}
}

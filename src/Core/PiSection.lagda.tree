\date{2025-06-26}
\author{samueltoth}
\title{Pi types as sections}
\taxon{Module}
\import{stt-macros}


\agda{
module Core.PiSection where

open import Foundations.Prelude
open import Axioms.UF
}


\subtree[stt-006J]{
\taxon{Theorem}
\title{Pi types are sections}

\p{We show that the type #{\Pi_{(a : A)} B(a)} is equivalent to
the type of sections of #{\pi : \Sigma_{(a : A)} B(a)}.}


\agda{
sectionвҶҗО 
  : вҲҖ {рқ“Ө рқ“Ҙ} {A : Type рқ“Ө}
      {B : A вҶ’ Type рқ“Ҙ}
    вҶ’ О  _ B
    вҶ’ section (fst {B = B})
sectionвҶҗО  {B = B} f = ((О» x вҶ’ (x , f x)) , ~refl)

sectionвҶҗО -map
  : вҲҖ {рқ“Ө рқ“Ҙ} {A : Type рқ“Ө} {B : Type рқ“Ҙ} {p : A вҶ’ B}
    вҶ’ О  _ (fibre p)
    вҶ’ section p
sectionвҶҗО -map {A = A} {p = p} =  ОЈ-О -swap (const _ _ A) (О» x a вҶ’ p a пјқ x)

sectionвүғО 
  : вҲҖ {рқ“Ө рқ“Ҙ} {A : Type рқ“Ө}
      {B : A вҶ’ Type рқ“Ҙ}
    вҶ’ section (fst {B = B})
    вүғ О  _ B
sectionвүғО  {A = A} {B}
  = section fst                                  вүғвҹЁ ОЈ-О -swapвүғ _ _ eвҒ»В№ вҹ©
    (вҲҖ (a : A) вҶ’ ОЈ[ x вҲ¶ ОЈ A B ] (fst x пјқ a))    вүғвҹЁ О -вүғ (О» a вҶ’ ОЈ-assoc) вҹ©
    ((a : A) вҶ’ ОЈ[ a' вҲ¶ A ] ((B a') Г— (a' пјқ a))) вүғвҹЁ О -вүғ (О» a
                                                    вҶ’ ОЈ-вүғ (О» a' вҶ’ Г—-swap)) вҹ©
    (((a : A) вҶ’ ОЈ[ a' вҲ¶ A ] ((a' пјқ a) Г— B a'))) вүғвҹЁ О -вүғ (О» a вҶ’ ОЈ-пјқsingl) вҹ©
    О  A B вүғвҲҺ

О вҶҗsection
  : вҲҖ {рқ“Ө рқ“Ҙ} {A : Type рқ“Ө}
      {B : A вҶ’ Type рқ“Ҙ}
    вҶ’ section (fst {B = B})
    вҶ’ О  _ B
О вҶҗsection {B = B} (f , s) a = tr B (s a) (snd (f a))

О вҶҗsection-map
  : вҲҖ {рқ“Ө рқ“Ҙ} {A : Type рқ“Ө} {B : Type рқ“Ҙ} {p : A вҶ’ B}
    вҶ’ section p
    вҶ’ О  _ (fibre p)
О вҶҗsection-map {A = A} {p = p} = _вүғ_.bwd (ОЈ-О -swapвүғ (О» _ вҶ’ A) (О» x a вҶ’ p a пјқ x))
}
}

\subtree[stt-00KZ]{
\title{Lifts as pi-types}

\p{More generally, given a diagram as follows, which we call a lift
of #{f} along #{\pi}:}

\quiver{
\begin{tikzcd}[cramped]
	&& {\Sigma_BA} \\
	\\
	X && A
	\arrow["\pi"', from=1-3, to=3-3]
	\arrow["{\bar{f}}", from=3-1, to=1-3]
	\arrow["f"', from=3-1, to=3-3]
	\arrow[curve={height=12pt}, dashed, from=3-3, to=1-3]
\end{tikzcd}
}

\p{We show that there is an equivalence between maps that extend #{f} along
#{\pi} and dependent functions #{\Pi_{x : X} B(f(x))}.}

\agda{
LiftMap
  : вҲҖ {рқ“Ө рқ“Ҙ рқ“Ұ} {О“ : Type рқ“Ө} {E : Type рқ“Ҙ} {B : Type рқ“Ұ}
      (p : E вҶ’ B) (A : О“ вҶ’ B)
    вҶ’ Type (рқ“Ө вҠ” рқ“Ҙ вҠ” рқ“Ұ)
LiftMap p A = fibre (postcomp _ p) A

LiftMapвҶҗО 
  : вҲҖ {рқ“Ө рқ“Ҙ рқ“Ұ} {A : Type рқ“Ө} {B : A вҶ’ Type рқ“Ҙ}
      {X : Type рқ“Ұ} (f : X вҶ’ A)
    вҶ’ О  X (B вҲҳ f) вҶ’ LiftMap (fst: B) f
LiftMapвҶҗО  f g = ((О» x вҶ’ f x , g x) , refl)

LiftMapвүғО 
  : вҲҖ {рқ“Ө рқ“Ҙ рқ“Ұ} {A : Type рқ“Ө} {B : A вҶ’ Type рқ“Ҙ}
      {X : Type рқ“Ұ} (f : X вҶ’ A)
    вҶ’ LiftMap (fst: B) f вүғ О  X (B вҲҳ f)
LiftMapвүғО  f = fibre-postcompвүғ fst f вҲҷвүғ postcomp-О -вүғ (fibre-straighten _ вҲҳ f)

LiftMapвҶҗО -is-equiv
  : вҲҖ {рқ“Ө рқ“Ҙ рқ“Ұ} {A : Type рқ“Ө} {B : A вҶ’ Type рқ“Ҙ}
      {X : Type рқ“Ұ} (f : X вҶ’ A)
    вҶ’ is-equiv (LiftMapвҶҗО  {B = B} f)
LiftMapвҶҗО -is-equiv f
  = homotopy-is-equiv
      (О» a вҶ’ ОЈ-pathвҶ’ (refl , funext-refl))
      (is-equivвҒ»В№ (LiftMapвүғО  f ._вүғ_.fwd-is-equiv))
}
}

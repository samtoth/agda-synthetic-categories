\date{2025-02-21}
\title{Inverses of functions}
\taxon{Module}

\import{stt-macros}

% ```agda
\agda{
module Foundations.FunctionInverses where

open import Foundations.Functions
open import Foundations.Homotopy
open import Foundations.Universes
open import Foundations.Identity
open import Foundations.Sigma
}
% ```

\subtree[stt-000H]{
\taxon{Definition}
\title{Sections}

\p{Given a map #{f : A \to B}, a \em{section} of f, or equivalently a right inverse is a map #{g : B \to A} together with a
homotopy: #{f \circ g \sim \id}}


% ```agda
\agda{
module _ {рЭУ§ рЭУ•} {A : Type рЭУ§} {B : Type рЭУ•} where

  section-witness : (f : A вЖТ B) (g : B вЖТ A) вЖТ Type рЭУ•
  section-witness f g = f вИШ g ~ id

  section : (f : A вЖТ B) вЖТ Type (рЭУ§ вКФ рЭУ•)
  section f = ќ£ (B вЖТ A) (section-witness f)
}
% ```
}

\subtree[stt-000I]{
\taxon{Definition}
\title{Retractions}


\p{Dually to [[stt-000H]], a \em{retraction} (or left-inverse) of a map #{g : B \to A} is a map #{f : A \to B} together with a homotopy: #{f \circ g \sim \id}.}


% ```agda
\agda{
module _ {рЭУ§ рЭУ•} {A : Type рЭУ§} {B : Type рЭУ•} where

  retraction-witness : (f : A вЖТ B) (g : B вЖТ A) вЖТ Type рЭУ§
  retraction-witness f g = g вИШ f ~ id

  retraction : (f : A вЖТ B) вЖТ Type (рЭУ§ вКФ рЭУ•)
  retraction f = ќ£ (B вЖТ A) (retraction-witness f)
}
% ```
}

\subtree[stt-001J]{
\taxon{Remark}
\p{We can express this duality by saying #{f} is a retraction of #{g} iff #{g} is a section of #{f}.}

% ```agda
\agda{
module _ {рЭУ§ рЭУ•} {A : Type рЭУ§} {B : Type рЭУ•} where

  retractionвЖТsection : вИА {f : A вЖТ B} {g : B вЖТ A}
                     вЖТ retraction-witness f g
                     вЖТ section-witness g f
  retractionвЖТsection p = p

  sectionвЖТretraction : вИА {f : A вЖТ B} {g : B вЖТ A}
                     вЖТ section-witness g f
                     вЖТ retraction-witness f g
  sectionвЖТretraction p = p
}
% ```
}

\subtree[stt-0070]{
\title{Sections and retracts compose}
\taxon{Theorem}

%```agda
\agda{
section-вИШ : вИА {рЭУ§ рЭУ• рЭУ¶} {A : Type рЭУ§}
              {B : Type рЭУ•} {C : Type рЭУ¶}
              {f : B вЖТ C} {g : A вЖТ B}
            вЖТ section f вЖТ section g
            вЖТ section (f вИШ g)
section-вИШ {f = f} {g} (sf , pf) (sg , pg)
  = (sg вИШ sf , f вЧВ pg вЦЄ sf ~вИЩ pf)

retraction-вИШ : вИА {рЭУ§ рЭУ• рЭУ¶} {A : Type рЭУ§}
                 {B : Type рЭУ•} {C : Type рЭУ¶}
                 {f : B вЖТ C} {g : A вЖТ B}
               вЖТ retraction f вЖТ retraction g
               вЖТ retraction (f вИШ g)
retraction-вИШ {f = f} {g} (rf , pf) (rg , pg)
  = (rg вИШ rf , rg вЧВ pf вЦЄ g ~вИЩ pg)
}
%```
}

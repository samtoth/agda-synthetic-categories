\subtree[stt-005G]{
\date{2025-06-17}
\author{samueltoth}
\taxon{Definition}
\title{Null types}

\p{
Given a family of types #{A_i}, we say a type #{X} is #{A} \em{null} if
it is right orthogonal to each #{A_i}. Or equivalently, if the
obvious maps #{X \to (A_i \to X)} are equivalences for each #{i}.
}

%```agda
\agda{
module _
  {ūĚďė ūĚď§ ūĚď• : Level} {I : Type ūĚďė}
  where

  is-null : (A : I ‚Üí Type ūĚď§) ‚Üí Type ūĚď• ‚Üí Type (ūĚďė ‚äĒ ūĚď§ ‚äĒ ūĚď•)
  is-null A X = (i : I) ‚Üí is-equiv (const X (A i))

  is-null-is-prop
    : {A : I ‚Üí Type ūĚď§}
    ‚Üí (X : Type ūĚď•) ‚Üí is-prop (is-null A X)
  is-null-is-prop X = ő†-is-prop őĽ a ‚Üí is-equiv-is-prop

  null‚ČÉ : {A : I ‚Üí Type ūĚď§}
          {X : Type ūĚď•} (_ : is-null A X) (i : I)
        ‚Üí X ‚ČÉ (A i ‚Üí X)
  null‚ČÉ {A} {X} An i = mk‚ČÉ (const X (A i)) (An i)

  is-null-equiv
    : {A : I ‚Üí Type ūĚď§}
      {X : Type ūĚď•} {Y : Type ūĚď•}
    ‚Üí X ‚ČÉ Y
    ‚Üí is-null A X
    ‚Üí is-null A Y
  is-null-equiv e anull i
    = is-equiv‚ÜźArrow-equiv
        {F = mk-amap fwd (postcomp _ fwd) ~refl}
        (has-is-eqv , postcomp-equiv has-is-eqv)
        (anull i) where
    open _‚ČÉ_ e

Null-SubU
  : ‚ąÄ {ūĚďė ūĚď§} {I : Type ūĚďė}
      (A : I ‚Üí Type ūĚď§)
      ūĚď¶
    ‚Üí SubU ūĚď¶ (ūĚď¶ ‚äĒ ūĚďė ‚äĒ ūĚď§)
Null-SubU A ūĚď¶ .Subtype.family = is-null A
Null-SubU A ūĚď¶ .Subtype.has-is-subtype = is-null-is-prop
}
%```
}


\subtree[stt-005H]{
\date{2025-06-17}
\author{samueltoth}
\taxon{Theorem}
\title{Null types are #{!}-local}

\p{A type is #{A_i}-null iff it is #{(! : A_i \to 1)}-local.}

\proof{ \p{A type #{X} is #{!\rm{-local}} when the map #{- \circ\ ! :
(1 \to X) \to (A_i \to X)} is an equivalence.}
}

%```agda
\agda{
is-local‚Üźis-null : ‚ąÄ {ūĚďė ūĚď§ ūĚď•} {I : Type ūĚďė} {A : I ‚Üí Type ūĚď§}
                   ‚Üí {X : Type ūĚď•}
                   ‚Üí is-null A X
                   ‚Üí is-local (őĽ i ‚Üí !: A i) X
is-local‚Üźis-null eq i = 3-for-2' (point-is-equiv) (eq i)

is-local-sing‚Üźis-null : ‚ąÄ {ūĚďė ūĚď§ ūĚď• ūĚď¶} {I : Type ūĚďė}
                          {A : I ‚Üí Type ūĚď§}
                          {B : I ‚Üí Type ūĚď•}
                          (Bsing : ‚ąÄ i ‚Üí is-singleton (B i))
                          (f : ‚ąÄ i ‚Üí A i ‚Üí B i)
                        ‚Üí {X : Type ūĚď¶}
                        ‚Üí is-null A X
                        ‚Üí is-local f X
is-local-sing‚Üźis-null Bsing f null i
  = 3-for-2'
    (is-equiv‚ĀĽ¬Ļ (sing-ev-is-equiv global-funext (Bsing i)))
    (null i)

is-null‚Üźis-local : ‚ąÄ {ūĚďė ūĚď§ ūĚď•} {I : Type ūĚďė} {A : I ‚Üí Type ūĚď§}
                   ‚Üí {X : Type ūĚď•}
                   ‚Üí is-local (őĽ i ‚Üí !: A i) X
                   ‚Üí is-null A X
is-null‚Üźis-local eq i = is-equiv-‚ąė (eq i) point-is-equiv

is-null‚Üźis-local-sing : ‚ąÄ {ūĚďė ūĚď§ ūĚď• ūĚď¶} {I : Type ūĚďė}
                          {A : I ‚Üí Type ūĚď§}
                          {B : I ‚Üí Type ūĚď•}
                          (Bsing : ‚ąÄ i ‚Üí is-singleton (B i))
                          (f : ‚ąÄ i ‚Üí A i ‚Üí B i)
                        ‚Üí {X : Type ūĚď¶}
                        ‚Üí is-local f X
                        ‚Üí is-null A X
is-null‚Üźis-local-sing Bs f loc i
  = is-equiv-‚ąė
      (loc i)
      (is-equiv‚ĀĽ¬Ļ (sing-ev-is-equiv global-funext (Bs i)))

Null‚ČÉ!Local
  : ‚ąÄ {ūĚďė ūĚď§ ūĚď•} {I : Type ūĚďė} {A : I ‚Üí Type ūĚď§}
  ‚Üí Subtype-equiv (Local-SubU (őĽ i ‚Üí !: A i) ūĚď•)
                  (Null-SubU A ūĚď•)
Null‚ČÉ!Local A = (is-null‚Üźis-local , is-local‚Üźis-null)
}
%```
}

\subtree[stt-005K]{
\date{2025-06-17}
\author{samueltoth}
\title{Nullification at a pointed family}
\taxon{Definition}

\p{The nullification of a pointed type can be constructed
using the [free algebraic injection](stt-005I)
higher inductive type. By definition, the free
algebraic injection already gives a section to
the precomposition map. Because any map #{A \to 1}
has a section, then the precomposition by this
map already has a retract, and so the type is not just
algebraically #{A}-injective, but #{A}-null.}

%```agda
\agda{
Null‚ąô : ‚ąÄ {ūĚďė ūĚď§ ūĚď•} {I : Type ūĚďė} (A : I ‚Üí Type ūĚď§)
         (A‚ąô : ő† _ A) (X : Type ūĚď•)
       ‚Üí Type ūĚď•
Null‚ąô A _ X = Free-inj
               (őĽ i ‚Üí !: A i)
                X

Null‚ąô-is-null : ‚ąÄ {ūĚďė ūĚď§ ūĚď•} {I : Type ūĚďė}
                 {A : I ‚Üí Type ūĚď§} (A‚ąô : ő† _ A)
                 {X : Type ūĚď•}
               ‚Üí is-null A (Null‚ąô A A‚ąô X)
Null‚ąô-is-null a = is-null‚Üźis-local I where
  I : is-local (őĽ _ ‚Üí !) _
  I i = is-equiv‚Üźqiso őĽ where
    .fst ‚Üí injector-Free-inj i .fst
    .snd .fst őĪ ‚Üí funext‚Üí (őĽ _ ‚Üí Free-inj.is-ext (őĪ ‚ąė !) (a i))
    .snd .snd ‚Üí injector-Free-inj i .snd
}
%```
}

\subtree[stt-0065]{
\date{2025-06-21}
\author{samueltoth}
\title{Nullification is a [reflective subuniverse](stt-0041)}
\taxon{Corollary}


%```agda
\agda{
module _ where
  open is-globally-reflective
  open is-global-reflector

  Null-gSubU : ‚ąÄ {ūĚďė ūĚď§} {I : Type ūĚďė}
               (A : I ‚Üí Type ūĚď§)
              ‚Üí gSubU (_‚äĒ (ūĚďė ‚äĒ ūĚď§))
  Null-gSubU A .gSubU.S = Null-SubU A _
  Null-gSubU A .gSubU.‚ąąS‚Üźequiv e anull i
    = is-equiv‚ÜźArrow-equiv
        {F = mk-amap fwd (postcomp _ fwd) ~refl}
        (has-is-eqv , postcomp-equiv has-is-eqv)
        (anull i) where open _‚ČÉ_ e

  Null-globally-reflective
    : ‚ąÄ {ūĚďė ūĚď§} {I : Type ūĚďė} {A : I ‚Üí Type ūĚď§}
    ‚Üí is-globally-reflective (Null-gSubU A)
  Null-globally-reflective {A = A}
    = is-globally-reflective-subtype-equiv
        (Null‚ČÉ!Local)
        (Local-global-reflectors (őĽ i ‚Üí !: A i))

  opaque
    Null‚ąô-global-reflectors
      : ‚ąÄ {ūĚďė ūĚď§} {I : Type ūĚďė}
          {A : I ‚Üí Type ūĚď§}
          (a‚ąô : ‚ąÄ i ‚Üí A i)
        ‚Üí is-globally-reflective (Null-gSubU A)
    Null‚ąô-global-reflectors a .‚óč = Null‚ąô _ a
    Null‚ąô-global-reflectors a .ő∑ = Free-inj.inc
    Null‚ąô-global-reflectors a .has-is-reflector
      .‚óč‚ąąS = Null‚ąô-is-null a
    Null‚ąô-global-reflectors a .has-is-reflector
      .reflects cnull = Free-inj-reflects _ (is-local‚Üźis-null cnull)

  Null‚ąô-reflective
    : ‚ąÄ {ūĚďė ūĚď§ ūĚď¶} {I : Type ūĚďė}
        {A : I ‚Üí Type ūĚď§}
        (a‚ąô : ‚ąÄ i ‚Üí A i)
      ‚Üí is-reflective (Null-SubU A ūĚď¶)
  Null‚ąô-reflective a = is-reflective‚Üźglobal (Null‚ąô-global-reflectors a)

  Null-gRSubU
    : ‚ąÄ {ūĚďė ūĚď§} {I : Type ūĚďė} (A : I ‚Üí Type ūĚď§)
    ‚Üí gRSubU (_‚äĒ (ūĚďė ‚äĒ ūĚď§))
  Null-gRSubU A .gRSubU.GS = Null-gSubU A
  Null-gRSubU A .gRSubU.has-is-globally-reflective = Null-globally-reflective

  Null‚ąô-gRSubU
    : ‚ąÄ {ūĚďė ūĚď§} {I : Type ūĚďė}
        {A : I ‚Üí Type ūĚď§}
        (a‚ąô : ‚ąÄ i ‚Üí A i)
      ‚Üí gRSubU (_‚äĒ (ūĚďė ‚äĒ ūĚď§))
  Null‚ąô-gRSubU {A = A} a .gRSubU.GS = Null-gSubU A
  Null‚ąô-gRSubU a .gRSubU.has-is-globally-reflective = Null‚ąô-global-reflectors a
}
%```
}

\subtree[stt-006E]{
\date{2025-06-25}
\author{samueltoth}
\taxon{Theorem}
\title{Nullification is a #{\Sigma}-closed reflective subuniverse}

\p{Nullification is a #{\Sigma}-closed reflective subuniverse and so
is also a higher modality.}

\proof{
\p{By calculation:}

##{
\begin{align}
  \Sigma_{(x : X)} Y(x)  &\simeq \Sigma_{(x : X)} A_i \to Y(x) \\
                         &\simeq \Sigma_{(x : A_i \to X)} \Pi_{(a : A_i)} Y(f(a))\\
                         &\simeq A_i \to \Sigma_{(x : X)} Y(x)
\end{align}
}

\p{Where (1) and (2) follow from the fact #{X} and each #{Y(x)} are
#{A}-[null](stt-005G), and (3) is the [type theoretic theorem of
choice](Foundations.TheoremOfChoice).}  }

%```agda
\agda{
ő£-is-null : ‚ąÄ {ūĚďė ūĚď§ ūĚď• ūĚď¶}
              {I : Type ūĚďė}
              {P : I ‚Üí Type ūĚď§}
              {X : Type ūĚď•} {Y : X ‚Üí Type ūĚď¶}
            ‚Üí is-null P X
            ‚Üí (‚ąÄ x ‚Üí is-null P (Y x))
            ‚Üí is-null P (ő£ X Y)
ő£-is-null {P = P} {X = X} {Y} Xnull Ynull i
  = eqv where
  opaque
    I : ő£ X Y ‚ČÉ (P i ‚Üí ő£ X Y)
    I = ő£ X Y
          ‚ČÉ‚ü® ő£-ap-‚ČÉ (őĽ x ‚Üí null‚ČÉ (Ynull x) i) ‚ü©
        ő£ X (őĽ x ‚Üí P i ‚Üí Y x)
          ‚ČÉ‚ü® ő£-ap-‚ČÉ-fst {B = őĽ f ‚Üí (a : P i) ‚Üí Y (f a)} (null‚ČÉ Xnull i) ‚ü©
        ő£ (P i ‚Üí X) (őĽ f ‚Üí (a : P i) ‚Üí Y (f a))
          ‚ČÉ‚ü® ő£-ő†-swap‚ČÉ (őĽ _ ‚Üí X) (őĽ _ ‚Üí Y) e‚ĀĽ¬Ļ ‚ü©
        (P i ‚Üí ő£ X Y) ‚ČÉ‚ąé

    eqv : is-equiv (const (ő£ X Y) (P i))
    eqv = I ._‚ČÉ_.has-is-eqv

prop-is-null‚ąô
  : ‚ąÄ {ūĚďė ūĚď§ ūĚď•} {I : Type ūĚďė} {P : I ‚Üí Type ūĚď§} {A : Type ūĚď•}
    ‚Üí (‚ąÄ i ‚Üí P i) ‚Üí is-prop A ‚Üí is-null P A
prop-is-null‚ąô p ap i
  = is-equiv‚Üźinverse ap (ő†-is-prop (őĽ _ ‚Üí ap)) (ev (p i))

Null-globally-ő£-closed : ‚ąÄ {ūĚďė ūĚď§} {I : Type ūĚďė}
                   {P : I ‚Üí Type ūĚď§}
                 ‚Üí is-globally-ő£-closed (Null-gSubU P)
Null-globally-ő£-closed = ő£-is-null

Null-gRSubU-ő£-closed
  : ‚ąÄ {ūĚďė ūĚď§} {I : Type ūĚďė}
      (P : I ‚Üí Type ūĚď§)
    ‚Üí is-globally-ő£-closed (Null-gRSubU P .gRSubU.GS)
Null-gRSubU-ő£-closed P = Null-globally-ő£-closed

Null-ő£-closed : ‚ąÄ {ūĚďė ūĚď§ ūĚď¶} {I : Type ūĚďė}
                   {A : I ‚Üí Type ūĚď§}
                 ‚Üí is-ő£-closed (Null-SubU A ūĚď¶)
Null-ő£-closed {A = A}
  = is-ő£-closed‚Üźglobally (Null-gSubU A) Null-globally-ő£-closed

Null‚ąô-HigherModality
  : ‚ąÄ {ūĚďė ūĚď§ ūĚď¶} {I : Type ūĚďė}
      {A : I ‚Üí Type ūĚď§}
      (a : ő† _ A)
    ‚Üí HigherModality ūĚď¶
Null‚ąô-HigherModality a
  = HigherModality‚ÜźSubU (Null‚ąô-reflective a) (Null-ő£-closed)

module _
  {ūĚďė ūĚď§ : Level} {I : Type ūĚďė}
  (X : I ‚Üí Type ūĚď§)
  where

  open gSubU (Null-gSubU X) public using () renaming
    ( ‚ąąS‚Üźequiv to is-null‚Üźequiv)

  open gReflectiveClosure (Null-gRSubU X) public using () renaming
    ( ‚ąąS‚Üźretract to is-null‚Üźretract
    ; ő†‚ąąS to ő†-is-null
    ; ULift‚ąąS to ULift-is-null
    ; ūĚüô‚ąąS to ūĚüô-is-null
    ; ‚ąąS‚Üźis-singleton to is-null‚Üźis-singleton
    ; Pullback‚ąąS to Pullback-is-null
    ; fibre‚ąąS to fibre-is-null
    ; Ext‚ąąS to Ext-is-null
    ; √ó‚ąąS to √ó-is-null
    ; ÔľĚ‚ąąS to ÔľĚ-is-null
    ; ~‚ąąS to ~-is-null
    ; retract‚ąąS to retract-is-null
    ; biinv‚ąąS to biinv-is-null
    ; ‚ČÉ‚ąąS to ‚ČÉ-is-null
    ; Equaliser‚ąąS to Equaliser-is-null
    ; Seq-lim‚ąąS to Seq-lim-is-null
    ; preidempotent-map‚ąąS to preidempotent-map-is-null
    ; qidempotent-map‚ąąS to qidempotent-map-is-null
    ; idempotent-map‚ąąS to idempotent-map-is-null
    ; Retracts‚ąąS to Retracts-is-null)

module Null {ūĚďė ūĚď§ : Level} {I : Type ūĚďė} (A : I ‚Üí Type ūĚď§) where
  open gRSubUInduction (Null-gRSubU A) (Null-gRSubU-ő£-closed A) public
  open gRSubU (Null-gRSubU A) public
  open gReflectiveClosure (Null-gRSubU A) public
}
%```
}

\subtree[stt-00GG]{
\date{2026-03-18}
\author{fredrikbakke}
\title{Localisations at families of maps into contractible types are higher modalities}
\taxon{Corollary}

\p{
If each codomain #{B_i} is [contractible](stt-000F), then localisation at
#{f_i : A_i \to B_i} is [#{\Sigma}-closed](stt-006F), and hence determines a
higher modality.
}

%```agda
\agda{
module _ {ūĚďė ūĚď§ ūĚď• ūĚď¶ : Level} {I : Type ūĚďė}
         {A : I ‚Üí Type ūĚď§} {B : I ‚Üí Type ūĚď•}
         where

  Local-ő£-closed
    : (f : (i : I) ‚Üí A i ‚Üí B i)
    ‚Üí (‚ąÄ i ‚Üí is-singleton (B i))
    ‚Üí is-ő£-closed (Local-SubU f ūĚď¶)
  Local-ő£-closed f sngl aloc bloc
    = is-local-sing‚Üźis-null sngl f
        (Null-ő£-closed
          (is-null‚Üźis-local-sing sngl f aloc)
          őĽ a ‚Üí is-null‚Üźis-local-sing sngl f (bloc a))

  Local-HigherModality
    : (f : (i : I) ‚Üí A i ‚Üí B i)
    ‚Üí (‚ąÄ i ‚Üí is-singleton (B i))
    ‚Üí HigherModality ūĚď¶
  Local-HigherModality f s
    = HigherModality‚ÜźSubU
        (Local-reflective f)
        (Local-ő£-closed f s)
}
%```
}

\subtree[stt-00GY]{
\date{2026-03-10}
\author{fredrikbakke}
\title{Closure of null types under retracts in the exponent}
\taxon{Lemma}

\p{
Given an #{A}-[null](stt-005G) type #{X}, then #{X} is null at any
[retract](stt-00HE) of #{A}.
}

%```agda
\agda{
module _
  {ūĚďė ūĚď§ ūĚď• ūĚďß : Level} {I : Type ūĚďė}
  {A : I ‚Üí Type ūĚď§}
  {B : I ‚Üí Type ūĚď•}
  {X : Type ūĚďß}
  where

  is-null-at-retract
    : ((i : I) ‚Üí retract (A i) (B i)) ‚Üí is-null B X ‚Üí is-null A X
  is-null-at-retract R Bnull i
    = is-equiv‚Üźincoherent-retraction-equiv
        (mk-amap id (precomp X (R i .snd .fst)) ~refl)
        (mk-amap id (precomp X (R i .fst)) ~refl
        , ~refl
        , őĽ h ‚Üí funext‚Üí őĽ a ‚Üí ap h (R i .snd .snd a))
        (Bnull i)

  is-null-at-equiv
    : ((i : I) ‚Üí A i ‚ČÉ B i) ‚Üí is-null B X ‚Üí is-null A X
  is-null-at-equiv e = is-null-at-retract (őĽ i ‚Üí retract‚Üźequiv (e i))

  is-null-at-equiv‚ĀĽ¬Ļ
    : ((i : I) ‚Üí B i ‚ČÉ A i) ‚Üí is-null B X ‚Üí is-null A X
  is-null-at-equiv‚ĀĽ¬Ļ e = is-null-at-equiv (őĽ i ‚Üí (e i) e‚ĀĽ¬Ļ)
}
%```
}

\subtree[fre-00GZ]{
\date{2026-03-31}
\author{fredrikbakke}
\title{Closure of null types under dependent sums in the exponent}
\taxon{Lemma}

\p{
If a type is null at a family #{X}, and for each #{i} also null at a family
#{Y_{i}} over #{X_i}, then it is null at the family of dependent sums
#{\sum_{(x : X_i)} Y_{i,x}}.
}

%```agda
\agda{
module _
  {ūĚďė ūĚď§ ūĚď• ūĚď¶ : Level} {I : Type ūĚďė}
  where

  is-null-at-ő£
    : {X : I ‚Üí Type ūĚď§} {Y : (i : I) ‚Üí X i ‚Üí Type ūĚď•} {A : Type ūĚď¶}
    ‚Üí is-null X A
    ‚Üí ((i : I) ‚Üí is-null (Y i) A)
    ‚Üí is-null (őĽ i ‚Üí ő£ (X i) (Y i)) A
  is-null-at-ő£ {X = X} {Y = Y} Xnull Ynull i
    = 3-for-2
        (curry-is-equiv)
        (is-equiv-‚ąė (postcomp-ő†-equiv őĽ {x} ‚Üí Ynull i x) (Xnull i))

  is-null-at-√ó
    : {X : I ‚Üí Type ūĚď§} {Y : I ‚Üí Type ūĚď•} {A : Type ūĚď¶}
    ‚Üí is-null X A
    ‚Üí is-null Y A
    ‚Üí is-null (őĽ i ‚Üí X i √ó Y i) A
  is-null-at-√ó {X = X} {Y = Y} Xnull Ynull
    = is-null-at-ő£ Xnull (őĽ i _ ‚Üí Ynull i)
}
%```
}

\subtree[fre-0P05]{
\date{2026-04-01}
\author{fredrikbakke}
\title{Closure of null types under pushouts in the exponent}
\taxon{Lemma}

\p{
If a type is null at #{C} and local at #{f : A \to B}, then it is null at any
pushout #{B \amalg_A C}.
}

%```agda
\agda{
module _
  {ūĚďė ūĚď§ ūĚď• ūĚď¶ : Level} {I : Type ūĚďė}
  {A : I ‚Üí Type ūĚď§} {B : I ‚Üí Type ūĚď•} {C : I ‚Üí Type ūĚď¶}
  (f : (i : I) ‚Üí A i ‚Üí B i) (g : (i : I) ‚Üí A i ‚Üí C i)
  where

  is-null-at-pushout'
    : {ūĚď† : Level} {X : Type ūĚď†}
    ‚Üí is-null C X
    ‚Üí is-local f X
    ‚Üí is-null (őĽ i ‚Üí (Pushout (f i) (g i))) X
  is-null-at-pushout' {X = X} Cnull floc i
    = 3-for-2
        (is-equiv-‚ąė
          (pullback-equiv‚āĀ {f = precomp X (g i)} (floc i))
          (is-equiv-‚ąė (precomp-cocone‚ČÉpb ._‚ČÉ_.has-is-eqv) Pushout-is-pushoutŌČ))
        (Cnull i)
}
%```
}

\subtree[stt-00GD]{
\date{2026-03-09}
\author{fredrikbakke}
\title{The universe of null types in a subuniverse at a family of propositions}
\taxon{Theorem}

\p{
Let #{P_i} be a family of propositions, and let #{\mathcal{S}} be a
[global subuniverse](stt-007A) which is closed under dependent products over each
#{P_i}. Then the type of #{P}-null types in #{\mathcal{S}} is again #{P}-null.
}

%```agda
\agda{
Null-in-gSubU
  : {őĪ : Level ‚Üí Level} {ūĚďė ūĚď§ : Level} {I : Type ūĚďė}
  ‚Üí (P : I ‚Üí Type ūĚď§)
  ‚Üí gSubU őĪ
  ‚Üí ‚ąÄ ūĚď• ‚Üí Type (lsuc (ūĚď§ ‚äĒ ūĚď•) ‚äĒ őĪ (ūĚď§ ‚äĒ ūĚď•) ‚äĒ ūĚďė)
Null-in-gSubU {ūĚď§ = ūĚď§} P S ūĚď•
  = ő£[ X ‚ą∂ Type (ūĚď§ ‚äĒ ūĚď•) ] ((X ‚ąą gSubU.S S) √ó is-null P X)

Null-in-gSubU-is-null‚Üźis-prop
  : {őĪ : Level ‚Üí Level} {ūĚďė ūĚď§ ūĚď• : Level} {I : Type ūĚďė}
    {P : I ‚Üí Type ūĚď§} {S : gSubU őĪ}
  ‚Üí ((i : I) ‚Üí is-prop (P i))
  ‚Üí ( {ūĚď¶ : Level} (i : I) {B : P i ‚Üí Type ūĚď¶}
      ‚Üí (‚ąÄ a ‚Üí (B a) ‚ąą gSubU.S S)
      ‚Üí (ő† (P i) B) ‚ąą gSubU.S S)
  ‚Üí is-null P (Null-in-gSubU P S ūĚď•)
Null-in-gSubU-is-null‚Üźis-prop {ūĚď§ = ūĚď§} {ūĚď• = ūĚď•} {P = P} {S = S} is-prop-P Ső† i
  = is-equiv‚Üźqiso qiso where
  U = Null-in-gSubU P S ūĚď•
  SU = gSubU.S S

  is-in-SU-and-is-null-is-prop
    : (X : Type (ūĚď§ ‚äĒ ūĚď•)) ‚Üí is-prop ((X ‚ąą SU) √ó is-null P X)
  is-in-SU-and-is-null-is-prop X
    = √ó-is-prop (‚ąą-is-prop SU X) (is-null-is-prop X)

  qiso : quasi-iso (const U (P i))
  qiso .fst f
    = ( ő† (P i) (fst ‚ąė f)
      , Ső† i (őĽ a ‚Üí snd (f a) .fst)
      , ő†-is-null P (őĽ a ‚Üí snd (f a) .snd))
  qiso .snd .fst (X , X‚ąąS , Xnull)
    = ő£-path‚Üí (ua (null‚ČÉ Xnull i e‚ĀĽ¬Ļ) , is-in-SU-and-is-null-is-prop _ _ _)
  qiso .snd .snd f
    = funext‚Üí őĽ a ‚Üí ő£-path‚Üí
      ( ua (mk‚ČÉ (ev a)
                (sing-evŠĶą-is-equiv global-funext (mk-singl a (is-prop-P i a))))
      , is-in-SU-and-is-null-is-prop _ _ _)
}
%```
}

\subtree[stt-00IS]{
\date{2026-03-09}
\author{fredrikbakke}
\title{The universe of null types at a family of propositions}
\taxon{Corollary}

\p{
For a family of propositions #{P_i}, the type of #{P}-null types is itself #{P}-null.
}

%```agda
\agda{
Null-U
  : {ūĚďė ūĚď§ : Level}
  ‚Üí {I : Type ūĚďė}
  ‚Üí (P : I ‚Üí Type ūĚď§)
  ‚Üí (ūĚď• : Level) ‚Üí Type (ūĚďė ‚äĒ lsuc ūĚď§ ‚äĒ lsuc ūĚď•)
Null-U P ūĚď• = Null-in-gSubU P Full-gSubU ūĚď•

Null-U-is-null‚Üźis-prop
  : {ūĚďė ūĚď§ ūĚď• : Level}
    {I : Type ūĚďė}
    {P : I ‚Üí Type ūĚď§}
  ‚Üí ((i : I) ‚Üí is-prop (P i))
  ‚Üí is-null P (Null-U P ūĚď•)
Null-U-is-null‚Üźis-prop {ūĚď• = ūĚď•} {P = P} is-prop-P
  = Null-in-gSubU-is-null‚Üźis-prop
      {ūĚď• = ūĚď•}
      {P = P}
      {S = Full-gSubU}
      (is-prop-P)
      (őĽ _ _ ‚Üí tt)
}
%```
}

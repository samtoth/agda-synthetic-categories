\subtree[fre-0AA5]{
\title{The horn inclusion is a retract of the horn inclusion into endomaps on #{\Delta^1}}
\taxon{Lemma}
\author{fredrikbakke}
\date{2026-04-08}

%```agda
\agda{
О”В№-endoвҶҗОӣ[2,1]-section : Arrow-map Оӣ[2,1]-incl О”В№-endoвҶҗОӣ[2,1]
О”В№-endoвҶҗОӣ[2,1]-section = mk-amap id (О”ВІ-retract-О”В№-endo .fst) ~refl

О”В№-endoвҶҗОӣ[2,1]-ret : retraction-arrow-map О”В№-endoвҶҗОӣ[2,1]-section
О”В№-endoвҶҗОӣ[2,1]-ret .fst
  = mk-amap id (О”ВІ-retract-О”В№-endo .snd .fst)
      (О”ВІ-retract-О”В№-endo .snd .snd в–ё Оӣ[2,1]-incl)
О”В№-endoвҶҗОӣ[2,1]-ret .snd .fst = ~refl
О”В№-endoвҶҗОӣ[2,1]-ret .snd .snd .fst = О”ВІ-retract-О”В№-endo .snd .snd
О”В№-endoвҶҗОӣ[2,1]-ret .snd .snd .snd _ = вҲҷ-reflr _
}
%```
}

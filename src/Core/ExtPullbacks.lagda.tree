\date{2025-08-12}
\title{Pullbacks using Identity systems}
\taxon{Module}
\author{samueltoth}
\import{stt-macros}

\agda{
module Core.ExtPullbacks where
}

\agda-imports{
\agda{
open import Foundations.Prelude
open import Ergonomics.Extensionality
open import Axioms.UF
}
}

\p{
We can define pullbacks (and other limits such as fibres)
for types with non standard identity systems.
This is particularly useful for example when a type is locally small,
we can then construct small pullbacks over it.
}

\subtree[stt-008U]{
\title{Pullbacks using identity systems}
\taxon{Construction}

\agda{
Pullbackₑ
  : ∀ {𝓤 𝓥 𝓦 𝓘} {A : Type 𝓤} {B : Type 𝓥} {C : Type 𝓦}
      (f : A → C) (g : B → C)
      ⦃ IdC : Identity-system C 𝓘 ⦄
    → Type (𝓤 ⊔ 𝓥 ⊔ 𝓘)
Pullbackₑ {A = A} {B} f g = Σ[ a ∶ A ] Σ[ b ∶ B ] (f a ＝ₑ g b)

pullbackₑ
  : ∀ {𝓤 𝓥 𝓦 𝓘} {A : Type 𝓤} {B : Type 𝓥} {C : Type 𝓦}
      (f : A → C) (g : B → C)
      ⦃ IdC : Identity-system C 𝓘 ⦄
    → Cone (mk-cospan C f g) (Pullbackₑ f g)
pullbackₑ f g = mk-cone fst (fst ∘ snd) (ext! ∘ snd ∘ snd)

pullbackₑ-has-up-pullback
  : ∀ {𝓤 𝓥 𝓦 𝓘} {A : Type 𝓤} {B : Type 𝓥} {C : Type 𝓦}
      (f : A → C) (g : B → C)
      ⦃ IdC : Identity-system C 𝓘 ⦄
    → up-pullback (mk-cospan C f g) (pullbackₑ f g)
pullbackₑ-has-up-pullback f g
  = up-pullback←is-pullback _ (is-total-equiv←is-fibrewise-equiv (λ
      a → is-total-equiv←is-fibrewise-equiv (λ
        b → ext!-is-equiv)))

module pbₑ {𝓤 𝓥 𝓦 𝓘} {A : Type 𝓤} {B : Type 𝓥} {C : Type 𝓦}
           ⦃ IdC : Identity-system C 𝓘 ⦄ {f : A → C} {g : B → C}
       = Cone (pullbackₑ f g) renaming (i to π₁; j to π₂)
}
}

\subtree[stt-008V]{
\title{Fibres using identity systems}
\taxon{Construction}

\agda{
fibreₑ
  : ∀ {𝓤 𝓥 𝓘} {A : Type 𝓤} {B : Type 𝓥}
      ⦃ s : Identity-system B 𝓘 ⦄
    → (A → B) → B → Type (𝓤 ⊔ 𝓘)
fibreₑ {A = A} f b = Σ[ a ∶ A ] (f a ＝ₑ b)

fibre≃fibreₑ
  : ∀ {𝓤 𝓥 𝓘} {A : Type 𝓤} {B : Type 𝓥}
      ⦃ s : Identity-system B 𝓘 ⦄
    → (f : A → B) (b : B)
    → fibre f b ≃ fibreₑ f b
fibre≃fibreₑ f b = Σ-snd-≃ (λ a → ext!≃)

fibreₑ-cone
  : ∀ {𝓤 𝓥 𝓘} {A : Type 𝓤} {B : Type 𝓥}
      ⦃ s : Identity-system B 𝓘 ⦄
    → (f : A → B) (b : B)
    → Cone (mk-cospan _ f (point b)) (fibreₑ f b)
fibreₑ-cone f b = mk-cone fst ! (ext! ∘ snd)

fibreₑ-has-up-pullback
  : ∀ {𝓤 𝓥 𝓘} {A : Type 𝓤} {B : Type 𝓥}
      ⦃ s : Identity-system B 𝓘 ⦄
    → (f : A → B) (b : B)
    → up-pullback _ (fibreₑ-cone f b)
fibreₑ-has-up-pullback f b = up-pullback←is-pullback _
  (is-total-equiv←is-fibrewise-equiv (λ a
    → is-equiv-∘ (bwd-is-equiv (Σ-singl 𝟙-is-singleton tt)) ext!-is-equiv))
}
}

\date{2026-04-24}
\title{Lists}
\author{fredrikbakke}
\author{samueltoth}
\taxon{Module}

\import{stt-macros}

\agda{
module Foundations.List where

open import Foundations.Universes
open import Foundations.Nat
}

\subtree[fre-3601]{
\title{List}
\taxon{Definition}

\agda{
infixr 5 _∷_

data List {𝓤} (A : Type 𝓤) : Type 𝓤 where
  [] : List A
  _∷_ : A → List A → List A

{-# BUILTIN LIST List #-}
}
}

\subtree[fre-3602]{
\title{Functorial action of lists}
\taxon{Definition}

\agda{
List-map
  : ∀ {𝓤 𝓥} {A : Type 𝓤} {B : Type 𝓥}
    → (f : A → B)
    → List A → List B
List-map f [] = []
List-map f (x ∷ xs) = f x ∷ List-map f xs
}
}

\subtree[fre-3603]{
\title{Operations on lists}
\taxon{Definition}

\agda{
map-up
  : ∀ {𝓤 𝓥} {A : Type 𝓤} {B : Type 𝓥}
    → (ℕ → A → B) → ℕ → List A → List B
map-up f _ []       = []
map-up f n (x ∷ xs) = f n x ∷ map-up f (suc n) xs

rev-ap
  : ∀ {𝓤} {A : Type 𝓤}
    → List A
    → (List A → List A)
rev-ap [] ys = ys
rev-ap (x ∷ xs) ys = rev-ap xs (x ∷ ys)

reverse
  : ∀ {𝓤} {A : Type 𝓤}
    → List A → List A
reverse xs = rev-ap xs []

foldr
  : ∀ {𝓤 𝓥} {A : Type 𝓤} {B : Type 𝓥}
    → (A → B → B) → B → List A → B
foldr f b [] = b
foldr f b (x ∷ l) = f x (foldr f b l)

_++_ : ∀ {𝓤} {A : Type 𝓤} → List A → List A → List A
[] ++ ys = ys
(x ∷ xs) ++ ys = x ∷ (xs ++ ys)
}
}

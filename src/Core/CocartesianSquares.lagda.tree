\subtree[stt-007V]{
\title{Co-cartesian squares}
\taxon{Definition}

\p{Given a square:}

\quiver{
\begin{tikzcd}
	A && X \\
	\\
	B && Y
	\arrow["{f'}", from=1-1, to=1-3]
	\arrow["f"', from=1-1, to=3-1]
	\arrow["g", from=1-3, to=3-3]
	\arrow["{g'}"', from=3-1, to=3-3]
\end{tikzcd}
}

\p{we say that the square is cocartesian if the square [given by
precomposition](stt-003P) is a [cartesian square](stt-003V).}

\agda{
up-cocartesian'
  : вИА {рЭУ§ рЭУ• рЭУ¶ рЭУЬ} {A : Type рЭУ§} {B : Type рЭУ•}
      {X : Type рЭУ¶} {Y : Type рЭУЬ}
      {f : A вЖТ B} {g : X вЖТ Y}
    вЖТ Arrow-map f g вЖТ (рЭУ† : Level)
    вЖТ Type (рЭУ§ вКФ рЭУ• вКФ рЭУ¶ вКФ рЭУЬ вКФ lsuc рЭУ†)
up-cocartesian' F рЭУ† = вИА (Q : Type рЭУ†)
                     вЖТ is-cartesian (precomp-square F Q)


up-cocartesian
  : вИА {рЭУ§ рЭУ• рЭУ¶ рЭУЬ} {A : Type рЭУ§} {B : Type рЭУ•}
      {X : Type рЭУ¶} {Y : Type рЭУЬ}
      {f : A вЖТ B} {g : X вЖТ Y}
    вЖТ Arrow-map f g
    вЖТ TypeѕЙ
up-cocartesian F = вИА {рЭУ†} (Q : Type рЭУ†)
                    вЖТ is-cartesian (precomp-square F Q)
}
}

\subtree[stt-007W]{
\title{Cocartesian squares are pushouts}
\taxon{Theorem}

\proof{An easy consequence of \ref{stt-003C} and \ref{stt-007Y}}

\agda{
up-pushoutвЖРup-cocartesian
  : вИА {рЭУ§ рЭУ• рЭУ¶ рЭУЬ} {A : Type рЭУ§} {B : Type рЭУ•}
      {X : Type рЭУ¶} {Y : Type рЭУЬ}
      {f : A вЖТ B} {g : X вЖТ Y}
      (F : Arrow-map f g)
    вЖТ up-cocartesian F вЖТ up-pushout _ (CoconeвЖРArrow-map F .snd)
up-pushoutвЖРup-cocartesian {f = f} {g} F cc
  = up-pushoutвЖРprecomp-pullback _
       (ќї Q вЖТ up-pullbackвЖРis-cartesian (precomp-square F Q) (cc Q))

up-cocartesianвЖРup-pushout
  : вИА {рЭУ§ рЭУ• рЭУ¶ рЭУЬ} {S : Span рЭУ§ рЭУ• рЭУ¶} {D : Type рЭУЬ} {C : Cocone S D}
    вЖТ up-pushout S C вЖТ up-cocartesian (Arrow-mapвЖРCocone C)
up-cocartesianвЖРup-pushout po Q
  = is-cartesianвЖРup-pullback
      (precomp-square (Arrow-mapвЖРCocone _) Q)
      (precomp-pullbackвЖРup-pushout _ po Q)
}
}


\subtree[stt-00CQ]{
\title{The mirror of a cocartesian square is cocartesian}
\taxon{Lemma}

\agda{
transpose-square-has-up-cocartesian
  : вИА {рЭУ§ рЭУ• рЭУ¶ рЭУЬ} {A : Type рЭУ§} {B : Type рЭУ•}
      {X : Type рЭУ¶} {Y : Type рЭУЬ}
      {f : A вЖТ B} {g : X вЖТ Y}
      (F : Arrow-map f g)
    вЖТ up-cocartesian F вЖТ up-cocartesian (transpose-square F)
transpose-square-has-up-cocartesian F cocart
  = up-cocartesianвЖРup-pushout
     (up-pushoutвЖРis-pushout _
      (is-equiv-~вИШ
        {f = cogap-mapвЖРsquare F}
        {g = pushout-flip}
        (sym вИШ pushout-rec-unique _ _ ~refl ~refl
          (ќї a вЖТ вИЩ-reflr _ вИЩ ap-вИШ (cogap-mapвЖРsquare F) (pushout-flip) (glue a)
          вИЩ ap (ap _) (pushout-rec-apќ≤ a) вИЩ ap-sym _ (glue a)
          вИЩ ap sym (pushout-rec-apќ≤ a)))
        (is-pushoutвЖРup-pushout _ (up-pushoutвЖРup-cocartesian _ cocart))
        (pushout-comm ._вЙГ_.fwd-is-equiv)))

transpose-is-idempotent-cube
  : вИА {рЭУ§ рЭУ• рЭУ¶ рЭУЬ} {A : Type рЭУ§} {B : Type рЭУ•}
      {X : Type рЭУ¶} {Y : Type рЭУЬ}
      {f : A вЖТ B} {g : X вЖТ Y}
      (F : Arrow-map f g)
      {рЭУ†} (Q : Type рЭУ†)
    вЖТ Cube
        (precomp-square (transpose-square (transpose-square F)) Q)
        (precomp-square F Q)
transpose-is-idempotent-cube F Q .Cube.left = id-square
transpose-is-idempotent-cube F Q .Cube.right = id-square
transpose-is-idempotent-cube F Q .Cube.comm .fst = ~refl
transpose-is-idempotent-cube F Q .Cube.comm .snd .fst = ~refl
transpose-is-idempotent-cube F Q .Cube.comm .snd .snd a
  = ap (_вИЩ refl)
       (sym (ap-id _ вИЩ ap funextвЖТ (funextвЖТ (ќї x вЖТ ap (ap a) sym-sym))))

transpose-is-idempotent
  : вИА {рЭУ§ рЭУ• рЭУ¶ рЭУЬ} {A : Type рЭУ§} {B : Type рЭУ•}
      {X : Type рЭУ¶} {Y : Type рЭУЬ}
      {f : A вЖТ B} {g : X вЖТ Y}
      (F : Arrow-map f g)
      {рЭУ†} (Q : Type рЭУ†)
    вЖТ is-Cube-equiv (transpose-is-idempotent-cube F Q)
transpose-is-idempotent {f = f} {g} F Q .fst
  = id-square-is-equiv {f = precomp Q g}
transpose-is-idempotent {f = f} {g} F Q .snd
  = id-square-is-equiv {f = precomp Q f}

untranspose-square-has-up-cocartesian
  : вИА {рЭУ§ рЭУ• рЭУ¶ рЭУЬ} {A : Type рЭУ§} {B : Type рЭУ•}
      {X : Type рЭУ¶} {Y : Type рЭУЬ}
      {f : A вЖТ B} {g : X вЖТ Y}
      (F : Arrow-map f g)
    вЖТ up-cocartesian (transpose-square F)
    вЖТ up-cocartesian F
untranspose-square-has-up-cocartesian F rFcc Q
  = back-cartesianвЖРequiv-cube
      {F = (precomp-square (transpose-square (transpose-square F)) Q)}
      {G = precomp-square F Q}
      (transpose-is-idempotent-cube F Q)
      (transpose-is-idempotent F Q)
      (transpose-square-has-up-cocartesian _ rFcc Q)
}
}

\subtree[stt-00BT]{
\title{Canonical pushouts are cocartesian squares}
\taxon{Corollary}

\agda{
Pushout-square
  : вИА {рЭУ§ рЭУ• рЭУ¶} (S : Span рЭУ§ рЭУ• рЭУ¶) вЖТ let open Span S
    in Arrow-map left {D = Pushout left right} ќєвВВ
Pushout-square S .Arrow-map.top = S .Span.right
Pushout-square S .Arrow-map.bot = ќєвВБ
Pushout-square S .Arrow-map.comm = glue

Pushout-square-has-up-cocartesian
  : вИА {рЭУ§ рЭУ• рЭУ¶} (S : Span рЭУ§ рЭУ• рЭУ¶) вЖТ up-cocartesian (Pushout-square S)
Pushout-square-has-up-cocartesian S = up-cocartesianвЖРup-pushout Pushout-has-up-pushout

Pushout-square'
  : вИА {рЭУ§ рЭУ• рЭУ¶} (S : Span рЭУ§ рЭУ• рЭУ¶) вЖТ let open Span S
    in Arrow-map right {D = Pushout left right} ќєвВБ
Pushout-square' S = transpose-square (Pushout-square S)

Pushout-square'-has-up-cocartesian
  : вИА {рЭУ§ рЭУ• рЭУ¶} (S : Span рЭУ§ рЭУ• рЭУ¶) вЖТ up-cocartesian (Pushout-square' S)
Pushout-square'-has-up-cocartesian S = transpose-square-has-up-cocartesian _
                                     (up-cocartesianвЖРup-pushout
                                       Pushout-has-up-pushout)
}
}

\subtree[stt-0080]{
\title{Pushouts squares of equivalences}
\taxon{Theorem}

\p{Given an equivalence #{f} and any map #{g}, together with a
square #{f \to g}, the square is cocartesian iff #{g} is an
equivalence.}

\proof{
\p{We have the following square given by precomposition:}
\quiver{
\begin{tikzcd}
	{Q^Y} &&& {Q^B} \\
	& \bullet \\
	\\
	{Q^X} &&& {Q^A}
	\arrow["{Q^b}", from=1-1, to=1-4]
	\arrow["{\rm{gap}}", dashed, from=1-1, to=2-2]
	\arrow["{Q^g}"', from=1-1, to=4-1]
	\arrow["{Q^f}", from=1-4, to=4-4]
	\arrow[from=2-2, to=1-4]
	\arrow["\sim", from=2-2, to=4-1]
	\arrow["\lrcorner"{anchor=center, pos=0.125}, draw=none, from=2-2, to=4-4]
	\arrow["{Q^t}"', from=4-1, to=4-4]
\end{tikzcd}
}

\p{By \ref{stt-007Z}, the projection from the pullback to #{Q^X} is an
equivalence because #{Q^f} is. Then we have a triangle which, by the
[3 for 2](stt-003E) property, shows that #{Q^g} is an equivalence iff
the gap map is.}
}

\agda{
cocartesianвЖРequiv-map
  : вИА {рЭУ§ рЭУ• рЭУ¶ рЭУЬ} {A : Type рЭУ§} {B : Type рЭУ•} {X : Type рЭУ¶}
      {Y : Type рЭУЬ} {f : A вЖТ B} {g : X вЖТ Y}
      (F : Arrow-map f g)
    вЖТ is-equiv f
    вЖТ is-equiv g
    вЖТ up-cocartesian F
cocartesianвЖРequiv-map F feq geq Q
  = is-cartesianвЖРup-pullback (precomp-square F Q)
      (up-pullbackвЖРis-pullback (ConeвЖРArrow-map (precomp-square F Q) .snd)
        (3-for-2
           (pullback-equivвВБ (precomp-equiv feq))
           (precomp-equiv geq))) where
  module F = Arrow-map F

dom-is-equivвЖРcocartesian
  : вИА {рЭУ§ рЭУ• рЭУ¶ рЭУЬ} {A : Type рЭУ§} {B : Type рЭУ•} {X : Type рЭУ¶}
      {Y : Type рЭУЬ} {f : A вЖТ B} {g : X вЖТ Y}
      (F : Arrow-map f g)
    вЖТ is-equiv f
    вЖТ up-cocartesian F
    вЖТ is-equiv g
dom-is-equivвЖРcocartesian F feq cart = is-equivвЖРprecomp _
  ќї {_} {Q} вЖТ is-equiv-вИШ
      (pullback-equivвВБ (precomp-equiv feq))
      (is-pullbackвЖРup-pullback
        (ConeвЖРArrow-map (precomp-square F Q) .snd)
        (up-pullbackвЖРis-cartesian _ (cart Q)))
}
}

\subtree[stt-00EC]{
\title{Pasting for cocartesian squares}
\taxon{Lemma}

\p{Given a pair of squares, as follows: }

\quiver{
\begin{tikzcd}
	\bullet && \bullet && \bullet \\
	\\
	\bullet && \bullet && \bullet
	\arrow[from=1-1, to=1-3]
	\arrow[from=1-1, to=3-1]
	\arrow[from=1-3, to=1-5]
	\arrow[from=1-3, to=3-3]
	\arrow[from=1-5, to=3-5]
	\arrow[from=3-1, to=3-3]
	\arrow["\lrcorner"{anchor=center, pos=0.125, rotate=180}, draw=none, from=3-3, to=1-1]
	\arrow[from=3-3, to=3-5]
\end{tikzcd}
}

\p{The right square is a pushout iff the whole square is.}

\proof{
\p{Call the first square #{F} and the second #{G}. Then we first prove that
#{Q^{F \circ G} \sim Q^G \circ Q^F}. Then the result follows from the
[analogous theorem](stt-003W) for [cartesian squares](stt-003V). Note however,
that the contravariance of taking the postcomposition square means that
cartesian squares are right cancelative, so cocartesian squares must be left
cancelative.}
}

\agda{
precomp-square-вИШ
  : вИА {рЭУ§ рЭУ• рЭУ¶ рЭУЬ рЭУЭ рЭУЫ} {A : Type рЭУ§} {B : Type рЭУ•} {X : Type рЭУ¶} {Y : Type рЭУЬ}
      {U : Type рЭУЭ} {V : Type рЭУЫ} {f : A вЖТ B} {g : X вЖТ Y} {h : U вЖТ V}
      (F : Arrow-map g h) (G : Arrow-map f g)
      {рЭУ†} (Q : Type рЭУ†)
    вЖТ Arrow-map-path
        (paste-squares (precomp-square G Q) (precomp-square F Q))
        (precomp-square (paste-squares F G) Q)
precomp-square-вИШ F G Q .fst = ~refl
precomp-square-вИШ F G Q .snd .fst = ~refl
precomp-square-вИШ {f = f} {g} {h} F G Q .snd .snd
 = comm (paste-squares (precomp-square G Q) (precomp-square F Q)) ~вИЩ ~refl
       ~вЯ® ~вИЩ-reflr _ вЯ©
   comm (paste-squares (precomp-square G Q) (precomp-square F Q))
       ~вЯ®вЯ©
    (precomp Q (G .top) вЧВ precomp-square F Q .comm
    ~вИЩ precomp-square G Q .comm вЦЄ precomp Q (F .bot))
       ~вЯ®вЯ©
    (precomp Q (G .top) вЧВ (funextвЖТ вИШ (_вЧВ (comm F ~вБї¬є)))
    ~вИЩ (funextвЖТ вИШ (_вЧВ (comm G ~вБї¬є))) вЦЄ precomp Q (F .bot))
       ~вЯ® (ќї a вЖТ ap (_вИЩ funextвЖТ _)
         (sym (commutes-prewhisker-funext (a вЧВ (comm F ~вБї¬є))))
         вИЩ sym (funext-вИЩ _ _)) вЯ©
   funextвЖТ вИШ (ќї a вЖТ a вЧВ (sym вИШ comm F вИШ top G) ~вИЩ (a вИШ F .bot) вЧВ (sym вИШ comm G))
       ~вЯ® (ќї a вЖТ ap funextвЖТ (funextвЖТ ќї x
         вЖТ ap (ap a (sym (comm F _)) вИЩ_)
             ( вЧВвИШ  a (bot F) (sym вИШ comm G) x)
             вИЩ sym (ap-вИЩ a (sym (comm F (top G x))) (ap (bot F) _))
             вИЩ ap (ap a) (sym (вИЩ-symsym (ap (bot F) (comm G x)) _
             вИЩ ap (sym (comm F (top G x)) вИЩ_)
                  (sym (ap-sym (bot F) (comm G x))))))) вЯ©
   funextвЖТ вИШ (ќї a вЖТ a вЧВ ((F .bot вЧВ comm G ~вИЩ comm F вЦЄ G .top) ~вБї¬є))
       ~вЯ®вЯ©
   comm (precomp-square (paste-squares F G) Q) ~вИО where open Arrow-map

opaque
  cocartesian-square-вИШ
    : вИА {рЭУ§ рЭУ• рЭУ¶ рЭУЬ рЭУЭ рЭУЫ} {A : Type рЭУ§} {B : Type рЭУ•} {X : Type рЭУ¶} {Y : Type рЭУЬ}
        {U : Type рЭУЭ} {V : Type рЭУЫ} {f : A вЖТ B} {g : X вЖТ Y} {h : U вЖТ V}
        {F : Arrow-map g h} {G : Arrow-map f g}
      вЖТ up-cocartesian F вЖТ up-cocartesian G
      вЖТ up-cocartesian (paste-squares F G)
  cocartesian-square-вИШ {F = F} {G} fc gc Q
    = tr is-cartesian (Arrow-map-pathвЖТ (precomp-square-вИШ F G Q))
        (compose-cartesian (gc Q) (fc Q))

  cocartesian-square-cancel
    : вИА {рЭУ§ рЭУ• рЭУ¶ рЭУЬ рЭУЭ рЭУЫ} {A : Type рЭУ§} {B : Type рЭУ•} {X : Type рЭУ¶} {Y : Type рЭУЬ}
        {U : Type рЭУЭ} {V : Type рЭУЫ} {f : A вЖТ B} {g : X вЖТ Y} {h : U вЖТ V}
        {F : Arrow-map g h} {G : Arrow-map f g}
      вЖТ up-cocartesian G вЖТ up-cocartesian (paste-squares F G)
      вЖТ up-cocartesian F
  cocartesian-square-cancel {F = F} {G = G} Gc FGc Q
    = 3-for-2-cartesian
        {a = precomp-square G Q}
        {b = precomp-square F Q}
        (Arrow-map-pathвЖРid (sym (Arrow-map-pathвЖТ (precomp-square-вИШ F G Q))))
        (FGc Q)
        (Gc Q)
}
}

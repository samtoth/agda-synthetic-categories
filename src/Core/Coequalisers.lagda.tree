\date{2025-07-30}
\title{Coequalisers}
\taxon{Module}
\author{samueltoth}
\import{stt-macros}


\agda{
module Core.Coequalisers where

open import Foundations.Prelude
open import Axioms.UF
open import Core.CanonicalPushouts
open import Core.Postwhisker
open import Core.PushoutEquiv
open import Ergonomics.Representation
}

\subtree[stt-009M]{
\title{Coequalisers}
\taxon{Definition}

\p{Given a pair of maps #{f,g : A \to B}, we define a \em{cofork} under
#{f} and #{g} at a particular type #{C} to be a map #{h : B \to C}
together with an homotopy #{hf \sim hg}. Given a particular cofork
centred at #{C}, we can define a map #{Q^C \to \rm{cofork}_{f,g}(Q)}
for each type #{Q}. The given cofork is said to be a \em{coequaliser}
if the aforementioned cofork-map is an equivalence.}

\agda{
Cofork
  : ‚ąÄ {ūĚď§ ūĚď• ūĚď¶} {A : Type ūĚď§} {B : Type ūĚď•}
    ‚Üí (f g : A ‚Üí B) ‚Üí (C : Type ūĚď¶) ‚Üí Type (ūĚď§ ‚äĒ ūĚď• ‚äĒ ūĚď¶)
Cofork {B = B} f g C = ő£[ p ‚ą∂ (B ‚Üí C) ] (p ‚ąė f ~ p ‚ąė g)

cofork-map
  : ‚ąÄ {ūĚď§ ūĚď• ūĚď¶} {A : Type ūĚď§} {B : Type ūĚď•}
    ‚Üí {f g : A ‚Üí B} ‚Üí {C : Type ūĚď¶}
    ‚Üí Cofork f g C ‚Üí ‚ąÄ {ūĚď†} {Q : Type ūĚď†}
    ‚Üí (C ‚Üí Q) ‚Üí Cofork f g Q
cofork-map (p , H) f = (f ‚ąė p , f ‚óā H)
}

\p{We use the abbreviation \code{up} for "universal property".}

\agda{
up-coeq
  : ‚ąÄ {ūĚď§ ūĚď• ūĚď¶} {A : Type ūĚď§} {B : Type ūĚď•}
      {f g : A ‚Üí B} {C : Type ūĚď¶}
    ‚Üí Cofork f g C ‚Üí TypeŌČ
up-coeq f = ‚ąÄ {ūĚď†} {Q : Type ūĚď†} ‚Üí is-equiv (cofork-map f {ūĚď†} {Q})
}
}

\subtree[stt-009N]{
\taxon{Theorem}
\title{Coequalisers are pushouts}

\p{Given a pair of maps #{f,g : A \to B} we can define a span
#{B \xleftarrow{[id,f]} B + A \xrightarrow{[id,g]} B} and show the
following:}

\ul{
\li{There is an equivalence between coforks over #{f,g} and
[cocones](stt-0016) over the induced span.}
\li{A cofork is a coequaliser iff the corresponding cocone is a
pushout}
\li{We can construct canonical coequalisers via
[canonical pushouts](Core.CanonicalPushouts)}
}
}

\agda{
Coeq
  : ‚ąÄ {ūĚď§ ūĚď•} {A : Type ūĚď§} {B : Type ūĚď•}
    ‚Üí (f g : A ‚Üí B) ‚Üí Type (ūĚď§ ‚äĒ ūĚď•)
Coeq {_} {_} {A} {B} f g
  = Pushout l r  module Coeq where
  l : B ‚äé A ‚Üí B
  l (inl x) = x
  l (inr x) = f x

  r : B ‚äé A ‚Üí B
  r (inl x) = x
  r (inr x) = g x

  span : Span _ _ _
  span = mk-span _ l r

{-# DISPLAY Pushout (Coeq.l f g) (Coeq.r f g) = Coeq f g #-}

coeq
  : ‚ąÄ {ūĚď§ ūĚď•} {A : Type ūĚď§} {B : Type ūĚď•}
    ‚Üí (f g : A ‚Üí B) ‚Üí Cofork f g (Coeq f g)
coeq f g = (őĻ‚āā , őĽ x ‚Üí sym (glue (inl (f x))) ‚ąô glue (inr x))

őĻ-coeq
  : ‚ąÄ {ūĚď§ ūĚď•} {A : Type ūĚď§} {B : Type ūĚď•}
    ‚Üí {f g : A ‚Üí B}
    ‚Üí B ‚Üí Coeq f g
őĻ-coeq = coeq _ _ .fst

glue-coeq
  : ‚ąÄ {ūĚď§ ūĚď•} {A : Type ūĚď§} {B : Type ūĚď•}
    ‚Üí {f g : A ‚Üí B}
    ‚Üí őĻ-coeq ‚ąė f ~ őĻ-coeq ‚ąė g
glue-coeq = coeq _ _ .snd


cocone‚Üźcofork
  : ‚ąÄ {ūĚď§ ūĚď• ūĚď¶} {A : Type ūĚď§} {B : Type ūĚď•}
      {f g : A ‚Üí B} {C : Type ūĚď¶}
    ‚Üí Cofork f g C ‚Üí Cocone (Coeq.span f g) C
cocone‚Üźcofork {f = f} {g} (p , H) = mk-cocone p p (‚äé-ind (~refl , H))

cofork‚Üźcocone
  : ‚ąÄ {ūĚď§ ūĚď• ūĚď¶} {A : Type ūĚď§} {B : Type ūĚď•}
      {f g : A ‚Üí B} {C : Type ūĚď¶}
    ‚Üí Cocone (Coeq.span f g) C ‚Üí Cofork f g C
cofork‚Üźcocone {f = f} {g} (mk-cocone p q filler)
  = p , őĽ a ‚Üí filler (inr a) ‚ąô sym (filler (inl (g a)))

cocone‚ČÉfork
  : ‚ąÄ {ūĚď§ ūĚď• ūĚď¶} {A : Type ūĚď§} {B : Type ūĚď•}
      {f g : A ‚Üí B} {C : Type ūĚď¶}
    ‚Üí Cofork f g C ‚ČÉ Cocone (Coeq.span f g) C
cocone‚ČÉfork {B = B} {f} {g} {C}
  = Cofork f g C
      ‚ČÉ‚ü®‚ü©
    (ő£[ p ‚ą∂ (B ‚Üí C)] (p ‚ąė f ~ p ‚ąė g))
      ‚ČÉ‚ü® ő£-ap-‚ČÉ (őĽ _ ‚Üí ő£-ÔľĚsingl') e‚ĀĽ¬Ļ ‚ü©
    (ő£[ p ‚ą∂ (B ‚Üí C)] ő£[ q ‚ą∂ (B ‚Üí C)] ((p ÔľĚ q) √ó (p ‚ąė f ~ q ‚ąė g)))
      ‚ČÉ‚ü® ő£-ap-‚ČÉ (őĽ p ‚Üí ő£-ap-‚ČÉ (őĽ q ‚Üí ő£-ap-‚ČÉ-fst funext‚ČÉ)) ‚ü©
    (ő£[ p ‚ą∂ (B ‚Üí C)] ő£[ q ‚ą∂ (B ‚Üí C)] ((p ~ q) √ó (p ‚ąė f ~ q ‚ąė g)))
      ‚ČÉ‚ü® ő£-ap-‚ČÉ (őĽ p ‚Üí ő£-ap-‚ČÉ (őĽ q ‚Üí ‚äé-UP‚ČÉ global-funext)) ‚ü©
    (ő£[ p ‚ą∂ (B ‚Üí C)] ő£[ q ‚ą∂ (B ‚Üí C)] (p ‚ąė Coeq.l f g ~ q ‚ąė Coeq.r f g))
      ‚ČÉ‚ü® cocone-repr‚ČÉ e‚ĀĽ¬Ļ ‚ü©
    Cocone (Coeq.span f g) C ‚ČÉ‚ąé

cocone‚Üźfork-is-equiv
  : ‚ąÄ {ūĚď§ ūĚď• ūĚď¶} {A : Type ūĚď§} {B : Type ūĚď•}
      {f g : A ‚Üí B} {C : Type ūĚď¶}
    ‚Üí is-equiv (cocone‚Üźcofork {f = f} {g} {C})
cocone‚Üźfork-is-equiv = cocone‚ČÉfork ._‚ČÉ_.fwd-is-equiv

coeq-has-up-coeq : ‚ąÄ {ūĚď§ ūĚď•} {A : Type ūĚď§} {B : Type ūĚď•}
                 {f g : A ‚Üí B} ‚Üí up-coeq (coeq f g)
coeq-has-up-coeq {f = f} {g} {Q = Q}
  = 3-for-2~ (H ~‚ĀĽ¬Ļ)
             (cocone‚ČÉfork ._‚ČÉ_.fwd-is-equiv)
             (Pushout-has-up-pushout) where
  H : cocone‚Üźcofork ‚ąė cofork-map (coeq f g) {Q = Q}
    ~ cocone-map (Coeq.span f g) pushout
  H k = Cocone-path‚Üí _ _ (funext‚Üí (k ‚óā (glue ~‚ĀĽ¬Ļ) ‚Ėł inl)) refl őĽ where
    (inl x) ‚Üí sym ( ap (_‚ąô ap k (glue (inl x))) (ap-sym k (glue (inl x)))
                  ‚ąô ‚ąô-sym' (ap k (glue _)))
            ‚ąô ap (_‚ąô ap k (glue (inl x)))
                 (sym (happly funext-redex x))
    (inr x) ‚Üí ‚ąô-reflr _
            ‚ąô ap-‚ąô k (sym (glue _)) (glue (inr x))
            ‚ąô ap (_‚ąô ap k (glue (inr x)))
                 (sym (happly funext-redex (f x)))


coeq-rec
  : ‚ąÄ {ūĚď§ ūĚď• ūĚď¶} {A : Type ūĚď§} {B : Type ūĚď•}
      {f g : A ‚Üí B} {C : Type ūĚď¶}
    ‚Üí Cofork f g C
    ‚Üí Coeq f g ‚Üí C
coeq-rec = is-equiv.bwd coeq-has-up-coeq

coeq-recő≤
  : ‚ąÄ {ūĚď§ ūĚď• ūĚď¶} {A : Type ūĚď§} {B : Type ūĚď•}
      {f g : A ‚Üí B} {C : Type ūĚď¶}
    ‚Üí (C : Cofork f g C)
    ‚Üí coeq-rec C ‚ąė őĻ-coeq ~ (fst C)
coeq-recő≤ c = happly (ap fst (snd (is-equiv.retraction-bwd coeq-has-up-coeq) c))

coeq-rec-apő≤
  : ‚ąÄ {ūĚď§ ūĚď• ūĚď¶} {A : Type ūĚď§} {B : Type ūĚď•}
    ‚Üí {f g : A ‚Üí B} {C : Type ūĚď¶}
    ‚Üí {c : Cofork f g C}
    ‚Üí (‚ąÄ x ‚Üí ap (coeq-rec c) (glue-coeq x) ÔľĚ c .snd x )
coeq-rec-apő≤ {f = f} {c = c} x =
  ap (pushout-rec _) (sym (glue (inl (f x))) ‚ąô glue (inr x))
    ÔľĚ‚ü® ap-‚ąô (pushout-rec _) (sym (glue (inl (f x)))) (glue (inr x)) ‚ü©
  ap (pushout-rec cocone-data) (sym (glue (inl (f x)))) ‚ąô ap (pushout-rec cocone-data) (glue (inr x))
    ÔľĚ‚ü® ap (_‚ąô ap (pushout-rec cocone-data) (glue (inr x))) (ap-sym (pushout-rec cocone-data) (glue (inl (f x))))‚ü©
  sym (ap (pushout-rec cocone-data) (glue (inl (f x)))) ‚ąô ap (pushout-rec cocone-data) (glue (inr x))
    ÔľĚ‚ü® ap (_‚ąô ap (pushout-rec cocone-data) (glue (inr x))) (ap sym (pushout-rec-apő≤ (inl (f x)))) ‚ü©
  ap (pushout-rec cocone-data) (glue (inr x))
    ÔľĚ‚ü® pushout-rec-apő≤ (inr x) ‚ü©
  (c .snd x) ‚ąé where
    cocone-data =  (_‚Čä_.fwd-qinv cocone-repr‚Čä .fst
        (c .fst , c .fst , ‚äé-ind ((őĽ a ‚Üí refl) , c .snd)))

coeq-rec-is-equiv
  : ‚ąÄ {ūĚď§ ūĚď• ūĚď¶} {A : Type ūĚď§} {B : Type ūĚď•}
      {f g : A ‚Üí B} {C : Type ūĚď¶}
    ‚Üí is-equiv (coeq-rec {f = f} {g} {C})
coeq-rec-is-equiv
  = is-equiv-‚ąė pushout-rec-is-equiv cocone‚Üźfork-is-equiv


module _ {ūĚď§ ūĚď• ūĚď¶} {A : Type ūĚď§} {B : Type ūĚď•} {f g : A ‚Üí B}
         {C : Type ūĚď¶} (cf : Cofork f g C) where
  private
    H : ‚ąÄ {ūĚď†} {Q : Type ūĚď†}
        ‚Üí cocone-map (Coeq.span f g) (cocone‚Üźcofork cf) {Q}
        ~ cocone‚Üźcofork ‚ąė cofork-map cf
    H f = Cocone-path‚Üí _ _ refl refl (‚äé-ind (~refl , (~‚ąô-reflr _)))

  up-coeq‚Üźup-pushout
    : up-pushout (Coeq.span f g) (cocone‚Üźcofork cf)
    ‚Üí up-coeq cf
  up-coeq‚Üźup-pushout po = 3-for-2~ H (cocone‚ČÉfork ._‚ČÉ_.fwd-is-equiv) po

  up-pushout‚Üźup-coeq
    : up-coeq cf
    ‚Üí up-pushout (Coeq.span f g) (cocone‚Üźcofork cf)
  up-pushout‚Üźup-coeq coe
    = is-equiv-~‚ąė H (cocone‚ČÉfork ._‚ČÉ_.fwd-is-equiv) coe

cogap-is-equiv‚Üźup-coeq
  : ‚ąÄ {ūĚď§ ūĚď• ūĚď¶} {A : Type ūĚď§} {B : Type ūĚď•} {f g : A ‚Üí B} {C : Type ūĚď¶}
      {cf : Cofork f g C} ‚Üí up-coeq cf ‚Üí is-equiv (coeq-rec cf)
cogap-is-equiv‚Üźup-coeq {cf = cf} ce
  = is-pushout‚Üźup-pushout (cocone‚Üźcofork cf)
                              (up-pushout‚Üźup-coeq cf ce)

up-coeq‚Üźcogap-is-equiv
  : ‚ąÄ {ūĚď§ ūĚď• ūĚď¶} {A : Type ūĚď§} {B : Type ūĚď•} {f g : A ‚Üí B} {C : Type ūĚď¶}
      {cf : Cofork f g C} ‚Üí is-equiv (coeq-rec cf) ‚Üí up-coeq cf
up-coeq‚Üźcogap-is-equiv {cf = cf} ce
  = up-coeq‚Üźup-pushout cf (up-pushout‚Üźis-pushout _ ce)
}

\subtree[stt-009O]{
\title{Induction for coequalisers}
\taxon{Theorem}

\p{Coequalisers satisfy an induction principle: given maps
#{f,g : A \to B}, and a family of types #{P} over the coequaliser
of #{f} and #{g}, we can give a section #{\Pi_{(a : \rm{Coeq}_{f,g})} P(a)}
by giving a section #{p : \Pi_{(b:B)}(P(\iota(b)))} and for each #{a},
a dependent identification #{p(f(a)) =_P^{gl} p(g(a))}. This data
is called a dependent cofork or \code{CoforkŠĶą} in code.}

\agda{
CoforkŠĶą
  : ‚ąÄ {ūĚď§ ūĚď• ūĚď¶} {A : Type ūĚď§} {B : Type ūĚď•}
      (f g : A ‚Üí B) (C : Coeq f g ‚Üí Type ūĚď¶)
    ‚Üí Type (ūĚď§ ‚äĒ ūĚď• ‚äĒ ūĚď¶)
CoforkŠĶą {A = A} {B} f g C
  =  ő£[ p ‚ą∂ ((b : B) ‚Üí C (őĻ‚āā b))]
      (‚ąÄ a ‚Üí IdŠ∂† C (coeq f g .snd a) (p (f a)) (p (g a)))

cocone‚ÜźcoforkŠĶą
  : ‚ąÄ {ūĚď§ ūĚď• ūĚď¶} {A : Type ūĚď§} {B : Type ūĚď•}
      {f g : A ‚Üí B} {C : Coeq f g ‚Üí Type ūĚď¶}
    ‚Üí CoforkŠĶą f g C
    ‚Üí CoconeŠĶą (Coeq.span f g) (cocone‚Üźcofork (coeq f g)) C
cocone‚ÜźcoforkŠĶą {f = f} {g} (p , H)
  = mk-coconeŠĶą p p (‚äé-ind (~refl , H))

cocone‚ČÉforkŠĶą
  : ‚ąÄ {ūĚď§ ūĚď• ūĚď¶} {A : Type ūĚď§} {B : Type ūĚď•}
      {f g : A ‚Üí B} {C : Coeq f g ‚Üí Type ūĚď¶}
    ‚Üí CoforkŠĶą f g C
    ‚ČÉ CoconeŠĶą (Coeq.span f g) (cocone‚Üźcofork (coeq f g)) C
cocone‚ČÉforkŠĶą {B = B} {f} {g} {C}
  = CoforkŠĶą f g C
      ‚ČÉ‚ü®‚ü©
    (ő£[ p ‚ą∂ (ő† B (C ‚ąė őĻ‚āā))] (p ‚ąė f ~[ (C ‚óā (coeq f g .snd)) ] p ‚ąė g))
      ‚ČÉ‚ü® ő£-ap-‚ČÉ (őĽ p ‚Üí ő£-ÔľĚsingl') e‚ĀĽ¬Ļ ‚ü©
    (ő£[ p ‚ą∂ (ő† B (C ‚ąė őĻ‚āā))] ő£[ q ‚ą∂ ő† B (C ‚ąė őĻ‚āā)] ((p ÔľĚ q) √ó (p ‚ąė f ~[ C ‚óā (coeq f g .snd) ] q ‚ąė g)))
      ‚ČÉ‚ü® ő£-ap-‚ČÉ (őĽ p ‚Üí ő£-ap-‚ČÉ (őĽ q ‚Üí ő£-ap-‚ČÉ-fst funext‚ČÉ)) ‚ü©
    (ő£[ p ‚ą∂ ő† B (C ‚ąė őĻ‚āā)] ő£[ q ‚ą∂ ő† B (C ‚ąė őĻ‚āā)] ((p ~ q) √ó (p ‚ąė f ~[ C ‚óā (coeq f g .snd) ] q ‚ąė g)))
      ‚ČÉ‚ü® ő£-ap-‚ČÉ (őĽ p ‚Üí ő£-ap-‚ČÉ (őĽ q ‚Üí ‚äé-UP‚ČÉ global-funext)) ‚ü©
    (ő£[ p ‚ą∂ ő† B (C ‚ąė őĻ‚āā)] ő£[ q ‚ą∂ ő† B (C ‚ąė őĻ‚āā)] (p ‚ąė Coeq.l f g ~[ (C ‚óā ‚äé-ind (~refl , coeq f g .snd)) ] q ‚ąė Coeq.r f g))
      ‚ČÉ‚ü® coconeD-repr‚ČÉ e‚ĀĽ¬Ļ ‚ü©
    CoconeŠĶą (Coeq.span f g) _ C ‚ČÉ‚ąé

cocone‚ÜźcoforkŠĶą-is-equiv
  : ‚ąÄ {ūĚď§ ūĚď• ūĚď¶} {A : Type ūĚď§} {B : Type ūĚď•}
      {f g : A ‚Üí B} {C : Coeq f g ‚Üí Type ūĚď¶}
    ‚Üí is-equiv (cocone‚ÜźcoforkŠĶą {f = f} {g} {C})
cocone‚ÜźcoforkŠĶą-is-equiv = cocone‚ČÉforkŠĶą ._‚ČÉ_.fwd-is-equiv

coforkŠĶą-map
  : ‚ąÄ {ūĚď§ ūĚď• ūĚď¶} {A : Type ūĚď§} {B : Type ūĚď•}
      {f g : A ‚Üí B} {C : Coeq f g ‚Üí Type ūĚď¶}
    ‚Üí ő† _ C ‚Üí CoforkŠĶą f g C
coforkŠĶą-map {C = C} f = (f ‚ąė őĻ‚āā , f ‚óāŠĶą coeq _ _ .snd)

coeq-is-coeqŠĶą
  : ‚ąÄ {ūĚď§ ūĚď• ūĚď¶} {A : Type ūĚď§} {B : Type ūĚď•}
      {f g : A ‚Üí B} {C : Coeq f g ‚Üí Type ūĚď¶}
    ‚Üí is-equiv (coforkŠĶą-map {C = C})
coeq-is-coeqŠĶą {f = f} {g} {Q}
  = 3-for-2~ (H ~‚ĀĽ¬Ļ) cocone‚ÜźcoforkŠĶą-is-equiv coeq-is-po where
  H : cocone‚ÜźcoforkŠĶą ‚ąė coforkŠĶą-map {C = Q}
    ~ coconeŠĶą-map (Coeq.span f g) (cocone‚Üźcofork (coeq f g))  {Q = Q}
  H f = from-coconeŠĶą-path (record {
      pÔľĚ = refl
    ; qÔľĚ = refl
    ; fillerÔľĚ = funext‚Üí (‚äé-ind (~refl , ~refl)) })

  lem : cocone‚Üźcofork (coeq f g) ÔľĚ pushout
  lem = Cocone-path‚Üí _ _ (funext‚Üí (őĽ b ‚Üí sym (glue (inl b)))) refl
          (‚äé-ind ( (őĽ b ‚Üí sym (‚ąô-sym' (glue (inl b)))
                        ‚ąô ap (_‚ąô glue (inl b)) (sym (happly funext-redex b)))
                  , (őĽ a ‚Üí ‚ąô-reflr _
                         ‚ąô ap (_‚ąô glue (inr a)) (sym (happly funext-redex (f a))))))

  coeq-is-po : upŠĶą-pushout (Coeq.span f g) (cocone‚Üźcofork (coeq f g))
  coeq-is-po {ūĚďú} = tr (őĽ x ‚Üí ‚ąÄ {Q : Coeq f g ‚Üí Type ūĚďú} ‚Üí is-equiv (coconeŠĶą-map (Coeq.span f g) x {Q}))
                       (sym lem) Pushout-has-upŠĶą-pushout

coeq-ind
  : ‚ąÄ {ūĚď§ ūĚď• ūĚď¶} {A : Type ūĚď§} {B : Type ūĚď•}
      {f g : A ‚Üí B} {C : Coeq f g ‚Üí Type ūĚď¶}
    ‚Üí CoforkŠĶą f g C
    ‚Üí (x : Coeq f g) ‚Üí C x
coeq-ind = is-equiv.bwd coeq-is-coeqŠĶą

coeq-indő≤
  : ‚ąÄ {ūĚď§ ūĚď• ūĚď¶} {A : Type ūĚď§} {B : Type ūĚď•}
      {f g : A ‚Üí B} {C : Coeq f g ‚Üí Type ūĚď¶}
    ‚Üí (c : CoforkŠĶą f g C)
    ‚Üí coeq-ind c ‚ąė őĻ-coeq ~ fst c
coeq-indő≤ c = happly (ap fst (snd (is-equiv.retraction-bwd coeq-is-coeqŠĶą) c))




{-# DISPLAY is-equiv.bwd coeq-is-coeqŠĶą x = coeq-ind x #-}
}
}

\subtree[stt-00D4]{
\date{2025-12-14}
\author{markwilliams}
\title{Bi-recursion principle for coequalisers}

\p{We prove a Bi-recursion principle for maps out of two coequalisers.
  Given #{f_1, g_1 : A_1 \to B_1} and #{f_2, g_2 : A_2 \to B_2},
  the data of a map out of both coequalisers is given by a \em{bicofork}.
  Explicitly we have a map #{c : B_1 \to B_2 \to C} with paths #{c(f_1(a), b) = c(g_1(a), b)} and #{c(b, f_2(a)) = c(b, g_2(a)) }.
  Further these paths must satisfy the coherence that for all #{a_1 : A_1}, #{a_2 : A_2} that the following square must commute.
  \quiver{\begin{tikzcd}
    {c(f_1(a_1), f_2(a_2))} & {c(g_1(a_1), f_2(a_2))} \\
    {c(f_1(a_1), g_2(a_2))} & {c(g_1(a_1), g_2(a_2))}
      \arrow[equals, from=1-1, to=1-2]
      \arrow[equals, from=1-1, to=2-1]
      \arrow[equals, from=1-2, to=2-2]
      \arrow[equals, from=2-1, to=2-2]
    \end{tikzcd}}
  This ensures the two maps form a cofork under #{A_1 \rightrightarrows B_1} into the type #{\mathrm{coeq}(f_2, g_2) \to C}.
}



\agda{
module _  {ūĚď§‚āĀ ūĚď§‚āā ūĚď•‚āĀ ūĚď•‚āā ūĚď¶} {A‚āĀ : Type ūĚď§‚āĀ} {A‚āā : Type ūĚď§‚āā} {B‚āĀ : Type ūĚď•‚āĀ} {B‚āā : Type ūĚď•‚āā} where

  BiCofork : (f‚āĀ g‚āĀ : A‚āĀ ‚Üí B‚āĀ) (f‚āā g‚āā : A‚āā ‚Üí B‚āā) (C : Type ūĚď¶) ‚Üí Type (ūĚď§‚āĀ ‚äĒ ūĚď§‚āā ‚äĒ ūĚď•‚āĀ ‚äĒ ūĚď•‚āā ‚äĒ ūĚď¶)
  BiCofork f‚āĀ g‚āĀ f‚āā g‚āā C =
    ő£[ c ‚ą∂ (B‚āĀ ‚Üí B‚āā ‚Üí C) ]
    ő£[ H ‚ą∂ (‚ąÄ a b ‚Üí c (f‚āĀ a) b ÔľĚ c (g‚āĀ a) b) ]
    ő£[ K ‚ą∂ (‚ąÄ b a ‚Üí c b (f‚āā a) ÔľĚ c b (g‚āā a)) ]
    ‚ąÄ a‚āĀ a‚āā ‚Üí Square (K (f‚āĀ a‚āĀ) a‚āā) (K (g‚āĀ a‚āĀ) a‚āā) (H a‚āĀ (f‚āā a‚āā)) (H a‚āĀ (g‚āā a‚āā))


  inner-Cofork‚ÜźBiCofork
    : {f‚āĀ g‚āĀ : A‚āĀ ‚Üí B‚āĀ} {f‚āā g‚āā : A‚āā ‚Üí B‚āā} {C : Type ūĚď¶}
    ‚Üí BiCofork f‚āĀ g‚āĀ f‚āā g‚āā C
    ‚Üí (b‚āĀ : B‚āĀ) ‚Üí Cofork f‚āā g‚āā C
  inner-Cofork‚ÜźBiCofork  (c , (H , (K , S))) b‚āĀ = c b‚āĀ ,  K b‚āĀ

  Cofork‚ÜźBiCofork
    : {f‚āĀ g‚āĀ : A‚āĀ ‚Üí B‚āĀ} {f‚āā g‚āā : A‚āā ‚Üí B‚āā} {C : Type ūĚď¶}
    ‚Üí BiCofork f‚āĀ g‚āĀ f‚āā g‚āā C
    ‚Üí Cofork f‚āĀ g‚āĀ ((Coeq f‚āā g‚āā) ‚Üí C)
  Cofork‚ÜźBiCofork {f‚āĀ = f‚āĀ} {g‚āĀ} {f‚āā} {g‚āā} (c , (H , (K , S)))
    = (őĽ b‚āĀ ‚Üí coeq-rec (inner-Cofork‚ÜźBiCofork (c , (H , (K , S))) b‚āĀ)) ,
         őĽ a‚āĀ ‚Üí funext‚Üí (coeq-ind ((H a‚āĀ)
                        , őĽ a‚āā ‚Üí IdŠĶą-func‚ÜźSquare
                           {f = coeq-rec (c (f‚āĀ a‚āĀ) , K (f‚āĀ a‚āĀ))}
                           {g = coeq-rec (c (g‚āĀ a‚āĀ) , K (g‚āĀ a‚āĀ))}
                           (coeq f‚āā g‚āā .snd a‚āā) (H a‚āĀ (f‚āā a‚āā)) (H a‚āĀ (g‚āā a‚āā))
                             (coe (sym (ap (őĽ x ‚Üí Square x _ (H a‚āĀ (f‚āā a‚āā)) (H a‚āĀ (g‚āā a‚āā))) (coeq-rec-apő≤ _)
                                       ‚ąô ap (őĽ x ‚Üí Square _ x (H a‚āĀ (f‚āā a‚āā)) (H a‚āĀ (g‚āā a‚āā))) (coeq-rec-apő≤ _)))
                                  (S a‚āĀ a‚āā))))

  coeq-rec‚āā
    : {f‚āĀ g‚āĀ : A‚āĀ ‚Üí B‚āĀ} {f‚āā g‚āā : A‚āā ‚Üí B‚āā} {C : Type ūĚď¶}
    ‚Üí BiCofork f‚āĀ g‚āĀ f‚āā g‚āā C ‚Üí Coeq f‚āĀ g‚āĀ ‚Üí Coeq f‚āā g‚āā ‚Üí C
  coeq-rec‚āā = coeq-rec ‚ąė Cofork‚ÜźBiCofork

  coeq-rec‚āāő≤
    : {f‚āĀ g‚āĀ : A‚āĀ ‚Üí B‚āĀ} {f‚āā g‚āā : A‚āā ‚Üí B‚āā} {C : Type ūĚď¶}
    ‚Üí (BC : BiCofork f‚āĀ g‚āĀ f‚āā g‚āā C)
    ‚Üí ‚ąÄ b‚āĀ b‚āā ‚Üí coeq-rec‚āā BC (őĻ-coeq b‚āĀ) (őĻ-coeq b‚āā) ÔľĚ (fst BC) b‚āĀ b‚āā
  coeq-rec‚āāő≤ BC b‚āĀ b‚āā =
    coeq-rec‚āā BC (őĻ-coeq b‚āĀ) (őĻ-coeq b‚āā)                  ÔľĚ‚ü® happly (coeq-recő≤ (Cofork‚ÜźBiCofork BC) b‚āĀ) (őĻ-coeq b‚āā) ‚ü©
    coeq-rec (inner-Cofork‚ÜźBiCofork BC b‚āĀ)  (őĻ-coeq b‚āā)  ÔľĚ‚ü® coeq-recő≤ (inner-Cofork‚ÜźBiCofork BC b‚āĀ) b‚āā ‚ü©
      (fst BC) b‚āĀ b‚āā ‚ąé
}
}

\subtree[stt-009D]{
\title{Adjusting coequalisers by equivalences}

\p{We mirror the results in \ref{stt-0083} about pushouts.

Given a pair of maps #{f g : A \to B} and an equivalence #{e : A' \to A},
we show that a cofork coequalises #{(f,g)} iff it coequalises
#{(fe,ge)}.}

\agda{
postcomp-cofork
  : ‚ąÄ {ūĚď§ ūĚď• ūĚď¶ ūĚďõ} {A' : Type ūĚď¶} {A : Type ūĚď§} {B : Type ūĚď•}
      (f g : A ‚Üí B)
      (h : A' ‚Üí A) {D : Type ūĚďõ}
    ‚Üí Cofork f g D
    ‚Üí Cofork (f ‚ąė h) (g ‚ąė h) D
postcomp-cofork _ _ h = total-map őĽ f ‚Üí _‚Ėł h


postcomp-cofork-is-equiv
  : ‚ąÄ {ūĚď§ ūĚď• ūĚď¶ ūĚďõ} {A' : Type ūĚď¶} {A : Type ūĚď§} {B : Type ūĚď•}
      (f g : A ‚Üí B) {h : A' ‚Üí A} ‚Üí is-equiv h
    ‚Üí {D : Type ūĚďõ} ‚Üí is-equiv (postcomp-cofork f g h {D})
postcomp-cofork-is-equiv f g heq {D}
  = is-total-equiv‚Üźis-fibrewise-equiv őĽ a ‚Üí prewhisker-equiv-is-equiv heq

postcomp-cofork-has-up-coeq
  : ‚ąÄ {ūĚď§ ūĚď• ūĚď¶ ūĚďõ} {A' : Type ūĚď¶} {A : Type ūĚď§} {B : Type ūĚď•}
      {f g : A ‚Üí B}
      {h : A' ‚Üí A} ‚Üí is-equiv h
    ‚Üí {D : Type ūĚďõ}
    ‚Üí {cf : Cofork f g D}
    ‚Üí up-coeq cf
    ‚Üí up-coeq (postcomp-cofork _ _ h cf)
postcomp-cofork-has-up-coeq {f = f} {g} {h} heq {D} {cf} coeq
  = is-equiv-‚ąė (postcomp-cofork-is-equiv _ _ heq) coeq


postcomp-coeq‚ČÉ
  : ‚ąÄ {ūĚď§ ūĚď• ūĚď¶} {A' : Type ūĚď¶} {A : Type ūĚď§} {B : Type ūĚď•}
      {f g : A ‚Üí B} {h : A' ‚Üí A} ‚Üí is-equiv h
    ‚Üí Coeq (f ‚ąė h) (g ‚ąė h) ‚ČÉ Coeq f g
postcomp-coeq‚ČÉ {f = f} {g} {h} heq
  = mk‚ČÉ map (cogap-is-equiv‚Üźup-coeq
              (postcomp-cofork-has-up-coeq heq coeq-has-up-coeq)) where
  map : Coeq (f ‚ąė h) (g ‚ąė h) ‚Üí Coeq f g
  map = coeq-rec (postcomp-cofork f g h (coeq _ _))
}

\p{We dualise this to precomposing coforks.}

\agda{
precomp-cofork
  : ‚ąÄ {ūĚď§ ūĚď• ūĚď¶ ūĚďõ} {A : Type ūĚď§} {B : Type ūĚď•} {B' : Type ūĚď¶}
      (f g : A ‚Üí B)
      (h : B ‚Üí B') {D : Type ūĚďõ}
    ‚Üí Cofork (h ‚ąė f) (h ‚ąė g) D
    ‚Üí Cofork f g D
precomp-cofork f g h = total-map-fst (_‚ąė h)

precomp-cofork-is-equiv
  : ‚ąÄ {ūĚď§ ūĚď• ūĚď¶ ūĚďõ} {A : Type ūĚď§} {B : Type ūĚď•} {B' : Type ūĚď¶}
      (f g : A ‚Üí B) {h : B ‚Üí B'} ‚Üí (heq : is-equiv h)
    ‚Üí {D : Type ūĚďõ} ‚Üí is-equiv (precomp-cofork f g h {D})
precomp-cofork-is-equiv f g {h} heq {D}
  = total-is-equiv‚Üźfst-is-equiv (precomp-equiv heq)

precomp-cofork-has-up-coeq
  : ‚ąÄ {ūĚď§ ūĚď• ūĚď¶ ūĚďõ} {A : Type ūĚď§} {B : Type ūĚď•} {B' : Type ūĚď¶}
      {f g : A ‚Üí B} {h : B ‚Üí B'} ‚Üí is-equiv h
    ‚Üí {D : Type ūĚďõ}
    ‚Üí {cf : Cofork (h ‚ąė f) (h ‚ąė g) D}
    ‚Üí up-coeq cf
    ‚Üí up-coeq (precomp-cofork _ _ h cf)
precomp-cofork-has-up-coeq {f = f} {g} {h} heq {D} {cf} coeq
  = is-equiv-‚ąė (precomp-cofork-is-equiv _ _ heq) coeq

precomp-coeq‚ČÉ
  : ‚ąÄ {ūĚď§ ūĚď• ūĚď¶} {A : Type ūĚď§} {B : Type ūĚď•} {B' : Type ūĚď¶}
      {f g : A ‚Üí B} {h : B ‚Üí B'} ‚Üí is-equiv h
    ‚Üí Coeq f g ‚ČÉ Coeq (h ‚ąė f) (h ‚ąė g)
precomp-coeq‚ČÉ {f = f} {g} {h} heq
  = mk‚ČÉ map (cogap-is-equiv‚Üźup-coeq
              (precomp-cofork-has-up-coeq heq coeq-has-up-coeq)) where
  map : Coeq f g ‚Üí Coeq (h ‚ąė f) (h ‚ąė g)
  map = coeq-rec (precomp-cofork f g h (coeq _ _))
}
}

\subtree[stt-009J]{
\title{Coequalisers of homotopic maps}
\taxon{Lemma}

\p{Given maps #{f,g,f',g' : A \to B} if #{f ~ f'} and #{g ~ g'} then
the coequaliser of #{f} and #{g} is equivalent to the coequalisers of
#{f'} and #{g'}.}

\agda{
module _ {ūĚď§ ūĚď•} {A : Type ūĚď§} {B : Type ūĚď•} {f g h k : A ‚Üí B}
         (H : f ~ h) (K : g ~ k) where
  Coeq‚ČÉ‚Üźhomotopy : Coeq h k ‚ČÉ Coeq f g
  Coeq‚ČÉ‚Üźhomotopy = Pushout‚ČÉ‚Üźhomotopy (‚äé-ind (~refl , H))
                                     (‚äé-ind (~refl , K))

postcomp-coeq‚ČÉ~
  : ‚ąÄ {ūĚď§ ūĚď• ūĚď¶} {A' : Type ūĚď¶} {A : Type ūĚď§} {B : Type ūĚď•}
      {f g : A ‚Üí B} {h : A' ‚Üí A} (heq : is-equiv h)
      {f' g' : A' ‚Üí B} (H : f ‚ąė h ~ f') (K : g ‚ąė h ~ g')
    ‚Üí Coeq f' g' ‚ČÉ Coeq f g
postcomp-coeq‚ČÉ~ {f = f} {g} {h} heq {f'} {g'} H K
  = Coeq f' g'           ‚ČÉ‚ü® Coeq‚ČÉ‚Üźhomotopy H K ‚ü©
    Coeq (f ‚ąė h) (g ‚ąė h) ‚ČÉ‚ü® postcomp-coeq‚ČÉ heq ‚ü©
    Coeq f g ‚ČÉ‚ąé

precomp-coeq‚ČÉ~
  : ‚ąÄ {ūĚď§ ūĚď• ūĚď¶} {A : Type ūĚď§} {B : Type ūĚď•} {B' : Type ūĚď¶}
      {f g : A ‚Üí B} {h : B ‚Üí B'} (heq : is-equiv h)
      {f' g' : A ‚Üí B'} (H : f' ~ h ‚ąė f) (K : g' ~ h ‚ąė g)
    ‚Üí Coeq f g ‚ČÉ Coeq f' g'
precomp-coeq‚ČÉ~ {f = f} {g} {h} heq {f'} {g'} H K
  = Coeq f g             ‚ČÉ‚ü® precomp-coeq‚ČÉ heq ‚ü©
    Coeq (h ‚ąė f) (h ‚ąė g) ‚ČÉ‚ü® Coeq‚ČÉ‚Üźhomotopy H K ‚ü©
    Coeq f' g' ‚ČÉ‚ąé
}
}

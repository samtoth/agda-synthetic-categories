{
  "Agda block": {
    "prefix": "\\agda{",
    "body": ["%```agda", "\\agda{", "$1", "}", "%```"],
    "include": ["**/*.tree", "**/*.lagda.tree"],
  },
  "Quiver": {
    "prefix": "\\quiver{",
    "body": [
      "\\quiver{",
      "\\begin{tikzcd}",
      "$0",
      "\\arrow[\"?\", from=?-?, to=?-?]",
      "\\end{tikzcd}",
      "}",
    ],
  },
  "esh (ʃ)": {
    "prefix": "esh",
    "body": "ʃ",
  },
}

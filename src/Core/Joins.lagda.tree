\date{2025-04-18}
\title{Joins}
\author{samueltoth}
\taxon{Module}

\import{stt-macros}


\agda{
module Core.Joins where

open import Foundations.Prelude
open import UF
open import Core.Suspensions
open import Core.Arrows
open import Core.CocartesianSquares
open import Core.CanonicalPushouts

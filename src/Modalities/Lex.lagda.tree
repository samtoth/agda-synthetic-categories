\subtree{
\title{Modality extensionality}
\taxon{Definition}

%```agda
\agda{
module _ {α} {S : GSU α}
             (Srfl : is-globally-reflective S)
             (let Srfl' = is-reflective←global Srfl)
             (Σ-is-modal : is-globally-Σ-closed S)
             where
  open is-globally-reflective Srfl
  open GPiClosure Srfl
  open GRSUInduction Srfl Σ-is-modal

  opaque
    mapply-○ : ∀ {𝓤} {A : Type 𝓤} {a b : A} → ○ (a ＝ b) → η a ＝ η b
    mapply-○ = ○-rec (＝∈S ○∈S) (ap η)

    mapply-refl
      : ∀ {𝓤} {A : Type 𝓤} {a : A} → mapply-○ (η (refl)) ＝ refl {a = η a}
    mapply-refl = ○-rec-β (＝∈S ○∈S) (ap η) refl

module _ {α} {S : GSU α}
             (Srfl : is-globally-reflective S)
             (let Srfl' = is-reflective←global Srfl)
             (Σ-is-modal : is-globally-Σ-closed S)
             (mapply-○ : ∀ {𝓤} {A : Type 𝓤} {a b : A}
                         → let open is-globally-reflective Srfl
                         in ○ (a ＝ b)
                         → η a ＝ η b)
             where
  open is-globally-reflective Srfl
  open GPiClosure Srfl
  open GRSUInduction Srfl Σ-is-modal

  is-lex : Typeω
  is-lex = ∀ {𝓤} {A : Type 𝓤} {a b : A} → is-equiv (mapply-○ {a = a}{b})

  η-square
    : ∀ {𝓤 𝓥} {A : Type 𝓤} {B : Type 𝓥} (f : A → B)
      → Arrow-map f (○-map (η f))
  η-square f .Arrow-map.top = η
  η-square f .Arrow-map.bot = η
  η-square f .Arrow-map.comm _ = sym ○-map-β

  ○-fibre-map
    : ∀ {𝓤 𝓥} {A : Type 𝓤} {B : Type 𝓥} (f : A → B)
      → ∀ b → fibre f b → fibre (○-map (η f)) (η b)
  ○-fibre-map f = arrow-fibre (η-square f)


  module Lex (lex : is-lex) where
    ○-modext→ : ∀ {𝓤} {A : Type 𝓤} {a b : A} → η a ＝ η b → ○ (a ＝ b)
    ○-modext→ = is-equiv.bwd lex

    ＝-is-connected
      : ∀ {𝓤} {A : Type 𝓤} {a b : A}
        → is-connected Srfl' A → is-connected Srfl' (a ＝ b)
    ＝-is-connected Ac
      = is-single←equiv-to-single
          ((mk≃ _ lex) e⁻¹)
          (＝-singleton←is-prop (is-prop←is-single Ac) (η _) (η _))

    is-connected←cod-dom-is-connected
      : ∀ {𝓤 𝓥} {A : Type 𝓤} {B : Type 𝓥}
        → is-connected Srfl' A → is-connected Srfl' B
        → ∀ (f : A → B) → is-connected-map Srfl' f
    is-connected←cod-dom-is-connected Ac Bc f b
      = Σ-is-connected Ac λ _ → ＝-is-connected Bc

    is-connected-left-cancel
      : ∀ {𝓤 𝓥 𝓦} {A : Type 𝓤} {B : Type 𝓥} {C : Type 𝓦}
          {f : A → B} {g : B → C}
        → is-connected-map Srfl' g → is-connected-map Srfl' (g ∘ f)
        → is-connected-map Srfl' f
    is-connected-left-cancel {f = f}{g} fconn gfconn b
      = is-single←equiv-to-single
          (○-≃ (fibre-unstable-octagon {f = g} {f} b e⁻¹))
          (is-connected←cod-dom-is-connected
            (gfconn (g b))
            (fconn  (g b))
            _
            (b , refl))

    is-connected-map←is-modal-equiv
      : ∀ {𝓤 𝓥} {A : Type 𝓤} {B : Type 𝓥} {f : A → B}
        → is-modal-equiv Srfl f
        → is-connected-map (is-reflective←global Srfl) f
    is-connected-map←is-modal-equiv {A = A} {B} {f} feq
      = is-connected-left-cancel {f = f} {g = η}
          (η-is-connected Srfl Σ-is-modal)
          (is-connected-~
            Srfl
            (sym ∘ η-square f .Arrow-map.comm)
            (is-connected-∘ Srfl Σ-is-modal
              {f = ○-map (η f)} {η}
              (η-is-connected Srfl Σ-is-modal)
              (is-connected←is-equiv Srfl feq)))

    -- is-fibrewise-connected←is-total-connected
    --   : ∀ {𝓤 𝓥 𝓦 𝓜} {A : Type 𝓤} {B : Type 𝓥} (f : A → B)
    --       {P : A → Type 𝓦} {Q : B → Type 𝓜}
    --     → (g : (a : A) → P a → Q (f a))
    --     → is-connected-map {A = Σ A P} {B = Σ B Q} Srfl'
    --                        (λ (a , b) → (f a , g a b))

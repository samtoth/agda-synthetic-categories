      έΚΔ έθρέβφ| LiftMap (╬╡έβφ (έΙγTypeέΙβ-╧Α {ΏζΥξ})) (╬╡έβφ (transpose (modέβφ A))) έθσ
    transpose-liftέβφ {ΏζΥν}{ΏζΥξ}{╬Υ}{A}
      =   έθρέβφ| LiftMap (Type-╧Α ΏζΥξ) A έθσ
      έΚΔέθρ έβφ-comm╬μ _ eέΒ╗┬╣ έθσ
          (╬μ[έβφ l έΙ╢ ((I έΗΤ ╬Υ) έΗΤ TypeέΙβ ΏζΥξ) ] έθρέβφ| fst έΙα l Ύ╝ζ A  έθσ)
      έΚΔέθρ ╬μ-ap-έΚΔ-fst-bwd expέΛμέΙγ eέΒ╗┬╣ έθσ
         ╬μ έθρέβφ| (╬Υ έΗΤ έΙγ (TypeέΙβ ΏζΥξ)) έθσ
          (έβφ-ind _ (╬╗ (@έβφ l) έΗΤ έθρέβφ| fst έΙα l Ύ╝ζ A έθσ) έΙα έβφ-map untranspose)
      έΚΔέθρ ╬μ-ap-έΚΔ (╬╗ {(modέβφ l) έΗΤ idέΚΔ}) έθσ
          (╬μ[έβφ l έΙ╢ (╬Υ έΗΤ έΙγ (TypeέΙβ ΏζΥξ)) ] έθρέβφ| fst έΙα untranspose l Ύ╝ζ A έθσ)
      έΚΔέθρ ╬μ-ap-έΚΔ (╬╗ {(modέβφ l) έΗΤ mkέΚΔ (f l) (feq l)}) έθσ
          (╬μ[έβφ l έΙ╢ (╬Υ έΗΤ έΙγ (TypeέΙβ ΏζΥξ)) ]
             έθρέβφ| (╬╡έβφ έΙγTypeέΙβ-╧Α) έΙα l Ύ╝ζ ╬╡έβφ (transpose (modέβφ A)) έθσ)
      έΚΔέθρ έβφ-comm╬μ _ έθσ
          έθρέβφ| LiftMap (╬╡έβφ έΙγTypeέΙβ-╧Α) (╬╡έβφ (transpose (modέβφ A))) έθσ
      έΚΔέΙΟ where
      @έβφ f : έΙΑ (@έβφ l : ╬Υ έΗΤ έΙγ (TypeέΙβ ΏζΥξ))
             έΗΤ έθρέβφ| fst έΙα untranspose l Ύ╝ζ A έθσ
             έΗΤ έθρέβφ| ╬╡έβφ έΙγTypeέΙβ-╧Α έΙα l Ύ╝ζ ╬╡έβφ (transpose (modέβφ A)) έθσ
      f l  = transpose-unique έΙα έβφ-map ((happly (έΙγέΓΒ-nat (modέβφ fst)) l έΙβ_))

      @έβφ feq : έΙΑ (@έβφ l) έΗΤ is-equiv (f l)
      feq l = is-equiv-έΙα
        transpose-unique-is-equiv
        (έβφ-map-is-equiv (έΙβ-is-equiv (happly (έΙγέΓΒ-nat (modέβφ fst)) l)))

  ╬ιέΗΡlift : έΙΑ {@έβφ ΏζΥν ΏζΥξ} {@έβφ ╬Υ : Type ΏζΥν} {@έβφ A : (I έΗΤ ╬Υ) έΗΤ Type ΏζΥξ}
         έΗΤ LiftMap (╬╡έβφ (έΙγTypeέΙβ-╧Α {ΏζΥξ})) (╬╡έβφ (transpose (modέβφ A)))
         έΗΤ ╬ι ╬Υ (έΙγά╡Ι A)
  ╬ιέΗΡlift {A = A} = universal-section (╬╡έβφ (transpose (modέβφ A)))
                                     (╬╗ _ έΗΤ self-is-small)

  opaque
    rintro
      : έΙΑ {@έβφ ΏζΥν ΏζΥξ} {@έβφ ╬Υ : Type ΏζΥν} {@έβφ A : (I έΗΤ ╬Υ) έΗΤ Type ΏζΥξ}
        έΗΤ έθρέβφ| ╬ι (I έΗΤ ╬Υ) A έθσ
        έΗΤ έθρέβφ| ╬ι ╬Υ (έΙγά╡Ι A) έθσ
    rintro {A = A}
      = έβφ-map ╬ιέΗΡlift έΙα transpose-liftέβφ ._έΚΔ_.fwd έΙα έβφ-map (LiftέΗΡ╬ι A)

    rintro-is-equiv
      : έΙΑ {@έβφ ΏζΥν ΏζΥξ} {@έβφ ╬Υ : Type ΏζΥν} {@έβφ A : (I έΗΤ ╬Υ) έΗΤ Type ΏζΥξ}
        έΗΤ is-equiv (rintro {A = A})
    rintro-is-equiv
      = is-equiv-έΙα
          (έβφ-map-is-equiv (universal-section-is-equiv _ (╬╗ _ έΗΤ self-is-small)))
          (is-equiv-έΙα
            (transpose-liftέβφ ._έΚΔ_.has-is-eqv)
            (έβφ-map-is-equiv (LiftέΗΡ╬ι-is-equiv _)))


    relim

-- !!CAUTION!! - this is not in general sound with --without-K - use with caution.
primitive
  primEraseEquality : {рЭУ§ : Level} {A : Type рЭУ§} {x y : A} вЖТ x пЉЭ y вЖТ x пЉЭ y


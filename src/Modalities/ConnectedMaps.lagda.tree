          (тЧЛЁЭЯЩ-is-single RS)

    is-connected-mapтЖРup-connected-map
      : up-connected-map GS f
      тЖТ is-connected-map RS f
    is-connected-mapтЖРup-connected-map fconn
      = reflected-fibres-singletonтЖРmerely-local-centre
          (LC.merely-fibre-local-centreтЖРsurjective-precomp-╬а
            (╬╗ UтИИK y тЖТ Trunc.╬╖
              ( is-equiv.bwd (fconn UтИИK) y
              , is-equiv.╬╡ (fconn UтИИK) y)))

    up-connected-mapтЖРis-connected-map
      : is-connected-map RS f
      тЖТ up-connected-map GS f
    up-connected-mapтЖРis-connected-map fconn
      = up-connected-mapтЖРfibre-terminal-equiv GS f
          (up-connected-!-fibreтЖРis-connected-map fconn)

  connectedтКеmodal
    : тИА {ЁЭУд ЁЭУе ЁЭУж ЁЭУЬ} {A : Type ЁЭУд} {B : Type ЁЭУе} {f : A тЖТ B}
        {X : Type ЁЭУж} {Y : Type ЁЭУЬ} {g : X тЖТ Y}
      тЖТ is-connected-map' (is-reflectiveтЖРgRSubU RS) f

\subtree[fre-2100]{
\date{2026-03-11}
\author{fredrikbakke}
\taxon{Definition}
\title{Equalisers}

\p{
Given a a pair of parallel maps #{f\ g : A \to B}, the \em{equaliser} if #{f} and
#{g} is the limit of the diagram presented by #{f} and #{g}. The equaliser has a
very simple presentation in type theory: it is the type of elements #{a : A} such
that #{f(a) = g(a)}.
}

% ```agda
\agda{
is-equaliser
  : {рЭУ§ рЭУ• рЭУ¶ : Level} {A : Type рЭУ§} {B : Type рЭУ•}
    {f g : A вЖТ B} {E : Type рЭУ¶}
  вЖТ Fork f g E
  вЖТ TypeѕЙ
is-equaliser {f = f} {g = g} {E = E} F
  = вИА {рЭУ†} {Q : Type рЭУ†}
  вЖТ is-equiv (fork-map {f = f} {g = g} {E = E} F {Q = Q})

Equaliser
  : {рЭУ§ рЭУ• : Level} {A : Type рЭУ§} {B : Type рЭУ•}
  вЖТ (f g : A вЖТ B)
  вЖТ Type (рЭУ§ вКФ рЭУ•)
Equaliser {A = A} f g = ќ£[ a вИґ A ] (f a пЉЭ g a)

module _ {рЭУ§ рЭУ• : Level} {A : Type рЭУ§} {B : Type рЭУ•} (f g : A вЖТ B) where

  Equaliser-fork : Fork f g (Equaliser f g)
  Equaliser-fork = fst , snd

  Equaliser-gap
    : вИА {рЭУ†} {Q : Type рЭУ†}
    вЖТ Fork f g Q
    вЖТ Q вЖТ Equaliser f g
  Equaliser-gap (e , H) q = (e q , H q)
}
% ```
}

\subtree[fre-2102]{
\date{2026-03-11}
\author{fredrikbakke}
\taxon{Theorem}
\title{Equalisers as pullbacks}

\p{
The equaliser of a pair of parallel maps #{f\ g : A \to B} can be presented as the
pullback

\quiver{
\begin{tikzcd}
	\textrm{Eq}(f,g) && A  \\
	\\
	B && B \times B
	\arrow[from=1-1, to=1-3]
	\arrow[from=1-1, to=3-1]
	\arrow["{[f,g]}", from=1-3, to=3-3]
	\arrow["\Delta", from=3-1, to=3-3]
	\arrow["\lrcorner" very near start, phantom, from=1-1, to=3-3]
\end{tikzcd}
}
}

% ```agda
\agda{
module _
  {рЭУ§ рЭУ• : Level} {A : Type рЭУ§} {B : Type рЭУ•} {f g : A вЖТ B}
  where

  Equaliser-diagonal-cone
    : Cone
        (mk-cospan (B √Ч B) (ќї b вЖТ (b , b)) (ќї a вЖТ (f a , g a)))
        (Equaliser f g)
  Equaliser-diagonal-cone
    = mk-cone
        (f вИШ fst)
        (fst)
        (ќї (_ , p) вЖТ √Ч-pathвЖТ (refl , p))

  PullbackвЖРEqualiser
    : Equaliser f g
    вЖТ Pullback (ќї b вЖТ (b , b)) (ќї a вЖТ (f a , g a))
  PullbackвЖРEqualiser = gap Equaliser-diagonal-cone

  PullbackвЖРEqualiser-is-equiv
    : is-equiv PullbackвЖРEqualiser
  PullbackвЖРEqualiser-is-equiv = is-equivвЖРqiso qiso where
    bwd : Pullback (ќї b вЖТ (b , b)) (ќї a вЖТ (f a , g a)) вЖТ Equaliser f g
    bwd (b , a , p) = (a , sym (ap fst p) вИЩ ap snd p)

    qiso : quasi-iso PullbackвЖРEqualiser
    qiso .fst = bwd
    qiso .snd .fst (a , p) = ќ£-pathвЖТ (refl , retp) where
      retp
        : sym (ap fst (√Ч-pathвЖТ (refl , p))) вИЩ ap snd (√Ч-pathвЖТ (refl , p))
        пЉЭ p
      retp
        = ap (ќї q вЖТ sym q вИЩ ap snd (√Ч-pathвЖТ (refl , p))) √Ч-path-ap-fst
        вИЩ вИЩ-refll _
        вИЩ √Ч-path-ap-snd
    qiso .snd .snd (b , a , p)
      = pullback-pathвЖТ (sym (ap fst p) , refl , sq p вИЩ sym (вИЩ-reflr _)) where
      sq : {b' : B} {a' : A}
           (p' : (b' , b') пЉЭ (f a' , g a'))
         вЖТ ap (ќї c вЖТ (c , c)) (sym (ap fst p')) вИЩ p'
         пЉЭ √Ч-pathвЖТ (refl , sym (ap fst p') вИЩ ap snd p')
      sq = J ( ќї y p'
             вЖТ ap (ќї c вЖТ (c , c)) (sym (ap fst p')) вИЩ p'
             пЉЭ √Ч-pathвЖТ (refl , sym (ap fst p') вИЩ ap snd p'))
        ( refl)

  EqualiserвЙГPullback-diagonal
    : Equaliser f g
    вЙГ Pullback (ќї b вЖТ (b , b)) (ќї a вЖТ (f a , g a))
  EqualiserвЙГPullback-diagonal
    = mkвЙГ PullbackвЖРEqualiser PullbackвЖРEqualiser-is-equiv
}
% ```
}

\subtree{
\date{2026-03-11}
\author{fredrikbakke}
\taxon{Lemma}
\title{Identity types as equalisers}

\p{
The identity type #{x пЉЭ y} can be presented as the equaliser of the two maps
#{\point(x),\point(y) : \bb{1} \to A}.
}

% ```agda
\agda{
module _ {рЭУ§ : Level} {A : Type рЭУ§} (x y : A) where

  пЉЭ-fork
    : Fork (point x) (point y) (x пЉЭ y)
  пЉЭ-fork = (! , id)

  пЉЭ-Equaliser-point-gap
    : x пЉЭ y
    вЖТ Equaliser (point x) (point y)
  пЉЭ-Equaliser-point-gap
    = Equaliser-gap (point x) (point y) (пЉЭ-fork)

  пЉЭ-Equaliser-point-gap-is-equiv
    : is-equiv пЉЭ-Equaliser-point-gap
  пЉЭ-Equaliser-point-gap-is-equiv
    = mk-eqv (snd , ~refl , ~refl) (~refl)

  пЉЭвЙГEqualiser-point
    : (x пЉЭ y)
    вЙГ Equaliser (point x) (point y)
  пЉЭвЙГEqualiser-point
    = mkвЙГ пЉЭ-Equaliser-point-gap пЉЭ-Equaliser-point-gap-is-equiv
}
% ```
}

\date{2026-05-01}
\title{Contravariant type families}
\taxon{Module}
\import{stt-macros}

\agda{
open import Foundations.Prelude
open import Algebra.Lattice

module Synthetic.Categories.ContravariantFamilies
  {рЭУШ} (ќФ¬є : Type рЭУШ) (I : Lattice ќФ¬є) (I-distr : is-distributive I)
  where

open Lattice I renaming (0l to i0; 1l to i1)
}

\imports{
\agda{
open import Axioms.UF

open is-distributive I-distr

open import Core.Orthogonal
open import Core.OrthogonalClosure
open import Core.Arrows
open import Core.PushoutSums

open import Ergonomics.Notations.Orthogonality
open Core.Orthogonal.notation

open import Synthetic.Hom ќФ¬є i0 i1
open import Synthetic.Horns ќФ¬є I
open import Synthetic.Categories.Precategories ќФ¬є I
}
}

\subtree[stt-00OD]{
\title{Contravariant families}
\taxon{Definition}

\p{A type family #{P : A \to \UU} is said to be \em{contravariant} if for any arrow
#{f : \Delta^1 \to A}, and lift #{x_1 : P(f(1))} over the right endpoint,
the type of morphisms over #{f} which extend #{x_1} forms a singleton.}

\agda{
is-contravariant
  : вИА {рЭУ§ рЭУ•} {A : Type рЭУ§} (P : A вЖТ Type рЭУ•)
    вЖТ Type (рЭУШ вКФ рЭУ§ вКФ рЭУ•)
is-contravariant {A = A} P
  = вИА f (xвВБ : P (f i1)) вЖТ is-singleton (ќ£[ xвВА вИґ P (f i0) ] HomбµИ (P вИШ f) xвВА xвВБ)

{-# INJECTIVE_FOR_INFERENCE is-contravariant #-}

is-contravariant-is-prop
  : вИА {рЭУ§ рЭУ•} {A : Type рЭУ§} (P : A вЖТ Type рЭУ•) вЖТ is-prop (is-contravariant P)
is-contravariant-is-prop _
  = ќ†-is-prop (ќї _ вЖТ ќ†-is-prop (ќї _ вЖТ is-single-is-prop))

is-contravariant-hom
  : вИА {рЭУ§ рЭУ•} {A : Type рЭУ§} (P : A вЖТ Type рЭУ•)
    вЖТ Type (рЭУШ вКФ рЭУ§ вКФ рЭУ•)
is-contravariant-hom {A = A} P
  = вИА {x y} (f : Hom A x y) (y' : P y)
    вЖТ is-singleton (ќ£[ x' вИґ P x ] Hom-over f x' y')

module _ {рЭУ§ рЭУ•} {A : Type рЭУ§} {B : A вЖТ Type рЭУ•} where
  is-contravariant-homвЖРis-contravariant
    : is-contravariant B вЖТ is-contravariant-hom B
  is-contravariant-homвЖРis-contravariant contrav (mk-hom f refl refl) x'
    = contrav f x'

  is-contravariantвЖРis-contravariant-hom
    : is-contravariant-hom B вЖТ is-contravariant B
  is-contravariantвЖРis-contravariant-hom contrav f x'
    = contrav (ќїhom f) x'
}
}


\subtree[stt-00OF]{
\title{Contravariant type families admit directed transport}
\taxon{Lemma}

\agda{
tr-contrav
  : вИА {рЭУ§ рЭУ•} {A : Type рЭУ§} {P : A вЖТ Type рЭУ•}
    вЖТ is-contravariant P вЖТ (h : ќФ¬є вЖТ A) вЖТ P (h i1) вЖТ P (h i0)
tr-contrav contrav h = fst вИШ centre вИШ contrav h

tr-contrav-filler
  : вИА {рЭУ§ рЭУ•} {A : Type рЭУ§} {P : A вЖТ Type рЭУ•}
    вЖТ (Pc : is-contravariant P) вЖТ (h : ќФ¬є вЖТ A)
    вЖТ вИА p вЖТ HomбµИ (P вИШ h) (tr-contrav {P = P} Pc h p) p
tr-contrav-filler cov h = snd вИШ centre вИШ cov h

tr-contrav-hom
  : вИА {рЭУ§ рЭУ•} {A : Type рЭУ§} {P : A вЖТ Type рЭУ•}
    вЖТ is-contravariant P
    вЖТ вИА {x y} (h : Hom A x y) вЖТ P y вЖТ P x
tr-contrav-hom contrav h
  = fst вИШ centre вИШ is-contravariant-homвЖРis-contravariant contrav h

tr-contrav-over
  : вИА {рЭУ§ рЭУ•} {A : Type рЭУ§} {P : A вЖТ Type рЭУ•}
    вЖТ (cov : is-contravariant P)
    вЖТ вИА {x y} (h : Hom A x y) вЖТ (y' : P y)
    вЖТ Hom-over h (tr-contrav-hom cov h y') y'
tr-contrav-over contrav h
  = snd вИШ centre вИШ is-contravariant-homвЖРis-contravariant contrav h
}
}

\subtree[stt-00OE]{
\title{Right type families}
\taxon{Definition}

\p{We say that a type family is a \em{right family} if, as a type family, it is right orthogonal to
the right endpoint inclusion.}

\agda{
is-right-family
  : вИА {рЭУ§ рЭУ•} {A : Type рЭУ§} (B : A вЖТ Type рЭУ•) вЖТ Type (рЭУШ вКФ рЭУ§ вКФ рЭУ•)
is-right-family = are-orthogonal-fam (point i1)
}
}

\subtree[stt-00OG]{
\title{Right families are contravariant}

\agda{
module _ {рЭУ§ рЭУ•} {A : Type рЭУ§} (P : A вЖТ Type рЭУ•) where

  contrav-lift-is-extension
    : вИА (ѕГ : ќФ¬є вЖТ A) (xвВБ : P (ѕГ i1))
      вЖТ (ќ£[ xвВА вИґ P (ѕГ i0) ] HomбµИ (P вИШ ѕГ) xвВА xвВБ)
      вЙГ ExtбµИ (point i1) (P вИШ ѕГ) (point xвВБ)
  contrav-lift-is-extension ѕГ xвВБ
    =  ќ£[ xвВА вИґ P (ѕГ i0) ] HomбµИ (P вИШ ѕГ) xвВА xвВБ
    вЙГвЯ® ќ£-snd-вЙГ (ќї x вЖТ HomбµИ-reprвЙГ) вЯ©
       ќ£[ xвВА вИґ P (ѕГ i0) ] ќ£[ f вИґ ќ† _ (P вИШ ѕГ)] ((f i0 пЉЭ xвВА) √Ч (f i1 пЉЭ xвВБ))
    вЙГвЯ® ќ£-comm вЯ©
       ќ£[ f вИґ ќ† _ (P вИШ ѕГ)] ќ£[ xвВА вИґ P (ѕГ i0) ] ((f i0 пЉЭ xвВА) √Ч (f i1 пЉЭ xвВБ))
    вЙГвЯ® ќ£-snd-вЙГ (ќї f вЖТ ќ£-assoc eвБї¬є вИЩe √Ч-swap вИЩe ќ£-singleton (ќї _ вЖТ Sing-is-singleton)) вЯ©
       ќ£ (ќ† ќФ¬є (P вИШ ѕГ)) (ќї z вЖТ z i1 пЉЭ xвВБ)
    вЙГвЯ® ќ£-snd-вЙГ (ќї f вЖТ unit-UPвЙГ eвБї¬є) вЯ©
       ExtбµИ (point i1) (P вИШ ѕГ) (point xвВБ)
    вЙГвИО

  opaque
    is-contravariantвЖРhas-unique-extensions
      : has-unique-extensions (point i1) P вЖТ is-contravariant P
    is-contravariantвЖРhas-unique-extensions ext ѕГ xвВБ
      = is-singleвЖРequiv-to-single
          (contrav-lift-is-extension ѕГ xвВБ eвБї¬є)
          (ext (mk-afmap ѕГ (point xвВБ)))

    has-unique-extensionsвЖРis-contravariant
      : is-contravariant P вЖТ has-unique-extensions (point i1) P
    has-unique-extensionsвЖРis-contravariant contrav (mk-afmap ѕГ f)
      = is-singleвЖРequiv-to-single
          (contrav-lift-is-extension ѕГ (f tt))
          (contrav ѕГ (f tt))

  has-unique-extensionsвЖФis-contravariant
    : has-unique-extensions (point i1) P вЖФ is-contravariant P
  has-unique-extensionsвЖФis-contravariant
    = ( is-contravariantвЖРhas-unique-extensions
      , has-unique-extensionsвЖРis-contravariant)

  is-right-familyвЖФis-covariant
    : is-right-family P вЖФ is-contravariant P
  is-right-familyвЖФis-covariant
    =  are-orthogonal-famвЖФhas-unique-extensions
    вИЩiff has-unique-extensionsвЖФis-contravariant
}
}

\subtree[stt-00OH]{
\title{Right fibrations}
\taxon{Definition}

\p{A map is a \em{right fibration} if it is [right orthogonal](stt-0048) to the right
endpoint inclusion of #{\Delta^1}.}

\p{See [[stt-00AV]] for the dual notion.}

\agda{
is-right-fibration
  : вИА {рЭУ§ рЭУ•} {A : Type рЭУ§} {B : Type рЭУ•} вЖТ (A вЖТ B)
    вЖТ Type (рЭУ§ вКФ рЭУ• вКФ рЭУШ)
is-right-fibration f = (point i1) вК• f
}
}

\subtree[stt-00OI]{
\title{Contravariant type families straighten to right fibrations}
\taxon{Corollary}

\p{We show that some family #{P : A \to \UU} is [contravariant](stt-00OD) iff
the map #{\pi : \tilde{P} \to A} is a [right fibration](stt-00OH).}

\agda{
module _ {рЭУ§ рЭУ•} {A : Type рЭУ§} (P : A вЖТ Type рЭУ•) where opaque
  is-contravariantвЖФis-right-fibration
    : is-contravariant P вЖФ is-right-fibration (fst: P)
  is-contravariantвЖФis-right-fibration
    = (is-right-familyвЖФis-covariant P iffвБї¬є)
    вИЩiff are-orthogonal-famвЖФare-orthogonal-fst

  is-right-fibrationвЖРis-contravariant
    : is-contravariant P вЖТ is-right-fibration (fst: P)
  is-right-fibrationвЖРis-contravariant = is-contravariantвЖФis-right-fibration .fst

  is-contravariantвЖРis-right-fibration
    : is-right-fibration (fst: P) вЖТ is-contravariant P
  is-contravariantвЖРis-right-fibration = is-contravariantвЖФis-right-fibration .snd
}
}

\subtree[stt-00OJ]{
\title{Right fibrations are inner}
\taxon{Lemma}

\proof{
\p{We use the fact that left orthogonal maps [are closed under pushout products
and embeddings](stt-00BV). In particular we take the pushout product:
#{\underset{\Delta^1}{\overset{\{0\}}{\downarrow}} \pushprod
\underset{\Delta^1}{\overset{\{1\}}{\downarrow}}}, which modulo contracting away
some singletons, is the [inner horn](stt-00AD) inclusion into the square. Now
the following retract square completes the proof:}
\transclude{stt-00LC}
}

\remark{
We may use a perfectly symmetric proof for [left fibrations](stt-00AV)
(\ref{stt-00C7})
}

\agda{
is-innerвЖРis-right-fibration
  : вИА {рЭУ§ рЭУ•} {A : Type рЭУ§} {B : Type рЭУ•} {f : A вЖТ B}
    вЖТ is-right-fibration f вЖТ is-inner f
is-innerвЖРis-right-fibration {f = f} rf
  = left-orthogonal-retraction
      ќЫ[2,1]-incl (pushout-product (point i1) (point i0))
      ќЫ[2,1]вЖ™вЦ°-section ќЫ[2,1]вЖ™вЦ°-ret _
      (left-orthogonal-pushout-product (point i1) f rf (point i0))
}
}

\subtree[stt-00OL]{
\taxon{Corollary}

\p{The total type of a contravariant type family over a Segal type is itself Segal.}

\agda{
is-inner-familyвЖРis-contravariant
  : вИА {рЭУ§ рЭУ•} {A : Type рЭУ§} {B : A вЖТ Type рЭУ•}
    вЖТ is-contravariant B вЖТ is-inner-family B
is-inner-familyвЖРis-contravariant
  = is-innerвЖРis-right-fibration вИШ (is-contravariantвЖФis-right-fibration _ .fst)

is-inner-familyвЖРis-contravariant-hom
  : вИА {рЭУ§ рЭУ•} {A : Type рЭУ§} {B : A вЖТ Type рЭУ•}
    вЖТ is-contravariant-hom B вЖТ is-inner-family B
is-inner-familyвЖРis-contravariant-hom
  = is-inner-familyвЖРis-contravariant вИШ is-contravariantвЖРis-contravariant-hom

ќ£-contrav-is-segal
  : вИА {рЭУ§ рЭУ•} {A : Type рЭУ§} {B : A вЖТ Type рЭУ•}
    вЖТ is-segal A вЖТ is-contravariant B вЖТ is-segal (ќ£ A B)
ќ£-contrav-is-segal apc contrav
  = ќ£-is-segal apc
      (is-innerвЖРis-right-fibration
        (is-contravariantвЖФis-right-fibration _ .fst  contrav))
}
}

\subtree[stt-00OK]{
\title{Contravariant transport is functorial}
\taxon{Theorem}


\p{Given a contravariant type family #{P}, we show the transport operation is
functorial, in the sense that #{P(\id) \sim \id} and
#{P(f \circ g) \sim P(g) \circ P(f)}.}

\agda{
tr-contrav-id
  : вИА {рЭУ§ рЭУ•} {A : Type рЭУ§} (P : A вЖТ Type рЭУ•) (Pc : is-contravariant P) {x}
    вЖТ tr-contrav Pc (ќї _ вЖТ x) ~ id
tr-contrav-id P contrav {x} x' = ap fst (contrav (ќї _ вЖТ x) x' .central (x' , idH x'))

tr-contrav-idH
  : вИА {рЭУ§ рЭУ•} {A : Type рЭУ§} (P : A вЖТ Type рЭУ•) (Pc : is-contravariant P) {x}
    вЖТ tr-contrav-hom {P = P} Pc (idH x) ~ id
tr-contrav-idH P contrav {x} x' = ap fst
  (is-contravariant-homвЖРis-contravariant contrav (idH x) x' .central (x' , idH x'))

tr-contrav-вИШ
  : вИА {рЭУ§ рЭУ•} {A : Type рЭУ§} (Apc : is-segal A) (P : A вЖТ Type рЭУ•)
      (contrav : is-contravariant P) {x y z} (g : Hom A y z) (f : Hom A x y)
      (z' : P z)
    вЖТ tr-contrav-hom contrav (g вИШ[ Apc ] f) z'
    пЉЭ tr-contrav-hom contrav f (tr-contrav-hom contrav g z')
tr-contrav-вИШ apc P contrav g f z'
  = ap fst
      (is-contravariant-homвЖРis-contravariant contrav (g вИШ[ apc ] f) z' .central
        ( tr-contrav-hom contrav f (tr-contrav-hom contrav g z')
        , CompбµИ apc P (is-inner-familyвЖРis-contravariant contrav) g f
                (tr-contrav-over contrav g _) (tr-contrav-over contrav f _)))
}
}

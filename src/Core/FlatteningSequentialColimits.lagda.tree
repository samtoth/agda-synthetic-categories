\subtree[stt-009I]{
\title{Flatteninig for sequential colimits}
\taxon{Theorem}

\agda{
module _ {ùì§ ùì•} {S : Cotower ùì§} (P : Seq-colimit S ‚Üí Type ùì•) where
  open Cotower S
  total-cotower : Cotower (ùì§ ‚äî ùì•)
  total-cotower .Cotower.Point n = Œ£ (Point n) (P ‚àò Œπ-cotower S)
  total-cotower .Cotower.incr (a , b) = (incr a , tr P (glue-suc S a) b)

  total-cotower-cocone : Seq-cocone total-cotower (Œ£ _ P)
  total-cotower-cocone .Seq-cocone.Œπ (a , b) = (Œπ-cotower S a , b)
  total-cotower-cocone .Seq-cocone.comm (a , b)
    = Œ£-path‚Üí (glue-suc S a , refl)


  total-cotower-colim‚âÉ : Œ£ _ P ‚âÉ Seq-colimit total-cotower
  total-cotower-colim‚âÉ
    = Œ£ _ P                              ‚âÉ‚ü® total-fork‚âÉ _ _ P ‚ü©
      Coeq (total-maps id incrŒ£ P .fst)
           (total-maps id incrŒ£ P .snd)  ‚âÉ‚ü®‚ü©
      Coeq (total-map (Œª a ‚Üí tr P (sym (glue-suc _ _))))
           (total-map-fst incrŒ£)         ‚âÉ‚ü® postcomp-coeq‚âÉ (is-equiv-‚àò (is-total-equiv‚Üêis-fibrewise-equiv (Œª a ‚Üí tr-is-equiv (glue-suc S (a .snd)))) (is-equiv‚Åª¬π (Œ£-assoc ._‚âÉ_.fwd-is-equiv))) e‚Åª¬π ‚ü©
      Coeq _ _                           ‚âÉ‚ü® precomp-coeq‚âÉ~ (Œ£-assoc ._‚âÉ_.fwd-is-equiv) LL RR ‚ü©
      Coeq id (Cotower.incrŒ£ total-cotower) ‚âÉ‚ü®‚ü©
      Seq-colimit total-cotower ‚âÉ‚àé where

    LL : id: (Œ£[ n ‚à∂ ‚Ñï ] Œ£ (Point n) (P ‚àò Œπ-cotower S))
      ~ Œ£-assoc ._‚âÉ_.fwd ‚àò total-map (Œª p ‚Üí tr P (sym (glue-suc S (p .snd)))) ‚àò (total-map (Œª p ‚Üí tr P (glue-suc S (p .snd))) ‚àò _‚âÉ_.bwd Œ£-assoc)
    LL (n , (p , pp))
      = Œ£-path‚Üí
          ( refl
          , (Œ£-path‚Üí
            ( refl
            , sym (tr‚àòtr-sym (glue-suc S p) pp)
            )))

    RR : Cotower.incrŒ£ total-cotower ~ Œ£-assoc ._‚âÉ_.fwd ‚àò total-map-fst incrŒ£ ‚àò (total-map (Œª p ‚Üí tr P (glue-suc S (p .snd))) ‚àò _‚âÉ_.bwd Œ£-assoc)
    RR (n , (p , pp)) = refl
}
}


\subtree[stt-009K]{
\title{Characterising the fibres of the sequential cogap map}
\taxon{Theorem}

\p{Let #{S} be a sequence and #{f} be a map #{\rm{colim}(S) \to Q},
the fibres of #{f} at some #{x : Q} can be characterised using the
[flattening lemma](stt-009I) for sequential colimits. In particular,
since #{\fibre{f}{x} = \Sigma_{s : \rm{Colim}(S)}(f(s) = x)}, we have
an equivalence #{\fibre{f}{x} = Colim_(\tilde{S})}, where #{\tidle{S}}
is the [total sequence](stt-009I): }

\quiver{
\begin{tikzcd}
	{\Sigma_{(s : S_0)}(f(\iota_0(s))= x)} && {\Sigma_{(s : S_1)}(f(\iota_1(s))=x)} && {...} \\
	\\
	{\fibre{f\iota_0}{x}} && {\fibre{f\iota_1}{x}} && {....}
	\arrow["{(\rm{incr},tr_{=x}(gl))}", from=1-1, to=1-3]
	\arrow[equals, from=1-1, to=3-1]
	\arrow[from=1-3, to=1-5]
	\arrow[equals, from=1-3, to=3-3]
	\arrow["{\fibre{gl}{x}}"', from=3-1, to=3-3]
	\arrow[from=3-3, to=3-5]
\end{tikzcd}
}

\p{From the above diagram, we se that we get the slogan: \em{The fibres
of the colimit are the colimit of fibres}.}

\agda{
module _ {ùì§ ùì•} {S : Cotower ùì§} {Q : Type ùì•} (f : Seq-colimit S ‚Üí Q) (x : Q) where
  open Cotower S

  fibre-cotower : Cotower (ùì§ ‚äî ùì•)
  fibre-cotower .Cotower.Point n = fibre (f ‚àò Œπ-cotower S {n}) x
  fibre-cotower .Cotower.incr {n} (a , b) = (incr a , ap f (sym (glue-suc S a)) ‚àô b)

  fibre-cotower‚Üêtotal : Cotower-map (total-cotower (Œª s ‚Üí f s Ôºù x)) fibre-cotower
  fibre-cotower‚Üêtotal .Cotower-map.map = id
  fibre-cotower‚Üêtotal .Cotower-map.comm a
    = Œ£-path‚Üí
      ( refl
      , sym (tr‚àò (_Ôºù x) f (glue-suc S _)
      ‚àô coe-precompÔºù (ap f (glue-suc S _)) (a .snd)
      ‚àô ap (_‚àô a .snd) (sym (ap-sym f _))))

  fibre-cotower‚âÉtotal : is-cotower-equiv fibre-cotower‚Üêtotal
  fibre-cotower‚âÉtotal n = id-is-equiv

  fibre-cotower-cogap‚âÉ : fibre f x ‚âÉ Seq-colimit fibre-cotower
  fibre-cotower-cogap‚âÉ
    = fibre f x                                    ‚âÉ‚ü® total-cotower-colim‚âÉ (Œª s ‚Üí f s Ôºù x) ‚ü©
      Seq-colimit (total-cotower (Œª s ‚Üí f s Ôºù x)) ‚âÉ‚ü® mk‚âÉ _ (seq-colimit-map-is-equiv fibre-cotower‚Üêtotal fibre-cotower‚âÉtotal) ‚ü©
      Seq-colimit fibre-cotower                    ‚âÉ‚àé
}
}

%```agda
\agda{
module Ergonomics.Universal where

open import Foundations.Prelude
open import UF

-- Although this is called Universal, really this is kind of
-- a general purpose 'coercion' class. The 'Universal' record
-- type is actually just the Singleton wrt. identity-extensionality.
-- I.e. assuming univalence, Universal A ЁЭУе тЙГ ╬г B : ЁЭУд, A я╝Э B тЙГ ЁЭЯЩ
-- so it is reasonable to ask instance search to do this work for us

-- In order to make instance search actually work, we really define
-- instances for types either of the form `A -> X` where A is a kind
-- of colimit, or `X -> A` where A is a kind of limit.

record Universal {ЁЭУд} (A : Type ЁЭУд) ЁЭУе : Type (ЁЭУд тКФ lsuc ЁЭУе) where
  field
    methods       : Type ЁЭУе
    from          : methods тЖТ A
    from-is-equiv : is-equiv from

  UnivтЖР : A тЖТ methods
  UnivтЖР = is-equiv.bwd from-is-equiv

  UnivтЙГ : methods тЙГ A
  UnivтЙГ = mkтЙГ from from-is-equiv

  UnivтЙГ' : A тЙГ methods
  UnivтЙГ' = UnivтЙГ eтБ╗┬╣

  module UnivтЙГ = _тЙГ_ (mkтЙГ from from-is-equiv)

open Universal

UniversalтЖРEquiv : тИА {ЁЭУд ЁЭУе} {A : Type ЁЭУд} {B : Type ЁЭУе}
                тЖТ B тЙГ A тЖТ Universal A ЁЭУе
UniversalтЖРEquiv {A = A} {B} e .methods = B
UniversalтЖРEquiv e .from = _тЙГ_.fwd e
UniversalтЖРEquiv e .from-is-equiv = _тЙГ_.has-is-eqv e


instance
  -- The basic structural rules allow us to stop recurring (we can
  -- produce an A given an A) and to skip an argument, introducing a
  -- function type into the methods:

  Universal-default : тИА {ЁЭУд} {A : Type ЁЭУд} тЖТ Universal A ЁЭУд
  Universal-default .methods = _
  Universal-default .from x  = x
  Universal-default .from-is-equiv = id-is-equiv

  Universal-╬а
    : тИА {ЁЭУд ЁЭУе ЁЭУж} {A : Type ЁЭУд} {B : A тЖТ Type ЁЭУе}
    тЖТ тжГ _ : тИА {a} тЖТ Universal (B a) ЁЭУж тжД
    тЖТ Universal (тИА a тЖТ B a) (ЁЭУд тКФ ЁЭУж)
  Universal-╬а тжГ u тжД .methods = тИА a тЖТ u {a} .methods
  Universal-╬а тжГ u тжД .from = u .from тИШ_
  Universal-╬а {A = A} {B} тжГ u тжД .from-is-equiv
    = postcomp-╬а-equiv (u .from-is-equiv)

  {-# INCOHERENT Universal-default #-}
  {-# OVERLAPPABLE Universal-╬а #-}

UniversalтЖРequiv-to-universal : тИА {ЁЭУд ЁЭУе ЁЭУж} {A : Type ЁЭУд} {B : Type ЁЭУе}
                             тЖТ A тЙГ B
                             тЖТ Universal A ЁЭУж
                             тЖТ Universal B ЁЭУж
UniversalтЖРequiv-to-universal eq ua = UniversalтЖРEquiv (UnivтЙГ ua тИЩтЙГ eq)


instance
  Universal-╬г
    : тИА {ЁЭУд ЁЭУе ЁЭУж ЁЭУЫ} {A : Type ЁЭУд} {B : A тЖТ Type ЁЭУе} {C : (x : A) тЖТ B x тЖТ Type ЁЭУж}
    тЖТ тжГ _ : Universal ((x : A) (y : B x) тЖТ C x y) ЁЭУЫ тжД
    тЖТ Universal ((x : ╬г A B) тЖТ C (x .fst) (x .snd)) ЁЭУЫ
  Universal-╬г тжГ u тжД = UniversalтЖРequiv-to-universal uncurryтЙГ u

  Universal-ЁЭЯЩ
    : тИА {ЁЭУд ЁЭУе} {A : Type ЁЭУд}
      тЖТ тжГ _ : Universal A ЁЭУе тжД
      тЖТ Universal (ЁЭЯЩ тЖТ A) ЁЭУе
  Universal-ЁЭЯЩ тжГ u тжД = UniversalтЖРequiv-to-universal (unit-UPтЙГ eтБ╗┬╣) u

  Universal-тКе
    : тИА {ЁЭУд} {A : Type ЁЭУд}
      тЖТ Universal (тИЕ тЖТ A) lzero
  Universal-тКе .methods = ЁЭЯЩ
  Universal-тКе .from _  = ┬б
  Universal-тКе .from-is-equiv = K┬б-ЁЭЯЩ-is-equiv


rec! : тИА {ЁЭУд ЁЭУе ЁЭУж} {A : Type ЁЭУд} {B : Type ЁЭУе} тжГ r : Universal (A тЖТ B) ЁЭУж тжД тЖТ r .methods тЖТ A тЖТ B
rec! тжГ r тжД = r .from

ind! : тИА {ЁЭУд ЁЭУе ЁЭУж} {A : Type ЁЭУд} {B : A тЖТ Type ЁЭУе} тжГ r : Universal (тИА x тЖТ B x) ЁЭУж тжД тЖТ r .methods тЖТ тИА x тЖТ B x
ind! тжГ r тжД = r .from

corec! : тИА {ЁЭУд ЁЭУе ЁЭУж} {A : Type ЁЭУд} {B : Type ЁЭУе} тжГ r : Universal (A тЖТ B) ЁЭУж тжД тЖТ r .methods тЖТ A тЖТ B
corec! тжГ r тжД = r .from

coind! : тИА {ЁЭУд ЁЭУе ЁЭУж} {A : Type ЁЭУд} {B : A тЖТ Type ЁЭУе} тжГ r : Universal (тИА x тЖТ B x) ЁЭУж тжД тЖТ r .methods тЖТ тИА x тЖТ B x
coind! тжГ r тжД = r .from
}
%```

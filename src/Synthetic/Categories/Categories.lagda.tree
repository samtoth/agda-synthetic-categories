\subtree[fre-44QA]{
\title{Comparison map between the total space of identities and isomorphisms}
\author{fredrikbakke}
\taxon{Lemma}
\date{2026-05-15}

\agda{
is-Iso‚ÜźId-equiv : ‚ąÄ {ūĚď§} ‚Üí Type ūĚď§ ‚Üí Type (ūĚďė ‚äĒ ūĚď§)
is-Iso‚ÜźId-equiv A = (a b : A) ‚Üí is-equiv (Iso‚ÜźId: a b)

TotalId' : ‚ąÄ {ūĚď§} ‚Üí Type ūĚď§ ‚Üí Type ūĚď§
TotalId' A = ő£[ a ‚ą∂ A ] ő£[ b ‚ą∂ A ] (a ÔľĚ b)

module _ {ūĚď§} {A : Type ūĚď§} where

  refl-TotalId' : A ‚Üí TotalId' A
  refl-TotalId' a = a , a , refl

  TotalIso‚ÜźTotalId' : TotalId' A ‚Üí TotalIso A
  TotalIso‚ÜźTotalId' = total-map őĽ a ‚Üí total-map őĽ b ‚Üí Iso‚ÜźId: a b

  refl-TotalId'-is-equiv : is-equiv refl-TotalId'
  refl-TotalId'-is-equiv = mk-eqv qinv ~refl where
    qinv : quasi-inv refl-TotalId'
    qinv .fst = fst
    qinv .snd .fst = ~refl
    qinv .snd .snd (a , .a , refl) = refl

  id-TotalIso-is-equiv‚Üźis-Iso‚ÜźId-equiv
    : is-Iso‚ÜźId-equiv A ‚Üí is-equiv id-TotalIso
  id-TotalIso-is-equiv‚Üźis-Iso‚ÜźId-equiv Aiso
    = is-equiv-‚ąė
        ( is-total-equiv‚Üźis-fibrewise-equiv őĽ a
        ‚Üí is-total-equiv‚Üźis-fibrewise-equiv őĽ b
        ‚Üí Aiso a b)
        refl-TotalId'-is-equiv

  TotalIso‚ÜźTotalId'-refl-TotalId'
    : TotalIso‚ÜźTotalId' ‚ąė refl-TotalId' ~ id-TotalIso
  TotalIso‚ÜźTotalId'-refl-TotalId' = ~refl

  TotalIso‚ÜźTotalId'-fst
    : id-TotalIso ‚ąė fst ~ TotalIso‚ÜźTotalId'
  TotalIso‚ÜźTotalId'-fst (a , .a , refl) = refl
}
}

\subtree[fre-F900]{
\title{A Segal type is Rezk-complete iff \code{Iso‚ÜźId} is an equivalence}
\taxon{Proposition}
\author{fredrikbakke}
\date{2026-05-15}

\p{
In fact, we show the backwards implication is true without assuming Segalness.
}

\agda{
module _ {ūĚď§} {A : Type ūĚď§} where

  is-rezk-complete‚Üźis-Iso‚ÜźId-equiv
    : is-Iso‚ÜźId-equiv A
    ‚Üí is-rezk-complete A
  is-rezk-complete‚Üźis-Iso‚ÜźId-equiv A-iso
    = is-localŠīł‚Üźis-null őĽ _ ‚Üí is-equiv‚Üźqinv qinv where
    module totid = is-equiv (id-TotalIso-is-equiv‚Üźis-Iso‚ÜźId-equiv A-iso)

    qinv : quasi-inv (const A ‚ĄĎ)
    qinv .fst F = totid.bwd (‚ĄĎ-rep‚Üí F)
    qinv .snd .fst a = ap fst (totid.őĶ (‚ĄĎ-rep‚Üí (const A ‚ĄĎ a)))
    qinv .snd .snd F
      = sym (‚ĄĎ-rep‚Üźid (totid.bwd (‚ĄĎ-rep‚Üí F)))
      ‚ąô ap ‚ĄĎ-rep‚Üź (totid.őĶ (‚ĄĎ-rep‚Üí F))
      ‚ąô ‚ĄĎ-rep‚Üź‚Üí F

  id-TotalIso-is-equiv‚Üźis-rezk-complete
    : is-segal A ‚Üí is-rezk-complete A ‚Üí is-equiv (id-TotalIso {A = A})
  id-TotalIso-is-equiv‚Üźis-rezk-complete A-is-segal A-is-rezk-complete
    = is-equiv-‚ąė~
        (‚ĄĎ-rep‚Üíconst A-is-segal)
        (‚ĄĎ-rep‚Üí-is-equiv A-is-segal)
        (is-null‚Üźis-localŠīł A-is-rezk-complete tt)

  is-Iso‚ÜźId-equiv‚Üźis-rezk-complete
    : is-segal A ‚Üí is-rezk-complete A ‚Üí is-Iso‚ÜźId-equiv A
  is-Iso‚ÜźId-equiv‚Üźis-rezk-complete A-is-segal A-is-rezk-complete a
    = is-fibrewise-equiv‚Üźis-total-equiv
        (is-fibrewise-equiv‚Üźis-total-equiv
          (is-equiv-‚ąė~
            (TotalIso‚ÜźTotalId'-fst)
              (id-TotalIso-is-equiv‚Üźis-rezk-complete A-is-segal A-is-rezk-complete)
              (is-equiv‚ĀĽ¬Ļ refl-TotalId'-is-equiv))
          (a))

  is-rezk-complete‚áĒis-Iso‚ÜźId-equiv
    : is-segal A ‚Üí is-rezk-complete A ‚áĒ is-Iso‚ÜźId-equiv A
  is-rezk-complete‚áĒis-Iso‚ÜźId-equiv A-is-segal
    = ( is-Iso‚ÜźId-equiv‚Üźis-rezk-complete A-is-segal
      , is-rezk-complete‚Üźis-Iso‚ÜźId-equiv)
}
}


\subtree[fre-00OH]{
\title{Complete Segal types}
\taxon{Definition}
\author{fredrikbakke}

\p{
A type is \em{complete Segal} if it is Rezk-complete and Segal.
}

\agda{
fam-is-complete-segal : ‚®Ą‚āĀŠ∂†-carrier (point őõ[2,1]-incl) (point (!Šīł: ūĚďė ‚ĄĎ))
fam-is-complete-segal = point őõ[2,1]-incl ‚®Ą‚āĀŠ∂† point (!Šīł: ūĚďė ‚ĄĎ)

is-complete-segal : ‚ąÄ {ūĚď§} ‚Üí Type ūĚď§ ‚Üí Type (ūĚďė ‚äĒ ūĚď§)
is-complete-segal A = is-local fam-is-complete-segal A

module _  {ūĚď§ : Level} {A : Type ūĚď§}  where

  is-complete-segal-is-prop : is-prop (is-complete-segal A)
  is-complete-segal-is-prop = is-local-is-prop A

  is-segal√óis-rezk-complete‚Üźis-complete-segal
    : is-complete-segal A ‚Üí is-segal A √ó is-rezk-complete A
  is-segal√óis-rezk-complete‚Üźis-complete-segal = √ó-is-local‚Üźis-local-‚®Ą‚āĀŠ∂†

  is-complete-segal‚Üźis-segal‚Üźis-rezk-complete
    : is-segal A ‚Üí is-rezk-complete A ‚Üí is-complete-segal A
  is-complete-segal‚Üźis-segal‚Üźis-rezk-complete = is-local-‚®Ą‚āĀŠ∂†‚Üźis-local
}

\agda{
CompleteSegal-SubU : ‚ąÄ {ūĚď§} ‚Üí SubU ūĚď§ (ūĚď§ ‚äĒ ūĚďė)
CompleteSegal-SubU = Local-SubU fam-is-complete-segal _


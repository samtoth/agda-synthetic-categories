is still TODO.}
}

\p{Under the assumption of \ref{stt-00JJ}, we have the following lemmas:}

\subtree[stt-00JX]{
\title{Fibre maps of connected arrow maps are connected}
\taxon{Lemma}

\p{Given a connected map of arrows #{f \to g}, the induced map on fibres is
connected.}

%```agda
\agda{
    module _
      (is-fibrewise-connectedвЖРis-total-connected
        : вИА {рЭУ§ рЭУ• рЭУ¶ рЭУЬ} {A : Type рЭУ§} {B : Type рЭУ•} (f : A вЖТ B)
            {P : A вЖТ Type рЭУ¶} {Q : B вЖТ Type рЭУЬ}
          вЖТ (g : (a : A) вЖТ P a вЖТ Q (f a))
          вЖТ is-connected-map GR f
          вЖТ is-connected-map GR {A = ќ£ A P} {B = ќ£ B Q} (map-ќ£ f g)
          вЖТ вИА a вЖТ is-connected-map GR (g a)) where
      fibre-map-is-connected
        : вИА {рЭУ§ рЭУ• рЭУ¶ рЭУЬ} {A : Type рЭУ§} {B : Type рЭУ•} {X : Type рЭУ¶} {Y : Type рЭУЬ}
            {f : A вЖТ B} {g : X вЖТ Y}
          вЖТ (F : Arrow-map f g)
          вЖТ (let module F = Arrow-map F)
          вЖТ is-connected-map GR F.bot
          вЖТ is-connected-map GR F.top
          вЖТ вИА a вЖТ is-connected-map GR (arrow-fibre F a)
      fibre-map-is-connected {A = A}{B}{X}{Y}{f = f}{g} F bconn tconn b
        = is-fibrewise-connectedвЖРis-total-connected
            (F .Arrow-map.bot)
            {P = fibre f} {Q = fibre g}
            (arrow-fibre F)
            bconn
            (is-connected-mapвЖРis-arrow-equivвБї¬є GR ќ£-is-modal
              amap amap-is-equiv tconn)
            b where
        module F = Arrow-map F
        amap : Arrow-map {A = ќ£ B (fibre f)} {ќ£ Y (fibre g)}
                         (map-ќ£ F.bot (arrow-fibre F)) F.top
        amap .Arrow-map.top = totalвЖРtotal-fibre f
        amap .Arrow-map.bot = totalвЖРtotal-fibre g
        amap .Arrow-map.comm = ~refl

        amap-is-equiv : is-Arrow-equiv amap
        amap-is-equiv .fst = totalвЙГtotal-fibre f ._вЙГ_.has-is-eqv
        amap-is-equiv .snd = totalвЙГtotal-fibre g ._вЙГ_.has-is-eqv
}
%```
}

\subtree[stt-00JS]{
\title{The modal unit naturality square is a connected arrow map}
\taxon{Lemma}

%```agda
\agda{
      ќЈ-fibre-map-is-equiv
        : вИА {рЭУ§ рЭУ•} {A : Type рЭУ§} {B : Type рЭУ•} {f : A вЖТ B}
          вЖТ вИА a вЖТ is-connected-map GR (ќЈ-fibre-map GR ќ£-is-modal f a)
      ќЈ-fibre-map-is-equiv {A = A} {B} {f} b
        = fibre-map-is-connected amap
            (ќЈ-is-connected GR ќ£-is-modal)
            (ќЈ-is-connected GR ќ£-is-modal) b where
        amap : Arrow-map f (вЧЛвВБ f)
        amap .Arrow-map.top = ќЈ
        amap .Arrow-map.bot = ќЈ
        amap .Arrow-map.comm a = sym (вЧЛвВБ-ќ≤ f a)
}
%```
}
}

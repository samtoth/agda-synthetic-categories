\subtree[stt-005F]{
\taxon{Definition}
\title{Local types}

\p{Given a family of maps #{f_i : A_i \to B_i}, we say that a type
is #{f}-local if it is [orthogonal](stt-004O) to each map.}

\agda{
is-local
  : ‚ąÄ {ūĚďė ūĚď§ ūĚď• ūĚď¶} {I : Type ūĚďė} {A : I ‚Üí Type ūĚď§} {B : I ‚Üí Type ūĚď•}
    ‚Üí (f : (i : I) ‚Üí A i ‚Üí B i)
    ‚Üí Type ūĚď¶
    ‚Üí Type (ūĚďė ‚äĒ ūĚď§ ‚äĒ ūĚď• ‚äĒ ūĚď¶)
is-local f A = ‚ąÄ i ‚Üí orthogonal-type (f i) A

is-local-is-prop
  : ‚ąÄ {ūĚďė ūĚď§ ūĚď• ūĚď¶} {I : Type ūĚďė} {A : I ‚Üí Type ūĚď§} {B : I ‚Üí Type ūĚď•}
      {f : (i : I) ‚Üí A i ‚Üí B i}
    ‚Üí ‚ąÄ (A : Type ūĚď¶) ‚Üí is-prop (is-local f A)
is-local-is-prop A = ő†-is-prop őĽ i ‚Üí is-equiv-is-prop
}
}

\subtree[stt-00PF]{
\title{Local types with respect to coproducts of families of maps}
\taxon{Lemma}
\author{fredrikbakke}

\agda{
module _
  {ūĚďė ūĚďô ūĚď§ ūĚď• ūĚď†}
  {I : Type ūĚďė} {J : Type ūĚďô}
  {A : I ‚Üí Type ūĚď§} {B : I ‚Üí Type ūĚď•}
  {C : J ‚Üí Type ūĚď§} {D : J ‚Üí Type ūĚď•}
  {f : (i : I) ‚Üí A i ‚Üí B i}
  {g : (j : J) ‚Üí C j ‚Üí D j}
  {X : Type ūĚď†}
  where

  is-local-‚®Ą‚āĀŠ∂†‚Üźis-local
    : is-local f X ‚Üí is-local g X ‚Üí is-local (f ‚®Ą‚āĀŠ∂† g) X
  is-local-‚®Ą‚āĀŠ∂†‚Üźis-local floc gloc (inl i) = floc i
  is-local-‚®Ą‚āĀŠ∂†‚Üźis-local floc gloc (inr j) = gloc j

  √ó-is-local‚Üźis-local-‚®Ą‚āĀŠ∂†
    : is-local (f ‚®Ą‚āĀŠ∂† g) X ‚Üí is-local f X √ó is-local g X
  √ó-is-local‚Üźis-local-‚®Ą‚āĀŠ∂† loc = (loc ‚ąė inl , loc ‚ąė inr)

  is-local-‚®Ą‚āĀŠ∂†‚ÜĒ√ó-is-local
    : is-local (f ‚®Ą‚āĀŠ∂† g) X ‚ÜĒ (is-local f X √ó is-local g X)
  is-local-‚®Ą‚āĀŠ∂†‚ÜĒ√ó-is-local .fst = √ó-is-local‚Üźis-local-‚®Ą‚āĀŠ∂†
  is-local-‚®Ą‚āĀŠ∂†‚ÜĒ√ó-is-local .snd (floc , gloc) = is-local-‚®Ą‚āĀŠ∂†‚Üźis-local floc gloc

  is-local-‚®Ą‚āĀŠ∂†‚ČÉ√ó-is-local
    : is-local (f ‚®Ą‚āĀŠ∂† g) X ‚ČÉ (is-local f X √ó is-local g X)
  is-local-‚®Ą‚āĀŠ∂†‚ČÉ√ó-is-local
    = equiv‚Üźlogical
        (is-local-is-prop X)
        (√ó-is-prop (is-local-is-prop X) (is-local-is-prop X))
        (is-local-‚®Ą‚āĀŠ∂†‚ÜĒ√ó-is-local)
}
}

\subtree[stt-007L]{
\title{Equivalent local maps}
\taxon{Theorem}

\p{If #{f_i} and #{g_i} are [equivalent maps](stt-004R), then #{f}-local
types are #{g}-local.}

\agda{
is-local-equiv
  : ‚ąÄ {ūĚďė ūĚď§ ūĚď§' ūĚď• ūĚď•' ūĚď¶} {I : Type ūĚďė}
      {A : I ‚Üí Type ūĚď§} {A' : I ‚Üí Type ūĚď§'}
      {B : I ‚Üí Type ūĚď•} {B' : I ‚Üí Type ūĚď•'}
      {f : (i : I) ‚Üí A i ‚Üí B i}
      {f' : (i : I) ‚Üí A' i ‚Üí B' i}
      (F : ‚ąÄ i ‚Üí Arrow-map (f i) (f' i))
    ‚Üí (‚ąÄ i ‚Üí is-Arrow-equiv (F i))
    ‚Üí {X : Type ūĚď¶}
    ‚Üí is-local f X ‚Üí is-local f' X
is-local-equiv F eq loc i
  = src-is-equiv‚ÜźArrow-equiv
      (precomp-Arrow-map _ (F i) , precomp-square-is-equiv (F i) (eq i))
      (loc i)
}
}

\subtree[stt-005Z]{
\taxon{Lemma}
\title{Locality via sections of the codiagonal}
\citet{Thm 2.13}{RSS20}

\p{Given maps #{f_i : A_i \to B_i}, a type #{X} is #{f\rm{-local}}
iff #{{-} \circ f_i} and #{{-} \circ \nabla_{f_i}} all have sections.}

\agda{
is-local‚Üźsec‚Üźsec-‚ąá
  : ‚ąÄ {ūĚďė ūĚď§ ūĚď• ūĚď¶} {I : Type ūĚďė}
      {A : I ‚Üí Type ūĚď§} {B : I ‚Üí Type ūĚď•}
      {f : (i : I) ‚Üí A i ‚Üí B i}
      {X : Type ūĚď¶}
    ‚Üí (‚ąÄ i ‚Üí section (precomp X (f i)))
    ‚Üí (‚ąÄ i ‚Üí section (precomp X (‚ąá (f i))))
    ‚Üí is-local f X
is-local‚Üźsec‚Üźsec-‚ąá sec sec‚ąá i
  = is-equiv‚Üźis-pathsplit
      (is-pathsplit‚Üźsec-diag
        (sec i)
        (sec‚Üźsec-Coslice-equiv'
          (őĒ‚Üź‚ąá _ _)
          (őĒ‚Üź‚ąá-is-equiv)
          (sec‚ąá i)))


sec‚ąá‚Üźis-local
  : ‚ąÄ {ūĚďė ūĚď§ ūĚď• ūĚď¶} {I : Type ūĚďė}
      {A : I ‚Üí Type ūĚď§} {B : I ‚Üí Type ūĚď•}
      {f : (i : I) ‚Üí A i ‚Üí B i}
      {X : Type ūĚď¶}
    ‚Üí is-local f X
    ‚Üí ‚ąÄ i ‚Üí section (precomp X (‚ąá (f i)))
sec‚ąá‚Üźis-local loc i
  = sec‚Üźsec-Coslice-equiv
      (őĒ‚Üź‚ąá _ _)
      (őĒ‚Üź‚ąá-is-equiv)
      (sec-diag‚Üźis-pathsplit
        (is-pathsplit‚Üźis-equiv (loc i)))
}
}

\subtree[stt-005Y]{
\title{Localisation}
\taxon{Definition}

\p{Unlike in the case of [nullification](stt-005K), we cannot in
general expect the family of functions against which we are localising
to all have sections, and so the [free algebraically injective](stt-005I)
type will not get us all the way to a localisation.}


\p{As explained in \citet{2.14}{RSS20}, even though we don't
immediately get a localisation, we can add some morphisms to the class
with which we localise against to make it so. By the observation in
\ref{stt-005Z}, we need to add all maps of the form #{\nabla_{f_i}} to
#{f}.}

\agda{
module _ {ūĚďė ūĚď§ ūĚď• ūĚď¶ : Level} {I : Type ūĚďė}
         {A : I ‚Üí Type ūĚď§} {B : I ‚Üí Type ūĚď•}
         where
  private
    A' : (f : ‚ąÄ i ‚Üí A i ‚Üí B i) ‚Üí I ‚äé I ‚Üí Type (ūĚď§ ‚äĒ ūĚď•)
    A' f (inl i) = ULift ūĚď• (A i)
    A' f (inr i) = Pushout (f i) (f i)

    B' : (f : ‚ąÄ i ‚Üí A i ‚Üí B i) ‚Üí I ‚äé I ‚Üí Type ūĚď•
    B' f (inl i)  = B i
    B' f (inr i) = B i

    f' : (f : ‚ąÄ i ‚Üí A i ‚Üí B i) ‚Üí (i : I ‚äé I) ‚Üí A' f i ‚Üí B' f i
    f' f (inl i) =  f i ‚ąė unlift
    f' f (inr i) = ‚ąá (f i)

  Loc : (f : ‚ąÄ i ‚Üí A i ‚Üí B i) ‚Üí Type ūĚď¶ ‚Üí Type ūĚď¶
  Loc f = FreeInj (f' f)

  Loc-is-local
    : ‚ąÄ {X : Type ūĚď¶}
        {f : ‚ąÄ i ‚Üí A i ‚Üí B i}
      ‚Üí is-local f (Loc f X)
  Loc-is-local {X} {f}
    =  is-local‚Üźsec‚Üźsec-‚ąá
         (őĽ i ‚Üí sec-3-for-2 {f = precomp _ unlift} {precomp _ (f i)}
                             (precomp-equiv (is-equiv‚ĀĽ¬Ļ lift-is-equiv))
                             (injector-FreeInj (inl i)))
         (őĽ i ‚Üí injector-FreeInj (inr i))
}
}

\subtree[stt-006C]{
\date{2025-06-23}
\taxon{Theorem}
\title{A partial universal property for Free Algebraic Injectives}

\p{The Free Algebraic Injective type former is the left adjoint to the
forgetful functor from algebraic injectives on #{\SS} to #{\SS}.  In
this formalisaton we have shied away from formalising this full
universal property, but we now formalise the (easier) restriction to
the category of #{f\rm{-local}} types.}

\p{For an #{f\rm{-local}} type #{Y}, and any type #{X},
   the map #{{-} \circ \eta : (\mathcal{J}_f(X) \to Y) \to (X \to Y)}
   is an equivalence.
   }

\agda{
postcomp-inj
  : ‚ąÄ {ūĚďė ūĚď§ ūĚď• ūĚď¶ ūĚďú}
      {I : Type ūĚďė} {A : I ‚Üí Type ūĚď§}
      {B : I ‚Üí Type ūĚď•}
      {f : (i : I) ‚Üí A i ‚Üí B i}
      (X : Type ūĚď¶) {Y : Type ūĚďú}
    ‚Üí (FreeInj f X ‚Üí Y)
    ‚Üí (X ‚Üí Y)
postcomp-inj X {Y} = precomp Y FreeInj.inc
}
\proof{

\p{To prove this, we use [pathsplit](stt-005Q) as our notion of
   equivalence.  So we have to give a section to #{({-} \circ \eta)} and
   to #{\rm{ap}_{{-} \circ \eta}^{g,h}} for any pair of maps #{g, h :
   \mathcal{J}_f(X) \to Y}.  }

\agda{
FreeInj-reflects
  : ‚ąÄ {ūĚďė ūĚď§ ūĚď• ūĚď¶ ūĚďú}
      {I : Type ūĚďė} {A : I ‚Üí Type ūĚď§}
      {B : I ‚Üí Type ūĚď•}
      {f : (i : I) ‚Üí A i ‚Üí B i}
      (X : Type ūĚď¶) {Y : Type ūĚďú}
    ‚Üí is-local f Y
    ‚Üí is-equiv (postcomp-inj {f = f} X {Y})
FreeInj-reflects {I = I} {A} {B} {f} X {Y} Y-loc
  = is-equiv‚Üźis-pathsplit ps where
  module Y {i} = is-equiv (Y-loc i)
}

\p{In the first case, the section of #{({-} \circ \eta)} is relatively
trivial to construct. To do so, we are given a map #{g : X \to Y} and
need to construct one #{\mathcal{J}_f(X) \to Y}. We induct on the free
algebraic injective:}

\ol{
\li{case \strong{inc}: We need a map #{X \to Y}, which is given by
     #{g}.  The map we are constructing needs to be a section of #{-
     \circ \eta}, but the computation rule says that
     #{\rm{ind}(g,..)(\eta(x)) = g(x)}, and thus our map is a section
     by definition.
     }
\li{case \strong{ext}: For all #{f' : A_i \to \mathcal{J}_f(X)} we
    need a map #{(A_i \to Y) \to (B_i \to Y)} which is equal to #{f'}
    under postcomposition by #{f}. This map is obtained by the fact
    that #{Y} is #{f}-local.}
}


\agda{
  sec-postcomp-inj : section (postcomp-inj X)
  sec-postcomp-inj .fst g = FreeInj.ind
                     (őĽ _ ‚Üí Y)
                     g
                     (őĽ _ ‚Üí Y.bwd)
                     őĽ g' h a ‚Üí tr-const (FreeInj.is-ext g' a)
                                ‚ąô happly (Y.őĶ h) a
  sec-postcomp-inj .snd h = refl
}

\p{Now we fix a pair of maps #{g, h : \mathcal{J}_f(X) \to Y}, and
give a section to #{\rm{ap}_{{-} \circ \eta}^{g,h} : g = h \to g\eta =
h\eta}.}

\p{[We can construct](stt-006I) an [equivalence of arrows](stt-004R)
between [postwhiskering](stt-006G) by #{\eta} and #{\rm{ap}_{{-} \circ
\eta}} using function extensionality. As a result, [it
suffices](stt-0069) then to give a section to the map by
\em{postwhiskering} with #{\eta}.  By the same result, we note that
because postcomposition by #{f_i} at #{Y} is an equivalence, then so
is the postwhiskering by #{f_i} at maps #{B_i \to Y}}

\agda{
  opaque
    Y‚Ėł-is-equiv : ‚ąÄ {i} {g h : B i ‚Üí Y} ‚Üí is-equiv (prewhisker (f i) g h)
    Y‚Ėł-is-equiv {i} = prewhisker-is-equiv‚Üźap-compose
      (is-embedding‚Üźis-equiv (Y-loc i))

  module Y‚Ėł {i} {g h} = is-equiv (Y‚Ėł-is-equiv {i} {g} {h})
}

\p{Now, we are ready to construct the section. Given #{H : g\eta \sim
h\eta} we want to show for all #{x : \mathcal{J}_f(X)}, #{g(x) =
h(x)}, which we do again by induction on #{x} with the motive #{x
\mapsto g(x) = h(x)}.}

\ol{
\li{case \strong{inc}: We require #{g\eta \sim h\eta}, so as above, we
     can supply the #{H} in the hypothesis. As above, the #{\beta}
     rule for HITs means, that the map we are constructing will be a
     definitional section of postwhiskering by #{\eta}.}
\li{case \strong{ext}: Now, for any #{f' : A_i \to \mathcal{J}_f(X)},
     we need to give a map #{f'' : gf' \sim hf' \to g\rm{ext}(f') \sim
     h\rm{ext}(f')}, such that for any #{(K : gf' \sim hf')},
     #{f''(K)f_i =_{x \mapsto g(x) = h(x)}^{\rm{is-ext}_{f'}} K}
     (N.B. #{\rm{ext}(f') : B_i \to \mathcal{J}_f(X)})

     \p{For the map in question, we take:
       ##{(K : gf' \sim hf') \mapsto
         (- ‚Ėł f_f)^{-1}(g(\rm{is-ext}_{f'}) \cdot K \cdot h(\rm{is-ext}_{f'})^{-1})}
      }

      \p{Unfolding #{f''(K)f_i =_{x \mapsto g(x) = h(x)}^{\rm{is-ext}_{f'}} K},
         we find that we need to give a witness to the following square:
         }

      \quiver{
        \begin{tikzcd}
	{gf'} && {g\textrm{ext}_{f'}f_i} \\
	\\
	{hf'} && {h\textrm{ext}_{f'}f_i}
	\arrow["{g(\textrm{is-ext}_{f'})^{-1}}", no head, from=1-1, to=1-3]
	\arrow["{K}"', no head, from=1-1, to=3-1]
	\arrow["{(- \blacktriangleright f')^{-1}(f''(K))f_i}", no head, from=1-3, to=3-3]
	\arrow["{h(\textrm{is-ext}_{f'})}^{-1}"', no head, from=3-1, to=3-3]
        \end{tikzcd}
      }

      \p{But now we have the postwhiskering applied to the inverse of postwhiskering
         on the right hand side. Once this is eliminated, and #{f''} is unfolded,
         we get:}

      \quiver{
        \begin{tikzcd}
	{gf'} && {g\rm{ext}_{f'}f_i} && {gf'} \\
	\\
	{hf'} && {h\rm{ext}_{f'}f_i} && {hf'}
	\arrow["{g(\textrm{is-ext}_{f'})^{-1}}", no head, from=1-1, to=1-3]
	\arrow["K"', no head, from=1-1, to=3-1]
	\arrow["{g(\textrm{is-ext}_{f'})}", no head, from=1-3, to=1-5]
	\arrow[""{name=0, anchor=center, inner sep=0}, "{(- \blacktriangleright f')^{-1}(f''(K))f_i}"{description}, no head, from=1-3, to=3-3]
	\arrow[""{name=1, anchor=center, inner sep=0}, "K", no head, from=1-5, to=3-5]
	\arrow["{h(\textrm{is-ext}_{f'})^{-1}}"', no head, from=3-1, to=3-3]
	\arrow["{h(\textrm{is-ext}_{f'})}"', no head, from=3-3, to=3-5]
	\arrow["\epsilon"{pos=0.7}, shorten <=41pt, shorten >=14pt, Rightarrow, from=0, to=1]
        \end{tikzcd}
      }

      \p{and this square clearly commutes.}
     }
}

\agda{
  lem : (g h : FreeInj f X ‚Üí Y)
     (i : I)
     (g' : A i ‚Üí FreeInj _ X)
     (q : g ‚ąė g' ~ h ‚ąė g') ‚Üí
     precomp Y (f i) (g ‚ąė FreeInj.ext g') ~
     precomp Y (f i) (h ‚ąė FreeInj.ext g')
  lem g h i g' K =      g ‚óā (FreeInj.is-ext g')
                     ‚ąôh K
                     ‚ąôh ((h ‚óā FreeInj.is-ext g') h‚ĀĽ¬Ļ)

  opaque
    secAp
      : ‚ąÄ (g h : FreeInj f X ‚Üí Y)
        ‚Üí section (prewhisker FreeInj.inc g h)
    secAp g h .fst H
      = FreeInj.ind (őĽ z ‚Üí g z ÔľĚ h z)
          H
          (őĽ f' (K : g ‚ąė f' ~ h ‚ąė f')
            ‚Üí Y‚Ėł.bwd (lem g h _ f' K))
          őĽ f' (K : g ‚ąė f' ~ h ‚ąė f') a
            ‚Üí IdŠĶą-func‚ÜźSquare
               (FreeInj.is-ext f' a)
               _
               (K a)
               (Square‚ÜźbrtÔľĚl
                 (ap g (FreeInj.is-ext f' a))
                 {ap h (FreeInj.is-ext f' a)}
                 {Y‚Ėł.bwd {g = g ‚ąė FreeInj.ext f'}
                         {h = h ‚ąė FreeInj.ext f'}
                         (lem g h _ f' K) (f _ a)}
                 (sym (happly (Y‚Ėł.őĶ (lem g h _ f' K)) a)))
    secAp g h .snd K = refl

  ps : is-pathsplit (postcomp-inj X)
  ps .fst = sec-postcomp-inj
  ps .snd g h = section‚ÜźArrow-equiv‚ĀĽ¬Ļ {F = prewhisker‚Üźap-compose _ _ _}
                                      prewhisker-funext(secAp g h)
}
}
}

\subtree[stt-006A]{
\date{2025-06-23}
\taxon{Lemma}
\title{#{f} local maps are #{‚ąá(f)} local}

\agda{
is-local‚ąá‚Üźis-local
  : ‚ąÄ {ūĚď§ ūĚď• ūĚď¶} {A : Type ūĚď§} {B : Type ūĚď•}
      (f : A ‚Üí B)
      {X : Type ūĚď¶}
    ‚Üí is-equiv (precomp X f)
    ‚Üí is-equiv (precomp X (‚ąá f))
is-local‚ąá‚Üźis-local f {X} eq = equiv‚ÜźCoslice-equiv
                                (őĒ‚Üź‚ąá f X)
                                (őĒ‚Üź‚ąá-is-equiv)
                                (diagonal-is-equiv eq)
}
}

\subtree[stt-00GM]{
\date{2026-03-10}
\author{fredrikbakke}
\taxon{Proposition}
\title{Propositions are local when the domains are inhabited}

\agda{
is-local‚Üźis-prop‚Üźsection-domain
  : ‚ąÄ {ūĚďė ūĚď§ ūĚď• ūĚď¶} {I : Type ūĚďė}
      {A : I ‚Üí Type ūĚď§} {B : I ‚Üí Type ūĚď•}
      (f : (i : I) ‚Üí A i ‚Üí B i)
    ‚Üí ő† _ A
    ‚Üí {X : Type ūĚď¶}
    ‚Üí is-prop X
    ‚Üí is-local f X
is-local‚Üźis-prop‚Üźsection-domain f a Xprop i = is-equiv‚Üźqinv qinv where
  qinv : quasi-inv (precomp _ (f i))
  qinv .fst őĪ _ = őĪ (a i)
  qinv .snd .fst ő≤ = ő†-is-prop (őĽ _ ‚Üí Xprop) _ _
  qinv .snd .snd őĪ = ő†-is-prop (őĽ _ ‚Üí Xprop) _ _
}
}

\subtree[stt-00IO]{
\date{2026-03-10}
\author{fredrikbakke}
\taxon{Proposition}
\title{Empty types are local when the domains are irrefutable}

\agda{
module _
  {ūĚďė ūĚď§ ūĚď• : Level} {I : Type ūĚďė}
  {A : I ‚Üí Type ūĚď§} {B : I ‚Üí Type ūĚď•}
  (f : (i : I) ‚Üí A i ‚Üí B i)
  where

  ‚ąÖ-is-local
    : ((i : I) ‚Üí ¬¨ ¬¨ A i)
    ‚Üí is-local f ‚ąÖ
  ‚ąÖ-is-local nnA i = is-equiv‚Üźqinv qinv where
    qinv : quasi-inv (precomp ‚ąÖ (f i))
    qinv .fst őĪ _ = nnA i őĪ
    qinv .snd .fst ő≤ = ő†-is-prop (őĽ _ ‚Üí őĽ ()) _ _
    qinv .snd .snd őĪ = ő†-is-prop (őĽ _ ‚Üí őĽ ()) _ _
}
}


\subtree[fre-AFKE]{
\date{2026-04-09}
\author{fredrikbakke}
\title{Deformation cone argument}
\taxon{Theorem}

\p{
Suppose a map #{f : X \to Y} has a section #{s}, and there are maps
#{g : J \to X}, #{H : J \to X}, and #{j_0,j_1 : X \to J} such that
#{g(j_0(x)) = g(j_1(x))}, #{H(j_0(x)) = s(f(x))}, and #{H(j_1(x)) = x}
for all #{x}. Then any #{g}-local type is #{f}-local.
}

\agda{
module _
  {ūĚďô ūĚď§ ūĚď• ūĚď¶ : Level}
  {J : Type ūĚďô} {X : Type ūĚď§} {Y : Type ūĚď•}
  {A : Type ūĚď¶}
  {g : J ‚Üí X} {f : X ‚Üí Y}
  where

  is-local‚Üźdeformation-cone-over
    : is-local (point g) A
    ‚Üí (sf : section f)
    ‚Üí (H : J ‚Üí X)
    ‚Üí (j0 j1 : X ‚Üí J)
    ‚Üí ((x : X) ‚Üí g (j0 x) ÔľĚ g (j1 x))
    ‚Üí ((x : X) ‚Üí H (j0 x) ÔľĚ sf .fst (f x))
    ‚Üí ((x : X) ‚Üí H (j1 x) ÔľĚ x)
    ‚Üí is-local (point f) A
  is-local‚Üźdeformation-cone-over gloc (s , sec) H j0 j1 G H0 H1 _
    = is-equiv‚Üźqinv qiso where

    qiso : quasi-inv (precomp A f)
    qiso .fst = precomp A s
    qiso .snd .fst őĪ = funext‚Üí (őĪ ‚óā sec)
    qiso .snd .snd h = funext‚Üí őĽ x ‚Üí
      h (s (f x))                               ÔľĚ‚ü® sym (ap h (H0 x)) ‚ü©
      h (H (j0 x))                              ÔľĚ‚ü® sym (happly (is-equiv.őĶ (gloc tt) (h ‚ąė H)) (j0 x)) ‚ü©
      is-equiv.bwd (gloc tt) (h ‚ąė H) (g (j0 x)) ÔľĚ‚ü® ap (is-equiv.bwd (gloc tt) (h ‚ąė H)) (G x) ‚ü©
      is-equiv.bwd (gloc tt) (h ‚ąė H) (g (j1 x)) ÔľĚ‚ü® happly (is-equiv.őĶ (gloc tt) (h ‚ąė H)) (j1 x) ‚ü©
      h (H (j1 x))                              ÔľĚ‚ü® ap h (H1 x) ‚ü©
      h x                                       ‚ąé
}

\p{
Suppose a map #{f : X \to Y} has a section #{s}, and admits a \em{parametrised
deformation cone}: a map
#{H : (x : X) \to J(x) \to X} for some type family #{J} over #{X} equipped with
sections #{j_0,j_1 : (x : X) \to J(x)}, such that #{H(x,j_0(x)) = s(f(x))} and
#{H(x,j_1(x)) = x} for all #{x}, then any type that is local at the total space
projection #{\Sigma_{(x:X)} J(x) \to X} is #{f}-local.
}

\agda{
module _
  {ūĚďô ūĚď§ ūĚď• ūĚď¶ : Level}
  {X : Type ūĚď§} {J : X ‚Üí Type ūĚďô} {Y : Type ūĚď•}
  {A : Type ūĚď¶}
  {f : X ‚Üí Y}
  where

  is-local-at-deformation-cone
    : is-local (point (fst: J)) A
    ‚Üí (sf : section f)
    ‚Üí (H : (x : X) ‚Üí J x ‚Üí X)
    ‚Üí (j0 : (x : X) ‚Üí J x)
    ‚Üí (j1 : (x : X) ‚Üí J x)
    ‚Üí ((x : X) ‚Üí H x (j0 x) ÔľĚ sf .fst (f x))
    ‚Üí ((x : X) ‚Üí H x (j1 x) ÔľĚ x)
    ‚Üí is-local (point f) A
  is-local-at-deformation-cone Jloc sf H j0 j1
    = is-local‚Üźdeformation-cone-over Jloc sf
        (őĽ (x , t) ‚Üí H x t)
        (őĽ x ‚Üí x , j0 x)
        (őĽ x ‚Üí x , j1 x)
        (~refl)
}
}

\subtree[fre-1238]{
\title{Deformation cone argument for equivalences}
\taxon{Corollary}
\author{fredrikbakke}
\date{2026-04-09}

\agda{
module _
  {ūĚďô ūĚď§ ūĚď• : Level}
  {J : Type ūĚďô} {X : Type ūĚď§} {Y : Type ūĚď•}
  {g : J ‚Üí X} {f : X ‚Üí Y}
  where

  is-equiv‚Üźlocal-deformation-cone
    : is-local (point g) X
    ‚Üí (sf : section f)
    ‚Üí (H : J ‚Üí X)
    ‚Üí (j0 : X ‚Üí J)
    ‚Üí (j1 : X ‚Üí J)
    ‚Üí ((x : X) ‚Üí g (j0 x) ÔľĚ g (j1 x))
    ‚Üí ((x : X) ‚Üí H (j0 x) ÔľĚ sf .fst (f x))
    ‚Üí ((x : X) ‚Üí H (j1 x) ÔľĚ x)
    ‚Üí is-equiv f
  is-equiv‚Üźlocal-deformation-cone Xloc sf H j0 j1 G H0 H1
    = is-equiv‚Üźqinv (r .fst , r .snd , sf .snd) where

    r : retraction f
    r = retraction‚Üźis-equiv-precomp-dom
          (is-local‚Üźdeformation-cone-over Xloc sf H j0 j1 G H0 H1 tt)
}
}

\subtree[stt-0066]{
\title{Localisation is a [reflective subuniverse](stt-0041)}
\taxon{Corollary}

\p{Localisation at any family of maps forms a reflective subuniverse
which is not in general #{\Sigma}-closed.}

\agda{
module _
  {ūĚďė ūĚď§ ūĚď• : Level} {I : Type ūĚďė}
  {A : I ‚Üí Type ūĚď§} {B : I ‚Üí Type ūĚď•}
  (f : (i : I) ‚Üí A i ‚Üí B i)
  where

  open is-reflective
  open is-reflector
  open is-globally-reflective
  open is-global-reflector

  Local-SubU
    : (ūĚď¶ : Level)
    ‚Üí SubU ūĚď¶ (ūĚďė ‚äĒ ūĚď§ ‚äĒ ūĚď• ‚äĒ ūĚď¶)
  Local-SubU ūĚď¶ = mk-subtype
                    {family = is-local f}
                    is-local-is-prop

  Local-gSubU
    : gSubU ((ūĚďė ‚äĒ ūĚď§ ‚äĒ ūĚď•) ‚äĒ_)
  Local-gSubU .gSubU.S {ūĚď§} = Local-SubU ūĚď§
  Local-gSubU .gSubU.‚ąąS‚Üźequiv {A = A} {B} e A-loc i
    = tgt-is-equiv‚ÜźArrow-equiv
       ( mk-amap (postcomp _ fwd) (postcomp _ fwd) ~refl
       , postcomp-equiv fwd-is-equiv
       , postcomp-equiv fwd-is-equiv)
       (A-loc i) where
    open _‚ČÉ_ e

  Local-global-reflectors
    : is-globally-reflective Local-gSubU
  Local-global-reflectors .‚óč = Loc f
  Local-global-reflectors .ő∑ = FreeInj.inc
  Local-global-reflectors .ő∑-is-reflector .‚óč‚ąąS = Loc-is-local
  Local-global-reflectors .ő∑-is-reflector .reflects cloc
    = FreeInj-reflects _ őĽ where
       (inl i) ‚Üí is-equiv-‚ąė (precomp-equiv (is-equiv‚ĀĽ¬Ļ lift-is-equiv))
                             (cloc i)
       (inr i) ‚Üí is-local‚ąá‚Üźis-local (f i) (cloc i)

  Local-reflective
    : {ūĚď¶ : Level}
    ‚Üí is-reflective (Local-SubU ūĚď¶)
  Local-reflective = is-reflective‚Üźglobal Local-global-reflectors

  Local-gRSubU : gRSubU ((ūĚďė ‚äĒ ūĚď§ ‚äĒ ūĚď•) ‚äĒ_)
  Local-gRSubU .gRSubU.GS = Local-gSubU
  Local-gRSubU .gRSubU.GS-is-globally-reflective = Local-global-reflectors

  open gSubU Local-gSubU public using () renaming
    ( ‚ąąS‚Üźequiv to is-local‚Üźequiv)

  open gReflectiveClosure Local-gRSubU public using () renaming
    ( ő†‚ąąS to ő†-is-local
    ; ULift‚ąąS to ULift-is-local
    ; ūĚüô‚ąąS to ūĚüô-is-local
    ; ‚ąąS‚Üźis-singleton to is-local‚Üźis-singleton
    ; ‚ąąS‚Üźretract to is-local‚Üźretract
    ; Pullback‚ąąS to Pullback-is-local
    ; fibre‚ąąS to fibre-is-local
    ; Ext‚ąąS to Ext-is-local
    ; √ó‚ąąS to √ó-is-local
    ; ÔľĚ‚ąąS to ÔľĚ-is-local
    ; ~‚ąąS to ~-is-local
    ; retract‚ąąS to retract-is-local
    ; biinv‚ąąS to biinv-is-local
    ; ‚ČÉ‚ąąS to ‚ČÉ-is-local
    ; Equaliser‚ąąS to Equaliser-is-local
    ; Seq-lim‚ąąS to Seq-lim-is-local
    ; preidempotent-map‚ąąS to preidempotent-map-is-local
    ; qidempotent-map‚ąąS to qidempotent-map-is-local
    ; idempotent-map‚ąąS to idempotent-map-is-local
    ; Retracts‚ąąS to Retracts-is-local)

  module Local where
    open gRSubU Local-gRSubU public
    open gReflectiveClosure Local-gRSubU public
}
}

\subtree[stt-00AP]{
\title{Local maps are fibrewise local}
\taxon{Theorem}

\p{A map is #{f}-local if it is right orthogonal to each #{f_i}. We show that
that a map is #{f}-local iff it is a [modal map](stt-0045) in the sense that each
fibre is local.}

\proof{
\p{Let #{p} be a map #{X \to Y}. First note that a type #{A} is right orthogonal
to #{f_i} iff the map #{! : A \to 1} is right orthogonal to #{f_i}. Then we
arrange the arrows as below, noting that the fibre is a pullback.}

\quiver{
\begin{tikzcd}
	{A_i} && {\fibre{p}{y}} && {\tilde{P}} \\
	\\
	{B_i} && 1 && Y
	\arrow[from=1-1, to=1-3]
	\arrow["{f_i}"', from=1-1, to=3-1]
	\arrow[from=1-3, to=1-5]
	\arrow[from=1-3, to=3-3]
	\arrow["\lrcorner"{anchor=center, pos=0.125}, draw=none, from=1-3, to=3-5]
	\arrow[from=1-5, to=3-5]
	\arrow[color={rgb,255:red,214;green,92;blue,92}, dashed, from=3-1, to=1-3]
	\arrow[curve={height=6pt}, dashed, from=3-1, to=1-5]
	\arrow[from=3-1, to=3-3]
	\arrow[from=3-3, to=3-5]
\end{tikzcd}
}

\p{We complete the proof by appealing to the fact that right orthogonality is
preserved by base change.}
}

\agda{
module _ {ūĚďė ūĚď§ ūĚď• ūĚď¶ : Level} {I : Type ūĚďė}
         {A : I ‚Üí Type ūĚď§} {B : I ‚Üí Type ūĚď•}
         (f : (i : I) ‚Üí A i ‚Üí B i)
         where

  is-modal-map'‚Üźis-local
    : ‚ąÄ {ūĚďú ūĚďĚ} {X : Type ūĚďú} {Y : Type ūĚďĚ} (p : X ‚Üí Y)
      ‚Üí (‚ąÄ i ‚Üí are-orthogonal (f i) p) ‚Üí is-modal-map' (Local-SubU f (ūĚďú ‚äĒ ūĚďĚ)) p
  is-modal-map'‚Üźis-local p orth y i
    = is-orthogonal‚ÜĒorthogonal-! .fst
        (orthogonal‚Üźbase-change
          (f i) _
          (fibre-square-is-cartesian p y)
          (orth i))
}
}

\title{Directed glueing types}
\author{samueltoth}
\date{2026-06-04}
\taxon{Module}
\import{stt-macros}


\subtree[stt-00US]{
\taxon{Idea}
\author{samueltoth}

\p{A glue type was originally introduced to give a constructive interpretation of
univalence in work on cubical type theory \citek{CCHM15}. Weaver and Licata
\citek{WL20} and later Gratzer, Weinberger and Buchholtz \citek{GWB24} adapted it in
the directed setting to construct directed univalent universes. In this module we
use a directed gluing type to, under certain modal restrictions, give an equivalence
between covariant type families over the interval and types together with a map between
them. In \ref{Synthetic.Categories.Spaces}, we use this result to show that the
classifier for covariant families satisfies directed univalence.}
}

\agda{
open import Foundations.Universes
open import Foundations.Identity
open import Foundations.Empty
open import Algebra.Lattice
open import Synthetic.Quasicoherence

module Synthetic.Categories.DirectedGlueing
  {@♭ 𝓘} (@♭ Δ¹ : Type 𝓘) (@♭ I : Lattice Δ¹) (@♭ I-distr : is-distributive I)
  (open Lattice I renaming (0l to i0; 1l to i1))
  (@♭ non-triv : i1 ＝ i0 → ∅)
  (@♭ phoa : Δ¹-endos-are-mono Δ¹ I I-distr)
  where

open import Axioms.UF
}

\agda-imports{
\agda{
open import Foundations.Prelude

open import Ergonomics.Extensionality
open import Ergonomics.Auto

open import Modalities.Instances.Truncation

open import Modalities.Cohesion.Flat

open import Core.Arrows
open import Core.ArrowEquiv

open import Algebra.Lattice.Instances.Free.Inductive Δ¹ I

open import Synthetic.Hom Δ¹ i0 i1
open import Synthetic.Boundaries Δ¹ I
open import Synthetic.Categories.WalkingHom Δ¹ I
open import Synthetic.Categories.CovariantFamilies Δ¹ I
open import Synthetic.Categories.CovariantClosure Δ¹ I I-distr
}
}

\subtree[stt-00UY]{
\title{The glueing of a fibrewise map}
\taxon{Construction}

\p{Given a pair of type families #{F, G : B \to \Type} and a fibrewise map
#{\alpha_b : F_b \to G_b}, we can construct the glueing family
#{\textrm{Gl}(\alpha) : B \times \Delta^1 \to \Type}.
##{\textrm{Gl}(\alpha)(b, i) := \Sigma_{g : G_b} (i = 0) \to \fibre{\alpha_b}{g}}}

\agda{
Gl
  : ∀ {𝓤 𝓥} {B : Type 𝓤} (F : B → Type 𝓥) (G : B → Type 𝓥)
    → (α : ∀ b → F b → G b) → B × Δ¹ → Type (𝓘 ⊔ 𝓥)
Gl F G α (b , i) = Σ[ a ∶ G b ] ((i ＝ i0) → fibre (α b) a)
}

\p{#{\textrm{Gl}(\alpha)(b,0) = F(b)} and #{\textrm{Gl}(\alpha)(b,1) = G(b)}}

\agda{
module _
  {𝓤 𝓥} {B : Type 𝓤}
  (F : B → Type 𝓥) (G : B → Type 𝓥)
  (α : ∀ b → F b → G b)
  where

  Gl-0 : ∀ b → Gl F G α (b , i0) → F b
  Gl-0 b = fst ∘ ev refl ∘ snd

  Gl-0-is-equiv : is-fibrewise-equiv Gl-0
  Gl-0-is-equiv b
    = is-equiv-∘
        (total≃total-fibre _ ._≃_.fwd-is-equiv)
        (is-total-equiv←is-fibrewise-equiv
          (λ _
           → sing-ev-is-equiv global-funext
               (mk-singl refl (J-set! _ refl))))

  Gl-1 : ∀ b → Gl F G α (b , i1) → G b
  Gl-1 b = fst

  Gl-1-is-equiv : is-fibrewise-equiv Gl-1
  Gl-1-is-equiv b = singleton-fst-is-equiv (λ _ → Π-is-single (¡ ∘ non-triv))
}

\p{We may also define a map from
#{\textrm{Gl}(\alpha)(0,b) \to \textrm{Gl}(\alpha)(1,b)}, which is equivalent as a
map to #{\alpha_b}.}

\agda{
module _
  {𝓤 𝓥}{B : Type 𝓤} {F G : B → Type 𝓥} (α : ∀ b → F b → G b)
  where

  Gl-map : ∀ b → Gl F G α (b , i0) → Gl F G α (b , i1)
  Gl-map b = total-map (λ a → precomp-Π _ (¡ ∘ non-triv))

  Gl-map-agrees : ∀ b → Arrow-equiv (Gl-map b) (α b)
  Gl-map-agrees b .fst .Arrow-Π.top  = Gl-0 F G α b
  Gl-map-agrees b .fst .Arrow-Π.bot  = Gl-1 F G α b
  Gl-map-agrees b .fst .Arrow-Π.comm = sym ∘ snd ∘ ev refl ∘ snd
  Gl-map-agrees b .snd .fst = Gl-0-is-equiv F G α b
  Gl-map-agrees b .snd .snd = Gl-1-is-equiv F G α b
}
}

\subtree[stt-00UZ]{
\title{Covariance of the directed glueing family}
\taxon{Lemma}

\p{If #{F} and #{G} are covariant families over #{B}, then the directed glueing of any
map #{\alpha} is also covariant over #{B \times \Delta^1}.}

\agda{
opaque
  Gl-is-covariant
    : ∀ {𝓤 𝓥} {B : Type 𝓤}
        (F : B → Type 𝓥) (G : B → Type 𝓥)
        (α : ∀ b → F b → G b)
      → is-covariant F → is-covariant G
      → is-covariant (Gl F G α)
  Gl-is-covariant {B = B} F G α Fc Gc
    = Σ-is-covariant
        {B = G ∘ fst}
        {C = λ bi a → (bi .snd ＝ i0) → fibre (α (bi .fst)) a}
        (covariant-base-change {P = G} (fst: λ _ → Δ¹) Gc)
        (covariant-base-change
          {P = λ x → x .snd ＝ i0
                   → fibre (α (x .fst .fst)) (x .fst .snd)}
          (λ ((b , i) , g) → ((b , g) , i))
          (^●-is-covariant
            phoa
            (uncurry (λ b g → fibre (α b) g) ∘ fst)
            (covariant-base-change
              {P = uncurry (λ b g → fibre (α b) g)}
              fst
              (fibre-is-covariant _ _ Fc Gc α))
            snd))

Gl∘-is-covariant
  : ∀ {𝓤 𝓤' 𝓥} {A : Type 𝓤} {B : Type 𝓤'} (f : A → B × Δ¹)
      (F : B → Type 𝓥) (G : B → Type 𝓥)
      (α : ∀ b → F b → G b)
    → is-covariant F → is-covariant G
    → is-covariant (Gl F G α ∘ f)
Gl∘-is-covariant f F G α Fc Gc
  = covariant-base-change {P = Gl F G α} f
      (Gl-is-covariant F G α Fc Gc)
}
}


\subtree[stt-00KF]{
\title{Paths in glue types}
\taxon{Lemma}

\agda{
module _
  {𝓤 𝓥} {B : Type 𝓤}
  {F G : B → Type 𝓥}
  {f : ∀ b → F b → G b}
  where

  Gl-Id : ∀ (bi : B × Δ¹) → Gl F G f bi → Gl F G f bi → Type (𝓘 ⊔ 𝓥)
  Gl-Id (b , i) x y
    = Σ[ p ∶ x .fst ＝ y .fst ]
       (∀ (pi : i ＝ i0)
        → Σ[ q ∶ x .snd pi .fst ＝ y .snd pi .fst ]
           (Square (x .snd pi .snd) (y .snd pi .snd) (ap (f b) q) p))

  Gl-Id-refl : ∀ i → (x : Gl F G f i) → Gl-Id i x x
  Gl-Id-refl i x = (refl , (λ pi → refl , Square-degen-hor _ _ refl))

  opaque
    Gl-Id-is-torsorial
      : ∀ (bi : B × Δ¹) → (x : Gl F G f bi) → is-singleton (Σ _ (Gl-Id bi x))
    Gl-Id-is-torsorial bi x
      = is-singleton-structure←parts
          Sing-is-singleton
          (_ , refl)
          (is-single←equiv-to-single
            (Σ-Π-swap≃ _ λ p y
              → Σ[ q ∶ x .snd p .fst ＝ y .fst ]
                 Square (x .snd p .snd) (y .snd) (ap _ q) refl)
            (Π-is-single (λ where
              refl → is-singleton-structure←parts
                       Sing-is-singleton
                       (_ , refl)
                       (Square-degen-hor-is-torsorial
                         (x .snd refl .snd)))))

  IdS-Gl
    : ∀ (bi : B × Δ¹) → Identity-system (Gl F G f bi) (𝓘 ⊔ 𝓥)
  IdS-Gl bi .Identity-system.IdS = Gl-Id bi
  IdS-Gl bi .Identity-system.IdS←Id refl
    = Gl-Id-refl bi _
  IdS-Gl bi .Identity-system.IdS←Id-is-equiv a
    = fundamental-Id _ (Gl-Id-is-torsorial bi a) _

Gl-Id→
  : ∀ {𝓤 𝓥} {B : Type 𝓤}
      {F G : B → Type 𝓥}
      (f : ∀ b → F b → G b)
      (bi : B × Δ¹)
      {x y : Gl F G f bi}
    → Gl-Id {f = f} bi x y → x ＝ y
Gl-Id→ f bi = Id←IdS ⦃ IdS-Gl {f = f} bi ⦄
}
}

\subtree[stt-00V3]{
\title{Covariant #{Δ¹}-bundles}
\taxon{Definition}

\p{For some base type #{B} we define covariant #{\Delta^1}-bundles over #{B} to
be the data consisting of:

\ul{
\li{A pair of covariant type families #{F} and #{G} over #{B}}
\li{A fibrewise map #{\alpha_{(b,i)} : F(b,i) \to G(b,i)}}
}
}

\agda{
Cov-Δ¹-bundle
  : ∀ {𝓤} 𝓥 (B : Type 𝓤) → Type (𝓘 ⊔ 𝓤 ⊔ lsuc 𝓥)
Cov-Δ¹-bundle 𝓥 B
  = Σ[ X Y ∶ Σ (B → Type 𝓥) is-covariant ] (∀ b → X .fst b → Y .fst b)
}
}

\subtree[stt-00V1]{
\title{Characterising the identity type of a [covariant #{Δ¹}-bundle](stt-00V3)}
\taxon{Lemma}

\p{Given #{(A, B , α)} and #{(X, Y, β)}, a pair of covariant #{\Delta^1}-bundles over
some type #{B}, the identity type #{(A,B,α) = (X,Y,β)} is equivalent to fibrewise
equivalences #{e : A \simeq X} and #{p : B \simeq Y} such that the resulting square
commutes (#{p\alpha \sim \beta e}). Note that this is equivalent to an arrow
equivalence #{\alpha_x \simeq \beta_x} for all #{x : B \times \Delta^1}.}

\agda{
cov-Δ¹-bundle-Path
  : ∀ {𝓤 𝓥} {B : Type 𝓤} (x y : Cov-Δ¹-bundle 𝓥 B)
    → Type (𝓤 ⊔ 𝓥)
cov-Δ¹-bundle-Path ((A , _) , (B , _) , f) ((X , _) , (Y , _) , g)
  = Σ[ e ∶ (∀ b → A b ≃ X b) ] Σ[ p ∶ (∀ b → B b ≃ Y b) ]
      (∀ b → p b ._≃_.fwd ∘ f b ~ g b ∘ e b ._≃_.fwd)

cov-Δ¹-bundle-Path-refl
  : ∀ {𝓤 𝓥} {B : Type 𝓤} (x : Cov-Δ¹-bundle 𝓥 B)
    → cov-Δ¹-bundle-Path x x
cov-Δ¹-bundle-Path-refl x = ((λ _ → id≃) , (λ _ → id≃) , λ _ → ~refl)

instance
  IdS-cov-fam
    : ∀ {𝓤 𝓥} {A : Type 𝓤} → Identity-system (Σ (A → Type 𝓥) is-covariant) (𝓤 ⊔ 𝓥)
  IdS-cov-fam = IdS←Subtype is-covariant-is-prop auto!

opaque
  cov-Δ¹-bundle-Path-is-torsorial
    : ∀ {𝓤 𝓥} {B : Type 𝓤} (x : Cov-Δ¹-bundle 𝓥 B)
      → is-singleton (Σ _ (cov-Δ¹-bundle-Path x))
  cov-Δ¹-bundle-Path-is-torsorial (A , B , f)
    = is-singleton-structure←parts
       (SingS-is-single A)
       (A , λ _ → id≃)
       (is-singleton-structure←parts
         (SingS-is-single B)
         (B , λ _ → id≃)
         (SingS-is-single _))

instance
  cov-Δ¹-bundle-IdS
    : ∀ {𝓤 𝓥} {B : Type 𝓤} → Identity-system (Cov-Δ¹-bundle 𝓥 B) (𝓤 ⊔ 𝓥)
  cov-Δ¹-bundle-IdS .Identity-system.IdS = cov-Δ¹-bundle-Path
  cov-Δ¹-bundle-IdS .Identity-system.IdS←Id {a = A} refl = cov-Δ¹-bundle-Path-refl A
  cov-Δ¹-bundle-IdS .Identity-system.IdS←Id-is-equiv x
    = fundamental-Id _ (cov-Δ¹-bundle-Path-is-torsorial x) _
}
}

\subtree[stt-00V0]{
\title{The induced transport of a covariant family over #{Δ¹}}
\taxon{Construction}

\p{Given a covariant type family over #{B \times \Delta^1}, we can construct a
[\em{covariant bundle}](stt-00V3) over #{\Delta^1} – i.e.  a pair of covariant
families #{B \to \Type} together with a fibrewise map between them. }

\agda{
total-tr-cov
  : ∀ {𝓤 𝓥} {B : Type 𝓤}
    → (Σ (B × Δ¹ → Type 𝓥) is-covariant)
    → Cov-Δ¹-bundle 𝓥 B
total-tr-cov (F , Fcov)
  = ( (F ∘ (_, i0) , covariant-base-change {P = F} (_, i0) Fcov)
    , (F ∘ (_, i1) , covariant-base-change {P = F} (_, i1) Fcov)
    , (λ b → tr-cov {P = F ∘ (b ,_)} (covariant-base-change {P = F} (b ,_) Fcov) id))
}
}

\subtree[stt-00V2]{
\title{Directed univalence for covariant families}
\taxon{Theorem}

\p{The map defined in \ref{stt-00V0} induces an equivalence between covariant
families over #{B \times \Delta^1} and covariant bundles over #{B}, i.e. pairs of covariant
families over #{B} equipped with a fibrewise map between them.}

\proof{
\p{We first define a putative inverse:}

\agda{
module _
  {𝓤 𝓥} {B : Type 𝓤}
  where

  total-tr-cov-inv
    : Cov-Δ¹-bundle 𝓥 B
    → Σ (B × Δ¹ → Type (𝓥 ⊔ 𝓘)) is-covariant
  total-tr-cov-inv ((A , Ac) , (B , Bc) , α)
    = (Gl A B α , Gl-is-covariant A B α Ac Bc)
}

\subtree[stt-00V4]{
\title{Left inverse}
\taxon{Lemma}

\p{Under no assumptions, this map is a left inverse.}

\agda{
module _
  {𝓤 𝓥} {B : Type 𝓤}
  where

  tr-Gl-hom
    : ∀ {X Y : B → Type (𝓘 ⊔ 𝓥)}
        (α : ∀ b → X b → Y b)
      → ∀ b x → Homᵈ (Gl X Y α ∘ (b ,_)) x (Gl-map α b x)
  tr-Gl-hom α b x .Homᵈ.hom i = (x .fst , λ p → x .snd refl)
  tr-Gl-hom α b x .Homᵈ.hom0  = Σ-path→ (refl , (funext→ (J-set! _ refl)))
  tr-Gl-hom α b x .Homᵈ.hom1  = Σ-path→ (refl , (funext→ (¡ ∘ non-triv)))

  tr-Gl
    : ∀ {X Y : B → Type (𝓘 ⊔ 𝓥)}
        (α : ∀ b → X b → Y b)
        (Xc : is-covariant X) (Yc : is-covariant Y)
      → ∀ b
      → tr-cov {P = Gl X Y α} (Gl-is-covariant X Y α Xc Yc) (b ,_)
      ~ Gl-map α b
  tr-Gl α Xc Yc b x
    = tr-cov-unique
        (Gl-is-covariant _ _ α Xc Yc)
        (b ,_)
        (Gl-map α b)
        x
        (tr-Gl-hom α b x)

  tr-hom-Gl
    : ∀ {X Y : B → Type (𝓘 ⊔ 𝓥)}
        (α : ∀ b → X b → Y b)
        (Xc : is-covariant X) (Yc : is-covariant Y)
      → ∀ b
      → tr-cov-hom {P = Gl X Y α ∘ (b ,_)}
          (Gl∘-is-covariant (b ,_) X Y α Xc Yc)
          0≤1
      ~ Gl-map α b
  tr-hom-Gl {X} {Y} α Xc Yc b x
    = tr-cov-hom-unique (Gl X Y α ∘ (b ,_))
        (Gl∘-is-covariant (b ,_) X Y α Xc Yc)
        0≤1
        x
        (Gl-map α b x)
        (mk-hom
          (λ i → x .fst , λ _ → x .snd refl)
          (Σ-path→ (refl , (funext→ (J-set! _ refl))))
          (Σ-path→ (refl , (funext→ (¡ ∘ non-triv)))))

  tr-Gl-0≤1H
    : ∀ {X Y : B → Type (𝓘 ⊔ 𝓥)}
        (α : ∀ b → X b → Y b)
        (Xc : is-covariant X) (Yc : is-covariant Y)
        (b : B)
      → Arrow-equiv
          (tr-cov-hom {P = Gl X Y α ∘ (b ,_)}
            (covariant-base-change
              {P = Gl X Y α}
              (b ,_)
              (Gl-is-covariant X Y α Xc Yc) )
            0≤1)
          (α b)
  tr-Gl-0≤1H α Xc Yc b .fst .Arrow-Π.top = Gl-0 _ _ α b
  tr-Gl-0≤1H α Xc Yc b .fst .Arrow-Π.bot = Gl-1 _ _ α b
  tr-Gl-0≤1H α Xc Yc b .fst .Arrow-Π.comm  x
    = ap fst (tr-hom-Gl α Xc Yc b x) ∙ sym (x .snd refl .snd)
  tr-Gl-0≤1H α Xc Yc b .snd .fst = Gl-0-is-equiv _ _ α b
  tr-Gl-0≤1H α Xc Yc b .snd .snd = Gl-1-is-equiv _ _ α b

  tr-Gl-0≤1
    : ∀ {X Y : B → Type (𝓘 ⊔ 𝓥)}
        (α : ∀ b → X b → Y b)
        (Xc : is-covariant X) (Yc : is-covariant Y)
        (b : B)
      → Arrow-equiv
          (tr-cov {P = Gl X Y α} (Gl-is-covariant X Y α Xc Yc) (b ,_))
          (α b)
  tr-Gl-0≤1 α Xc Yc b .fst .Arrow-Π.top = Gl-0 _ _ α b
  tr-Gl-0≤1 α Xc Yc b .fst .Arrow-Π.bot = Gl-1 _ _ α b
  tr-Gl-0≤1 α Xc Yc b .fst .Arrow-Π.comm x@(y , p)
    = (fst ∘ tr-cov {P = Gl _ _ α} (Gl-is-covariant _ _ α Xc Yc) (b ,_)) x
    ＝⟨ ap fst (tr-Gl α Xc Yc b x) ⟩
      x .fst
    ＝⟨ sym (p refl .snd) ⟩
      α b (p refl .fst)
    ∎
  tr-Gl-0≤1 α Xc Yc b .snd .fst = Gl-0-is-equiv _ _ α b
  tr-Gl-0≤1 α Xc Yc b .snd .snd = Gl-1-is-equiv _ _ α b

  opaque
    -- This makes me think maybe tr-cov shouldn't be opaque, theres some kind of
    -- naturality that you get for free
    unfolding tr-cov

    total-tr-cov-section
      : ∀ (x : Cov-Δ¹-bundle (𝓘 ⊔ 𝓥) B)
        → cov-Δ¹-bundle-Path {𝓤} {𝓘 ⊔ 𝓥} {B} (total-tr-cov (total-tr-cov-inv x)) x
    total-tr-cov-section ((X , _) , (Y , _) , F) .fst b
      = mk≃ (Gl-0 X Y F b) (Gl-0-is-equiv X Y F b)
    total-tr-cov-section ((X , _) , (Y , _) , F) .snd .fst b
      = mk≃ (Gl-1 X Y F b) (Gl-1-is-equiv X Y F b)
    total-tr-cov-section ((X , Ac) , (Y , Bc) , F) .snd .snd b
      = tr-Gl-0≤1 {X} {Y} F Ac Bc b .fst .Arrow-map.comm
}
}

\subtree[stt-00V5]{
\taxon{Lemma}
\title{Right inverse}

\p{To show that we have a right inverse, for a covariant family
#{F} over #{B \times \Delta^1}, we need that #{F(b,i)} is equal to
#{Gl(F(b,0), F(b,1), F(b,-)_*)}. By univalence we may give a fibrewise map and show it
is an equivalence.
}

\p{To show that this map is indeed an equivalence we assume an additional axiom; namely that
for a crisp fibrewise map #{\alpha} between crisp covariant families over #{B \times
\Delta^1}, to check it is an equivalence it suffices to check that for all #{b},
#{\alpha_{(b, 0)}} and #{\alpha_{(b,1)}} are equivalences.}

\remark{
This axiom follows for example from the pair of axioms that [cubes
separate](stt-00J7) and the booleans cover the global points of #{\Delta^1}.
}

\agda{
module _
  {𝓤 𝓥} {B : Type 𝓤}
  (FF@(F , Fc) : Σ (B × Δ¹ → Type (𝓘 ⊔ 𝓥)) is-covariant)
  (let Fbc b = covariant-base-change {P = F} (b ,_) Fc)
  where

  Gl←cov-fam
    : (i : B × Δ¹)
    → F i
    → Gl
       (F ∘ (_, i0))
       (F ∘ (_, i1))
       (λ b → tr-cov {P = F} Fc (b ,_))
       i
  Gl←cov-fam (b , i) x .fst
    = tr-cov-hom {P = F ∘ (b ,_)}
        (Fbc b)
        (Δ¹-hom←≤ 1-top)
        x
  Gl←cov-fam (b , i) x .snd refl
    = ( x
      , sym
         (happly
           (coe-cov-0≤1 (F ∘ (b ,_)) (Fbc b) 1-top)
           x))

  Gl←cov-fam-is-equiv-at-0
    : ∀ b → is-equiv (Gl←cov-fam (b , i0))
  Gl←cov-fam-is-equiv-at-0 b
    = 3-for-2
        (Gl-0-is-equiv
           (F ∘ (_, i0))
           (F ∘ (_, i1))
           (λ b → tr-cov {P = F} Fc (b ,_))
           b)
        id-is-equiv

  Gl←cov-fam-is-equiv-at-1
    : ∀ b → is-equiv (Gl←cov-fam (b , i1))
  Gl←cov-fam-is-equiv-at-1 b
    = 3-for-2~
        (tr-cov-idH~ (F ∘ (b ,_)) (Fbc b) (Δ¹-hom←≤ 1-top) (Δ¹-hom-≤-refl 1-top) h⁻¹)
        (Gl-1-is-equiv
           (F ∘ (_, i0))
           (F ∘ (_, i1))
           (λ b → tr-cov {P = F} Fc (b ,_))
           b)
        id-is-equiv

module _
  {@♭ 𝓤 𝓥} {@♭ B : Type 𝓤}
  (@♭ crisp-cov-Nat-is-equiv
    : ∀ {@♭ 𝓤} (@♭ F G : Σ (B × Δ¹ → Type 𝓤) is-covariant)
        (@♭ α : ∀ i → F .fst i → G .fst i)
      → @♭ (∀ (@♭ b : B) (@♭ x) → is-equiv (♭-map (α (b , ∂Δ¹-incl x))))
      → is-fibrewise-equiv α)
  where

  Gl←cov-fam-is-equiv
    : ∀ (@♭ F : Σ (B × Δ¹ → Type (𝓥 ⊔ 𝓘)) is-covariant)
      → is-fibrewise-equiv (Gl←cov-fam {𝓤} {𝓥} F)
  Gl←cov-fam-is-equiv FF@(F , Fc)
    = crisp-cov-Nat-is-equiv FF (total-tr-cov-inv {𝓤}{𝓥 ⊔ 𝓘}{B} (total-tr-cov FF))
        (Gl←cov-fam (F , Fc))
        ( λ { b ∂Δ¹-1 → ♭-map-is-equiv (Gl←cov-fam-is-equiv-at-1 (F , Fc) b)
            ; b ∂Δ¹-0 → ♭-map-is-equiv (Gl←cov-fam-is-equiv-at-0 (F , Fc) b) })

  total-tr-cov-retraction
    : ∀ (@♭ F : Σ (B × Δ¹ → Type (𝓥 ⊔ 𝓘)) is-covariant)
      → (bi : B × Δ¹)
      → F .fst bi ≃ total-tr-cov-inv {𝓤} {𝓥 ⊔ 𝓘} {B} (total-tr-cov F) .fst bi
  total-tr-cov-retraction F bi ._≃_.fwd = Gl←cov-fam {𝓤} {𝓥} F bi
  total-tr-cov-retraction F bi ._≃_.fwd-is-equiv = Gl←cov-fam-is-equiv F bi
}
}

\agda{
  opaque
    total-tr-cov-is-♭-equiv
      : is-equiv (♭-map (total-tr-cov {𝓤} {𝓥 ⊔ 𝓘} {B}))
    total-tr-cov-is-♭-equiv = is-equiv←qinv
      ( ♭-map total-tr-cov-inv
      , ♭-ind (λ a → mapply♭ (mod♭ (ext! (λ b → total-tr-cov-retraction a b e⁻¹))))
      , ♭-ind (λ a → mapply♭ (mod♭ (ext! (total-tr-cov-section {𝓤} {𝓥} a)))))
}
}
}

\subtree[stt-00H6]{
\date{2026-03-11}
\author{fredrikbakke}
\taxon{Definition}
\title{The canonical equaliser}

\p{
Given a pair of parallel maps #{f\ g : A \to B}, the canonical equaliser is the
type of elements #{a : A} equipped with a path #{f(a) = g(a)}.
}

\agda{
Equaliser
  : {ūĚď§ ūĚď• : Level} {A : Type ūĚď§} {B : Type ūĚď•}
  ‚Üí (f g : A ‚Üí B)
  ‚Üí Type (ūĚď§ ‚äĒ ūĚď•)
Equaliser {A = A} f g = ő£[ a ‚ą∂ A ] (f a ÔľĚ g a)

module _ {ūĚď§ ūĚď• : Level} {A : Type ūĚď§} {B : Type ūĚď•} (f g : A ‚Üí B) where

  Equaliser-fork : Fork f g (Equaliser f g)
  Equaliser-fork = fst , snd

  Equaliser-gap
    : {ūĚď† : Level} {Q : Type ūĚď†}
    ‚Üí Fork f g Q
    ‚Üí Q ‚Üí Equaliser f g
  Equaliser-gap (e , H) q = (e q , H q)
}
}

\subtree[stt-00H7]{
\date{2026-03-18}
\author{fredrikbakke}
\taxon{Theorem}
\title{The canonical equaliser is an equaliser}

\agda{
module _
  {ūĚď§ ūĚď• : Level} {A : Type ūĚď§} {B : Type ūĚď•}
  (f g : A ‚Üí B)
  where

  Equaliser-has-up-equaliser
    : up-equaliser f g (Equaliser-fork f g)
  Equaliser-has-up-equaliser = mk-eqv (Equaliser-gap f g , ~refl , ~refl) ~refl
}
}

\subtree[stt-00H8]{
\date{2026-03-11}
\author{fredrikbakke}
\taxon{Theorem}
\title{Canonical equalisers as pullbacks}

\p{
The equaliser of a pair of parallel maps #{f\ g : A \to B} can be presented as the
pullback

\quiver{
\begin{tikzcd}
	\textrm{Eq}(f,g) && A  \\
	\\
	B && B \times B
	\arrow[from=1-1, to=1-3]
	\arrow[from=1-1, to=3-1]
	\arrow["{(f,g)}", from=1-3, to=3-3]
	\arrow["\Delta", from=3-1, to=3-3]
	\arrow["\lrcorner" very near start, phantom, from=1-1, to=3-3]
\end{tikzcd}
}
}

\agda{
module _
  {ūĚď§ ūĚď• : Level} {A : Type ūĚď§} {B : Type ūĚď•} {f g : A ‚Üí B}
  where

  Equaliser-diagonal-cone
    : Cone
        (mk-cospan (B √ó B) (őĽ b ‚Üí (b , b)) (őĽ a ‚Üí (f a , g a)))
        (Equaliser f g)
  Equaliser-diagonal-cone
    = mk-cone
        (f ‚ąė fst)
        (fst)
        (őĽ (_ , p) ‚Üí √ó-path‚Üí (refl , p))

  Pullback‚ÜźEqualiser
    : Equaliser f g
    ‚Üí Pullback (őĽ b ‚Üí (b , b)) (őĽ a ‚Üí (f a , g a))
  Pullback‚ÜźEqualiser = gap Equaliser-diagonal-cone

  Pullback‚ÜźEqualiser-is-equiv
    : is-equiv Pullback‚ÜźEqualiser
  Pullback‚ÜźEqualiser-is-equiv = is-equiv‚Üźqinv qinv where
    bwd : Pullback (őĽ b ‚Üí (b , b)) (őĽ a ‚Üí (f a , g a)) ‚Üí Equaliser f g
    bwd (b , a , p) = (a , sym (ap fst p) ‚ąô ap snd p)

    qinv : quasi-inv Pullback‚ÜźEqualiser
    qinv .fst = bwd
    qinv .snd .fst (a , p) = ő£-path‚Üí (refl , retp) where
      retp
        : sym (ap fst (√ó-path‚Üí (refl , p))) ‚ąô ap snd (√ó-path‚Üí (refl , p))
        ÔľĚ p
      retp
        = ap (őĽ q ‚Üí sym q ‚ąô ap snd (√ó-path‚Üí (refl , p))) √ó-path-ap-fst
        ‚ąô ‚ąô-refll _
        ‚ąô √ó-path-ap-snd
    qinv .snd .snd (b , a , p)
      = pullback-path‚Üí (sym (ap fst p) , refl , sq p ‚ąô sym (‚ąô-reflr _)) where
      sq
        : {b' : B} {a' : A}
          (p' : (b' , b') ÔľĚ (f a' , g a'))
        ‚Üí ap (őĽ c ‚Üí (c , c)) (sym (ap fst p')) ‚ąô p'
        ÔľĚ √ó-path‚Üí (refl , sym (ap fst p') ‚ąô ap snd p')
      sq = J ( őĽ y p'
             ‚Üí ap (őĽ c ‚Üí (c , c)) (sym (ap fst p')) ‚ąô p'
             ÔľĚ √ó-path‚Üí (refl , sym (ap fst p') ‚ąô ap snd p'))
        ( refl)

  Equaliser‚ČÉPullback-diagonal
    : Equaliser f g
    ‚ČÉ Pullback (őĽ b ‚Üí (b , b)) (őĽ a ‚Üí (f a , g a))
  Equaliser‚ČÉPullback-diagonal
    = mk‚ČÉ Pullback‚ÜźEqualiser Pullback‚ÜźEqualiser-is-equiv
}
}

\subtree{
\date{2026-03-11}
\author{fredrikbakke}
\taxon{Lemma}
\title{Identity types as equalisers}

\p{
The identity type #{x = y} can be presented as the equaliser of the two maps
#{\point(x),\point(y) : \b1 \to A}.
}

\agda{
module _ {ūĚď§ : Level} {A : Type ūĚď§} (x y : A) where

  ÔľĚ-fork
    : Fork (point x) (point y) (x ÔľĚ y)
  ÔľĚ-fork = (! , id)

  ÔľĚ-Equaliser-point-gap
    : x ÔľĚ y
    ‚Üí Equaliser (point x) (point y)
  ÔľĚ-Equaliser-point-gap
    = Equaliser-gap (point x) (point y) (ÔľĚ-fork)

  ÔľĚ-Equaliser-point-gap-is-equiv
    : is-equiv ÔľĚ-Equaliser-point-gap
  ÔľĚ-Equaliser-point-gap-is-equiv
    = mk-eqv (snd , ~refl , ~refl) (~refl)

  ÔľĚ‚ČÉEqualiser-point
    : (x ÔľĚ y)
    ‚ČÉ Equaliser (point x) (point y)
  ÔľĚ‚ČÉEqualiser-point
    = mk‚ČÉ ÔľĚ-Equaliser-point-gap ÔľĚ-Equaliser-point-gap-is-equiv
}
}

\subtree{
\date{2026-03-17}
\author{fredrikbakke}
\taxon{Lemma}
\title{The total identity type}

\p{
The total identity type of a type #{X} is the total space of the identity family on
#{X}. It can equally be presented as the equaliser of the two projections
#{\fst,\snd : X \times X \to X}.
}

\agda{
total-Id
  : {ūĚď§ : Level} ‚Üí Type ūĚď§ ‚Üí Type ūĚď§
total-Id X = Equaliser (fst {B = őĽ _ ‚Üí X}) snd

total-Id-point
  : {ūĚď§ : Level} {X : Type ūĚď§}
  ‚Üí total-Id X ‚Üí X
total-Id-point ((x , _) , _) = x

point-total-Id
  : {ūĚď§ : Level} {X : Type ūĚď§}
  ‚Üí X ‚Üí total-Id X
point-total-Id x = ((x , x) , refl)

total-Id-point-is-equiv
  : {ūĚď§ : Level} {X : Type ūĚď§}
  ‚Üí is-equiv (total-Id-point {X = X})
total-Id-point-is-equiv {X = X}
  = mk-eqv
      ( point-total-Id
      , (őĽ { ((x , .x) , refl) ‚Üí refl })
      , (őĽ _ ‚Üí refl))
      (őĽ { ((x , .x) , refl) ‚Üí refl })

total-Id‚ČÉ
  : {ūĚď§ : Level} {X : Type ūĚď§}
  ‚Üí total-Id X ‚ČÉ X
total-Id‚ČÉ
  = mk‚ČÉ total-Id-point total-Id-point-is-equiv
}
}

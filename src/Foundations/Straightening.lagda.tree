\subtree[stt-003S]{
\taxon{Theorem}
\title{Replacement by fibres}

\p{Given a map #{p : E \to B}, the type #{\Sigma_{(b:B)} \fibre{p}{b}}
is equivalent to the type #{E}. }

% ```agda
\agda{
total‚Üźtotal-fibre : ‚ąÄ {ūĚď§} {B : Type ūĚď§}
                     {ūĚď•} {A : Type ūĚď•} (p : A ‚Üí B)
                   ‚Üí total-fibre p ‚Üí A
total‚Üźtotal-fibre p (_ , a , _) = a

refl-fibre : ‚ąÄ {ūĚď§} {B : Type ūĚď§}
               {ūĚď•} {A : Type ūĚď•} (p : A ‚Üí B)
               ‚Üí A ‚Üí total-fibre  p
refl-fibre p a = (p a , a , refl)

total‚ČÉtotal-fibre : ‚ąÄ {ūĚď§} {B : Type ūĚď§}
                     {ūĚď•} {A : Type ūĚď•} (p : A ‚Üí B)
                   ‚Üí total-fibre p ‚ČÉ A
total‚ČÉtotal-fibre {A = A} p
 = mk‚ČÉ (total‚Üźtotal-fibre p) (is-equiv‚Üźqinv f-qinv) where
  f-qinv : quasi-inv (total‚Üźtotal-fibre p)
  f-qinv .fst = refl-fibre p
  f-qinv .snd .fst (_ , a , refl) = refl
  f-qinv .snd .snd a = refl
}
% ```
}

\subtree[stt-003Q]{
\title{Straightening}
\taxon{Theroem}
\date{2025-08-06}

\p{Under the assumption of univalence, given a base type #{B}, we can
define an equivalence between types \em{over} #{B} - #{\Sigma_{E : \UU} (E
\to B)} and type families #{B \to \UU}. The former type is said to be
the \em{unstraightened} version of the later - and
visa-versa. Sometimes, we also call the unstraightened perspective to
be called \em{fibred} and the staightened version \em{indexed}.}

%```agda
\agda{
module WithUA {ūĚď§} (UU : is-univalent ūĚď§)(FE : FunExt-global) where
  open WithLocalUnivalence UU
  open WithFunExt-global FE

  Bundle : Type ūĚď§ ‚Üí Type (lsuc ūĚď§)
  Bundle B = ő£[ E ‚ą∂ Type ūĚď§ ] (E ‚Üí B)

  straighten : ‚ąÄ {B} ‚Üí Bundle B ‚Üí B ‚Üí Type ūĚď§
  straighten (E , p) = fibre p

  unstraighten : ‚ąÄ {B} ‚Üí (B ‚Üí Type ūĚď§) ‚Üí Bundle B
  unstraighten {B} P = (ő£ _ P , fst)

  straighten-qinv : ‚ąÄ {B} ‚Üí quasi-inv (straighten {B})
  straighten-qinv .fst = unstraighten
  straighten-qinv .snd .snd P
    = funext‚Üí (őĽ b ‚Üí ua (fibre-straighten P b))
  straighten-qinv .snd .fst (E , p)
    = ő£-path‚Üí
      ( ua (total‚ČÉtotal-fibre p)
      , tr-ap1 (ua (total‚ČÉtotal-fibre p)) fst ‚ąô ap (fst ‚ąė_) (sym-coe-ua)
      )
    where
    tr-ap1 : ‚ąÄ {A A' B : Type ūĚď§} (p : A ÔľĚ A') f
             ‚Üí tr (őĽ A ‚Üí A ‚Üí B) p f ÔľĚ őĽ x ‚Üí f (coe (sym p) x)
    tr-ap1 refl f = refl

    lem : ‚ąÄ {A} ‚Üí id‚ČÉ e‚ĀĽ¬Ļ ÔľĚ id‚ČÉ {ūĚď§} {A}
    lem = ‚ČÉ-path‚Üí FE refl

    ua-sym : ‚ąÄ {A B} {e : A ‚ČÉ B} ‚Üí sym (ua e) ÔľĚ ua (e e‚ĀĽ¬Ļ)
    ua-sym = equiv-J (őĽ _ e ‚Üí sym (ua e) ÔľĚ ua (e e‚ĀĽ¬Ļ))
                     (ap sym (ua-id‚ČÉ) ‚ąô sym (ap ua lem ‚ąô ua-id‚ČÉ))
                     _ _

    sym-coe-ua : ‚ąÄ {A B} ‚Üí {e : A ‚ČÉ B} ‚Üí coe (sym (ua e)) ÔľĚ _‚ČÉ_.bwd e
    sym-coe-ua {A} {e = e} = ‚ČÉ-ind (őĽ _ e ‚Üí coe (sym (ua e)) ÔľĚ _‚ČÉ_.bwd e)
                              (őĽ where .A refl ‚Üí ap coe ua-sym ‚ąô coe-ua)
                               _ e

  straighten-is-equiv : ‚ąÄ {B} ‚Üí is-equiv (straighten {B})
  straighten-is-equiv = is-equiv‚Üźqinv straighten-qinv

  straighten‚ČÉ : ‚ąÄ {B} ‚Üí Bundle B ‚ČÉ (B ‚Üí Type ūĚď§)
  straighten‚ČÉ = mk‚ČÉ _ straighten-is-equiv
}
%```
}

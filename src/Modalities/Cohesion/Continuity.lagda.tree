\subtree[stt-00J6]{
\title{Detecting continuity}

\p{We say that a crisp family of types #{\{G_i\}_{i:I}}
(for #{I} #{\flat}-discrete and inhabited) detects continuity when for all
crisp maps #{f : A \to B}, #{f} is a #{\sharp}-codiscrete map iff
#{\varepsilon_{G_i} \perp_\flat f} for all #{i :^\flat I}.}

\agda{
large-detects-continuity
  : ∀ {@♭ α β : Level → Level} (@♭ I : ∀ 𝓤 → Type (α 𝓤))
      (@♭ G : ∀ {𝓤} → I 𝓤 → Type (β 𝓤)) → Typeω
large-detects-continuity I G
  = ∀ {@♭ 𝓤 𝓥} (@♭ af : Arrow 𝓤 𝓥)
      (let @♭ f = Arrow.f af)
    → (∀ {@♭ 𝓜} {@♭ i : I 𝓜} → are-♭-orthogonal (ε♭: G i) f)
    → is-♯-codiscrete-map f

detects-continuity
  : ∀ {@♭ 𝓘 𝓤} {@♭ I : Type 𝓘} (@♭ G : I → Type 𝓤) → Typeω
detects-continuity G
  = ∀ {@♭ 𝓤 𝓥} (@♭ af : Arrow 𝓤 𝓥)
      (let @♭ f = Arrow.f af)
    → (∀ {@♭ i} → are-♭-orthogonal (ε♭: G i) f)
    → is-♯-codiscrete-map f
}

\p{\ref{stt-00J3} now says exactly that the large family of all types
always detects continuity.}
}

\subtree[stt-00J5]{
\title{Detecting sharp codiscrete types}
\taxon{Lemma}
\citet{3.1.5}{MR23}

\p{A family that detects continuity can give us a useful criteria for checking
when crisp types are sharp codiscrete.}

\p{Fixing a family #{G_i} which detects continuity, a crisp type #{X} is
#{\sharp}-codiscrete if and only if the induced map
#{\modflat{G_i \to X} \to \modflat{\modflat{G_i} \to X}} is an equivalence.}

\agda{
module _
         {@♭ α β : Level → Level}
         {@♭ I : ∀ 𝓤 → Type (α 𝓤)}
         (@♭ G : ∀ {𝓤} → I 𝓤 → Type (β 𝓤))
         (@♭ det : large-detects-continuity I G)
         where
  detects-continuous-types
    : ∀ {@♭ 𝓤} {@♭ X : Type 𝓤}
      → (∀ {@♭ 𝓤} {@♭ i : I 𝓤} → is-♭-orthogonal-type (ε♭: G i) X)
      → is-♯-codiscrete X
  detects-continuous-types P
    = is-modal←is-modal-! ♯-SubU
        (det (mk-arrow !)
        (are-♭-orthogonal-!←is-orthogonal-type P))
}
}

\subtree[stt-00J7]{
\title{Separating families}
\taxon{Definition}

\p{We say that a (possible large) family #{G_i} of crisp types \em{separates} if
for all crisp maps #{f :^{\flat} A \to B}, if #{f} is a #{\flat} equivalence,
and if each induced map #{\modflat{G_i \to X} \to \modflat{G_i \to Y}} is an
equivalence then #{f} itself is an equivalence.}

\agda{
family-separates : ∀ {@♭ 𝓘 𝓤} {@♭ I : Type 𝓘} (@♭ G : I → Type 𝓤) → Typeω
family-separates G = ∀ {@♭ 𝓤 𝓥} (@♭ fa : Arrow 𝓤 𝓥) (let @♭ f = Arrow.f fa)
                     → @♭ is-equiv (♭-map f)
                     → ((∀ {@♭ i} → is-equiv (♭-map (postcomp (G i) f))))
                     → is-equiv f

large-family-separates
  : ∀ {@♭ α β : Level → Level} (@♭ I : ∀ 𝓤 → Type (α 𝓤))
    → (@♭ G : ∀ {𝓤} → I 𝓤 → Type (β 𝓤)) → Typeω
large-family-separates I G
  = ∀ {@♭ 𝓤 𝓥} (@♭ fa : Arrow 𝓤 𝓥) (let @♭ f = Arrow.f fa)
    → @♭ is-equiv (♭-map f)
    → ((∀ {@♭ 𝓤} {@♭ i : I 𝓤} → is-equiv (♭-map (postcomp (G i) f))))
    → is-equiv f
}
}

\subtree[stt-00NM]{
\title{Types separate}
\taxon{Theorem}
\author{fredrikbakke}
\author{samueltoth}
\date{2026-04-28}

\p{
The universal type family is a [separating family](stt-00J7).
}

\agda{
Types-separate
  : ∀ {@♭ 𝓤 𝓥} {@♭ A : Type 𝓤} {@♭ B : Type 𝓥} (@♭ f : A → B) → Typeω
Types-separate f
  = @♭ (∀ {@♭ 𝓤} {@♭ Γ : Type 𝓤} → is-equiv (♭-map (postcomp Γ f)))
    → is-equiv f

module _ {@♭ 𝓤 𝓥 : Level} {@♭ A : Type 𝓤} {@♭ B : Type 𝓥} (@♭ f : A → B) where

  left-inverse←♭-postcomp-section
    : is-equiv (♭-map (postcomp A f))
    → (g♭ : ⟨♭| (B → A) ⟩)
    → ♭-map (postcomp B f) g♭ ＝ mod♭ id
    → ε♭ g♭ ∘ f ＝ id
  left-inverse←♭-postcomp-section F (mod♭ g) gβ
    = ap ε♭ (unap-equiv F (ap (♭-map (precomp _ f)) gβ))

  types-separate
    : Types-separate f
  types-separate sep = is-equiv←qinv
    ( ε♭ f⁻¹♭
    , happly (left-inverse←♭-postcomp-section (sep {Γ = A}) f⁻¹♭ f⁻¹β)
    , happly (sym (ε♭-natural {f = postcomp B f} f⁻¹♭) ∙ ap ε♭ f⁻¹β))
    where
    f⁻¹♭ : ⟨♭| (B → A) ⟩
    f⁻¹♭ = is-equiv.bwd (sep {Γ = B}) (mod♭ id)

    f⁻¹β : ♭-map (postcomp B f) f⁻¹♭ ＝ mod♭ id
    f⁻¹β = is-equiv.ε (sep {Γ = B}) (mod♭ id)
}
}


\subtree[stt-00J8]{
\title{Families that detect continuity also separate}
\taxon{Theorem}

\p{If #{G_i} [detects continuity](stt-00J6), then it also [separates](stt-00J7).}

\proof{
\citet{3.1.6}{MR23}

\p{Because #{f} is a #{\flat}-equivalence, it is also a #{\sharp}-equivalence,
and by the [lexness](stt-00JU) of sharp, it follows that it is #{\sharp}-connected. It
thus suffices to show that #{f} is #{\sharp}-codiscrete. To this end we make use
our assumption that #{G_i} detects continuity.}

\p{Consider the following square:}

\quiver{
\begin{tikzcd}
	{\flat(X^{G_i})} && {\flat(X^{\flat{G_i}})} && {\flat(\sharp X^{G_i})} \\
	\\
	{\flat(Y^{G_i})} && {\flat(Y^{\flat{G_i}})} && {\flat(\sharp Y^{G_i})}
	\arrow[from=1-1, to=1-3]
	\arrow[from=1-1, to=3-1]
	\arrow[from=1-3, to=1-5]
	\arrow[from=1-3, to=3-3]
	\arrow[from=1-5, to=3-5]
	\arrow[from=3-1, to=3-3]
	\arrow[from=3-3, to=3-5]
\end{tikzcd}
}

\p{We hope to show the left square is a pullback (and thus #{\varepsilon_{G_i}
\perp_{\flat} f}).  The right-most square is an equivalence of arrows by the #{\flat
\dashv \sharp} adjunction, and because the right-most map is an equivalence,
so is the middle map. Notice that the leftmost vertical map is an
equivalence by assumption, and any square with two opposing faces being
equivalences is cartesian.}
}

\agda{
large-family-separates←detects-continuity
  : ∀ {@♭ α β : Level → Level} {@♭ I : ∀ 𝓤 → Type (α 𝓤)}
    → (@♭ G : ∀ {𝓤} → I 𝓤 → Type (β 𝓤))
    → large-detects-continuity I G
    → large-family-separates I G
large-family-separates←detects-continuity {I = I} G gc f f♭eq fsep
  = is-equiv←is-modal←is-connected ♯-gRSubU
      f-is-♯-codisc
      (is-♯-connected←is-♯-equiv (is-♯-equiv←is-♭-equiv f♭eq)) where
  module _  {@♭ 𝓤} {@♭ i : I 𝓤} where
    lsquare : Arrow-map (♭-map (postcomp (G i) (Arrow.f f)))
                        (♭-map (postcomp ⟨♭| G i ⟩ (Arrow.f f)))
    lsquare = ♭Square (power-hom (ε♭: G i) (Arrow.f f))

    rsquare : Arrow-map (♭-map (postcomp ⟨♭| G i ⟩ (Arrow.f f)))
                        (♭-map (postcomp (G i) (♯-map (Arrow.f f))))
    rsquare .Arrow-Π.top = global-transpose
    rsquare .Arrow-Π.bot = global-transpose
    rsquare .Arrow-Π.comm (mod♭ f) = refl

    rsquare-is-equiv : is-Arrow-equiv rsquare
    rsquare-is-equiv .fst = global-transpose-is-equiv
    rsquare-is-equiv .snd = global-transpose-is-equiv

    lemma : is-equiv (♭-map (postcomp ⟨♭| G i ⟩ (Arrow.f f)))
    lemma = src-is-equiv←Arrow-equiv
              (rsquare , rsquare-is-equiv)
              (♭-map-is-equiv (postcomp-equiv (is-♯-equiv←is-♭-equiv f♭eq)))

    lsquare-cart : is-cartesian lsquare
    lsquare-cart = is-cartesian←dom+cod-is-equiv lsquare fsep lemma

  f-is-♯-codisc : is-♯-codiscrete-map (Arrow.f f)
  f-is-♯-codisc = gc f lsquare-cart


family-separates←detects-continuity
  : ∀ {@♭ 𝓘 𝓤 : Level} {@♭ I : Type 𝓘}
    → (@♭ G : I → Type 𝓤)
    → detects-continuity G
    → family-separates G
family-separates←detects-continuity {𝓘} {I = I} G Gc fa eq eq'
  = large-family-separates←detects-continuity
      {I = λ _ → I}
      G
      (λ af x b → Gc af (x {𝓘}) b)
      fa
      eq
      eq'
}
}

\subtree[tot-0009]{
\title{Separating families which contain a singleton}
\taxon{Lemma}

\p{If #{X} is a family of types such that #{X_i} is a singleton for
some #{i}, then we have a simpler condition to test equivalences on:}


\agda{
module _
  {@♭ 𝓘 𝓧} {@♭ I : Type 𝓘} (@♭ X : I → Type 𝓧)
  (@♭ X-separates : family-separates X)
  {@♭ is : I}
  (@♭ Xi-singleton : is-singleton (X is))
  where

  family-separates-with-𝟙
    : ∀ {@♭ 𝓤 𝓥} (@♭ fa : Arrow 𝓤 𝓥) (let @♭ f = Arrow.f fa)
      → @♭ ((∀ {@♭ i} → is-equiv (♭-map (postcomp (X i) f))))
      → is-equiv f
  family-separates-with-𝟙 fa eq
    = X-separates
        fa
        (tgt-is-equiv←Arrow-equiv (amap , amap-is-equiv) eq)
        eq where
    open Arrow fa
    amap : Arrow-map (♭-map (postcomp (X is) f)) (♭-map f)
    amap .Arrow-Π.top = ♭-map (ev (Xi-singleton .centre))
    amap .Arrow-Π.bot = ♭-map (ev (Xi-singleton .centre))
    amap .Arrow-Π.comm (mod♭ f) = refl

    amap-is-equiv : is-Arrow-equiv amap
    amap-is-equiv .fst
      = ♭-map-is-equiv (sing-ev-is-equiv global-funext Xi-singleton)
    amap-is-equiv .snd
      = ♭-map-is-equiv (sing-ev-is-equiv global-funext Xi-singleton)
}
}

\subtree[tot-2KKP]{
\taxon{Lemma}
\title{The separation principle for fibrewise equivalences}

\p{If #{\alpha : \Pi_{x : X} A_x \to B_x} is a family of maps, then for a
family #{\mathcal{F}}, which [separates](stt-00J&), #{\alpha} is a
fibrewise equivalence iff for each #{I \in \mathcal{F}}, and
#{x :^{\flat} I \to X}, the induced map
##{\flat(\Pi_{i : I} A_{x(i)}) \to \flat(\Pi_{i : I}B_{x(i)})} is an
equivalence.}

\agda{
module _
  {@♭ 𝓘 𝓤} {@♭ I : Type 𝓘}
  (@♭ G : I → Type 𝓤)
  (@♭ G-sep : family-separates G)
  {@♭ 𝓥 𝓦 𝓜} {@♭ X : Type 𝓥} {@♭ P : X → Type 𝓦} {@♭ Q : X → Type 𝓜}
  (@♭ α : (x : X) → P x → Q x)
  where

  -- TODO extract this useful theorem :)
  @♭ amap
    : ∀ (@♭ i)
      → Arrow-equiv
          (postcomp (G i) (total-map α))
          (total-map {A = G i → X} (postcomp-Π ∘ (α ∘_)))
  amap i .fst .Arrow-Π.top = Σ-Π-swap (λ _ → X) (λ _ → P)
  amap i .fst .Arrow-Π.bot = Σ-Π-swap (λ _ → X) (λ _ → Q)
  amap i .fst .Arrow-Π.comm = ~refl
  amap i .snd .fst = Σ-Π-swap-is-equiv
  amap i .snd .snd = Σ-Π-swap-is-equiv

  is-fibrewise-equiv←family-separates
      : @♭ (∀ (@♭ x) → is-equiv (♭-map (α x)))
      → @♭ (∀ (@♭ i : I) (@♭ x : G i → X)
          → is-equiv {A = ⟨♭| Π (G i) (P ∘ x) ⟩}
                     {B = ⟨♭| Π (G i) (Q ∘ x) ⟩}
                     (♭-map (postcomp-Π (α ∘ x))))
      → is-fibrewise-equiv α
  is-fibrewise-equiv←family-separates ♭eq eq2
    = is-fibrewise-equiv←is-total-equiv
        (G-sep
          (mk-arrow (total-map α))
          (♭-map-total-is-equiv α
            (is-total-equiv←is-fibrewise-equiv (♭-ind ♭eq)))
          (λ {i} → lem i)) where

    lem : ∀ (@♭ i) → is-equiv (♭-map (postcomp (G i) (total-map α)))
    lem i = src-is-equiv←Arrow-equiv
              (♭-arrow-equiv (amap i))
              (♭-map-total-is-equiv
                (postcomp-Π ∘ (α ∘_))
                (is-total-equiv←is-fibrewise-equiv (♭-ind (eq2 i))))

  is-fibrewise-equiv←family-separates-with-𝟙
    : ∀ {@♭ is} (@♭ Gi-singleton : is-singleton (G is))
      → @♭ (∀ (@♭ i : I) (@♭ x : G i → X)
          → is-equiv {A = ⟨♭| Π (G i) (P ∘ x) ⟩}
                     {B = ⟨♭| Π (G i) (Q ∘ x) ⟩}
                     (♭-map (postcomp-Π (α ∘ x))))
      → is-fibrewise-equiv α
  is-fibrewise-equiv←family-separates-with-𝟙 {is} Gs ♭eq
    = is-fibrewise-equiv←is-total-equiv
        (family-separates-with-𝟙 G G-sep Gs
          (mk-arrow (total-map α))
          λ {i} → src-is-equiv←Arrow-equiv
                    (♭-arrow-equiv (amap i))
                    (♭-map-total-is-equiv (postcomp-Π ∘ (α ∘_))
                    (is-total-equiv←is-fibrewise-equiv (♭-ind (♭eq i)))))
}
}

\subtree[fre-5BFE]{
\taxon{Theorem}
\title{Function extensionality from weak function extensionality}
\author{fredrikbakke}
\date{2026-05-29}

\p{
Having a function #{(f \sim g) \to (f = g)} for all #{f} and #{g} implies that
singletons are closed under dependent products, which in turn implies function
extensionality.
}

\agda{

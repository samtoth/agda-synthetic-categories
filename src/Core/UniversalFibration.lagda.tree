\subtree[tot-1110]{
\title{Global classes of maps}
\taxon{Definition}

\p{A global class of maps is a family of subtypes of #{\textsf{Arrow(\UU,\UV)}}
for each pair of universes #{\UU, \UV}. We ask for this class to be stable
under equivalence of arrows.}

%```agda
\agda{
infix 30 _вИИбµГ_

_вИИбµГ_ : вИА {рЭУ§ рЭУ• рЭУ¶} {X : Type рЭУ§}{Y : Type рЭУ•}
       вЖТ (X вЖТ Y) вЖТ Subtype (Arrow рЭУ§ рЭУ•) рЭУ¶ вЖТ Type рЭУ¶
f вИИбµГ рЭУХ = mk-arrow f вИИ рЭУХ

straightening-arrow-map
  : вИА {рЭУ§ рЭУ•} {B : Type рЭУ§} {E : Type рЭУ•} (p : E вЖТ B)
    вЖТ Arrow-equiv (fst: fibre p) p
straightening-arrow-map p .fst .Arrow-ќ†.top = fst вИШ snd
straightening-arrow-map p .fst .Arrow-ќ†.bot = id
straightening-arrow-map p .fst .Arrow-ќ†.comm a = sym (a .snd .snd)
straightening-arrow-map p .snd .fst
  = totalвЙГtotal-fibre p ._вЙГ_.has-is-eqv
straightening-arrow-map p .snd .snd = id-is-equiv

record gClass-maps (ќ± : Level вЖТ Level вЖТ Level) : TypeѕЙ where
  field
    рЭУХ : вИА {рЭУ§ рЭУ•} вЖТ Subtype (Arrow рЭУ§ рЭУ•) (ќ± рЭУ§ рЭУ•)
    stable-equiv
      : вИА {рЭУ§ рЭУ• рЭУ¶ рЭУЬ} {A : Type рЭУ§}{B : Type рЭУ•} {f : A вЖТ B}
          {X : Type рЭУ¶} {Y : Type рЭУЬ} {g : X вЖТ Y}
        вЖТ (F : Arrow-map f g)
        вЖТ is-Arrow-equiv F
        вЖТ f вИИбµГ рЭУХ
        вЖТ g вИИбµГ рЭУХ

  рЭУХ-fam : вИА {рЭУ§ рЭУ•} {X : Type рЭУ§} вЖТ Subtype (X вЖТ Type рЭУ•) (ќ± (рЭУ§ вКФ рЭУ•) рЭУ§)
  рЭУХ-fam .Subtype.family P = (fst: P) вИИбµГ рЭУХ
  рЭУХ-fam .Subtype.has-is-subtype P = вИИ-is-prop рЭУХ (mk-arrow (fst: P))

  рЭУХвЖРрЭУХ-fam : вИА {рЭУ§ рЭУ•} {A : Type рЭУ§} {E : Type рЭУ•} (p : E вЖТ A)
            вЖТ fibre p вИИ рЭУХ-fam вЖТ p вИИбµГ рЭУХ
  рЭУХвЖРрЭУХ-fam p fibвИИрЭУХ
    = stable-equiv
        (straightening-arrow-map p .fst)
        (straightening-arrow-map p .snd)
        fibвИИрЭУХ
}
%```
}

\subtree[tot-00AO]{
\title{Relative notions of fibrancy}
\taxon{Definition}

\p{Fixing a type #{I}, and given #{\mathcal{F}} a family of predicates over
families of types #{A \to \UU}, we say that #{\mathcal{F}} is #{I}-relative for
some type #{I} if #{P} is fibrant iff for any map #{x : I \to A}, #{P \circ x}
is fibrant. If #{\mathcal{F}} is #{1}-relative, then we call it a fibrewise
condition.
}

%```agda
\agda{
pullback-arrow : вИА {рЭУ§ рЭУ• рЭУ¶} {A : Type рЭУ§} {B : Type рЭУ•} {E : Type рЭУ¶}
                 вЖТ (f : A вЖТ B) вЖТ (p : E вЖТ B) вЖТ (Pullback f p вЖТ A)
pullback-arrow f p = pb.ѕАвВБ

pullback-arrow-map
  : вИА {рЭУ§ рЭУ• рЭУ¶} {A : Type рЭУ§} {B : Type рЭУ•} {E : Type рЭУ¶}
    вЖТ (f : A вЖТ B) вЖТ (p : E вЖТ B)
    вЖТ Arrow-map (pullback-arrow f p) p
pullback-arrow-map f p .Arrow-ќ†.top = pb.ѕАвВВ
pullback-arrow-map f p .Arrow-ќ†.bot = f
pullback-arrow-map f p .Arrow-ќ†.comm = pb.filler

pullback-arrow-map-is-cartesian
  : вИА {рЭУ§ рЭУ• рЭУ¶} {A : Type рЭУ§} {B : Type рЭУ•} {E : Type рЭУ¶}
    вЖТ (f : A вЖТ B) вЖТ (p : E вЖТ B)
    вЖТ is-cartesian (pullback-arrow-map f p)
pullback-arrow-map-is-cartesian f p
  = is-cartesianвЖРis-pullback _ pullback-is-pullback

pullback-arrow-вИШ
  : вИА {рЭУ§ рЭУ• рЭУ¶ рЭУЬ} {A : Type рЭУ§} {B : Type рЭУ•} {C : Type рЭУ¶} {E : Type рЭУЬ}
      (g : B вЖТ C) (f : A вЖТ B) (p : E вЖТ C)
    вЖТ Arrow-equiv (pullback-arrow f (pullback-arrow g p)) (pullback-arrow (g вИШ f) p)
pullback-arrow-вИШ g f p = ( mk-amap (gap-mapвЖРsquare lem) id ~refl
                         , gap-is-equivвЖРis-cartesian lem lem-is-cart
                         , id-is-equiv) where
  lem : Arrow-map (pullback-arrow f (pullback-arrow g p)) p
  lem = paste-squares (pullback-arrow-map g p)
                      (pullback-arrow-map f (pullback-arrow g p))

  lem-is-cart : is-cartesian lem
  lem-is-cart = compose-cartesian
                  (pullback-arrow-map-is-cartesian g p)
                  (pullback-arrow-map-is-cartesian f (pullback-arrow g p))

is-relative : вИА {рЭУШ} {ќ± : Level вЖТ Level вЖТ Level}
              вЖТ Type рЭУШ
              вЖТ gClass-maps ќ±
              вЖТ TypeѕЙ
is-relative I is-fib
  = вИА {рЭУ§ рЭУ•} {B : Type рЭУ§} {E : Type рЭУ•} (p : E вЖТ B)
    вЖТ (p вИИбµГ рЭУХ вЗФ (вИА (x : I вЖТ B) вЖТ pullback-arrow x p вИИбµГ рЭУХ)) where
    open gClass-maps is-fib
}
%```
}

\subtree[tot-00BB]{
\taxon{Theorem}
\title{Relative fibrations are pullback stable}

\p{Any notion of fibration which is relative is pullback stable.}

%```agda
\agda{
is-pullback-stable : вИА {ќ± : Level вЖТ Level вЖТ Level}
                     вЖТ gClass-maps ќ±
                     вЖТ TypeѕЙ
is-pullback-stable is-fib
  = вИА {рЭУ§ рЭУ§' рЭУ•} {A : Type рЭУ§} {B : Type рЭУ§'} {E : Type рЭУ•} (ѕГ : A вЖТ B) (p : E вЖТ B)
    вЖТ p вИИбµГ рЭУХ вЖТ pullback-arrow ѕГ p вИИбµГ рЭУХ where
    open gClass-maps is-fib

opaque
  is-pullback-stableвЖРis-relative
    : вИА {ќ± : Level вЖТ Level вЖТ Level} {рЭУШ}
      вЖТ (I : Type рЭУШ)
      вЖТ (P : gClass-maps ќ±)
      вЖТ is-relative I P вЖТ is-pullback-stable P
  is-pullback-stableвЖРis-relative I is-fib rel ѕГ p fib
    = rel (pullback-arrow ѕГ p) .snd ќї
        x вЖТ is-fib .gClass-maps.stable-equiv
              (inv-Arrow-equiv (pullback-arrow-вИШ ѕГ x p) .fst)
              (inv-Arrow-equiv (pullback-arrow-вИШ ѕГ x p) .snd)
              (rel p .fst fib (ѕГ вИШ x))
}
%```
}


%```agda
\agda{
record is-universal {ќ± : Level вЖТ Level вЖТ Level}
      {рЭУ§ рЭУ•} {UвИЩ : Type рЭУ§} {U : Type рЭУ•}
      (ѕА : UвИЩ вЖТ U)
      (class : gClass-maps ќ±) : TypeѕЙ where
  open gClass-maps class
  field
    univ-is-fib : ѕА вИИбµГ рЭУХ
    classifies : вИА {рЭУ§ рЭУ•} {X : Type рЭУ§}{Y : Type рЭУ•} {f : X вЖТ Y} вЖТ f вИИбµГ рЭУХ
                 вЖТ is-singleton (ќ£ (Arrow-map f ѕА) is-cartesian)

  arrow-map : вИА {рЭУ§ рЭУ•} {X : Type рЭУ§}{Y : Type рЭУ•} {f : X вЖТ Y} вЖТ f вИИбµГ рЭУХ
              вЖТ Arrow-map f ѕА
  arrow-map ff = classifies ff .centre .fst

  arrow-map-is-cartesian
    : вИА {рЭУ§ рЭУ•} {X : Type рЭУ§}{Y : Type рЭУ•} {f : X вЖТ Y} вЖТ (ff : f вИИбµГ рЭУХ)
      вЖТ is-cartesian (arrow-map ff)
  arrow-map-is-cartesian ff = classifies ff .centre .snd

TypeвИЩ : вИА рЭУ§ вЖТ Type (lsuc рЭУ§)
TypeвИЩ рЭУ§ = ќ£[ A вИґ Type рЭУ§ ] A

TypeвИЩ-fam : вИА рЭУ§ вЖТ Fam (lsuc рЭУ§) рЭУ§
TypeвИЩ-fam рЭУ§ = (Type рЭУ§ , id)

Type-ѕА : вИА рЭУ§ вЖТ TypeвИЩ рЭУ§ вЖТ Type рЭУ§
Type-ѕА рЭУ§ = arrowвЖРFam (TypeвИЩ-fam рЭУ§)

fibre-Type-ѕА : вИА {рЭУ§} b вЖТ fibre (Type-ѕА рЭУ§) b вЙГ b
fibre-Type-ѕА b = fibre-straighten id b


small-gClass : вИА рЭУ§ вЖТ gClass-maps (ќї рЭУ• рЭУ¶ вЖТ lsuc рЭУ§ вКФ рЭУ• вКФ рЭУ¶)
small-gClass рЭУ§ .gClass-maps.рЭУХ .Subtype.family f
  = is-small-map рЭУ§ (f .Arrow.f)
small-gClass рЭУ§ .gClass-maps.рЭУХ .Subtype.has-is-subtype _
  = is-prop-ќ† (ќї _ вЖТ is-small-is-prop)
small-gClass рЭУ§ .gClass-maps.stable-equiv F Fe fsmall y
  = is-smallвЖРequiv (mkвЙГ _ (inverse-is-cartesianвЖРis-equiv F Fe y) eвБї¬є)
                   (fsmall (is-equiv.bwd (Fe .snd) y))

Small : вИА рЭУ§ {рЭУ• рЭУ¶} вЖТ Subtype (Arrow рЭУ• рЭУ¶) (lsuc рЭУ§ вКФ рЭУ• вКФ рЭУ¶)
Small рЭУ§ = small-gClass рЭУ§ .gClass-maps.рЭУХ

postcomp-вЙГ-is-equiv
  : вИА {рЭУ§ рЭУ• рЭУ¶} {A : Type рЭУ§} {B : Type рЭУ•} {C : Type рЭУ¶}
    вЖТ (e : B вЙГ C) вЖТ is-equiv (ќї (p : A вЙГ B) вЖТ p вИЩвЙГ e)
postcomp-вЙГ-is-equiv e = is-equivвЖРqiso
  (_вИЩвЙГ e eвБї¬є
  , (ќї a вЖТ ext! (ќї x вЖТ _вЙГ_.ќЈ e (_вЙГ_.fwd a x)))
  , ќї b вЖТ ext! (ќї a вЖТ _вЙГ_.ќµ e (_вЙГ_.fwd b a)))


postcomp-вЙГбґ†-is-equiv
  : вИА {рЭУ§ рЭУ• рЭУ¶ рЭУЬ рЭУ¶' рЭУЬ'} {F : Fam рЭУ§ рЭУ•} {G : Fam рЭУ¶ рЭУЬ} {H : Fam рЭУ¶' рЭУЬ'}
    вЖТ (e : G вЙГбґ† H)
    вЖТ is-equiv (postcomp-вЙГбґ† {F = F}{H = H} e)
postcomp-вЙГбґ†-is-equiv (e , b)
  = map-ќ£-is-equiv (postcomp-equiv (e ._вЙГ_.has-is-eqv))
                   ќї a вЖТ postcomp-ќ†-equiv
                           (ќї {i} вЖТ postcomp-вЙГ-is-equiv (b (a i)))

postcomp-вЙГбґ†-equiv
  : вИА {рЭУ§ рЭУ• рЭУ¶ рЭУЬ рЭУ¶' рЭУЬ'} {F : Fam рЭУ§ рЭУ•} {G : Fam рЭУ¶ рЭУЬ} {H : Fam рЭУ¶' рЭУЬ'}
    вЖТ (e : G вЙГбґ† H)
    вЖТ Cart-fam-map F G вЙГ Cart-fam-map F H
postcomp-вЙГбґ†-equiv {F = F} {H = H} e
  = mkвЙГ _ (postcomp-вЙГбґ†-is-equiv {H = H} e)

char-cart-typeвИЩ
  : вИА {рЭУ§ рЭУ• рЭУЬ} {X : Type рЭУ§}{Y : Type рЭУ•} {f : X вЖТ Y}
    вЖТ (ќ£ (Arrow-map f (Type-ѕА рЭУЬ)) is-cartesian) вЙГ is-small-map рЭУЬ f
char-cart-typeвИЩ {рЭУЬ = рЭУЬ} {f = f}
  =    ќ£ (Arrow-map f (Type-ѕА рЭУЬ)) is-cartesian
  вЙГвЯ® Cart-fam-mapвЙГcart-arrow-map вЯ©
       Cart-fam-map (fibre-fam f) (fibre-fam (Type-ѕА рЭУЬ))
  вЙГвЯ® postcomp-вЙГбґ†-equiv {H = TypeвИЩ-fam рЭУЬ}
                       (fibre-fam-arrowвЖРFamвЙГбґ† (TypeвИЩ-fam рЭУЬ) ) вЯ©
       Cart-fam-map (fibre-fam f) (TypeвИЩ-fam рЭУЬ)
  вЙГвЯ® ќ£-ќ†-swapвЙГ _ _ eвБї¬є вЯ©
       (вИА a вЖТ is-small рЭУЬ (fibre f a)) вЙГвИО

opaque
  Type-is-universal-small-map
    : вИА {рЭУ§} вЖТ is-universal (Type-ѕА рЭУ§) (small-gClass рЭУ§)
  Type-is-universal-small-map .is-universal.univ-is-fib A
    = (A , remove-singleton-structure Sing'-is-singleton (_ , refl))
  Type-is-universal-small-map .is-universal.classifies {f = f} fsm
    = is-singleвЖРequiv-to-single
        (char-cart-typeвИЩ eвБї¬є)
        (mk-singl fsm (is-prop-ќ† (ќї a вЖТ is-small-is-prop) _))

module Type-is-universal {рЭУ§}
  = is-universal (Type-is-universal-small-map {рЭУ§})

Lift
  : вИА {рЭУ§ рЭУ• рЭУ¶} {ќУ : Type рЭУ§} {E : Type рЭУ•} {B : Type рЭУ¶}
      (p : E вЖТ B) (A : ќУ вЖТ B)
    вЖТ Type (рЭУ§ вКФ рЭУ• вКФ рЭУ¶)
Lift p A = fibre (postcomp _ p) A

LiftвЖРarrow-map
  : вИА {рЭУ§ рЭУ• рЭУ¶ рЭУЬ рЭУЭ} {A : Type рЭУ§} {B : Type рЭУ•} {f : A вЖТ B}
      {X : Type рЭУ¶} {Y : Type рЭУЬ} {g : X вЖТ Y}
      (F : Arrow-map f g)
    вЖТ {ќУ : Type рЭУЭ} (A : ќУ вЖТ B)
    вЖТ Lift f A
    вЖТ Lift g (F .Arrow-map.bot вИШ A)
LiftвЖРarrow-map F A = arrow-fibre (postcomp-square F _) A

section-typeвИЩ : вИА {рЭУ§ рЭУ• рЭУ¶} {ќУ : Type рЭУ§} (A : ќУ вЖТ Type (рЭУ• вКФ рЭУ¶))
                вЖТ Lift (Type-ѕА _) A вЖТ ќ† ќУ A
section-typeвИЩ A = is-equiv.bwd (extensionвЖРќ†-is-equiv A)

universal-section
  : вИА {рЭУ§ рЭУ• рЭУ¶ рЭУЬ} {ќУ : Type рЭУ§} {E : Type рЭУ•} {B : Type рЭУ¶} {p : E вЖТ B}
      (A : ќУ вЖТ B)
    вЖТ (ff : p вИИбµГ Small рЭУЬ)
    вЖТ Lift p A
    вЖТ ќ† ќУ (is-universal.arrow-map Type-is-universal-small-map ff .Arrow-ќ†.bot вИШ A)
universal-section {рЭУ§} {рЭУ•} {рЭУ¶} {рЭУЬ} {p  = p} A fsm
  = section-typeвИЩ {рЭУ• = рЭУЬ} {рЭУЬ}
      (Arrow-ќ†.bot (is-universal.arrow-map Type-is-universal-small-map fsm) вИШ A)
  вИШ LiftвЖРarrow-map {f = p}{g = Type-ѕА рЭУЬ}
                   (is-universal.arrow-map Type-is-universal-small-map fsm) A

universal-section-is-equiv
  : вИА {рЭУ§ рЭУ• рЭУ¶ рЭУЬ} {ќУ : Type рЭУ§} {E : Type рЭУ•} {B : Type рЭУ¶} {p : E вЖТ B}
      (A : ќУ вЖТ B)
    вЖТ (ff : p вИИбµГ Small рЭУЬ)
    вЖТ is-equiv (universal-section A ff)
universal-section-is-equiv A fsm
  = is-equiv-вИШ
      (is-equivвБї¬є (extensionвЖРќ†-is-equiv _))
      (postcomp-cartesian (Type-is-universal.arrow-map fsm)
          (is-universal.arrow-map-is-cartesian Type-is-universal-small-map fsm)
          A)
}
%```


\subtree{
\title{Subuniversal fibrations}
\taxon{construction}

\p{If #{\mathcal{F}} is a fibrewise relative class of maps, then we can
construct a universal fibration.}

\remark{This is a shadow of a more general fact that any class of maps which
is relative with respect to a \em{tiny} type has a universal fibration.}

%```agda
\agda{
!-map : вИА {рЭУ§ рЭУ•} {A : Type рЭУ§} {B : Type рЭУ•} вЖТ (A вЖТ B) вЖТ Arrow-map (!: A) (!: B)
!-map f .Arrow-ќ†.top = f
!-map f .Arrow-ќ†.bot = id
!-map f .Arrow-ќ†.comm = ~refl

!-map-is-equiv
  : вИА {рЭУ§ рЭУ•} {A : Type рЭУ§} {B : Type рЭУ•} {f : A вЖТ B}
    вЖТ is-equiv f вЖТ is-Arrow-equiv (!-map f)
!-map-is-equiv fe = (fe , id-is-equiv)

module _ where
  open gClass-maps
  and-small-gClass
    : вИА {ќ± : Level вЖТ Level вЖТ Level} рЭУ§ вЖТ gClass-maps ќ±
      вЖТ gClass-maps ќї рЭУ• рЭУ¶ вЖТ ќ± рЭУ• рЭУ¶ вКФ (lsuc рЭУ§ вКФ рЭУ• вКФ рЭУ¶)
  and-small-gClass рЭУ• F .рЭУХ .Subtype.family f = f вИИ Small рЭУ• √Ч f вИИ F .рЭУХ
  and-small-gClass рЭУ• F .рЭУХ .Subtype.has-is-subtype x
    = is-prop-ќ£ (вИИ-is-prop (Small рЭУ•) x) ќї _ вЖТ вИИ-is-prop (F .рЭУХ) x
  and-small-gClass рЭУ• F .stable-equiv {f = f}{g = g}a ae (fs , ff)
    = (stable-equiv (small-gClass рЭУ•) a ae fs , stable-equiv F a ae ff)

module SubuniversalFibration
         {ќ± : Level вЖТ Level вЖТ Level} (F : gClass-maps ќ±)
         (F-rel : is-relative рЭЯЩ F) where
  open gClass-maps F
  open is-universal

  рЭУХ-gSubU : gSubU (ќї рЭУ§ вЖТ ќ± рЭУ§ lzero)
  рЭУХ-gSubU .gSubU.S .Subtype.family A = (!: A) вИИбµГ рЭУХ
  рЭУХ-gSubU .gSubU.S .Subtype.has-is-subtype x = вИИ-is-prop рЭУХ (mk-arrow (!: x))
  рЭУХ-gSubU .gSubU.вИИSвЖРequiv e af
    = stable-equiv (!-map _) (!-map-is-equiv (e ._вЙГ_.has-is-eqv)) af

  open gSubU рЭУХ-gSubU using () renaming
    ( S to рЭУХ-ty
    ; вИИSвЖРequiv to рЭУХ-tyвЖРis-equiv
    ; вЙГвИИSвЖРequiv to equiv-рЭУХ-ty)

  U : вИА рЭУ§ вЖТ Type (lsuc рЭУ§ вКФ ќ± рЭУ§ lzero)
  U рЭУ§ = ќ£[ A вИґ Type рЭУ§ ] (!: A)  вИИбµГ рЭУХ

  UвИЩ : вИА рЭУ§ вЖТ Type (lsuc рЭУ§ вКФ ќ± рЭУ§ lzero)
  UвИЩ рЭУ§ = ќ£[ A вИґ TypeвИЩ рЭУ§ ] (A .fst) вИИ рЭУХ-ty

  UвИЩ-repr : вИА {рЭУ§} вЖТ UвИЩ рЭУ§ вЙГ ќ£ (U рЭУ§) (fst)
  UвИЩ-repr = ќ£-assoc вИЩвЙГ (ќ£-ap-вЙГ (ќї A вЖТ √Ч-swap) вИЩвЙГ ќ£-assoc eвБї¬є)

  U-ѕА : вИА рЭУ§ вЖТ UвИЩ рЭУ§ вЖТ U рЭУ§
  U-ѕА _ = total-map-fst fst

  UвИЩ-fam : вИА рЭУ§ вЖТ Fam (ќ± рЭУ§ lzero вКФ lsuc рЭУ§) рЭУ§
  UвИЩ-fam рЭУ§ = (U рЭУ§ , fst)

  straighten-U-ѕА : вИА {рЭУ§} вЖТ fibre-fam (U-ѕА рЭУ§) вЙГбґ† UвИЩ-fam рЭУ§
  straighten-U-ѕА {рЭУ§}
    = concatвЙГбґ† (UвИЩ-fam рЭУ§)
       (idequiv , lemma)
       (fibre-fam-arrowвЖРFamвЙГбґ† (UвИЩ-fam рЭУ§)) where
    lemma : (a : ќ£ (Type рЭУ§) (ќї A вЖТ A вИИ рЭУХ-ty)) вЖТ
             fibre-fam (U-ѕА рЭУ§) .snd a вЙГ
             fibre-fam (arrowвЖРFam (UвИЩ-fam рЭУ§)) .snd (_вЙГ_.fwd idequiv a)
    lemma (A , Af)
      = (ќ£[ B вИґ UвИЩ рЭУ§ ] (U-ѕА рЭУ§ B пЉЭ (A , Af)))
      вЙГвЯ® (ќ£-ap-вЙГ-fst {B = ќї B вЖТ U-ѕА рЭУ§ B пЉЭ (A , Af)} (UвИЩ-repr eвБї¬є)) eвБї¬є вЯ©
        (ќ£[ B вИґ ќ£ (U рЭУ§) fst ] (fst B пЉЭ (A , Af)))
      вЙГвИО

  fibre-U-ѕА : вИА {рЭУ§} b вЖТ fibre (U-ѕА рЭУ§) b вЙГ b .fst
  fibre-U-ѕА b = fibre-total-map-fst _ (b .fst) (b .snd) вИЩвЙГ fibre-Type-ѕА (b .fst)

  U-ѕА-is-small : вИА {рЭУ§} вЖТ is-small-map рЭУ§ (U-ѕА рЭУ§)
  U-ѕА-is-small b = (b .fst , fibre-U-ѕА b)

  test-fibres : вИА {рЭУ§ рЭУ•}{A : Type рЭУ§}{B : Type рЭУ•} (f : A вЖТ B)
               вЖТ (f вИИбµГ рЭУХ) вЗФ (вИА x вЖТ (fibre f x) вИИ рЭУХ-ty)
  test-fibres f .fst ff b = рЭУХ-tyвЖРis-equiv (pullback-pointвЙГfibre f b)
                                          (F-rel f .fst ff (point b))
  test-fibres f .snd ff
    = F-rel f .snd ќї x вЖТ рЭУХ-tyвЖРis-equiv
                           (fibreвЙГpullback-point f (x tt))
                           (ff (x tt))

  opaque
    U-ѕА-is-fibrant : вИА {рЭУ§} вЖТ U-ѕА рЭУ§ вИИбµГ рЭУХ
    U-ѕА-is-fibrant = F-rel (U-ѕА _) .snd ќї
      x вЖТ рЭУХ-tyвЖРis-equiv
            (fibre-U-ѕА _ eвБї¬є вИЩвЙГ fibreвЙГpullback-point _ _)
            (x tt .snd)

  is-small-fibration : вИА {рЭУ§ рЭУ•} {A : Type рЭУ§} {B : Type рЭУ•} рЭУ¶ вЖТ (A вЖТ B)
                       вЖТ Type (ќ± рЭУ§ рЭУ• вКФ рЭУ§ вКФ рЭУ• вКФ lsuc рЭУ¶)
  is-small-fibration рЭУ¶ p = p вИИбµГ and-small-gClass рЭУ¶ F .gClass-maps.рЭУХ


  char-cart-UвИЩ
    : вИА {рЭУ§ рЭУ• рЭУЬ} {X : Type рЭУ§}{Y : Type рЭУ•} {f : X вЖТ Y}
      вЖТ (ќ£ (Arrow-map f (U-ѕА рЭУЬ)) is-cartesian) вЙГ (is-small-fibration рЭУЬ f)
  char-cart-UвИЩ {рЭУЬ = рЭУЬ} {f = f}
    =    ќ£ (Arrow-map f (U-ѕА рЭУЬ)) is-cartesian
    вЙГвЯ® Cart-fam-mapвЙГcart-arrow-map вЯ©
         Cart-fam-map (fibre-fam f) (fibre-fam (U-ѕА рЭУЬ))
    вЙГвЯ® postcomp-вЙГбґ†-equiv {H = UвИЩ-fam рЭУЬ} straighten-U-ѕА вЯ©
         Cart-fam-map (fibre-fam f) (UвИЩ-fam рЭУЬ)
    вЙГвЯ® ќ£-ќ†-swapвЙГ _ _ eвБї¬є вЯ©
         (вИА y вЖТ ќ£[ A вИґ (ќ£[ A вИґ Type рЭУЬ ] (!: A) вИИбµГ рЭУХ)]
                   (fibre f y вЙГ A .fst))
    вЙГвЯ® postcomp-ќ†-вЙГ (ќї y вЖТ ќ£-assoc вИЩвЙГ (ќ£-ap-вЙГ
      (ќї A вЖТ √Ч-swap вИЩвЙГ ќ£-ap-вЙГ (ќї e вЖТ equiv-рЭУХ-ty (e eвБї¬є))) вИЩвЙГ ќ£-assoc eвБї¬є)) вЯ©
         (вИА y вЖТ is-small рЭУЬ (fibre f y) √Ч (fibre f y) вИИ рЭУХ-ty)
    вЙГвЯ® ќ£-ќ†-swapвЙГ _ _ вЯ©
         is-small-map рЭУЬ f √Ч (вИА y вЖТ (!: fibre f y) вИИбµГ рЭУХ)
    вЙГвЯ® (idequiv √ЧвЙГ equivвЖРlogical (is-prop-ќ† (ќї _ вЖТ вИИ-is-prop рЭУХ _))
                                 (вИИ-is-prop рЭУХ _) (test-fibres f вЗФвБї¬є)) вЯ©
         is-small-fibration рЭУЬ f вЙГвИО

  UFib-classifies : вИА {рЭУ§} вЖТ is-universal (U-ѕА рЭУ§) (and-small-gClass рЭУ§ F)
  UFib-classifies .univ-is-fib = (U-ѕА-is-small , U-ѕА-is-fibrant)
  UFib-classifies .classifies {f = f} ff
    = is-singleвЖРequiv-to-single
        (char-cart-UвИЩ eвБї¬є)
        (mk-singl ff (вИИ-is-prop (and-small-gClass _ F .gClass-maps.рЭУХ) _ ff))
}

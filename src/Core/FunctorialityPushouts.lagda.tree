\title{Pushouts are functorial over the span diagram}
\author{samueltoth}
\date{2025-11-20}
\taxon{Module}
\import{stt-macros}

\agda{
module Core.FunctorialityPushouts where

open import Axioms.UF
open import Foundations.Prelude
open import Core.CanonicalPushouts
open import Core.SpanMaps
open import Core.Postwhisker
}


\subtree[stt-00B1]{
\title{Span maps induce functors of pushouts}
\taxon{Theorem}

\agda{
Cocone₁
  : ∀ {𝓤 𝓥 𝓦 𝓤' 𝓥' 𝓦' 𝓛}
      {S : Span 𝓤 𝓥 𝓦} {S' : Span 𝓤' 𝓥' 𝓦'}
    → let module S = Span S; module S' = Span S'
      in (F : Span-map S S')
      → {P' : Type 𝓛} (Pc' : Cocone S' P')
      → Cocone S P'
Cocone₁ F Pc'
  = mk-cocone (Pc'.p ∘ F.h₁) (Pc'.q ∘ F.h₃)
              (  Pc'.p ◂ F.H
              ∙h Pc'.filler ▸ F.h₂
              ∙h Pc'.q ◂ (F.K h⁻¹)) where
  module Pc' = Cocone Pc'
  module F = Span-map F

Pushout-map←span-map : ∀ {𝓤 𝓥 𝓦 𝓤' 𝓥' 𝓦' 𝓜 𝓛}
                {S : Span 𝓤 𝓥 𝓦} {S' : Span 𝓤' 𝓥' 𝓦'}
              → let module S = Span S; module S' = Span S'
                in (F : Span-map S S')
                → {P : Type 𝓜} (Pc : Cocone S P)
                  (Po : up-pushout S Pc)
                  {P' : Type 𝓛} (Pc' : Cocone S' P')
                → P → P'
Pushout-map←span-map F pcc po pcc'
  = is-equiv.bwd po (Cocone₁ F pcc')

Pushout-map-id
  : ∀ {𝓤 𝓥 𝓦 𝓜} {S : Span 𝓤 𝓥 𝓦} {P : Type 𝓜} {Pc : Cocone S P}
      (Po : up-pushout S Pc)
    → Pushout-map←span-map id-span-map Pc Po (Cocone₁ id-span-map Pc)
    ＝ id
Pushout-map-id po
  = ap (is-equiv.bwd po) (ap (mk-cocone _ _)
                         (funext→ (λ a → ∙-reflr _ ∙ ∙-reflr _ ∙ sym (ap-id _))))
  ∙ is-equiv.η po id

Pushout₀ : ∀ {𝓤 𝓥 𝓦} → Span 𝓤 𝓥 𝓦 → Type (𝓤 ⊔ 𝓥 ⊔ 𝓦)
Pushout₀ S = Pushout (Span.left S) (Span.right S)

Pushout₁
  : ∀ {𝓤 𝓥 𝓦 𝓤' 𝓥' 𝓦'}
      {S : Span 𝓤 𝓥 𝓦} {S' : Span 𝓤' 𝓥' 𝓦'}
      (F : Span-map S S')
    → Pushout₀ S → Pushout₀ S'
Pushout₁ F = cogap (Cocone₁ F pushout)

Pushout-id
  : ∀ {𝓤 𝓥 𝓦} {S : Span 𝓤 𝓥 𝓦}
    → id ~ Pushout₁ (id-span-map {S = S})
Pushout-id
  = pushout-rec-unique _ _ ~refl ~refl λ a → ap (_∙ refl) (ap-id (glue a))

Pushout-∘
  : ∀ {𝓤 𝓥 𝓦 𝓤' 𝓥' 𝓦' 𝓤'' 𝓥'' 𝓦''}
      {S : Span 𝓤 𝓥 𝓦} {S' : Span 𝓤' 𝓥' 𝓦'} {S'' : Span 𝓤'' 𝓥'' 𝓦''}
      (F : Span-map S' S'') (G : Span-map S S')
    → Pushout₁ F ∘ Pushout₁ G
    ~ Pushout₁ (compose-span-map F G)
Pushout-∘ {S = S} F G
  = pushout-rec-unique
          (Cocone₁ (compose-span-map F G) pushout)
          (Pushout₁ F ∘ Pushout₁ G)
          ~refl
          ~refl
          (∙h-reflr _
          ∙h (ap-∘ (Pushout₁ F) (Pushout₁ G) ∘ glue)
          ∙h (λ x → ap (ap (Pushout₁ F)) (pushout-rec-apβ x))
          ∙h λ x → ap-∙∙ (Pushout₁ F)
                         (ap ι₁ (G.H x)) (glue (G.h₂ x)) (ap ι₂ (sym (G.K x)))
                  ∙   ap₃ (λ x y z → x ∙ y ∙ z)
                         (sym (ap-∘ (Pushout₁ F) ι₁ (G.H x)))
                         (pushout-rec-apβ (G.h₂ x))
                         (sym (ap-∘ (Pushout₁ F) ι₂ (sym (G.K x))))
                  ∙ lem) where
    module F = Span-map F
    module G = Span-map G
    lem : {x : G.S.Centre} →
      ap (λ a → ι₁ (F.h₁ a)) (G.H x) ∙
      (ap ι₁ (F.H (G.h₂ x)) ∙
       glue (F.h₂ (G.h₂ x)) ∙ ap ι₂ (sym (F.K (G.h₂ x))))
      ∙ ap (λ a → ι₂ (F.h₃ a)) (sym (G.K x))
      ＝
      ap ι₁ (ap F.h₁ (G.H x) ∙ F.H (G.h₂ x)) ∙
      glue (F.h₂ (G.h₂ x)) ∙ ap ι₂ (sym (ap F.h₃ (G.K x) ∙ F.K (G.h₂ x)))
    lem {x}
      = ap (ι₁ ∘ F.h₁) (G.H x) ∙
         (ap ι₁ (F.H (G.h₂ x)) ∙
          glue (F.h₂ (G.h₂ x)) ∙ ap ι₂ (sym (F.K (G.h₂ x))))
         ∙ ap (ι₂ ∘ F.h₃) (sym (G.K x))

          ＝⟨ ap₂ _∙_ (ap-∘ ι₁ F.h₁ (G.H x))
                     (∙-assoc (ap ι₁ (F.H (G.h₂ x)))
                              (glue (F.h₂ (G.h₂ x)) ∙ ap ι₂ (sym (F.K (G.h₂ x))))
                              (ap (ι₂ ∘ F.h₃) (sym (G.K x)))) ⟩
        ap ι₁ (ap F.h₁ (G.H x)) ∙
         ap ι₁ (F.H (G.h₂ x)) ∙
         (glue (F.h₂ (G.h₂ x)) ∙ ap ι₂ (sym (F.K (G.h₂ x)))) ∙
         ap (ι₂ ∘ F.h₃) (sym (G.K x))

         ＝⟨ sym (∙-assoc (ap ι₁ (ap F.h₁ (G.H x))) (ap ι₁ (F.H (G.h₂ x))) _)
             ∙ ap (_∙ _) (sym (ap-∙ ι₁ (ap F.h₁ (G.H x)) (F.H (G.h₂ x)))) ⟩

        ap ι₁ (ap F.h₁ (G.H x) ∙ F.H (G.h₂ x)) ∙
         (glue (F.h₂ (G.h₂ x)) ∙ ap ι₂ (sym (F.K (G.h₂ x)))) ∙
         ap (ι₂ ∘ F.h₃) (sym (G.K x))

         ＝⟨ ap (ap ι₁ (ap F.h₁ (G.H x) ∙ F.H (G.h₂ x)) ∙_)
              (∙-assoc (glue (F.h₂ (G.h₂ x))) _ _
              ∙ ap (glue (F.h₂ (G.h₂ x)) ∙_)
                   (ap (ap ι₂ _ ∙_) (ap-∘ ι₂ F.h₃ (sym (G.K x))
                                    ∙ ap (ap ι₂) (ap-sym F.h₃ (G.K x)))
                   ∙ sym (ap-∙ ι₂ (sym (F.K (G.h₂ x))) _)
                   ∙ ap (ap ι₂) ( sym (∙-symsym (ap F.h₃ (G.K x)) (F.K (G.h₂ x)))))) ⟩

        ap ι₁ (ap F.h₁ (G.H x) ∙ F.H (G.h₂ x)) ∙
         glue (F.h₂ (G.h₂ x)) ∙ ap ι₂ (sym (ap F.h₃ (G.K _) ∙ F.K (G.h₂ _))) ∎

Pushout-qinv
  : ∀ {𝓤 𝓥 𝓦 𝓤' 𝓥' 𝓦'} {S : Span 𝓤 𝓥 𝓦} {S' : Span 𝓤' 𝓥' 𝓦'}
      (F : Span-map S S')
    → Span-quasi-inv F
    → quasi-inv (Pushout₁ F)
Pushout-qinv F x .fst = Pushout₁ (x .Span-quasi-inv.bwd)
Pushout-qinv F x .snd .fst
  = Pushout-∘ (x .Span-quasi-inv.bwd) F
  ∙h happly (ap Pushout₁ (Span-map-funext→ (x .Span-quasi-inv.η)))
  ∙h (Pushout-id h⁻¹)
Pushout-qinv F x .snd .snd
  = Pushout-∘ F (x .Span-quasi-inv.bwd)
  ∙h happly (ap Pushout₁ (Span-map-funext→ (x .Span-quasi-inv.ε)))
  ∙h (Pushout-id h⁻¹)

Pushout-equiv←logical
  : ∀ {𝓤 𝓥 𝓦 𝓤' 𝓥' 𝓦'} {S : Span 𝓤 𝓥 𝓦} {S' : Span 𝓤' 𝓥' 𝓦'}
    → is-prop-span S → is-prop-span S'
    → Span-logical-equiv S S'
    → Pushout₀ S
    ≃ Pushout₀ S'
Pushout-equiv←logical sp s'p le
  = mk≃ (Pushout₁ fwd)
        (is-equiv←qinv (Pushout-qinv fwd fwd-qinv)) where
  open Span-logical-equiv sp s'p le
}
}

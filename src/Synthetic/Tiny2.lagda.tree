  --       (вҲҡбөҲ-is-singleton (modвҷӯ (О» a вҶ’ Sing-is-singleton {a = вҲҡОө a}))))
  --      -- ({!вҷӯ-map (postcomp-О  ?)!}
  --      -- (Оөвҷӯ (вҲҡбөҲ-is-singleton (modвҷӯ (О» _ вҶ’ Sing-is-singleton)))))

  is-afib : вҲҖ {@вҷӯ рқ“Ө} вҶ’ Type рқ“Ө вҶ’ Type (lsuc (Оұ рқ“ҳ рқ“Ө))
  is-afib = вҲҡбөҲ is-fib

  is-afib-is-prop : вҲҖ {@вҷӯ рқ“Ө} {A : Type рқ“Ө} вҶ’ is-prop (is-afib A)
  is-afib-is-prop = {!!}

  record UFib (@вҷӯ рқ“Ө) : Type (lsuc (Оұ рқ“ҳ рқ“Ө вҠ” рқ“Ө)) where
    constructor mk-ufib
    field
      Car : Type рқ“Ө
      has-is-afib : is-afib Car

  UFibвҲҷ : вҲҖ (@вҷӯ рқ“Ө) вҶ’ Type (lsuc (Оұ рқ“ҳ рқ“Ө вҠ” рқ“Ө))
  UFibвҲҷ рқ“Ө = ОЈ (UFib рқ“Ө) UFib.Car

  UFib-ПҖ : вҲҖ {@вҷӯ рқ“Ө} вҶ’ UFibвҲҷ рқ“Ө вҶ’ UFib рқ“Ө
  UFib-ПҖ = fst

  UFib-ПҖ-is-fib : вҲҖ {@вҷӯ рқ“Ө} вҶ’ is-fib (UFib.Car {рқ“Ө})
  UFib-ПҖ-is-fib = rel-fib _ .snd
    (Оөвҷӯ (relim (modвҷӯ (О» a вҶ’ вҲҡбөҲ-naturalityвҶ’ _ UFib.Car a (a .UFib.has-is-afib)))))

  UFib-is-fib : вҲҖ {@вҷӯ рқ“Ө рқ“Ҙ} {A : Type рқ“Ө} (P : A вҶ’ UFib рқ“Ҙ)
                вҶ’ is-fib (UFib.Car вҲҳ P)
  UFib-is-fib P
    = is-pullback-stableвҶҗis-relative
        I is-fib rel-fib UFib.Car P
        UFib-ПҖ-is-fib

  liftFib : вҲҖ {@вҷӯ рқ“Ө рқ“Ҙ} {@вҷӯ A : Type рқ“Ө} {@вҷӯ P : A вҶ’ Type рқ“Ҙ}
              вҶ’ вҹЁвҷӯ| is-fib P вҹ© вҮ” вҹЁвҷӯ| (вҲҖ a вҶ’ is-afib (P a)) вҹ©
  liftFib {A = A} {P = P} .fst fib
    = вҷӯ-map (postcomp-О  (вҲҡбөҲ-naturalityвҶҗ _ _))
            (rintro (вҷӯ-map (rel-fib P .fst) fib))
  liftFib {A = A} {P = P} .snd
    = вҷӯ-map (UFib-is-fib вҲҳ (О» af a вҶ’ (mk-ufib (P a) (af a))))

  Car-is-emb : вҲҖ {@вҷӯ рқ“Ө} вҶ’ is-prop-map (UFib.Car {рқ“Ө})
  Car-is-emb X = is-propвҶҗequiv-to-prop
    (equivвҶҗqiso
      (mk-iso
       (О» a вҶ’ (mk-ufib X a , refl))
       ( (О» where (a , refl) вҶ’ a .UFib.has-is-afib)
       , ~refl
       , О» where (a , refl) вҶ’ refl)))
    (is-afib-is-prop {A = X})

  instance
    UFib-IdS : вҲҖ {@вҷӯ рқ“Ө} вҶ’ Identity-system (UFib рқ“Ө) рқ“Ө
    UFib-IdS {рқ“Ө} = IdSвҶҗEmbedding {f = UFib.Car} Car-is-emb (IdS-ua {рқ“Ө})
}
%```
}

\taxon{Module}
\import{stt-macros}

\title{The pullback power}

%```agda
\agda{
module Core.PullbackPower where

open import Foundations.Prelude
open import ufAxioms

open import Core.Arrow
open import Core.Lifts
open import Ergonomics.Extensionality
}
%```


\subtree[stt-004D]{
\title{Pullback power}
\taxon{Construction}

\quiver{
\begin{tikzcd}
	A && C \\
	\\
	B && D
	\arrow[dashed, from=1-1, to=1-3]
	\arrow["f"', from=1-1, to=3-1]
	\arrow["g", from=1-3, to=3-3]
	\arrow["l"{description}, from=3-1, to=1-3]
	\arrow[dashed, from=3-1, to=3-3]
\end{tikzcd}
}

\p{Given a pair of arrows as above, any diagonal map
gives rise to a square for which it is trivially a lifting.}

%```agda
\agda{
module _ {ùì§ ùì• ùì¶ ùìú} {A : Type ùì§} {B : Type ùì•}
         {C : Type ùì¶} {D : Type ùìú} (f : A ‚Üí B)
         (f' : C ‚Üí D) where
  pullback-power : (B ‚Üí C) ‚Üí Arrow-map f f'
  pullback-power l .Arrow-map.top = l ‚àò f
  pullback-power l .Arrow-map.bot = f' ‚àò l
  pullback-power l .Arrow-map.comm = ~refl

  pullback-power-lifts : (l : B ‚Üí C) ‚Üí Lift (pullback-power l)
  pullback-power-lifts l .Lift.lift = l
  pullback-power-lifts l .Lift.K = ~refl
  pullback-power-lifts l .Lift.L = ~refl
  pullback-power-lifts l .Lift.pastes = ~refl
}
%```

\p{The pullback power of #{f} with #{g} is sometimes written #{f \pitchfork g}.}
}

\subtree[stt-004C]{
\title{Pullback power is a gap map}
\taxon{Theorem}

\p{The name pullback power comes from the fact that for any pair
of maps, we can define a square as follows:}

\quiver{
\begin{tikzcd}
	{C^B} && {C^A} \\
	\\
	{D^B} && {D^A}
	\arrow["{- \circ f}", from=1-1, to=1-3]
	\arrow["{g \circ -}"', from=1-1, to=3-1]
	\arrow["{g \circ -}", from=1-3, to=3-3]
	\arrow["{- \circ f}"', from=3-1, to=3-3]
\end{tikzcd}
}

\p{Then the gap map of this square is the [pullback power](stt-004D) in the
sense that the following triangle commutes.}

\quiver{
\begin{tikzcd}
	& {B \to C} \\
	\\
	{\Hom(f,g)} && {D^B\times_{D^A}C^A}
	\arrow["{f\pitchfork g}"', from=1-2, to=3-1]
	\arrow["gap", from=1-2, to=3-3]
	\arrow["\sim"', from=3-1, to=3-3]
\end{tikzcd}
}

%```agda
\agda{
module _ {ùì§ ùì• ùì¶ ùìú} {A : Type ùì§} {B : Type ùì•}
         {C : Type ùì¶} {D : Type ùìú} (f : A ‚Üí B)
         (g : C ‚Üí D)  where
  power-hom : Arrow-map (postcomp B g) (postcomp A g)
  power-hom .Arrow-map.top = precomp _ f
  power-hom .Arrow-map.bot = precomp _ f
  power-hom .Arrow-map.comm = ~refl

  pb-power-cone : Cone (mk-cospan (A ‚Üí D) (precomp _ f) (postcomp _ g)) (B ‚Üí C)
  pb-power-cone = snd (Cone‚ÜêArrow-map power-hom)

  pullback-gap~pullback-power :
    gap pb-power-cone ~ pullback‚Üêarrow' ‚àò pullback-power f g
  pullback-gap~pullback-power f
    = pullback-path‚Üí (refl , refl , ‚àô-refll _ ‚àô funext-refl ‚àô sym (‚àô-reflr _))
}
%```
}

\subtree[stt-004L]{
% \title{The pullback power is an equiv  is a pullback}
\taxon{Corollary}

\p{For a pair of maps #{f} and #{g}, the following are equivalent:}
\ol{
\li{The [pullback power](stt-004D) of #{f} with #{g} is an equivalence}
\li{The square of \ref{stt-004C} is cartesian}
\li{The cone given by the pullback power is a pullback cone}
}

%```agda
\agda{
module _ {ùì§ ùì• ùì¶ ùìú} {A : Type ùì§} {B : Type ùì•}
         {C : Type ùì¶} {D : Type ùìú} (f : A ‚Üí B)
         (g : C ‚Üí D)  where
  power-pb‚Üêpb-power-is-equiv : is-equiv (pullback-power f g)
                             ‚Üí is-pullbackœâ _ (pb-power-cone f g)
  power-pb‚Üêpb-power-is-equiv pb-eq = is-pullback‚Üêgap (pb-power-cone f g)
    (homotopy-is-equiv (pullback-gap~pullback-power f g ~‚Åª¬π)
                       (is-equiv-‚àò (Arrow‚âÉpullback' ._‚âÉ_.has-is-eqv)
                                   pb-eq))


  pb-power-is-equiv‚Üêpower-pb : is-pullbackœâ _ (pb-power-cone f g)
                             ‚Üí is-equiv (pullback-power f g)
  pb-power-is-equiv‚Üêpower-pb pb = 3-for-2~ (pullback-gap~pullback-power f g)
                                           (Arrow‚âÉpullback' ._‚âÉ_.has-is-eqv)
                                           (gap-is-equiv‚Üêis-pullback _ pb)

  power-hom-cartesian‚Üêpullback-power : is-equiv (pullback-power f g)
                                     ‚Üí is-cartesian (power-hom f g)
  power-hom-cartesian‚Üêpullback-power ppeq
    = is-cartesian‚Üêis-pullback (power-hom f g) lem where
    lem : is-pullbackœâ _ (pb-power-cone f g)
    lem = power-pb‚Üêpb-power-is-equiv ppeq


  pullback-power‚Üêpower-hom-cartesian : is-cartesian (power-hom f g)
                                     ‚Üí is-equiv (pullback-power f g)
  pullback-power‚Üêpower-hom-cartesian pb = 3-for-2~ {f = pullback‚Üêarrow'}
                                     (pullback-gap~pullback-power f g)
                                     (Arrow‚âÉpullback' ._‚âÉ_.has-is-eqv)
                                     gap-is-equiv where
    gap-is-equiv : is-equiv (gap (pb-power-cone f g))
    gap-is-equiv = gap-is-equiv‚Üêis-pullback _ (is-pullback‚Üêis-cartesian _ pb)
}
%```
}

\subtree[stt-004K]{
\taxon{Theorem}
\title{Characterising fibres of the pullback map}

%```agda
\agda{
module _ {ùì§ ùì• ùì¶ ùìú} {A : Type ùì§} {B : Type ùì•}
         {C : Type ùì¶} {D : Type ùìú} (f : A ‚Üí B)
         (g : C ‚Üí D)  where

  pb-power-fibre‚âÉlifts : ‚àÄ (G : Arrow-map f g)
                         ‚Üí fibre (pullback-power f g) G ‚âÉ Lift G
  pb-power-fibre‚âÉlifts G
    = fibre (pullback-power f g) G ‚âÉ‚ü®‚ü©
      Œ£[ l ‚à∂ (B ‚Üí C)] _            ‚âÉ‚ü® Œ£-ap-‚âÉ (Œª
                                   l ‚Üí Arrow-map-path‚âÉ
                                       (pullback-power f g l) G) ‚ü©
      (Œ£[ l ‚à∂ (B ‚Üí C)] _) ‚âÉ‚ü® Lift-repr‚âÉ G e‚Åª¬π ‚ü©
      Lift G ‚âÉ‚àé
}
%```
}

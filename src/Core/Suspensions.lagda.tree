\subtree[stt-002M]{
\taxon{Definition}
\title{Suspension}

\p{Given a type #{X}, we define the suspension #{ОЈX} to be the pushout of:}

\quiver{
\begin{tikzcd}
	X && 1 \\
	\\
	1 && {\Sigma X}
	\arrow[from=1-1, to=1-3]
	\arrow[from=1-1, to=3-1]
	\arrow["N", from=1-3, to=3-3]
	\arrow["S"', from=3-1, to=3-3]
	\arrow["\lrcorner"{anchor=center, pos=0.125, rotate=180}, draw=none, from=3-3, to=1-1]
\end{tikzcd}
}

\p{We call the two distinguished points \em{N}orth and \em{S}outh and the family of maps from North to South
   the \em{merid}ians.}

\agda{
Susp : вҲҖ {рқ“Ө} вҶ’ Type рқ“Ө вҶ’ Type рқ“Ө
Susp X = Pushout {A = X} ! !
{-# NOINLINE Susp #-}

North South : вҲҖ {рқ“Ө} {A : Type рқ“Ө} вҶ’ Susp A
North = О№вӮҒ tt
South = О№вӮӮ tt

merid : вҲҖ {рқ“Ө} {A : Type рқ“Ө} вҶ’ A вҶ’ Id (Susp A) North South
merid = glue
}
}


\subtree[stt-002N]{
\title{Universal property of suspensions}

\p{The type #{\Sigma X \to Y} is equivalent to #{\Sigma_{y_N, y_S : Y} (X \to y_N = y_S)}.}

\proof{
##{
\begin{align*}
  (\Sigma X \to Y) & \simeq (1 +^X 1 \to Y) \\
                   & \simeq (\Sigma_{(x, y : 1 \to Y)}(X \to x \sim y)) \\
                   & \simeq (\Sigma_{(x, y : Y)}(X \to x = y))
\end{align*}
}
}

\todo{
\p{Ideally we use universal property for pushouts macro,
   followed by coconeбөҳ representation macro, but the latter isn't
   working at the moment.}
}

\agda{
Susp-UPвҶ’
  : вҲҖ {рқ“Ө рқ“Ҙ} {X : Type рқ“Ө}
      {Y : Type рқ“Ҙ}
    вҶ’ ОЈ[ x вҲ¶ Y ] ОЈ[ y вҲ¶ Y ] (X вҶ’ x пјқ y)
    вҶ’ Susp X вҶ’ Y
Susp-UPвҶ’ (x , y , p) = pushout-rec (mk-cocone (О» _ вҶ’ x) (О» _ вҶ’ y) p)

Susp-UP-is-equiv
  : вҲҖ {рқ“Ө рқ“Ҙ} {X : Type рқ“Ө}
      {Y : Type рқ“Ҙ}
    вҶ’ is-equiv (Susp-UPвҶ’ {X = X} {Y})
Susp-UP-is-equiv = is-equivвҶҗqinv (О» where
  .fst po вҶ’ (po (О№вӮҒ tt) , po (О№вӮӮ tt) , po в—Ӯ glue)
  .snd .fst (a , b , H) вҶ’ ap ((a ,_) вҲҳ (b ,_)) (funextвҶ’ pushout-rec-apОІ)
  .snd .snd вҶ’ is-equiv.О· Pushout-up-pushout)

Susp-UPвүғ
  : вҲҖ {рқ“Ө рқ“Ҙ} {X : Type рқ“Ө}
      {Y : Type рқ“Ҙ}
    вҶ’ (Susp X вҶ’ Y) вүғ (ОЈ[ x вҲ¶ Y ] ОЈ[ y вҲ¶ Y ] (X вҶ’ x пјқ y))
Susp-UPвүғ {X = X} {Y} = mkвүғ _ (is-equivвҒ»В№ Susp-UP-is-equiv)
  -- = (Susp X вҶ’ Y) вүғвҹЁ mkвүғ _ Pushout-up-pushout вҹ©
  --   Cocone _ Y                                            вүғвҹЁ cocone-reprвүғ вҹ©
  --   (ОЈ[ f вҲ¶ (рқҹҷ вҶ’ Y) ] ОЈ[ g вҲ¶ (рқҹҷ вҶ’ Y)] (X вҶ’ f tt пјқ g tt)) вүғвҹЁ ОЈ-ap-вүғ-fst unit-UPвүғ вҹ©
  --   (ОЈ[ x вҲ¶ Y ] ОЈ[ g вҲ¶ (рқҹҷ вҶ’ Y) ] (X вҶ’ x пјқ g tt))          вүғвҹЁ ОЈ-ap-вүғ (О» x вҶ’ ОЈ-ap-вүғ-fst (unit-UPвүғ)) вҹ©
  --   ОЈ[ x вҲ¶ Y ] ОЈ[ y вҲ¶ Y ] (X вҶ’ x пјқ y) вүғвҲҺ
}
}

\subtree[stt-007G]{
\title{Suspension is a functor}
\taxon{Theorem}

\agda{
Susp-map
  : вҲҖ {рқ“Ө рқ“Ҙ} {A : Type рқ“Ө} {B : Type рқ“Ҙ}
    вҶ’ (A вҶ’ B)
    вҶ’ Susp A вҶ’ Susp B
Susp-map f = Susp-UPвҶ’ (О№вӮҒ tt , О№вӮӮ tt , glue вҲҳ f)
}
}

\subtree[stt-007J]{
\title{Suspension preserves the unit type}
\taxon{Theorem}

\agda{
Susp-рқҹҷ : Susp рқҹҷ вүғ рқҹҷ
Susp-рқҹҷ = equivвҶҗqequiv (О» where
  ._вүҠ_.fwd вҶ’ !
  ._вүҠ_.fwd-qinv .fst _ вҶ’ North
  ._вүҠ_.fwd-qinv .snd .fst
    вҶ’ pushout-ind _ (mk-coconeбөҲ ~refl glue О»
                        a вҶ’ IdбөҲвҶҗSquare refl refl _ (glue a)
                              (mk-square
                                (sym ( вҲҷ-reflr _
                                   вҲҷ coe-postcompпјқ refl (glue a)))))
  ._вүҠ_.fwd-qinv .snd .snd вҶ’ ~refl)
}
}


\subtree[stt-007K]{
\title{Suspension map of #{!}}
\taxon{Corollary}
\p{There exists an equivalence of arrows #{!_{\Sigma A} \simeq \Sigma !_A}}

\agda{
Susp-! : вҲҖ {рқ“Ө} {A : Type рқ“Ө} вҶ’ Arrow-map (Susp-map (!: A)) (!: Susp A)
Susp-! .Arrow-map.top = id
Susp-! .Arrow-map.bot = !
Susp-! .Arrow-map.comm = ~refl

infix 30 Susp-!:_
Susp-!:_ : вҲҖ {рқ“Ө} (A : Type рқ“Ө) вҶ’ Arrow-map (Susp-map (!: A)) (!: Susp A)
Susp-!: A = Susp-!


Susp-!-is-equiv : вҲҖ {рқ“Ө} {A : Type рқ“Ө} вҶ’ is-Arrow-equiv (Susp-!: A)
Susp-!-is-equiv .fst = id-is-equiv
Susp-!-is-equiv .snd = Susp-рқҹҷ ._вүғ_.fwd-is-equiv

Susp-!вҒ»В№ : вҲҖ {рқ“Ө} {A : Type рқ“Ө} вҶ’ Arrow-map (!: Susp A) (Susp-map (!: A))
Susp-!вҒ»В№ = ArrowвҒ»В№вҶҗis-Arrow-equiv Susp-! Susp-!-is-equiv
}
}

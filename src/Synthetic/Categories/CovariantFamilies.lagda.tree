\subtree[stt-00AY]{
\taxon{Definition}
\title{Covariant families}

\p{We say that a type family #{P : A \to \UU} is covariant if for any arrow #{f}
in #{A}, and term #{x_0} at #{P_{f(0)}}, the type of homs over #{f} which extend
#{x_0} is a singleton type.}

\p{Covariant families admit a directed transport.}

\agda{
is-covariant
  : вҲҖ {рқ“Ө рқ“Ҙ} {A : Type рқ“Ө} (B : A вҶ’ Type рқ“Ҙ)
    вҶ’ Type (рқ“ҳ вҠ” рқ“Ө вҠ” рқ“Ҙ)
is-covariant {A = A} B
    = вҲҖ (x : О”В№ вҶ’ A) (xвӮҖ : B (x i0))
      вҶ’ is-singleton (ОЈ[ xвӮҒ вҲ¶ B (x i1)] HomбөҲ (B вҲҳ x) xвӮҖ xвӮҒ)

{-# INJECTIVE_FOR_INFERENCE is-covariant #-}

is-covariant-is-prop
  : вҲҖ {рқ“Ө рқ“Ҙ} {A : Type рқ“Ө} (B : A вҶ’ Type рқ“Ҙ) вҶ’ is-prop (is-covariant B)
is-covariant-is-prop B
  = О -is-prop (О» a вҶ’ О -is-prop (О» b вҶ’ is-single-is-prop))

is-covariant-hom
  : вҲҖ {рқ“Ө рқ“Ҙ} {A : Type рқ“Ө} (B : A вҶ’ Type рқ“Ҙ)
    вҶ’ Type (рқ“ҳ вҠ” рқ“Ө вҠ” рқ“Ҙ)
is-covariant-hom {A = A} B
  = вҲҖ {x y} (f : Hom A x y) (x' : B x)
    вҶ’ is-singleton (ОЈ[ y' вҲ¶ B y ] Hom-over f x' y')

is-covariant-homвҶҗis-covariant
  : вҲҖ {рқ“Ө рқ“Ҙ} {A : Type рқ“Ө} (B : A вҶ’ Type рқ“Ҙ)
    вҶ’ is-covariant B вҶ’ is-covariant-hom B
is-covariant-homвҶҗis-covariant B cov (mk-hom f refl refl) x' = cov f x'

is-covariantвҶҗis-covariant-hom
  : вҲҖ {рқ“Ө рқ“Ҙ} {A : Type рқ“Ө} (B : A вҶ’ Type рқ“Ҙ)
    вҶ’ is-covariant-hom B вҶ’ is-covariant B
is-covariantвҶҗis-covariant-hom B cov f x' = cov (О»hom f) x'

}
}

\subtree[stt-00O8]{
\title{Covariant type families admit directed transport}
\taxon{Lemma}

\agda{
tr-cov
  : вҲҖ {рқ“Ө рқ“Ҙ} {A : Type рқ“Ө} {P : A вҶ’ Type рқ“Ҙ}
    вҶ’ is-covariant P вҶ’ (h : О”В№ вҶ’ A) вҶ’ P (h i0) вҶ’ P (h i1)
tr-cov cov h = fst вҲҳ centre вҲҳ cov h

tr-cov-filler
  : вҲҖ {рқ“Ө рқ“Ҙ} {A : Type рқ“Ө} {P : A вҶ’ Type рқ“Ҙ}
    вҶ’ (Pc : is-covariant P) вҶ’ (h : О”В№ вҶ’ A)
    вҶ’ вҲҖ p вҶ’ HomбөҲ (P вҲҳ h) p (tr-cov {P = P} Pc h p)
tr-cov-filler cov h = snd вҲҳ centre вҲҳ cov h

tr-cov-hom
  : вҲҖ {рқ“Ө рқ“Ҙ} {A : Type рқ“Ө} {P : A вҶ’ Type рқ“Ҙ}
    вҶ’ is-covariant P
    вҶ’ вҲҖ {x y} (h : Hom A x y) вҶ’ P x вҶ’ P y
tr-cov-hom cov h = fst вҲҳ centre вҲҳ is-covariant-homвҶҗis-covariant _ cov h

tr-cov-over
  : вҲҖ {рқ“Ө рқ“Ҙ} {A : Type рқ“Ө} {P : A вҶ’ Type рқ“Ҙ}
    вҶ’ (cov : is-covariant P)
    вҶ’ вҲҖ {x y} (h : Hom A x y) вҶ’ (x' : P x) вҶ’ Hom-over h x' (tr-cov-hom cov h x')
tr-cov-over cov h = snd вҲҳ centre вҲҳ is-covariant-homвҶҗis-covariant _ cov h
}
}

\subtree[stt-00O5]{
\title{Left families}
\taxon{Definition}

\p{We say that a type family is \em{a left family} if, as a family, it is right orthogonal
to the left endpoint inclusion.}

\agda{
is-left-family
  : вҲҖ {рқ“Ө рқ“Ҙ} {A : Type рқ“Ө} (B : A вҶ’ Type рқ“Ҙ) вҶ’ Type (рқ“ҳ вҠ” рқ“Ө вҠ” рқ“Ҙ)
is-left-family = are-orthogonal-fam (point i0)
}
}

\subtree[stt-00O6]{
\title{Left families are covariant}
\taxon{Lemma}

\proof{
\p{
Left families are equivalently those type families #{B} for which each
#{B_{\sigma(0)}} admits a unique extension along #{0 \to \Delta^1}.
We have already characterised orthogonal families as those who admit
unique extensions.
}
}

\agda{
module _ {рқ“Ө рқ“Ҙ} {A : Type рқ“Ө} (B : A вҶ’ Type рқ“Ҙ) where
  cov-lift-is-extension
    : вҲҖ (Пғ : О”В№ вҶ’ A) (xвӮҖ : B (Пғ i0))
      вҶ’ ОЈ (B (Пғ i1)) (HomбөҲ (B вҲҳ Пғ) xвӮҖ) вүғ ExtбөҲ (point i0) (B вҲҳ Пғ) (point xвӮҖ)
  cov-lift-is-extension Пғ xвӮҖ
    =  ОЈ (B (Пғ i1)) (HomбөҲ (B вҲҳ Пғ) xвӮҖ)
    вүғвҹЁ ОЈ-snd-вүғ (О» b вҶ’ HomбөҲ-reprвүғ) вҹ©
       (ОЈ[ xвӮҒ вҲ¶ B (Пғ i1) ] ОЈ[ f вҲ¶ О  О”В№ (B вҲҳ Пғ) ] ((f i0 пјқ xвӮҖ) Г— (f i1 пјқ xвӮҒ)))
    вүғвҹЁ ОЈ-comm вҲҷe ОЈ-snd-вүғ (О» f вҶ’ ОЈ-comm) вҹ©
       (ОЈ[ f вҲ¶ О  О”В№ (B вҲҳ Пғ) ] ((f i0 пјқ xвӮҖ) Г— ОЈ[ xвӮҒ вҲ¶ B (Пғ i1) ] (f i1 пјқ xвӮҒ)))
    вүғвҹЁ ОЈ-snd-вүғ (О» f вҶ’ ОЈ-singleton (О» _ вҶ’ Sing-is-singleton)) вҹ©
       (ОЈ[ f вҲ¶ О  О”В№ (B вҲҳ Пғ)] (f i0 пјқ xвӮҖ))
    вүғвҹЁ ОЈ-snd-вүғ (О» f вҶ’ unit-UPвүғ eвҒ»В№) вҹ©
       ExtбөҲ (point i0) (B вҲҳ Пғ) (point xвӮҖ)
    вүғвҲҺ

  opaque
    is-covariantвҶҗhas-unique-extensions
      : has-unique-extensions (point i0) B вҶ’ is-covariant B
    is-covariantвҶҗhas-unique-extensions ext Пғ xвӮҖ
      = is-singleвҶҗequiv-to-single
          (cov-lift-is-extension Пғ xвӮҖ eвҒ»В№)
          (ext (mk-afmap Пғ (point xвӮҖ)))

    has-unique-extensionsвҶҗis-covariant
      : is-covariant B вҶ’ has-unique-extensions (point i0) B
    has-unique-extensionsвҶҗis-covariant cov (mk-afmap Пғ f)
      = is-singleвҶҗequiv-to-single
          (cov-lift-is-extension Пғ (f tt))
          (cov Пғ (f tt))

  has-unique-extensionsвҶ”is-covariant
    : has-unique-extensions (point i0) B вҶ” is-covariant B
  has-unique-extensionsвҶ”is-covariant
    = ( is-covariantвҶҗhas-unique-extensions
      , has-unique-extensionsвҶҗis-covariant)

  is-left-familyвҶ”is-covariant
    : is-left-family B вҶ” is-covariant B
  is-left-familyвҶ”is-covariant
    =  are-orthogonal-famвҶ”has-unique-extensions
    вҲҷiff has-unique-extensionsвҶ”is-covariant
}
}

\subtree[stt-00AV]{
\title{Left fibrations}
\taxon{Definition}

\p{A map is a left fibration if it is [right orthogonal](stt-0048) to the left
endpoint of #{\Delta^1}.}

\p{See [[stt-00OH]] for the dual notion.}

\agda{
is-left-fibration
  : вҲҖ {рқ“Ө рқ“Ҙ} {A : Type рқ“Ө} {B : Type рқ“Ҙ} вҶ’ (A вҶ’ B)
    вҶ’ Type (рқ“Ө вҠ” рқ“Ҙ вҠ” рқ“ҳ)
is-left-fibration f = (point i0) вҠҘ f

is-left-anodyne
  : вҲҖ {рқ“Ө рқ“Ҙ} {A : Type рқ“Ө} {B : Type рқ“Ҙ} вҶ’ (A вҶ’ B) вҶ’ TypeПү
is-left-anodyne f = is-anodyne f (point i0)
}
}


\subtree[stt-00AR]{
\title{Covariant families straighten to left fibrations}
\taxon{Corollary}

\p{We show that some family #{P : A \to \UU} is [covariant](stt-00AO) iff the map
#{\pi : \tilde{P} \to A} is a [left fibration](stt-00AV).}

\agda{
opaque
  is-covariantвҶ”is-left-fibration
    : вҲҖ {рқ“Ө рқ“Ҙ} {A : Type рқ“Ө} (B : A вҶ’ Type рқ“Ҙ)
      вҶ’ is-covariant B вҶ” is-left-fibration (fst: B)
  is-covariantвҶ”is-left-fibration {A = A} B
    = (is-left-familyвҶ”is-covariant B iffвҒ»В№) вҲҷiff are-orthogonal-famвҶ”are-orthogonal-fst
}
}

\subtree[tot-00A2]{
\title{Left fibrations are maps which induce equivalences on coslices}
\taxon{Lemma}

\p{#{p : E \to B} is a left fibration iff for each #{e : E}, the induced map
#{E_{e/} \to B_{p(e)/}} is an equivalence.}

\agda{
module _ {рқ“Ө рқ“Ҙ} {E : Type рқ“Ө} {B : Type рқ“Ҙ} (p : E вҶ’ B) where
  arrow-fibre-left-fibration-is-coslice-map
    : вҲҖ (e : E)
      вҶ’ Arrow-equiv
          (postcompose-coslice (point e) p)
          (arrow-fibre (transpose-square (power-hom (point i0) p)) (point e))
  arrow-fibre-left-fibration-is-coslice-map e .fst .Arrow-О .top
    = total-map (О» a вҶ’ ap point) вҲҳ Coslice-object-reprвүғ e ._вүғ_.fwd
  arrow-fibre-left-fibration-is-coslice-map e .fst .Arrow-О .bot
    = total-map (О» a вҶ’ ap point) вҲҳ Coslice-object-reprвүғ (p e) ._вүғ_.fwd
  arrow-fibre-left-fibration-is-coslice-map e .fst .Arrow-О .comm (e' , f)
    = fibre-pathвҶ’ (refl , sym (ap-вҲҳ (p вҲҳ_) (О» a _ вҶ’ a) (HomбөҲ.hom0 (f tt)))
                        вҲҷ ap-вҲҳ (О» a _ вҶ’ a) p (HomбөҲ.hom0 (f tt)))
  arrow-fibre-left-fibration-is-coslice-map e .snd .fst
    = is-equiv-вҲҳ
        (is-total-equivвҶҗis-fibrewise-equiv
          (О» a вҶ’ is-embeddingвҶҗis-equiv (point-is-equiv)))
        (Coslice-object-reprвүғ e ._вүғ_.fwd-is-equiv)
  arrow-fibre-left-fibration-is-coslice-map e .snd .snd
    = is-equiv-вҲҳ
        (is-total-equivвҶҗis-fibrewise-equiv
          (О» a вҶ’ is-embeddingвҶҗis-equiv (point-is-equiv)))
        (Coslice-object-reprвүғ (p e) ._вүғ_.fwd-is-equiv)

  coslice-map-is-equivвҶҗis-left-fibration
    : is-left-fibration p вҶ’ (вҲҖ e вҶ’ is-equiv (postcompose-coslice (point e) p))
  coslice-map-is-equivвҶҗis-left-fibration lfib e
    = src-is-equivвҶҗArrow-equiv
        (arrow-fibre-left-fibration-is-coslice-map e)
        (transpose-is-cartesian _ (is-cartesianвҶҗare-orthogonal lfib) (point e))


  is-left-fibrationвҶҗcoslice-map-is-equiv
    : (вҲҖ e вҶ’ is-equiv (postcompose-coslice (point e) p)) вҶ’ is-left-fibration p
  is-left-fibrationвҶҗcoslice-map-is-equiv eqv
    = are-orthogonalвҶҗis-cartesian
        (transpose-is-cartesian _
          О» e 
          вҶ’ tgt-is-equivвҶҗArrow-equiv
              (arrow-fibre-left-fibration-is-coslice-map (e tt))
              (eqv (e tt)))
}
}

\subtree[stt-00C7]{
\title{Left fibrations are inner}
\taxon{Lemma}

\proof{
\p{We use the fact that left orthogonal maps [are closed under pushout products
and embeddings](stt-00BV). In particular we take the pushout product:
#{\underset{\Delta^1}{\overset{\{0\}}{\downarrow}} \pushprod
\underset{\Delta^1}{\overset{\{1\}}{\downarrow}}}, which modulo some contracting
away singletons, is the [inner horn](stt-00AD) inclusion into the square. Now
the following retract square completes the proof:}
\transclude{stt-00LC}
}


\remark{
We may use the dual proof for [right fibrations](stt-00OJ)
(\ref{stt-00C7})
}

\agda{
is-innerвҶҗis-left-fibration
  : вҲҖ {рқ“Ө рқ“Ҙ} {A : Type рқ“Ө} {B : Type рқ“Ҙ} {f : A вҶ’ B}
    вҶ’ is-left-fibration f вҶ’ is-inner f
is-innerвҶҗis-left-fibration {f = f} lf
  = left-orthogonal-retraction
      Оӣ[2,1]-incl (pushout-product (point i1) (point i0))
      Оӣ[2,1]вҶӘв–Ў-section Оӣ[2,1]вҶӘв–Ў-ret _
      (left-orthogonal-pushout-product' (point i0) f lf (point i1))
}
}

\subtree[stt-00C8]{
\taxon{Corollary}

\p{The total type of a covariant family over a Segal type is itself Segal.}

\agda{
is-inner-familyвҶҗis-covariant
  : вҲҖ {рқ“Ө рқ“Ҙ} {A : Type рқ“Ө} {B : A вҶ’ Type рқ“Ҙ}
    вҶ’ is-covariant B вҶ’ is-inner-family B
is-inner-familyвҶҗis-covariant
  = is-innerвҶҗis-left-fibration вҲҳ (is-covariantвҶ”is-left-fibration _ .fst)

is-inner-familyвҶҗis-covariant-hom
  : вҲҖ {рқ“Ө рқ“Ҙ} {A : Type рқ“Ө} {B : A вҶ’ Type рқ“Ҙ}
    вҶ’ is-covariant-hom B вҶ’ is-inner-family B
is-inner-familyвҶҗis-covariant-hom
  = is-inner-familyвҶҗis-covariant вҲҳ is-covariantвҶҗis-covariant-hom _

ОЈ-cov-is-segal
  : вҲҖ {рқ“Ө рқ“Ҙ} {A : Type рқ“Ө} {B : A вҶ’ Type рқ“Ҙ}
    вҶ’ is-segal A вҶ’ is-covariant B вҶ’ is-segal (ОЈ A B)
ОЈ-cov-is-segal apc cov
  = ОЈ-is-segal apc
      (is-innerвҶҗis-left-fibration
        (is-covariantвҶ”is-left-fibration _ .fst  cov))
}
}

\subtree[stt-00DH]{
\title{Morphisms in Hom types}
\taxon{Lemma}

\p{We show that for a covariant family #{P}, given any #{f : \Hom_A(x,y)},
the type of dependent morphisms #{\Hom_{Pf}(x',y')} is equivalent to
#{f^*(x') = y'}.}

\proof{
\p{We first give a map #{f^*(x') = y'}, by identity induction, it suffices to give
a morphism #{\Hom_{Pf}(x', f^*(x'))} for each #{x'}, but this is just the
coherence you get from covariant transport.
Now since #{\Sigma_{y' : P(f(1))} \Hom_{Pf}(x',y')} is a singleton by the
definition of transport, the fundamental theorem of identity types gives us that
this map is an equivalence.}
}

\agda{
Hom-cov
  : вҲҖ {рқ“Ө рқ“Ҙ} {A : Type рқ“Ө} (P : A вҶ’ Type рқ“Ҙ) (cov : is-covariant P)
      (f : О”В№ вҶ’ A) x' y'
    вҶ’ tr-cov {P = P} cov f x' пјқ y' вҶ’ HomбөҲ (P вҲҳ f) x' y'
Hom-cov _ Pc f x' y' refl = Pc f x' .centre .snd

Hom-cov-is-equiv
  : вҲҖ {рқ“Ө рқ“Ҙ} {A : Type рқ“Ө} (P : A вҶ’ Type рқ“Ҙ) (cov : is-covariant P)
      (f : О”В№ вҶ’ A) x' y'
    вҶ’ is-equiv (Hom-cov P cov f x' y')
Hom-cov-is-equiv P Pc f x' = fundamental-Id _ (Pc f x') (Hom-cov P Pc f x')

Hom-cov'
  : вҲҖ {рқ“Ө рқ“Ҙ} {A : Type рқ“Ө} (P : A вҶ’ Type рқ“Ҙ) (cov : is-covariant P)
      {x y} (f : Hom A x y) x' y'
    вҶ’ tr-cov-hom {P = P} cov f x' пјқ y' вҶ’ Hom-over f x' y'
Hom-cov' P cov f x' y' refl
  = is-covariant-homвҶҗis-covariant _ cov f x' .centre .snd

Hom-cov'-is-equiv
  : вҲҖ {рқ“Ө рқ“Ҙ} {A : Type рқ“Ө} (P : A вҶ’ Type рқ“Ҙ) (cov : is-covariant P)
      {x y} (f : Hom A x y) x' y'
    вҶ’ is-equiv (Hom-cov' P cov f x' y')
Hom-cov'-is-equiv P Pc f x'
  = fundamental-Id
      _
      (is-covariant-homвҶҗis-covariant _ Pc f x')
      (Hom-cov' P Pc f x')

Hom-cov'вүғ
  : вҲҖ {рқ“Ө рқ“Ҙ} {A : Type рқ“Ө} (P : A вҶ’ Type рқ“Ҙ) (cov : is-covariant P)
      {x y} (f : Hom A x y) x' y'
    вҶ’ (tr-cov-hom {P = P} cov f x' пјқ y') вүғ (Hom-over f x' y')
Hom-cov'вүғ  P Pc f x' y'
  = mkвүғ (Hom-cov' P Pc f x' y') (Hom-cov'-is-equiv P Pc f x' y')
}
}

\subtree[stt-00DQ]{
\title{Covariant transport is functorial}
\taxon{Theorem}

\citet{8.16}{RS17}

\p{Given a covariant family #{P}, we show the transport operation is functorial,
in the sense that #{P(\id) \sim \id} and
#{P(f \circ g) \sim P(f) \circ P(g)}.}

\agda{
tr-cov-id
  : вҲҖ {рқ“Ө рқ“Ҙ} {A : Type рқ“Ө} (P : A вҶ’ Type рқ“Ҙ) (cov : is-covariant P) {x}
    вҶ’ tr-cov {P = P} cov (О» _ вҶ’ x) ~ id
tr-cov-id P cov {x} x' = ap fst (cov (О» _ вҶ’ x) x' .central (x' , idH x'))

tr-cov-idH
  : вҲҖ {рқ“Ө рқ“Ҙ} {A : Type рқ“Ө} (P : A вҶ’ Type рқ“Ҙ) (cov : is-covariant P) {x}
    вҶ’ tr-cov-hom {P = P} cov (idH x) ~ id
tr-cov-idH P cov {x} x' = ap fst
  (is-covariant-homвҶҗis-covariant _ cov (idH x) x' .central (x' , idH x'))

tr-cov-вҲҳ
  : вҲҖ {рқ“Ө рқ“Ҙ} {A : Type рқ“Ө} (Apc : is-segal A) (P : A вҶ’ Type рқ“Ҙ)
      (cov : is-covariant P) {x y z} (g : Hom A y z) (f : Hom A x y)
      (x' : P x)
    вҶ’ tr-cov-hom cov (g вҲҳ[ Apc ] f) x'
    пјқ tr-cov-hom cov g (tr-cov-hom cov f x')
tr-cov-вҲҳ apc P cov g f x'
  = ap fst
      (is-covariant-homвҶҗis-covariant _ cov (g вҲҳ[ apc ] f) x' .central
        ( tr-cov-hom cov g (tr-cov-hom cov f x')
        , CompбөҲ apc P (is-inner-familyвҶҗis-covariant cov) g f
                (tr-cov-over cov g _) (tr-cov-over cov f _)))
}
}

\subtree[stt-00K3]{
\title{Covariant transport along inequalities in #{О”В№}}
\taxon{Lemma}

\p{Each #{i \le j} in #{\Delta^1} induces a morphism #{\Hom_{\Delta^1}(i,j)}.
consequently, for covariant families over #{\Delta^1}, we may coerce along
#{i \le j}. Since #{i \le j} is a proposition, we have the coercing along
#{i \le i} for any #{i} is the identity and coercing along #{0 \le 1} is the
same as covariant transport over the canonical morphisms from #{0} to #{1} given
by #{id : \Delta^1 \to \Delta^1}.}

\agda{
О”В№-homвҶҗвүӨ  : вҲҖ {i j} вҶ’ i вүӨ j вҶ’ Hom О”В№ i j
О”В№-homвҶҗвүӨ {i} {j} p .HomбөҲ.hom l = (l вҲЁ i) вҲ§ (i вҲЁ j)
О”В№-homвҶҗвүӨ p .HomбөҲ.hom0 = apвӮӮ (_вҲ§_) (вҲЁ-comm вҲҷ 0-bottom) (вүӨ-max p) вҲҷ p
О”В№-homвҶҗвүӨ p .HomбөҲ.hom1 = apвӮӮ (_вҲ§_) (вҲЁ-comm вҲҷ 1-coinit) (вүӨ-max p) вҲҷ вҲ§-comm вҲҷ 1-top

О”В№-hom-вүӨ-refl : вҲҖ {i} (p : i вүӨ i) вҶ’ О”В№-homвҶҗвүӨ p пјқ idH i
О”В№-hom-вүӨ-refl {i} p
  = Hom-extвҶ’ ( (О» a вҶ’ ap ((a вҲЁ i) вҲ§_) вҲЁ-idem вҲҷ вҲЁ-вҲ§-abs') , prop! , prop!)

О”В№-hom-0вүӨ1 : (p : i0 вүӨ i1) вҶ’ О”В№-homвҶҗвүӨ p пјқ 0вүӨ1
О”В№-hom-0вүӨ1 p
  = Hom-extвҶ’ ( (О» a вҶ’ apвӮӮ (_вҲ§_) 0-bottom 1-coinit вҲҷ 1-top) , prop! , prop!)

module _ {рқ“Ө} (B : О”В№ вҶ’ Type рқ“Ө) (bc : is-covariant B) where

  coe-cov : {i j : О”В№} вҶ’ i вүӨ j вҶ’ B i вҶ’ B j
  coe-cov p = tr-cov-hom bc (О”В№-homвҶҗвүӨ p)

  opaque
    coe-cov-id : {i  : О”В№} (p : i вүӨ i) вҶ’ coe-cov p ~ id
    coe-cov-id {i} p
      =  happly (ap (tr-cov-hom bc) (О”В№-hom-вүӨ-refl p))
      вҲҷh tr-cov-idH B bc

    coe-cov-пјқ : {i j : О”В№} (p : i пјқ j) (q : i вүӨ j) вҶ’ coe-cov q ~ tr B p
    coe-cov-пјқ refl = coe-cov-id

    coe-cov-0вүӨ1 : (p : i0 вүӨ i1) вҶ’ coe-cov p пјқ tr-cov bc id
    coe-cov-0вүӨ1 p = ap (tr-cov-hom bc) (О”В№-hom-0вүӨ1 p)
}
}

\subtree[stt-00FR]{
\title{Natural transformations are natural w.r.t. covariant transport}
\taxon{Lemma}
\author{samueltoth}
\date{2025-12-09}

\citet{Proposition 8.17}{RS17}

\agda{
tr-cov-hom-naturality
  : вҲҖ {рқ“Ө рқ“Ҙ рқ“Ұ} {A : Type рқ“Ө} {F : A вҶ’ Type рқ“Ҙ} {G : A вҶ’ Type рқ“Ұ}
      (Fc : is-covariant F)
      (Gc : is-covariant G)
      (Оұ : вҲҖ a вҶ’ F a вҶ’ G a)
      {x y : A} (f : Hom A x y)
    вҶ’ tr-cov-hom Gc f вҲҳ Оұ x ~ Оұ y вҲҳ tr-cov-hom Fc f
tr-cov-hom-naturality {A = A} {F} Fc Gc Оұ f x'
  = ap fst
      (is-covariant-homвҶҗis-covariant _ Gc f (Оұ _ x') .central
        ( Оұ _ (tr-cov-hom Fc f x')
        , help f x')) where
  help
    : {x y : A} (f : Hom A x y) (x' : F x)
    вҶ’ Hom-over f (Оұ x x') (Оұ y (tr-cov-hom Fc f x'))
  help (mk-hom f refl refl) x'
    = mk-hom (О» i вҶ’ Оұ (f i) ((Fc f x') .centre .snd .HomбөҲ.hom i))
             (ap (Оұ (f i0)) ((Fc f x') .centre .snd .HomбөҲ.hom0))
             (ap (Оұ (f i1)) ((Fc f x') .centre .snd .HomбөҲ.hom1))
}
}


\subtree[stt-00FR]{
\title{Natural transformations are natural with respect to covariant transport}
\taxon{Lemma}

\citet{Proposition 8.17}{RS17}

\agda{
tr-naturality
  : вҲҖ {рқ“Ө рқ“Ҙ рқ“Ұ} {A : Type рқ“Ө} {F : A вҶ’ Type рқ“Ҙ} {G : A вҶ’ Type рқ“Ұ}
      (Fc : is-covariant F)
      (Gc : is-covariant G)
      (Оұ : вҲҖ a вҶ’ F a вҶ’ G a)
      {x y} (f : Hom A x y)
    вҶ’ tr-cov-hom Gc f вҲҳ Оұ x ~ Оұ y вҲҳ tr-cov-hom Fc f
tr-naturality Fc Gc Оұ f x'
  = ap fst
      (is-covariant-homвҶҗis-covariant _ Gc f (Оұ _ x') .central
        ( Оұ _ (tr-cov-hom Fc f x')
        , help f x')) where
  help
    : вҲҖ {x y} (f : Hom _ x y) x'
      вҶ’ Hom-over f (Оұ x x') (Оұ y (tr-cov-hom Fc f x'))
  help (mk-hom f refl refl) x'
    = mk-hom (О» i вҶ’ Оұ (f i) ((Fc f x') .centre .snd .HomбөҲ.hom i))
             (ap (Оұ (f i0)) ((Fc f x') .centre .snd .HomбөҲ.hom0))
             (ap (Оұ (f i1)) ((Fc f x') .centre .snd .HomбөҲ.hom1))
}
}

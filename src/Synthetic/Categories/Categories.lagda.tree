\subtree[fre-00N1]{
\title{Rezk completeness}
\taxon{Definition}
\author{fredrikbakke}

\agda{
fam-is-rezk-complete : рқҹҷ вҶ’ в„‘ вҶ’ рқҹҷбҙё: рқ“ҳ
fam-is-rezk-complete _ = !бҙё

is-rezk-complete
  : вҲҖ {рқ“Ө}
  вҶ’ (A : Type рқ“Ө)
  вҶ’ Type (рқ“ҳ вҠ” рқ“Ө)
is-rezk-complete A
  = is-local fam-is-rezk-complete A

is-rezk-complete-is-prop
  : вҲҖ {рқ“Ө} {A : Type рқ“Ө}
  вҶ’ is-prop (is-rezk-complete A)
is-rezk-complete-is-prop {A = A}
  = is-local-is-prop A
}

\agda{
RezkCompl-SubU : вҲҖ {рқ“Ө} вҶ’ SubU рқ“Ө (рқ“Ө вҠ” рқ“ҳ)
RezkCompl-SubU = Local-SubU fam-is-rezk-complete _

RezkCompl-gSubU : gSubU (_вҠ” рқ“ҳ)
RezkCompl-gSubU = Local-gSubU fam-is-rezk-complete

RezkCompl-is-globally-reflective
  : is-globally-reflective RezkCompl-gSubU
RezkCompl-is-globally-reflective = Local-global-reflectors fam-is-rezk-complete

RezkCompl-gRSubU : gRSubU (_вҠ” рқ“ҳ)
RezkCompl-gRSubU .gRSubU.GS = RezkCompl-gSubU
RezkCompl-gRSubU .gRSubU.GS-is-globally-reflective = RezkCompl-is-globally-reflective

open gSubU RezkCompl-gSubU public using () renaming
  ( вҲҲSвҶҗequiv to is-rezk-completeвҶҗequiv)
open gReflectiveClosure RezkCompl-gRSubU public using () renaming
  ( О вҲҲS to О -is-rezk-complete
  ; ULiftвҲҲS to ULift-is-rezk-complete
  ; рқҹҷвҲҲS to рқҹҷ-is-rezk-complete
  ; вҲҲSвҶҗis-singleton to is-rezk-completeвҶҗis-singleton
  ; вҲҲSвҶҗretract to is-rezk-completeвҶҗretract
  ; PullbackвҲҲS to Pullback-is-rezk-complete
  ; fibreвҲҲS to fibre-is-rezk-complete
  ; ExtвҲҲS to Ext-is-rezk-complete
  ; Г—вҲҲS to Г—-is-rezk-complete
  ; пјқвҲҲS to пјқ-is-rezk-complete
  ; ~вҲҲS to ~-is-rezk-complete
  ; retractвҲҲS to retract-is-rezk-complete
  ; biinvвҲҲS to biinv-is-rezk-complete
  ; вүғвҲҲS to вүғ-is-rezk-complete
  ; EqualiserвҲҲS to Equaliser-is-rezk-complete
  ; Seq-limвҲҲS to Seq-lim-is-rezk-complete
  ; preidempotent-mapвҲҲS to preidempotent-map-is-rezk-complete
  ; qidempotent-mapвҲҲS to qidempotent-map-is-rezk-complete
  ; idempotent-mapвҲҲS to idempotent-map-is-rezk-complete
  ; RetractsвҲҲS to Retracts-is-rezk-complete)
open gRSubUHomClosure RezkCompl-gRSubU public using () renaming
  ( HomвҲҲS to Hom-is-rezk-complete)

module RezkCompl where
  open gRSubU RezkCompl-gRSubU public
  open gReflectiveClosure RezkCompl-gRSubU public
  open gRSubUHomClosure RezkCompl-gRSubU public
}
}


\subtree[fre-00OH]{
\title{Rezk types}
\taxon{Definition}
\author{fredrikbakke}

\agda{
fam-is-complete-segal : вЁ„вӮҒб¶ -carrier (point Оӣ[2,1]-incl) (point (!бҙё: рқ“ҳ в„‘))
fam-is-complete-segal = point Оӣ[2,1]-incl вЁ„вӮҒб¶  point (!бҙё: рқ“ҳ в„‘)

is-complete-segal : вҲҖ {рқ“Ө} вҶ’ Type рқ“Ө вҶ’ Type (рқ“ҳ вҠ” рқ“Ө)
is-complete-segal A = is-local fam-is-complete-segal A


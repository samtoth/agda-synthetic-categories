\title{Simplicial HoTT}
\taxon{Reference}

\subtree{
\taxon{Abstract}
\p{
This is a formalization library for simplicial Homotopy Type Theory (sHoTT) with the
aim of proving results in synthetic #{\infty}-category theory.
}

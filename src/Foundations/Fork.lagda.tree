\title{Forks}
\taxon{Module}

\import{stt-macros}

% ```agda
\agda{
module Foundations.Fork where

open import Foundations.Universes
open import Foundations.Functions
open import Foundations.Homotopy
open import Foundations.Sigma
}
% ```

\subtree[fre-2127]{
\date{2026-03-11}
\author{fredrikbakke}
\taxon{Definition}
\title{Forks}

\p{
Given two parallel maps #{f\ g : A \to B}, a \em{fork} is a map #{e : E → A} such
that #{f \circ e \sim g \circ e}.
}

% ```agda
\agda{
Fork
  : ∀ {𝓤 𝓥 𝓦} {A : Type 𝓤} {B : Type 𝓥}
  → (f g : A → B)
  → (E : Type 𝓦)
  → Type (𝓤 ⊔ 𝓥 ⊔ 𝓦)
Fork {A = A} f g E = Σ[ e ∶ (E → A) ] (f ∘ e ~ g ∘ e)
}
% ```
}

\subtree[fre-2128]{
\date{2026-03-11}
\author{fredrikbakke}
\taxon{Definition}
\title{Maps of forks}

% ```agda
\agda{
fork-map
  : {𝓤 𝓥 𝓦 : Level} {A : Type 𝓤} {B : Type 𝓥}
    {f g : A → B} {E : Type 𝓦}
  → Fork f g E
  → ∀ {𝓠} {Q : Type 𝓠}
  → (Q → E)
  → Fork f g Q
fork-map (e , H) u = (e ∘ u , H ▸ u)
}
% ```
}

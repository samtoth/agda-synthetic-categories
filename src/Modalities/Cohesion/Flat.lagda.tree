\date{2025-06-06}
\title{The Flat Modalitiy}
\taxon{Module}
\author{samueltoth}
\import{stt-macros}

%```agda
\agda{
module Modalities.Cohesion.Flat where

open import Foundations.Prelude
}

\subtree[stt-004Z]{
\title{The Flat type operator}
\taxon{Definition}

\p{Given a crisp type #{A}, we can form the type #{\modflat{A}}. In agda flat
we can encode this with an inductive datatype generated by a crisp elements
of #{A}. We also note the corresponding induction principal for the inductive
type.}

\agda{
data έθρέβφ|_έθσ {@έβφ ΏζΥν} (@έβφ A : Type ΏζΥν) : Type ΏζΥν where
  modέβφ : (@έβφ _ : A) έΗΤ έθρέβφ| A έθσ

έβφ-ind : έΙΑ {@έβφ ΏζΥν} {ΏζΥξ} {@έβφ A : Type ΏζΥν} (B : έθρέβφ| A έθσ έΗΤ Type ΏζΥξ)
          έΗΤ ((@έβφ x : A) έΗΤ B (modέβφ x))
          έΗΤ (x : έθρέβφ| A έθσ) έΗΤ B x
έβφ-ind B f (modέβφ x) = f x
}
%```
}

\subtree[stt-0051]{
\taxon{Theroem}
\title{Flat is a Functor}

\p{Using the rules of [modal type theory](stt-0050) and #{\flat}-induction,
we can define operations making #{\modflat{-}} into a comonad.}

\p{To get a feel for how to reason informally about modal type theory, we
give the definition making #{\modflat{-}} into a functor informally
(in pain-staking detail), and compare it to the agda definition:}

\p{Given crisp types #{A :^\flat \UU} and #{B :^\flat \UV}, and a function
#{f :^\flat A \to B}, we can define a function #{\modflat{A} \to \modflat{B}}.
By crisp induction, it surfices to define a function
#{(a :^\flat A) \to \modflat{B}}. Then by #{\flat}-intro, we can assume a
crisp #{a :^\flat A} and give a crisp term of type #{B}, but now both #{f} and
#{a} were assumed crisp and so #{f(a) :^\flat B}, and we are done.
 }

%```agda
\agda{
έβφ-map : έΙΑ {@έβφ ΏζΥν ΏζΥξ} {@έβφ A : Type ΏζΥν} {@έβφ B : Type ΏζΥξ}
        έΗΤ (@έβφ f : A έΗΤ B) έΗΤ έθρέβφ| A έθσ έΗΤ έθρέβφ| B έθσ
έβφ-map f (modέβφ x) = modέβφ (f x)

έβφ-id : έΙΑ {@έβφ ΏζΥν} {@έβφ A : Type ΏζΥν}
        έΗΤ έβφ-map {A = A} id ~ id
έβφ-id (modέβφ x) = refl

έβφ-έΙα : έΙΑ {@έβφ ΏζΥν ΏζΥξ ΏζΥο} {@έβφ A : Type ΏζΥν} {@έβφ B : Type ΏζΥξ} {@έβφ C : Type ΏζΥο}
        έΗΤ (@έβφ f : B έΗΤ C) (@έβφ g : A έΗΤ B)
        έΗΤ έβφ-map (f έΙα g) ~ έβφ-map f έΙα έβφ-map g
έβφ-έΙα f g (modέβφ x) = refl
}
%```
}

\subtree[stt-0052]{
\taxon{Theorem}
\title{Flat is a comonad}

\p{Similarly, we can define the counit and comultiplication functions that
make #{\modflat{-}} into a comonad.}

%```agda
\agda{
╬╡έβφ : έΙΑ {@έβφ ΏζΥν} {@έβφ A : Type ΏζΥν} έΗΤ έθρέβφ| A έθσ έΗΤ A
╬╡έβφ (modέβφ x) = x

╬╡έβφ-natural : έΙΑ {@έβφ ΏζΥν ΏζΥξ} {@έβφ A : Type ΏζΥν} {@έβφ B : Type ΏζΥξ} {@έβφ f : A έΗΤ B}
             έΗΤ ╬╡έβφ  έΙα έβφ-map f ~ f έΙα ╬╡έβφ
╬╡έβφ-natural (modέβφ x) = refl

έθρέβφέβφ|_έθσ : έΙΑ {@έβφ ΏζΥν} έΗΤ (@έβφ _ : Type ΏζΥν) έΗΤ Type ΏζΥν
έθρέβφέβφ| A έθσ = έθρέβφ| έθρέβφ| A έθσ έθσ

comult : έΙΑ {@έβφ ΏζΥν} {@έβφ A : Type ΏζΥν} έΗΤ έθρέβφ| A έθσ έΗΤ έθρέβφέβφ| A έθσ
comult (modέβφ x) = modέβφ (modέβφ x)
}
%```
}

\subtree[stt-0054]{
\title{Flat is an idempotent comonad}
\taxon{Theorem}

\p{We show that \code{comult} is an equivalence.}

%```agda
\agda{
╬╝ : έΙΑ {@έβφ ΏζΥν} {@έβφ A : Type ΏζΥν}
    έΗΤ έθρέβφέβφ| A έθσ έΗΤ έθρέβφ| A έθσ
╬╝ = ╬╡έβφ

comult-is-equiv : έΙΑ {@έβφ ΏζΥν} {@έβφ A : Type ΏζΥν} έΗΤ is-equiv (comult {A = A})
comult-is-equiv .is-equiv.qiso .fst = ╬╝
comult-is-equiv .is-equiv.qiso .snd .fst (modέβφ _) = refl
comult-is-equiv .is-equiv.qiso .snd .snd (modέβφ (modέβφ x)) = refl
comult-is-equiv .is-equiv.coherent (modέβφ x) = refl

έβφ-idem : έΙΑ {@έβφ ΏζΥν} {@έβφ A : Type ΏζΥν}
         έΗΤ έθρέβφέβφ| A έθσ έΚΔ έθρέβφ| A έθσ
έβφ-idem = mkέΚΔ ╬╝ (is-equivέΒ╗┬╣ comult-is-equiv)
}
%```
}

\subtree[stt-0057]{
\taxon{Definition}
\title{Crisp Identity Induction}
\date{2025-06-10}

\p{We can define an induction principal for crisp identity types, defined for
families #{P : \Pi_{(a :^{\flat} A)} (a = b) \to \UU}}

%```agda
\agda{
Jέβφ : έΙΑ {@έβφ ΏζΥν} {ΏζΥξ} {@έβφ A : Type ΏζΥν} {@έβφ a : A}
       (P : (@έβφ b : A) έΗΤ (p : a Ύ╝ζ b) έΗΤ Type ΏζΥξ)
     έΗΤ P a refl
     έΗΤ {@έβφ b : A} έΗΤ (@έβφ p : a Ύ╝ζ b)
     έΗΤ P b p
Jέβφ P pr refl = pr

_ : έΙΑ {@έβφ ΏζΥν} {@έβφ A : Type ΏζΥν} {@έβφ a b : A}
       έΗΤ modέβφ a Ύ╝ζ modέβφ b
       έΗΤ έθρέβφ| a Ύ╝ζ b έθσ
_ = ╬╗ p έΗΤ J (╬╗ where (modέβφ x) p' έΗΤ έθρέβφ| _ Ύ╝ζ x έθσ) (modέβφ refl) p
}
%```

\p{This can be used to define the functoriality of functions with respect to
crisp-identity types.}

%```agda
\agda{
apέβφ : έΙΑ {@έβφ ΏζΥν} {ΏζΥξ} {@έβφ A : Type ΏζΥν} {B : Type ΏζΥξ}
      (f : @έβφ A έΗΤ B) έΗΤ {@έβφ x y : A} έΗΤ @έβφ x Ύ╝ζ y
      έΗΤ f x Ύ╝ζ f y
apέβφ f refl = refl

_ : έΙΑ {@έβφ ΏζΥν} {ΏζΥξ} {@έβφ A : Type ΏζΥν} {B : Type ΏζΥξ}
      (f : @έβφ A έΗΤ B) έΗΤ {@έβφ x y : A} έΗΤ @έβφ x Ύ╝ζ y
      έΗΤ f x Ύ╝ζ f y
_ = ╬╗ f έΗΤ Jέβφ (╬╗ b _ έΗΤ f _ Ύ╝ζ f b) refl
}
%```

\p{We sometimes call the above construction the weak crisp induction principal
in contrast with the following stronger induction principal:
}
%```agda
\agda{
J-crisp-ind : έΙΑ (@έβφ ΏζΥν ΏζΥξ : Level) έΗΤ Type (lsuc (ΏζΥν έΛΦ ΏζΥξ))
J-crisp-ind ΏζΥν ΏζΥξ = έΙΑ {@έβφ A : Type ΏζΥν} {@έβφ a : A}
                     (@έβφ P : (@έβφ b : A) έΗΤ (@έβφ p : a Ύ╝ζ b) έΗΤ Type ΏζΥξ)
                    έΗΤ @έβφ P a refl
                    έΗΤ {@έβφ b : A} έΗΤ (@έβφ p : a Ύ╝ζ b)
                    έΗΤ P b p
}
%```

\p{With just the flat modality, the full crisp induction principal is
not derivable in base MTT. \citek{DG21} However, as we show in \ref{tot-000C},
we can use the #{\sharp} modality, and its adjointness with #{\flat} to derive
this stronger crisp induction principal}
}


\subtree[stt-0055]{
\taxon{Construction}

\p{Using induction on #{\flat} and this (weak) crisp identity induction
principal, we can define a map
#{\modflat{a = b} \to \mod_{\flat}(a) Ύ╝ζ \mod_{\flat}(b)}. In analogy to function
types, we call this map #{\textsf{mapply}_\flat}.}

%```agda
\agda{
mapplyέβφ : έΙΑ {@έβφ ΏζΥν} {@έβφ A : Type ΏζΥν} {@έβφ a b : A}
       έΗΤ έθρέβφ| a Ύ╝ζ b έθσ
       έΗΤ modέβφ a Ύ╝ζ modέβφ b
mapplyέβφ (modέβφ refl) = refl

_ : έΙΑ {@έβφ ΏζΥν} {@έβφ A : Type ΏζΥν} {@έβφ a b : A}
       έΗΤ έθρέβφ| a Ύ╝ζ b έθσ
       έΗΤ modέβφ a Ύ╝ζ modέβφ b
_ = έβφ-ind _ (apέβφ modέβφ)
}
%```
}


\subtree{
\taxon{Lemma}

\p{Equivalences #{f : A \toeq B} induce equivalences
#{\flat f : \modflat{A} \toeq \modflat{B}}}

%```agda
\agda{
έβφ-map-is-equiv
  : έΙΑ {@έβφ ΏζΥν ΏζΥξ} {@έβφ A : Type ΏζΥν} {@έβφ B : Type ΏζΥξ} {@έβφ f : A έΗΤ B}
    έΗΤ @έβφ is-equiv f έΗΤ is-equiv (έβφ-map f)
έβφ-map-is-equiv fe = is-equivέΗΡqiso
  ( έβφ-map (bwd fe)
  , (╬╗ where (modέβφ x) έΗΤ apέβφ modέβφ (╬╖ fe x))
  , (╬╗ where (modέβφ x) έΗΤ apέβφ modέβφ (╬╡ fe x)))
  where open is-equiv
}
%```
}

\subtree[stt-0053]{
\title{Flat commutes with #{\Sigma} and #{1}}
\taxon{Theorem}

\p{First we show that #{\flat} commutes with #{1}, or in other words
#{\modflat{1}} is a [singleton](stt-0006). Similarly we can show that
#{\modflat{-}} preserves all singletons.}

%```agda
\agda{
έβφΏζθβ-is-single : is-singleton έθρέβφ| Ώζθβ έθσ
έβφΏζθβ-is-single = mk-singl (modέβφ tt) ╬╗ where (modέβφ tt) έΗΤ refl

έβφ-is-single : έΙΑ {@έβφ ΏζΥν} {@έβφ A : Type ΏζΥν}
              έΗΤ @έβφ is-singleton A έΗΤ is-singleton έθρέβφ| A έθσ
έβφ-is-single (mk-singl c p) = mk-singl (modέβφ c) ╬╗ where
  (modέβφ x) έΗΤ mapplyέβφ (modέβφ (p x))
}
%```

\p{Given a crisp type #{A},
and a family of types #{B} crisply over #{A}, we can define the
dependent flat-sum, written #{\Sigma_{a :^\flat A} B(a)}. Defined
as #{\Sigma_{x : \modflat{A}}\flat\textrm{-rec}(\_,B,x)}.}

%```agda
\agda{
╬μέβφ : έΙΑ {@έβφ ΏζΥν ΏζΥξ} (@έβφ A : Type ΏζΥν) (B : @έβφ A έΗΤ Type ΏζΥξ)
     έΗΤ Type (ΏζΥν έΛΦ ΏζΥξ)
╬μέβφ A B = ╬μ έθρέβφ| A έθσ (έβφ-ind _ B)

syntax ╬μέβφ A (╬╗ x έΗΤ B) = ╬μ[έβφ x έΙ╢ A ] B

sndέβφ : έΙΑ {@έβφ ΏζΥν ΏζΥξ} {@έβφ A : Type ΏζΥν} {B : @έβφ A έΗΤ Type ΏζΥξ}
       έΗΤ (x : ╬μέβφ A B) έΗΤ έβφ-ind _ B (x .fst)
sndέβφ = snd
}
%```

\p{We now show #{\flat} commutes with #{\Sigma} in the sense that
#{\Sigma_{a :^\flat A} \modflat{B(a)}} is equivalent to
#{\modflat{\Sigma_{a : A}B(a)}}}

%```agda
\agda{
έβφ-╬μ : έΙΑ {@έβφ ΏζΥν ΏζΥξ} {@έβφ A : Type ΏζΥν} (@έβφ B : A έΗΤ Type ΏζΥξ)
      έΗΤ ╬μ[έβφ x έΙ╢ A ] έθρέβφ| B x έθσ
      έΗΤ έθρέβφ| ╬μ A B έθσ
έβφ-╬μ B (modέβφ a , modέβφ b) = modέβφ (a , b)

έβφ-╬μ' : έΙΑ {@έβφ ΏζΥν ΏζΥξ} {@έβφ A : Type ΏζΥν} (@έβφ B : A έΗΤ Type ΏζΥξ)
      έΗΤ έθρέβφ| ╬μ A B έθσ
      έΗΤ ╬μ[έβφ x έΙ╢ A ] έθρέβφ| B x έθσ
έβφ-╬μ' B (modέβφ (a , b)) = (modέβφ a , modέβφ b)

έβφ-comm╬μ : έΙΑ {@έβφ ΏζΥν ΏζΥξ} {@έβφ A : Type ΏζΥν} (@έβφ B : A έΗΤ Type ΏζΥξ)
                 έΗΤ (╬μ[έβφ x έΙ╢ A ] έθρέβφ| B x έθσ) έΚΔ έθρέβφ| ╬μ A B έθσ
έβφ-comm╬μ P ._έΚΔ_.fwd = έβφ-╬μ P
έβφ-comm╬μ P ._έΚΔ_.has-is-eqv .is-equiv.qiso .fst = έβφ-╬μ' P
έβφ-comm╬μ P ._έΚΔ_.has-is-eqv .is-equiv.qiso .snd .fst (modέβφ a , modέβφ b) = refl
έβφ-comm╬μ P ._έΚΔ_.has-is-eqv .is-equiv.qiso .snd .snd (modέβφ (a , b)) = refl
έβφ-comm╬μ P ._έΚΔ_.has-is-eqv .is-equiv.coherent (modέβφ a , modέβφ b) = refl
}
%```
}

open import Foundations.FibrePath
open import Foundations.EquivSingleton
open import Foundations.SigmaPath
open import Foundations.SigmaProperties
open import Foundations.FunextUnivalence
open import Foundations.PropExt
open import Foundations.PropClosure
open import Foundations.Unit
open import Foundations.Empty
open import Foundations.Lift
open import Foundations.Embedding
open import Foundations.PropMapEmbedding
}
% ```

% ```agda
\agda{
is-subtype : вҲҖ {рқ“Ө рқ“Ҙ} {A : Type рқ“Ө} (P : A вҶ’ Type рқ“Ҙ) вҶ’ Type (рқ“Ө вҠ” рқ“Ҙ)
is-subtype P = вҲҖ x вҶ’ is-prop (P x)

record Subtype {рқ“Ө} (A : Type рқ“Ө) рқ“Ҙ : Type (рқ“Ө вҠ” lsuc рқ“Ҙ) where
  constructor mk-subtype
  field
    {family} : A вҶ’ Type рқ“Ҙ
    has-is-subtype : is-subtype family

  ОЈМғ : Type (рқ“Ө вҠ” рқ“Ҙ)
  ОЈМғ = ОЈ A family

  ОЈМғ-ПҖ : ОЈМғ вҶ’ A
  ОЈМғ-ПҖ = fst

  ОЈМғ-ПҖ-is-prop-map : is-prop-map ОЈМғ-ПҖ
  ОЈМғ-ПҖ-is-prop-map a = is-propвҶҗequiv-to-prop
               (fibre-straighten _ _ eвҒ»В№)
               (has-is-subtype a)

  ОЈМғ-ПҖ-is-embedding : is-embedding ОЈМғ-ПҖ
  ОЈМғ-ПҖ-is-embedding = is-embeddingвҶҗis-prop-map ОЈМғ-ПҖ-is-prop-map

  subtype-path : вҲҖ {x y : ОЈМғ} вҶ’ (ОЈМғ-ПҖ x пјқ ОЈМғ-ПҖ y) вҶ’ x пјқ y
  subtype-path = is-equiv.bwd ОЈМғ-ПҖ-is-embedding

_вҲҲ_ : вҲҖ {рқ“Ө рқ“Ҙ} {A : Type рқ“Ө} вҶ’ A вҶ’ Subtype A рқ“Ҙ вҶ’ Type рқ“Ҙ
a вҲҲ S = S .Subtype.family a

вҲҲ-is-prop : вҲҖ {рқ“Ө рқ“Ҙ} {A : Type рқ“Ө} вҶ’ (S : Subtype A рқ“Ҙ)
            вҶ’ is-subtype (_вҲҲ S)
вҲҲ-is-prop S = S .Subtype.has-is-subtype
}
% ```

% ```agda
\agda{
module _ {рқ“Ө} {A : Type рқ“Ө} {рқ“Ҙ} (P : Subtype A рқ“Ҙ) where
  open Subtype P
}
% ```

\subtree[stt-007N]{
\title{Equivalent subtypes}
\taxon{Definition}

\p{We say two subtypes #{S} and #{K} are equal if they contain the same
types, that is: #{\forall x, x \in S \iff x \in K}.}


%```agda
\agda{
Subtype-equiv : вҲҖ {рқ“Ө рқ“Ҙ рқ“Ҙ'} {A : Type рқ“Ө}
                  (S : Subtype A рқ“Ҙ) (K : Subtype A рқ“Ҙ')
                вҶ’ Type (рқ“Ө вҠ” рқ“Ҙ вҠ” рқ“Ҙ')
Subtype-equiv S K = вҲҖ a вҶ’ ((a вҲҲ S) вҮ” (a вҲҲ K))

Subtype-equivвҶҗId : вҲҖ {рқ“Ө рқ“Ҙ} {A : Type рқ“Ө}
                  {S : Subtype A рқ“Ҙ} {K : Subtype A рқ“Ҙ}
                 вҶ’ S пјқ K вҶ’ Subtype-equiv S K
Subtype-equivвҶҗId = (logicalвҶҗId вҲҳ_) вҲҳ happly вҲҳ ap Subtype.family
}
%```
}

\subtree[stt-2082]{
\title{Join semi-lattice structure on subtypes}
\taxon{Construction}
\p{We can construct minimal and maximal subtypes as well as
 intersection of subtypes. In order to construct the union of
 subtypes, we will require a propositional truncation, so leave this
 for later.}

%```agda
\agda{
ULift-subtype : вҲҖ {рқ“Ө рқ“Ҙ} рқ“Ұ {A : Type рқ“Ө}
                вҶ’ Subtype A рқ“Ҙ вҶ’ Subtype A (рқ“Ҙ вҠ” рқ“Ұ)
ULift-subtype рқ“Ұ {A} S .Subtype.family a = ULift рқ“Ұ (a вҲҲ S)
ULift-subtype рқ“Ұ {A} S .Subtype.has-is-subtype a
  = is-prop-ULift (вҲҲ-is-prop S a)

module SubtypeLattice {рқ“Ө} (A : Type рқ“Ө) where
   _вҲ©_ : вҲҖ {рқ“Ҙ рқ“Ұ} вҶ’ Subtype A рқ“Ҙ вҶ’ Subtype A рқ“Ұ вҶ’ Subtype A _
   (P вҲ© Q) .Subtype.family a = (a вҲҲ P) Г— (a вҲҲ Q)
   (P вҲ© Q) .Subtype.has-is-subtype a
     = is-prop-ОЈ (вҲҲ-is-prop P a) О» _ вҶ’ вҲҲ-is-prop Q a

   вҠӨ : Subtype A lzero
   вҠӨ .Subtype.family _ = рқҹҷ
   вҠӨ .Subtype.has-is-subtype x _ _ = refl

   вҠҘ : Subtype A lzero
   вҠҘ .Subtype.family _ = вҲ…
   вҠҘ .Subtype.has-is-subtype a ()
}
%```
}

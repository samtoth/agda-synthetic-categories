\agda{
module Foundations.IdentitySystem where

open import Foundations.Universes
open import Foundations.Sigma
open import Foundations.Currying
open import Foundations.SigmaIdentity
open import Foundations.SigmaProperties
open import Foundations.FibrewiseEquivalences
open import Foundations.Identity
open import Foundations.DependentIdentity
open import Foundations.Functions
open import Foundations.FunctionInverses
open import Foundations.Homotopy
open import Foundations.Singletons
open import Foundations.SingletonClosure
open import Foundations.CoherentEquivalences
open import Foundations.QuasiEquivalences
open import Foundations.TotalEquiv
open import Foundations.EquivOfSingleton
open import Foundations.SingletonFibres
open import Foundations.EquivHomotopy
open import Foundations.EquivSingleton

module _ {ūĚď§} (A : Type ūĚď§) (a‚āÄ : A) where
  Reflexive-ppred : ‚ąÄ ūĚď• ‚Üí Type (ūĚď§ ‚äĒ lsuc ūĚď•)
  Reflexive-ppred ūĚď• = ő£[ R ‚ą∂ (A ‚Üí Type ūĚď•) ] R a‚āÄ

  SingR : ‚ąÄ {ūĚď•} (R : A ‚Üí A ‚Üí Type ūĚď•) ‚Üí Type (ūĚď§ ‚äĒ ūĚď•)
  SingR R = ő£[ b ‚ą∂ A ] R a‚āÄ b

  SingR' : ‚ąÄ {ūĚď•} (R : A ‚Üí A ‚Üí Type ūĚď•) ‚Üí Type (ūĚď§ ‚äĒ ūĚď•)
  SingR' R = ő£[ b ‚ą∂ A ] R b a‚āÄ


idtoppred
  : ‚ąÄ {ūĚď§ ūĚď•} {A : Type ūĚď§} {a : A} ‚Üí (R : Reflexive-ppred A a ūĚď•)
    ‚Üí ‚ąÄ b ‚Üí (a ÔľĚ b) ‚Üí R .fst b
idtoppred (R , R‚āÄ) _ p = tr _ p R‚āÄ

is-identity-system-at
  : ‚ąÄ {ūĚď§ ūĚď•} ‚Üí (A : Type ūĚď§) ‚Üí (a‚āÄ : A)
    ‚Üí Reflexive-ppred A a‚āÄ ūĚď•
    ‚Üí Type (ūĚď§ ‚äĒ ūĚď•)
is-identity-system-at A a‚āÄ (R , R‚āÄ) = is-fibrewise-equiv (idtoppred (R , R‚āÄ))


record Identity-system {ūĚď§} (A : Type ūĚď§) ūĚď• : Type (ūĚď§ ‚äĒ lsuc ūĚď•) where
  field
    IdS  : A ‚Üí A ‚Üí Type ūĚď•
    IdS‚ÜźId : ‚ąÄ {a b} ‚Üí a ÔľĚ b ‚Üí IdS a b

  IdS‚āÄ : ‚ąÄ {a} ‚Üí IdS a a
  IdS‚āÄ = IdS‚ÜźId refl

  Rpp : ‚ąÄ a ‚Üí Reflexive-ppred A a ūĚď•
  Rpp a = (IdS a , IdS‚āÄ)

  field
    has-is-ids : ‚ąÄ a b ‚Üí is-equiv (IdS‚ÜźId {a} {b})

  module ids-eqv {a b} = is-equiv (has-is-ids a b)

  open ids-eqv public renaming
    (bwd to Id‚ÜźIdS
    ; őĶ to IdS‚ÜźId‚ÜźIdS
    ; ő∑ to Id‚ÜźIdS‚ÜźId) using ()

mk-identity-system
  : ‚ąÄ {ūĚď§ ūĚď•} {A : Type ūĚď§} ‚Üí (I : A ‚Üí A ‚Üí Type ūĚď•)
    ‚Üí (‚ąÄ {x y} ‚Üí I x y ‚ČÉ (x ÔľĚ y))
    ‚Üí Identity-system A ūĚď•
mk-identity-system I eq = ids where
  module eq {x y} = _‚ČÉ_ (eq {x} {y})

  ids : Identity-system _ _
  ids .Identity-system.IdS = I
  ids .Identity-system.IdS‚ÜźId = eq.bwd
  ids .Identity-system.has-is-ids x y = is-equiv‚ĀĽ¬Ļ eq.has-is-eqv


module IdSReasoning {ūĚď§ ūĚď•} {A : Type ūĚď§} (Id : Identity-system A ūĚď•) where
  open Identity-system Id

  SingS : A ‚Üí Type (ūĚď§ ‚äĒ ūĚď•)
  SingS a = SingR A a IdS

  SingS' : A ‚Üí Type (ūĚď§ ‚äĒ ūĚď•)
  SingS' a = SingR' A a IdS

  tr‚Üźidtopred : ‚ąÄ {a b : A} ‚Üí (p : a ÔľĚ b) ‚Üí tr _ p (IdS‚āÄ {a}) ÔľĚ IdS‚ÜźId p
  tr‚Üźidtopred refl = refl

  tr‚Üźidtopred' : ‚ąÄ {a b : A} ‚Üí (p : a ÔľĚ b) ‚Üí tr (őĽ x ‚Üí IdS x b) (sym p) (IdS‚āÄ {b}) ÔľĚ IdS‚ÜźId p
  tr‚Üźidtopred' refl = refl

  SingS-is-single : ‚ąÄ a ‚Üí is-singleton (SingS a)
  SingS-is-single a = mk-singl (a , IdS‚āÄ) I where
    I : (x : SingS a) ‚Üí (a , IdS‚āÄ) ÔľĚ x
    I (b , p) = ő£-path‚Üí (Id‚ÜźIdS p , tr‚Üźidtopred (Id‚ÜźIdS p) ‚ąô IdS‚ÜźId‚ÜźIdS p)

  SingS-is-single' : ‚ąÄ a ‚Üí is-singleton (SingS' a)
  SingS-is-single' a = mk-singl (a , IdS‚āÄ) I where
    I : (x : SingS' a) ‚Üí (a , IdS‚āÄ) ÔľĚ x
    I (b , p) = ő£-path‚Üí (sym (Id‚ÜźIdS p) , tr‚Üźidtopred' (Id‚ÜźIdS p) ‚ąô IdS‚ÜźId‚ÜźIdS p)

  Id‚ČÉIdS : ‚ąÄ {a b} ‚Üí (a ÔľĚ b) ‚ČÉ IdS a b
  Id‚ČÉIdS = (mk‚ČÉ IdS‚ÜźId (has-is-ids _ _))

  IdS‚ČÉId : ‚ąÄ {a b} ‚Üí IdS a b ‚ČÉ (a ÔľĚ b)
  IdS‚ČÉId = mk‚ČÉ Id‚ÜźIdS (is-equiv‚ĀĽ¬Ļ (has-is-ids _ _))

  opaque
    IdSJ
      : ‚ąÄ {ūĚď¶} {a} (P : SingS a ‚Üí Type ūĚď¶)
        ‚Üí (P‚āÄ : P (a , IdS‚āÄ)) ‚Üí ‚ąÄ {b} (p : IdS a b)
        ‚Üí P (_ , p)
    IdSJ P p‚āÄ p = tr id
                   (ap P (SingS-is-single _ .central (_ , p)))
                   p‚āÄ

    IdSJ-refl
      : ‚ąÄ {ūĚď¶} {a} (P : SingS a ‚Üí Type ūĚď¶)
        ‚Üí {P‚āÄ : P (a , IdS‚āÄ)}
        ‚Üí IdSJ P P‚āÄ IdS‚āÄ ÔľĚ P‚āÄ
    IdSJ-refl {a = a} P {P‚āÄ}
      = IdSJ P P‚āÄ IdS‚āÄ                                 ÔľĚ‚ü®‚ü©
        tr id (ap P (SingS-is-single _ .central _)) P‚āÄ ÔľĚ‚ü® ap (őĽ p ‚Üí tr id (ap P p) P‚āÄ) lem ‚ü©
        tr id (ap P refl) P‚āÄ                           ÔľĚ‚ü®‚ü©
        P‚āÄ ‚ąé  where

      lem : SingS-is-single a .central (_ , IdS‚āÄ) ÔľĚ refl
      lem = is-prop‚Üźis-single (ÔľĚ-is-single (SingS-is-single a) _ _) _ _

  trS : ‚ąÄ {ūĚď¶} {B : A ‚Üí Type ūĚď¶} {a b : A} (p : IdS a b) ‚Üí B a ‚Üí B b
  trS {_} {B} p ba = IdSJ (B ‚ąė fst) ba p

  ő£-singS
    : ‚ąÄ {ūĚď¶} {a' : A} {B : (a : A) ‚Üí IdS a a' ‚Üí Type ūĚď¶}
      ‚Üí ő£ A (őĽ a ‚Üí ő£ (IdS a a') őĽ p ‚Üí B a p) ‚ČÉ B a' IdS‚āÄ
  ő£-singS {_} {a'} {B} = ő£-assoc e‚ĀĽ¬Ļ ‚ąô‚ČÉ ő£-singl (SingS-is-single' a') (a' , IdS‚āÄ)

  ő£-singS'
    : ‚ąÄ {ūĚď¶} {a' : A} {B : (a : A) ‚Üí IdS a' a ‚Üí Type ūĚď¶}
      ‚Üí ő£ A (őĽ a ‚Üí ő£ (IdS a' a) őĽ p ‚Üí B a p) ‚ČÉ B a' IdS‚āÄ
  ő£-singS' {_} {a'} {B} = ő£-assoc e‚ĀĽ¬Ļ ‚ąô‚ČÉ ő£-singl (SingS-is-single a') (a' , IdS‚āÄ)


-- fundamental theorem of Identity types
fundamental-Id
  : ‚ąÄ {ūĚď§ ūĚď•} {A : Type ūĚď§} {a‚āÄ}
    ‚Üí (R : A ‚Üí Type ūĚď•)
    ‚Üí is-singleton (ő£[ b ‚ą∂ A ] R b)
    ‚Üí (f : ‚ąÄ b ‚Üí a‚āÄ ÔľĚ b ‚Üí R b)
    ‚Üí is-fibrewise-equiv f
fundamental-Id {a‚āÄ = a‚āÄ} R Sing-sing f
  = is-fibrewise-equiv‚Üźis-total-equiv
             (is-equiv‚Üźsingle-to-prop Sing-is-singleton
                                      (is-prop‚Üźis-single Sing-sing)
                                      (total-map f))

fundamental-Id‚ĀĽ¬Ļ
  : ‚ąÄ {ūĚď§ ūĚď•} {A : Type ūĚď§} {a‚āÄ}
      (R : A ‚Üí Type ūĚď•)
    ‚Üí is-singleton (ő£[ b ‚ą∂ A ] R b)
    ‚Üí ((b : A) ‚Üí a‚āÄ ÔľĚ b ‚Üí R b)
    ‚Üí {b : A} ‚Üí R b ‚Üí a‚āÄ ÔľĚ b
fundamental-Id‚ĀĽ¬Ļ R tor f {b} = is-equiv.bwd (fundamental-Id R tor f b)

remove-singleton-structure
  : ‚ąÄ {ūĚď§ ūĚď• ūĚď¶} {A : Type ūĚď§} {B : A ‚Üí Type ūĚď•}
      {Ra : A ‚Üí Type ūĚď¶}
    ‚Üí is-singleton  (ő£ A Ra)
    ‚Üí ((a , _) : ő£ A Ra)
    ‚Üí (ő£[ (a , b) ‚ą∂ ő£ A B ] Ra a) ‚ČÉ B a
remove-singleton-structure ars a
  = ő£-assoc
  ‚ąô‚ČÉ ő£-ap-‚ČÉ (őĽ _ ‚Üí √ó-swap)
  ‚ąô‚ČÉ ő£-assoc e‚ĀĽ¬Ļ
  ‚ąô‚ČÉ ő£-singl ars a

-- TODO: Find special place for this
--    creds to Egbert/agda-unimath
--  The idea is that we have some type of the form ő£ A ...,
--   given a basepoint (a‚āÄ,b‚āÄ), the partially applied equality type
--   ('SingR') will have the structure, ő£( (a‚āĀ,b‚āĀ) : ő£ A B) ő£ (R a‚āÄ a‚āĀ) ....
--   It's clear then, that if ő£ A (R a‚āÄ) is singleton and recursively
--   if ő£ b (R b‚āÄ) is a singleton, then the whole thing is. And this is pretty
--   handy for defining identity system instances
is-singleton-structure‚Üźparts
  : ‚ąÄ {ūĚď§ ūĚď• ūĚď¶ ūĚďú} {A : Type ūĚď§} {B : A ‚Üí Type ūĚď•}
      {Ra : A ‚Üí Type ūĚď¶} {Rb : (a : A) ‚Üí B a ‚Üí Ra a ‚Üí Type ūĚďú}
    ‚Üí is-singleton (ő£ A Ra)
    ‚Üí (t@(a , c) : ő£ A Ra)
    ‚Üí is-singleton (ő£[ b ‚ą∂ B a ] Rb a b c)
    ‚Üí is-singleton (ő£[ t@(a , b) ‚ą∂ (ő£ A B)] ő£ (Ra a) (Rb a b))
is-singleton-structure‚Üźparts aR t@(a , c) bR
  = is-single‚Üźequiv-to-single ő£-interchange (ő£-is-single' aR t bR)


ap-equiv‚Üźequiv : ‚ąÄ {ūĚď§ ūĚď•} {A : Type ūĚď§} {B : Type ūĚď•} {f : A ‚Üí B} {x y : A} ‚Üí
               is-equiv f ‚Üí is-equiv (ap f)
ap-equiv‚Üźequiv {A = A} {f = f} {x} {y} h
  = fundamental-Id _ sing (őĽ a ‚Üí ap f) y where abstract
  sing : is-singleton (ő£ A (őĽ z ‚Üí f x ÔľĚ f z))
  sing = is-single‚Üźsection-single (total-map (őĽ a ‚Üí sym))
                                  ( (őĽ (a , p) ‚Üí (a , (sym p)))
                                  , (őĽ x ‚Üí ő£-path‚Üí (refl , sym-sym)))
                                  (has-singleton-fibres‚Üźis-equiv h (f x))
}

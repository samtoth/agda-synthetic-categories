\subtree[stt-00DY]{
\taxon{Definition}
\title{Disjunctive types}

\p{
The generic interval is not necessarily \em{disjunctive}, in the sense that
for all #{i} and #{j} such that #{(i ∨ j) = 1} we would have #{i = 1} or
#{j = 1}. Instead, we can speak of particular types which \em{'see'} the
interval as being disjunctive. This can be made precise by asking for types
which are [null](stt-005G) with respect to the family of propositions
#{(i = 1) ∨ (j = 1)} for all #{i} and #{j} such that #{(i ∨ j) = 1}. Let #{∨²}
be the type of elements #{i} and #{j} such that #{(i ∨ j) = 1}.
}

%```agda
\agda{
∨² : Type 𝓘
∨² = Σ (Δ¹ × Δ¹) (λ (i , j) → (i ∨ j ＝ i1))

fam-disjunctive : Δ¹ × Δ¹ → Type 𝓘
fam-disjunctive (i , j) = (i ＝ i1) * (j ＝ i1)

fam-is-disjunctive : ∨² → Type 𝓘
fam-is-disjunctive = fam-disjunctive ∘ fst

is-disjunctive : ∀ {𝓤} → Type 𝓤 → Type (𝓘 ⊔ 𝓤)
is-disjunctive = is-null fam-is-disjunctive
}
%```

\p{
By virtue of being defined in terms of nullification at a proposition, we
know that disjunctive types form a lex [#{\Sigma}-closed](stt-006E)
[reflective subuniverse](stt-0065).
}

%```agda
\agda{
Disjunctive-SubU : ∀ {𝓤} → SubU 𝓤 (𝓤 ⊔ 𝓘)
Disjunctive-SubU = Null-SubU fam-is-disjunctive _

Disjunctive-gSubU : gSubU (_⊔ 𝓘)
Disjunctive-gSubU = Null-gSubU fam-is-disjunctive

Disjunctive-is-globally-reflective
  : is-globally-reflective Disjunctive-gSubU
Disjunctive-is-globally-reflective = Null-globally-reflective

Disjunctive-gRSubU : gRSubU (_⊔ 𝓘)
Disjunctive-gRSubU .gRSubU.GS = Disjunctive-gSubU
Disjunctive-gRSubU .gRSubU.has-is-globally-reflective = Disjunctive-is-globally-reflective

open gSubU Disjunctive-gSubU public using () renaming
  ( ∈S←equiv to is-disjunctive←equiv)

open gReflectiveClosure Disjunctive-gRSubU public using () renaming
  ( Π∈S to Π-is-disjunctive
  ; ULift∈S to ULift-is-disjunctive
  ; 𝟙∈S to 𝟙-is-disjunctive
  ; ∈S←is-singleton to is-disjunctive←is-singleton
  ; ∈S←retract to is-disjunctive←retract
  ; ~∈S to ~-is-disjunctive
  ; Pullback∈S to Pullback-is-disjunctive
  ; ＝∈S to ＝-is-disjunctive
  ; fibre∈S to fibre-is-disjunctive
  ; ×∈S to ×-is-disjunctive
  ; retract∈S to retract-is-disjunctive
  ; biinv∈S to biinv-is-disjunctive
  ; ≃∈S to ≃-is-disjunctive
  ; Equaliser∈S to Equaliser-is-disjunctive
  ; Seq-lim∈S to Seq-lim-is-disjunctive
  ; preidempotent-map∈S to preidempotent-map-is-disjunctive
  ; qidempotent-map∈S to qidempotent-map-is-disjunctive
  ; Retracts∈S to Retracts-is-disjunctive)

Σ-is-disjunctive : is-globally-Σ-closed Disjunctive-gSubU
Σ-is-disjunctive = Null-globally-Σ-closed

module Disj where
  open gRSubUInduction Disjunctive-gRSubU Σ-is-disjunctive public
  open gSubU Disjunctive-gSubU public
  open gRSubU Disjunctive-gRSubU public
  open gReflectiveClosure Disjunctive-gRSubU public
}
%```

%```agda
\agda{
Λ[2,2]-∨-rec : ∀ {𝓤} {A : Type 𝓤} {i j} → (i ∨ j ＝ i1) → is-disjunctive A
          → (l : i ＝ i1 → A) → (r : j ＝ i1 → A)
          → ((pi : i ＝ i1) (pj : j ＝ i1) → l pi ＝ r pj) → A
Λ[2,2]-∨-rec {i = i} {j} p disj-A l r eq
  = is-equiv.bwd
  (disj-A ((i , j) , p))
  (cogap (mk-cocone l r (λ (p , q) → eq p q)))

Λ[2,2]-∨-rec' : ∀ {𝓤} {A : Type 𝓤} {i j} → (p : i ∨ j ＝ i1)
              → is-disjunctive A
              → (l : i ＝ i1 → A) → (r : j ＝ i1 → A)
              → ((q : i ＝ j) → l (=∨←= q ∙ p) ＝ r ((=∨'←= (sym q)) ∙ p)) → A
Λ[2,2]-∨-rec' {i = i} {j} p disj-A l r eq
  = Λ[2,2]-∨-rec p disj-A l r (λ pi pj
    → ap l (is-prop-separated _ _ _ _)
    ∙ eq (pi ∙ sym pj)
    ∙ ap r (is-prop-separated _ _ _ _))

Λ[2,2]-∨-rec! : ∀ {𝓤} {A : Type 𝓤} i j → ⦃ p : i ∨ j ＝ i1 ⦄
              → is-disjunctive A
              → (l : ⦃ i ＝ i1 ⦄ → A) → (r : ⦃ j ＝ i1 ⦄ → A)
              → ((pi : i ＝ i1) (pj : j ＝ i1) → l ⦃ pi ⦄ ＝ r ⦃ pj ⦄)
              → A
Λ[2,2]-∨-rec! i j ⦃ p ⦄ disj-A l r
  = Λ[2,2]-∨-rec p disj-A (λ p → l ⦃ p ⦄) (λ q → r ⦃ q ⦄)
}
%```
}

\subtree[stt-00DT]{
\taxon{Definition}
\title{The outer horn #{Λ^2_2}}

\p{
We give a slightly nonstandard definition of the outer horn #{Λ^2_2} as the
subtype of the square consisting of elements #{(i,j)} such that
#{(i = 1) * (j = 1)}. Normally, it is defined as the subtype such that
#{(i = 1) * (i = j)}.
}

\p{
We show that #{Λ^2_2} is a subtype of #{∨²} by showing that
#{(i = 1) ∨ (j = 1)} implies #{(i ∨ j) = 1}, and hence #{Λ^2_2} is
equivalent to the type #{Σ_{(i\,j:Δ¹)}((i ∨ j = 1) ∧ ((i = 1) ∨ (j = 1)))}.
}

%```agda
\agda{
∨=1←fam-disjunctive : ∀ {i j} → fam-disjunctive (i , j) → (i ∨ j ＝ i1)
∨=1←fam-disjunctive {i = i} {j}
  = *-prop-rec
      (is-prop-separated _ _)
      (λ pi → ap (_∨ j) pi ∙ ∨-comm ∙ 1-coinit)
      (λ pj → ap (i ∨_) pj ∙ 1-coinit)

Λ[2,2]' : Type 𝓘
Λ[2,2]' = Σ ∨² fam-is-disjunctive

Λ[2,2] : Type 𝓘
Λ[2,2] = Σ (Δ¹ × Δ¹) fam-disjunctive

drop-join-proof
  : (ij : Δ¹ × Δ¹)
  → ((fst ij ∨ snd ij ＝ i1) × (fam-disjunctive ij))
  → fam-disjunctive ij
drop-join-proof _ = snd

drop-join-proof-is-equiv
  : (ij : Δ¹ × Δ¹) → is-equiv (drop-join-proof ij)
drop-join-proof-is-equiv (i , j)
  = is-equiv←inverse
      (is-prop-Σ
        (is-prop-separated _ _)
        (λ _ → *-is-prop (is-prop-separated _ _) (is-prop-separated _ _)))
      (*-is-prop (is-prop-separated _ _) (is-prop-separated _ _))
      (λ d → ∨=1←fam-disjunctive d , d)

Λ[2,2]←Λ[2,2]' : Λ[2,2]' → Λ[2,2]
Λ[2,2]←Λ[2,2]' = total-map drop-join-proof ∘ _≃_.fwd Σ-assoc

Λ[2,2]←Λ[2,2]'-is-equiv : is-equiv Λ[2,2]←Λ[2,2]'
Λ[2,2]←Λ[2,2]'-is-equiv
  = is-equiv-∘
      (is-total-equiv←is-fibrewise-equiv drop-join-proof-is-equiv)
      (_≃_.has-is-eqv Σ-assoc)

Λ[2,2]'≃Λ[2,2] : Λ[2,2]' ≃ Λ[2,2]
Λ[2,2]'≃Λ[2,2] = mk≃ Λ[2,2]←Λ[2,2]' Λ[2,2]←Λ[2,2]'-is-equiv

Λ[2,2]'←Λ[2,2] : Λ[2,2] → Λ[2,2]'
Λ[2,2]'←Λ[2,2] = _≃_.bwd Λ[2,2]'≃Λ[2,2]

Λ[2,2]-incl : Λ[2,2] → ∨²
Λ[2,2]-incl ((i , j) , d) = ((i , j) , ∨=1←fam-disjunctive d)
}
%```
}

\subtree[stt-00DU]{
\taxon{Definition}
\title{Upper located types}

\p{
We might say a type is \em{upper located} if it is local at the inclusion of
#{Σ_{(i\,j:Δ¹)}((i = 1) ∨ (j = 1))} into
#{Σ_{(i\,j:Δ¹)}(i ∨ j = 1)}. In other words, it sees the outer horn #{Λ^2_2}
as identical to the subset of the square whose join is #{1}.
}

%```agda
\agda{
is-upper-located : ∀ {𝓤} → Type 𝓤 → Type (𝓘 ⊔ 𝓤)
is-upper-located = is-local (point Λ[2,2]-incl)
}
%```
}

\subtree[stt-00DV]{
\title{Disjunctive types are upper located}
\taxon{Lemma}

\proof{
\p{
By sum-closure, disjunctive types are local at the inclusion of
#{Σ_{(i\,j:Δ¹)}((i ∨ j = 1) ∧ ((i = 1) ∨ (j = 1)))} into
#{Σ_{(i\,j:Δ¹)}(i ∨ j = 1)}, which is equivalent to the inclusion of #{Λ^2_2}
into #{∨²}.
}
}

%```agda
\agda{
disj-is-upper-located : ∀ {𝓤} {A : Type 𝓤}
                      → is-disjunctive A → is-upper-located A
disj-is-upper-located {_} {A} disj tt
  = orthogonal-type←is-arrow-equiv amap amap-is-eqv
      (orthogonal-type-total-map-!←is-null disj) where

  amap : Arrow-map (total-map (λ _ → !)) Λ[2,2]-incl
  amap .Arrow-map.top = Λ[2,2]←Λ[2,2]'
  amap .Arrow-map.bot = fst
  amap .Arrow-map.comm (((i , j) , p) , d)
    = Σ-path→ (refl , is-prop-separated _ _ _ _)

  amap-is-eqv : is-Arrow-equiv amap
  amap-is-eqv .fst = Λ[2,2]←Λ[2,2]'-is-equiv
  amap-is-eqv .snd = singleton-fst-is-equiv (λ _ → 𝟙-is-singleton)
}
%```
}

\subtree[stt-00DW]{
\title{Simplicial types are disjunctive}
\taxon{Lemma}

\p{
We call a type [simplicial](stt-00AB) if it is null at #{((i ≤ j) * (j ≤ i))}
for all #{i\,j:Δ¹}. We show that every simplicial type is disjunctive.
}

\proof{
\p{
If #{P} implies #{Q} then #{P}-null types are #{Q}-null, so it suffices to show
that #{((i ≤ j) * (j ≤ i))} implies #{i = 1} or #{j = 1} for all #{i} and #{j}
such that #{(i ∨ j) = 1}.
}
}

%```agda
\agda{
disj←simp-over-∨² : (x : ∨²)
                  → fam-is-simplicial (fst x) → fam-is-disjunctive x
disj←simp-over-∨² ((i , j) , p)
  = *-prop-rec
      (*-is-prop (is-prop-separated _ _) (is-prop-separated _ _))
      (λ ij → ι₂ (sym (≤-max ij) ∙ p))
      (λ ji → ι₁ (sym (≤-max ji) ∙ sym ∨-comm ∙ p))

disj→simp-over-∨² : (x : ∨²)
                  → fam-is-disjunctive x → fam-is-simplicial (fst x)
disj→simp-over-∨² ((i , j) , _)
  = *-prop-rec
      (*-is-prop ≤-is-prop ≤-is-prop)
      (λ pi → ι₂ (tr (j ≤_) (sym pi) ≤-top))
      (λ pj → ι₁ (tr (i ≤_) (sym pj) ≤-top))

disj←simp-over-∨²-is-equiv
  : (x : ∨²) → is-equiv (disj←simp-over-∨² x)
disj←simp-over-∨²-is-equiv x@((i , j) , _)
  = is-equiv←inverse
      (*-is-prop ≤-is-prop ≤-is-prop)
      (*-is-prop (is-prop-separated _ _) (is-prop-separated _ _))
      (disj→simp-over-∨² x)

simp-is-disjunctive : ∀ {𝓤} {A : Type 𝓤}
                    → is-simplicial A → is-disjunctive A
simp-is-disjunctive {_}{A} simp
  = is-null←is-local
      (is-local-equiv amap amap-is-eqv
        (is-local←is-null simp-over-∨²)) where

  simp-over-∨² : is-null (fam-is-simplicial ∘ fst) A
  simp-over-∨² x = simp (fst x)

  amap : (x : ∨²)
       → Arrow-map (!: fam-is-simplicial (fst x))
                   (!: fam-is-disjunctive x)
  amap x .Arrow-map.top = disj←simp-over-∨² x
  amap x .Arrow-map.bot = id
  amap x .Arrow-map.comm = ~refl

  amap-is-eqv : ∀ x → is-Arrow-equiv (amap x)
  amap-is-eqv x .fst = disj←simp-over-∨²-is-equiv x
  amap-is-eqv x .snd = id-is-equiv
}
%```
}

\subtree[stt-00DX]{
\title{Simplicial types are upper located}
\taxon{Corollary}

%```agda
\agda{
simp-is-upper-located : ∀ {𝓤} {A : Type 𝓤}
                      → is-simplicial A → is-upper-located A
simp-is-upper-located = disj-is-upper-located ∘ simp-is-disjunctive
}
%```
}

\subtree[fre-3333]{
\date{2026-03-09}
\author{fredrikbakke}
\title{Universes of disjunctive types}
\taxon{Theorem}

\p{
We record that the following universes of disjunctive types are disjunctive:
\ul{
\li{The type of disjunctive types.}
\li{The type of disjunctive #{n}-types for any #{n}.}
\li{The type of disjunctive sets.}
\li{The type of disjunctive propositions.}
}
}
%```agda
\agda{
Disjunctive-U
  : (𝓤 : Level) → Type (lsuc (𝓘 ⊔ 𝓤))
Disjunctive-U 𝓤
  = Null-U {𝓤 = 𝓘} fam-is-disjunctive 𝓤

Disjunctive-U-is-disjunctive
  : {𝓤 : Level}
  → is-disjunctive (Disjunctive-U 𝓤)
Disjunctive-U-is-disjunctive {𝓤}
  = Null-U-is-null←is-prop {𝓤 = 𝓘} {𝓥 = 𝓤}
      (λ _ → *-is-prop (is-prop-separated _ _) (is-prop-separated _ _))

Disjunctive-Trunc-U
  : (n : ℕ) (𝓤 : Level) → Type (lsuc (𝓘 ⊔ 𝓤))
Disjunctive-Trunc-U n 𝓤
  = Null-in-gSubU {𝓤 = 𝓘} fam-is-disjunctive (Truncation-gSubU n) 𝓤

Disjunctive-Trunc-U-is-disjunctive
  : (n : ℕ) {𝓤 : Level}
  → is-disjunctive (Disjunctive-Trunc-U n 𝓤)
Disjunctive-Trunc-U-is-disjunctive n {𝓤}
  = Null-in-gSubU-is-null←is-prop {𝓤 = 𝓘} {𝓥 = 𝓤}
      {S = Truncation-gSubU n}
      (λ _ → *-is-prop (is-prop-separated _ _) (is-prop-separated _ _))
      (λ _ → Π-is-truncated)

Disjunctive-Set-U
  : (𝓤 : Level) → Type (lsuc (𝓘 ⊔ 𝓤))
Disjunctive-Set-U 𝓤 = Disjunctive-Trunc-U 2 𝓤

Disjunctive-Set-U-is-disjunctive
  : {𝓤 : Level}
  → is-disjunctive (Disjunctive-Set-U 𝓤)
Disjunctive-Set-U-is-disjunctive {𝓤}
  = Disjunctive-Trunc-U-is-disjunctive 2 {𝓤}

Disjunctive-Prop-U
  : (𝓤 : Level) → Type (lsuc (𝓘 ⊔ 𝓤))
Disjunctive-Prop-U 𝓤
  = Disjunctive-Trunc-U 1 𝓤

Disjunctive-Prop-U-is-disjunctive
  : {𝓤 : Level}
  → is-disjunctive (Disjunctive-Prop-U 𝓤)
Disjunctive-Prop-U-is-disjunctive {𝓤}
  = Disjunctive-Trunc-U-is-disjunctive 1 {𝓤}
}
%```
}

\subtree[fre-Q008]{
\date{2026-03-18}
\title{The right endpoint inclusion is exponentiable at disjunctive types}
\taxon{Theorem}

\p{
The point inclusion of #{1} into the interval #{\Delta^1} is exponentiable at
disjunctive types, meaning that given a diagram of the form

\quiver{
\begin{tikzcd}
  U && V && \{1\} \\
  \\
  \Lambda^2_1 && \Delta^2 && \Delta^1
	\arrow["p", from=1-5, to=3-5]
	\arrow[from=3-1, to=3-3]
	\arrow["q", from=1-1, to=1-3]
	\arrow[from=3-3, to=3-5]
	\arrow[from=1-1, to=3-1]
	\arrow["\iota", from=3-1, to=3-3]
	\arrow[from=1-3, to=1-5]
	\arrow["\alpha", from=3-3, to=3-5]
	\arrow[from=1-3, to=3-5, "\lrcorner" very near start, phantom]
	\arrow[from=1-1, to=3-3, "\lrcorner" very near start, phantom]
\end{tikzcd}
}

then every disjunctive segal type is local at #{q}.
}

\p{Fibre types over #{Δ^2} and #{Λ^2_1}, given #{\alpha : \Delta^2 \to \Delta^1}.}

%```agda
\agda{
Δ²· : (α : Δ² → Δ¹) → Type 𝓘
Δ²· α = fibre α i1

Λ[2,1]· : (α : Δ² → Δ¹) → Type 𝓘
Λ[2,1]· α = fibre (α ∘ Λ[2,1]-incl) i1

v00 : Δ²
v00 = (i0 , i0) ⦃ ≤-refl ⦄
}
%```

\p{
The disjunctive replacement of the fibre types over #{Δ^2} and #{Λ^2_1}, and the
corresponding horn inclusion.
}

%```agda
\agda{
checked-over
  : (α : Δ² → Δ¹)
  → Δ² → Type 𝓘
checked-over α t = (α v00 ＝ i1) * (βα-phoa-Δ² α t ＝ i1)

over-∨Δ²·
  : (α : Δ² → Δ¹)
  → Δ²· α → Type 𝓘
over-∨Δ²· α = checked-over α ∘ fst

∨Δ²· : (α : Δ² → Δ¹) → Type 𝓘
∨Δ²· α = Σ Δ² (checked-over α)

over-∨Λ[2,1]·
  : (α : Δ² → Δ¹)
  → Λ[2,1]· α → Type 𝓘
over-∨Λ[2,1]· α
  = (checked-over α ∘ Λ[2,1]-incl) ∘ fst

∨Λ[2,1]· : (α : Δ² → Δ¹) → Type 𝓘
∨Λ[2,1]· α = Σ Λ[2,1] (checked-over α ∘ Λ[2,1]-incl)

η· : (α : Δ² → Δ¹) → Λ[2,1]· α → Δ²· α
η· α = arrow-fibre (mk-amap Λ[2,1]-incl id ~refl) i1

∨η· : (α : Δ² → Δ¹) → ∨Λ[2,1]· α → ∨Δ²· α
∨η· α = total-map-fst Λ[2,1]-incl
}
%```

\p{
Assuming Phoa's principle from disjunctive replacement data we may conclude
#{\alpha(t) = i_1}, and identify the total types with certain fibres.
}

%```agda
\agda{
module _
  (phoa : phoas-principle)
  where

  disj-index·
    : (α : Δ² → Δ¹)
    → Δ²· α → ∨²
  disj-index· α (t , p)
    = ((α v00 , βα-phoa-Δ² α t) , sym (phoa-Δ² phoa α t) ∙ p)
α=i1←disj
  α=i1←disj
    : (α : Δ² → Δ¹)
    → (t : Δ²)
    → ((α v00 ＝ i1) * (βα-phoa-Δ² α t ＝ i1))
    → α t ＝ i1
  α=i1←disj α t d
    = phoa-Δ² phoa α t ∙ ∨=1←fam-disjunctive d

  ∨Δ²·→Δ²·
    : (α : Δ² → Δ¹)
    → ∨Δ²· α → Δ²· α
  ∨Δ²·→Δ²· α
    = subtype←family
        (checked-over α)
        (mk-subtype (λ _ → is-prop-separated _ _))
        (α=i1←disj α)

  ∨Λ[2,1]·→Λ[2,1]·
    : (α : Δ² → Δ¹)
    → ∨Λ[2,1]· α → Λ[2,1]· α
  ∨Λ[2,1]·→Λ[2,1]· α
    = subtype←family
        (checked-over α ∘ Λ[2,1]-incl)
        (mk-subtype (λ _ → is-prop-separated _ _))
        (λ t → α=i1←disj α (Λ[2,1]-incl t))
}
%```

\p{The map #{η^{\bullet}} is homotopic to a #{total\text{-}map\text{-}fst}, with
computable fibres.}

%```agda
\agda{
η·~total-map-fst
  : (α : Δ² → Δ¹)
  → η· α ~ total-map-fst Λ[2,1]-incl {B = λ t → α t ＝ i1}
η·~total-map-fst α (u , q) = Σ-path→ (refl , is-prop-separated _ _ _ _)

η·-fibre≃
  : (α : Δ² → Δ¹)
  → (tp : Δ²· α)
  → fibre (η· α) tp ≃ fibre Λ[2,1]-incl (fst tp)
η·-fibre≃ α (t , p)
  = fibre-homotopy≃ (η·~total-map-fst α)
  ∙≃ fibre-total-map-fst Λ[2,1]-incl t p
}
%```

\p{The pushout presentation of  #{\check{\eta}\mathpunct{.}\alpha}, parametrised over
#{\alpha : \Delta^2 \to \Delta^1}.}

%```agda
\agda{
module ExpPointi1At
  (α : Δ² → Δ¹)
  where
}
%```

\p{The pushout span for #{\check{\eta}\mathpunct{.}\alpha}.}

%```agda
\agda{
  ∨η·-overlap→left
    : ((α v00 ＝ i1) × Λ[2,1]· (βα-phoa-Δ² α))
    → ((α v00 ＝ i1) × Λ[2,1])
  ∨η·-overlap→left = (id: (α v00 ＝ i1)) ⊗ (fst: (λ a → (βα-phoa-Δ² α ∘ Λ[2,1]-incl) a ＝ i1))

  ∨η·-overlap→right
    : ((α v00 ＝ i1) × Λ[2,1]· (βα-phoa-Δ² α))
    → Δ²· (βα-phoa-Δ² α)
  ∨η·-overlap→right = η· (βα-phoa-Δ² α) ∘ (snd: (λ _ → Λ[2,1]· (βα-phoa-Δ² α)))

  ∨η·-left' : Type 𝓘
  ∨η·-left' = (α v00 ＝ i1) × Δ²

  ∨η·-overlap→left'
    : ((α v00 ＝ i1) × Λ[2,1]· (βα-phoa-Δ² α))
    → ∨η·-left'
  ∨η·-overlap→left' = ((id: (α v00 ＝ i1)) ⊗ Λ[2,1]-incl) ∘ ∨η·-overlap→left

  ∨η·-left-coslice
    : Coslice-map ∨η·-overlap→left ∨η·-overlap→left'
  ∨η·-left-coslice .fst = (id: (α v00 ＝ i1)) ⊗ Λ[2,1]-incl
  ∨η·-left-coslice .snd = ~refl

  ∨η·-right-coslice
    : Coslice-map snd ∨η·-overlap→right
  ∨η·-right-coslice .fst = η· (βα-phoa-Δ² α)
  ∨η·-right-coslice .snd = ~refl

  ∨η·-pushout
    : Pushout ∨η·-overlap→left snd
    → Pushout ∨η·-overlap→left' ∨η·-overlap→right
  ∨η·-pushout
    = Pushout₁-left-right
        ∨η·-left-coslice
        ∨η·-right-coslice

}
%```

\p{The simplified #{\beta} pushout span, where the horn is replaced by
#{\Delta^2\mathpunct{.}(\beta\alpha)}.}

%```agda
\agda{
  ∨η·-overlapβ : Type 𝓘
  ∨η·-overlapβ = (α v00 ＝ i1) × Δ²· (βα-phoa-Δ² α)

  ∨η·-overlapβ→left
    : ∨η·-overlapβ → ∨η·-left'
  ∨η·-overlapβ→left = (id: (α v00 ＝ i1)) ⊗ (fst: (λ a → βα-phoa-Δ² α a ＝ i1))

  ∨η·-overlapβ→right
    : ∨η·-overlapβ → Δ²· (βα-phoa-Δ² α)
  ∨η·-overlapβ→right = snd: (λ _ → Δ²· (βα-phoa-Δ² α))
}
%```

\p{
To analyse that square, we first build a simpler pushout model where the horn part
has already been replaced by the equivalent family
#{\Delta^2\mathpunct{.}(\beta\alpha)}. This gives a direct pushout presentation of
#{\check{\Delta}^2\mathpunct{.}(\alpha)}, and in parallel a pushout presentation of
#{\check{\Lambda}^2_1\mathpunct{.}(\alpha)}.}

%```agda
\agda{
  ∨η·-pushoutβ
    : Pushout ∨η·-overlapβ→left ∨η·-overlapβ→right
    → ∨Δ²· α
  ∨η·-pushoutβ
    = pushout-rec
        (mk-cocone
          (λ (p , t) → (t , ι₁ p))
          (λ (t , q) → (t , ι₂ q))
          (λ (p , (t , q)) → Σ-path→ (refl , glue (p , q))))

  pushoutβ←∨η·
    : ∨Δ²· α
    → Pushout ∨η·-overlapβ→left ∨η·-overlapβ→right
  pushoutβ←∨η· (t , d)
    = pushout-rec
        (mk-cocone
          (λ p → ι₁ (p , t))
          (λ q → ι₂ (t , q))
          (λ (p , q) → glue (p , (t , q))))
        d

  ∨η·-pushoutβ-β
    : (p : α v00 ＝ i1)
    → (t : Δ²)
    → (q : βα-phoa-Δ² α t ＝ i1)
    → ap ∨η·-pushoutβ (glue (p , (t , q)))
      ＝ Σ-path→ (refl , glue (p , q))
  ∨η·-pushoutβ-β p t q = pushout-rec-apβ (p , (t , q))

  ∨η·-pushout-β
    : (p : α v00 ＝ i1)
    → (t : Λ[2,1])
    → (q : βα-phoa-Δ² α (Λ[2,1]-incl t) ＝ i1)
    → ap ∨η·-pushout (glue (p , (t , q)))
      ＝ glue (p , (t , q))
  ∨η·-pushout-β p t q
    = pushout-rec-apβ (p , (t , q)) ∙ ∙-reflr _

  ∨Δ²·-is-set : is-set (∨Δ²· α)
  ∨Δ²·-is-set
    =
      is-set←is-truncated
       ( Σ-is-truncated Δ²-is-set
        (λ _ → suc-is-truncated 1
          (is-truncated←is-prop
            (*-is-prop (is-prop-separated _ _) (is-prop-separated _ _)))))

  ∨η·-Σ-path
    : (t : Δ²)
    → {d d' : (α v00 ＝ i1) * (βα-phoa-Δ² α t ＝ i1)}
    → (q : d ＝ d')
    → Σ-path→
        {A = Δ²}
        {B = λ t → (α v00 ＝ i1) * (βα-phoa-Δ² α t ＝ i1)}
        {x = (t , d)} {y = (t , d')}
        (refl , q)
      ＝ ap (t ,_) q
  ∨η·-Σ-path t refl = refl

  pushoutβ←∨η·-β
    : (p : α v00 ＝ i1)
    → (t : Δ²)
    → (q : βα-phoa-Δ² α t ＝ i1)
    → ap pushoutβ←∨η· (Σ-path→ (refl , glue (p , q)))
      ＝ glue (p , (t , q))
  pushoutβ←∨η·-β p t q
    = ap (ap pushoutβ←∨η·) (∨η·-Σ-path t (glue (p , q)))
    ∙ sym (ap-∘ pushoutβ←∨η· (t ,_) (glue (p , q)))
    ∙ pushout-rec-apβ (p , q)

  ∨η·-pushoutβ-qiso : quasi-iso ∨η·-pushoutβ
  ∨η·-pushoutβ-qiso .fst = pushoutβ←∨η·
  ∨η·-pushoutβ-qiso .snd .fst x
    = to-rec ∙ sym id-to-rec where

    to-rec
      : pushoutβ←∨η· (∨η·-pushoutβ x)
      ＝ pushout-rec pushout x
    to-rec
      = pushout-rec-unique _ _
          ~refl ~refl
          (λ (p , (t , q)) →
               ap (_∙ refl)
                 ( ap-∘ pushoutβ←∨η· ∨η·-pushoutβ
                     (glue (p , (t , q)))
                 ∙ ap (ap pushoutβ←∨η·)
                     (∨η·-pushoutβ-β p t q)
                 ∙ pushoutβ←∨η·-β p t q )
             ∙ ∙-reflr _)
          x

    id-to-rec
      : x ＝ pushout-rec pushout x
    id-to-rec
      = pushout-rec-unique _ _
          ~refl ~refl
          (λ a → ap (_∙ refl) (ap-id (glue a)) ∙ ∙-reflr _)
          x

  ∨η·-pushoutβ-qiso .snd .snd (t , d)
    = to-rec ∙ sym pair-to-rec where

    C : Cocone
          (mk-span
            ((α v00 ＝ i1) × (βα-phoa-Δ² α t ＝ i1))
            fst snd)
          (∨Δ²· α)
    C = mk-cocone
          (λ p → (t , ι₁ p))
          (λ q → (t , ι₂ q))
          (λ pq → Σ-path→ (refl , glue pq))

    F
      : (α v00 ＝ i1) * (βα-phoa-Δ² α t ＝ i1)
      → ∨Δ²· α
    F d = ∨η·-pushoutβ (pushoutβ←∨η· (t , d))

    to-rec
      : F d ＝ pushout-rec C d
    to-rec
      = pushout-rec-unique C F
          ~refl ~refl
          (λ (p , q) →
               ap (_∙ refl)
                 ( ap-∘ ∨η·-pushoutβ (λ d → pushoutβ←∨η· (t , d))
                     (glue (p , q))
                 ∙ ap (ap ∨η·-pushoutβ)
                     (pushout-rec-apβ (p , q))
                 ∙ ∨η·-pushoutβ-β p t q )
             ∙ ∙-reflr _)
          d

    pair-to-rec
      : (t , d) ＝ pushout-rec C d
    pair-to-rec
      = pushout-rec-unique C
          (λ d → (t , d))
          ~refl ~refl
          (λ (p , q) →
               ap (_∙ refl) (sym (∨η·-Σ-path t (glue (p , q))))
             ∙ ∙-reflr _)
          d

  ∨η·≃pushoutβ
    : Pushout ∨η·-overlapβ→left ∨η·-overlapβ→right
      ≃ ∨Δ²· α
  ∨η·≃pushoutβ = mk≃ _ (is-equiv←qiso ∨η·-pushoutβ-qiso)
}
%```

\p{The analogous pushout is equivalent to #{\check{\Lambda}^2_1\mathpunct{.}(\alpha)}.}

%```agda
\agda{
  ∨Λ[2,1]·←pushout
    : Pushout ∨η·-overlap→left snd
    → ∨Λ[2,1]· α
  ∨Λ[2,1]·←pushout
    = pushout-rec
        (mk-cocone
          (λ (p , t) → (t , ι₁ p))
          (λ (t , q) → (t , ι₂ q))
          (λ (p , (t , q)) → Σ-path→ (refl , glue (p , q))))

  ∨Λ[2,1]·←pushout-β
    : (p : α v00 ＝ i1)
    → (t : Λ[2,1])
    → (q : βα-phoa-Δ² α (Λ[2,1]-incl t) ＝ i1)
    → ap ∨Λ[2,1]·←pushout (glue (p , (t , q)))
      ＝ Σ-path→ (refl , glue (p , q))
  ∨Λ[2,1]·←pushout-β p t q = pushout-rec-apβ (p , (t , q))

  ∨Λ[2,1]·-Σ-path
    : (t : Λ[2,1])
    → {d d' : (α v00 ＝ i1) * (βα-phoa-Δ² α (Λ[2,1]-incl t) ＝ i1)}
    → (q : d ＝ d')
    → Σ-path→
        {A = Λ[2,1]}
        {B = λ t → (α v00 ＝ i1) * (βα-phoa-Δ² α (Λ[2,1]-incl t) ＝ i1)}
        {x = (t , d)} {y = (t , d')}
        (refl , q)
      ＝ ap (λ z → (t , z)) q
  ∨Λ[2,1]·-Σ-path t refl = refl

  pushout←∨Λ[2,1]·
    : ∨Λ[2,1]· α
    → Pushout ∨η·-overlap→left snd
  pushout←∨Λ[2,1]· (t , d)
    = pushout-rec
        (mk-cocone
          (λ p → ι₁ (p , t))
          (λ q → ι₂ (t , q))
          (λ (p , q) → glue (p , (t , q))))
        d

  pushout←∨Λ[2,1]·-β
    : (p : α v00 ＝ i1)
    → (t : Λ[2,1])
    → (q : βα-phoa-Δ² α (Λ[2,1]-incl t) ＝ i1)
    → ap pushout←∨Λ[2,1]· (Σ-path→ (refl , glue (p , q)))
      ＝ glue (p , (t , q))
  pushout←∨Λ[2,1]·-β p t q
    = ap (ap pushout←∨Λ[2,1]·) (∨Λ[2,1]·-Σ-path t (glue (p , q)))
    ∙ sym (ap-∘ pushout←∨Λ[2,1]· (λ z → (t , z)) (glue (p , q)))
    ∙ pushout-rec-apβ (p , q)

  ∨Λ[2,1]·-pushout-qiso
    : quasi-iso ∨Λ[2,1]·←pushout
  ∨Λ[2,1]·-pushout-qiso .fst = pushout←∨Λ[2,1]·
  ∨Λ[2,1]·-pushout-qiso .snd .fst x
    = to-rec ∙ sym id-to-rec where

      to-rec
        : pushout←∨Λ[2,1]· (∨Λ[2,1]·←pushout x)
        ＝ pushout-rec pushout x
      to-rec
        = pushout-rec-unique _ _
            ~refl ~refl
            (λ (p , (t , q)) →
                 ap (_∙ refl)
                   ( ap-∘ pushout←∨Λ[2,1]· ∨Λ[2,1]·←pushout
                       (glue (p , (t , q)))
                   ∙ ap (ap pushout←∨Λ[2,1]·)
                       (∨Λ[2,1]·←pushout-β p t q)
                   ∙ pushout←∨Λ[2,1]·-β p t q )
               ∙ ∙-reflr _)
            x

      id-to-rec
        : x ＝ pushout-rec pushout x
      id-to-rec
        = pushout-rec-unique _ _
            ~refl ~refl
            (λ a → ap (_∙ refl) (ap-id (glue a)) ∙ ∙-reflr _)
            x

  ∨Λ[2,1]·-pushout-qiso .snd .snd (t , d)
    = to-rec ∙ sym pair-to-rec where

      C : Cocone
            (mk-span
              ((α v00 ＝ i1) × (βα-phoa-Δ² α (Λ[2,1]-incl t) ＝ i1))
              fst snd)
            (∨Λ[2,1]· α)
      C = mk-cocone
            (λ p → (t , ι₁ p))
            (λ q → (t , ι₂ q))
            (λ pq → Σ-path→ (refl , glue pq))

      F
        : (α v00 ＝ i1) * (βα-phoa-Δ² α (Λ[2,1]-incl t) ＝ i1)
        → ∨Λ[2,1]· α
      F d = ∨Λ[2,1]·←pushout (pushout←∨Λ[2,1]· (t , d))

      to-rec
        : F d ＝ pushout-rec C d
      to-rec
        = pushout-rec-unique C F
            ~refl ~refl
            (λ (p , q) →
                 ap (_∙ refl)
                   ( ap-∘ ∨Λ[2,1]·←pushout (λ d → pushout←∨Λ[2,1]· (t , d))
                       (glue (p , q))
                   ∙ ap (ap ∨Λ[2,1]·←pushout)
                       (pushout-rec-apβ (p , q))
                   ∙ ∨Λ[2,1]·←pushout-β p t q )
               ∙ ∙-reflr _)
            d

      pair-to-rec
        : (t , d) ＝ pushout-rec C d
      pair-to-rec
        = pushout-rec-unique C
            (λ d → (t , d))
            ~refl ~refl
            (λ (p , q) →
                 ap (_∙ refl) (sym (∨Λ[2,1]·-Σ-path t (glue (p , q))))
               ∙ ∙-reflr _)
            d

  ∨Λ[2,1]·≃pushout : Pushout ∨η·-overlap→left snd ≃ ∨Λ[2,1]· α
  ∨Λ[2,1]·≃pushout = mk≃ _ (is-equiv←qiso ∨Λ[2,1]·-pushout-qiso)
}
%```

\p{
We then compare the actual pushout for #{\check{\eta}\mathpunct{.}(\alpha)} with the
simpler β-pushout, deduce that #{\check{\eta}\mathpunct{.}(\alpha)} is itself
equivalent to a pushout map, and conclude its locality from the standard closure
properties of orthogonal types under products and pushouts.}

%```agda
\agda{
  ∨η·-β
    : (p : α v00 ＝ i1)
    → (t : Λ[2,1])
    → (q : βα-phoa-Δ² α (Λ[2,1]-incl t) ＝ i1)
    → ap (∨η· α) (Σ-path→ (refl , glue (p , q)))
      ＝ Σ-path→ (refl , glue (p , q))
  ∨η·-β p t q
    = ap (ap (∨η· α)) (∨Λ[2,1]·-Σ-path t (glue (p , q)))
    ∙ sym (ap-∘ (∨η· α) (λ z → (t , z)) (glue (p , q)))
    ∙ sym (∨η·-Σ-path (Λ[2,1]-incl t) (glue (p , q)))
}
%```

\p{
The map #{\eta\mathpunct{.}(\beta\alpha)} is an equivalence, so the overlap types are
equivalent.
}

%```agda
\agda{
  βα-phoa-Δ²=1→s=1
    : (t : Δ²)
    → βα-phoa-Δ² α t ＝ i1
    → i1 ＝ t .Poly.Δ².s
  βα-phoa-Δ²=1→s=1 t p
    = sym
        ( sym (≤-max (βα-phoa-Δ²≤s α t))
        ∙ ap (_∨ t .Poly.Δ².s) p
        ∙ ∨-comm
        ∙ 1-coinit)

  η·β-is-equiv : is-equiv (η· (βα-phoa-Δ² α))
  η·β-is-equiv
    = is-equiv←is-contr-map λ tp
        → is-single←equiv-to-single
            (η·-fibre≃ (βα-phoa-Δ² α) tp e⁻¹)
            (is-single←equiv-to-single
              (Λ[2,1]-as-subtype (fst tp) e⁻¹)
              (*-single'
                (mk-singl
                  (βα-phoa-Δ²=1→s=1 (fst tp) (snd tp))
                  (λ x → is-prop-separated _ _ _ _))))

  ∨η·-overlap≃β
    : ((α v00 ＝ i1) × Λ[2,1]· (βα-phoa-Δ² α)) ≃ ∨η·-overlapβ
  ∨η·-overlap≃β
    = idequiv ×≃ (mk≃ _ η·β-is-equiv)

  ∨η·-pushoutβ←actual
    : Pushout ∨η·-overlap→left' ∨η·-overlap→right
    → Pushout ∨η·-overlapβ→left ∨η·-overlapβ→right
  ∨η·-pushoutβ←actual
    = _≃_.fwd
        (Pushout-adjust-equiv
          {f = ∨η·-overlapβ→left}
          {g = ∨η·-overlapβ→right}
          ∨η·-overlap≃β)
}
%```

\p{The composite comparison map #{\check{\eta}\mathpunct{.}\alpha}.}

%```agda
\agda{
  ∨η·-pushout→∨Δ²·
    : Pushout ∨η·-overlap→left' ∨η·-overlap→right
    → ∨Δ²· α
  ∨η·-pushout→∨Δ²·
    = ∨η·-pushoutβ ∘ ∨η·-pushoutβ←actual

  ∨η·-pushout→∨Δ²·-comm
    : ∨η·-pushout→∨Δ²· ∘ ∨η·-pushout
      ~ ∨η· α ∘ ∨Λ[2,1]·←pushout
  ∨η·-pushout→∨Δ²·-comm x
    = lhs-to-rec ∙ sym rhs-to-rec where

      C : Cocone
            (mk-span
              ((α v00 ＝ i1) × Λ[2,1]· (βα-phoa-Δ² α))
              ∨η·-overlap→left
              snd)
            (∨Δ²· α)
      C = mk-cocone
            (λ (p , t) → (Λ[2,1]-incl t , ι₁ p))
            (λ (t , q) → (Λ[2,1]-incl t , ι₂ q))
            (λ (p , (t , q)) → Σ-path→ (refl , glue (p , q)))

      K
        : (u : Λ[2,1]· (βα-phoa-Δ² α))
        → ∨η·-pushout→∨Δ²· (∨η·-pushout (ι₂ u))
          ＝ C .Cocone.q u
      K (t , q) = ap (λ r → (Λ[2,1]-incl t , ι₂ r)) (ap-id q)

      lhs-to-rec
        : ∨η·-pushout→∨Δ²· (∨η·-pushout x)
        ＝ pushout-rec C x
      lhs-to-rec
        = pushout-rec-unique C
            (∨η·-pushout→∨Δ²· ∘ ∨η·-pushout)
            (~refl)
            (K)
            (λ (p , t , q) →
                 ap
                   ( _∙ K (t , q))
                   ( ap-∘ ∨η·-pushout→∨Δ²· ∨η·-pushout (glue (p , (t , q)))
                   ∙ ap (ap ∨η·-pushout→∨Δ²·) (∨η·-pushout-β p t q)
                   ∙ ap-∘ ∨η·-pushoutβ ∨η·-pushoutβ←actual (glue (p , (t , q)))
                   ∙ ap (ap ∨η·-pushoutβ) (pushout-rec-apβ (p , (t , q)))
                   ∙ ∨η·-pushoutβ-β p (Λ[2,1]-incl t) (ap id q) )
               ∙ ∨Δ²·-is-set _ _ _ _)
            (x)

      rhs-to-rec
        : ∨η· α (∨Λ[2,1]·←pushout x)
        ＝ pushout-rec C x
      rhs-to-rec
        = pushout-rec-unique C
            (∨η· α ∘ ∨Λ[2,1]·←pushout)
            (~refl)
            (~refl)
            (λ (p , t , q) →
             ∙-reflr _
             ∙ ap-∘ (∨η· α) ∨Λ[2,1]·←pushout (glue (p , (t , q)))
             ∙ ap (ap (∨η· α)) (∨Λ[2,1]·←pushout-β p t q)
             ∙ ∨η·-β p t q )
            (x)

  ∨η·≃pushout : Arrow-equiv ∨η·-pushout (∨η· α)
  ∨η·≃pushout
    = mk-amap ∨Λ[2,1]·←pushout ∨η·-pushout→∨Δ²· ∨η·-pushout→∨Δ²·-comm
    , ∨Λ[2,1]·≃pushout ._≃_.has-is-eqv
    , is-equiv-∘
        (∨η·≃pushoutβ ._≃_.has-is-eqv)
        (_≃_.has-is-eqv (Pushout-adjust-equiv ∨η·-overlap≃β))
}
%```

\p{Disjunctive Segal types are local at #{\check{\eta}\mathpunct{.}\alpha}.}

%```agda
\agda{
  η·β-local
    : {𝓤 : Level} {X : Type 𝓤}
    → orthogonal-type (η· (βα-phoa-Δ² α)) X
  η·β-local = precomp-equiv η·β-is-equiv

  ∨η·-left-local
    : {𝓤 : Level} {X : Type 𝓤}
    → orthogonal-type Λ[2,1]-incl X
    → orthogonal-type (id {A = α v00 ＝ i1} ⊗ Λ[2,1]-incl) X
  ∨η·-left-local segal-X
    = orthogonal-type-×₁ (id {A = α v00 ＝ i1}) Λ[2,1]-incl
        orthogonal-type-id segal-X

  ∨η·-pushout-local
    : {𝓤 : Level} {X : Type 𝓤}
    → orthogonal-type Λ[2,1]-incl X
    → orthogonal-type
        (Pushout₁-left-right ∨η·-left-coslice ∨η·-right-coslice)
        (X)
  ∨η·-pushout-local segal-X
    = orthogonal-type-pushout₁
        (∨η·-left-coslice)
        (∨η·-right-coslice)
        (∨η·-left-local segal-X)
        (η·β-local)

  ∨η·-is-disjunctive-segal-equiv
    : {𝓤 : Level} {X : Type 𝓤}
    → is-disjunctive X
    → orthogonal-type Λ[2,1]-incl X
    → orthogonal-type (∨η· α) X
  ∨η·-is-disjunctive-segal-equiv _ segal-X
    = orthogonal-type←Arrow-equiv
        (∨η·≃pushout)
        (∨η·-pushout-local segal-X)

}
%```

\p{Every pullback of the point inclusion of #{1} along the inner horn inclusion
is classified by some #{η^{\bullet}(\alpha)}.}

%```agda
\agda{
module Exp = ExponentiabilityAt Disjunctive-gSubU (point Λ[2,1]-incl)

η·-classify-Pb
  : ∀ {𝓤 𝓥} {X : Type 𝓤} {Y : Type 𝓥} {g : X → Y}
  → Exp.is-Pb (point i1) g
  → Σ[ α ∶ (Δ² → Δ¹) ] Arrow-equiv g (η· α)
η·-classify-Pb {g = g} (tt , F , F-cart , bc)
  = α , Arrow-equiv←fibre-fam≃ᶠ fam-eq where

  open Arrow-map F

  α : Δ² → Δ¹
  α = Arrow-map.bot (Arrow-cartesian-map.square bc)

  bot-eq
    : Arrow-equiv bot (arrow←Fam (Δ² , λ t → α t ＝ i1))
  bot-eq = point-base-change-Arrow-equiv
    i1
    (Arrow-cartesian-map.square bc)
    (Arrow-cartesian-map.cartesian bc)

  fam-eq
    : fibre-fam g ≃ᶠ fibre-fam (η· α)
  fam-eq .fst = mk≃ (Arrow-map.top (bot-eq .fst)) (bot-eq .snd .fst)
  fam-eq .snd v
    = mk≃ (arrow-fibre F v) (F-cart v)
    ∙≃ η·-fibre≃ α (Arrow-map.top (bot-eq .fst) v) e⁻¹
}
%```

\p{
Under Phoa's principle, disjunctive types are local at the underlying comparison maps
from the disjunctive replacements, and hence at each #{\eta\mathpunct{.}\alpha}.
}

%```agda
\agda{
module _
  (phoa : phoas-principle)
  where

  ∨Δ²·→Δ²·-is-disjunctive-equiv
    : ∀ {𝓤} {X : Type 𝓤}
    → is-disjunctive X
    → (α : Δ² → Δ¹)
    → orthogonal-type (∨Δ²·→Δ²· phoa α) X
  ∨Δ²·→Δ²·-is-disjunctive-equiv disj-X α
    = local-at-subtype←family←is-null-over
        (checked-over α)
        (λ t → α t ＝ i1)
        (λ _ → is-prop-separated _ _)
        (α=i1←disj phoa α)
        (λ tp → disj-X (disj-index· phoa α tp))

  ∨Λ[2,1]·→Λ[2,1]·-is-disjunctive-equiv
    : ∀ {𝓤} {X : Type 𝓤}
    → is-disjunctive X
    → (α : Δ² → Δ¹)
    → orthogonal-type (∨Λ[2,1]·→Λ[2,1]· phoa α) X
  ∨Λ[2,1]·→Λ[2,1]·-is-disjunctive-equiv disj-X α
    = local-at-subtype←family←is-null-over
        (checked-over α ∘ Λ[2,1]-incl)
        (λ t → α (Λ[2,1]-incl t) ＝ i1)
        (λ _ → is-prop-separated _ _)
        (λ t → α=i1←disj phoa α (Λ[2,1]-incl t))
        (λ tp → disj-X (disj-index· phoa α (η· α tp)))
}
%```

\p{
Assembling the pieces: disjunctive Segal types are local at #{η\mathpunct{.}\alpha}.
}

%```agda
\agda{
  η·-is-disjunctive-equiv
    : ∀ {𝓤} {X : Type 𝓤}
    → is-disjunctive X
    → orthogonal-type Λ[2,1]-incl X
    → (α : Δ² → Δ¹)
    → orthogonal-type (η· α) X
  η·-is-disjunctive-equiv disj-X segal-X α
    = orthogonal-type-homotopy
        (η·~total-map-fst α ~⁻¹)
        (subtype←family-local←family-replacement
          (checked-over α)
          (λ t → α t ＝ i1)
          (λ _ → is-prop-separated _ _)
          (α=i1←disj phoa α)
          Λ[2,1]-incl
          (A.∨η·-is-disjunctive-segal-equiv disj-X segal-X)
          (∨Λ[2,1]·→Λ[2,1]·-is-disjunctive-equiv disj-X α)
          (∨Δ²·→Δ²·-is-disjunctive-equiv disj-X α)) where

    module A = ExpPointi1At α

  point-i1-is-globally-exponentiable-at-disjunctive-types
    : Exp.is-globally-exponentiable-at (point i1)
  point-i1-is-globally-exponentiable-at-disjunctive-types
    = Exp.classified-is-globally-exponentiable-at
        (point i1)
        (η·)
        (η·-classify-Pb)
        ( λ {Q = Q} disj-X loc
          → η·-is-disjunctive-equiv {X = Q} disj-X (loc tt))
}
%```
}

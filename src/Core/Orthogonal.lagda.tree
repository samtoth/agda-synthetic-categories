\subtree[stt-0048]{
\title{Orthogonal maps}
\taxon{Definition}

\p{Given maps #{f : A \to B} and #{g : C \to D}, we say
#{f} is orthogonal to #{g} when any [square](stt-003U) has
a unqique [lifting](stt-0044).}

\agda{
module _ {рқ“Ө рқ“Ҙ рқ“Ұ рқ“ӣ} {A : Type рқ“Ө}
       {B : Type рқ“Ҙ} {C : Type рқ“Ұ}
       {D : Type рқ“ӣ} where
  are-orthogonal : вҲҖ (f : A вҶ’ B) (g : C вҶ’ D) вҶ’ Type (рқ“Ө вҠ” рқ“Ҙ вҠ” рқ“Ұ вҠ” рқ“ӣ)
  are-orthogonal f g = вҲҖ (F : Arrow-map f g) вҶ’ unique-lifts F
}
}



\subtree[stt-004A]{
\title{Classification of orthogonal maps}
\taxon{Theorem}

\p{For maps #{f : A \to B} and #{g : C \to D}, we have that the following
are equivalent:}

\ol{
  \li{#{f \perp g}}
  \li{The square defined in \ref{stt-004C} is a pullback square}
  \li{The [pullback power](stt-004D) of f with g is an equivalence}
  \li{The [dependent postcomposition](stt-004M) by #{f} at the fibre of
      #{g} is an equivalence.}
}

\proof{
  \p{We have already shown (2) iff (3) as a [corollary](stt-004L) of the fact
     that the pullback power [is homotopic to the gap map](stt-004C).}

  \p{To show (1) iff (3), we note that the pullback power is an equiv
  iff for all #{(G = (t , b , H) : \Hom(f,g))},
  #{\fibre{\pullpow{f}{g}}{G}} is a singleton. [We have
  shown](stt-004K) the fibres of the pullback power are equivalent to the
  type of lifts of #{G}.

  \p{Finally we show (2) iff (4).}
}


\agda{
pb-power-is-equivвҶҗorthogonal
  : вҲҖ {рқ“Ө рқ“Ҙ рқ“Ұ рқ“ӣ} {A : Type рқ“Ө} {B : Type рқ“Ҙ}
      {C : Type рқ“Ұ} {D : Type рқ“ӣ}
      {f : A вҶ’ B} {g : C вҶ’ D}
    вҶ’ are-orthogonal f g
    вҶ’ is-equiv (pullback-power f g)
pb-power-is-equivвҶҗorthogonal {A = A} {B} {C} {D} {f} {g} orth
  = is-equivвҶҗhas-singleton-fibres О» where
    G@(mk-amap t b H) вҶ’ is-singleвҶҗequiv-to-single
                        (pb-power-fibreвүғlifts f g G eвҒ»В№)
                        (orth G)


precomp-О вҶҗis-cartesian
  : вҲҖ {рқ“Ө рқ“Ҙ рқ“Ұ рқ“ӣ} {A : Type рқ“Ө} {B : Type рқ“Ҙ}
      {C : Type рқ“Ұ} {D : Type рқ“ӣ}
      {f : A вҶ’ B} {g : C вҶ’ D}
    вҶ’ is-cartesian (power-hom f g)
    вҶ’ вҲҖ (h : B вҶ’ D)
    вҶ’ is-equiv (precomp-О  (fibre g вҲҳ h) f)
precomp-О вҶҗis-cartesian {f = f} {g} pb h
  = is-equivвҶҗArrow-equiv {F = amap} amap-eq (pb h) where
  amap : Arrow-map
           (arrow-fibre (power-hom f g) h)
           (precomp-О  (fibre g вҲҳ h) f)
  amap .Arrow-map.top = _вүғ_.fwd (fibre-postcompвүғ g h)
  amap .Arrow-map.bot = _вүғ_.fwd (fibre-postcompвүғ g (h вҲҳ f))
  amap .Arrow-map.comm (_ , refl) = refl

  amap-eq : is-Arrow-equiv amap
  amap-eq = ( fibre-postcompвүғ g h ._вүғ_.fwd-is-equiv
            , fibre-postcompвүғ g (h вҲҳ f) ._вүғ_.fwd-is-equiv
            )

is-cartesianвҶҗprecomp-О 
  : вҲҖ {рқ“Ө рқ“Ҙ рқ“Ұ рқ“ӣ} {A : Type рқ“Ө} {B : Type рқ“Ҙ}
      {C : Type рқ“Ұ} {D : Type рқ“ӣ}
      {f : A вҶ’ B} {g : C вҶ’ D}
    вҶ’ (вҲҖ h вҶ’ is-equiv (precomp-О  (fibre g вҲҳ h) f))
    вҶ’ is-cartesian (power-hom f g)
is-cartesianвҶҗprecomp-О  {f = f} {g} eq h
  = is-equivвҶҗArrow-equivвҒ»В№ {F = amap} amap-eq (eq h) where
  amap : Arrow-map
           (arrow-fibre (power-hom f g) h)
           (precomp-О  (fibre g вҲҳ h) f)
  amap .Arrow-map.top = _вүғ_.fwd (fibre-postcompвүғ g h)
  amap .Arrow-map.bot = _вүғ_.fwd (fibre-postcompвүғ g (h вҲҳ f))
  amap .Arrow-map.comm (_ , refl) = refl

  amap-eq : is-Arrow-equiv amap
  amap-eq = ( fibre-postcompвүғ g h ._вүғ_.fwd-is-equiv
            , fibre-postcompвүғ g (h вҲҳ f) ._вүғ_.fwd-is-equiv
            )

orthogonalвҶҗprecomp-О 
  : вҲҖ {рқ“Ө рқ“Ҙ рқ“Ұ рқ“ӣ} {A : Type рқ“Ө} {B : Type рқ“Ҙ}
      {C : Type рқ“Ұ} {D : Type рқ“ӣ}
      {f : A вҶ’ B} {g : C вҶ’ D}
    вҶ’ (вҲҖ (h : B вҶ’ D) вҶ’ is-equiv (precomp-О  (fibre g вҲҳ h) f))
    вҶ’ are-orthogonal f g
orthogonalвҶҗprecomp-О  {f = f} {g} eqv F
  = is-singleвҶҗequiv-to-single (pb-power-fibreвүғlifts _ _ F)
     (has-singleton-fibresвҶҗis-equiv
       (pullback-powerвҶҗpower-hom-cartesian _ _
         (is-cartesianвҶҗprecomp-О  eqv))
        F)

precomp-О вҶҗorthogonal
  : вҲҖ {рқ“Ө рқ“Ҙ рқ“Ұ рқ“ӣ} {A : Type рқ“Ө} {B : Type рқ“Ҙ}
      {C : Type рқ“Ұ} {D : Type рқ“ӣ}
      {f : A вҶ’ B} {g : C вҶ’ D}
    вҶ’ (вҲҖ (h : B вҶ’ D)
    вҶ’ are-orthogonal f g
    вҶ’ is-equiv (precomp-О  (fibre g вҲҳ h) f))
precomp-О вҶҗorthogonal {f = f} {g} h orth
  = precomp-О вҶҗis-cartesian
      (power-hom-cartesianвҶҗpullback-power f g
        (pb-power-is-equivвҶҗorthogonal orth)) h


orthogonalвҶҗis-cartesian
  : вҲҖ {рқ“Ө рқ“Ҙ рқ“Ұ рқ“ӣ} {A : Type рқ“Ө} {B : Type рқ“Ҙ}
      {C : Type рқ“Ұ} {D : Type рқ“ӣ}
      {f : A вҶ’ B} {g : C вҶ’ D}
    вҶ’ is-cartesian (power-hom f g)
    вҶ’ are-orthogonal f g
orthogonalвҶҗis-cartesian cart
  = orthogonalвҶҗprecomp-О  (precomp-О вҶҗis-cartesian cart)

is-cartesianвҶҗorthogonal
  : вҲҖ {рқ“Ө рқ“Ҙ рқ“Ұ рқ“ӣ} {A : Type рқ“Ө} {B : Type рқ“Ҙ}
      {C : Type рқ“Ұ} {D : Type рқ“ӣ}
      {f : A вҶ’ B} {g : C вҶ’ D}
    вҶ’ are-orthogonal f g
    вҶ’ is-cartesian (power-hom f g)
is-cartesianвҶҗorthogonal orth
  = is-cartesianвҶҗprecomp-О  О» h вҶ’ precomp-О вҶҗorthogonal h orth

orthogonalвҶҗpb-power-is-equiv
  : вҲҖ {рқ“Ө рқ“Ҙ рқ“Ұ рқ“ӣ} {A : Type рқ“Ө} {B : Type рқ“Ҙ}
      {C : Type рқ“Ұ} {D : Type рқ“ӣ}
      {f : A вҶ’ B} {g : C вҶ’ D}
    вҶ’ is-equiv (pullback-power f g)
    вҶ’ are-orthogonal f g
orthogonalвҶҗpb-power-is-equiv
  = orthogonalвҶҗis-cartesian вҲҳ power-hom-cartesianвҶҗpullback-power _ _

orthogonalвҮ”pb-power-is-equiv
  : вҲҖ {рқ“Ө рқ“Ҙ рқ“Ұ рқ“ӣ} {A : Type рқ“Ө} {B : Type рқ“Ҙ}
      {C : Type рқ“Ұ} {D : Type рқ“ӣ}
      {f : A вҶ’ B} {g : C вҶ’ D}
    вҶ’ is-equiv (pullback-power f g)
    вҮ” are-orthogonal f g
orthogonalвҮ”pb-power-is-equiv
  = (orthogonalвҶҗpb-power-is-equiv , pb-power-is-equivвҶҗorthogonal)
}
}
}


\subtree[stt-004N]{
\date{2025-05-24}
\taxon{Remark}
\title{Orthogonality at types}
\p{We say that a type #{A} is orthogonal to a map when the unique map #{A \to 1}
   is.}
}


\subtree[stt-004O]{
\date{2025-05-24}
\taxon{Theorem}
\title{Orthogonality via composition}

\p{A type #{A} is [orthogonal](stt-004N) to a map #{X \to Y} iff postcomposition
by f is an equivalence.}

\p{We postpone this proof until later, but for now in the formalisation we
   define orthogonality to be the types satisfying the above property.}

\agda{
orthogonal-type : вҲҖ {рқ“Ө рқ“Ҙ рқ“Ұ} {X : Type рқ“Ө} {Y : Type рқ“Ҙ}
                    (f : X вҶ’ Y)
                    (A : Type рқ“Ұ) вҶ’ Type (рқ“Ө вҠ” рқ“Ҙ вҠ” рқ“Ұ)
orthogonal-type f A = is-equiv (precomp A f)
}
}


\subtree[stt-004B]{
\taxon{Notation}

\p{When we have that #{f} is orthogonal to #{g}, we write
#{f \perp g}. Likewise if #{A} is a type, then we can write
  #{f \perp A} to mean #{f} is orthogonal to #{!_A}.}

\agda{
module notation where
  instance
    orth-maps
      : вҲҖ {рқ“Ө рқ“Ҙ рқ“Ұ рқ“ӣ}
          {A : Type рқ“Ө} {B : Type рқ“Ҙ} {C : Type рқ“Ұ} {D : Type рқ“ӣ}
        вҶ’ Orthogonality (A вҶ’ B) (C вҶ’ D)
    orth-maps .Orthogonality._вҠҘ_ = are-orthogonal

  instance
    orth-map-typ
      : вҲҖ {рқ“Ө рқ“Ҙ рқ“Ұ} {A : Type рқ“Ө} {B : Type рқ“Ҙ}
        вҶ’ Orthogonality (A вҶ’ B) (Type рқ“Ұ)
    orth-map-typ .Orthogonality._вҠҘ_ = orthogonal-type

open notation
}
}

\subtree[stt-004Q]{
\taxon{Proof}
\title{Proof of \ref{stt-004O}}

\p{
We want to show #{A \to \b1} is orthogonal to #{f : X \to Y}, which by
the [[stt-004A]], it surfices to show that for all #{h : Y \to 1}, the map
#{{-} \circ f : ((y : Y) \to \fibre{!}{h(y)}) \to ((x : X) \to \fibre{!}{h(f(x))})}
is an equivalence. But the fibre of #{A \to 1} is just A. Formally, we can
use the 3-for-2 property on the following diagram:
}

\quiver{
\begin{tikzcd}
	{\fibre{!}{-}^Y} &&& {\fibre{!}{-}^X} \\
	\\
	& {A^Y} & {A^X}
	\arrow[from=1-1, to=1-4]
	\arrow["\sim"', from=1-1, to=3-2]
	\arrow["{A^f}"', from=3-2, to=3-3]
	\arrow["\sim"', from=3-3, to=1-4]
\end{tikzcd}
}

\agda{
is-orthogonalвҮ”orthogonal-!
  : вҲҖ {рқ“Ө рқ“Ҙ рқ“Ұ} {X : Type рқ“Ө} {Y : Type рқ“Ҙ}
      {f : X вҶ’ Y} {A : Type рқ“Ұ}
    вҶ’ (f вҠҘ !: A)
    вҮ” (f вҠҘ A)
is-orthogonalвҮ”orthogonal-! {X = X} {Y} {f} {A}
  = ((О» orth вҶ’ is-equivвҶҗArrow-equiv {F = sq} sq-is-equiv
                                             (precomp-О вҶҗorthogonal ! orth))
    , О» orth вҶ’ orthogonalвҶҗprecomp-О 
                 О» _ вҶ’ is-equivвҶҗArrow-equivвҒ»В№ {F = sq} sq-is-equiv orth) where
  fstвҒ»В№ : A вҶ’ fibre {A = A} ! _
  fstвҒ»В№ a = a , refl

  fst-is-equiv : is-equiv {A = fibre {A = A} ! tt} fst
  fst-is-equiv = is-equivвҶҗqinv (fstвҒ»В№
                               , (О» where (a , refl) вҶ’ refl)
                               , ~refl)

  H :   (fst вҲҳ_) вҲҳ precomp-О  (fibre ! вҲҳ (О» _ вҶ’ tt)) f
      ~ precomp A f вҲҳ (fst вҲҳ_)
  H f' = funextвҶ’ ~refl

  sq : Arrow-map (precomp-О  (fibre {A = A} ! вҲҳ !) f) (precomp A f)
  sq .Arrow-map.top = fst вҲҳ_
  sq .Arrow-map.bot = fst вҲҳ_
  sq .Arrow-map.comm = H

  sq-is-equiv  : is-Arrow-equiv sq
  sq-is-equiv .fst = postcomp-equiv fst-is-equiv
  sq-is-equiv .snd = postcomp-equiv fst-is-equiv
}
}

\subtree[stt-00EB]{
\title{Anodyne maps}
\taxon{Definition}

\p{We say a map #{f} is #{k}-anodyne if any map orthogonal to #{k} is also
orthogonal to #{f}.}

\agda{
is-anodyne
  : вҲҖ {рқ“Ө рқ“Ҙ рқ“Ұ рқ“ң} {A : Type рқ“Ө} {B : Type рқ“Ҙ} {X : Type рқ“Ұ} {Y : Type рқ“ң}
    вҶ’ (A вҶ’ B) вҶ’ (X вҶ’ Y) вҶ’ TypeПү
is-anodyne f k
  = вҲҖ {рқ“Ө' рқ“Ҙ'} {U : Type рқ“Ө'} {V : Type рқ“Ҙ'} (g : U вҶ’ V)
   вҶ’ k вҠҘ g вҶ’ f вҠҘ g
}
}

\subtree[stt-00L3]{
\title{Orthogonality at a point}


\p{We can give a more simple representation of the type of lifting
problems as a pullback when the left map is an inclusion of a point.}

\agda{
module _ {рқ“ҳ рқ“Ө рқ“Ҙ} {A : Type рқ“Ө} {B : Type рқ“Ҙ} {f : A вҶ’ B}
         {I : Type рқ“ҳ} (p : I) where
  private
    m : Cospan-map
          (mk-cospan (рқҹҷ вҶ’ B) (postcomp _ f) (precomp _ (point p)))
          (mk-cospan B f (ev p))
    m .Cospan-map.hвӮҒ = ev tt
    m .Cospan-map.hвӮӮ = ev tt
    m .Cospan-map.hвӮғ = id
    m .Cospan-map.H = ~refl
    m .Cospan-map.K = ~refl

    m-is-equiv : is-cospan-equiv m
    m-is-equiv .fst = unit-ev-is-equiv
    m-is-equiv .snd .fst = unit-ev-is-equiv
    m-is-equiv .snd .snd = id-is-equiv

  orthogonal-point-gap-map : (I вҶ’ A) вҶ’ Pullback f (ev p)
  orthogonal-point-gap-map = PullbackвӮҒ m
                           вҲҳ pullbackвҶҗarrow
                           вҲҳ pullback-power (point p) f

  orthogonal-point-pullback-condition
    : point p вҠҘ f вҶ’ is-equiv orthogonal-point-gap-map
  orthogonal-point-pullback-condition orth
    = is-equiv-вҲҳ
        (PullbackвӮҒ-is-equiv m m-is-equiv)
        (is-equiv-вҲҳ
          (Arrow-mapвүғpullback ._вүғ_.fwd-is-equiv)
          (pullback-powerвҶҗpower-hom-cartesian
            (point p) f (is-cartesianвҶҗorthogonal orth)))
}
}

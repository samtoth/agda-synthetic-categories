\Function{[is-relative](stt-00AA)} \Symbol{:} \Symbol{∀} \Symbol{\lbrace{}}\Bound{[α](stt-00AA)} \Symbol{:} \Postulate{[Level](/html/Agda.Primitive.html#742)} \Symbol{→} \Postulate{[Level](/html/Agda.Primitive.html#742)} \Symbol{→} \Postulate{[Level](/html/Agda.Primitive.html#742)}\Symbol{\rbrace{}}
              \Symbol{→} \Symbol{\lpar{}∀} \Symbol{\lbrace{}}\Bound{[𝓤](stt-00AA)} \Bound{[𝓥](stt-00AA)}\Symbol{\rbrace{}} \Symbol{\lbrace{}}\Bound{[A](stt-00AA)} \Symbol{:} \Primitive{[Type](Foundations.Universes)} \Bound{[𝓤](stt-00AA)}\Symbol{\rbrace{}} \Symbol{→} \Symbol{\lpar{}}\Bound{[A](stt-00AA)} \Symbol{→} \Primitive{[Type](Foundations.Universes)} \Bound{[𝓥](stt-00AA)}\Symbol{\rpar{}} \Symbol{→} \Primitive{[Type](Foundations.Universes)} \Symbol{\lpar{}}\Bound{[α](stt-00AA)} \Bound{[𝓤](stt-00AA)} \Bound{[𝓥](stt-00AA)}\Symbol{\rpar{}\rpar{}}
              \Symbol{→} \Primitive{[Typeω](Foundations.Universes)}
\Function{[is-relative](stt-00AA)} \Bound{[is-fib](stt-00AA)}
  \Symbol{=} \Symbol{∀} \Symbol{\lbrace{}}\Bound{[𝓤](stt-00AA)} \Bound{[𝓥](stt-00AA)}\Symbol{\rbrace{}} \Symbol{\lbrace{}}\Bound{[A](stt-00AA)} \Symbol{:} \Primitive{[Type](Foundations.Universes)} \Bound{[𝓤](stt-00AA)}\Symbol{\rbrace{}} \Symbol{\lpar{}}\Bound{[P](stt-00AA)} \Symbol{:} \Bound{[A](stt-00AA)} \Symbol{→} \Primitive{[Type](Foundations.Universes)} \Bound{[𝓥](stt-00AA)}\Symbol{\rpar{}}
    \Symbol{→} \Symbol{\lpar{}}\Bound{[is-fib](stt-00AA)} \Bound{[P](stt-00AA)} \Function{\Operator{[⇔](stt-001G)}} \Symbol{\lpar{}∀} \Symbol{\lpar{}}\Bound{[x](stt-00AA)} \Symbol{:} \Bound{[I](Archive.Synthetic.Tiny)} \Symbol{→} \Bound{[A](stt-00AA)}\Symbol{\rpar{}} \Symbol{→} \Bound{[is-fib](stt-00AA)} \Symbol{\lpar{}}\Bound{[P](stt-00AA)} \Function{\Operator{[∘](Foundations.Functions)}} \Bound{[x](stt-00AA)}\Symbol{\rpar{}} \Symbol{\rpar{}\rpar{}}

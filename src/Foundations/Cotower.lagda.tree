}
%```

\subtree[stt-0085]{
\title{Cotowers}
\taxon{Definition}

\p{
A \em{cotower}, or \em{increasing type sequence}, is a diagram of the form:

\quiver{
\begin{tikzcd}
	{A_0} & {A_1} & {A_n} & {A_{n+1}} & {...}
	\arrow["{f_0}"', from=1-1, to=1-2]
	\arrow[dashed, from=1-2, to=1-3]
	\arrow["{f_n}"', from=1-3, to=1-4]
	\arrow[dashed, from=1-4, to=1-5]
\end{tikzcd}
}
Concretely, for each natural number #{n} we have a type #{A_n} and a map
#{f_n : A_n \to A_{n+1}}.
}

%```agda
\agda{
record Cotower 𝓤 : Type (lsuc 𝓤) where
  constructor mk-cotower
  field
    Point : ℕ → Type 𝓤
    incr  : ∀ {n} → Point n → Point (suc n)

  incrΣ : Σ ℕ Point → Σ ℕ Point
  incrΣ (n , a) = (suc n , incr a)

  incrℕ : ∀ m → Point 0 → Point m
  incrℕ zero = id
  incrℕ (suc m) = incr ∘ incrℕ m

  incr-+ : ∀ {n} m → Point n → Point (n + m)
  incr-+ {n} zero = id
  incr-+ {n} (suc m) = incr ∘ incr-+ m

shift-cotower : ∀ {𝓤} → Cotower 𝓤 → Cotower 𝓤
shift-cotower (mk-cotower Point incr)
  = mk-cotower (Point ∘ suc) (λ {n} → incr {suc n})
}
%```
}

\subtree[stt-0086]{
\title{Maps of cotowers}
\taxon{Definition}

\p{
A \em{map} of cotowers #{A \to B} is a map of each type #{A_n \to B_n}, such that all
the squares commute.
}

%```agda
\agda{
record Cotower-map {𝓤 𝓥}
         (A : Cotower 𝓤) (B : Cotower 𝓥) : Type (𝓤 ⊔ 𝓥) where
  constructor mk-cotower-map
  module A = Cotower A
  module B = Cotower B
  field
    map  : ∀ {n} → A.Point n → B.Point n
    comm : ∀ {n} → B.incr ∘ map {n} ~ map ∘ A.incr
}
%```
}

\subtree[stt-0090]{
\title{Composing maps of cotowers}
\taxon{Construction}

\p{
We compose maps of cotowers in the obvious way by composing their components and
pasting together squares.
}

%```agda
\agda{
comp-cotower-map
  : ∀ {𝓤 𝓥 𝓦} {S : Cotower 𝓤} {S' : Cotower 𝓥}
      {S'' : Cotower 𝓦}
    → Cotower-map S' S''
    → Cotower-map S S'
    → Cotower-map S S''
comp-cotower-map F G = map where
  module F = Cotower-map F
  module G = Cotower-map G

  map : Cotower-map _ _
  map .Cotower-map.map = F.map ∘ G.map
  map .Cotower-map.comm = F.comm ▸ G.map ~∙ F.map ◂ G.comm

id-cotower-map
  : ∀ {𝓤} {S : Cotower 𝓤} → Cotower-map S S
id-cotower-map .Cotower-map.map = id
id-cotower-map .Cotower-map.comm = ~refl
}
%```
}

\subtree[stt-0091]{
\title{Homotopies of maps of cotowers}
\taxon{Definition}

\p{
Given a pair of maps of cotowers #{f, g : A \to B}, we define a \em{homotopy}
#{f \sim g} to be a homotopy at each component #{f_n \sim g_n} together
with a coherence condition between the squares of each maps.
}

%```agda
\agda{
cotower-map~ : ∀ {𝓤 𝓥} {S : Cotower 𝓤} {S' : Cotower 𝓥}
              (F G : Cotower-map S S')
            → Type (𝓤 ⊔ 𝓥)
cotower-map~ F G = Σ[ α ∶ (∀ {n} → map F {n} ~ map G)]
                  (∀ {n} →  comm F ~∙ α ▸ A.incr G
                       ~ (B.incr F ◂ α) ~∙ comm G {n})
  where open Cotower-map
}
%```
}


\subtree[stt-008X]{
\title{Equivalences of cotowers}
\taxon{Definition}
\date{2025-08-14}

\p{
A map of cotowers is an \em{equivalence} of sequences when each component is an
equivalence.
}

%```agda
\agda{
is-cotower-equiv : ∀ {𝓤 𝓥} {A : Cotower 𝓤} {B : Cotower 𝓥}
                  (F : Cotower-map A B) → Type (𝓤 ⊔ 𝓥)
is-cotower-equiv F = ∀ n → is-equiv (F .Cotower-map.map {n})


cotower-map-inv←equiv : ∀ {𝓤 𝓥} {A : Cotower 𝓤} {B : Cotower 𝓥}
                      {F : Cotower-map A B} (Feq : is-cotower-equiv F)
                    → Cotower-map B A
cotower-map-inv←equiv {A = A}{B}{F} Feq = imap where
  open Cotower-map
  module F {n} = is-equiv (Feq n)
  imap : Cotower-map B A
  imap .map = F.bwd
  imap .comm =   (F.η ~⁻¹) ▸ Cotower.incr A ▸ F.bwd
               ~∙ F.bwd ◂ (  (comm F ~⁻¹) ▸ F.bwd
                          ~∙ Cotower.incr B ◂ F.ε)
}
%```
}


\subtree[stt-00HK]{
\date{2026-03-11}
\author{fredrikbakke}
\title{The cotower associated to an endomap}
\taxon{Definition}

\p{
Given an endomap #{f : A \to A} then we can form the cotower which repeats that
endomap indefinitely.
##{A \xrightarrow{f} A \to \cdots \to A \xrightarrow{f} A \to \cdots}
}

%```agda
\agda{
cotower←endomap
  : ∀ {𝓤} {A : Type 𝓤}
  → (A → A) → Cotower 𝓤
cotower←endomap {A = A} f = mk-cotower (λ _ → A) f
}
%```
}

\subtree[stt-0087]{
\title{Constant cotowers}
\taxon{Definition}

\p{We can define the constant sequence at a type. We write #{\Delta_A}
for the constant sequence at #{A}.}

%```agda
\agda{
const-cotower : ∀ {𝓤} → Type 𝓤 → Cotower 𝓤
const-cotower A = cotower←endomap {A = A} id
}
%```
}

\subtree[stt-0088]{
\title{Cocones over cotowers}
\taxon{Definition}

%```agda
\agda{
record Seq-cocone {𝓤 𝓥} (S : Cotower 𝓤) (Apex : Type 𝓥)
         : Type (𝓤 ⊔ 𝓥) where
  constructor mk-seq-cocone
  open Cotower S

  field
    ι    : ∀ {n} → Point n → Apex
    comm : ∀ {n} → ι ~ ι ∘ incr {n}
}
%```
}

\subtree[stt-0089]{
\title{Cocones as maps of cotowers}
\taxon{Theorem}

\p{A cone over a decreasing sequence #{B} at apex #{A} is a map
#{\Delta_A \to B}}

%```agda
\agda{
cotower-map←cocone : ∀ {𝓤 𝓥} {S : Cotower 𝓤} {Apex : Type 𝓥}
                   → Seq-cocone S Apex
                   → Cotower-map S (const-cotower Apex)
cotower-map←cocone (mk-seq-cocone ι comm) = mk-cotower-map ι comm

cotower-map≃cocone : ∀ {𝓤 𝓥} {S : Cotower 𝓤} {Apex : Type 𝓥}
                   → Seq-cocone S Apex
                   ≃ Cotower-map S (const-cotower Apex)
cotower-map≃cocone = mk≃ _ (is-equiv←qiso qiso) where
  qiso : quasi-iso cotower-map←cocone
  qiso .fst (mk-cotower-map map comm) = mk-seq-cocone map comm
  qiso .snd .fst (mk-seq-cocone π comm) = refl
  qiso .snd .snd (mk-cotower-map map comm) = refl
}
%```
}

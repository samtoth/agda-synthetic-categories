\subtree[stt-00JV]{
\title{Sharp codiscrete maps lift crisply against the flat counit}
\taxon{Lemma}

\citet{3.1.2}{MR2023}

\p{This follows straightforwardly from the fact that for any reflective
subuniverse, connected and modal maps are the (respectively) left and right
classes of an orthogonal factorisation system, and the fact that
#{\varepsilon} is a #{\sharp}-connected map.}

%```agda
\agda{
lifts-╬╡έβφέΗΡis-έβψ-codiscrete
  : έΙΑ {@έβφ ΏζΥν ΏζΥξ} {@έβφ A : Type ΏζΥν} {@έβφ B : Type ΏζΥξ} {@έβφ f : A έΗΤ B}
    έΗΤ @έβφ is-έβψ-codiscrete-map f
    έΗΤ (έΙΑ {@έβφ ΏζΥι} {@έβφ Q : Type ΏζΥι} έΗΤ are-έβφ-orthogonal (╬╡έβφ: Q) f)
lifts-╬╡έβφέΗΡis-έβψ-codiscrete {f = f} fcd {_}{Q}
  = έβφ-is-cartesian (power-hom ╬╡έβφ f)
      (is-cartesianέΗΡorthogonal
        (gRSubUConnectedCharacterisation.connectedέΛξmodal έβψ-gRSubU
          (is-έβψ-connectedέΗΡis-έβψ-equiv ╬╡-is-έβψ-equiv)
          fcd))
}
%```
}


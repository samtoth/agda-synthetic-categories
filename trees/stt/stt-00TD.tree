\date{2026-06-08}
\title{Quasicoherent Algebras}
\author{markwilliams}
\meta{external}{https://github.com/samtoth/agda-synthetic-categories/pull/69}
\tag{changelog}
\import{stt-macros}

\subtree{
\title{Summary}
\p{This PR defines the type of quasicoherent algebras over a lattice as the fixed points
of an adjunction #{\Obs \vdash \Spec}. From this we show for distributive #{\II} that
if #{\II[x]} is quasicoherent then Phoa's principle holds. This PR also makes a number of
improvements to the lattice algebra section of the library, notably moving the algebra
interface to be bundled.}
}

\subtree{
\title{New modules}

\ul{
\li{\ref{Synthetic.Quasicoherence}}
}

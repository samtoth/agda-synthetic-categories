\subtree[stt-00BU]{
\title{Being right orthogonal is preserved under pullback and equivalence}
\taxon{Lemma}
\date{2025-11-26}

\p{Given a [cartesian square](stt-003V) between maps #{g} and #{h}, then if
#{f \perp h}, #{f \perp g}.}


\proof{
\p{Consider the following [cube](stt-00B2):}

\quiver{
\begin{tikzcd}[cramped]
	& {C^Y} && {C^X} \\
	{A^Y} && {A^X} \\
	& {D^Y} && {D^X} \\
	{B^Y} && {B^X}
	\arrow[from=1-2, to=1-4]
	\arrow["{h_*}"'{pos=0.6}, from=1-2, to=3-2]
	\arrow[from=1-4, to=3-4]
	\arrow[from=2-1, to=1-2]
	\arrow[from=2-1, to=2-3]
	\arrow["{g_*}"', from=2-1, to=4-1]
	\arrow[from=2-3, to=1-4]
	\arrow[from=2-3, to=4-3]
	\arrow["{f^*}"{pos=0.3}, from=3-2, to=3-4]
	\arrow[from=4-1, to=3-2]
	\arrow["{f^*}"', from=4-1, to=4-3]
	\arrow[from=4-3, to=3-4]
\end{tikzcd}
}

\p{The left and right faces are cartesian since [precomposing a cartesian square
gives a cartesian square](stt-003R), then by our assumption the back square is
cartesian, [so the front square is cartesian](stt-00B3).}
}

%```agda
\agda{
power-hom-cubeтЖРright-arrow-map
  : тИА {ЁЭУд ЁЭУе ЁЭУж ЁЭУЬ ЁЭУЭ ЁЭУЫ} {A : Type ЁЭУд} {B : Type ЁЭУе} (f : A тЖТ B)
      {X : Type ЁЭУж} {Y : Type ЁЭУЬ} (g : X тЖТ Y)
      {C : Type ЁЭУЭ} {D : Type ЁЭУЫ} (g' : C тЖТ D)
      (F : Arrow-map g g')
    тЖТ Cube (power-hom f g) (power-hom f g')
power-hom-cubeтЖРright-arrow-map f g g' F .Cube.left = postcomp-square F _
power-hom-cubeтЖРright-arrow-map f g g' F .Cube.right = postcomp-square F _
power-hom-cubeтЖРright-arrow-map f g g' F .Cube.comm .fst = ~refl
power-hom-cubeтЖРright-arrow-map f g g' F .Cube.comm .snd .fst = ~refl
power-hom-cubeтЖРright-arrow-map f g g' F .Cube.comm .snd .snd a
    = тИЩ-reflr _ тИЩ тИЩ-reflr _ тИЩ sym (commutes-prewhisker-funext _)

orthogonalтЖРbase-change
  : тИА {ЁЭУд ЁЭУе ЁЭУР ЁЭУС ЁЭУТ ЁЭУУ} {X : Type ЁЭУд} {Y : Type ЁЭУе} (f : X тЖТ Y)
      {A : Type ЁЭУР} {B : Type ЁЭУС} {C : Type ЁЭУТ} {D : Type ЁЭУУ}
      {g : A тЖТ B} {h : C тЖТ D}
    тЖТ (F : Arrow-map g h) тЖТ is-cartesian F
    тЖТ are-orthogonal f h тЖТ are-orthogonal f g
orthogonalтЖРbase-change {X = X} {Y} f {A} {g = g}{h} F cart orth
  = orthogonalтЖРis-cartesian
     (front-cartesianтЖРcartesian-cube
       (power-hom f g) (power-hom f h)
       (power-hom-cubeтЖРright-arrow-map _ _ _ F)
       (postcomp-cartesian F cart)
       (postcomp-cartesian F cart)
       (is-cartesianтЖРorthogonal orth))
}
%```


\p{Similarly, if #{F : g \to h} is an equivalence, then
#{f \perp g \iff f \perp h}.}

%```agda
\agda{
right-orthogonalтЖРequiv
  : тИА {ЁЭУд ЁЭУе ЁЭУР ЁЭУС ЁЭУТ ЁЭУУ} {X : Type ЁЭУд} {Y : Type ЁЭУе} (f : X тЖТ Y)
      {A : Type ЁЭУР} {B : Type ЁЭУС} {C : Type ЁЭУТ} {D : Type ЁЭУУ}
      {g : A тЖТ B} {h : C тЖТ D}
    тЖТ (F : Arrow-map g h) тЖТ is-Arrow-equiv F
    тЖТ are-orthogonal f h тЖТ are-orthogonal f g
right-orthogonalтЖРequiv f F Fe o
  = orthogonalтЖРis-cartesian
      (front-cartesianтЖРequiv-cube
        (power-hom-cubeтЖРright-arrow-map f _ _ F)
        (postcomp-square-is-equiv F Fe , postcomp-square-is-equiv F Fe)
        (is-cartesianтЖРorthogonal o))

right-orthogonalтЖРequiv'
  : тИА {ЁЭУд ЁЭУе ЁЭУР ЁЭУС ЁЭУТ ЁЭУУ} {X : Type ЁЭУд} {Y : Type ЁЭУе} (f : X тЖТ Y)
      {A : Type ЁЭУР} {B : Type ЁЭУС} {C : Type ЁЭУТ} {D : Type ЁЭУУ}
      {g : A тЖТ B} {h : C тЖТ D}
    тЖТ (F : Arrow-map g h) тЖТ is-Arrow-equiv F
    тЖТ are-orthogonal f g тЖТ are-orthogonal f h
right-orthogonalтЖРequiv' f F Fe o
  = orthogonalтЖРis-cartesian
      (back-cartesianтЖРequiv-cube
        (power-hom-cubeтЖРright-arrow-map f _ _ F)
        (postcomp-square-is-equiv F Fe , postcomp-square-is-equiv F Fe)
        (is-cartesianтЖРorthogonal o))

right-orthogonal-iffтЖРequiv
  : тИА {ЁЭУд ЁЭУе ЁЭУР ЁЭУС ЁЭУТ ЁЭУУ} {X : Type ЁЭУд} {Y : Type ЁЭУе} (f : X тЖТ Y)
      {A : Type ЁЭУР} {B : Type ЁЭУС} {C : Type ЁЭУТ} {D : Type ЁЭУУ}
      {g : A тЖТ B} {h : C тЖТ D}
    тЖТ (F : Arrow-map g h) тЖТ is-Arrow-equiv F
    тЖТ are-orthogonal f h тЗФ are-orthogonal f g
right-orthogonal-iffтЖРequiv f F Fe
  = (right-orthogonalтЖРequiv f F Fe , right-orthogonalтЖРequiv' f F Fe)

right-orthogonal-id
  : тИА {ЁЭУд ЁЭУе ЁЭУж} {X : Type ЁЭУд} {Y : Type ЁЭУе} (f : X тЖТ Y)
      {A : Type ЁЭУж}
    тЖТ are-orthogonal f (id: A)
right-orthogonal-id f {A = A}
  = orthogonalтЖРis-cartesian
      (is-cartesianтЖРdom+cod-is-equiv
        (power-hom f (id: A))
        (postcomp-equiv id-is-equiv)
        (postcomp-equiv id-is-equiv))

right-orthogonalтЖРis-equiv
  : тИА {ЁЭУд ЁЭУе ЁЭУж ЁЭУЫ} {X : Type ЁЭУд} {Y : Type ЁЭУе} (f : X тЖТ Y)
      {A : Type ЁЭУж} {B : Type ЁЭУЫ}
      {g : A тЖТ B}
    тЖТ is-equiv g
    тЖТ are-orthogonal f g
right-orthogonalтЖРis-equiv f {B = B} {g = g} geq
  = right-orthogonalтЖРequiv
      f
      (mk-amap g (id: B) ~refl)
      (geq , id-is-equiv)
      (right-orthogonal-id f)
}
%```
}

\subtree[stt-00LW]{
\title{Right orthogonal maps are closed under retracts of arrows}
\taxon{Lemma}
\author{fredrikbakke}
\date{2026-04-05}

%```agda
\agda{
right-orthogonalтЖРretraction
  : {ЁЭУд ЁЭУе ЁЭУР ЁЭУС ЁЭУТ ЁЭУУ : Level}
    {X : Type ЁЭУд} {Y : Type ЁЭУе} (f : X тЖТ Y)
    {A : Type ЁЭУР} {B : Type ЁЭУС} {C : Type ЁЭУТ} {D : Type ЁЭУУ}
    {g : A тЖТ B} {h : C тЖТ D}
  тЖТ (F : Arrow-map g h)
  тЖТ retraction-arrow-map F
  тЖТ are-orthogonal f h
  тЖТ are-orthogonal f g
right-orthogonalтЖРretraction f F ret orth
  = orthogonalтЖРpb-power-is-equiv
      (is-equivтЖРincoherent-retraction-equiv
        (pullback-powerтЖРright-arrow-map f F)
        (pullback-powerтЖРright-arrow-map f (ret .fst)
        , (╬╗ l тЖТ funextтЖТ (╬╗ b тЖТ ret .snd .fst (l b)))
        , ╬╗ G
          тЖТ Arrow-map-pathтЖТ (paste-squares-assoc (ret .fst) F G)
          тИЩ ap (╬╗ K тЖТ paste-squares K G)
               (Arrow-map-pathтЖТ (retraction-arrow-map-is-retraction F ret))
          тИЩ Arrow-map-pathтЖТ (paste-squares-left-id G))
        (pb-power-is-equivтЖРorthogonal orth))
}
%```
}

\subtree[stt-00BW]{
\title{Composition and left cancellation closure of right orthogonal maps}
\taxon{Lemma}
\date{2025-12}
\author{samueltoth}
\date{2026-04-07}
\author{fredrikbakke}

%```agda
\agda{
right-orthogonal-тИШ
  : тИА {ЁЭУз ЁЭУи ЁЭУд ЁЭУе ЁЭУж} {X : Type ЁЭУз} {Y : Type ЁЭУи} (f : X тЖТ Y)
      {A : Type ЁЭУд}{B : Type ЁЭУе} {C : Type ЁЭУж}
      {g : B тЖТ C} {h : A тЖТ B}
    тЖТ f тКе g тЖТ f тКе h тЖТ f тКе g тИШ h
right-orthogonal-тИШ h fg fh
  = orthogonalтЖРis-cartesian
      (transpose-is-cartesian _
        (compose-cartesian
          (transpose-is-cartesian _ (is-cartesianтЖРorthogonal fg))
          (transpose-is-cartesian _ (is-cartesianтЖРorthogonal fh))))

right-orthogonal-left-cancel
  : тИА {ЁЭУз ЁЭУи ЁЭУд ЁЭУе ЁЭУж} {X : Type ЁЭУз} {Y : Type ЁЭУи} (f : X тЖТ Y)
      {A : Type ЁЭУд}{B : Type ЁЭУе} {C : Type ЁЭУж}
      {g : B тЖТ C} {h : A тЖТ B}
    тЖТ f тКе g тЖТ f тКе g тИШ h тЖТ f тКе h
right-orthogonal-left-cancel f fg fgh
  = orthogonalтЖРis-cartesian
      (transpose-is-cartesian _
        (3-for-2-cartesian
          Arrow-map-path-refl
          (transpose-is-cartesian _ (is-cartesianтЖРorthogonal fgh))
          (transpose-is-cartesian _ (is-cartesianтЖРorthogonal fg))))

right-orthogonal-homotopy
  : тИА {ЁЭУз ЁЭУи ЁЭУд ЁЭУе} {X : Type ЁЭУз} {Y : Type ЁЭУи} (f : X тЖТ Y)
      {A : Type ЁЭУд} {B : Type ЁЭУе} {g h : A тЖТ B}
    тЖТ g ~ h
    тЖТ f тКе g
    тЖТ f тКе h
right-orthogonal-homotopy f {A = A} {B = B} {g = g} {h = h} H
  = right-orthogonalтЖРequiv' f
      (mk-amap (id: A) (id: B) H)
      (id-square-is-equiv {f = g})

right-orthogonal-тИШ~
  : тИА {ЁЭУз ЁЭУи ЁЭУд ЁЭУе ЁЭУж} {X : Type ЁЭУз} {Y : Type ЁЭУи} (f : X тЖТ Y)
      {A : Type ЁЭУд} {B : Type ЁЭУе} {C : Type ЁЭУж}
      {g : B тЖТ C} {h : A тЖТ B} {k : A тЖТ C}
    тЖТ g тИШ h ~ k
    тЖТ f тКе g
    тЖТ f тКе h
    тЖТ f тКе k
right-orthogonal-тИШ~ f H fg fh
  = right-orthogonal-homotopy f H (right-orthogonal-тИШ f fg fh)

right-orthogonal-left-cancel~
  : тИА {ЁЭУз ЁЭУи ЁЭУд ЁЭУе ЁЭУж} {X : Type ЁЭУз} {Y : Type ЁЭУи} (f : X тЖТ Y)
      {A : Type ЁЭУд} {B : Type ЁЭУе} {C : Type ЁЭУж}
      {g : B тЖТ C} {h : A тЖТ B} {k : A тЖТ C}
    тЖТ k ~ g тИШ h
    тЖТ f тКе g
    тЖТ f тКе k
    тЖТ f тКе h
right-orthogonal-left-cancel~ f H fg fk
  = right-orthogonal-left-cancel f fg
      (right-orthogonal-homotopy f H fk)
}
%```
}

\subtree{
\title{Equivalences are right orthogonal to any map}

%```agda
\agda{
opaque
  тКеequiv
    : тИА {ЁЭУд ЁЭУе ЁЭУж ЁЭУЬ} {A : Type ЁЭУд} {B : Type ЁЭУе} (f : A тЖТ B)
        {C : Type ЁЭУж} {D : Type ЁЭУЬ} (e : C тЖТ D) тЖТ is-equiv e
      тЖТ f тКе e
  тКеequiv f e ee = orthogonalтЖРis-cartesian
    (transpose-is-cartesian (transpose-square (power-hom f e))
      (is-cartesianтЖРis-equiv
        _
        ((postcomp-equiv ee) , (postcomp-equiv ee))))

_тКеid : тИА {ЁЭУд ЁЭУе ЁЭУж} {A : Type ЁЭУд} {B : Type ЁЭУе} (f : A тЖТ B) {C : Type ЁЭУж}
       тЖТ f тКе id: C
f тКеid = тКеequiv f id id-is-equiv
}
%```
}

\subtree[stt-00BV]{
\title{Closure properties of left orthogonal maps}
\taxon{Theorem}

\subtree[stt-00C0]{
\p{In general, left orthogonal maps are closed under 'colimit' like operations.
Suppose any map labeled with an #{f} is left orthogonal to #{h}, then:}

\ol{
\li{#{f \times f' \perp h}}
\li{#{g \circ f \perp h} iff #{g \perp h}}
\li{#{\Sigma_{i}f_i \perp h}}
\li{If there is a cocartesian square #{f \to g}, then #{g \perp h}}
\li{If #{g} is a retract of #{f}, then #{g \perp h}}
\li{For \strong{any} #{g}, the pushout product #{f \pushprod g \perp h}}
}
}

%```agda
\agda{
power-hom-cubeтЖРarrow-map
  : тИА {ЁЭУд ЁЭУе ЁЭУж ЁЭУЬ ЁЭУЭ ЁЭУЫ} {A : Type ЁЭУд} {B : Type ЁЭУе} (f : A тЖТ B)
      {X : Type ЁЭУж} {Y : Type ЁЭУЬ} (f' : X тЖТ Y)
      (F : Arrow-map f f')
      {C : Type ЁЭУЭ} {D : Type ЁЭУЫ} (g : C тЖТ D)
    тЖТ Cube (transpose-square (power-hom f' g)) (transpose-square (power-hom f g))
power-hom-cubeтЖРarrow-map f f' F g .Cube.left = precomp-square F _
power-hom-cubeтЖРarrow-map f f' F g .Cube.right = precomp-square F _
power-hom-cubeтЖРarrow-map f f' F g .Cube.comm .fst = ~refl
power-hom-cubeтЖРarrow-map f f' F g .Cube.comm .snd .fst = ~refl
power-hom-cubeтЖРarrow-map f f' F g .Cube.comm .snd .snd k
  = тИЩ-reflr _ тИЩ тИЩ-reflr _
  тИЩ sym (commutes-postwhisker-funext {h = g} _)
  тИЩ ap funextтЖТ (funextтЖТ (тЧВтИШ g k _ ~тБ╗┬╣))

left-orthogonal-retraction
  : тИА {ЁЭУд ЁЭУе ЁЭУж ЁЭУЬ ЁЭУЭ ЁЭУЫ} {A : Type ЁЭУд} {B : Type ЁЭУе} (f : A тЖТ B)
      {X : Type ЁЭУж} {Y : Type ЁЭУЬ} (f' : X тЖТ Y)
      (F : Arrow-map f f') (R : retraction-arrow-map F)
      {C : Type ЁЭУЭ} {D : Type ЁЭУЫ} (g : C тЖТ D)
      тЖТ (f' тКе g) тЖТ (f тКе g)
left-orthogonal-retraction {A = A}{B} f f' F ret {C}{D} h f'h
  = orthogonalтЖРis-cartesian
      (transpose-is-cartesian _
        (is-cartesianтЖР1-coherent-retraction-cube cube cube-ret
          (transpose-is-cartesian _ (is-cartesianтЖРorthogonal f'h)))) where
  cube : Cube (transpose-square (power-hom f h)) (transpose-square (power-hom f' h))
  cube = power-hom-cubeтЖРarrow-map _ _ (ret .fst) h

  cube-ret : 1-coherent-retraction-cube cube
  cube-ret .fst = power-hom-cubeтЖРarrow-map _ _ F h
  cube-ret .snd .fst x = funextтЖТ (x тЧВ ret .snd .snd .fst)
  cube-ret .snd .snd
    = (ret-left .snd .fst
    ,  ret-right .snd .fst
    ,  ret-right .fst
    ,  (╬╗ f тЖТ sym (ap-тИШ  (h тИШ_) (f тИШ_) (funextтЖТ (ret .snd .fst))))
    ,  ╬╗ a тЖТ sym
              (тИЩ-assoc
                (ap (_тИШ Arrow-map.top F) (funextтЖТ (a тЧВ _)))
                (funextтЖТ ( a тИШ Arrow-map.bot (ret .fst) тЧВ (Arrow-map.comm F ~тБ╗┬╣)))
                ((precomp D f тЧВ ret-right .fst) a))
              тИЩ ret-right .snd .snd a тИЩ тИЩ-reflr _) where
    ret-left : Arrow-map-path
                (paste-squares (precomp-retraction-square F ret .fst)
                               (precomp-square (ret .fst) C))
                id-square
    ret-left = retraction-arrow-map-is-retraction
                         (precomp-square (ret .fst) C)
                         (precomp-retraction-square F ret)


    ret-right : Arrow-map-path
                (paste-squares (precomp-retraction-square F ret .fst)
                               (precomp-square (ret .fst) D))
                id-square
    ret-right = retraction-arrow-map-is-retraction
                         (precomp-square (ret .fst) D)
                         (precomp-retraction-square F ret)

left-orthogonal-equiv
  : тИА {ЁЭУд ЁЭУе ЁЭУж ЁЭУЬ ЁЭУЭ ЁЭУЫ} {A : Type ЁЭУд} {B : Type ЁЭУе} (f : A тЖТ B)
      {X : Type ЁЭУж} {Y : Type ЁЭУЬ} (f' : X тЖТ Y)
      (F : Arrow-map f f') тЖТ is-Arrow-equiv F
    тЖТ {C : Type ЁЭУЭ} {D : Type ЁЭУЫ} (g : C тЖТ D)
    тЖТ f тКе g тЖТ f' тКе g
left-orthogonal-equiv f f' F Feq g fperp
  = orthogonalтЖРis-cartesian
      (transpose-is-cartesian _
        (front-cartesianтЖРequiv-cube (power-hom-cubeтЖРarrow-map _ _ F g)
          (precomp-square-is-equiv F Feq , precomp-square-is-equiv F Feq)
          (transpose-is-cartesian _ (is-cartesianтЖРorthogonal fperp))))

left-orthogonal-тИШ
  : тИА {ЁЭУд ЁЭУе ЁЭУж ЁЭУЬ ЁЭУЭ} {B : Type ЁЭУд} {C : Type ЁЭУе} (f : B тЖТ C)
      {A : Type ЁЭУж} (g : A тЖТ B)
      {X : Type ЁЭУЬ} {Y : Type ЁЭУЭ} (h : X тЖТ Y)
    тЖТ (f тКе h) тЖТ (g тКе h) тЖТ (f тИШ g) тКе h
left-orthogonal-тИШ f g h fh gh
  = orthogonalтЖРis-cartesian
      (compose-cartesian
        (is-cartesianтЖРorthogonal gh)
        (is-cartesianтЖРorthogonal fh))

is-anodyne-тИШ
  : тИА {ЁЭУд ЁЭУе ЁЭУж ЁЭУз ЁЭУи} {A : Type ЁЭУд} {B : Type ЁЭУе} {C : Type ЁЭУж}
      {f : B тЖТ C} {g : A тЖТ B}
      {X : Type ЁЭУз} {Y : Type ЁЭУи} (h : X тЖТ Y)
    тЖТ is-anodyne f h тЖТ is-anodyne g h тЖТ is-anodyne (f тИШ g) h
is-anodyne-тИШ h fia gia k ko
  =  left-orthogonal-тИШ _ _ _ (fia k ko) (gia k ko)

left-orthogonal-right-cancel
  : тИА {ЁЭУд ЁЭУе ЁЭУж ЁЭУЬ ЁЭУЭ} {B : Type ЁЭУд} {C : Type ЁЭУе} {f : B тЖТ C}
      {A : Type ЁЭУж} {g : A тЖТ B}
      {X : Type ЁЭУЬ} {Y : Type ЁЭУЭ} {h : X тЖТ Y}
    тЖТ (g тКе h) тЖТ (f тИШ g) тКе h тЖТ (f тКе h)
left-orthogonal-right-cancel gh fgh
  = orthogonalтЖРis-cartesian
      (3-for-2-cartesian
         Arrow-map-path-refl
         (is-cartesianтЖРorthogonal fgh)
         (is-cartesianтЖРorthogonal gh))

is-anodyne-right-cancel
  : тИА {ЁЭУд ЁЭУе ЁЭУж ЁЭУз ЁЭУи} {A : Type ЁЭУд} {B : Type ЁЭУе} {C : Type ЁЭУж}
      {f : B тЖТ C} {g : A тЖТ B}
      {X : Type ЁЭУз} {Y : Type ЁЭУи} (h : X тЖТ Y)
    тЖТ is-anodyne (f тИШ g) h тЖТ is-anodyne g h тЖТ is-anodyne f h
is-anodyne-right-cancel h fgia gia k ko
  = left-orthogonal-right-cancel (gia k ko) (fgia k ko)


left-orthogonal-homotopy
  : тИА {ЁЭУд ЁЭУе ЁЭУЬ ЁЭУЭ} {A : Type ЁЭУд} {B : Type ЁЭУе} {f g : A тЖТ B}
      {X : Type ЁЭУЬ} {Y : Type ЁЭУЭ} (h : X тЖТ Y)
      (H : f ~ g)
    тЖТ (f тКе h) тЖТ (g тКе h)
left-orthogonal-homotopy h = funext-rec _ ╬╗ where refl тЖТ id

is-anodyne-homotopy
  : тИА {ЁЭУд ЁЭУе ЁЭУз ЁЭУи} {A : Type ЁЭУд} {B : Type ЁЭУе} {f g : A тЖТ B}
      {X : Type ЁЭУз} {Y : Type ЁЭУи} (h : X тЖТ Y)
    тЖТ f ~ g
    тЖТ is-anodyne f h тЖТ is-anodyne g h
is-anodyne-homotopy h H fia k o = left-orthogonal-homotopy k H (fia k o)

left-orthogonal-╬г
  : тИА {ЁЭУд ЁЭУе ЁЭУж ЁЭУЬ ЁЭУЭ} {A : Type ЁЭУд}
      {B : A тЖТ Type ЁЭУе} {C : A тЖТ Type ЁЭУж} (f : тИА a тЖТ B a тЖТ C a)
      {X : Type ЁЭУЬ} {Y : Type ЁЭУЭ} (g : X тЖТ Y)
      тЖТ (тИА a тЖТ f a тКе g) тЖТ (total-map f) тКе g
left-orthogonal-╬г {A = A} {B} {C} f {Y = Y} g fg
  = orthogonalтЖРis-cartesian
      (front-cartesianтЖРequiv-cube
        cube
        cube-is-equiv
        (╬а-square-is-cartesian _ (is-cartesianтЖРorthogonal тИШ fg))) where
  cube : Cube (power-hom (total-map f) g) (╬а-square (╬╗ i тЖТ power-hom (f i) g))
  cube .Cube.left .Arrow-map.top = curry
  cube .Cube.left .Arrow-map.bot = curry
  cube .Cube.left .Arrow-map.comm = ~refl
  cube .Cube.right .Arrow-map.top = curry
  cube .Cube.right .Arrow-map.bot = curry
  cube .Cube.right .Arrow-map.comm = ~refl
  cube .Cube.comm .fst = ~refl
  cube .Cube.comm .snd .fst = ~refl
  cube .Cube.comm .snd .snd a = тИЩ-reflr _ тИЩ funext-refl

  cube-is-equiv : is-Cube-equiv cube
  cube-is-equiv .fst .fst = curry-is-equiv
  cube-is-equiv .fst .snd = curry-is-equiv
  cube-is-equiv .snd .fst = curry-is-equiv
  cube-is-equiv .snd .snd = curry-is-equiv


left-orthogonal-├Ч
  : тИА {ЁЭУд ЁЭУе ЁЭУж ЁЭУЬ ЁЭУЭ ЁЭУЫ} {A : Type ЁЭУд} {B : Type ЁЭУе} (f : A тЖТ B)
      {X : Type ЁЭУж} {Y : Type ЁЭУЬ} (f' : X тЖТ Y)
      {C : Type ЁЭУЭ} {D : Type ЁЭУЫ} (g : C тЖТ D)
      тЖТ (f тКе g) тЖТ (f' тКе g) тЖТ (f тКЧ f') тКе g
left-orthogonal-├Ч {ЁЭУд} {ЁЭУе}{ЁЭУж}{ЁЭУЬ}{ЁЭУЭ}{ЁЭУЫ}{A} {B} f {X} {Y} g h fh gh
  = left-orthogonal-тИШ (f тКЧ id) (id тКЧ g) h
      (left-orthogonal-retraction (f тКЧ id) (id тКЧ f)
        (mk-amap (├Ч-swap ._тЙГ_.fwd) (├Ч-swap ._тЙГ_.fwd) ~refl)
        ( mk-amap (├Ч-swap ._тЙГ_.fwd) (├Ч-swap ._тЙГ_.fwd) ~refl
        , ~refl
        , ~refl
        , ~refl)
        h
        (left-orthogonal-╬г (╬╗ _ тЖТ f) h (╬╗ _ тЖТ fh)))
      (left-orthogonal-╬г (╬╗ _ тЖТ g) h ╬╗ _ тЖТ gh )

idтКе_ : тИА {ЁЭУд ЁЭУе ЁЭУж} {A : Type ЁЭУд} {B : Type ЁЭУе} {C : Type ЁЭУж} (f : B тЖТ C)
       тЖТ id{A = A} тКе f
idтКе f = orthogonalтЖРprecomp-╬а (╬╗ _ тЖТ id-is-equiv)

equivтКе : тИА {ЁЭУд ЁЭУе ЁЭУж ЁЭУЬ} {A : Type ЁЭУд} {B : Type ЁЭУе} {C : Type ЁЭУж} {D : Type ЁЭУЬ}
            {l : A тЖТ B} тЖТ is-equiv l тЖТ (r : C тЖТ D)
          тЖТ l тКе r
equivтКе le r = orthogonalтЖРprecomp-╬а (╬╗ _ тЖТ precomp-╬а-is-equiv le)

left-orthogonal-pushout
  : тИА {ЁЭУд ЁЭУе ЁЭУж ЁЭУЬ ЁЭУЭ ЁЭУЫ} {A : Type ЁЭУд} {B : Type ЁЭУе} {f : A тЖТ B}
      {X : Type ЁЭУж} {Y : Type ЁЭУЬ} {g : X тЖТ Y}
      (F : Arrow-map f g)
    тЖТ is-cocartesian╧Й F
    тЖТ {C : Type ЁЭУЭ} {D : Type ЁЭУЫ} (h : C тЖТ D)
    тЖТ (f тКе h) тЖТ (g тКе h)
left-orthogonal-pushout {f = f} {g = g} F cocart h fh
  = orthogonalтЖРis-cartesian
      (transpose-is-cartesian
        _
        (front-cartesianтЖРcartesian-cube
        _ _ the-cube
        (cocart _)
        (cocart _)
        (transpose-is-cartesian _ (is-cartesianтЖРorthogonal fh)))) where

  the-cube : Cube (transpose-square (power-hom g h)) (transpose-square (power-hom f h))
  the-cube .Cube.left = precomp-square F _
  the-cube .Cube.right = precomp-square F _
  the-cube .Cube.comm .fst = ~refl
  the-cube .Cube.comm .snd .fst = ~refl
  the-cube .Cube.comm .snd .snd k
    = тИЩ-reflr _ тИЩ тИЩ-reflr _
    тИЩ sym (commutes-postwhisker-funext {h = h} (ap k тИШ sym тИШ Arrow-map.comm F))
    тИЩ ap funextтЖТ (funextтЖТ (╬╗ a тЖТ sym (ap-тИШ h k _)))

left-orthogonal-pushout-product
  : тИА {ЁЭУд ЁЭУе ЁЭУж ЁЭУЬ ЁЭУЭ ЁЭУЫ}
      {A : Type ЁЭУд} {B : Type ЁЭУе} (f : A тЖТ B)
      {X : Type ЁЭУЭ} {Y : Type ЁЭУЫ} (h : X тЖТ Y)
  тЖТ f тКе h
  тЖТ {C : Type ЁЭУж} {D : Type ЁЭУЬ} (g : C тЖТ D)
  тЖТ pushout-product f g тКе h
left-orthogonal-pushout-product f h fh g
  = left-orthogonal-right-cancel
      (left-orthogonal-pushout _
        (Pushout-square-is-cocartesian (mk-span _ (f тКЧ1 _) (_ 1тКЧ g)))
        h (left-orthogonal-├Ч f id h fh (idтКе h)))
      (left-orthogonal-├Ч f id h fh (idтКе h))

left-orthogonal-pushout-product'
  : тИА {ЁЭУд ЁЭУе ЁЭУж ЁЭУЬ ЁЭУЭ ЁЭУЫ}
      {A : Type ЁЭУд} {B : Type ЁЭУе} (f : A тЖТ B)
      {X : Type ЁЭУЭ} {Y : Type ЁЭУЫ} (h : X тЖТ Y)
  тЖТ f тКе h
  тЖТ {C : Type ЁЭУж} {D : Type ЁЭУЬ} (g : C тЖТ D)
  тЖТ pushout-product g f тКе h
left-orthogonal-pushout-product' f h fh g
  = left-orthogonal-right-cancel {g = ╬╣тВБ}
      (left-orthogonal-pushout _
        (transpose-square-is-cocartesian _ (Pushout-square-is-cocartesian _))
        h
        (left-orthogonal-├Ч id f h (idтКе h) fh))
      (left-orthogonal-├Ч id f h (idтКе h) fh)
}
%```
}


\subtree[stt-00E7]{
\title{Left orthogonal maps are closed under functorial action of the pushout}
\taxon{Lemma}

\p{Consider spans #{A_i \xleftarrow{f_i} B \xrightarrow{g} C} for #{i \in \{1,2\}}.
Given a coslice map #{F : f_0 \to_B f_1}, we have an action on pushouts
#{A_0 +^B C \to A_1 +^B C}. If #{F \perp k}, then #{F +^B C \perp k}.}

\proof{
\p{We can arrange these maps into squares as follows:}

\quiver{
\begin{tikzcd}
	B && C \\
	\\
	{A_0} && {A_0+^BC} \\
	\\
	{A_1} && {A_1+^B C}
	\arrow[from=1-1, to=1-3]
	\arrow[from=1-1, to=3-1]
	\arrow[from=1-3, to=3-3]
	\arrow[from=3-1, to=3-3]
	\arrow[from=3-1, to=5-1]
	\arrow["\lrcorner"{anchor=center, pos=0.125, rotate=180}, draw=none, from=3-3, to=1-1]
	\arrow[from=3-3, to=5-3]
	\arrow[from=5-1, to=5-3]
\end{tikzcd}
}

\p{The total square and top square is cocartesian, so by pushout pasting, we have
that the bottom square is cocartesian. So the result follows from the fact that
cocartesian squares preserve left orthogonal maps.}

\p{We have a similar result for the action on the right hand side of a pushout.}
}

%```agda
\agda{
module Pushout-functorial-left
         {ЁЭУд ЁЭУд' ЁЭУе ЁЭУж} {A : Type ЁЭУд} {A' : Type ЁЭУд'} {B : Type ЁЭУе} {C : Type ЁЭУж}
         {f : B тЖТ A} {f' : B тЖТ A'} (F : Coslice-map f f') (g : B тЖТ C) where

  left-span-map : Span-map (mk-span _ f g) (mk-span _ f' g)
  left-span-map = (mk-span-map (F .fst) id id (F .snd) ~refl)

  PushoutтВБ-left : Pushout f g тЖТ Pushout f' g
  PushoutтВБ-left = PushoutтВБ (mk-span-map (F .fst) id id (F .snd) ~refl)

  top-square : Arrow-map f ╬╣тВВ
  top-square = Pushout-square (mk-span _ f g)

  bot-square : Arrow-map (F .fst) PushoutтВБ-left
  bot-square .Arrow-map.top = ╬╣тВБ
  bot-square .Arrow-map.bot = ╬╣тВБ
  bot-square .Arrow-map.comm = ~refl

  total-square' : Arrow-map (F .fst тИШ f) ╬╣тВВ
  total-square' = Pushout-square (mk-span _ (F .fst тИШ f) g)

  _ : PushoutтВБ-left тИШ ╬╣тВВ ~ ╬╣тВВ
  _ = ~refl

open Pushout-functorial-left public using (PushoutтВБ-left)
open Pushout-functorial-left hiding (PushoutтВБ-left)

private
  total-square-comp
    : тИА {ЁЭУд ЁЭУд' ЁЭУе ЁЭУж} {A : Type ЁЭУд} {A' : Type ЁЭУд'} {B : Type ЁЭУе} {C : Type ЁЭУж}
        {f : B тЖТ A} (F : A тЖТ A') (g : B тЖТ C)
      тЖТ Arrow-map (F тИШ f) (╬╣тВВ {f = F тИШ f} {g = g})
  total-square-comp F g
    = transpose-square
        (paste-squares
          (transpose-square (bot-square (F , ~refl) g))
          (transpose-square (top-square (F , ~refl) g)))

  total-square-comp-is-total
    : тИА {ЁЭУд ЁЭУд' ЁЭУе ЁЭУж} {A : Type ЁЭУд} {A' : Type ЁЭУд'} {B : Type ЁЭУе} {C : Type ЁЭУж}
        {f : B тЖТ A} (F : A тЖТ A') (g : B тЖТ C)
      тЖТ Arrow-map-path (total-square-comp {f = f} F g)
                       (total-square' (F , ~refl) g)
  total-square-comp-is-total F g .fst = ~refl
  total-square-comp-is-total F g .snd .fst = ~refl
  total-square-comp-is-total F g .snd .snd a
    = тИЩ-reflr _ тИЩ тИЩ-symsym _ refl
    тИЩ ap sym (ap-sym _ (glue a) тИЩ ap sym (pushout-rec-ap╬▓ a))
    тИЩ sym-sym тИЩ тИЩ-reflr _

opaque
  total-square-comp-is-cocartesian
    : тИА {ЁЭУд ЁЭУд' ЁЭУе ЁЭУж} {A : Type ЁЭУд} {A' : Type ЁЭУд'} {B : Type ЁЭУе} {C : Type ЁЭУж}
        {f : B тЖТ A} (F : A тЖТ A') (g : B тЖТ C)
      тЖТ is-cocartesian╧Й (total-square-comp {f = f} F g)
  total-square-comp-is-cocartesian F g
    = tr (╬╗ p тЖТ is-cocartesian p _)
         {a = total-square' (F , ~refl) g}
         {b = total-square-comp F g}
         (sym (Arrow-map-pathтЖТ (total-square-comp-is-total F g)))
         (Pushout-square-is-cocartesian _)

opaque
  left-orthogonal-pushoutтВБ-left
    : тИА {ЁЭУд ЁЭУд' ЁЭУе ЁЭУж} {A : Type ЁЭУд} {A' : Type ЁЭУд'} {B : Type ЁЭУе} {C : Type ЁЭУж}
        {f : B тЖТ A} {f' : B тЖТ A'} (F : Coslice-map f f') (g : B тЖТ C)
      тЖТ тИА {ЁЭУЬ ЁЭУЭ} {U : Type ЁЭУЬ} {V : Type ЁЭУЭ} (k : U тЖТ V)
      тЖТ F .fst тКе k
      тЖТ PushoutтВБ-left F g тКе k
  left-orthogonal-pushoutтВБ-left (F , p) g k Fk
    = funext-rec
        (╬╗ H тЖТ PushoutтВБ-left (F , H) g тКе k)
        (╬╗ where refl тЖТ left-orthogonal-pushout
                          (bot-square (F , ~refl) g)
                          (transpose-square-is-cocartesian
                            (transpose-square (bot-square (F , ~refl) g))
                            (cocartesian-square-cancel
                              {F = transpose-square (bot-square (F , ~refl) g)}
                              {G = transpose-square (top-square (F , ~refl) g)}
                              (Pushout-square'-is-cocartesian (mk-span _ _ g))
                              (untranspose-square-is-cocartesian _
                                (total-square-comp-is-cocartesian F g))))
                          k
                          Fk)
        p

module Pushout-functorial-right
         {ЁЭУд ЁЭУе ЁЭУж ЁЭУж'} {A : Type ЁЭУд}  {B : Type ЁЭУе} {C : Type ЁЭУж} {C' : Type ЁЭУж'}
         (f : B тЖТ A) {g : B тЖТ C} {g' : B тЖТ C'} (G : Coslice-map g g') where

  right-span-map : Span-map (mk-span _ f g) (mk-span _ f g')
  right-span-map = (mk-span-map id id (G .fst) ~refl (G .snd))

  PushoutтВБ-right : Pushout f g тЖТ Pushout f g'
  PushoutтВБ-right = PushoutтВБ right-span-map

  left-square : Arrow-map f ╬╣тВВ
  left-square = Pushout-square (mk-span _ f g)

  right-square : Arrow-map (╬╣тВВ {g = g}) (╬╣тВВ {g = g'})
  right-square .Arrow-map.top = G .fst
  right-square .Arrow-map.bot = PushoutтВБ-right
  right-square .Arrow-map.comm = ~refl

  total-square'' : Arrow-map f (╬╣тВВ {g = g'})
  total-square'' = Pushout-square (mk-span _ f g')


open Pushout-functorial-right public using (PushoutтВБ-right)
open Pushout-functorial-right hiding (PushoutтВБ-right)

private
  total-square'-comp-is-total
      : тИА {ЁЭУд ЁЭУе ЁЭУж ЁЭУж'} {A : Type ЁЭУд}  {B : Type ЁЭУе} {C : Type ЁЭУж} {C' : Type ЁЭУж'}
           (f : B тЖТ A) {g : B тЖТ C} (G : C тЖТ C')
      тЖТ Arrow-map-path
          (paste-squares (right-square f {g = g} (G , ~refl))
                         (left-square f (G , ~refl)))
          (total-square'' f (G , ~refl))
  total-square'-comp-is-total f G .fst = ~refl
  total-square'-comp-is-total f G .snd .fst = ~refl
  total-square'-comp-is-total f G .snd .snd a
    = тИЩ-reflr _ тИЩ тИЩ-reflr _ тИЩ pushout-rec-ap╬▓ a тИЩ тИЩ-reflr _

  opaque
    total-square'-comp-is-cocartesian
      : тИА {ЁЭУд ЁЭУе ЁЭУж ЁЭУж'} {A : Type ЁЭУд}  {B : Type ЁЭУе} {C : Type ЁЭУж} {C' : Type ЁЭУж'}
           (f : B тЖТ A) {g : B тЖТ C} (G : C тЖТ C')
        тЖТ is-cocartesian╧Й (paste-squares (right-square f {g = g} (G , ~refl))
                                         (left-square f (G , ~refl)))
    total-square'-comp-is-cocartesian f G
      = tr (╬╗ p тЖТ is-cocartesian p _)
           {a = total-square'' f (G , ~refl)}
           {b = _}
           (sym (Arrow-map-pathтЖТ (total-square'-comp-is-total f G)))
           (Pushout-square-is-cocartesian _)
opaque
  left-orthogonal-pushoutтВБ-right
    : тИА {ЁЭУд ЁЭУе ЁЭУж ЁЭУж'} {A : Type ЁЭУд}  {B : Type ЁЭУе} {C : Type ЁЭУж} {C' : Type ЁЭУж'}
         (f : B тЖТ A) {g : B тЖТ C} {g' : B тЖТ C'} (G : Coslice-map g g')
         {ЁЭУЬ ЁЭУЭ} {U : Type ЁЭУЬ} {V : Type ЁЭУЭ} (k : U тЖТ V)
      тЖТ G .fst тКе k
      тЖТ PushoutтВБ-right f G тКе k
  left-orthogonal-pushoutтВБ-right f G@(Gg , p)
    = left-orthogonal-pushout
        (transpose-square (right-square f G))
        (transpose-square-is-cocartesian (right-square f G)
          (cocartesian-square-cancel
             {F = right-square f G}
             {G = left-square f G}
             (Pushout-square-is-cocartesian _)
             (funext-rec
               (╬╗ H тЖТ is-cocartesian
                        (paste-squares
                          (right-square f (Gg , H))
                          (left-square f (Gg , H))) _)
               (╬╗ where refl тЖТ total-square'-comp-is-cocartesian f Gg)
               p)))


private
  outer-span-map
      : тИА {ЁЭУд ЁЭУд' ЁЭУе ЁЭУж ЁЭУж'} {A : Type ЁЭУд} {A' : Type ЁЭУд'} {B : Type ЁЭУе}
          {C : Type ЁЭУж} {C' : Type ЁЭУж'}
          {f : B тЖТ A} {f' : B тЖТ A'} (F : Coslice-map f f')
          {g : B тЖТ C} {g' : B тЖТ C'} (G : Coslice-map g g')
        тЖТ Span-map (mk-span _ f g) (mk-span _ f' g')
  outer-span-map F G .Span-map.hтВБ = F .fst
  outer-span-map F G .Span-map.hтВВ = id
  outer-span-map F G .Span-map.hтВГ = G .fst
  outer-span-map F G .Span-map.H = F .snd
  outer-span-map F G .Span-map.K = G .snd

PushoutтВБ-left-right
    : тИА {ЁЭУд ЁЭУд' ЁЭУе ЁЭУж ЁЭУж'} {A : Type ЁЭУд} {A' : Type ЁЭУд'} {B : Type ЁЭУе}
        {C : Type ЁЭУж} {C' : Type ЁЭУж'}
        {f : B тЖТ A} {f' : B тЖТ A'} (F : Coslice-map f f')
        {g : B тЖТ C} {g' : B тЖТ C'} (G : Coslice-map g g')
      тЖТ PushoutтВА (mk-span B f g) тЖТ PushoutтВА (mk-span B f' g')
PushoutтВБ-left-right F G = PushoutтВБ (outer-span-map F G)

PushoutтВБ-leftтИШright
    : тИА {ЁЭУд ЁЭУд' ЁЭУе ЁЭУж ЁЭУж'} {A : Type ЁЭУд} {A' : Type ЁЭУд'} {B : Type ЁЭУе}
        {C : Type ЁЭУж} {C' : Type ЁЭУж'}
        {f : B тЖТ A} {f' : B тЖТ A'} (F : Coslice-map f f')
        {g : B тЖТ C} {g' : B тЖТ C'} (G : Coslice-map g g')
      тЖТ Span-map-homotopy
          (compose-span-map (left-span-map F g') (right-span-map f G))
          (outer-span-map F G)
PushoutтВБ-leftтИШright F G .fst = ~refl
PushoutтВБ-leftтИШright F G .snd .fst = ~refl
PushoutтВБ-leftтИШright F G .snd .snd .fst = ~refl
PushoutтВБ-leftтИШright F G .snd .snd .snd .fst = ~тИЩ-reflr _ ~тБ╗┬╣
PushoutтВБ-leftтИШright F G .snd .snd .snd .snd a = ap (_тИЩ refl) (ap-id (snd G a))

opaque
  left-orthogonal-pushoutтВБ
    : тИА {ЁЭУд ЁЭУд' ЁЭУе ЁЭУж ЁЭУж'} {A : Type ЁЭУд} {A' : Type ЁЭУд'} {B : Type ЁЭУе}
        {C : Type ЁЭУж} {C' : Type ЁЭУж'}
        {f : B тЖТ A} {f' : B тЖТ A'} (F : Coslice-map f f')
        {g : B тЖТ C} {g' : B тЖТ C'} (G : Coslice-map g g')
        {ЁЭУЬ ЁЭУЭ} {U : Type ЁЭУЬ} {V : Type ЁЭУЭ} (k : U тЖТ V)
      тЖТ F .fst тКе k
      тЖТ G .fst тКе k
      тЖТ PushoutтВБ-left-right F G тКе k
  left-orthogonal-pushoutтВБ F G k Fk Gk
    = left-orthogonal-homotopy k
        (Pushout-тИШ (left-span-map F _) (right-span-map _ G)
        ~тИЩ happly (ap PushoutтВБ (Span-map-funextтЖТ (PushoutтВБ-leftтИШright F G))))
        (left-orthogonal-тИШ _ _ k
            (left-orthogonal-pushoutтВБ-left F _ k Fk)
            (left-orthogonal-pushoutтВБ-right _ G k Gk))
}
%```
}

\subtree[stt-00LS]{
\date{2026-04-04}
\author{fredrikbakke}
\title{The right orthogonal class generated by a family of maps}
\taxon{Module}

\p{
Given a family of maps #{f_i : A_i \to B_i}, the maps right orthogonal to every
#{f_i} form a [global class of maps](stt-00KN) with many closure properties.
}

%```agda
\agda{
module RightOrthogonalClassClosure
  {ЁЭУШ ЁЭУд ЁЭУе} {I : Type ЁЭУШ}
  {A : I тЖТ Type ЁЭУд} {B : I тЖТ Type ЁЭУе}
  (f : (i : I) тЖТ A i тЖТ B i)
  where

  R-gClass : gClass-maps (╬╗ ЁЭУж ЁЭУЫ тЖТ ЁЭУШ тКФ ЁЭУд тКФ ЁЭУе тКФ ЁЭУж тКФ ЁЭУЫ)
  R-gClass .gClass-maps.ЁЭУХ .Subtype.family g
    = (i : I) тЖТ are-orthogonal (f i) (g .Arrow.f)
  R-gClass .gClass-maps.ЁЭУХ .Subtype.has-is-subtype _
    = ╬а-is-prop ╬╗ _ тЖТ ╬а-is-prop ╬╗ _ тЖТ is-single-is-prop
  R-gClass .gClass-maps.stable-equiv F Fe orth i
    = right-orthogonalтЖРequiv (f i) F Fe (orth i)

  R : тИА {ЁЭУж ЁЭУЫ} тЖТ Subtype (Arrow ЁЭУж ЁЭУЫ) (ЁЭУШ тКФ ЁЭУд тКФ ЁЭУе тКФ ЁЭУж тКФ ЁЭУЫ)
  R = R-gClass .gClass-maps.ЁЭУХ

  тИИR
    : тИА {ЁЭУж ЁЭУЫ} {X : Type ЁЭУж} {Y : Type ЁЭУЫ}
    тЖТ (X тЖТ Y) тЖТ Type (ЁЭУШ тКФ ЁЭУд тКФ ЁЭУе тКФ ЁЭУж тКФ ЁЭУЫ)
  тИИR g = g тИИс╡Г R

  тИИRтЖРbase-change
    : тИА {ЁЭУж ЁЭУЫ ЁЭУЬ ЁЭУЭ} {X : Type ЁЭУж} {Y : Type ЁЭУЫ}
        {Z : Type ЁЭУЬ} {W : Type ЁЭУЭ}
        {g : X тЖТ Y} {h : Z тЖТ W}
      тЖТ (F : Arrow-map g h) тЖТ is-cartesian F
      тЖТ тИИR h тЖТ тИИR g
  тИИRтЖРbase-change F cart orth i
    = orthogonalтЖРbase-change (f i) F cart (orth i)

  тИИRтЖРequiv
    : тИА {ЁЭУж ЁЭУЫ ЁЭУЬ ЁЭУЭ} {X : Type ЁЭУж} {Y : Type ЁЭУЫ}
        {Z : Type ЁЭУЬ} {W : Type ЁЭУЭ}
        {g : X тЖТ Y} {h : Z тЖТ W}
      тЖТ (F : Arrow-map g h) тЖТ is-Arrow-equiv F
      тЖТ тИИR h тЖТ тИИR g
  тИИRтЖРequiv = R-gClass .gClass-maps.stable-equiv

  тИИRтЖРequiv'
    : тИА {ЁЭУж ЁЭУЫ ЁЭУЬ ЁЭУЭ} {X : Type ЁЭУж} {Y : Type ЁЭУЫ}
        {Z : Type ЁЭУЬ} {W : Type ЁЭУЭ}
        {g : X тЖТ Y} {h : Z тЖТ W}
      тЖТ (F : Arrow-map g h) тЖТ is-Arrow-equiv F
      тЖТ тИИR g тЖТ тИИR h
  тИИRтЖРequiv' F Fe orth i
    = right-orthogonalтЖРequiv' (f i) F Fe (orth i)

  тИИRтЖРis-equiv
    : тИА {ЁЭУж ЁЭУЫ} {X : Type ЁЭУж} {Y : Type ЁЭУЫ}
        {g : X тЖТ Y}
      тЖТ is-equiv g
      тЖТ тИИR g
  тИИRтЖРis-equiv geq i
    = right-orthogonalтЖРis-equiv (f i) geq

  тИИR-iffтЖРequiv
    : тИА {ЁЭУж ЁЭУЫ ЁЭУЬ ЁЭУЭ} {X : Type ЁЭУж} {Y : Type ЁЭУЫ}
        {Z : Type ЁЭУЬ} {W : Type ЁЭУЭ}
        {g : X тЖТ Y} {h : Z тЖТ W}
      тЖТ (F : Arrow-map g h) тЖТ is-Arrow-equiv F
      тЖТ тИИR h тЗФ тИИR g
  тИИR-iffтЖРequiv F Fe
    = (тИИRтЖРequiv F Fe , тИИRтЖРequiv' F Fe)

  тИИRтЖРretraction
    : тИА {ЁЭУж ЁЭУЫ ЁЭУЬ ЁЭУЭ} {X : Type ЁЭУж} {Y : Type ЁЭУЫ}
        {Z : Type ЁЭУЬ} {W : Type ЁЭУЭ}
        {g : X тЖТ Y} {h : Z тЖТ W}
      тЖТ (F : Arrow-map g h)
      тЖТ retraction-arrow-map F
      тЖТ тИИR h тЖТ тИИR g
  тИИRтЖРretraction F ret orth i
    = right-orthogonalтЖРretraction (f i) F ret (orth i)

  тИИR-тИШ
    : тИА {ЁЭУж ЁЭУЫ ЁЭУЬ} {X : Type ЁЭУж} {Y : Type ЁЭУЫ} {Z : Type ЁЭУЬ}
        {g : Y тЖТ Z} {h : X тЖТ Y}
      тЖТ тИИR g тЖТ тИИR h
      тЖТ тИИR (g тИШ h)
  тИИR-тИШ og oh i = right-orthogonal-тИШ (f i) (og i) (oh i)

  тИИR-left-cancel
    : тИА {ЁЭУж ЁЭУЫ ЁЭУЬ} {X : Type ЁЭУж} {Y : Type ЁЭУЫ} {Z : Type ЁЭУЬ}
        {g : Y тЖТ Z} {h : X тЖТ Y}
      тЖТ тИИR g тЖТ тИИR (g тИШ h)
      тЖТ тИИR h
  тИИR-left-cancel og ogh i
    = right-orthogonal-left-cancel (f i) (og i) (ogh i)

  тИИRтЖРhomotopy
    : тИА {ЁЭУж ЁЭУЫ} {X : Type ЁЭУж} {Y : Type ЁЭУЫ}
        {g h : X тЖТ Y}
      тЖТ g ~ h тЖТ тИИR g тЖТ тИИR h
  тИИRтЖРhomotopy H og i
    = right-orthogonal-homotopy (f i) H (og i)

  тИИR-тИШ~
    : тИА {ЁЭУж ЁЭУЫ ЁЭУЬ} {X : Type ЁЭУж} {Y : Type ЁЭУЫ} {Z : Type ЁЭУЬ}
        {g : Y тЖТ Z} {h : X тЖТ Y} {k : X тЖТ Z}
      тЖТ g тИШ h ~ k тЖТ тИИR g тЖТ тИИR h тЖТ тИИR k
  тИИR-тИШ~ H og oh i
    = right-orthogonal-тИШ~ (f i) H (og i) (oh i)

  тИИR-left-cancel~
    : тИА {ЁЭУж ЁЭУЫ ЁЭУЬ} {X : Type ЁЭУж} {Y : Type ЁЭУЫ} {Z : Type ЁЭУЬ}
        {g : Y тЖТ Z} {h : X тЖТ Y} {k : X тЖТ Z}
      тЖТ k ~ g тИШ h
      тЖТ тИИR g тЖТ тИИR k
      тЖТ тИИR h
  тИИR-left-cancel~ H og ok i
    = right-orthogonal-left-cancel~ (f i) H (og i) (ok i)
}
%```
}

\date{2025-12-12}
\title{Homotopies of morphisms}
\author{samueltoth}
\taxon{Module}
\import{stt-macros}

\transclude{stt-00AB}

%```agda
\agda{
open import Foundations.Prelude
open import Algebra.Lattice

module Synthetic.Categories.Homotopies
  {𝓘} (Δ¹ : Type 𝓘) (I : Lattice Δ¹) (I-distr : is-distributive I)
  where

open import ufAxioms

open Lattice I renaming (0l to i0; 1l to i1)
import Algebra.Lattice.Instances.Polynomial as Poly
open Poly  hiding (L[x]; Δ²)
open is-distributive I-distr

private
  Δ² = Poly.Δ² I
  I[x] = Poly.L[x] I

open import Modalities.Subuniverses
open import Modalities.GlobalSubuniverses
open import Modalities.Instances.Localisation
open import Modalities.Instances.Truncation
open import Modalities.Flat.Flat renaming (ε to ε♭)

open import Core.Orthogonal
open import Core.CanonicalPushouts
open import Core.Arrow
open import Core.ArrowEquiv
open import Core.Lifts
open import Core.FlatteningPushouts
open import Core.PiSection
open import Core.CocartesianSquare
open import Core.Postwhisker

open import Ergonomics.Notations.Orthogonality
open import Ergonomics.Extensionality
open Core.Orthogonal.notation

open import Synthetic.Hom Δ¹ i0 i1
open import Synthetic.Categories.Precategories Δ¹ I I-distr
open import Synthetic.Categories.Horns Δ¹ I I-distr
open import Synthetic.Categories.Boundaries Δ¹ I I-distr
}
%```


\subtree[stt-00CH]{
\title{Homotopies of synthetic morphisms}
\taxon{Definition}

%```agda
\agda{
_~▵_ : ∀ {𝓤} {A : Type 𝓤} {a b : A} → (f g : Hom A a b) → Type (𝓘 ⊔ 𝓤)
f ~▵ g = Hom2 f (idH _) g

refl~▵ : ∀ {𝓤} {A : Type 𝓤} {a b : A} (f : Hom A a b) → f ~▵ f
refl~▵ f = (f .Homᵈ.hom ∘ Poly.Δ².t , funext→
           (pushout-rec-unique _ _
             (pushout-rec-unique _ _
               (λ _ → f .Homᵈ.hom0)
               ~refl
               λ _ → ∙-reflr _
                   ∙ ap-∘ (f .Homᵈ.hom ∘ Poly.Δ².t) (pushout-rec _) (glue tt)
                   ∙ ap (ap _) (pushout-rec-apβ _)
                   ∙ ap-∘ (f .Homᵈ.hom) _ Δ²-refl
                   ∙ ap (ap _) (Δ²-ext-ap-t refl refl)
                   ∙ sym (∙-sym (f .Homᵈ.hom0)))
             ~refl
             (~∙-reflr _
             ~∙ δΔ¹-UP→ ( ap-∘ (f .Homᵈ.hom ∘ Poly.Δ².t) (pushout-rec _) (glue _)
                        ∙ ap (ap _) (pushout-rec-apβ _)
                        ∙ ap-∘ (f .Homᵈ.hom) _ Δ²-refl
                        ∙ ap (ap _) (Δ²-ext-ap-t refl refl)
                        ∙ sym (∙-sym (f .Homᵈ.hom0))
                        , ap-∘ (f .Homᵈ.hom ∘ Poly.Δ².t) (pushout-rec _) (glue _)
                        ∙ ap (ap _) (pushout-rec-apβ _)
                        ∙ ap-∘ (f .Homᵈ.hom) _ Δ²-refl
                        ∙ ap (ap _) (Δ²-ext-ap-t refl refl)
                        ∙ sym (∙-sym (f .Homᵈ.hom1))))))


~▵←＝ : ∀ {𝓤} {A : Type 𝓤} {a b : A} {f g : Hom A a b} → f ＝ g → f ~▵ g
~▵←＝ {a = a} {_} {f} refl = refl~▵ f
}
%```
}

\subtree[stt-00CI]{
\title{Homotopies are an identity system for morphisms}
\taxon{Theorem}

\p{We show that when #{A} is a precategery, #{\sim_{\Delta}} is torsorial,
and thus forms an identity system for morphisms in #{A}}

%```agda
\agda{
opaque
  ~▵-is-torsorial
    : ∀ {𝓤} {A : Type 𝓤} {a b : A} → is-segal A
      → ∀ (f : Hom A a b) → is-singleton (Σ[ g ∶ Hom A a b ] (f ~▵ g))
  ~▵-is-torsorial apc f
    = is-single←equiv-to-single
        (mk≃ _ (composite←horn-extension-is-equiv f (idH _)))
        (segal-unique-composite apc f (idH _))

Hom-homotopy-IdS : ∀ {𝓤} {A : Type 𝓤} {a b : A} → is-segal A
                   → Identity-system (Hom A a b) (𝓤 ⊔ 𝓘)
Hom-homotopy-IdS apc .Identity-system.IdS = _~▵_
Hom-homotopy-IdS apc .Identity-system.IdS←Id = ~▵←＝
Hom-homotopy-IdS apc .Identity-system.has-is-ids f
  = fundamental-Id _ (~▵-is-torsorial apc f) _

_ : ∀ {𝓤} {A : Type 𝓤} {a b : A} (apc : is-segal A)
              → is-equiv (λ (f : Hom A a b) → (f , f , refl~▵ f))
_ = λ apc → is-equiv⁻¹ (singleton-fst-is-equiv
                          (SingS-is-single ⦃ Hom-homotopy-IdS apc ⦄))
}
%```
}

\subtree[stt-00DK]{
\title{The walking homotopy}
\taxon{Definition}
\date{2026-01-29}

\p{We define the walking homotopy #{\Delta_\sim} by taking the pushout
#{\Delta^2 +^{\Delta^1} 1}, that contracts the edge #{0 \leq 1}. We show that
a map #{\Delta_\sim \to A} is equivant to the type consisting of a pair of
morphisms and a homotopy between them.}

%```agda
\agda{
Δ~ : Type 𝓘
Δ~ = Pushout {B = Δ²} (_, i0) !

src-Δ~ : Δ¹ → Δ~
src-Δ~ = ι₁ ∘ Δ²-diagonal

tgt-Δ~ : Δ¹ → Δ~
tgt-Δ~ = ι₁ ∘ (i1 ,_)

Δ~-rep1
  : ∀ {𝓤} {A : Type 𝓤}
    → (Δ~ → A) ≃ Σ[ x ∶ A ] Ext (Λ[2,1]-incl ∘ ι₁) (const _ _ x)
Δ~-rep1 {A = A}
  = (Δ~ → A) ≃⟨ Pushout-UP≃ ∙≃ cocone-repr≃ ⟩
    Σ[ g ∶ (Δ² → A)]
     Σ[ x ∶ (𝟙 → A)] (g ∘ (_, i0) ~ x ∘ !)
       ≃⟨ Σ-comm ∙≃ (Σ-ap-≃-fst unit-UP≃) ⟩
    Σ[ x ∶ A ] Σ[ g ∶ (Δ² → A)]
      (g ∘ Λ[2,1]-incl ∘ ι₁ ~ const A Δ¹ x)
       ≃⟨ Σ-ap-≃ (λ x → Σ-ap-≃ (λ g → funext≃ e⁻¹)) ⟩
    Σ[ x ∶ A ] Σ[ g ∶ (Δ² → A)]
      (g ∘ Λ[2,1]-incl ∘ ι₁ ＝ const A Δ¹ x)    ≃⟨⟩
    Σ[ x ∶ A ] (Ext (Λ[2,1]-incl ∘ ι₁) (const A Δ¹ x))    ≃∎

_ : ∀ {𝓤} {A : Type 𝓤} (f : Δ~ → A)
    → f ∘ src-Δ~ ~ Δ~-rep1 ._≃_.fwd f .snd .fst ∘ Δ²-diagonal
_ = λ _ → ~refl

Δ~-rep2
  : ∀ {𝓤} {A : Type 𝓤}
    → (Δ~ → A)
    ≃ Σ[ x ∶ A ]
       Σ[ f ∶ Ext {B = Λ[2,1]} ι₁ (const _ _ x) ]
         Ext Λ[2,1]-incl (f .fst)
Δ~-rep2 = Δ~-rep1 ∙≃ Σ-ap-≃ (λ a → Ext-compose Λ[2,1]-incl ι₁ (const _ _ a))

_ : ∀ {𝓤} {A : Type 𝓤} (f : Δ~ → A)
    → f ∘ src-Δ~ ~ Δ~-rep2 ._≃_.fwd f .snd .snd .fst ∘ Δ²-diagonal
_ = λ _ → ~refl

Λ[2,1]-ext-l
  : ∀ {𝓤}{A : Type 𝓤} (f : Δ¹ → A)
  → Ext {B = Λ[2,1]} ι₁ {λ _ → A} f ≃ Σ[ g ∶ (Δ¹ → A)] (g i0 ＝ f i1)
Λ[2,1]-ext-l f = Σ-ap-≃-fst {B = λ x → x .fst ＝ f} (Pushout-UP≃ ∙≃ cocone-repr≃)
               ∙≃ (remove-singleton-structure Sing'-is-singleton (_ , refl)
               ∙≃ Σ-ap-≃ (λ a → unit-UP≃ ∙≃ sym≃))

Λ[2,1]-ext-l→
  : ∀ {𝓤}{A : Type 𝓤} (f : Δ¹ → A)
  → Ext {B = Λ[2,1]} ι₁ {λ _ → A} f → Σ[ g ∶ (Δ¹ → A)] (g i0 ＝ f i1)
Λ[2,1]-ext-l→ f (e , refl) = (e ∘ ι₂ , sym (ap e (glue tt)))

fst-Λ[2,1]-ext-l→
  : ∀ {𝓤}{A : Type 𝓤} (f : Δ¹ → A)
  → fst ∘ (Λ[2,1]-ext-l→ f) ~ (_∘ ι₂) ∘ fst
fst-Λ[2,1]-ext-l→ f (a , refl) = refl

Λ[2,1]-ext-l←
  : ∀ {𝓤}{A : Type 𝓤} (f : Δ¹ → A)
  → Σ[ g ∶ (Δ¹ → A)] (g i0 ＝ f i1) → Ext {B = Λ[2,1]} ι₁ {λ _ → A} f
Λ[2,1]-ext-l← f (g , k) = (cogap (mk-cocone f g (λ _ → sym k))) , refl

Λ[2,1]-ext-l-is-equiv
  : ∀ {𝓤}{A : Type 𝓤} (f : Δ¹ → A)
  → is-equiv (Λ[2,1]-ext-l→ f)
Λ[2,1]-ext-l-is-equiv f = is-equiv←qiso
  ( Λ[2,1]-ext-l← f
  , uncurry
      (λ where
           f refl → fibre-path→
                     (funext→
                      (sym ∘ pushout-rec-unique _ _ ~refl ~refl
                        (λ _ → ∙-reflr _ ∙ sym sym-sym))
                     , ∙-reflr _ ∙ sym (commutes-prewhisker-funext _)
                       ∙ funext-refl))
  , uncurry (λ x y → Σ-path→ (refl , (ap sym (pushout-rec-apβ tt) ∙ sym-sym))))

Δ~-rep3
  : ∀ {𝓤} {A : Type 𝓤}
    → (Δ~ → A)
    ≃ Σ[ f ∶ (Δ¹ → A) ]
         Ext Λ[2,1]-incl (make-horn (λhom f) (idH _))
Δ~-rep3 {A = A}
  = (Δ~ → A) ≃⟨ Δ~-rep2 ⟩
    Σ[ x ∶ A ]
     (Σ (Ext ι₁ (const A Δ¹ x)) (Ext Λ[2,1]-incl ∘ fst))
             ≃⟨ Σ-assoc e⁻¹ ⟩
    Σ[ xe ∶ (Σ[ x ∶ A ] Ext ι₁ (const _ _ x)) ]
      (Ext Λ[2,1]-incl ∘ fst) (xe .snd)
             ≃⟨ mk≃ lem lem-is-eqv ⟩
    Σ[ f ∶ (Δ¹ → A) ]
     (Ext Λ[2,1]-incl (make-horn (λhom f) (idH (f _))))
             ≃∎ where

    H : ∀ (a : Σ[ x ∶ A ] Ext ι₁ (const _ _ x))
        → (fst (a .snd)) ~
          make-horn (λhom (a .snd .fst ∘ ι₂)) (idH _)
    H (x , a , p) = pushout-rec-unique _ _
      (λ i → happly p i ∙ sym (happly p i1) ∙ ap a (glue tt)) ~refl
      λ _ → ap (_∙ refl) (sym (sym∙ (happly p i1) (ap a (glue tt))))

    lem : Σ[ xe ∶ (Σ[ x ∶ A ] Ext ι₁ (const _ _ x)) ]
             (Ext Λ[2,1]-incl ∘ fst) (xe .snd)
          → Σ[ f ∶ (Δ¹ → A)] Ext Λ[2,1]-incl (make-horn (λhom f) (idH _))
    lem (a , b , p) = (a .snd .fst ∘ ι₂ , b , p ∙ funext→ (H a))

    lem' : Σ[ xe ∶ (Σ[ x ∶ A ] Ext ι₁ (const _ _ x)) ]
             (Ext Λ[2,1]-incl ∘ fst) (xe .snd)
          → Σ[ f ∶ (Δ¹ → A)] Ext Λ[2,1]-incl (make-horn (λhom f) (idH _))
    lem' = total-map-fst
              {A = Δ¹ → A}
              {A' = Σ[ x ∶ A ] Ext {B = Λ[2,1]} ι₁ {X = λ _ → A} (const A Δ¹ x)}
              ((_∘ ι₂) ∘ fst ∘ snd)
              {λ g → Ext Λ[2,1]-incl (make-horn (λhom g) (idH _))}
            ∘ total-map (λ a → total-map (λ b → _∙ funext→ (H a)))


    K : fst ∘ Σ-comm ._≃_.fwd ∘ total-map (Λ[2,1]-ext-l→ ∘ const _ _)
      ~ (_∘ ι₂) ∘ fst ∘ snd
    K (a , b , c) = fst-Λ[2,1]-ext-l→ (λ _ → a) (b , c)

    lem-is-eqv : is-equiv lem
    lem-is-eqv
      = is-equiv-∘
          (total-is-equiv←fst-is-equiv
            (homotopy-is-equiv K
              (is-equiv-∘
                 (singleton-fst-is-equiv (λ _ → Sing-is-singleton))
                 (is-equiv-∘
                   (Σ-comm ._≃_.has-is-eqv)
                   (is-total-equiv←is-fibrewise-equiv
                     (λ a → Λ[2,1]-ext-l-is-equiv (const A Δ¹ a)))))))
          (is-total-equiv←is-fibrewise-equiv
            λ a → is-total-equiv←is-fibrewise-equiv
              λ b → ∙-is-equiv' (funext→ (H a)))

_ : ∀ {𝓤} {A : Type 𝓤} (f : Δ~ → A)
    → f ∘ src-Δ~ ~ Δ~-rep3 ._≃_.fwd f .snd .fst ∘ Δ²-diagonal
_ = λ f a → refl

Δ~-rep4
  : ∀ {𝓤} {A : Type 𝓤}
    → (Δ~ → A)
    ≃ Σ[ f ∶ (Δ¹ → A) ]
         Σ[ g ∶ Hom A (f i0) (f i1) ]
            Hom2 (λhom f) (idH _) g
Δ~-rep4 = Δ~-rep3
        ∙≃ Σ-ap-≃
            (λ f → mk≃ _ (composite←horn-extension-is-equiv (λhom f) (idH _)))

rep4-Δ~tgt
  : ∀ {𝓤} {A : Type 𝓤} → fst ∘ Δ~-rep4 ._≃_.fwd ~ precomp A (tgt-Δ~)
rep4-Δ~tgt = ~refl

rep4-Δ~src
  : ∀ {𝓤} {A : Type 𝓤}
    → Homᵈ.hom ∘ fst ∘ snd ∘ Δ~-rep4 ._≃_.fwd ~ precomp A (src-Δ~)
rep4-Δ~src f = composite←horn-extension-diagonal _ _ (Δ~-rep3 ._≃_.fwd f .snd)
}
%```
}

\subtree[stt-00DL]{
\taxon{Corollary}
\date{2026-01-29}

\p{As a corollary of \ref{stt-00CH}, we have the the map map that picks out the
source (or the target) of the walking homotopy is a Segal equivalence.}


%```agda
\agda{
opaque
  tgt-is-segal-equiv
    : is-segal-equiv tgt-Δ~
  tgt-is-segal-equiv {Q = Q} qpc
    = is-equiv-∘
        {f = fst}
        {g = Δ~-rep4 ._≃_.fwd}
        (singleton-fst-is-equiv
          (λ f → SingS-is-single ⦃ Hom-homotopy-IdS qpc ⦄ _))
        (Δ~-rep4 ._≃_.has-is-eqv)

  src-is-segal-equiv
    : is-segal-equiv src-Δ~
  src-is-segal-equiv {Q = Q} qpc
    = is-equiv~∘
        {f = (Homᵈ.hom ∘ fst ∘ snd)}
        {g = Δ~-rep4 ._≃_.fwd}
        (rep4-Δ~src ~⁻¹)
        (is-equiv←qiso lemma)
        (Δ~-rep4 ._≃_.has-is-eqv) where
    lemma : quasi-iso {A = Σ[ f ∶ (Δ¹ → Q) ]
                             Σ[ g ∶ Hom Q (f i0) (f i1) ]
                               Hom2 (λhom f) (idH _) g}
                     {B = Δ¹ → Q} (Homᵈ.hom ∘ fst ∘ snd)
    lemma .fst a = (a , λhom a , refl~▵ (λhom a))
    lemma .snd .fst (a , b , p)
      = Σ-path→ ( sym (ap Homᵈ.hom (Id←IdS ⦃ Hom-homotopy-IdS qpc ⦄ p))
                , (composite-is-prop qpc _ _ _ _))
    lemma .snd .snd a = refl
}
%```
}

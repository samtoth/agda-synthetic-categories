\date{2025-10-24}
\title{The pointwise lattice structure}
\author{samueltoth}
\taxon{Module}
\import{stt-macros}

%```agda
\agda{
module Algebra.Lattice.Instances.Pointwise where

open import Foundations.Prelude
open import ufAxioms

open import Algebra.Lattice

open import Modalities.Instances.Truncation
open import Ergonomics.Extensionality
}
%```


\subtree[stt-00AE]{
\title{Pointwise lattice structure}
\taxon{Example}

\p{Given any type #{I}, and an #{I} indexed family of Lattices #{L}, we can take the
product of #{L_i} - denoted #{\Pi_{i : I} L_i}}

\p{We can also show that a product of distributive lattices is itself
distributive.}

%```agda
\agda{
module _ {ūĚď§ ūĚďė}  (I : Type ūĚďė) {A : I ‚Üí Type ūĚď§} (L : (i : I) ‚Üí Lattice (A i)) where
  module L i = Lattice (L i)

  Pointwise-‚ąß : (ő† I A) ‚Üí (ő† I A) ‚Üí (ő† I A)
  Pointwise-‚ąß X Y i = L._‚ąß_ i (X i) (Y i)

  Pointwise-‚ą® : (ő† I A) ‚Üí (ő† I A) ‚Üí (ő† I A)
  Pointwise-‚ą® X Y i = L._‚ą®_ i (X i) (Y i)

  Pointwise-Lattice : Lattice (ő† I A)
  Pointwise-Lattice .Lattice.0l = L.0l
  Pointwise-Lattice .Lattice.1l = L.1l
  Pointwise-Lattice .Lattice._‚ąß_ = Pointwise-‚ąß
  Pointwise-Lattice .Lattice._‚ą®_ = Pointwise-‚ą®
  Pointwise-Lattice .Lattice.str-is-lattice = l where
    l : is-lattice L.0l L.1l Pointwise-‚ąß Pointwise-‚ą®
    l .is-lattice.car-is-set = Trunc.ő†-is-truncated L.car-is-set
    l .is-lattice.‚ąß-assoc  = funext‚Üí (őĽ i ‚Üí L.‚ąß-assoc i)
    l .is-lattice.‚ą®-assoc  = funext‚Üí (őĽ i ‚Üí L.‚ą®-assoc i)
    l .is-lattice.‚ąß-comm   = funext‚Üí (őĽ i ‚Üí L.‚ąß-comm i)
    l .is-lattice.‚ą®-comm   = funext‚Üí (őĽ i ‚Üí L.‚ą®-comm i)
    l .is-lattice.‚ą®-‚ąß-abs  = funext‚Üí (őĽ i ‚Üí L.‚ą®-‚ąß-abs i)
    l .is-lattice.‚ąß-‚ą®-abs  = funext‚Üí (őĽ i ‚Üí L.‚ąß-‚ą®-abs i)
    l .is-lattice.0-bottom = funext‚Üí (őĽ i ‚Üí L.0-bottom i)
    l .is-lattice.1-top    = funext‚Üí (őĽ i ‚Üí L.1-top i)


  Pointwise-Lattice-is-distributive
    : ((i : I) ‚Üí is-distributive (L i)) ‚Üí is-distributive (Pointwise-Lattice)
  Pointwise-Lattice-is-distributive distr .is-distributive.has-is-distrib
    = funext‚Üí őĽ i ‚Üí distr i .has-is-distrib
    where open is-distributive

module _ {ūĚď§ ūĚď• ūĚďė}
         (I : Type ūĚďė) {X : I ‚Üí Type ūĚď§}
         {B : Type ūĚď•} {LB : Lattice B}
         (A : (i : I) ‚Üí Algebra LB (X i)) where
    open Lattice LB
    open Algebra
    open is-lattice-hom

    pointwise-algebra-map : B ‚Üí (i : I) ‚Üí X i
    pointwise-algebra-map b i =  őĻ (A i) b

    pointwise-algebra-is-lattice-algebra :
      is-lattice-algebra LB
                         (Pointwise-Lattice I (str-Lattice ‚ąė A))
                         pointwise-algebra-map

    pointwise-algebra-is-lattice-algebra .pres-‚ą®
      = funext‚Üí őĽ x ‚Üí pres-‚ą® (őĻ-alg (A x))
    pointwise-algebra-is-lattice-algebra .pres-‚ąß
      = funext‚Üí őĽ x ‚Üí pres-‚ąß (őĻ-alg (A x))
    pointwise-algebra-is-lattice-algebra .pres-0
      = funext‚Üí őĽ x ‚Üí pres-0 (őĻ-alg (A x))
    pointwise-algebra-is-lattice-algebra .pres-1
      = funext‚Üí őĽ x ‚Üí pres-1 (őĻ-alg (A x))

    Pointwise-Algebra : Algebra LB ((i : I) ‚Üí X i)
    Pointwise-Algebra .str-Lattice = Pointwise-Lattice I (str-Lattice ‚ąė A)
    Pointwise-Algebra .őĻ           = pointwise-algebra-map
    Pointwise-Algebra .őĻ-alg       = pointwise-algebra-is-lattice-algebra

    Pointwise-Algebra-is-distributive
      : ((i : I) ‚Üí is-distributive-algebra (A i))
      ‚Üí is-distributive-algebra Pointwise-Algebra
    Pointwise-Algebra-is-distributive =
      Pointwise-Lattice-is-distributive I (őĽ i ‚Üí str-Lattice (A i))


module _ {ūĚď§ ūĚď• ūĚďė}
         (I : Type ūĚďė) {X : I ‚Üí Type ūĚď§}
         {B : Type ūĚď•} {LB : Lattice B}
         (A : (i : I) ‚Üí Dist-Algebra LB (X i)) where
  open Lattice LB
  open Algebra

  Pointwise-Dist-Algebra : Dist-Algebra LB ((i : I) ‚Üí X i)
  Pointwise-Dist-Algebra .fst =
    Pointwise-Algebra I őĽ i ‚Üí A i .fst
  Pointwise-Dist-Algebra .snd =
    Pointwise-Algebra-is-distributive I (őĽ i ‚Üí A i .fst) (őĽ i ‚Üí A i .snd)
}
%```
}

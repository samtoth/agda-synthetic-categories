\subtree[stt-00DA]{
\taxon{Definition}
\title{Left Segal types}
\contributor{fredrikbakke}

\p{We call a type \em{left Segal} if it is local with respect to the
map #{\Lambda^2_1 \to 1 \bjoin \Delta^1}.
}

\remark{See [[stt-00O3]] for the dual concept}

\agda{
őõ[2,1]-incl‚óÖ : őõ[2,1] ‚Üí őĒ¬Ļ ‚óÖ
őõ[2,1]-incl‚óÖ = cogap (mk-cocone (‚ÜĎ-hom (tt , i0) .HomŠĶą.hom) ‚ÜĎ-őĻ‚āā
                             őĽ a ‚Üí glue (‚ąāőĒ¬Ļ-1 , tt , i0))

őõ[2,1]-incl‚óÖ‚ąô : Coslice-map (point (őĻ‚āĀ i0)) őĽ _ ‚Üí ‚ÜĎ-őĻ‚āĀ tt
őõ[2,1]-incl‚óÖ‚ąô = (őõ[2,1]-incl‚óÖ , őĽ _ ‚Üí glue (‚ąāőĒ¬Ļ-0 , tt , i0))

is-left-segal : ‚ąÄ {ūĚď§} (A : Type ūĚď§) ‚Üí Type (ūĚďė ‚äĒ ūĚď§)
is-left-segal A = is-local (point őõ[2,1]-incl‚óÖ) A
}
}

\subtree[stt-00DB]{
\title{Left Segal types are Segal}
\taxon{Lemma}

\p{Any [left Segal](stt-00DA) type is [Segal](stt-00AI).}

\proof{
\p{
We give a splitting of #{\Delta^2 \hookrightarrow 1 \bjoin \Delta^1},
which furthermore preserves the inner horn inclusion.
(Note the split embedding #{\Delta^2 \hookrightarrow \square^2} in
\ref{stt-00C7} factors through this map.)}
}


\date{2025-04-14}
\title{Fibrewise equivalences}
\taxon{Module}

\import{stt-macros}

\agda{
module Foundations.FibrewiseEquivalences where

open import Foundations.Universes
open import Foundations.Sigma
open import Foundations.SigmaIdentity
open import Foundations.Identity
open import Foundations.DependentIdentity
open import Foundations.Functions
open import Foundations.QuasiEquivalences
open import Foundations.Equivalences
}

\subtree[stt-0029]{
\taxon{Definition}
\title{Fibrewise equivalence}

\agda{
is-fibrewise-equiv
  : ∀ {𝓤 𝓥 𝓦} {A : Type 𝓤} {B : A → Type 𝓥} {B' : A → Type 𝓦}
    → (∀ a → B a → B' a) → Type (𝓤 ⊔ 𝓥 ⊔ 𝓦)
is-fibrewise-equiv f = ∀ a → is-equiv (f a)
}
}


\subtree[stt-0030]{
\taxon{Theorem}
\title{Equivalences on fibres give equivalences on the total}

\agda{
total-map
  : ∀ {𝓤 𝓥 𝓦} {A : Type 𝓤} {B : A → Type 𝓥} {B' : A → Type 𝓦}
    → (f : ∀ a → B a → B' a) → Σ A B → Σ A B'
total-map f (a , b) = (a , f a b)

is-total-equiv←is-fibrewise-equiv
  : ∀ {𝓤 𝓥 𝓦} {A : Type 𝓤}
      {B : A → Type 𝓥} {B' : A → Type 𝓦} → {f : ∀ a → B a → B' a}
    → is-fibrewise-equiv f → is-equiv (total-map f)
is-total-equiv←is-fibrewise-equiv {f = f} feq = is-equiv←qinv qinv where
  module A x = is-equiv (feq x)

  qinv : quasi-inv (total-map f)
  qinv .fst (a , b) = a , A.bwd a b
  qinv .snd .fst (a , b) = Σ-path→ (refl , A.retraction-fwd a .snd b)
  qinv .snd .snd (a , b) = Σ-path→ (refl , A.section-fwd a .snd b)

Σ-≃
  : ∀ {𝓤 𝓥 𝓦} {A : Type 𝓤} {B : A → Type 𝓥} {B' : A → Type 𝓦}
    → ((a : A) → B a ≃ B' a) → Σ A B ≃ Σ A B'
Σ-≃ eq = mk≃ (total-map (_≃_.fwd ∘ eq))
                (is-total-equiv←is-fibrewise-equiv (_≃_.fwd-is-equiv ∘ eq))
}
}

\subtree[stt-008R]{
\title{Characterising fibrewise equivalences}
\taxon{Corollary}

\agda{
fibrewise-equiv≃
  : ∀ {𝓤 𝓥 𝓦} {A : Type 𝓤} {B : A → Type 𝓥}
      {B' : A → Type 𝓦}
    → (Σ[ f ∶ (∀ a → B a → B' a)] is-fibrewise-equiv f)
    ≃ (∀ a → B a ≃ B' a)
fibrewise-equiv≃ {B = B} {B'} = mk≃ map (is-equiv←qinv qinv) where
  map : Σ (∀ a → B a → B' a) is-fibrewise-equiv → ∀ a → B a ≃ B' a
  map (f , feq) a = mk≃ (f a) (feq a)

  qinv : quasi-inv map
  qinv .fst fe = ( (λ a x → fe a ._≃_.fwd x)
                 , (λ a → fe a ._≃_.fwd-is-equiv))
  qinv .snd .fst _ = refl
  qinv .snd .snd _ = refl
}
}

\subtree[stt-00B6]{
\title{Groupoids}
\taxon{Definition}

\p{A type is a \em{groupoid}, or \em{simplicially discrete}, if it is local with
respect to #{\Delta^1}. This forms a sigma closed reflective subuniverse.}

%```agda
\agda{
is-groupoid : ‚ąÄ {ūĚď§} (A : Type ūĚď§) ‚Üí Type (ūĚďė ‚äĒ ūĚď§)
is-groupoid = is-null (point őĒ¬Ļ)

Grpd-SubU : ‚ąÄ {ūĚď§} ‚Üí SubU ūĚď§ (ūĚď§ ‚äĒ ūĚďė)
Grpd-SubU = Null-SubU (point őĒ¬Ļ) _

Grpd-SubUŠĶć : SubUŠĶć (_‚äĒ ūĚďė)
Grpd-SubUŠĶć = Null-SubUŠĶć (point őĒ¬Ļ)

Grpd-is-globally-reflective
  : is-globally-reflective Grpd-SubUŠĶć
Grpd-is-globally-reflective = Null-globally-reflective

open SubUŠĶć Grpd-SubUŠĶć public using () renaming (‚ąąS‚Üźequiv to is-groupoid‚Üźequiv)

open ReflectiveClosureŠĶć Grpd-is-globally-reflective public using () renaming
  ( ő†‚ąąS to ő†-is-groupoid
  ; ULift‚ąąS to ULift-is-groupoid
  ; ūĚüô‚ąąS to ūĚüô-is-groupoid
  ; ‚ąąS‚Üźis-singleton to is-groupoid‚Üźis-singleton
  ; ‚ąąS‚Üźretract to is-groupoid‚Üźretract
  ; Pullback‚ąąS to Pullback-is-groupoid
  ; fibre‚ąąS to fibre-is-groupoid
  ; √ó‚ąąS to √ó-is-groupoid
  ; ÔľĚ‚ąąS to ÔľĚ-is-groupoid
  ; ~‚ąąS to ~-is-groupoid
  ; retract‚ąąS to retract-is-groupoid
  ; biinv‚ąąS to biinv-is-groupoid
  ; ‚ČÉ‚ąąS to ‚ČÉ-is-groupoid
  ; Equaliser‚ąąS to Equaliser-is-groupoid
  ; Seq-lim‚ąąS to Seq-lim-is-groupoid
  ; preidempotent-map‚ąąS to preidempotent-map-is-groupoid
  ; qidempotent-map‚ąąS to qidempotent-map-is-groupoid
  ; Retracts‚ąąS to Retracts-is-groupoid)

ő£-is-groupoid = Null-globally-ő£-closed

module Grpd where

  open SubUŠĶć Grpd-SubUŠĶć public using ()
  open RSubUŠĶćInduction Grpd-is-globally-reflective Null-globally-ő£-closed public
  open ReflectiveClosureŠĶć Grpd-is-globally-reflective public
  open is-globally-reflective Grpd-is-globally-reflective public
}
%```

%```agda
\agda{
Hom‚ÜźId
  : ‚ąÄ {ūĚď§} {A : Type ūĚď§} ‚Üí ‚ąÄ {a b} ‚Üí a ÔľĚ b ‚Üí Hom A a b
Hom‚ÜźId refl = idH _

Hom-gpd
  : ‚ąÄ {ūĚď§} {A : Type ūĚď§} ‚Üí is-groupoid A
  ‚Üí ‚ąÄ {a b} ‚Üí is-equiv (Hom‚ÜźId {_}{A}{a}{b})
Hom-gpd gpd {a} {b}
  = is-equiv~‚ąė {f = _‚ČÉ_.bwd HomŠĶą-repr‚ČÉ} {g = g ‚ąė f}
      (őĽ {refl ‚Üí refl})
      (is-equiv‚ĀĽ¬Ļ (_‚ČÉ_.has-is-eqv HomŠĶą-repr‚ČÉ))
      (is-equiv-‚ąė {f = g} {g = f}
        (total-is-equiv‚Üźfst-is-equiv (gpd tt))
        (is-equiv‚ĀĽ¬Ļ (ő£-ÔľĚsingl ._‚ČÉ_.has-is-eqv))) where
  f : a ÔľĚ b ‚Üí ő£[ c ‚ą∂ _ ] ((c ÔľĚ a) √ó (c ÔľĚ b))
  f = _‚ČÉ_.bwd ő£-ÔľĚsingl
  g : ő£[ c ‚ą∂ _ ] ((c ÔľĚ a) √ó (c ÔľĚ b))
    ‚Üí ő£[ g ‚ą∂ (őĒ¬Ļ ‚Üí _) ] ő£ (g i0 ÔľĚ a) (őĽ hom2 ‚Üí g i1 ÔľĚ b)
  g (a , p , q) = (const _ _ a , p , q)
}
%```
}


\subtree[stt-00B7]{
\title{Groupoids are left(right)-local types}
\taxon{Theorem}

\p{A type is a groupoid iff it is local with respect to the map #{1 \to \Delta^1}
which picks out the left endpoint iff it is local to the map that picks out the
right endpoint.}

%```agda
\agda{
is-left-local : ‚ąÄ {ūĚď§} (A : Type ūĚď§) ‚Üí Type (ūĚďė ‚äĒ ūĚď§)
is-left-local = is-local (őĽ (_ _ : ūĚüô) ‚Üí i0)

is-groupoid‚Üźis-left : ‚ąÄ {ūĚď§} {A : Type ūĚď§} ‚Üí is-left-local A ‚Üí is-groupoid A
is-groupoid‚Üźis-left {_}{A} il x
  = is-equiv~‚ąė lem (is-equiv‚ĀĽ¬Ļ (il x))
                   point-is-equiv where
  open is-equiv (il x)

  lem : const A őĒ¬Ļ ~ bwd ‚ąė point
  lem = il x ‚óāeqv ((őĶ ‚Ėł point) ~‚ĀĽ¬Ļ)


is-left‚Üźis-groupoid : ‚ąÄ {ūĚď§} {A : Type ūĚď§} ‚Üí is-groupoid A ‚Üí is-left-local A
is-left‚Üźis-groupoid {_} {A} gp x
  =  is-equiv~‚ąė H point-is-equiv (is-equiv‚ĀĽ¬Ļ (gp x)) where
  open is-equiv (gp x)

  H : precomp A (point i0) ~ point ‚ąė bwd
  H = ((point ‚óā ő∑) ~‚ĀĽ¬Ļ) ‚Ėłeqv (gp x)
}
%```
}

-- return : вИА {рЭУ§} {A : Type рЭУ§} {n} вЖТ A вЖТ Trunc n A
-- return = Trunc.ќЈ


module _ {рЭУ§} {A : Type рЭУ§} в¶Г _ : вИА {k} вЖТ Is-truncated (sucрЭХЛ (sucрЭХЛ k)) A в¶Д where
  _ : is-truncated 1 A
  _ = trunc!

  _ : вИА {x y : A} вЖТ is-truncated -1 (x пЉЭ y)
  _ = trunc!

  _ : is-truncated 0 (A вЖТ A)
  _ = trunc!

  _ : вИА {f g : S 5 вЖТ A} вЖТ is-truncated -1 (f ~ g)
  _ = trunc!

  _ : is-truncated -1 (A вЖТ Trunc -1 (S 5))
  _ = trunc!
}

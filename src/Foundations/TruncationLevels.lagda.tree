\subtree[fre-A070]{
\date{2026-04-24}
\author{fredrikbakke}
\title{Truncation levels}
\taxon{Definition}

% ```agda
\agda{
data рќ•‹ : Type where
  -2рќ•‹ : рќ•‹
  sucрќ•‹ : рќ•‹ в†’ рќ•‹

-1рќ•‹ : рќ•‹
-1рќ•‹ = sucрќ•‹ -2рќ•‹

0рќ•‹ : рќ•‹
0рќ•‹ = sucрќ•‹ -1рќ•‹

trunc-index : рќ•‹ в†’ в„•
trunc-index -2рќ•‹ = zero
trunc-index (sucрќ•‹ n) = suc (trunc-index n)

trunc-level : в„• в†’ рќ•‹
trunc-level zero = -2рќ•‹
trunc-level (suc n) = sucрќ•‹ (trunc-level n)

sucit-рќ•‹ : рќ•‹ в†’ в„• в†’ рќ•‹
sucit-рќ•‹ n zero = n
sucit-рќ•‹ n (suc k) = sucрќ•‹ (sucit-рќ•‹ n k)

itsuc-рќ•‹ : в„• в†’ рќ•‹ в†’ рќ•‹
itsuc-рќ•‹ n t = sucit-рќ•‹ t n

рќ•‹в†ђв„• : в„• в†’ рќ•‹
рќ•‹в†ђв„• n = sucit-рќ•‹ 0рќ•‹ n

neg-рќ•‹ : в„• в†’ рќ•‹
neg-рќ•‹ zero = рќ•‹в†ђв„• zero
neg-рќ•‹ (suc zero) = sucрќ•‹ -2рќ•‹
neg-рќ•‹ (suc (suc n)) = -2рќ•‹
}
% ```
}

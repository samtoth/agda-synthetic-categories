\subtree[stt-005Q]{
\title{Pathsplit maps}
\taxon{Definition}

\p{A map #{f : A \to B} is \em{pathsplit} when there
is a section of #{f} and for each #{x, y : A}, there
is a section of #{\rm{ap}_f^{x,y}}.}

%```agda
\agda{
is-pathsplit : вҲҖ {рқ“Ө рқ“Ҙ} {A : Type рқ“Ө} {B : Type рқ“Ҙ}
                 (f : A вҶ’ B) вҶ’ Type (рқ“Ө вҠ” рқ“Ҙ)
is-pathsplit f = section f Г— (вҲҖ x y вҶ’ section (ap f {x} {y}))
}
%```
}

\subtree[stt-005R]{
\title{Pathsplit maps are equivalences}
\taxon{Theorem}

\p{To show a [pathsplit](stt-005Q) map #{f : A \to B},
is an equivalence, it suffices to give a retraction of #{f}.
We can show that #{fgf = f} where #{g} is the given section,
and since #{\rm{ap}_f} has a section we derive that #{fg = id}.}

%```agda
\agda{
is-equivвҶҗis-pathsplit : вҲҖ {рқ“Ө рқ“Ҙ} {A : Type рқ“Ө} {B : Type рқ“Ҙ}
                           {f : A вҶ’ B}
                         вҶ’ is-pathsplit f
                         вҶ’ is-equiv f
is-equivвҶҗis-pathsplit {f = f} ((g , sec) , apsec)
  = is-equivвҶҗqiso О» where
      .fst вҶ’ g
      .snd .fst a вҶ’ apsec _ a .fst (sec (f a))
      .snd .snd вҶ’ sec
}
%```
}

\subtree[stt-005S]{
\title{Being pathsplit is equivalent to being an equivalence}
\taxon{Theorem}

\p{We want to show that the map defined in \ref{stt-005R} is an
equivalence.}

\proof{
\p{To show the map is an equivalence, [it suffices](stt-005T)
to assume the codomain is inhabited. Because [being an equivalence
is a property](stt-001Y), we just need to show that the domain is a
singleton. Then if the map is already an equivalence,
[it's type of sections is a singleton](stt-000Q), and it is
an embedding so the type of sections of #{\rm{ap}} is also a singleton.}
}


%```agda
\agda{
module PSWithFunExt (FE : FunExt-global) where
  is-equivвүғis-pathsplit : вҲҖ {рқ“Ө рқ“Ҙ} {A : Type рқ“Ө} {B : Type рқ“Ҙ}
                             {f : A вҶ’ B}
                           вҶ’ is-pathsplit f
                           вүғ is-equiv f
  is-equivвүғis-pathsplit {f = f}
    = mkвүғ is-equivвҶҗis-pathsplit (is-equivвҶҗis-equiv-if-cod (О»
        e вҶ’ is-equivвҶҗsingle-to-prop
             (ОЈ-is-single (section-is-singleвҶҗqinv FE (qisoвҶҗis-equiv e))
                          О» _ вҶ’ О -is-single FE
                           О» a вҶ’ О -is-single FE
                            О» b вҶ’ section-is-singleвҶҗqinv FE
                                   (qisoвҶҗis-equiv (is-embeddingвҶҗis-equiv e)))
             (is-equiv-is-prop FE) _))

  is-pathsplitвҶҗis-equiv : вҲҖ {рқ“Ө рқ“Ҙ} {A : Type рқ“Ө} {B : Type рқ“Ҙ}
                            {f : A вҶ’ B}
                          вҶ’ is-equiv f
                          вҶ’ is-pathsplit f
  is-pathsplitвҶҗis-equiv = _вүғ_.bwd is-equivвүғis-pathsplit
}
%```
}

\subtree[stt-005V]{
\title{Being pathsplit is a proposition}
\taxon{Corollary}

\p{Any type equivalent to a proposition is a proposition,
so from \ref{stt-005S} it follows that being pathsplit is a proposition.}

%```agda
  \agda{
  is-pathsplit-is-prop : вҲҖ {рқ“Ө рқ“Ҙ} {A : Type рқ“Ө} {B : Type рқ“Ҙ}
                           {f : A вҶ’ B}
                         вҶ’ is-prop (is-pathsplit f)
  is-pathsplit-is-prop = is-propвҶҗequiv-to-prop
                             (is-equivвүғis-pathsplit eвҒ»В№)
                             (is-equiv-is-prop FE)
  }
%```
}

\subtree[stt-005U]{
\title{Pathsplitness via the diagonal}
\taxon{Theorem}
\p{The type \code{is-pathsplit f} is equivalent to the type
#{\rm{section}(f) \times \rm{section}(\Delta_f)}, where #{\Delta_f}
is the [diagonal map](stt-005X) associated to a pullback.}

\proof{
\p{We show #{\rm{section}(\Delta_f) \simeq \Pi_{(x,y : A)}\rm{section}(\rm{ap}_{x,y}(f))}
by calculation:}

##{
\begin{align*}
  \rm{section}(\Delta_f) &\simeq
    \Sigma_{(g : A \times_B A \to A)} \Pi_{(x : A \times_B A)} (g(x), g(x), \refl) = x\\
  &\simeq \Pi_{(x, y : A)} \Pi_{(p : x = y)} \Sigma_{a : A} (a , a , \refl) = (x, y, p) \\
  &\simeq \Pi_{(x, y : A)} \Pi_{(p : x = y)} \Sigma_{a : A}
    \Sigma_{(q : a пјқ x)} \Sigma_{(r : a = y)} (\rm{ap}_f(q) \cdot p = \rm{ap}_f(r)) \\
  &\simeq \Pi_{(x, y : A)} \Pi_{(p : x = y)}
          \Sigma_{(r : a = y)} (p = \rm{ap}_f(r)) \\
  &\simeq \Pi_{(x, y: A)} \rm{section}(\rm{ap}_f)
\end{align*}
}
}

%```agda
\agda{
  is-pathsplitвүғsec-diag
    : вҲҖ {рқ“Ө рқ“Ҙ} {A : Type рқ“Ө} {B : Type рқ“Ҙ}
        {f : A вҶ’ B}
      вҶ’ (section f Г— section (diagonal f)) вүғ is-pathsplit f
  is-pathsplitвүғsec-diag {A = A}{f = f} = ОЈ-ap-вүғ О» a
    вҶ’ section (diagonal f) вүғвҹЁвҹ©
      ОЈ[ g вҲ¶ (Pullback f f вҶ’ A)] (вҲҖ pb вҶ’ (g pb , g pb , refl) пјқ pb)

         вүғвҹЁ ОЈ-О -swapвүғ _ (О» pb a вҶ’ (a , a , refl) пјқ pb) eвҒ»В№ вҹ©

      ((x : Pullback f f) вҶ’ ОЈ[ a вҲ¶ A ] ((a , a , refl) пјқ x))

          вүғвҹЁ postcomp-О -вүғ FE(О» c вҶ’ ОЈ-ap-вүғ (О» _ вҶ’ pullback-pathвүғ)) вҹ©

      (вҲҖ (x : Pullback f f) вҶ’ ОЈ[ a вҲ¶ A ] pullback-Path (a , a , refl) x)

         вүғвҹЁ curryвүғ вҹ©

      (вҲҖ x (y : ОЈ _ (О» vвӮҒ вҶ’ f x пјқ f vвӮҒ)) вҶ’
        ОЈ[ a вҲ¶ A ] pullback-Path (a , a , refl) (x , y))

         вүғвҹЁ postcomp-О -вүғ FE (О» c вҶ’ curryвүғ) вҹ©

      (вҲҖ x y (p : f x пјқ f y) вҶ’
          ОЈ[ z вҲ¶ A ] ОЈ[ P вҲ¶ (z пјқ x)] ОЈ[ Q вҲ¶ (z пјқ y)]
            ((ap f P) вҲҷ p пјқ ap f Q))

          вүғвҹЁ postcomp-О -вүғ FE (О» _ вҶ’ postcomp-О -вүғ FE О» _
              вҶ’ postcomp-О -вүғ FE О» c вҶ’ ОЈ-пјқsingl) вҹ©

      ((x y : A) (p : f x пјқ f y) вҶ’ (ОЈ[ Q вҲ¶ (x пјқ y)] (p пјқ ap f Q)))

        вүғвҹЁ postcomp-О -вүғ FE (О» _ вҶ’
             postcomp-О -вүғ FE (О» _ вҶ’
               ОЈ-О -swapвүғ _ _ вҲҷвүғ ОЈ-ap-вүғ (О» _ вҶ’ postcomp-О -вүғ FE (О» _ вҶ’ symвүғ)))) вҹ©

      (вҲҖ x y вҶ’ section (ap f)) вүғвҲҺ

  is-pathsplitвҶҗsec-diag
    : вҲҖ {рқ“Ө рқ“Ҙ} {A : Type рқ“Ө} {B : Type рқ“Ҙ}
        {f : A вҶ’ B}
      вҶ’ section f
      вҶ’ section (diagonal f)
      вҶ’ is-pathsplit f
  is-pathsplitвҶҗsec-diag sec secd = sec ,
    _вүғ_.fwd is-pathsplitвүғsec-diag (sec , secd) .snd

  sec-diagвҶҗis-pathsplit
    : вҲҖ {рқ“Ө рқ“Ҙ} {A : Type рқ“Ө} {B : Type рқ“Ҙ}
        {f : A вҶ’ B}
      вҶ’ is-pathsplit f
      вҶ’ section (diagonal f)
  sec-diagвҶҗis-pathsplit = snd вҲҳ _вүғ_.bwd is-pathsplitвүғsec-diag
}
%```
}

\subtree[fre-00E4]{
\title{The canonical inclusion of the #{n}-simplex into the #{n}-cube}
\taxon{Definition}

\agda{
в–ЎвҶҗО” : вҲҖ {n} вҶ’ О”^ n вҶ’ в–Ў^ n
в–ЎвҶҗО” В· = _
в–ЎвҶҗО” (В· :вүҘ: j) = j
в–ЎвҶҗО” (x :вүҘ: i :вүҘ: j) = в–ЎвҶҗО” (x :вүҘ: i) , j

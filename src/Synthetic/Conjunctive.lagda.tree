\date{2026-06-09}
\title{Conjunctive types}
\author{fredrikbakke}
\taxon{Module}
\import{stt-macros}

\transclude{stt-00AB}

\agda{
open import Foundations.Universes
open import Algebra.Lattice

module Synthetic.Conjunctive {𝓘} (Δ¹ : Type 𝓘) (I : Lattice Δ¹) where

open Lattice I renaming (0l to i0; 1l to i1)

import Synthetic.Disjunctive
import Synthetic.Simplicial
open import Algebra.Lattice.Instances.Opposite

module Conj = Synthetic.Disjunctive.Disj Δ¹ (Lattice-op I)

open import Axioms.UF
}

\agda-imports{
\agda{
open import Foundations.Prelude
}
}


\agda{
open import Synthetic.Disjunctive Δ¹ (Lattice-op I) public
  hiding (simp-is-disjunctive; simp-is-upper-located)
  renaming
    ( ∨² to ∧²
    ; fam-disjunctive to fam-conjunctive
    ; fam-is-disjunctive to fam-is-conjunctive
    ; is-disjunctive to is-conjunctive

    ; Disjunctive-SubU to Conjunctive-SubU
    ; Disjunctive-gSubU to Conjunctive-gSubU
    ; Disjunctive-is-globally-reflective to Conjunctive-is-globally-reflective
    ; Disjunctive-gRSubU to Conjunctive-gRSubU

    ; is-disjunctive←equiv to is-conjunctive←equiv
    ; Π-is-disjunctive to Π-is-conjunctive
    ; ULift-is-disjunctive to ULift-is-conjunctive
    ; 𝟙-is-disjunctive to 𝟙-is-conjunctive
    ; is-disjunctive←is-singleton to is-conjunctive←is-singleton
    ; is-disjunctive←retract to is-conjunctive←retract
    ; ~-is-disjunctive to ~-is-conjunctive
    ; Pullback-is-disjunctive to Pullback-is-conjunctive
    ; ＝-is-disjunctive to ＝-is-conjunctive
    ; fibre-is-disjunctive to fibre-is-conjunctive
    ; Ext-is-disjunctive to Ext-is-conjunctive
    ; ×-is-disjunctive to ×-is-conjunctive
    ; retract-is-disjunctive to retract-is-conjunctive
    ; biinv-is-disjunctive to biinv-is-conjunctive
    ; ≃-is-disjunctive to ≃-is-conjunctive
    ; Equaliser-is-disjunctive to Equaliser-is-conjunctive
    ; Seq-lim-is-disjunctive to Seq-lim-is-conjunctive
    ; preidempotent-map-is-disjunctive to preidempotent-map-is-conjunctive
    ; qidempotent-map-is-disjunctive to qidempotent-map-is-conjunctive
    ; idempotent-map-is-disjunctive to idempotent-map-is-conjunctive
    ; Retracts-is-disjunctive to Retracts-is-conjunctive
    ; Hom-is-disjunctive to Hom-is-conjunctive
    ; Σ-is-disjunctive to Σ-is-conjunctive

    ; Λ[2,2]-∨-rec to Λ[2,0]-∧-rec
    ; Λ[2,2]-∨-rec' to Λ[2,0]-∧-rec'
    ; Λ[2,2]-∨-rec! to Λ[2,0]-∧-rec!
    ; ∨=1←fam-disjunctive to ∧=0←fam-conjunctive
    ; Λ[2,2]' to Λ[2,0]'
    ; Λ[2,2] to Λ[2,0]
    ; drop-join-proof to drop-meet-proof
    ; drop-join-proof-is-equiv to drop-meet-proof-is-equiv

    ; Λ[2,2]←Λ[2,2]' to Λ[2,0]←Λ[2,0]'
    ; Λ[2,2]←Λ[2,2]'-is-equiv to Λ[2,0]←Λ[2,0]'-is-equiv
    ; Λ[2,2]'≃Λ[2,2] to Λ[2,0]'≃Λ[2,0]
    ; Λ[2,2]'←Λ[2,2] to Λ[2,0]'←Λ[2,0]
    ; Λ[2,2]-incl to Λ[2,0]-incl

    ; is-upper-located to is-lower-located
    ; disj-is-upper-located to conj-is-lower-located
    ; disj←simp-over-∨² to conj←op-simp-over-∧²
    ; disj→simp-over-∨² to conj→op-simp-over-∧²
    ; disj←simp-over-∨²-is-equiv to conj←op-simp-over-∧²-is-equiv

    ; Disjunctive-U to Conjunctive-U
    ; Disjunctive-U-is-disjunctive to Conjunctive-U-is-conjunctive
    ; Disjunctive-Trunc-U to Conjunctive-Trunc-U
    ; Disjunctive-Trunc-U-is-disjunctive to Conjunctive-Trunc-U-is-conjunctive
    ; Disjunctive-Set-U to Conjunctive-Set-U
    ; Disjunctive-Set-U-is-disjunctive to Conjunctive-Set-U-is-conjunctive
    ; Disjunctive-Prop-U to Conjunctive-Prop-U
    ; Disjunctive-Prop-U-is-disjunctive to Conjunctive-Prop-U-is-conjunctive)
}

\subtree{
\date{2026-03-19}
\author{fredrikbakke}
\taxon{Theorem}
\title{Unique dependent extension property of #{K}-connected maps}

\p{
#{K}-Connectedness is equivalent to saying every section of a #{K}-valued
family over the domain uniquely extends along the map.
}

% ```agda
\agda{
up-gconnected-mapтЗФunique-extensions
  : тИА {╬▒ ЁЭУд ЁЭУе} (K : gSubU ╬▒)
      {A : Type ЁЭУд} {B : Type ЁЭУе}
      (f : A тЖТ B)
    тЖТ up-gconnected-map K f
    тЖТ тИА {ЁЭУЪ} {U : B тЖТ Type ЁЭУЪ}
    тЖТ (тИА b тЖТ U b тИИ gSubU.S K)
    тЖТ (h : ╬а A (U тИШ f))
    тЖТ is-singleton (Ext f h)
up-gconnected-mapтЗФunique-extensions K f fconn UтИИK h
  = is-contr-mapтЖРis-equiv (fconn UтИИK) h

up-gconnected-mapтЖРunique-extensions
  : тИА {╬▒ ЁЭУд ЁЭУе} (K : gSubU ╬▒)
      {A : Type ЁЭУд} {B : Type ЁЭУе}
      (f : A тЖТ B)
    тЖТ (тИА {ЁЭУЪ} {U : B тЖТ Type ЁЭУЪ}
        тЖТ (тИА b тЖТ U b тИИ gSubU.S K)
        тЖТ (h : ╬а A (U тИШ f))
        тЖТ is-singleton (Ext f h))
  тЖТ up-gconnected-map K f
up-gconnected-mapтЖРunique-extensions K f ext {U = U} UтИИK
  = is-equivтЖРis-contr-map ╬╗ h тЖТ ext UтИИK h
}
%```
}

\subtree{
\date{2026-03-19}
\author{fredrikbakke}
\taxon{Lemma}
\title{Terminal projection and constant-map criteria on fibres}

\p{
For the fibres of a map, asking that the terminal projections be #{K}-equivalences is
equivalent to asking that the fibres satisfy the universal property of
#{K}-connected types.
}

% ```agda
\agda{
gconnected-map-!-fibresтЗФgconnected-fibres
  : тИА {╬▒ ЁЭУд ЁЭУе} (K : gSubU ╬▒)
      {A : Type ЁЭУд} {B : Type ЁЭУе}
      (f : A тЖТ B)
  тЖТ gconnected-map-!-fibre K f
  тЖТ gconnected-fibres K f
gconnected-map-!-fibresтЗФgconnected-fibres K f fib-eq b UтИИK
  = is-equiv-constтЖРprecomp-! (fib-eq b UтИИK)

gconnected-map-!-fibresтЖРgconnected-fibres
  : тИА {╬▒ ЁЭУд ЁЭУе} (K : gSubU ╬▒)
      {A : Type ЁЭУд} {B : Type ЁЭУе}
      (f : A тЖТ B)
  тЖТ gconnected-fibres K f
  тЖТ gconnected-map-!-fibre K f
gconnected-map-!-fibresтЖРgconnected-fibres K f fib-const b UтИИK
  = is-equiv-precomp-!тЖРconst (fib-const b UтИИK)
}
%```
}

\subtree{
\date{2026-03-19}
\author{fredrikbakke}
\taxon{Theorem}
\title{Fibrewise connected maps are connected}

\p{
If each fibre of #{f} is #{K}-connected, i.e., for each #{b} and each #{K}-type #{U},
the constant map #{U \to (\fibre{f}{b} \to U)} is an equivalence, then #{f} is
#{K}-connected.
}

% ```agda
\agda{
up-gconnected-mapтЖРgconnected-fibres
  : тИА {╬▒ ЁЭУд ЁЭУе} (K : gSubU ╬▒)
      {A : Type ЁЭУд} {B : Type ЁЭУе}
      (f : A тЖТ B)
  тЖТ gconnected-fibres K f
  тЖТ up-gconnected-map K f
up-gconnected-mapтЖРgconnected-fibres K f fibre-const {U = U} UтИИK
  = is-equivтЖРArrow-equivтБ╗┬╣ {F = eq .fst} (eq .snd)
      (postcomp-╬а-equiv ╬╗ {b} тЖТ fibre-const b (UтИИK b)) where
  eq = precomp-╬а-fibre-const-Arrow-equiv U f

up-gconnected-mapтЖРfibre-terminal-equiv
  : тИА {╬▒ ЁЭУд ЁЭУе} (K : gSubU ╬▒)
      {A : Type ЁЭУд} {B : Type ЁЭУе}
      (f : A тЖТ B)
  тЖТ gconnected-map-!-fibre K f
  тЖТ up-gconnected-map K f
up-gconnected-mapтЖРfibre-terminal-equiv K f fibterm
  = up-gconnected-mapтЖРgconnected-fibres K f
      (gconnected-map-!-fibresтЗФgconnected-fibres K f fibterm)
}
%```
}


\subtree[fre-0315]{
\date{2026-03-19}
\author{fredrikbakke}
\title{#{K}-Connected maps, given reflections of fibres}

\agda{
module gReflectorConnectedMaps
    {╬▒ ЁЭУд ЁЭУе} {GS : gSubU ╬▒}
    {A : Type ЁЭУд} {B : Type ЁЭУе}
    (f : A тЖТ B)
    (RЁЭЯЩ : gReflector GS ЁЭЯЩ)
    (тЧЛЁЭЯЩ-singleton : is-singleton (gReflector.тЧЛ RЁЭЯЩ))
    (Rf : (b : B) тЖТ gReflector GS (fibre f b)) where
  module One = gReflector RЁЭЯЩ

  reflected-fibres-singleton
    : Type _
  reflected-fibres-singleton = тИА b тЖТ is-singleton (gReflector.тЧЛ (Rf b))

  reflected-fibres-singletonтЖРgconnected-map-!-fibre
    : gconnected-map-!-fibre GS f
    тЖТ reflected-fibres-singleton
  reflected-fibres-singletonтЖРgconnected-map-!-fibre fibterm b
    = is-singleтЖРequiv-to-single
        (mkтЙГ (gReflectorMap.тЧЛтВБ (Rf b) RЁЭЯЩ (! {A = fibre f b}))
          (gReflectorModalEquivalences.is-gmodal-equivтЖРup-gmodal-equiv
            (Rf b) RЁЭЯЩ (! {A = fibre f b}) (fibterm b))
          eтБ╗┬╣)
        тЧЛЁЭЯЩ-singleton

  gconnected-map-!-fibreтЖРreflected-fibres-singleton
    : reflected-fibres-singleton
    тЖТ gconnected-map-!-fibre GS f
  gconnected-map-!-fibreтЖРreflected-fibres-singleton sing b
    = gReflectorModalEquivalences.up-gmodal-equivтЖРis-gmodal-equiv
        (Rf b) RЁЭЯЩ (! {A = fibre f b})
        (is-equivтЖРsingle-to-prop
          (sing b)
          (is-propтЖРis-single тЧЛЁЭЯЩ-singleton)
          (gReflectorMap.тЧЛтВБ (Rf b) RЁЭЯЩ (! {A = fibre f b})))
}
%```
}

\subtree[fre-0316]{
\date{2026-03-19}
\author{fredrikbakke}
\taxon{Theorem}
\title{Reflectors of #{\Sigma}-closed reflective global subuniverses are connected}

\agda{
module gRSubUReflectorConnected {╬▒}
    (RS : gRSubU ╬▒)
    (S╬г : is-globally-╬г-closed (RS .gRSubU.GS)) where
  open gRSubU RS
  open ReflectiveClosureс╡Н RS
  open gRSubUEquivMap RS
  open gRSubUInduction RS S╬г
  open gRSubUModalEquivalences RS

  ╬╖-connected-map
    : тИА {ЁЭУд} {A : Type ЁЭУд}
    тЖТ up-gconnected-map GS (╬╖ {A = A})
  ╬╖-connected-map {A = A} {U = U} UтИИS
    = is-equivтБ╗┬╣ (ind-is-equiv UтИИS)

  ╬╖тИШ-connected-mapтЖРup-gmodal-equiv
    : тИА {ЁЭУд ЁЭУе} {A : Type ЁЭУд} {B : Type ЁЭУе}
      (f : A тЖТ B)
    тЖТ up-gmodal-equiv GS f
    тЖТ up-gconnected-map GS (╬╖ {A = B} тИШ f)
  ╬╖тИШ-connected-mapтЖРup-gmodal-equiv {A = A} {B = B} f feq {U = U} UтИИS
    = homotopy-is-equiv {f = rhs} {g = precomp-╬а U (╬╖ тИШ f)}
        (comm ~тБ╗┬╣) rhs-is-equiv where
    mid
      : ╬а (тЧЛ B) U
      тЖТ ╬а A (╬╗ a тЖТ U (тЧЛтВБ f (╬╖ a)))
    mid = precomp-╬а (U тИШ тЧЛтВБ f) ╬╖ тИШ precomp-╬а U (тЧЛтВБ f)

    rhs
      : ╬а (тЧЛ B) U тЖТ ╬а A (U тИШ ╬╖ тИШ f)
    rhs = postcomp-╬а (╬╗ a тЖТ tr U (тЧЛтВБ-╬▓ f a)) тИШ mid

    rhs-is-equiv
      : is-equiv rhs
    rhs-is-equiv
      = is-equiv-тИШ
          (postcomp-╬а-equiv ╬╗ {a} тЖТ coe-is-equiv (ap U (тЧЛтВБ-╬▓ f a)))
          (is-equiv-тИШ
            (╬╖-connected-map (UтИИS тИШ тЧЛтВБ f))
            (precomp-╬а-is-equiv (is-gmodal-equivтЖРup-gmodal-equiv f feq)))

    comm
      : precomp-╬а U (╬╖ тИШ f)
      ~ rhs
    comm h = ufAxioms.funextтЖТ ╬╗ a тЖТ sym (apс╡И h (тЧЛтВБ-╬▓ f a))

  is-gmodal-equivтЖРup-gconnected-map
    : тИА {ЁЭУд ЁЭУе} {A : Type ЁЭУд} {B : Type ЁЭУе}
      (f : A тЖТ B)
    тЖТ up-gconnected-map GS f
    тЖТ is-gmodal-equiv f
  is-gmodal-equivтЖРup-gconnected-map f fconn
    = is-gmodal-equivтЖРup-gmodal-equiv f
        (up-gmodal-equivтЖРup-gconnected-map GS f fconn)
}
%```
}

\subtree{
\date{2026-03-19}
\author{fredrikbakke}
\taxon{Lemma}
\title{Connections between certain fibre conditions on a map with #{K}-reflections}

%```agda
\agda{
module gReflectorFibres
    {╬▒ ЁЭУд ЁЭУе} {GS : gSubU ╬▒}
    {A : Type ЁЭУд} {B : Type ЁЭУе}
    (f : A тЖТ B)
    (Rf : (b : B) тЖТ gReflector GS (fibre f b)) where

  ╬╖-fibre-section
    : ╬а A (╬╗ a тЖТ gReflector.тЧЛ (Rf (f a)))
  ╬╖-fibre-section a = gReflector.╬╖ (Rf (f a)) (a , refl)

  fibre-local-centreтЖРover
    : (b : B)
    тЖТ null-homotopy
        (precomp-╬а-over-fibres (╬╗ b тЖТ gReflector.тЧЛ (Rf b)) f ╬╖-fibre-section b)
    тЖТ ╬г[ u тИ╢ gReflector.тЧЛ (Rf b) ]
        ((x : fibre f b) тЖТ u я╝Э gReflector.╬╖ (Rf b) x)
  fibre-local-centreтЖРover b (u , H)
    = u , ╬╗ where (a , refl) тЖТ H (a , refl)

  reflected-fibre-singletonтЖРlocal-centre
    : {b : B}
    тЖТ ╬г[ u тИ╢ gReflector.тЧЛ (Rf b) ]
        ((x : fibre f b) тЖТ u я╝Э gReflector.╬╖ (Rf b) x)
    тЖТ is-singleton (gReflector.тЧЛ (Rf b))
  reflected-fibre-singletonтЖРlocal-centre {b} (u , H)
    = mk-singl u (happly p) where
    module Fb = gReflector (Rf b)

    p : const Fb.тЧЛ Fb.тЧЛ u я╝Э id
    p = unap
          (is-embeddingтЖРis-equiv (Fb.reflects Fb.тЧЛтИИS))
          (ufAxioms.funextтЖТ H)

  fibre-precomp-╬а-╬╖-fibreтЙГ╬а-local-centre-over
    : fibre (precomp-╬а (╬╗ b тЖТ gReflector.тЧЛ (Rf b)) f) ╬╖-fibre-section
      тЙГ ((b : B)
        тЖТ null-homotopy
            (precomp-╬а-over-fibres (╬╗ b тЖТ gReflector.тЧЛ (Rf b)) f
              ╬╖-fibre-section b))
  fibre-precomp-╬а-╬╖-fibreтЙГ╬а-local-centre-over
    = fibre-precomp-╬а-null-homotopyтЙГ
        (╬╗ b тЖТ gReflector.тЧЛ (Rf b)) f ╬╖-fibre-section

  merely-fibre-local-centreтЖРsurjective-precomp-╬а
    : (тИА {ЁЭУЪ} {U : B тЖТ Type ЁЭУЪ}
        тЖТ ((b : B) тЖТ U b тИИ gSubU.S GS)
        тЖТ is-surjective (precomp-╬а U f))
    тЖТ ((b : B)
      тЖТ тХС ╬г[ u тИ╢ gReflector.тЧЛ (Rf b) ]
            ((x : fibre f b) тЖТ u я╝Э gReflector.╬╖ (Rf b) x) тХС)
  merely-fibre-local-centreтЖРsurjective-precomp-╬а surj b
    = Trunc.тЧЛ-rec Trunc.тЧЛтИИS
        (Trunc.╬╖ тИШ fibre-local-centreтЖРover b тИШ ev b)
        (Trunc.тЧЛ-rec Trunc.тЧЛтИИS
          (Trunc.╬╖ тИШ fibre-precomp-╬а-╬╖-fibreтЙГ╬а-local-centre-over ._тЙГ_.fwd)
          (surj (╬╗ b тЖТ gReflector.тЧЛтИИS (Rf b)) ╬╖-fibre-section))
}
%```
}

\subtree{
\date{2026-03-19}
\author{fredrikbakke}
\taxon{Theorem}
\title{Fibre reflection conditions for #{K}-connected maps}

%```agda
\agda{
module gReflectorConnectedCharacterisation
    {╬▒ ЁЭУд ЁЭУе} {GS : gSubU ╬▒}
    {A : Type ЁЭУд} {B : Type ЁЭУе}
    (f : A тЖТ B)
    (RЁЭЯЩ : gReflector GS ЁЭЯЩ)
    (тЧЛЁЭЯЩ-singleton : is-singleton (gReflector.тЧЛ RЁЭЯЩ))
    (Rf : (b : B) тЖТ gReflector GS (fibre f b)) where
  open gReflectorConnectedMaps f RЁЭЯЩ тЧЛЁЭЯЩ-singleton Rf
  open gReflectorFibres f Rf

  reflected-fibres-singletonтЖРmerely-local-centre
    : ((b : B)
      тЖТ тХС ╬г[ u тИ╢ gReflector.тЧЛ (Rf b) ]
            ((x : fibre f b) тЖТ u я╝Э gReflector.╬╖ (Rf b) x) тХС)
    тЖТ reflected-fibres-singleton
  reflected-fibres-singletonтЖРmerely-local-centre mere b
    = Trunc.тЧЛ-rec
        (is-truncatedтЖРis-prop ufAxioms.is-single-is-prop)
        reflected-fibre-singletonтЖРlocal-centre
        (mere b)

  gconnected-map-!-fibreтЖРmerely-local-centre
    : ((b : B)
      тЖТ тХС ╬г[ u тИ╢ gReflector.тЧЛ (Rf b) ]
            ((x : fibre f b) тЖТ u я╝Э gReflector.╬╖ (Rf b) x) тХС)
    тЖТ gconnected-map-!-fibre GS f
  gconnected-map-!-fibreтЖРmerely-local-centre mere
    = gconnected-map-!-fibreтЖРreflected-fibres-singleton
        (reflected-fibres-singletonтЖРmerely-local-centre mere)

  up-gconnected-mapтЖРmerely-local-centre
    : ((b : B)
      тЖТ тХС ╬г[ u тИ╢ gReflector.тЧЛ (Rf b) ]
           ((x : fibre f b) тЖТ u я╝Э gReflector.╬╖ (Rf b) x) тХС)
    тЖТ up-gconnected-map GS f
  up-gconnected-mapтЖРmerely-local-centre mere
    = up-gconnected-mapтЖРfibre-terminal-equiv GS f
        (gconnected-map-!-fibreтЖРmerely-local-centre mere)
}
%```
}

\subtree[fre-0319]{
\date{2026-03-19}
\author{fredrikbakke}
\taxon{Corollary}
\title{Equivalent conditions for connected maps in reflective global subuniverses}

%```agda
\agda{
module gRSubUConnectedCharacterisation {╬▒} (RS : gRSubU ╬▒) where
  open gRSubU RS
  open gRSubUEquivMap RS
  open gRSubUModalEquivalences RS

  module _ {ЁЭУд ЁЭУе} {A : Type ЁЭУд} {B : Type ЁЭУе} (f : A тЖТ B) where
    module Ch = gReflectorConnectedCharacterisation
      f
      (gReflectorтЖРgRSubU RS ЁЭЯЩ)
      (тЧЛЁЭЯЩ-is-single RS)
      (╬╗ b тЖТ gReflectorтЖРgRSubU RS (fibre f b))
    open Ch
    module LC = gReflectorFibres f (╬╗ b тЖТ gReflectorтЖРgRSubU RS (fibre f b))

    gconnected-map-!-fibreтЖРfibre-connected
      : is-gconnected-map RS f
      тЖТ gconnected-map-!-fibre GS f
    gconnected-map-!-fibreтЖРfibre-connected fconn
      = gconnected-map-!-fibresтЖРgconnected-fibres GS f fib-const where

      fib-const : gconnected-fibres GS f
      fib-const b UтИИS
        = (is-equiv-тИШ
            (reflects {A = fibre f b} UтИИS)
            (sing-const-is-equiv global-funext (fconn b)))

    is-gconnected-mapтЖРgconnected-map-!-fibre
      : gconnected-map-!-fibre GS f
      тЖТ is-gconnected-map RS f
    is-gconnected-mapтЖРgconnected-map-!-fibre fibterm b
      = is-singleтЖРequiv-to-single
          (mkтЙГ (тЧЛтВБ (! {A = fibre f b}))
            (is-gmodal-equivтЖРup-gmodal-equiv (! {A = fibre f b}) (fibterm b))
            eтБ╗┬╣)
          (тЧЛЁЭЯЩ-is-single RS)

    is-gconnected-mapтЖРup-gconnected-map
      : up-gconnected-map GS f
      тЖТ is-gconnected-map RS f
    is-gconnected-mapтЖРup-gconnected-map fconn
      = reflected-fibres-singletonтЖРmerely-local-centre
          (LC.merely-fibre-local-centreтЖРsurjective-precomp-╬а
            (╬╗ UтИИK тЖТ is-surjectiveтЖРis-equiv (fconn UтИИK)))

    up-gconnected-mapтЖРis-gconnected-map
      : is-gconnected-map RS f
      тЖТ up-gconnected-map GS f
    up-gconnected-mapтЖРis-gconnected-map fconn
      = up-gconnected-mapтЖРfibre-terminal-equiv GS f
          (gconnected-map-!-fibreтЖРfibre-connected fconn)
}
%```
}

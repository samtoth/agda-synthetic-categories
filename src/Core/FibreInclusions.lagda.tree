-- LEMMA-I F c ((a  , p) , (b , q) , r) .fst = (a , b , r .fst)
-- LEMMA-I F c ((a  , p) , (b , q) , r) .snd .fst = p
-- LEMMA-I F c ((a , p) , (b , q) , r) .snd .snd .fst = q

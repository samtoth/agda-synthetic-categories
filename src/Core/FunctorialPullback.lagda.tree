    ő£[ _ ‚ą∂ (F ._‚ČÉ_.fwd ‚ąė S .left ~ S' .left ‚ąė L ._‚ČÉ_.fwd) ]
    ő£[ R ‚ą∂ (S .Right ‚ČÉ S' .Right) ]
      (F ._‚ČÉ_.fwd ‚ąė S .right ~ S' .right ‚ąė R ._‚ČÉ_.fwd)
  where
  open Cospan

Cospan-equiv‚ČÉcomponents
  : ‚ąÄ {ūĚď§ ūĚď• ūĚď¶ ūĚď§' ūĚď•' ūĚď¶'} {S : Cospan ūĚď§ ūĚď• ūĚď¶} {T : Cospan ūĚď§' ūĚď•' ūĚď¶'}
    ‚Üí Cospan-equiv S T ‚ČÉ Cospan-equiv-components S T
Cospan-equiv‚ČÉcomponents ._‚ČÉ_.fwd (F , e1 , e2 , e3)
  =
  ( mk‚ČÉ (F .h‚āā) e2
  , mk‚ČÉ (h‚āĀ F) e1
  , F .H
  , mk‚ČÉ (h‚āÉ F) e3
  , F .K)
Cospan-equiv‚ČÉcomponents ._‚ČÉ_.has-is-eqv .is-equiv.qiso .fst
  (mk‚ČÉ F Feq , mk‚ČÉ L Leq , H , mk‚ČÉ R Req , K)

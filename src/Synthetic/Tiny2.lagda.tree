  --                                                 , untranspose (snd ∘ x) gi)))))
  --     , (λ where (mod♭ x) → mapply♭ (mod♭ {!!}))
  --     , {!!})

  --   homotopy : ∀ {@♭ 𝓤} {@♭ Γ : Type 𝓤}
  --              → lemma {Γ = Γ} ._≃_.fwd ~ (♭-map (postcomp _ unpack-√×))
  --   homotopy (mod♭ x)
  --     = _≃_.fwd lemma (mod♭ x) ＝⟨⟩
  --       ♭-map _ (♭-×⁻¹
  --                ( (transpose ∘ ♭-map (postcomp _ fst ∘ postcomp _ √ε ∘ postcomp I)) (mod♭ x)
  --                , transpose (mod♭ (λ f → snd (√ε (λ a → x (f a))))))) ＝⟨ {!!} ⟩
  --       ♭-map (λ (a : (_ → √ A) × (_ → √ B)) b → a .fst b , a .snd b) (♭-×⁻¹
  --                ( {!x!}
  --                , transpose (mod♭ (λ f → snd (√ε (λ a → x (f a))))))) ＝⟨ {!!} ⟩
  --       ♭-map (λ (a : (_ → √ A) × (_ → √ B)) b → a .fst b , a .snd b) (mod♭
  --                ( √₁ fst ∘ x
  --                , √₁ snd ∘ x)) ＝⟨ refl ⟩
  --       ♭-map (postcomp _ unpack-√×) (mod♭ x) ∎

module Amazingly {@♭ 𝓘} (@♭ I : Type 𝓘)
            (@♭ √ : ∀ {@♭ 𝓤} → @♭ Type 𝓤 → Type 𝓤)
            (@♭ √ε : ∀ {@♭ 𝓤} {@♭ A : Type 𝓤} → (I → √ A) → A)
            (@♭ is-tiny-str : ∀ {@♭ 𝓤} {@♭ A : Type 𝓤}
                              → is-tiny-structure I A (√ A) √ε)
            (@♭ types-separate : ∀ {@♭ 𝓤 𝓥} {@♭ A : Type 𝓤} {@♭ B : Type 𝓥}
                                   {@♭ f : A → B} → Types-separate f)
            {@♭ α : Level → Level → Level}
            (@♭ is-fib : ∀ {𝓤 𝓥} {A : Type 𝓤} (B : A → Type 𝓥) → Type (α 𝓤 𝓥))
            (@♭ rel-fib : is-relative I is-fib)
            where
  open Tiny I √ √ε is-tiny-str types-separate
  private
    map : ∀ {𝓤} → 𝟙 → (PropU 𝓤)
    map _ = (ULift _ 𝟙 , trunc!)

    √map : ∀ {@♭ 𝓤} → √ 𝟙 → √(PropU 𝓤)
    √map = ε♭ (√₁ (mod♭ map))

    √Type∙-π : ∀ {@♭ 𝓤} → ⟨♭| (√(Σ (Type 𝓤) id) → √(Type 𝓤)) ⟩
    √Type∙-π = √₁ (mod♭ (Type∙-π _))


  transpose-naturality
    : ∀ {@♭ 𝓤 𝓥 𝓦} {@♭ Γ : Type 𝓤} {@♭ Δ : Type 𝓦} {@♭ A : Type 𝓥}
      → (P : ⟨♭| ((I → Γ) → A)⟩)
      → (@♭ σ : Δ → Γ)
      → transpose (♭-map (precomp _ (postcomp I σ)) P)
      ＝ ♭-map (precomp _ σ) (transpose P)
  transpose-naturality (mod♭ P) σ = sym (transpose-unique'
    ( (♭-map untranspose ∘ ♭-map (precomp (√ _) σ)) (transpose (mod♭ P))
    ＝⟨ sym (♭-∘ untranspose (precomp _ σ) _) ⟩
       ♭-map (untranspose ∘ precomp _ σ) (transpose (mod♭ P))
    ＝⟨⟩
       ♭-map (precomp _  (postcomp _ σ) ∘ untranspose) (transpose (mod♭ P))
    ＝⟨ ♭-∘ _ untranspose (transpose (mod♭ P)) ⟩
       ♭-map (precomp _  (postcomp _ σ)) (♭-map untranspose (transpose (mod♭ P)))
    ＝⟨ ap (♭-map _) (is-tiny.ε (mod♭ P)) ⟩
      ♭-map (precomp _ (postcomp I σ)) (mod♭ P) ∎))

  -- class-⊤-large : ∀ {@♭ 𝓤} → √(PropU 𝓤) → PropU (lsuc 𝓤)
  -- class-⊤-large x = (fibre √map x , {!trunc!!})

  class-Ty-large : ∀ {@♭ 𝓤} → √(Type 𝓤) → Type (lsuc 𝓤)
  class-Ty-large
    = Type-is-universal.arrow-map {f = ε♭ (√Type∙-π)} {!!} .Arrow-map.bot

  √ᵈ : ∀ {@♭ 𝓤 𝓥} {@♭ Γ : Type 𝓤} → @♭ ((I → Γ) → Type 𝓥) → Γ → Type (lsuc 𝓥)
  √ᵈ A = class-Ty-large ∘ ε♭ (transpose (mod♭ A))

  {-# INLINE √ᵈ #-}

  opaque
    transpose-lift♭ : ∀ {@♭ 𝓤 𝓥} {@♭ Γ : Type 𝓤} {@♭ A : (I → Γ) → Type 𝓥}
           → ⟨♭| Lift (Type∙-π 𝓥) A ⟩
           ≃ ⟨♭| Lift (ε♭ (√Type∙-π {𝓥})) (ε♭ (transpose (mod♭ A))) ⟩
    transpose-lift♭ {𝓤}{𝓥}{Γ}{A}
      =   ⟨♭| Lift (Type∙-π 𝓥) A ⟩
      ≃⟨ ♭-commΣ _ e⁻¹ ⟩
          (Σ[♭ l ∶ ((I → Γ) → Type∙ 𝓥) ] ⟨♭| fst ∘ l ＝ A  ⟩)
      ≃⟨ Σ-ap-≃-fst-bwd exp⊣√ e⁻¹ ⟩
         Σ ⟨♭| (Γ → √ (Type∙ 𝓥)) ⟩
          (♭-ind _ (λ (@♭ l) → ⟨♭| fst ∘ l ＝ A ⟩) ∘ ♭-map untranspose)
      ≃⟨ Σ-ap-≃ (λ {(mod♭ l) → idequiv}) ⟩
          (Σ[♭ l ∶ (Γ → √ (Type∙ 𝓥)) ] ⟨♭| fst ∘ untranspose l ＝ A ⟩)
      ≃⟨ Σ-ap-≃ (λ {(mod♭ l) → {!!}}) ⟩
          (Σ[♭ l ∶ (Γ → √ (Type∙ 𝓥)) ]
             ⟨♭| (ε♭ √Type∙-π) ∘ l ＝ ε♭ (transpose (mod♭ A)) ⟩)
      ≃⟨ ♭-commΣ _ ⟩
          ⟨♭| Lift (ε♭ √Type∙-π) (ε♭ (transpose (mod♭ A))) ⟩
      ≃∎

  Π←lift : ∀ {@♭ 𝓤 𝓥} {@♭ Γ : Type 𝓤} {@♭ A : (I → Γ) → Type 𝓥}
         → Lift (ε♭ (√Type∙-π {𝓥})) (ε♭ (transpose (mod♭ A)))
         → Π Γ (√ᵈ A)
  Π←lift {A = A} = universal-section (ε♭ (transpose (mod♭ A))) {!!}

  rintro
    : ∀ {@♭ 𝓤 𝓥} {@♭ Γ : Type 𝓤} {@♭ A : (I → Γ) → Type 𝓥}
      → ⟨♭| Π (I → Γ) A ⟩
      → ⟨♭| Π Γ (√ᵈ A) ⟩
  rintro {A = A} = ♭-map Π←lift ∘ transpose-lift♭ ._≃_.fwd ∘ ♭-map (extension←Π A)

  rintro-is-equiv
    : ∀ {@♭ 𝓤 𝓥} {@♭ Γ : Type 𝓤} {@♭ A : (I → Γ) → Type 𝓥}
      → is-equiv (rintro {A = A})
  rintro-is-equiv
    = is-equiv-∘
        (♭-map-is-equiv (universal-section-is-equiv _ {!!}))
        (is-equiv-∘
          (transpose-lift♭ ._≃_.has-is-eqv)
          (♭-map-is-equiv (extension←Π-is-equiv _)))

  is-afib : ∀ {@♭ 𝓤} → Type 𝓤 → Type (lsuc (α 𝓘 𝓤))
  is-afib = √ᵈ is-fib

  UFib : ∀ (@♭ 𝓤) → Type (lsuc (α 𝓘 𝓤 ⊔ 𝓤))
  UFib 𝓤 = Σ[ A ∶ Type 𝓤 ] is-afib A

  UFib∙ : ∀ (@♭ 𝓤) → Type (lsuc (α 𝓘 𝓤 ⊔ 𝓤))
  UFib∙ 𝓤 = Σ (UFib 𝓤) fst

  UFib-π : ∀ {@♭ 𝓤} → UFib∙ 𝓤 → UFib 𝓤
  UFib-π = fst

  UFib-π-is-fib : ∀ {@♭ 𝓤} → is-fib (fst {B = is-afib {𝓤}})
  UFib-π-is-fib = rel-fib _ .snd
    (ε♭ (is-equiv.bwd (rintro-is-equiv)
          (mod♭ (λ a → tr class-Ty-large
                          (sym (happly
                            ( ap ε♭ (transpose-naturality (mod♭ is-fib) fst)
                            ∙ ε♭-natural (transpose (mod♭ is-fib)))
                            a))
                          (a .snd)))))

  UFib-is-fib : ∀ {@♭ 𝓤 𝓥} {@♭ A : Type 𝓤} (P : A → UFib 𝓥)
                → is-fib (fst ∘ P)
  UFib-is-fib P
    = is-pullback-stable←is-relative
        I is-fib rel-fib _ P
        UFib-π-is-fib

  liftFib : ∀ {@♭ 𝓤 𝓥} {@♭ A : Type 𝓤} {@♭ P : A → Type 𝓥}
              → ⟨♭| is-fib P ⟩ ⇔ ⟨♭| (∀ a → is-afib (P a)) ⟩
  liftFib {A = A} {P = P} .fst fib
    = ♭-map (postcomp-Π (λ i → tr class-Ty-large (happly
                          ( ap ε♭ (transpose-naturality (mod♭ is-fib) P)
                          ∙ ε♭-natural (transpose (mod♭ is-fib))) i)))
            (rintro (♭-map (rel-fib P .fst) fib))
  liftFib {A = A} {P = P} .snd = ♭-map (UFib-is-fib ∘ (λ af a → (P a , af a)))
}
%```

open import Foundations.PropExt public using
  (PropExt; logicalвЖРequiv; equivвЖРlogical; is-equivвЖРinverse; logicalвЖРId; weak-PropExt; weak-PropExtвЖРFunExt)
import Foundations.PropExt as PE

propExt : вИА {рЭУ§} вЖТ PropExt рЭУ§
propExt = PE.PropExtвЖРUnivalence global-funext UA

weakPropExt : вИА {рЭУ§} вЖТ weak-PropExt рЭУ§ рЭУ§
weakPropExt = weak-PropExtвЖРFunExt global-funext

open import Foundations.Pushouts public
import Foundations.Spans as Sp

Cocone-pathвЖТ
  : вИА {рЭУ§ рЭУ• рЭУ¶} {S : Span рЭУ§ рЭУ• рЭУ¶} {рЭУЫ} {X : Type рЭУЫ}
    вЖТ (c c' : Cocone S X)
    вЖТ (p : c .Cocone.p пЉЭ c' .Cocone.p)
    вЖТ (q : c .Cocone.q пЉЭ c' .Cocone.q)
    вЖТ (c .Cocone.filler ~вИЩ happly q вЦЄ S .Span.right
         ~ happly p вЦЄ S .Span.left ~вИЩ c' .Cocone.filler)
    вЖТ c пЉЭ c'
Cocone-pathвЖТ = Sp.Cocone-pathвЖТ global-funext


open import Foundations.DependentCocones


module _ {рЭУ§ рЭУ• рЭУ¶} {A : Type рЭУ§} {B : Type рЭУ•} {C : Type рЭУ¶} where
  postulate
    Pushout : вИА (f : A вЖТ B) (g : A вЖТ C) вЖТ Type (рЭУ§ вКФ рЭУ• вКФ рЭУ¶)

    ќєвВБ : вИА {f : A вЖТ B} {g : A вЖТ C} вЖТ B вЖТ Pushout f g

    ќєвВВ :  вИА {f : A вЖТ B} {g : A вЖТ C} вЖТ C вЖТ Pushout f g

    glue : вИА {f : A вЖТ B} {g : A вЖТ C} вЖТ ќєвВБ {f} {g} вИШ f ~ ќєвВВ вИШ g

  pushout : вИА {f : A вЖТ B} {g : A вЖТ C} вЖТ Cocone (mk-span _ f g) (Pushout f g)
  pushout = mk-cocone ќєвВБ ќєвВВ glue

  postulate
    pushout-ind
      : вИА {f : A вЖТ B} {g : A вЖТ C} {рЭУ†} (Q : Pushout f g вЖТ Type рЭУ†)
        вЖТ CoconeбµИ (mk-span _ f g) pushout Q вЖТ (x : Pushout f g) вЖТ Q x

  pushout-indќ≤1
    : вИА {f : A вЖТ B} {g : A вЖТ C} {рЭУ†} {Q : Pushout f g вЖТ Type рЭУ†}
      вЖТ {c : CoconeбµИ (mk-span _ f g) pushout Q}
      вЖТ вИА x вЖТ pushout-ind Q c (ќєвВБ x) пЉЭ c .CoconeбµИ.p x
  pushout-indќ≤1 {c = c} x = primEraseEquality eq where
    postulate eq : pushout-ind _ _ (ќєвВБ x) пЉЭ c .CoconeбµИ.p x

  pushout-indќ≤2
    : вИА {f : A вЖТ B} {g : A вЖТ C} {рЭУ†} {Q : Pushout f g вЖТ Type рЭУ†}
      вЖТ {c : CoconeбµИ (mk-span _ f g) pushout Q}
      вЖТ вИА x вЖТ pushout-ind Q c (ќєвВВ x) пЉЭ c .CoconeбµИ.q x
  pushout-indќ≤2 {c = c} x = primEraseEquality eq where
    postulate eq : pushout-ind _ _ (ќєвВВ x) пЉЭ c .CoconeбµИ.q x

  {-# REWRITE pushout-indќ≤1 pushout-indќ≤2 #-}

  pushout-ind-apќ≤
    : вИА {f : A вЖТ B} {g : A вЖТ C} {рЭУ†} {Q : Pushout f g вЖТ Type рЭУ†}
        {c : CoconeбµИ (mk-span _ f g) pushout Q}
      вЖТ вИА x вЖТ apбґ† (pushout-ind Q c) (glue x) пЉЭ c .CoconeбµИ.filler x
  pushout-ind-apќ≤ {c = c} x = primEraseEquality eq where
    postulate eq : apбґ† (pushout-ind _ c) (glue x) пЉЭ c .CoconeбµИ.filler x

  opaque
    pushout-rec
      : вИА {f : A вЖТ B} {g : A вЖТ C} {рЭУ†} {Q : Type рЭУ†}
        вЖТ Cocone (mk-span _ f g) Q
        вЖТ Pushout f g вЖТ Q
    pushout-rec {Q = Q} cc@(mk-cocone p q h)
      = pushout-ind (ќї _ вЖТ Q) (DependentвЖРCocone {P = ќї _ вЖТ Q} cc)

    pushout-recќ≤1
      : вИА {f : A вЖТ B} {g : A вЖТ C} {рЭУ†} {Q : Type рЭУ†}
        вЖТ {c : Cocone (mk-span _ f g) Q}
        вЖТ вИА x вЖТ pushout-rec c (ќєвВБ x) пЉЭ c .Cocone.p x
    pushout-recќ≤1 _ = refl

    pushout-recќ≤2
      : вИА {f : A вЖТ B} {g : A вЖТ C} {рЭУ†} {Q : Type рЭУ†}
        вЖТ {c : Cocone (mk-span _ f g) Q}
        вЖТ вИА x вЖТ pushout-rec c (ќєвВВ x) пЉЭ c .Cocone.q x
    pushout-recќ≤2 _ = refl

  {-# REWRITE pushout-recќ≤1 pushout-recќ≤2 #-}

  opaque
    unfolding pushout-rec
    pushout-rec-apќ≤
      : вИА {f : A вЖТ B} {g : A вЖТ C} {рЭУ†} {Q : Type рЭУ†}
          {c : Cocone (mk-span _ f g)  Q}
        вЖТ вИА x вЖТ ap (pushout-rec c) (glue x) пЉЭ c .Cocone.filler x
    pushout-rec-apќ≤ {f} {g} {Q = Q} {c} x
      = ap (pushout-rec _) (glue x)                      пЉЭвЯ® sym apбґ†-is-ap вЯ©
        coe (tr-cst вИЩ-) (apбґ† (pushout-rec c) (glue x))   пЉЭвЯ® ap (coe (tr-cst вИЩ-)) (pushout-ind-apќ≤ x) вЯ©
        coe (tr-cst вИЩ-)
          (CoconeбµИ.filler {cc = pushout}
            (DependentвЖРCocone {P = ќї _ вЖТ Q} c) x)        пЉЭвЯ®вЯ©
        coe (tr-cst вИЩ-) (tr-cst вИЩ (c .Cocone.filler x))  пЉЭвЯ® coe-precompпЉЭ tr-cst _ вЯ©
        sym tr-cst вИЩ (tr-cst вИЩ (c .Cocone.filler x))     пЉЭвЯ® вИЩ.cancelr _ {h = tr-cst} (вИЩ-sym' tr-cst) {f = c .Cocone.filler x} вЯ©
        Cocone.filler c x вИО where
         tr-cst : tr (ќї _ вЖТ Q) (glue {f = f} {g} x) (pushout-rec c (ќєвВБ (f x))) пЉЭ pushout-rec c (ќєвВБ (f x))
         tr-cst = tr-constant (glue x) (pushout-rec c (ќєвВБ (f x)))
}

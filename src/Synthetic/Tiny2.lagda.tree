\subtree[stt-00BC]{
\title{Internally Tiny Object}
\date{2025-11-17}
\taxon{Definition}

\p{In a cartesian closed category #{\CC}, for each object #{I}, there is an
adjunction #{- \times I \dashv -^I}. The object is called (internally)-\em{tiny}
or sometimes \em{atomic} if #{-^I} has a further right adjoint, which we will
call #{\sqrt[I]{-}}. This right adjoint is also referred to as \em{the amazing
right adjoint} - terminology which stems from synthetic differential geometry.}
}

\subtree{
\title{Idea}

\p{In type theory, we can represent the situation where a type #{I} has a right
adjoint using with the following judgement (Where #{\mathcal{P}} represents
exponentiating the context by #{I}):}

##{
\frac{\mathcal{P}(\Gamma) \vdash A}{\Gamma \vdash \sqrt[I]{A}}
}

\p{In addition, you need rules expressing the unit and counit of the adjunction.
It is clearly not possible to introduce this type as an axiom inside of type
theory; but there have been structural extensions to type theory that allow this
type to be represented. Firstly, it fits within the general framework of
[multimode type theory](GKNB21) and this approach is taken in \citek{GWB2024} to
define the category of spaces. Secondly, Mitchel Riley \citek{MR2024} introduced a
bespoke type theory that incorporates a tiny object.}

\p{Seperately, \citek{LOPS2018} make use of the [flat
modality](Modalities.Flat.Flat) to postulate an amazing right adjoint. In this
module we formalise a similar construction, except instead of postulating the
adjunction directly, we postulate a type former with #{\beta} and #{\eta} laws
roughly based off Mitchel Riley's work.  }
}


\subtree[stt-00AO]{
\title{Relative notions of fibrancy}
\taxon{Definition}

\p{Fixing a type #{I}, and given #{\mathcal{F}} a family of predicates over
families of types #{A \to \UU}, we say that #{\mathcal{F}} is #{I}-relative for
some type #{I} if #{P} is fibrant iff for any map #{x : I \to A}, #{P \circ x}
is fibrant.
}

%```agda
\agda{
is-relative : ∀ {𝓘} {α : Level → Level → Level}
              → Type 𝓘
              → (∀ {𝓤 𝓥} {A : Type 𝓤} → (A → Type 𝓥) → Type (α 𝓤 𝓥))
              → Typeω
is-relative I is-fib
  = ∀ {𝓤 𝓥} {A : Type 𝓤} (P : A → Type 𝓥)
    → (is-fib P ⇔ (∀ (x : I → A) → is-fib (P ∘ x) ))
}
%```
}

\subtree[stt-00BB]{
\taxon{Theorem}
\title{Relative fibrations are pullback stable}

\p{Any notion of fibration which is relative is pullback stable.}

%```agda
\agda{
is-pullback-stable : ∀ {α : Level → Level → Level}
                     → (∀ {𝓤 𝓥} {A : Type 𝓤} → (A → Type 𝓥) → Type (α 𝓤 𝓥))
                     → Typeω
is-pullback-stable is-fib
  = ∀ {𝓤 𝓤' 𝓥} {Γ : Type 𝓤'} {A : Type 𝓤} (P : A → Type 𝓥) (σ : Γ → A)
    → is-fib P → is-fib (P ∘ σ)

is-pullback-stable←is-relative
  : ∀ {α : Level → Level → Level} {𝓘}
    → (I : Type 𝓘)
    → (P : ∀ {𝓤 𝓥} {A : Type 𝓤} → (A → Type 𝓥) → Type (α 𝓤 𝓥))
    → is-relative I P → is-pullback-stable P
is-pullback-stable←is-relative I is-fib rel P σ fib
  = rel (P ∘ σ) .snd (λ x → rel P .fst fib (σ ∘ x))
}
%```
}

\subtree[tot-0001]{
\title{Tiny types}

%```agda
\agda{

is-tiny-structure
  : ∀ {@♭ 𝓤 𝓥} (@♭ I : Type 𝓤) (@♭ A : Type 𝓥)
      (@♭ √A : Type 𝓥) (@♭ √ε : (I → √A) → A) → Typeω
is-tiny-structure I A √A √ε
  = ∀ {@♭ 𝓤} {@♭ X : Type 𝓤}
    → is-equiv {A = ⟨♭| (X → √A) ⟩} {B = ⟨♭| ((I → X) → A) ⟩}
               (♭-map (postcomp _ √ε ∘ postcomp I))

record Σω {𝓤} (A : Type 𝓤) (B : A → Typeω) : Typeω where
  constructor _,_
  field
    fstω : A
    sndω : B fstω

open Σω

Σω♭ : ∀ {@♭ 𝓤} (@♭ A : Type 𝓤) (B : @♭ A → Typeω)
     → Typeω
Σω♭ A B = Σω ⟨♭| A ⟩ λ where (mod♭ a) → B a

@♭ sndω♭ : ∀ {@♭ 𝓤} {@♭ A : Type 𝓤} {@♭ B : @♭ A → Typeω}
           → (@♭ x : Σω♭ A B) → B (ε♭ (fstω x))
sndω♭ (mod♭ x , y) = y

syntax Σω♭ A (λ x → B) = Σω[♭ x ∶ A ] B


is-tiny : ∀ {@♭ 𝓘} → @♭ Type 𝓘 → Typeω
is-tiny I
  = ∀ {@♭ 𝓤} → Σω[♭ √ ∶ (∀ (@♭ A : Type 𝓤) → Type 𝓤) ]
                 Σω[♭ √ε ∶ (∀ {@♭ A : Type 𝓤} → (I → √ A) → A) ]
                   (∀ {@♭ A : Type 𝓤} → is-tiny-structure I A (√ A) √ε)

Types-separate
  : ∀ {@♭ 𝓤 𝓥} {@♭ A : Type 𝓤} {@♭ B : Type 𝓥} (@♭ f : A → B) → Typeω
Types-separate f
  = (∀ {@♭ 𝓤 }{@♭ Γ : Type 𝓤} → is-equiv (♭-map (postcomp Γ f))) → is-equiv f

module Tiny {@♭ 𝓘} (@♭ I : Type 𝓘)
            (@♭ √ : ∀ {@♭ 𝓤} → @♭ Type 𝓤 → Type 𝓤)
            (@♭ √ε : ∀ {@♭ 𝓤} {@♭ A : Type 𝓤} → (I → √ A) → A)
            (@♭ is-tiny-str : ∀ {@♭ 𝓤} {@♭ A : Type 𝓤}
                              → is-tiny-structure I A (√ A) √ε)
            (@♭ types-separate : ∀ {@♭ 𝓤 𝓥} {@♭ A : Type 𝓤} {@♭ B : Type 𝓥}
                                   {@♭ f : A → B} → Types-separate f)
            where
  module is-tiny {@♭ 𝓤 𝓥} {@♭ A : Type 𝓤} {@♭ X : Type 𝓥}
    = is-equiv (is-tiny-str {𝓤} {A} {𝓥} {X})

  transpose : ∀ {@♭ 𝓤 𝓥} {@♭ Γ : Type 𝓤} {@♭ A : Type 𝓥}
              → ⟨♭| ((I → Γ) → A)⟩ → ⟨♭| (Γ → √ A) ⟩
  transpose = is-equiv.bwd is-tiny-str

  untranspose : ∀ {@♭ 𝓤 𝓥} {@♭ Γ : Type 𝓤} {@♭ A : Type 𝓥}
              → (Γ → √ A) → ((I → Γ) → A)
  untranspose = postcomp _ √ε ∘ postcomp I

  transpose-unique'
    : ∀ {@♭ 𝓤 𝓥} {@♭ Γ : Type 𝓤} {@♭ A : Type 𝓥}
        {f : ⟨♭| ((I → Γ) → A)⟩} {g : ⟨♭| (Γ → √ A) ⟩}
      → ♭-map untranspose g ＝ f
      → g ＝ transpose f
  transpose-unique' {f = f} H = unap-equiv is-tiny-str (H ∙ is-tiny.ε⁻¹ f)

  transpose-unique
    : ∀ {@♭ 𝓤 𝓥} {@♭ Γ : Type 𝓤} {@♭ A : Type 𝓥}
        {@♭ f : ((I → Γ) → A)} {@♭ g : Γ → √ A}
      → @♭ (postcomp _ √ε (postcomp I g)) ~ f
      → g ~ ε♭ (transpose (mod♭ f))
  transpose-unique {g = g} H x
    = happly (ap ε♭ (transpose-unique' {g = mod♭ g} (ap♭ mod♭ (funext→ H)))) x

  exp⊣√ : ∀ {@♭ 𝓤 𝓥} {@♭ A : Type 𝓤} {@♭ B : Type 𝓥}
          → ⟨♭| ((I → A) → B) ⟩ ≃ ⟨♭| (A → √ B) ⟩
  exp⊣√ ._≃_.fwd = _
  exp⊣√ ._≃_.has-is-eqv = is-equiv⁻¹ is-tiny-str

  √₁ : ∀ {@♭ 𝓤 𝓥} {@♭ A : Type 𝓤} {@♭ B : Type 𝓥} → ⟨♭| (A → B) ⟩ → ⟨♭| (√ A → √ B)⟩
  √₁ f = transpose (♭-map (precomp _ √ε) f)

  √₁-id : ∀ {@♭ 𝓤} {@♭ A : Type 𝓤} → √₁ (mod♭ id) ＝ mod♭ (id {A = √ A})
  √₁-id = sym (transpose-unique' refl)

  -- _∘♭_ : ∀ {@♭ 𝓤 𝓥 𝓦} {@♭ A : Type 𝓤} {@♭ B : Type 𝓥} {@♭ C : Type 𝓦}
  --          (f : ⟨♭| (B → C) ⟩) (g : ⟨♭| (A → B)⟩) → ⟨♭| (A → C)⟩
  -- mod♭ f ∘♭ mod♭ g = mod♭ (f ∘ g)

  -- ♭-map' : ∀ {@♭ 𝓤 𝓥} {@♭ A : Type 𝓤} {@♭ B : Type 𝓥}
  --            (f : ⟨♭| (A → B)⟩) → ⟨♭| A ⟩ → ⟨♭| B ⟩
  -- ♭-map' (mod♭ f) = ♭-map f

  -- ♭-map-∘ : ∀ {@♭ 𝓤 𝓥 𝓦 𝓜} {@♭ A : Type 𝓤} {@♭ B : Type 𝓥} {@♭ C : Type 𝓦}

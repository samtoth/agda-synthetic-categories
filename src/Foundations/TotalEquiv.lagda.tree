\date{2025-03-04}
\taxon{Theorem}
\title{Fibres of maps between Sigma types}
\import{stt-macros}

% ```agda
\agda{
module Foundations.TotalEquiv where

open import Foundations.Universes
open import Foundations.QuasiEquivalence
open import Foundations.CoherentEquivalence
open import Foundations.Sigma
open import Foundations.SigmaPath
open import Foundations.SigmaProperties
open import Foundations.FibrewiseEquiv
open import Foundations.Identity
open import Foundations.DependentIdentity
open import Foundations.Functions
open import Foundations.SingletonFibres
open import Foundations.Singleton
open import Foundations.EquivSingleton
}
% ```

\subtree[stt-00F9]{
\taxon{Definition}
\title{Functorial action of Σ-types}
\author{fredrikbakke}

% ```agda
\agda{
map-Σ
  : {𝓤1 𝓤2 𝓤3 𝓤4 : Level}
    {A : Type 𝓤1}
    {B : Type 𝓤2}
    {X : A → Type 𝓤3}
    {Y : B → Type 𝓤4}
    (f : A → B)
    (g : (a : A) → X a → Y (f a))
  → Σ A X → Σ B Y
map-Σ f g = total-map-fst f ∘ total-map g
}
% ```
}

\subtree[stt-0027]{
\taxon{Theorem}
\title{Classifying the fibre of total maps}

% ```agda
\agda{
module _
  {𝓤1 𝓤2 𝓤3 𝓤4}
  {A : Type 𝓤1}
  {B : Type 𝓤2}
  (f : A → B)
  {X : A → Type 𝓤3}
  {Y : B → Type 𝓤4}
  (g : (a : A) → X a → Y (f a))
  where

  fibre-map-Σ'
    : (b : B)
      (y : Y b)
    → fibre (map-Σ f g) (b , y)
    ≃ Σ[ a ∶ A ] Σ[ p ∶ f a ＝ b ] Σ[ x ∶ X a ] Idᶠ Y p (g a x) y
  fibre-map-Σ' b y
    = Σ[ (a , x) ∶ (Σ A X) ] ((f a , g a x) ＝ (b , y))
        ≃⟨ Σ-assoc ⟩
      Σ[ a ∶ A ] Σ[ x ∶ X a ] ((f a , g a x) ＝ (b , y))
        ≃⟨ Σ-ap-≃ (λ a → Σ-ap-≃ (λ x → Σ-path e⁻¹)) ⟩
      Σ[ a ∶ A ] Σ[ x ∶ X a ] Σ[ p ∶ f a ＝ b ] (Idᶠ Y p (g a x) y)
        ≃⟨ Σ-ap-≃ (λ a → Σ-comm) ⟩
      Σ[ a ∶ A ] Σ[ p ∶ f a ＝ b ] Σ[ x ∶ X a ] (Idᶠ Y p (g a x) y)
        ≃∎

  fibre-map-Σ
    : (b : B)
      (y : Y b)
    → fibre (map-Σ f g) (b , y)
    ≃ Σ[ af ∶ fibre f b ]
        fibre (λ x → coe (ap Y (af .snd)) (g (af .fst) x)) y
  fibre-map-Σ b y
    = fibre (map-Σ f g) (b , y)
        ≃⟨ fibre-map-Σ' b y ⟩
      Σ[ a ∶ A ] Σ[ p ∶ f a ＝ b ] Σ[ x ∶ X a ] (Idᶠ Y p (g a x) y)
        ≃⟨ Σ-assoc e⁻¹ ⟩
      Σ[ (a , p) ∶ fibre f b ] Σ[ x ∶ X a ] Idᶠ Y p (g a x) y
        ≃∎

fibre-total-map
  : {𝓤 𝓥 𝓦 : Level}
    {A : Type 𝓤} {B : A → Type 𝓥} {B' : A → Type 𝓦}
    {f : ∀ a → B a → B' a}
    {a : A} {b : B' a}
  → fibre (total-map f) (a , b) ≃ fibre (f a) b
fibre-total-map {A = A} {B} {B'} {f = f} {a} {b}
  = fibre (total-map f) (a , b)
      ≃⟨ fibre-map-Σ' id f a b ⟩
    Σ[ a' ∶ A ] Σ[ p ∶ a' ＝ a ] Σ[ b' ∶ B a' ] Idᶠ B' p (f a' b') b
      ≃⟨ Σ-＝singl ⟩
    fibre (f a) b
      ≃∎

fibre-total-map-fst
  : {𝓤 𝓥 𝓦 : Level}
    {A : Type 𝓤}
    {A' : Type 𝓥}
    {B : A → Type 𝓦}
    (f : A' → A)
    (a : A)
    (b : B a)
  → fibre (total-map-fst f {B}) (a , b) ≃ fibre f a
fibre-total-map-fst {A = A} {A'} {B} f a b
  = fibre (total-map-fst f {B}) (a , b)
      ≃⟨ fibre-map-Σ f (λ _ → id) a b ⟩
    Σ[ (a' , p) ∶ fibre f a ] (fibre (coe (ap B p)) b)
      ≃⟨ Σ-singleton (λ (a' , p) → has-singleton-fibres←is-equiv (coe-is-equiv (ap B p)) b) ⟩
    fibre f a
      ≃∎

module _
  {𝓤1 𝓤2 𝓤3 𝓤4}
  {A : Type 𝓤1}
  {B : Type 𝓤2}
  (f : A → B)
  {Y : B → Type 𝓤4}
  where

  fibre-map-Σ-over-at
    : {X : B → Type 𝓤3}
      (g : (b : B) → X b → Y b)
      (b : B)
      (y : Y b)
      (af@(a , p) : fibre f b)
    → fibre (coe (ap Y p) ∘ g (f a)) y
    ≃ fibre (g b) y
  fibre-map-Σ-over-at g b y (_ , refl) = id≃

  fibre-map-Σ-over
    : {X : B → Type 𝓤3}
      (g : (b : B) → X b → Y b)
      (b : B) (y : Y b)
    → fibre (map-Σ f (g ∘ f)) (b , y)
    ≃ (fibre f b × fibre (g b) y)
  fibre-map-Σ-over g b y
    = fibre (map-Σ f (g ∘ f)) (b , y)
        ≃⟨ fibre-map-Σ f (g ∘ f) b y ⟩
      Σ[ (a , p) ∶ fibre f b ] fibre (coe (ap Y p) ∘ g (f a)) y
        ≃⟨ Σ-ap-≃ (fibre-map-Σ-over-at g b y) ⟩
      (fibre f b × fibre (g b) y)
        ≃∎

  fibre-map-Σ-over-left
    : {X : B → Type 𝓤3}
      (g : (b : B) → X b → Y b)
      (b : B) (y : Y b)
      (a : A) (x : X (f a))
      (p : (f a , g (f a) x) ＝ (b , y))
    → _≃_.bwd fibre-total-map (snd (_≃_.fwd (fibre-map-Σ-over g b y) ((a , x) , p)))
    ＝ ((f a , x) , p)
  fibre-map-Σ-over-left g b y a x refl = refl

}
% ```
}

\subtree[stt-0028]{
\taxon{Corollary}

% ```agda
\agda{
is-fibrewise-equiv←is-total-equiv
  : ∀ {𝓤 𝓥 𝓦} {A : Type 𝓤} {B : A → Type 𝓥}
      {B' : A → Type 𝓦} {f : ∀ a → B a → B' a}
    → is-equiv (total-map f) → is-fibrewise-equiv f
is-fibrewise-equiv←is-total-equiv {f = f} teq a
  = is-equiv←has-singleton-fibres λ
      b → is-single←equiv-to-single
            fibre-total-map
            (has-singleton-fibres←is-equiv teq (a , b))

fibrewise⇔total-is-equiv
  : ∀ {𝓤 𝓥 𝓦} {A : Type 𝓤} {B : A → Type 𝓥}
      {B' : A → Type 𝓦} {f : ∀ a → B a → B' a}
    → is-equiv (total-map f) ⇔ is-fibrewise-equiv f
fibrewise⇔total-is-equiv
  = ( is-fibrewise-equiv←is-total-equiv
    , is-total-equiv←is-fibrewise-equiv)

map-Σ-is-equiv
  : ∀ {𝓤 𝓥 𝓦 𝓜} {A : Type 𝓤} {B : Type 𝓥}
      {X : A → Type 𝓦} {Y : B → Type 𝓜}
      {f : A → B} {g : ∀ a → X a → Y (f a)}
    → is-equiv f
    → is-fibrewise-equiv g
    → is-equiv (map-Σ {Y = Y} f g)
map-Σ-is-equiv {f = f} {g} fe ge
  = is-equiv-∘
      {f = total-map-fst f} {total-map g}
      (total-is-equiv←fst-is-equiv fe)
      (is-total-equiv←is-fibrewise-equiv ge)
}
% ```
}

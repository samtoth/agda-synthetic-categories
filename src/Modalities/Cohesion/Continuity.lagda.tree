\subtree[stt-00J6]{
\title{Detecting continuity}

\p{We say that a crisp family of types #{\{G_i\}_{i:I}}
(for #{I} #{\flat}-discrete and inhabited) detects continuity when for all
crisp maps #{f : A \to B}, #{f} is a #{\sharp}-codiscrete map iff
#{\varepsilon_{G_i} \perp_\flat f} for all #{i :^\flat I}.}

%```agda
\agda{
large-detects-continuity
  : έΙΑ {@έβφ ╬▒ ╬▓ : Level έΗΤ Level} (@έβφ I : έΙΑ ΏζΥν έΗΤ Type (╬▒ ΏζΥν))
      (@έβφ G : έΙΑ {ΏζΥν} έΗΤ I ΏζΥν έΗΤ Type (╬▓ ΏζΥν)) έΗΤ Type╧Κ
large-detects-continuity I G
  = έΙΑ {@έβφ ΏζΥν ΏζΥξ} (@έβφ af : Arrow ΏζΥν ΏζΥξ)
      (let @έβφ f = Arrow.f af)
    έΗΤ (έΙΑ {@έβφ ΏζΥε} {@έβφ i : I ΏζΥε} έΗΤ are-έβφ-orthogonal (╬╡έβφ {A = G i}) f)
    έΗΤ is-έβψ-codiscrete-map f

detects-continuity
  : έΙΑ {@έβφ ΏζΥα ΏζΥν} {@έβφ I : Type ΏζΥα} (@έβφ G : I έΗΤ Type ΏζΥν) έΗΤ Type╧Κ
detects-continuity G
  = έΙΑ {@έβφ ΏζΥν ΏζΥξ} (@έβφ af : Arrow ΏζΥν ΏζΥξ)
      (let @έβφ f = Arrow.f af)
    έΗΤ (έΙΑ {@έβφ i} έΗΤ are-έβφ-orthogonal (╬╡έβφ {A = G i}) f)
    έΗΤ is-έβψ-codiscrete-map f
}
%```

\p{\ref{stt-00J3} now says exactly that the large family of all types
always detects continuity.}
}

\subtree[stt-00J5]{
\title{Detecting sharp codiscrete types}
\taxon{Lemma}
\citet{3.1.5}{MR2023}

\p{A family that detects continuity can give us a useful criteria for checking
when crisp types are sharp codiscrete.}

\p{Fixing a family #{G_i} which detects continuity, a crisp type #{X} is
#{\sharp}-codiscrete if and only if the induced map
#{\modflat{G_i \to X} \to \modflat{\modflat{G_i} \to X}} is an equivalence.}

%```agda
\agda{
module _
         {@έβφ ╬▒ ╬▓ : Level έΗΤ Level}
         {@έβφ I : έΙΑ ΏζΥν έΗΤ Type (╬▒ ΏζΥν)}
         (@έβφ G : έΙΑ {ΏζΥν} έΗΤ I ΏζΥν έΗΤ Type (╬▓ ΏζΥν))
         (@έβφ det : large-detects-continuity I G)
         where
  detects-continuous-types
    : έΙΑ {@έβφ ΏζΥν} {@έβφ X : Type ΏζΥν}
      έΗΤ (έΙΑ {@έβφ ΏζΥν} {@έβφ i : I ΏζΥν} έΗΤ is-έβφ-orthogonal-type (╬╡έβφ: G i) X)
      έΗΤ is-έβψ-codiscrete X
  detects-continuous-types P
    = is-modalέΗΡis-modal-! έβψ-SubU
        (det (mk-arrow !)
        (are-έβφ-orthogonal-!έΗΡis-orthogonal-type P))
}
%```
}

\subtree[stt-00J7]{
\title{Separating families}
\taxon{Definition}

\p{We say that a (possible large) family #{G_i} of crisp types \em{separates} if
for all crisp maps #{f :^{\flat} A \to B}, if #{f} is a #{\flat} equivalence,
and if each induced map #{\modflat{G_i \to X} \to \modflat{G_i \to Y}} is an
equivalence then #{f} itself is an equivalence.}

%```agda
\agda{
family-separates : έΙΑ {@έβφ ΏζΥα ΏζΥν} {@έβφ I : Type ΏζΥα} (@έβφ G : I έΗΤ Type ΏζΥν) έΗΤ Type╧Κ
family-separates G = έΙΑ {@έβφ ΏζΥν ΏζΥξ} (@έβφ fa : Arrow ΏζΥν ΏζΥξ) (let @έβφ f = Arrow.f fa)
                     έΗΤ @έβφ is-equiv (έβφ-map f)
                     έΗΤ ((έΙΑ {@έβφ i} έΗΤ is-equiv (έβφ-map (postcomp (G i) f))))
                     έΗΤ is-equiv f

large-family-separates
  : έΙΑ {@έβφ ╬▒ ╬▓ : Level έΗΤ Level} (@έβφ I : έΙΑ ΏζΥν έΗΤ Type (╬▒ ΏζΥν))
    έΗΤ (@έβφ G : έΙΑ {ΏζΥν} έΗΤ I ΏζΥν έΗΤ Type (╬▓ ΏζΥν)) έΗΤ Type╧Κ
large-family-separates I G
  = έΙΑ {@έβφ ΏζΥν ΏζΥξ} (@έβφ fa : Arrow ΏζΥν ΏζΥξ) (let @έβφ f = Arrow.f fa)
    έΗΤ @έβφ is-equiv (έβφ-map f)
    έΗΤ ((έΙΑ {@έβφ ΏζΥν} {@έβφ i : I ΏζΥν} έΗΤ is-equiv (έβφ-map (postcomp (G i) f))))
    έΗΤ is-equiv f


Types-separate
  : έΙΑ {@έβφ ΏζΥν ΏζΥξ} {@έβφ A : Type ΏζΥν} {@έβφ B : Type ΏζΥξ} (@έβφ f : A έΗΤ B) έΗΤ Type╧Κ
Types-separate f
  = @έβφ (έΙΑ {@έβφ ΏζΥν }{@έβφ ╬Υ : Type ΏζΥν} έΗΤ  is-equiv (έβφ-map (postcomp ╬Υ f)))
    έΗΤ is-equiv f
}
%```
}


\subtree[stt-00J8]{
\title{Families that detect continuity also separate}
\taxon{Theorem}

\p{If #{G_i} [detects continuity](stt-00J6), then it also [separates](stt-00J7).}

\proof{
\citet{3.1.6}{MR2023}

\p{Because #{f} is a #{\flat}-equivalence, it is also a #{\sharp}-equivalence,
and by the [lexness](stt-00JU) of sharp, it follows that it is #{\sharp}-connected. It
thus suffices to show that #{f} is #{\sharp}-codiscrete. To this end we make use
our assumption that #{G_i} detects continuity.}

\p{Consider the following square:}

\quiver{
\begin{tikzcd}
	{\flat(X^{G_i})} && {\flat(X^{\flat{G_i}})} && {\flat(\sharp X^{G_i})} \\
	\\
	{\flat(Y^{G_i})} && {\flat(Y^{\flat{G_i}})} && {\flat(\sharp Y^{G_i})}
	\arrow[from=1-1, to=1-3]
	\arrow[from=1-1, to=3-1]
	\arrow[from=1-3, to=1-5]
	\arrow[from=1-3, to=3-3]
	\arrow[from=1-5, to=3-5]
	\arrow[from=3-1, to=3-3]
	\arrow[from=3-3, to=3-5]
\end{tikzcd}
}

\p{We hope to show the left square is a pullback (and thus #{\varepsilon_{G_i}
\perp_{\flat} f}).  The right-most square is an equivalence of arrows by the #{\flat
\dashv \sharp} adjunction, and because the right-most map is an equivalence,
so is the middle map. Notice that the leftmost vertical map is an
equivalence by assumption, and any square with two opposing faces being
equivalences is cartesian.}
}

%```agda
\agda{
large-family-separatesέΗΡdetects-continuity
  : έΙΑ {@έβφ ╬▒ ╬▓ : Level έΗΤ Level} {@έβφ I : έΙΑ ΏζΥν έΗΤ Type (╬▒ ΏζΥν)}
    έΗΤ (@έβφ G : έΙΑ {ΏζΥν} έΗΤ I ΏζΥν έΗΤ Type (╬▓ ΏζΥν))
    έΗΤ large-detects-continuity I G
    έΗΤ large-family-separates I G
large-family-separatesέΗΡdetects-continuity {I = I} G gc f fέβφeq fsep
  = is-equivέΗΡis-modalέΗΡis-connected έβψ-gRSubU
      f-is-έβψ-codisc
      (is-έβψ-connectedέΗΡis-έβψ-equiv (is-έβψ-equivέΗΡis-έβφ-equiv fέβφeq)) where
  module _  {@έβφ ΏζΥν} {@έβφ i : I ΏζΥν} where
    lsquare : Arrow-map (έβφ-map (postcomp (G i) (Arrow.f f)))
                        (έβφ-map (postcomp έθρέβφ| G i έθσ (Arrow.f f)))
    lsquare = έβφSquare (power-hom (╬╡έβφ {A = G i}) (Arrow.f f))

    rsquare : Arrow-map (έβφ-map (postcomp έθρέβφ| G i έθσ (Arrow.f f)))
                        (έβφ-map (postcomp (G i) (έβψ-map (Arrow.f f))))
    rsquare .Arrow-╬ι.top = global-transpose
    rsquare .Arrow-╬ι.bot = global-transpose
    rsquare .Arrow-╬ι.comm (modέβφ f) = refl

    rsquare-is-equiv : is-Arrow-equiv rsquare
    rsquare-is-equiv .fst = global-transpose-is-equiv
    rsquare-is-equiv .snd = global-transpose-is-equiv

    lemma : is-equiv (έβφ-map (postcomp έθρέβφ| G i έθσ (Arrow.f f)))
    lemma = is-equivέΗΡArrow-equivέΒ╗┬╣ {F = rsquare} rsquare-is-equiv
                                   (έβφ-map-is-equiv
                                     (postcomp-equiv
                                       {f = έβψ-map (f .Arrow.f)}
                                       (is-έβψ-equivέΗΡis-έβφ-equiv fέβφeq)))

    lsquare-cart : is-cartesian lsquare
    lsquare-cart = is-cartesianέΗΡdom+cod-is-equiv lsquare fsep lemma

  f-is-έβψ-codisc : is-έβψ-codiscrete-map (Arrow.f f)
  f-is-έβψ-codisc = gc f lsquare-cart


family-separatesέΗΡdetects-continuity
  : έΙΑ {@έβφ ΏζΥα ΏζΥν : Level} {@έβφ I : Type ΏζΥα}
    έΗΤ (@έβφ G : I έΗΤ Type ΏζΥν)
    έΗΤ detects-continuity G
    έΗΤ family-separates G
family-separatesέΗΡdetects-continuity {ΏζΥα} {I = I} G Gc fa eq eq'
  = large-family-separatesέΗΡdetects-continuity
      {I = ╬╗ _ έΗΤ I}
      G
      (╬╗ af x b έΗΤ Gc af (x {ΏζΥα}) b)
      fa
      eq
      eq'
}
%```
}

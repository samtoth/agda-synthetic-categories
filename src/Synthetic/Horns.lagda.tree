\subtree[stt-00AD]{
\taxon{Definition}
\title{The inner 2 horn}

\p{We define the type #{\Lambda^2_1} by glueing a pair of intervals end to
  end. This type comes with a canonical map into the 2-simplex.}

\quiver{
\begin{tikzcd}[cramped, sep=small]
	1 && {\Delta^1} \\
	\\
	{\Delta^1} && {\Lambda^2_1} \\
	&&& {\Delta^2}
	\arrow["1", from=1-1, to=1-3]
	\arrow["0"', from=1-1, to=3-1]
	\arrow[from=1-3, to=3-3]
	\arrow[curve={height=-6pt}, from=1-3, to=4-4]
	\arrow[from=3-1, to=3-3]
	\arrow[curve={height=6pt}, from=3-1, to=4-4]
	\arrow["\lrcorner"{anchor=center, pos=0.125, rotate=180}, draw=none, from=3-3, to=1-1]
	\arrow[dashed, from=3-3, to=4-4]
\end{tikzcd}
}


\agda{
open Subtype

Оӣ[2,1]-span : Span lzero рқ“ҳ рқ“ҳ
Оӣ[2,1]-span = wedge-span i1 i0

Оӣ[2,1] : Type рқ“ҳ
Оӣ[2,1] = Wedge i1 i0

Оӣ[2,1]-glue : О№вӮҒ {f = point i1} {g = point i0} i1 пјқ О№вӮӮ i0
Оӣ[2,1]-glue = glue tt

Оӣ[2,1]-О”ВІ-cocone : Cocone (wedge-span i1 i0) О”ВІ
Оӣ[2,1]-О”ВІ-cocone = mk-cocone (_, i0) (i1 ,_) О» _ вҶ’ О”ВІ-ext (refl , refl)

Оӣ[2,1]-incl : Оӣ[2,1] вҶ’ О”ВІ
Оӣ[2,1]-incl = cogap Оӣ[2,1]-О”ВІ-cocone

Оӣ[2,1]-left-eval : Оӣ[2,1] вҶ’ О”В№
Оӣ[2,1]-left-eval x = Poly.О”ВІ.t (Оӣ[2,1]-incl x)

Оӣ[2,1]-right-eval : Оӣ[2,1] вҶ’ О”В№
Оӣ[2,1]-right-eval x = Poly.О”ВІ.s (Оӣ[2,1]-incl x)

[2,1]-hom : вҲҖ {рқ“Ө} (C : Type рқ“Ө) вҶ’ Type (рқ“Ө вҠ” рқ“ҳ)
[2,1]-hom C = ОЈ[ f вҲ¶ (О”В№ вҶ’ C) ] ОЈ[ g вҲ¶ (О”В№ вҶ’ C)] (f i1 пјқ g i0)

module _
  {рқ“Ө} {C : Type рқ“Ө} {x y z : C} (f : Hom C y z) (g : Hom C x y)
  where


  horn-cocone : Cocone Оӣ[2,1]-span C
  horn-cocone
    = wedge-cocone (g .HomбөҲ.hom) (f .HomбөҲ.hom) (g .HomбөҲ.hom1 вҲҷ sym (f .HomбөҲ.hom0))

  make-horn : Оӣ[2,1] вҶ’ C
  make-horn = pushout-rec horn-cocone

  horn-glue : ap make-horn Оӣ[2,1]-glue пјқ g .HomбөҲ.hom1 вҲҷ sym (f .HomбөҲ.hom0)
  horn-glue = pushout-rec-apОІ {c = horn-cocone} tt

horn-const
    : вҲҖ {рқ“Ө} {A : Type рқ“Ө} (a : A) вҶ’ (О» _ вҶ’ a) ~ make-horn (idH a) (idH a)
horn-const a
  = pushout-rec-unique _ (О» _ вҶ’ a) ~refl ~refl
      (О» _ вҶ’ вҲҷ-reflr _ вҲҷ ap-const Оӣ[2,1]-glue)

ОҙвӮҖВІ : О”В№ вҶ’ О”ВІ
ОҙвӮҖВІ i = (i1 , i)

ОҙвӮҒВІ : О”В№ вҶ’ О”ВІ
ОҙвӮҒВІ i = (i , i)

ОҙвӮӮВІ : О”В№ вҶ’ О”ВІ
ОҙвӮӮВІ i = (i , i0)

О”ВІ-diagonal : О”В№ вҶ’ О”ВІ
О”ВІ-diagonal = ОҙвӮҒВІ

О”ВІ-diagonal-is-embedding : is-embedding О”ВІ-diagonal
О”ВІ-diagonal-is-embedding
  = is-equivвҶҗinverse (carrier-is-set _ _) (О”ВІ-is-set _ _) (ap Poly.О”ВІ.s)
}
}

\subtree[stt-00B8]{
\taxon{Theorem}

\p{The inclusion into the 2 simplex is an embedding and identifies #{\Lambda^2_1}
with the subset of #{\Delta^2} where #{i = 1} or #{j = 0}.}

\proof{
We show that the fibres of the inclusion are equivalent to the join of the
two propositions. This goes via the [flattening lemma for pushouts](stt-008D).
}

\agda{
Оӣ[2,1]Sub : Subtype О”ВІ рқ“ҳ
Оӣ[2,1]Sub .family (i , j) = (i0 пјқ j) * (i1 пјқ i)
Оӣ[2,1]Sub .family-is-subtype (i , j)
  = *-is-prop (carrier-is-set _ _) (carrier-is-set _ _)

Оӣ[2,1]-as-subtype : вҲҖ a вҶ’ fibre Оӣ[2,1]-incl a вүғ a вҲҲ Оӣ[2,1]Sub
Оӣ[2,1]-as-subtype s =
  fibre Оӣ[2,1]-incl s вүғвҹЁ cogap-fibre _ s вҹ©
  Pushout (total-fibre-span .left) (total-fibre-span .right)
    вүғвҹЁ coeвүғ (sym (ap (О» x вҶ’ Pushout (left x) (right x))
                     (ext! (span-map , span-map-is-equiv)))) вҹ©
  Pushout (intended-span .left) (intended-span .right)
    вүғвҹЁвҹ©
  (s вҲҲ Оӣ[2,1]Sub) вүғвҲҺ where
  open Span

  total-fibre-span : Span рқ“ҳ рқ“ҳ рқ“ҳ
  total-fibre-span = total-span (point i1) (point i0)
                                (Fibre-family Оӣ[2,1]-О”ВІ-cocone s)


  intended-span : Span рқ“ҳ рқ“ҳ рқ“ҳ
  intended-span = mk-span ((i0 пјқ s .Poly.О”ВІ.t) Г— (i1 пјқ s .Poly.О”ВІ.s)) fst snd

  span-map : Span-map intended-span total-fibre-span
  span-map .Span-map.hвӮҒ p = (s .Poly.О”ВІ.s , О”ВІ-ext (refl , p))
  span-map .Span-map.hвӮӮ (p , q) = (tt , О”ВІ-ext (q , p))
  span-map .Span-map.hвӮғ q = (s .Poly.О”ВІ.t , О”ВІ-ext (q , refl))
  span-map .Span-map.H (p , q) = ОЈ-pathвҶ’ (sym q , О”ВІ-is-set _ _ _ _)
  span-map .Span-map.K (p , q) = ОЈ-pathвҶ’ (sym p , О”ВІ-is-set _ _ _ _)


  opaque
    h1-eq : quasi-inv (Span-map.hвӮҒ span-map)
    h1-eq .fst (x , p) = ap Poly.О”ВІ.t p
    h1-eq .snd .fst p = carrier-is-set i0 _ _ _
    h1-eq .snd .snd (p , q) = ОЈ-pathвҶ’ (ap Poly.О”ВІ.s (sym q)
                                      , О”ВІ-is-set _ _ _ _)
    h2-eq : quasi-inv (Span-map.hвӮӮ span-map)
    h2-eq .fst (_ , p) = (ap Poly.О”ВІ.t p , ap Poly.О”ВІ.s p)
    h2-eq .snd .fst (p , q) = Г—-is-prop (carrier-is-set _ _) (carrier-is-set _ _)
                                        _ _
    h2-eq .snd .snd (_ , p) = ОЈ-pathвҶ’ (refl , О”ВІ-is-set _ _ _ _)

    h3-eq : quasi-inv (Span-map.hвӮғ span-map)
    h3-eq .fst x = ap Poly.О”ВІ.s (snd x)
    h3-eq .snd .fst p = carrier-is-set _ _ _ _
    h3-eq .snd .snd (x , p) = ОЈ-pathвҶ’ (sym (ap Poly.О”ВІ.t p)
                                      , О”ВІ-is-set _ _ _ _)

  span-map-is-equiv : is-Span-equiv span-map
  span-map-is-equiv .fst = is-equivвҶҗqinv h1-eq
  span-map-is-equiv .snd .fst = is-equivвҶҗqinv h2-eq
  span-map-is-equiv .snd .snd = is-equivвҶҗqinv h3-eq


Оӣ[2,1]-is-prop-map : is-prop-map Оӣ[2,1]-incl
Оӣ[2,1]-is-prop-map x = is-propвҶҗequiv-to-prop (Оӣ[2,1]-as-subtype x eвҒ»В№)
                                             (вҲҲ-is-prop Оӣ[2,1]Sub x)

Оӣ[2,1]вүғSub : Оӣ[2,1] вүғ ОЈМғ Оӣ[2,1]Sub
Оӣ[2,1]вүғSub
  = Оӣ[2,1]                            вүғвҹЁ totalвүғtotal-fibre Оӣ[2,1]-incl eвҒ»В№ вҹ©
    total-fibre Оӣ[2,1]-incl           вүғвҹЁвҹ©
    (ОЈ[ a вҲ¶ О”ВІ ] fibre Оӣ[2,1]-incl a) вүғвҹЁ ОЈ-snd-вүғ Оӣ[2,1]-as-subtype вҹ©
    (ОЈ[ a вҲ¶ О”ВІ ] (a вҲҲ Оӣ[2,1]Sub))     вүғвҹЁвҹ©
    ОЈМғ Оӣ[2,1]Sub                       вүғвҲҺ

Оӣ[2,1]-is-0-truncated : is-truncated 0 Оӣ[2,1]
Оӣ[2,1]-is-0-truncated
  = is-truncatedвҶҗequiv (Оӣ[2,1]вүғSub eвҒ»В№)
      (ОЈ-is-truncated О”ВІ-is-0-truncated
        О» a вҶ’ suc-is-truncated -1
                (is-truncatedвҶҗis-prop (вҲҲ-is-prop Оӣ[2,1]Sub a)))

Оӣ[2,1]-is-set : is-set Оӣ[2,1]
Оӣ[2,1]-is-set = is-setвҶҗis-truncated Оӣ[2,1]-is-0-truncated
}
}

\subtree[stt-00C9]{
\taxon{Lemma}

\p{We include a useful alternative dependent universal property for inner horns.}

\agda{
Оӣ[2,1]-UP
  : вҲҖ {рқ“Ө} (B : Оӣ[2,1] вҶ’ Type рқ“Ө)
    вҶ’ О  Оӣ[2,1] B
    вүғ ОЈ[ f вҲ¶ ((i : О”В№) вҶ’ B (О№вӮҒ i))]
        ОЈ[ z вҲ¶ B (О№вӮӮ i1)]
         HomбөҲ (B вҲҳ О№вӮӮ) (tr B Оӣ[2,1]-glue (f i1)) z
Оӣ[2,1]-UP B = mkвүғ (map2 ._вүғ_.fwd вҲҳ coconeбөҲ-map span pushout {Q = B})
              (is-equiv-вҲҳ (_вүғ_.fwd-is-equiv map2) Pushout-has-upбөҲ-pushout) where
  span : Span lzero рқ“ҳ рқ“ҳ
  span = mk-span _ (point i1) (point i0)

  by-inserting-singleton
    : (ОЈ[ f вҲ¶ ((i : О”В№) вҶ’ B (О№вӮҒ i))]
          ОЈ[ g вҲ¶ ((r : О”В№) вҶ’ B (О№вӮӮ r)) ]
              (g i0 пјқ tr B Оӣ[2,1]-glue (f i1)))
    вүғ (ОЈ[ f вҲ¶ ((i : О”В№) вҶ’ B (О№вӮҒ i))]
           ОЈ[ z вҲ¶ B (О№вӮӮ i1)] ОЈ[ h вҲ¶ ((r : О”В№) вҶ’ B (О№вӮӮ r)) ]
              ОЈ[ h0 вҲ¶ h i0 пјқ tr B Оӣ[2,1]-glue (f i1) ]
               (h i1 пјқ z))
  by-inserting-singleton = equivвҶҗqequiv qeqv where
    qeqv : _ вүҠ _
    qeqv ._вүҠ_.fwd (f , g , h) = (f , g i1 , g , h , refl)
    qeqv ._вүҠ_.fwd-qinv .fst (f , _ , g , h , refl) = (f , g , h)
    qeqv ._вүҠ_.fwd-qinv .snd .fst = ~refl
    qeqv ._вүҠ_.fwd-qinv .snd .snd (f , _ , g , h , refl) = refl

  map2 : CoconeбөҲ span pushout B
       вүғ ОЈ[ f вҲ¶ ((i : О”В№) вҶ’ B (О№вӮҒ i))]
           ОЈ[ z вҲ¶ B (О№вӮӮ i1)]
            HomбөҲ (B вҲҳ О№вӮӮ) (tr B Оӣ[2,1]-glue (f i1)) z

  map2
    = CoconeбөҲ span pushout B вүғвҹЁ coconeD-reprвүғ вҹ©

      (ОЈ[ f вҲ¶ ((l : О”В№) вҶ’ B (О№вӮҒ l)) ]
        ОЈ[ g вҲ¶ ((r : О”В№) вҶ’ B (О№вӮӮ r)) ]
          ((a : рқҹҷ) вҶ’ f i1 пјқ[ ap B (glue a) ] g i0))

                          вүғвҹЁ ОЈ-snd-вүғ (О» f вҶ’ ОЈ-snd-вүғ (О» g вҶ’ unit-UPвүғ вҲҷвүғ symвүғ)) вҹ©

      (ОЈ[ f вҲ¶ ((i : О”В№) вҶ’ B (О№вӮҒ i))]
          ОЈ[ g вҲ¶ ((r : О”В№) вҶ’ B (О№вӮӮ r)) ]
              (g i0 пјқ tr B Оӣ[2,1]-glue (f i1)))

                         вүғвҹЁ by-inserting-singleton вҹ©

      (ОЈ[ f вҲ¶ ((i : О”В№) вҶ’ B (О№вӮҒ i))]
           ОЈ[ z вҲ¶ B (О№вӮӮ i1)] ОЈ[ h вҲ¶ ((r : О”В№) вҶ’ B (О№вӮӮ r)) ]
              ОЈ[ h0 вҲ¶ h i0 пјқ tr B Оӣ[2,1]-glue (f i1) ]
               (h i1 пјқ z))

                          вүғвҹЁ ОЈ-snd-вүғ (О» a вҶ’ ОЈ-snd-вүғ (О» b вҶ’ HomбөҲ-reprвүғ eвҒ»В№)) вҹ©

      (ОЈ[ f вҲ¶ ((i : О”В№) вҶ’ B (О№вӮҒ i))]
           ОЈ[ z вҲ¶ B (О№вӮӮ i1)]
            HomбөҲ (B вҲҳ О№вӮӮ) (tr B Оӣ[2,1]-glue (f i1)) z)    вүғвҲҺ
}
}

\subtree[stt-00LH]{
\title{#{О”В№} is a retract of #{О”ВІ}}
\taxon{Lemma}
\author{fredrikbakke}
\date{2026-04-08}

\agda{
О”В№-retract-О”ВІ : retract О”В№ О”ВІ
О”В№-retract-О”ВІ = О”ВІ-diagonal , Poly.О”ВІ.t , ~refl
}
}

\subtree[stt-00LI]{
\title{#{О”ВІ} is a retract of #{О”В№ Г— О”В№}}
\taxon{Lemma}
\author{fredrikbakke}
\date{2026-04-08}

\agda{
О”ВІ-retract-О”В№Г—О”В№ : retract О”ВІ (О”В№ Г— О”В№)
О”ВІ-retract-О”В№Г—О”В№
  = (О» x вҶ’ (x .Poly.О”ВІ.s , x .Poly.О”ВІ.t))
  , (О» { (i , j) вҶ’ (i вҲЁ j , j) вҰғ вҲЁ-вүӨ-intror вүӨ-refl вҰ„ })
  , О» ((i , j) вҰғ p вҰ„) вҶ’ О”ВІ-ext (вҲЁ-comm вҲҷ вүӨ-max p , refl)

О”ВІ-retract-О”В№Г—О”В№' : retract О”ВІ (О”В№ Г— О”В№)
О”ВІ-retract-О”В№Г—О”В№'
  = (О» x вҶ’ (x .Poly.О”ВІ.s , x .Poly.О”ВІ.t))
  , (О» { (i , j) вҶ’ (i , i вҲ§ j) вҰғ вҲ§-вүӨ-eliml вүӨ-refl вҰ„ })
  , О» ((i , j) вҰғ p вҰ„) вҶ’ О”ВІ-ext (refl , вҲ§-comm вҲҷ p)
}
}

\subtree[stt-00LC]{
\title{The inner horn inclusion is a retract of pushout product of the endpoint inclusions of the interval}
\taxon{Lemma}
\author{samueltoth}
\date{2025-11-24}
\contributor{fredrikbakke}

\p{
We can display the inner horn inclusion #{\Lambda^2_1 \hookrightarrow \Delta^2} as a
retract of arrows of the pushout product #{\point(0) \pushprod \point(1)}.

\quiver{
\begin{tikzcd}
	{\Lambda^2_1} && {\Lambda^2_1} && {\Lambda^2_1} \\
	\\
	{\Delta^2} && {\square^2} && {\Delta^2}
	\arrow["\id", from=1-1, to=1-3]
	\arrow[hook, from=1-1, to=3-1]
	\arrow["\id", from=1-3, to=1-5]
	\arrow[hook, from=1-3, to=3-3]
	\arrow[hook, from=1-5, to=3-5]
	\arrow["{(x,y)\mapsto(x,y)}"', from=3-1, to=3-3]
	\arrow["{(x,y)\mapsto(x,x\land y)}"', from=3-3, to=3-5]
\end{tikzcd}
}
}

\agda{
Оӣ[2,1]вҶӘв–Ў-section : Arrow-map Оӣ[2,1]-incl (pushout-product (point i1) (point i0))
Оӣ[2,1]вҶӘв–Ў-section .Arrow-map.top = PushoutвӮҒ (mk-span-map (_, _) _ (_ ,_) ~refl ~refl)
Оӣ[2,1]вҶӘв–Ў-section .Arrow-map.bot (x , y) = (x , y)
Оӣ[2,1]вҶӘв–Ў-section .Arrow-map.comm
  = pushout-ind _
      (mk-coconeбөҲ ~refl ~refl О» _
      вҶ’ в–Ў-is-set carrier-is-set _ _ _ _)

Оӣ[2,1]вҶӘв–Ў-ret : retraction-arrow-map Оӣ[2,1]вҶӘв–Ў-section
Оӣ[2,1]вҶӘв–Ў-ret .fst .Arrow-map.top
  = PushoutвӮҒ (mk-span-map fst _ snd ~refl ~refl)
Оӣ[2,1]вҶӘв–Ў-ret .fst .Arrow-map.bot = О”ВІ-retract-О”В№Г—О”В№' .snd .fst
Оӣ[2,1]вҶӘв–Ў-ret .fst .Arrow-map.comm
  = pushout-ind _
      (mk-coconeбөҲ
        (О» l вҶ’ О”ВІ-ext (refl , вҲ§-comm вҲҷ 0-init))
        (О» l вҶ’ О”ВІ-ext (refl , вҲ§-comm вҲҷ 1-top))
        (О» _ вҶ’ О”ВІ-is-set _ _ _ _))
Оӣ[2,1]вҶӘв–Ў-ret .snd .fst
  = pushout-ind _ (mk-coconeбөҲ ~refl ~refl (О» _ вҶ’ Оӣ[2,1]-is-set _ _ _ _))
Оӣ[2,1]вҶӘв–Ў-ret .snd .snd .fst   = О”ВІ-retract-О”В№Г—О”В№' .snd .snd
Оӣ[2,1]вҶӘв–Ў-ret .snd .snd .snd x = О”ВІ-is-set _ _ _ _
}
}

\agda{
Оӣ[2,1]-map-repr
  : {рқ“Ө : Level} {A : Type рқ“Ө}
  вҶ’ (Оӣ[2,1] вҶ’ A)
  вүғ ОЈ[ f вҲ¶ (О”В№ вҶ’ A) ] ОЈ[ g вҲ¶ (О”В№ вҶ’ A) ] (f i1 пјқ g i0)
Оӣ[2,1]-map-repr {A = A} = mkвүғ fwd (is-equivвҶҗqinv qinv) where
  fwd : (Оӣ[2,1] вҶ’ A) вҶ’ ОЈ[ f вҲ¶ (О”В№ вҶ’ A) ] ОЈ[ g вҲ¶ (О”В№ вҶ’ A) ] (f i1 пјқ g i0)
  fwd h = h вҲҳ О№вӮҒ , h вҲҳ О№вӮӮ , ap h Оӣ[2,1]-glue

  qinv : quasi-inv fwd
  qinv .fst (f , g , p)
    = pushout-rec (mk-cocone f g (О» _ вҶ’ p))
  qinv .snd .fst h
    = sym (funextвҶ’ (pushout-rec-unique _ h ~refl ~refl (О» _ вҶ’ вҲҷ-reflr _)))
  qinv .snd .snd (f , g , p)
    = ОЈ-pathвҶ’ (refl , ОЈ-pathвҶ’ (refl , pushout-rec-apОІ tt))
}

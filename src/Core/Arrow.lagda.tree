\subtree[stt-0038]{
\taxon{Definition}
\title{Walking morphisms in #{\mathcal{S}\omega}}

% ```agda
\agda{
record Arrow : Type╧Й where
  constructor mk-arr
  no-eta-equality
  field
    {ЁЭУд ЁЭУе} : Level
    {dom} : Type ЁЭУд
    {cod} : Type ЁЭУе
    f : dom тЖТ cod
}
% ```

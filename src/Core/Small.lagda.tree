\subtree[fre-2127]{
\date{2026-03-13}
\author{fredrikbakke}
\taxon{Definition}
\title{Smallness at a universe level}

\p{
A type #{A : \UU} is \em{small at level} #{\UV} if it is [equivalent](stt-001U) to
some type in #{\UV}.
}

% ```agda
\agda{
is-small
  : (рЭУ• : Level) {рЭУ§ : Level}
  вЖТ Type рЭУ§
  вЖТ Type (lsuc рЭУ• вКФ рЭУ§)
is-small рЭУ• A = ќ£[ B вИґ Type рЭУ• ] (A вЙГ B)
}
% ```
}

\subtree[fre-2132]{
\date{2026-03-13}
\author{fredrikbakke}
\taxon{Definition}
\title{Local smallness}

\p{
We say that a type is \em{#{n}-locally small} at level #{\UV} if its #{n}th
identity types are [small](fre-2127) at that level. In particular, a type is
\em{locally small} if its identity types are small.
}

% ```agda
\agda{
is-n-locally-small
  : вДХ
  вЖТ (рЭУ• : Level) {рЭУ§ : Level}
  вЖТ Type рЭУ§
  вЖТ Type (lsuc рЭУ• вКФ рЭУ§)
is-n-locally-small zero рЭУ• A = is-small рЭУ• A
is-n-locally-small (suc n) рЭУ• A
  = (x y : A) вЖТ is-n-locally-small n рЭУ• (x пЉЭ y)

is-locally-small
  : (рЭУ• : Level) {рЭУ§ : Level}
  вЖТ Type рЭУ§
  вЖТ Type (lsuc рЭУ• вКФ рЭУ§)
is-locally-small = is-n-locally-small 1
}
% ```
}

\subtree[fre-2144]{
\date{2026-03-13}
\author{fredrikbakke}
\taxon{Theorem}
\title{Equality of smallness}

\p{
Equality on the type \code{is-small} is characterised by an [equivalence](stt-001U)
of carrier types such that the obvious triangle commutes. Consequently,
\code{is-small} is a [proposition](stt-0009). In fact, this is [equivalent](stt-001U)
to the [univalence axiom](Foundations.Univalence).
}

% ```agda
\agda{
open WithFunExt-global global-funext
module WUA = WithGlobalUnivalence UA

is-small-equiv
  : {рЭУ§ рЭУ• рЭУ¶ : Level} {A : Type рЭУ§}
  вЖТ is-small рЭУ• A
  вЖТ is-small рЭУ¶ A
  вЖТ Type (рЭУ§ вКФ рЭУ• вКФ рЭУ¶)
is-small-equiv (B , f) (C , g)
  = ќ£[ e вИґ B вЙГ C ] (_вЙГ_.fwd (f вИЩвЙГ e) ~ _вЙГ_.fwd g)

id-is-small-equiv
  : {рЭУ§ рЭУ• : Level} {A : Type рЭУ§}
    (S : is-small рЭУ• A)
  вЖТ is-small-equiv S S
id-is-small-equiv (_ , _)
  = idequiv , ~refl

module _
  {рЭУ§ рЭУ• : Level} {A : Type рЭУ§}
  where

  is-small-equiv-is-torsorial
    : (S : is-small рЭУ• A)
    вЖТ is-singleton (ќ£[ T вИґ is-small рЭУ• A ] is-small-equiv S T)
  is-small-equiv-is-torsorial S
    = is-singleton-structureвЖРparts
        (WUA.equiv-is-torsorial (S .fst))
        (_ , idequiv)
        (is-singleвЖРequiv-to-single
          ( ( ќ£-ap-вЙГ-fst вЙГ-rep
            вИЩвЙГ remove-singleton-structure
                  (htpy-is-torsorial global-funext
                    (_вЙГ_.fwd (S .snd вИЩвЙГ idequiv)))
                  (_вЙГ_.fwd (S .snd вИЩвЙГ idequiv) , ~refl)) eвБї¬є)
          (mk-singl
            ((S .snd вИЩвЙГ idequiv) ._вЙГ_.has-is-eqv)
            (ќї x вЖТ is-equiv-is-prop _ _)))

  small-equivвЖРId
    : {S T : is-small рЭУ• A}
    вЖТ S пЉЭ T
    вЖТ is-small-equiv S T
  small-equivвЖРId {S = S} refl = id-is-small-equiv S

  small-equivвЖРId-is-equiv
    : (S T : is-small рЭУ• A)
    вЖТ is-equiv (small-equivвЖРId {S = S} {T = T})
  small-equivвЖРId-is-equiv S
    = fundamental-Id
        (is-small-equiv S)
        (is-small-equiv-is-torsorial S)
        (ќї _ вЖТ small-equivвЖРId)

  IdвЙГis-small-equiv
    : (S T : is-small рЭУ• A)
    вЖТ (S пЉЭ T) вЙГ is-small-equiv S T
  IdвЙГis-small-equiv S T = mkвЙГ small-equivвЖРId (small-equivвЖРId-is-equiv S T)

  IdвЖРis-small-equiv
    : {S T : is-small рЭУ• A}
    вЖТ is-small-equiv S T
    вЖТ S пЉЭ T
  IdвЖРis-small-equiv {S = S} {T = T} = _вЙГ_.bwd (IdвЙГis-small-equiv S T)

  any-is-small-equiv
    : (S T : is-small рЭУ• A)
    вЖТ is-small-equiv S T
  any-is-small-equiv (_ , f) (_ , g)
    = (f eвБї¬є) вИЩвЙГ g , (_вЙГ_.fwd g вЧВ _вЙГ_.ќЈ f)

  is-small-is-prop
    : is-prop (is-small рЭУ• A)
  is-small-is-prop S T = IdвЖРis-small-equiv (any-is-small-equiv S T)

is-n-locally-small-is-prop
  : {рЭУ§ рЭУ• : Level} {n : вДХ} {A : Type рЭУ§}
  вЖТ is-prop (is-n-locally-small n рЭУ• A)
is-n-locally-small-is-prop {n = zero}
  = is-small-is-prop
is-n-locally-small-is-prop {n = suc n}
  = is-prop-ќ† ќї _ вЖТ is-prop-ќ† ќї _ вЖТ is-n-locally-small-is-prop {n = n}

is-locally-small-is-prop
  : {рЭУ§ рЭУ• : Level} {A : Type рЭУ§}
  вЖТ is-prop (is-locally-small рЭУ• A)
is-locally-small-is-prop = is-n-locally-small-is-prop {n = 1}
}
% ```
}

\subtree[fre-2128]{
\date{2026-03-13}
\author{fredrikbakke}
\taxon{Lemma}
\title{Types are small at their own level}

% ```agda
\agda{
self-is-small : {рЭУ§ : Level} {A : Type рЭУ§} вЖТ is-small рЭУ§ A
self-is-small {A = A} = (A , idequiv)
}
% ```
}

\subtree[fre-2136]{
\date{2026-03-13}
\author{fredrikbakke}
\taxon{Lemma}
\title{Smallness is preserved by equivalences}

% ```agda
\agda{
is-smallвЖРequiv
  : {рЭУ§ рЭУ• рЭУ¶ : Level} {A : Type рЭУ§} {B : Type рЭУ•}
  вЖТ A вЙГ B
  вЖТ is-small рЭУ¶ A
  вЖТ is-small рЭУ¶ B
is-smallвЖРequiv e (X , f) = X , ((e eвБї¬є) вИЩвЙГ f)

is-n-locally-smallвЖРequiv
  : {рЭУ§ рЭУ• рЭУ¶ : Level} (n : вДХ) {A : Type рЭУ§} {B : Type рЭУ•}
  вЖТ A вЙГ B
  вЖТ is-n-locally-small n рЭУ¶ A
  вЖТ is-n-locally-small n рЭУ¶ B
is-n-locally-smallвЖРequiv zero e H
  = is-smallвЖРequiv e H
is-n-locally-smallвЖРequiv (suc n) eq sep b b'
  = is-n-locally-smallвЖРequiv
      n
      (пЉЭ-equiv (eq eвБї¬є) eвБї¬є)
      (sep (bwd b) (bwd b')) where open _вЙГ_ eq

is-locally-smallвЖРequiv
  : {рЭУ§ рЭУ• рЭУ¶ : Level} {A : Type рЭУ§} {B : Type рЭУ•}
  вЖТ A вЙГ B
  вЖТ is-locally-small рЭУ¶ A
  вЖТ is-locally-small рЭУ¶ B
is-locally-smallвЖРequiv = is-n-locally-smallвЖРequiv 1
}
% ```
}

\subtree[fre-2129]{
\date{2026-03-13}
\author{fredrikbakke}
\taxon{Lemma}
\title{Universe lifts are small}

% ```agda
\agda{
ULift-is-small
  : {рЭУ§ : Level} (рЭУ• : Level) {A : Type рЭУ§}
  вЖТ is-small рЭУ§ (ULift рЭУ• A)
ULift-is-small рЭУ• {A = A}
  = (A , unliftвЙГ)
}
% ```
}

\subtree[fre-2133]{
\date{2026-03-13}
\author{fredrikbakke}
\taxon{Lemma}
\title{Small types are locally small}

% ```agda
\agda{
пЉЭ-is-small
  : {рЭУ§ рЭУ• : Level} {A : Type рЭУ§}
  вЖТ is-small рЭУ• A
  вЖТ (x y : A)
  вЖТ is-small рЭУ• (x пЉЭ y)
пЉЭ-is-small (_ , e) x y
  = ( e ._вЙГ_.fwd x пЉЭ e ._вЙГ_.fwd y , пЉЭ-equiv e )

suc-is-n-locally-small
  : {n : вДХ} {рЭУ§ рЭУ• : Level} {A : Type рЭУ§}
  вЖТ is-n-locally-small n рЭУ• A
  вЖТ is-n-locally-small (suc n) рЭУ• A
suc-is-n-locally-small {n = zero} H
  = пЉЭ-is-small H
suc-is-n-locally-small {n = suc n} H x y
  = suc-is-n-locally-small {n = n} (H x y)
}
% ```
}

\subtree[fre-2130]{
\date{2026-03-13}
\author{fredrikbakke}
\taxon{Lemma}
\title{Small types are closed under dependent sums}

% ```agda
\agda{
ќ£-is-small
  : {рЭУ§ рЭУ• рЭУ¶ рЭУЫ : Level}
    {A : Type рЭУ§}
    {B : A вЖТ Type рЭУЫ}
  вЖТ is-small рЭУ• A
  вЖТ ((a : A) вЖТ is-small рЭУ¶ (B a))
  вЖТ is-small (рЭУ• вКФ рЭУ¶) (ќ£ A B)
ќ£-is-small {B = B} (A' , e) H
  = ( ќ£[ a' вИґ A' ] fst (H (_вЙГ_.bwd e a'))
    , (ќ£-ap-вЙГ-fst-bwd e eвБї¬є)
    вИЩвЙГ ќ£-ap-вЙГ (ќї a' вЖТ snd (H (_вЙГ_.bwd e a'))) )
}
% ```
}

\subtree[fre-2131]{
\date{2026-03-13}
\author{fredrikbakke}
\taxon{Lemma}
\title{Small types are closed under dependent products}

% ```agda
\agda{
ќ†-is-small
  : {рЭУ§ рЭУ• рЭУ¶ рЭУЫ : Level}
    {A : Type рЭУ§}
    {B : A вЖТ Type рЭУЫ}
  вЖТ is-small рЭУ• A
  вЖТ ((a : A) вЖТ is-small рЭУ¶ (B a))
  вЖТ is-small (рЭУ• вКФ рЭУ¶) (ќ† A B)
ќ†-is-small {B = B} (A' , e) H
  = ( ќ† A' (ќї a' вЖТ fst (H (_вЙГ_.bwd e a')))
    , precomp-ќ†-вЙГ B (e eвБї¬є)
    вИЩвЙГ ќ†-ap-вЙГ (ќї a' вЖТ snd (H (_вЙГ_.bwd e a'))) )
}
% ```
}


\subtree[fre-2140]{
\date{2026-03-13}
\author{fredrikbakke}
\taxon{Theorem}
\title{Small types are closed under retracts}

\p{
Given a [small](fre-2127) type #{A}, then any [retract](fre-2115) of #{A} is again
small.
}

\p{
This appears as \citet{Thm 2.13}{de-jong-escardo-2023}, and is a consequence of the
[splitting construction on quasiidempotent maps](fre-2113).
}

% ```agda
\agda{
seq-splitting-type-is-small
  : {рЭУ§ рЭУ• : Level} {X : Type рЭУ§}
    (f : X вЖТ X)
  вЖТ is-small рЭУ• X
  вЖТ is-small рЭУ• (seq-splitting-type f)
seq-splitting-type-is-small {X = X} f Xsmall
  = ќ£-is-small
      (ќ†-is-small self-is-small (ќї _ вЖТ Xsmall))
      (ќї a вЖТ ќ†-is-small self-is-small
        (ќї n вЖТ пЉЭ-is-small Xsmall (a n) (f (a (suc n)))))

is-smallвЖРretract
  : {рЭУ§ рЭУ• рЭУ¶ : Level} {A : Type рЭУ§} {B : Type рЭУ•}
  вЖТ retract A B
  вЖТ is-small рЭУ¶ B
  вЖТ is-small рЭУ¶ A
is-smallвЖРretract R Bsmall
  = is-smallвЖРequiv
      (SplitRetractWithFunExt.split-retract-equiv global-funext R)
      (seq-splitting-type-is-small (fst (qidempotent-mapвЖРretract R)) Bsmall)

is-n-locally-smallвЖРretract
  : {рЭУ§ рЭУ• рЭУ¶ : Level} (n : вДХ) {A : Type рЭУ§} {B : Type рЭУ•}
  вЖТ retract A B
  вЖТ is-n-locally-small n рЭУ¶ B
  вЖТ is-n-locally-small n рЭУ¶ A
is-n-locally-smallвЖРretract zero R H
  = is-smallвЖРretract R H
is-n-locally-smallвЖРretract (suc n) R H x y
  = is-n-locally-smallвЖРretract n
      (retract-пЉЭ R)
      (H (R .fst x) (R .fst y))

is-locally-smallвЖРretract
  : {рЭУ§ рЭУ• рЭУ¶ : Level} {A : Type рЭУ§} {B : Type рЭУ•}
  вЖТ retract A B
  вЖТ is-locally-small рЭУ¶ B
  вЖТ is-locally-small рЭУ¶ A
is-locally-smallвЖРretract = is-n-locally-smallвЖРretract 1
}
% ```
}

\subtree[fre-2352]{
\date{2026-03-18}
\author{fredrikbakke}
\taxon{Theorem}
\title{The universe of retracts of a small type is small}

\p{
For any type #{A} in #{\UU}, the [universe of retracts](fre-1A1D) of #{A} in #{\UU}
is #{\UU}-[small](fre-2127).
}

\p{
This is a consequence of [retract closure of small types](fre-2140), using that the
universe of retracts [is a retract of the type of quasiidempotent maps](fre-2167).
}

% ```agda
\agda{
module _ {рЭУ§ рЭУ• : Level} {A : Type рЭУ§} where

  preidempotence-is-small
    : (f : A вЖТ A)
    вЖТ is-small рЭУ• A
    вЖТ is-small рЭУ• (preidempotence f)
  preidempotence-is-small f Asmall
    = ќ†-is-small Asmall
        (ќї a вЖТ пЉЭ-is-small Asmall (f (f a)) (f a))

  qcoh-preidempotence-is-small
    : (f : A вЖТ A)
      (I : preidempotence f)
    вЖТ is-small рЭУ• A
    вЖТ is-small рЭУ• (qcoh-preidempotence f I)
  qcoh-preidempotence-is-small f I Asmall
    = ќ†-is-small Asmall
        (ќї a вЖТ пЉЭ-is-small
          (пЉЭ-is-small Asmall (f (f (f a))) (f (f a)))
          (ap f (I a))
          (I (f a)))

  qidempotence-is-small
    : (f : A вЖТ A)
    вЖТ is-small рЭУ• A
    вЖТ is-small рЭУ• (qidempotence f)
  qidempotence-is-small f Asmall
    = ќ£-is-small
        (preidempotence-is-small f Asmall)
        (ќї I вЖТ qcoh-preidempotence-is-small f I Asmall)

  qidempotent-map-is-small
    : is-small рЭУ• A
    вЖТ is-small рЭУ• (qidempotent-map A)
  qidempotent-map-is-small Asmall
    = ќ£-is-small
        (ќ†-is-small Asmall (ќї _ вЖТ Asmall))
        (ќї f вЖТ qidempotence-is-small f Asmall)

module _ {рЭУ• : Level} {A : Type рЭУ•} where

  Retracts-is-small
    : is-small рЭУ• (Retracts рЭУ• A)
  Retracts-is-small
    = is-smallвЖРretract
        (retracts-qidempotent-map-retract)
        (qidempotent-map-is-small self-is-small)
}
% ```
}

\subtree[fre-2149]{
\date{2026-03-13}
\author{fredrikbakke}
\taxon{Definition}
\title{Small maps}

\p{
A map is \em{small} at level #{\UW} if all of its [fibres](stt-000M) are
[small](fre-2127) at that level.
}

% ```agda
\agda{
is-small-map
  : {рЭУ§ рЭУ• : Level} (рЭУ¶ : Level)
    {A : Type рЭУ§} {B : Type рЭУ•}
  вЖТ (A вЖТ B)
  вЖТ Type (lsuc рЭУ¶ вКФ рЭУ§ вКФ рЭУ•)
is-small-map рЭУ¶ {B = B} f = (b : B) вЖТ is-small рЭУ¶ (fibre f b)
}
% ```
}

\subtree[fre-2150]{
\date{2026-03-13}
\author{fredrikbakke}
\taxon{Theorem}
\title{Small maps with small codomain have small domain}

\p{
If the codomain of a [small map](fre-2149) is [small](fre-2127), then the domain is
[small](fre-2127).
}

% ```agda
\agda{
is-small-domainвЖРsmall-map
  : {рЭУ§ рЭУ• рЭУ¶ : Level}
    {A : Type рЭУ§}
    {B : Type рЭУ•}
  вЖТ {f : A вЖТ B}
  вЖТ is-small рЭУ¶ B
  вЖТ is-small-map рЭУ¶ f
  вЖТ is-small рЭУ¶ A
is-small-domainвЖРsmall-map {f = f} Bsmall fsmall
  = is-smallвЖРequiv
      (totalвЙГtotal-fibre f)
      (ќ£-is-small Bsmall fsmall)
}
% ```
}

\subtree[fre-2143]{
\date{2026-03-13}
\author{fredrikbakke}
\author{samueltoth}
\taxon{Theorem}
\title{Type theoretic replacement}

\p{
If the domain of a map is [small](fre-2127) at level #{\UW} and the codomain is
[locally small](fre-2132) at that level, then the [image](Core.Image) of the map is
[small](fre-2127).
}

\p{
This theorem makes use of the [modified join construction](stt-008G) and is due to
[[egbertrijke]] \citet{Thm 4.6}{rijke-2017}.
}

% ```agda
\agda{
record has-small-image
  {рЭУ§ рЭУ• : Level} (рЭУ¶ : Level)
  {A : Type рЭУ§} {B : Type рЭУ•}
  (f : A вЖТ B)
  : TypeѕЙ where
  field
    carrier : Type рЭУ¶
    incl : carrier вЖТ B
    has-is-image : is-image f incl

replacement
  : {рЭУ§ рЭУ• рЭУ¶ : Level}
    {A : Type рЭУ§}
    {B : Type рЭУ•}
  вЖТ (f : A вЖТ B)
  вЖТ is-small рЭУ¶ A
  вЖТ is-locally-small рЭУ¶ B
  вЖТ has-small-image рЭУ¶ f
replacement {рЭУ¶ = рЭУ¶} {B = B} f (A' , e) Bls = result
  where
  BIdS : Identity-system B рЭУ¶
  BIdS = mk-identity-system (ќї x y вЖТ fst (Bls x y)) (ќї {x} {y} вЖТ snd (Bls x y) eвБї¬є)

  module Img = Im' в¶Г BIdS в¶Д (f вИШ _вЙГ_.bwd e)

  result : has-small-image рЭУ¶ f
  result .has-small-image.carrier = Img.Im'
  result .has-small-image.incl = Img.incl
  result .has-small-image.has-is-image = is-imageвЖРequiv-domain e Img.Im-is-image

is-smallвЖРis-image
  : {рЭУ§ рЭУ• рЭУ¶ рЭУШ : Level}
    {A : Type рЭУ§} {B : Type рЭУ•}
  вЖТ (f : A вЖТ B)
  вЖТ is-small рЭУ¶ A
  вЖТ is-locally-small рЭУ¶ B
  вЖТ {I : Type рЭУШ} {i : I вЖТ B}
  вЖТ is-image f i
  вЖТ is-small рЭУ¶ I
is-smallвЖРis-image f Asmall Bls {I} {i} im
  = is-smallвЖРequiv
      (is-image-equiv f im
        (replacement f Asmall Bls .has-small-image.has-is-image)
        eвБї¬є)
      (self-is-small)

canonical-image-is-small
  : {рЭУ§ рЭУ• рЭУ¶ : Level}
    {A : Type рЭУ§} {B : Type рЭУ•}
    (f : A вЖТ B)
  вЖТ is-small рЭУ¶ A
  вЖТ is-locally-small рЭУ¶ B
  вЖТ is-small рЭУ¶ (canonical-image f)
canonical-image-is-small f Asmall Bls
  = is-smallвЖРis-image f Asmall Bls (canonical-image-is-image f)
}
% ```
}


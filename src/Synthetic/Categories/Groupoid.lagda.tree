is-left-local = is-local (خ» (_ _ : ً‌ں™) â†’ i0)

is-خ”آ¹-discreteâ†گis-left : âˆ€ {ً‌“¤} {A : Type ً‌“¤} â†’ is-left-local A â†’ is-خ”آ¹-discrete A
is-خ”آ¹-discreteâ†گis-left {_}{A} il x
  = is-equiv~âˆک (il x â—‚eqv ((خµ â–¸ point) ~âپ»آ¹)) (is-equivâپ»آ¹ (il x)) point-is-equiv where
  open is-equiv (il x)

is-leftâ†گis-خ”آ¹-discrete : âˆ€ {ً‌“¤} {A : Type ً‌“¤} â†’ is-خ”آ¹-discrete A â†’ is-left-local A
is-leftâ†گis-خ”آ¹-discrete {_} {A} gp x
  = is-equiv~âˆک (((point â—‚ خ·) ~âپ»آ¹) â–¸eqv (gp x)) point-is-equiv (is-equivâپ»آ¹ (gp x)) where
  open is-equiv (gp x)


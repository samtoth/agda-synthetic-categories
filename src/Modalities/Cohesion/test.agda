module Modalities.Cohesion.test where

open import Foundations.Prelude

-- data έθρέβψ|_έθσ {ΏζΥν} (A : Type ΏζΥν) : Type ΏζΥν where
--   modέβψ : @έβψ┬ιA έΗΤ έθρέβψ| A έθσ

-- {-# MODALOP έθρέβψ|_έθσ #-}

-- ╬╝έβψ : έΙΑ {ΏζΥν} {A : Type ΏζΥν} έΗΤ έθρέβψ| έθρέβψ| A έθσ έθσ έΗΤ έθρέβψ| A έθσ
-- ╬╝έβψ (modέβψ (modέβψ x)) = {!modέβψ ?!}



data έθρέβφ|_έθσ {@έβφ ΏζΥν} (@έβφ A : Set ΏζΥν) : Set ΏζΥν where
  modέβφ : (@έβφ a : A) έΗΤ έθρέβφ| A έθσ


-- The modality pragma means that any modality can split
-- on this type
{-# MODALOP έθρέβφ|_έθσ #-}

╬╡ : έΙΑ {@έβφ ΏζΥν} {@έβφ A : Set ΏζΥν} έΗΤ έθρέβφ| A έθσ έΗΤ A
╬╡ (modέβφ a) = a

έβφ-map : έΙΑ {@έβφ ΏζΥν ΏζΥξ} {@έβφ A : Set ΏζΥν} {@έβφ B : Set ΏζΥξ}
        έΗΤ έθρέβφ| (A έΗΤ B) έθσ έΗΤ έθρέβφ| A έθσ έΗΤ έθρέβφ| B έθσ
έβφ-map (modέβφ f) (modέβφ x) = modέβφ (f x)

data έθρέβψ|_έθσ {ΏζΥν} (@έβψ A : Set ΏζΥν) : Set ΏζΥν where
  modέβψ : (@έβψ a : A) έΗΤ έθρέβψ| A έθσ

{-# MODALOP έθρέβψ|_έθσ #-}

έβψ-map : έΙΑ {ΏζΥν ΏζΥξ} {A : Set ΏζΥν} {B : Set ΏζΥξ}
        έΗΤ έθρέβψ| (A έΗΤ B) έθσ έΗΤ έθρέβψ| A έθσ έΗΤ έθρέβψ| B έθσ
έβψ-map (modέβψ f) (modέβψ a) = modέβψ (f a)

╬╖ : έΙΑ {ΏζΥν} {A : Set ΏζΥν} έΗΤ A έΗΤ έθρέβψ| A έθσ
╬╖ a = modέβψ a

-- Will fail type check if uncommented
-- uh-oh : έΙΑ {ΏζΥν} {A : Set ΏζΥν} έΗΤ έθρέβψ| A έθσ έΗΤ A
-- uh-oh (modέβψ a) = {!a!}

crispy : έΙΑ {@έβφ ΏζΥν} {@έβφ A : Set ΏζΥν} έΗΤ @έβφ έθρέβψ| A έθσ έΗΤ A
crispy (modέβψ a) = a

╬╝ : έΙΑ {ΏζΥν} {A : Set ΏζΥν} έΗΤ @έβψ έθρέβψ| A έθσ έΗΤ έθρέβψ| A έθσ
╬╝ a = modέβψ (crispy a)

╬╝' : έΙΑ {ΏζΥν} {A : Set ΏζΥν} έΗΤ έθρέβψ| έθρέβψ| A έθσ έθσ έΗΤ έθρέβψ| A έθσ
╬╝' (modέβψ (modέβψ a)) = modέβψ a

comul : έΙΑ {ΏζΥν} {A : Set ΏζΥν} έΗΤ έθρέβψ| A έθσ έΗΤ έθρέβψ| έθρέβψ| A έθσ έθσ
comul (modέβψ a) = modέβψ (modέβψ a)

έβψ-rfl : έΙΑ {ΏζΥν} {A : Set ΏζΥν} (B : έθρέβψ| A έθσ έΗΤ Set ΏζΥν)
        έΗΤ (f : (a : A) έΗΤ έθρέβψ| B (╬╖ a) έθσ)
        έΗΤ (a : έθρέβψ| A έθσ) έΗΤ έθρέβψ| B a έθσ
έβψ-rfl B f (modέβψ a) = modέβψ (crispy (f a))

έβψ-rfl-╬╖ : έΙΑ {ΏζΥν} {A : Set ΏζΥν} {B : έθρέβψ| A έθσ έΗΤ Set ΏζΥν}
        έΗΤ (f : (a : A) έΗΤ έθρέβψ| B (╬╖ a) έθσ)
        έΗΤ (a : A) έΗΤ έβψ-rfl B f (╬╖ a) Ύ╝ζ f a
έβψ-rfl-╬╖ f a with f a
... | modέβψ b = refl

έβφ-eat-έβψ : έΙΑ {@έβφ ΏζΥν} {@έβφ A : Set ΏζΥν} έΗΤ έθρέβφ| έθρέβψ| A έθσ έθσ έΗΤ έθρέβφ| A έθσ
έβφ-eat-έβψ (modέβφ (modέβψ a)) = modέβφ a

έβφ-eat-έβψ' : έΙΑ {@έβφ ΏζΥν} {@έβφ A : Set ΏζΥν} έΗΤ έθρέβφ| A έθσ έΗΤ έθρέβφ| έθρέβψ| A έθσ έθσ
έβφ-eat-έβψ' (modέβφ a) = modέβφ (modέβψ a)

έβψ-eat-έβφ : έΙΑ {@έβφ ΏζΥν} {@έβφ A : Set ΏζΥν} έΗΤ έθρέβψ| έθρέβφ| A έθσ έθσ έΗΤ έθρέβψ| A έθσ
έβψ-eat-έβφ (modέβψ (modέβφ a)) = modέβψ a

έβψ-eat-έβφ' : έΙΑ {@έβφ ΏζΥν} {@έβφ A : Set ΏζΥν} έΗΤ έθρέβψ| A έθσ έΗΤ έθρέβψ| έθρέβφ| A έθσ έθσ
έβψ-eat-έβφ' (modέβψ a) = modέβψ (modέβφ a)

έβψέΗΡέβφ : έΙΑ {@έβφ ΏζΥν} {@έβφ A : Set ΏζΥν} έΗΤ έθρέβφ| A έθσ έΗΤ έθρέβψ| A έθσ
έβψέΗΡέβφ x = ╬╖ (╬╡ x)

-- έβφέΗΡέβψ : έΙΑ {@έβφ ΏζΥν} {@έβφ A : Set ΏζΥν} έΗΤ έθρέβψ| A έθσ έΗΤ έθρέβφ| A έθσ
-- έβφέΗΡέβψ (modέβψ a) = modέβφ {!a!}

adj : έΙΑ {@έβφ ΏζΥν ΏζΥξ} {@έβφ A : Set ΏζΥν} {B : Set ΏζΥξ}
      έΗΤ έθρέβψ| (έθρέβφ| A έθσ έΗΤ B) έθσ έΗΤ (A έΗΤ έθρέβψ| B έθσ)
adj (modέβψ f) a = modέβψ (f (modέβφ a))

adj' : έΙΑ {@έβφ ΏζΥν ΏζΥξ} {@έβφ A : Set ΏζΥν} {@έβφ B : @έβφ A έΗΤ Set ΏζΥξ}
       έΗΤ έθρέβφ| ((a : A) έΗΤ έθρέβψ| B a έθσ)έθσ έΗΤ έθρέβφ| ((@έβφ a : A) έΗΤ B a) έθσ
adj' (modέβφ f) = modέβφ (╬╗ b έΗΤ crispy (f b))

-- J-έβφ : έΙΑ {@έβφ ΏζΥν} {ΏζΥξ} {@έβφ A : Set ΏζΥν} {@έβφ a : A}
--             (M : (@έβφ b : A) έΗΤ a Ύ╝ζ b έΗΤ Set ΏζΥξ)
--             (Mrfl : M a refl)
--           έΗΤ έΙΑ {@έβφ b : A} (@έβφ p : a Ύ╝ζ b) έΗΤ M b p
-- J-έβφ M mrfl refl = mrfl

-- J-crisp : έΙΑ {@έβφ ΏζΥν} {@έβφ ΏζΥξ} {@έβφ A : Set ΏζΥν} {@έβφ a : A}
--             (@έβφ M : (@έβφ b : A) έΗΤ @έβφ a Ύ╝ζ b έΗΤ Set ΏζΥξ)
--             έΗΤ @έβφ M a refl
--             έΗΤ έΙΑ {@έβφ b : A} (@έβφ p : a Ύ╝ζ b) έΗΤ M b p
-- J-crisp M prfl = ╬╡ (adj' (modέβφ ╬╗ where p έΗΤ modέβψ (J-έβφ (╬╗ b p έΗΤ {!M b p!}) prfl p)))


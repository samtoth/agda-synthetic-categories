\date{2025-02-21}
\title{Homotopies of functions}
\taxon{Module}

\import{stt-macros}

\agda{
module Foundations.Homotopy where

open import Foundations.Functions
open import Foundations.Universes
open import Foundations.Identity
open import Foundations.IdentityReasoning
}

\subtree[stt-001M]{
\title{Homotopy}
\taxon{Definition}

\p{A homotopy between functions is a pointwise equality of functions.}

\agda{
infix 6 _~_
_~_ : ‚ąÄ {ūĚď§ ūĚď•} {A : Type ūĚď§} {B : A ‚Üí Type ūĚď•} ‚Üí (f g : (a : A) ‚Üí B a) ‚Üí Type (ūĚď§ ‚äĒ ūĚď•)
f ~ g = ‚ąÄ a ‚Üí f a ÔľĚ g a
}
}

\subtree[stt-001N]{
\taxon{Remark}

\p{Homotopies are 2-cells in the #{(\infty, 1)}-category of types and functions. Or equivalently, for every pair of types,
#{X} and #{Y}, we have a #{\infty}-groupoid #{\textrm{Map}(X,Y)} where 0-cells are functions, and 1-cells are homotopies.}

\agda{
infixr 15 _‚ąôh_
_‚ąôh_
  : ‚ąÄ {ūĚď§ ūĚď•} {A : Type ūĚď§} {B : A ‚Üí Type ūĚď•}
    ‚Üí {f g : (a : A) ‚Üí B a} ‚Üí f ~ g ‚Üí {h : (a : A) ‚Üí B a} ‚Üí g ~ h ‚Üí f ~ h
(p ‚ąôh q) a = p a ‚ąô q a

~refl : ‚ąÄ {ūĚď§ ūĚď•} {A : Type ūĚď§} {B : A ‚Üí Type ūĚď•} {f : (a : A) ‚Üí B a} ‚Üí f ~ f
~refl a = refl

infix 3 ~refl:_
~refl:_ : ‚ąÄ {ūĚď§ ūĚď•} {A : Type ūĚď§} {B : A ‚Üí Type ūĚď•} (f : (a : A) ‚Üí B a) ‚Üí f ~ f
~refl: f = ~refl

~sym : ‚ąÄ {ūĚď§ ūĚď•} {A : Type ūĚď§} {B : A ‚Üí Type ūĚď•} {f g : (a : A) ‚Üí B a} ‚Üí f ~ g ‚Üí g ~ f
~sym H a = sym (H a)

‚ąôh-reflr : ‚ąÄ {ūĚď§ ūĚď•} {A : Type ūĚď§} {B : A ‚Üí Type ūĚď•} {f g : (a : A) ‚Üí B a} ‚Üí (p : f ~ g) ‚Üí p ‚ąôh ~refl ~ p
‚ąôh-reflr p a = ‚ąô-reflr (p a)

infix 25 _h‚ĀĽ¬Ļ
_h‚ĀĽ¬Ļ : ‚ąÄ {ūĚď§ ūĚď•} {A : Type ūĚď§} {B : A ‚Üí Type ūĚď•} ‚Üí {f g : (a : A) ‚Üí B a} ‚Üí f ~ g ‚Üí g ~ f
(p h‚ĀĽ¬Ļ) a = sym (p a)

‚ąôh-sym : ‚ąÄ {ūĚď§ ūĚď•} {A : Type ūĚď§} {B : A ‚Üí Type ūĚď•} {f g : (a : A) ‚Üí B a} ‚Üí (p : f ~ g) ‚Üí p ‚ąôh (p h‚ĀĽ¬Ļ) ~ ~refl
‚ąôh-sym p a = ‚ąô-sym (p a)

‚ąôh-sym' : ‚ąÄ {ūĚď§ ūĚď•} {A : Type ūĚď§} {B : A ‚Üí Type ūĚď•} {f g : (a : A) ‚Üí B a} ‚Üí (p : f ~ g) ‚Üí (p h‚ĀĽ¬Ļ) ‚ąôh p ~ ~refl
‚ąôh-sym' p a = ‚ąô-sym' (p a)

‚ąôh-assoc
  : ‚ąÄ {ūĚď§ ūĚď•} {A : Type ūĚď§} {B : A ‚Üí Type ūĚď•} {f g h k : ő† A B}
    ‚Üí (H : f ~ g) (K : g ~ h) (L : h ~ k)
    ‚Üí (H ‚ąôh K) ‚ąôh L ~ H ‚ąôh K ‚ąôh L
‚ąôh-assoc H K L a = ‚ąô-assoc (H a) (K a) (L a)

right-transpose-‚ąôh
  : ‚ąÄ {ūĚď§ ūĚď•} {A : Type ūĚď§} {B : A ‚Üí Type ūĚď•}
    {f g h : ő† A B} {P : f ~ g} {Q : f ~ h} {R : g ~ h}
  ‚Üí P ‚ąôh R ~ Q ‚Üí P ~ Q ‚ąôh (R h‚ĀĽ¬Ļ)
right-transpose-‚ąôh {P = P} {Q} {R} E a
  = right-transpose-‚ąô (P a) (Q a) (R a) (E a)
}
}

\subtree[stt-001P]{
\taxon{Notation}
\title{Reasoning combinators}


\agda{
_~‚ü®‚ü©_ : ‚ąÄ {ūĚď§ ūĚď•} {A : Type ūĚď§} {B : A ‚Üí Type ūĚď•} (f : (a : A) ‚Üí B a) {g : (a : A) ‚Üí B a} ‚Üí f ~ g ‚Üí f ~ g
x ~‚ü®‚ü© x~y = x~y
infixr 0 _~‚ü®‚ü©_

~‚ü®‚ü©-syntax : ‚ąÄ {ūĚď§ ūĚď•} {A : Type ūĚď§} {B : A ‚Üí Type ūĚď•} ‚Üí (f : (a : A) ‚Üí B a) {g h : (a : A) ‚Üí B a} ‚Üí g ~ h ‚Üí f ~ g ‚Üí f ~ h
~‚ü®‚ü©-syntax f p q = q ‚ąôh p

infixr 0 ~‚ü®‚ü©-syntax
syntax ~‚ü®‚ü©-syntax x q p = x ~‚ü® p ‚ü© q

infix  1 _~‚ąé
_~‚ąé : ‚ąÄ {ūĚď§ ūĚď•} {A : Type ūĚď§} {B : A ‚Üí Type ūĚď•} ‚Üí (f : (a : A) ‚Üí B a) ‚Üí f ~ f
x ~‚ąé = ~refl

infixr 2 _‚ü©‚ąôh‚ü®_
_‚ü©‚ąôh‚ü®_
  : ‚ąÄ {ūĚď§ ūĚď•} {A : Type ūĚď§} {B : Type ūĚď•} {f g : A ‚Üí B} {p q : f ~ g} {h : A ‚Üí B} ‚Üí {r : g ~ h} {s : g ~ h}
    ‚Üí p ~ q ‚Üí r ~ s ‚Üí p ‚ąôh r ~ q ‚ąôh s
(p ‚ü©‚ąôh‚ü® q) a = (p a) ‚ü©‚ąô‚ü® (q a)
}
}


\subtree[stt-001Q]{
\taxon{Definition}
\title{Whiskerings}


\p{We can also define the whiskering of homotopies.}


\agda{
infixr 16 _‚óā_
_‚óā_
  : ‚ąÄ {ūĚď§ ūĚď• ūĚď¶} {A : Type ūĚď§} {B : A ‚Üí Type ūĚď•} {C : Type ūĚď¶}
    ‚Üí (h : ‚ąÄ {a} ‚Üí B a ‚Üí C) {f g : ő† A B} ‚Üí f ~ g ‚Üí h ‚ąė f ~ h ‚ąė g
(h ‚óā p) x = ap h (p x)

id‚óā : ‚ąÄ {ūĚď§ ūĚď•} {A : Type ūĚď§} {B : Type ūĚď•} {f g : A ‚Üí B} (H : f ~ g) ‚Üí id ‚óā H ~ H
id‚óā H a = ap-id (H a)


infixl 17 _‚Ėł_
_‚Ėł_
  : ‚ąÄ {ūĚď§ ūĚď• ūĚď¶} {A : Type ūĚď§} {B : Type ūĚď•} {C : Type ūĚď¶}
    ‚Üí {f g : B ‚Üí C} ‚Üí f ~ g ‚Üí (h : A ‚Üí B) ‚Üí f ‚ąė h ~ g ‚ąė h
(p ‚Ėł h) x = p (h x)


infixr 2 _‚ü©~‚óā‚ü®_
_‚ü©~‚óā‚ü®_ : ‚ąÄ {ūĚď§ ūĚď• ūĚď¶} {A : Type ūĚď§} {B : Type ūĚď•} {C : Type ūĚď¶}
           (f : B ‚Üí C) {g h : A ‚Üí B} {p q : g ~ h} ‚Üí p ~ q ‚Üí f ‚óā p ~ f ‚óā q
(f ‚ü©~‚óā‚ü® p) a = ap (ap f) (p a)


‚óā‚ąô
  : ‚ąÄ {ūĚď§ ūĚď• ūĚď¶} {A : Type ūĚď§} {B : A ‚Üí Type ūĚď•} {C : Type ūĚď¶}
      (k : ‚ąÄ {a} ‚Üí B a ‚Üí C) {f g h : ő† A B} (H : f ~ g) (K : g ~ h)
    ‚Üí k ‚óā (H ‚ąôh K) ~ (k ‚óā H) ‚ąôh (k ‚óā K)
‚óā‚ąô k H K a = ap-‚ąô k (H a) (K a)

‚óā‚ąô‚ąô
  : ‚ąÄ {ūĚď§ ūĚď• ūĚď¶} {A : Type ūĚď§} {B : A ‚Üí Type ūĚď•} {C : Type ūĚď¶}
      (l : ‚ąÄ {a} ‚Üí B a ‚Üí C) {f g h k : ő† A B}
      (H : f ~ g) (K : g ~ h) (L : h ~ k)
    ‚Üí l ‚óā (H ‚ąôh K ‚ąôh L) ~ (l ‚óā H) ‚ąôh (l ‚óā K) ‚ąôh (l ‚óā L)
‚óā‚ąô‚ąô k H K L a = ap-‚ąô‚ąô k (H a) (K a) (L a)

‚óā‚ąė
  : ‚ąÄ {ūĚď§ ūĚď• ūĚď¶ ūĚďú} {A : Type ūĚď§} {B : A ‚Üí Type ūĚď•} {C : Type ūĚď¶}
      {D : Type ūĚďú}
      (i : C ‚Üí D) (h : ‚ąÄ {a} ‚Üí B a ‚Üí C)
      {f g : ő† A B} (H : f ~ g)
    ‚Üí (i ‚ąė h) ‚óā H ~ i ‚óā h ‚óā H
‚óā‚ąė i k H a = ap-‚ąė i k (H a)

‚óā‚ąė‚ąė
  : ‚ąÄ {ūĚď§ ūĚď• ūĚď¶ ūĚďú ūĚďõ} {A : Type ūĚď§} {B : A ‚Üí Type ūĚď•} {C : Type ūĚď¶}
      {D : Type ūĚďú} {E : Type ūĚďõ}
      (j : D ‚Üí E) (i : C ‚Üí D) (h : ‚ąÄ {a} ‚Üí B a ‚Üí C)
      {f g : ő† A B} (H : f ~ g)
    ‚Üí (j ‚ąė i ‚ąė h) ‚óā H ~ j ‚óā i ‚óā h ‚óā H
‚óā‚ąė‚ąė h i j H a = ap-‚ąė‚ąė h i j (H a)

‚óā‚ĀĽ¬Ļ
  : ‚ąÄ {ūĚď§ ūĚď• ūĚď¶} {A : Type ūĚď§} {B : A ‚Üí Type ūĚď•} {C : Type ūĚď¶}
      (f : ‚ąÄ {a} ‚Üí B a ‚Üí C) {g h : ő† A B} (H : g ~ h)
    ‚Üí f ‚óā (H h‚ĀĽ¬Ļ) ~ ((f ‚óā H) h‚ĀĽ¬Ļ)
‚óā‚ĀĽ¬Ļ f H = ap-sym f ‚ąė H
}
}



\subtree[stt-001O]{
\taxon{Remark}
\title{Homotopies are invertible natural transformations}


\p{If [functions are functors](stt-001F), then homotopies are invertible natural transformations.}

\agda{
homotopy-natural
  : ‚ąÄ {ūĚď§ ūĚď•} {A : Type ūĚď§} {B : Type ūĚď•} {f g : A ‚Üí B} ‚Üí (h : f ~ g)
    ‚Üí ‚ąÄ {x y} (p : x ÔľĚ y) ‚Üí h x ‚ąô ap g p ÔľĚ ap f p ‚ąô h y
homotopy-natural _ refl = ‚ąô-reflr _

homotopy-conjugate
  : ‚ąÄ {ūĚď§ ūĚď•} {A : Type ūĚď§} {B : Type ūĚď•} {f g : A ‚Üí B}
      (H : f ~ g)
    ‚Üí ‚ąÄ {x y : A} (p : x ÔľĚ y)
    ‚Üí sym (ap f p) ‚ąô H x ‚ąô ap g p ÔľĚ H y
homotopy-conjugate H refl = ‚ąô-reflr _

homotopy-cancel
  : ‚ąÄ {ūĚď§ ūĚď•} {A : Type ūĚď§} {B : Type ūĚď•} {f g : A ‚Üí B}
      (H : f ~ g)
    ‚Üí ‚ąÄ {x y : A} (p : x ÔľĚ y)
    ‚Üí (ap f p ‚ąô H y) ‚ąô sym (ap g p) ÔľĚ H x
homotopy-cancel H refl = ‚ąô-reflr _

homotopy-inverse : ‚ąÄ {ūĚď§} {A : Type ūĚď§} (f : A ‚Üí A) (p : f ~ id) ‚Üí p ‚Ėł f ~ f ‚óā p
homotopy-inverse {ūĚď§} {A} f p x = p (f x)                ÔľĚ‚ü® ‚ąô.insertl A (‚ąô-sym (p x)) ‚ü©
                         (p (f x) ‚ąô p x) ‚ąô sym (p x)    ÔľĚ‚ü® II x ‚ü©
                         (ap f (p x) ‚ąô p x) ‚ąô sym (p x) ÔľĚ‚ü® ‚ąô.cancell A (‚ąô-sym (p x)) ‚ü©
                         ap f (p x) ‚ąé  where
  I : ‚ąÄ x ‚Üí p (f x) ‚ąô p x ÔľĚ ap f (p x) ‚ąô p x
  I x = ap (p (f x) ‚ąô_) (sym (ap-id _)) ‚ąô homotopy-natural p (p x)

  II : ‚ąÄ x ‚Üí (p (f x) ‚ąô p x) ‚ąô sym (p x) ÔľĚ (ap f (p x) ‚ąô p x) ‚ąô sym (p x)
  II x = ap (_‚ąô sym (p x)) (I x)
}
}

\subtree[stt-0094]{
\date{2025-08-14}
\title{Horizontal concatenation of homotopies}
\taxon{Definition}

\p{We define horizontal concatenation for homotopies, and show that
it admits an interchange law with respect to vertical concatenation.}

\proof{Follows from [naturality](stt-001O)}

\p{The symbol we use for horizontal concatenation \code{‚óĺ} has agda-input sequence:
\code{sq5}.}

\agda{
_‚óĺ_
  : ‚ąÄ {ūĚď§ ūĚď• ūĚď¶} {A : Type ūĚď§} {B : Type ūĚď•} {C : Type ūĚď¶}
    ‚Üí {f g : B ‚Üí C} ‚Üí f ~ g
    ‚Üí {h k : A ‚Üí B} ‚Üí h ~ k
    ‚Üí f ‚ąė h ~ g ‚ąė k
_‚óĺ_ {g = g} H {h = h} K = H ‚Ėł h ‚ąôh g ‚óā K

infixr 2 _‚ü©‚óĺ‚ü®_
_‚ü©‚óĺ‚ü®_
  : ‚ąÄ {ūĚď§ ūĚď• ūĚď¶} {A : Type ūĚď§} {B : Type ūĚď•} {C : Type ūĚď¶}
    ‚Üí {f g : B ‚Üí C} {H H' : f ~ g} ‚Üí H ~ H'
    ‚Üí {h k : A ‚Üí B} {K K' : h ~ k} ‚Üí K ~ K'
    ‚Üí H ‚óĺ K ~ H' ‚óĺ K'
(P ‚ü©‚óĺ‚ü® Q) a = ap‚āā (_‚ąô_) (P _) (ap (ap _) (Q a))

_‚óĺ'_
  : ‚ąÄ {ūĚď§ ūĚď• ūĚď¶} {A : Type ūĚď§} {B : Type ūĚď•} {C : Type ūĚď¶}
    ‚Üí {f g : B ‚Üí C} ‚Üí f ~ g
    ‚Üí {h k : A ‚Üí B} ‚Üí h ~ k
    ‚Üí f ‚ąė h ~ g ‚ąė k
_‚óĺ'_ {f = f} H {k = k} K = f ‚óā K ‚ąôh H ‚Ėł k

switch-‚óĺ
  : ‚ąÄ {ūĚď§ ūĚď• ūĚď¶} {A : Type ūĚď§} {B : Type ūĚď•} {C : Type ūĚď¶}
    ‚Üí {f g : B ‚Üí C} (H : f ~ g)
    ‚Üí {h k : A ‚Üí B} (K : h ~ k)
    ‚Üí H ‚óĺ K ~ H ‚óĺ' K
switch-‚óĺ H K a = homotopy-natural H (K a)

homotopy-interchange
  : ‚ąÄ {ūĚď§ ūĚď• ūĚď¶} {A : Type ūĚď§} {B : Type ūĚď•} {C : Type ūĚď¶}
      {f g h : B ‚Üí C} (H : f ~ g) (L : g ~ h)
      {k l m : A ‚Üí B} (K : k ~ l) (J : l ~ m)
    ‚Üí (H ‚óĺ K) ‚ąôh (L ‚óĺ J) ~ ((H ‚ąôh L) ‚óĺ (K ‚ąôh J))
homotopy-interchange {f = f} {g} {h} H L {k} {l} {m} K J
  = (H ‚óĺ K) ‚ąôh (L ‚óĺ J) ~‚ü®‚ü©
    (H ‚Ėł k ‚ąôh g ‚óā K) ‚ąôh L ‚Ėł l ‚ąôh h ‚óā J   ~‚ü® ‚ąôh-assoc _ (L ‚Ėł l) (h ‚óā J) h‚ĀĽ¬Ļ ‚ü©
    ((H ‚Ėł k ‚ąôh g ‚óā K) ‚ąôh L ‚Ėł l) ‚ąôh h ‚óā J ~‚ü® ‚ąôh-assoc _ (g ‚óā K) (L ‚Ėł l) ‚ü©‚ąôh‚ü® ~refl: (h ‚óā J) ‚ü©
    (H ‚Ėł k ‚ąôh (g ‚óā K ‚ąôh L ‚Ėł l)) ‚ąôh h ‚óā J ~‚ü® ‚ąôh-assoc (H ‚Ėł k) _ (h ‚óā J) ‚ü©
    H ‚Ėł k ‚ąôh (g ‚óā K ‚ąôh L ‚Ėł l) ‚ąôh h ‚óā J

        ~‚ü® ~refl: (H ‚Ėł k) ‚ü©‚ąôh‚ü® sym ‚ąė homotopy-natural L ‚ąė K ‚ü©‚ąôh‚ü® ~refl: (h ‚óā J) ‚ü©

    H ‚Ėł k ‚ąôh (L ‚Ėł k ‚ąôh h ‚óā K) ‚ąôh h ‚óā J ~‚ü® ~refl: (H ‚Ėł k) ‚ü©‚ąôh‚ü® ‚ąôh-assoc (L ‚Ėł k) (h ‚óā K) (h ‚óā J) ‚ü©
    H ‚Ėł k ‚ąôh L ‚Ėł k ‚ąôh (h ‚óā K ‚ąôh h ‚óā J) ~‚ü® ~refl: (H ‚Ėł k) ‚ü©‚ąôh‚ü® ~refl: (L ‚Ėł k) ‚ü©‚ąôh‚ü® ‚óā‚ąô h K J h‚ĀĽ¬Ļ ‚ü©
    H ‚Ėł k ‚ąôh L ‚Ėł k ‚ąôh h ‚óā (K ‚ąôh J)     ~‚ü® ‚ąôh-assoc (H ‚Ėł k) (L ‚Ėł k) _ h‚ĀĽ¬Ļ ‚ü©
    (H ‚Ėł k ‚ąôh L ‚Ėł k) ‚ąôh h ‚óā (K ‚ąôh J)   ~‚ü®‚ü©
    (H ‚ąôh L) ‚óĺ (K ‚ąôh J) ~‚ąé
}
}

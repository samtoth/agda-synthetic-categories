\subtree[stt-00D6]{
\title{Unstraightening hom families}
\taxon{Remark}

\p{The unstraightening of the family #{\Hom(x,-)} is #{X_{x/} \to X}. Thus
representable families are covariant iff #{X_{x/} \to X} are all left fibrations.}


%```agda
\agda{
hom-fam-is-cov‚áĒis-left-fibration
  : ‚ąÄ {ūĚď§} {X : Type ūĚď§} x
  ‚Üí is-covariant (őĽ a ‚Üí Hom X x a)
  ‚áĒ is-left-fibration {A = Coslice X (őĽ (_ : ūĚüô) ‚Üí x)} fst
hom-fam-is-cov‚áĒis-left-fibration x
  = is-covariant‚áĒis-left-fibration (őĽ a ‚Üí Hom _ x a)
  ‚ąô‚áĒ right-orthogonal-iff‚Üźequiv (őĽ _ ‚Üí i0) amap amap-eq where
  amap : Arrow-map (fst {B = őĽ c ‚Üí (i : ūĚüô) ‚Üí Hom _ x c})
                   (fst {B = őĽ a ‚Üí Hom _ x a})
  amap .Arrow-map.top = total-map (őĽ a ‚Üí ev tt)
  amap .Arrow-map.bot = id
  amap .Arrow-map.comm = ~refl

  amap-eq : is-Arrow-equiv amap
  amap-eq .fst = is-total-equiv‚Üźis-fibrewise-equiv (őĽ a ‚Üí unit-ev-is-equiv)
  amap-eq .snd = id-is-equiv
}
%```
}

\subtree[stt-00DA]{
\taxon{Definition}
\title{Strongly (left) Segal types}

\p{We call a type \em{strongly} (left) Segal if it is local with respect to the
map #{\Lambda^2_1 \to 1 \rtimes \Delta^1}.
}

%```agda
\agda{
weird-horn-inclusion : őõ[2,1] ‚Üí ūĚüô ‚čČ őĒ¬Ļ
weird-horn-inclusion = cogap (mk-cocone (‚ÜĎ-hom (tt , i0) .HomŠĶą.hom) ‚ÜĎ-őĻ‚āā
                             őĽ a ‚Üí glue (őīőĒ¬Ļ-1 , tt , i0))

weird-horn-inclusion‚ąô : Coslice-map (őĽ (_ : ūĚüô) ‚Üí őĻ‚āĀ i0) őĽ _ ‚Üí ‚ÜĎ-őĻ‚āĀ tt
weird-horn-inclusion‚ąô = (weird-horn-inclusion , őĽ _ ‚Üí glue (őīőĒ¬Ļ-0 , tt , i0))

is-strongly-segal : ‚ąÄ {ūĚď§} (A : Type ūĚď§) ‚Üí Type (ūĚďė ‚äĒ ūĚď§)
is-strongly-segal A = is-local (őĽ (_ : ūĚüô) ‚Üí weird-horn-inclusion) A
}
%```
}

\subtree[stt-00DB]{
\title{Strongly Segal types are Segal}
\taxon{Lemma}

\p{Any [strongly Segal](stt-00DA) type is [Segal](stt-00AI).}

\proof{
\p{We give a splitting of #{\Delta^2 \hookrightarrow 1 \rtimes \Delta^1},
   which furthermore preserves the inner horn inclusion.
   (Note the split embedding #{\Delta^2 \hookrightarrow \square^2} in
   \ref{stt-00C7} factors through this map.)}
}

%```agda
\agda{
retract-weird : ūĚüô ‚čČ őĒ¬Ļ ‚Üí őĒ¬≤
retract-weird
  = cogap (mk-cocone
            (őĽ {(i , tt , j) ‚Üí (i , i ‚ąß j) ‚¶É ‚ąß-‚Č§-eliml auto! ‚¶Ą})
            ‚äé[ (őĽ _ ‚Üí (i0 , i0)) , (i1 ,_) ]
            őĽ { (mk-lift true  , tt , b) ‚Üí őĒ¬≤-ext (refl , ‚ąß-comm ‚ąô 1-top)
              ; (mk-lift false , tt , b) ‚Üí őĒ¬≤-ext (refl , 0-init) })

retract-weird-resp-horn
  : retract-weird ‚ąė weird-horn-inclusion ~ őõ[2,1]-incl
retract-weird-resp-horn = pushout-ind _
  (mk-coconeŠĶą
    (őĽ l ‚Üí őĒ¬≤-ext (refl , ‚ąß-comm ‚ąô 0-init))
    (őĽ r ‚Üí refl)
    (őĽ _ ‚Üí is-set‚Üźis-truncated őĒ¬≤-is-set _ _ _ _))

section-weird : őĒ¬≤ ‚Üí ūĚüô ‚čČ őĒ¬Ļ
section-weird a = őĻ‚āĀ (Poly.őĒ¬≤.s a , tt , Poly.őĒ¬≤.t a)

section-weird-resp-horn
  : section-weird ‚ąė őõ[2,1]-incl ~ weird-horn-inclusion
section-weird-resp-horn = pushout-rec-unique _ _
  ~refl
  (őĽ a ‚Üí glue (őīőĒ¬Ļ-1 , tt , a))
  őĽ a ‚Üí ap (_‚ąô glue (őīőĒ¬Ļ-1 , tt , i0))
         ( ap-‚ąė section-weird őõ[2,1]-incl (glue a)
         ‚ąô ap (ap section-weird) (pushout-rec-apő≤ _)
         ‚ąô lem) where
  lem : ap (section-weird) őĒ¬≤-refl ÔľĚ refl
  lem = ap-‚ąė őĻ‚āĀ (őĽ where (i , j) ‚Üí (i , tt , j)) őĒ¬≤-refl
      ‚ąô ap (ap őĻ‚āĀ) (is-set‚Üźis-truncated
                     (Trunc.√ó‚ąąS car-is-set (Trunc.√ó‚ąąS Trunc.ūĚüô‚ąąS car-is-set))
                     _ _ _ _)

sec-weird-is-sec : retract-weird ‚ąė section-weird ~ id
sec-weird-is-sec (a , b) = őĒ¬≤-ext (refl , (‚ąß-comm ‚ąô auto!))

is-segal‚Üźis-strongly-segal
  : ‚ąÄ {ūĚď§} {A : Type ūĚď§}
    ‚Üí is-strongly-segal A
    ‚Üí is-segal A
is-segal‚Üźis-strongly-segal orth tt
  = is-orthogonal‚áĒorthogonal-! .fst
      (left-orthogonal-retract őõ[2,1]-incl weird-horn-inclusion
        (mk-amap id section-weird section-weird-resp-horn)
        ((mk-amap id retract-weird retract-weird-resp-horn) ,
          (~refl , ((őĽ (i , j) ‚Üí őĒ¬≤-ext (refl , ‚ąß-comm ‚ąô auto!))
          , őĽ _ ‚Üí is-set‚Üźis-truncated őĒ¬≤-is-set _ _ _ _)))
        !
        (is-orthogonal‚áĒorthogonal-! .snd (orth tt)))
}
%```
}


\subtree[stt-00D9]{
\taxon{Therem}
\title{Covariance of representable families}

\p{We show that a type #{A} is [strongly Segal](stt-00DA) iff the family
#{\Hom(x,-)} is covariant for each #{x}.}

\proof{
We will show that every #{A_{x/} \to A} is a left fibration iff A is right
orthogonal to the map #{\Lambda^2_1 \to 1 \rtimes \Delta^1}.

\p{First we give an equivalence of arrows:}

\quiver{
\begin{tikzcd}
	{1\rtimes \Delta^1 \to_\bullet A} && {{A_{x/}}^{\Delta^1}} \\
	\\
	{\Lambda^2_1 \to_\bullet A} && {A^{\Delta^1} \times_A A_{x/}}
	\arrow["\sim", from=1-1, to=1-3]
	\arrow[from=1-1, to=3-1]
	\arrow[from=1-3, to=3-3]
	\arrow["\sim"', from=3-1, to=3-3]
\end{tikzcd}
}

\p{The top equivalence is given by the [join-coslice adjunction](stt-00D5), and
the bottom via the universal property of the horn.}


\p{Now we use \ref{stt-00DC} to finish the proof.}
}

\closedScope{
\subtree[stt-00DD]{
\title{The bottom equivalence}
%```agda
\agda{
char-coslice-lift : ‚ąÄ {ūĚď§} {A : Type ūĚď§} x
      ‚Üí Arrow-map (őĽ (_ : ūĚüô) ‚Üí i0) {C = Coslice A (őĽ (_ : ūĚüô) ‚Üí x)} (fst)
      ‚Üí Coslice-map {X = őõ[2,1]} (őĽ _ ‚Üí őĻ‚āĀ i0) (őĽ (_ : ūĚüô) ‚Üí x)
char-coslice-lift x (mk-amap top bot comm)
  = cogap (mk-cocone (top tt .snd tt .HomŠĶą.hom)
                     bot
                     (őĽ c ‚Üí top tt .snd tt .HomŠĶą.hom1 ‚ąô sym (comm c)))
  , őĽ _ ‚Üí HomŠĶą.hom0 (top tt .snd tt)

opaque
  char-coslice-lift-is-equiv
    : ‚ąÄ {ūĚď§} {A : Type ūĚď§} x
    ‚Üí is-equiv (char-coslice-lift {A = A} x)
  char-coslice-lift-is-equiv x = is-equiv‚Üźqiso qiso where
    qiso : quasi-iso (char-coslice-lift x)
    qiso .fst (a , b) = mk-amap (őĽ _ ‚Üí _ , (őĽ _ ‚Üí mk-hom (a ‚ąė őĻ‚āĀ) (b tt) refl))
                                (a ‚ąė őĻ‚āā)
                                (ap a ‚ąė sym ‚ąė glue)
    qiso .snd .fst (mk-amap top bot comm)
      = let pth = ( top tt .snd tt .HomŠĶą.hom1
                  , őĽ i ‚Üí ( ~refl
                          , Square-degen-vert _ _ refl
                          , Square-flatten-hor refl))
        in Arrow-map-path‚Üí
          ( (őĽ a ‚Üí Coslice-path‚Üí pth)
          , (~refl
          , őĽ _ ‚Üí ap (_‚ąô ap fst (Coslice-path‚Üí pth))
                    (ap-sym _ (glue tt) ‚ąô ap sym (pushout-rec-apő≤ tt))
                ‚ąô ap (sym (HomŠĶą.hom1 (top tt .snd tt) ‚ąô sym (comm tt)) ‚ąô_)
                     (Coslice-path-ap-fst pth)
                ‚ąô ap (_‚ąô top tt .snd tt .HomŠĶą.hom1) (‚ąô-symsym _ (sym (comm tt)))
                ‚ąô ‚ąô.cancell _  (‚ąô-sym' (HomŠĶą.hom1 (top tt .snd tt)))
                               {f = sym (sym (comm tt))}
                ‚ąô sym-sym ))
    qiso .snd .snd (a , p)
      = ext! ( sym ‚ąė pushout-rec-unique _ _ ~refl ~refl
                      (őĽ _ ‚Üí ‚ąô-reflr _ ‚ąô sym (ap sym (ap-sym a _) ‚ąô sym-sym))
             , ~refl)
}
%```
}
}

%```agda
\agda{
coslice-is-left‚áĒstrongly-inner-coslice
  : ‚ąÄ {ūĚď§} {A : Type ūĚď§} x
  ‚Üí is-left-fibration {A = Coslice A (őĽ (_ : ūĚüô) ‚Üí x)} fst
  ‚áĒ (is-equiv (Coslice-map-precompose (őĽ (_ : ūĚüô) ‚Üí x) weird-horn-inclusion‚ąô))
coslice-is-left‚áĒstrongly-inner-coslice x
  = (orthogonal‚áĒpb-power-is-equiv ‚áĒ‚ĀĽ¬Ļ)
  ‚ąô‚áĒ top‚áĒbot-is-equiv‚ÜźArrow-equiv amap amap-eq module Cov-hom where

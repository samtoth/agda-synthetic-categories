\taxon{Module}

\import{stt-macros}

\agda{
module Algebra.Poset where
}

\agda-imports{
\agda{
open import Foundations.Prelude
}
}

\subtree[fre-35E5]{
\title{Posets}
\taxon{Definition}

\p{
A \em{poset} is a type #{A} together with a propositional binary relation
#{{-} \le {-}} that is reflexive, transitive, and antisymmetric.
}

\agda{
record is-poset {𝓤 𝓥} {A : Type 𝓤} (_≤_ : A → A → Type 𝓥) : Type (𝓤 ⊔ 𝓥) where
  no-eta-equality
  field
    ≤-is-prop : ∀ {a b} → is-prop (a ≤ b)
    ≤-refl    : ∀ {a} → a ≤ a
    ≤-trans   : ∀ {a b c} → a ≤ b → b ≤ c → a ≤ c
    ≤-antisym : ∀ {a b} → a ≤ b → b ≤ a → a ＝ b

  _≥_ : A → A → Type 𝓥
  i ≥ j = j ≤ i

record Poset {𝓤} 𝓥 (A : Type 𝓤) : Type (𝓤 ⊔ lsuc 𝓥) where
  constructor mk-poset
  field
    {_≤_} :  A → A → Type 𝓥
    ≤-is-poset :  is-poset _≤_

  open is-poset ≤-is-poset public
}
}

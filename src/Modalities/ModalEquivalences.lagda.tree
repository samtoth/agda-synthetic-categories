\date{2026-03-19}
\title{Modal equivalences}
\author{fredrikbakke}
\taxon{Module}
\import{stt-macros}



%```agda
\agda{
module Modalities.ModalEquivalences where

open import ufAxioms
open import Foundations.Prelude
open import Modalities.Subuniverses
open import Modalities.GlobalSubuniverses
open import Modalities.GlobalReflectiveSubuniverses
open import Modalities.ModalMaps
open import Core.Arrow
open import Core.ArrowRetract
open import Core.Orthogonal
open import Core.ArrowEquiv
}
%```

\subtree[fre-LMAO]{
\taxon{Definition}
\title{Universal property of glboal subuniverse equivalences}
\author{fredrikbakke}
\author{samueltoth}

\p{
Given a global subuniverse #{K} and a map #{f : A \to B}, then #{f} is a
#{K}-\em{equivalence} if for every type #{U} in #{K},
the precomposition map #{U^f} is an equivalence.
}

% ```agda
\agda{
up-gmodal-equiv : ∀ {α 𝓤 𝓥} (K : gSubU α)
                  → {A : Type 𝓤} {B : Type 𝓥}
                  → (A → B)
                  → Typeω
up-gmodal-equiv K f
  = ∀ {𝓚} {U : Type 𝓚}
  → U ∈ gSubU.S K
  → is-equiv (precomp U f)

is-modal-equiv
  : ∀ {𝓤 𝓥 α} {A : Type 𝓤} {B : Type 𝓥}
      {S : gSubU α}
    → is-globally-reflective S → (A → B) → Type (𝓤 ⊔ 𝓥)
is-modal-equiv Srfl f = is-equiv (○₁ f) where
  open gRSubUEquivMap (mk-gRSubU _ Srfl)
}
%```
}

\subtree{
\date{2026-03-19}
\author{fredrikbakke}
\taxon{Lemma}
\title{3-for-2 for global subuniverse equivalences}

\p{
Global #{K}-equivalences satisfy the 3-for-2 property. Given a commuting triangle of
#{K}-equivalences, if two of the three maps are #{K}-equivalences then so is the
third.
}

% ```agda
\agda{
up-gmodal-equiv-∘
  : ∀ {α 𝓤 𝓥 𝓦}
      (K : gSubU α)
      {A : Type 𝓤} {B : Type 𝓥} {C : Type 𝓦}
      (f : A → B) (g : B → C)
    → up-gmodal-equiv K f
    → up-gmodal-equiv K g
    → up-gmodal-equiv K (g ∘ f)
up-gmodal-equiv-∘ K f g fe ge U∈K
  = is-equiv-∘ (fe U∈K) (ge U∈K)

up-gmodal-equiv-right-cancel
  : ∀ {α 𝓤 𝓥 𝓦}
      (K : gSubU α)
      {A : Type 𝓤} {B : Type 𝓥} {C : Type 𝓦}
      (f : A → B) (g : B → C)
    → up-gmodal-equiv K f
    → up-gmodal-equiv K (g ∘ f)
    → up-gmodal-equiv K g
up-gmodal-equiv-right-cancel K f g fe gfe U∈K
  = 3-for-2 (fe U∈K) (gfe U∈K)

up-gmodal-equiv-left-cancel
  : ∀ {α 𝓤 𝓥 𝓦}
      (K : gSubU α)
      {A : Type 𝓤} {B : Type 𝓥} {C : Type 𝓦}
      (f : A → B) (g : B → C)
    → up-gmodal-equiv K g
    → up-gmodal-equiv K (g ∘ f)
    → up-gmodal-equiv K f
up-gmodal-equiv-left-cancel K f g ge gfe U∈K
  = 3-for-2' (ge U∈K) (gfe U∈K)
}
%```
}

\subtree{
\date{2026-03-19}
\author{fredrikbakke}
\taxon{Lemma}
\title{#{K}-equivalences are closed under retracts of arrows}

\p{
If #{f} is a retract of #{g} as an arrow, and #{g} is a global #{K}-equivalence,
then so is #{f}.
}

% ```agda
\agda{
up-gmodal-equiv←incoherent-retraction-arrow-map
  : ∀ {α 𝓤 𝓥 𝓦 𝓛}
      (K : gSubU α)
      {A : Type 𝓤} {B : Type 𝓥} {f : A → B}
      {X : Type 𝓦} {Y : Type 𝓛} {g : X → Y}
      (F : Arrow-map f g)
    → incoherent-retraction-arrow-map F
    → up-gmodal-equiv K g
    → up-gmodal-equiv K f
up-gmodal-equiv←incoherent-retraction-arrow-map K {f = f} {g = g} F R ge U∈K
  = is-equiv←incoherent-retraction-equiv
      (precomp-square (R .fst) _)
      precomp-incoh
      (ge U∈K)
  where
  precomp-incoh
    : incoherent-retraction-arrow-map (precomp-square (R .fst) _)
  precomp-incoh
    = precomp-square F _
    , ( (λ a → ap (a ∘_) (funext→ (R .snd .snd)))
      , (λ a → ap (a ∘_) (funext→ (R .snd .fst))))

up-gmodal-equiv←retraction-arrow-map
  : ∀ {α 𝓤 𝓥 𝓦 𝓛}
      (K : gSubU α)
      {A : Type 𝓤} {B : Type 𝓥} {f : A → B}
      {X : Type 𝓦} {Y : Type 𝓛} {g : X → Y}
      (F : Arrow-map f g)
    → retraction-arrow-map F
    → up-gmodal-equiv K g
    → up-gmodal-equiv K f
up-gmodal-equiv←retraction-arrow-map K F R
  = up-gmodal-equiv←incoherent-retraction-arrow-map K F
      (R .fst , (R .snd .fst , R .snd .snd .fst))
}
%```
}

\subtree{
\date{2026-03-19}
\author{fredrikbakke}
\taxon{Lemma}
\title{Global subuniverse equivalences with local domain and codomain}

\p{
If a #{K}-equivalence has both domain and codomain in #{K}, then it is an actual
equivalence.
}

% ```agda
\agda{
is-equiv←up-gmodal-equiv-domain-codomain
  : ∀ {α 𝓤 𝓥} (K : gSubU α)
      {A : Type 𝓤} {B : Type 𝓥}
      (f : A → B)
    → A ∈ gSubU.S K
    → B ∈ gSubU.S K
    → up-gmodal-equiv K f
    → is-equiv f
is-equiv←up-gmodal-equiv-domain-codomain K {A = A} {B = B} f A∈K B∈K feq
  = is-equiv←equiv-precomp-dom-cod
      (feq {U = A} A∈K)
      (feq {U = B} B∈K)
}
%```
}

\subtree{
\date{2026-03-19}
\author{fredrikbakke}
\taxon{Module}
\title{Modal equivalences, given reflections of domains}

\p{
If #{f : A \to B} is a map between types with #{K}-reflections, then we say #{f} is
a #{K}-equivalence if its reflection is an equivalence.
}

\agda{
module gReflectorModalEquivalences
    {α 𝓤 𝓥} {GS : gSubU α}
    {A : Type 𝓤} {B : Type 𝓥}
    (RA : gReflector GS A)
    (RB : gReflector GS B) where
  open gSubU GS
  module A = gReflector RA
  module B = gReflector RB
  module F = gReflectorMap RA RB

  is-gmodal-equiv
    : (A → B) → Type _
  is-gmodal-equiv f = is-equiv (F.○₁ f)

  precomp-○₁-is-equiv←up-gmodal-equiv
    : (f : A → B)
    → up-gmodal-equiv GS f
    → ∀ {𝓚} {U : Type 𝓚}
    → U ∈ S
    → is-equiv (precomp U (F.○₁ f))
  precomp-○₁-is-equiv←up-gmodal-equiv f feq {U = U} U∈S
    = 3-for-2
        (A.reflects U∈S)
        (is-equiv~∘ comm (feq U∈S) (B.reflects U∈S))
    where
    comm
      : precomp U A.η ∘ precomp U (F.○₁ f)
      ~ precomp U f ∘ precomp U B.η
    comm h = funext→ λ a → ap h (F.○₁-β f a)

  is-gmodal-equiv←up-gmodal-equiv
    : (f : A → B)
    → up-gmodal-equiv GS f
    → is-gmodal-equiv f
  is-gmodal-equiv←up-gmodal-equiv f feq
    = is-equiv←equiv-precomp-dom-cod
        (precomp-○₁-is-equiv←up-gmodal-equiv f feq A.○∈S)
        (precomp-○₁-is-equiv←up-gmodal-equiv f feq B.○∈S)

  up-gmodal-equiv←is-gmodal-equiv
    : (f : A → B)
    → is-gmodal-equiv f
    → up-gmodal-equiv GS f
  up-gmodal-equiv←is-gmodal-equiv f feq {U = U} U∈S
    = 3-for-2' (B.reflects U∈S)
        (homotopy-is-equiv
          {f = precomp U A.η ∘ precomp U (F.○₁ f)}
          {g = precomp U f ∘ precomp U B.η}
          comm
          (is-equiv-∘ (A.reflects U∈S) (precomp-equiv feq)))
    where
    comm
      : precomp U A.η ∘ precomp U (F.○₁ f)
      ~ precomp U f ∘ precomp U B.η
    comm h = funext→ λ a → ap h (F.○₁-β f a)
}
%```
}

\subtree[stt-02AD]{
\author{samueltoth}
\taxon{Module}

\agda{
module gRSubUModalEquivalences {α} (RS : gRSubU α) where
  open gRSubU RS
  open gReflectiveClosure RS
  open gRSubUEquivMap RS

  module RModal {𝓤 𝓥} {A : Type 𝓤} {B : Type 𝓥}
    = gReflectorModalEquivalences
        (gReflector←gRSubU RS A)
        (gReflector←gRSubU RS B)

  open RModal public

  up-gmodal-equiv←is-modal-equiv
    : ∀ {𝓤 𝓥} {A : Type 𝓤} {B : Type 𝓥} {f : A → B}
      → is-modal-equiv (RS .gRSubU.has-is-globally-reflective) f
      → up-gmodal-equiv (RS .gRSubU.GS) f
  up-gmodal-equiv←is-modal-equiv {A = A} {B = B} {f = f} ○fe {_}{X} X∈S
    = is-equiv←Arrow-equiv {F = amap} amap-is-equiv (precomp-equiv ○fe) where
    amap
      : Arrow-map
          (precomp X (○₁ f))
          (precomp X f)
    amap .Arrow-map.top = precomp X (RS .gRSubU.η)
    amap .Arrow-map.bot = precomp X (RS .gRSubU.η)
    amap .Arrow-map.comm h
      = funext→ (λ a → ap h (○₁-β f a))

    amap-is-equiv : is-Arrow-equiv amap
    amap-is-equiv .fst
      = is-globally-reflective.reflects
          (RS .gRSubU.has-is-globally-reflective) X∈S
    amap-is-equiv .snd
      = is-globally-reflective.reflects
          (RS .gRSubU.has-is-globally-reflective) X∈S
}
%```
}

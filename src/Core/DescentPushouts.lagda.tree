\date{2026-05-19}
\title{Descent for pushouts}
\taxon{Module}
\author{fredrikbakke}

\import{stt-macros}

\agda{
module Core.DescentPushouts where

open import Foundations.Prelude
open import Axioms.UF
open import Core.Arrows
open import Core.ArrowEquiv
open import Core.CartesianSpans
}

\subtree[fre-0001]{
\title{Displayed cartesian span diagrams classify cocones into the universe}
\taxon{Lemma}
\author{fredrikbakke}

\agda{
module _ {рқ“Ө рқ“Ҙ рқ“Ұ рқ“ӣ} {S : Span рқ“Ө рқ“Ҙ рқ“Ұ} where

  spanвҶҗType-cocone
    : Cocone S (Type рқ“ӣ) вҶ’ span-diagramбөҲ S рқ“ӣ рқ“ӣ рқ“ӣ
  spanвҶҗType-cocone (mk-cocone P-left P-right H)
    = mk-span-diagramбөҲ
        P-left
        P-right
        (P-left вҲҳ Span.left S)
        (О» _ вҶ’ idвүғ)
        (О» s вҶ’ coeвүғ (H s))

  О -swap-cartesian-spanбөҲ
    : (P-left : Span.Left S вҶ’ Type рқ“ӣ)
      (P-right : Span.Right S вҶ’ Type рқ“ӣ)
    вҶ’ cartesian-spanбөҲ S рқ“ӣ P-left P-right
    вүғ ( (s : Span.Centre S)
      вҶ’ ОЈ[ P-centre вҲ¶ Type рқ“ӣ ]
          ( (P-centre вүғ P-left (Span.left S s))
          Г— (P-centre вүғ P-right (Span.right S s))))
  О -swap-cartesian-spanбөҲ P-left P-right
    = mkвүғ
      ( О» R s
        вҶ’ ( R .cartesian-spanбөҲ.Centre s
          , R .cartesian-spanбөҲ.Leftвүғ s
          , R .cartesian-spanбөҲ.Rightвүғ s))
      ( mk-eqv
        ( ( О» R вҶ’ mk-cartesian-spanбөҲ (fst вҲҳ R) (fst вҲҳ snd вҲҳ R) (snd вҲҳ snd вҲҳ R))
          , ~refl
          , ~refl)
        (~refl))

  Type-coconeвҶҗspan
    : span-diagramбөҲ S рқ“ӣ рқ“ӣ рқ“ӣ вҶ’ Cocone S (Type рқ“ӣ)
  Type-coconeвҶҗspan P
    = mk-cocone
        (P .span-diagramбөҲ.Left)
        (P .span-diagramбөҲ.Right)
        (ua вҲҳ span-diagramбөҲ.LeftвүғRight P)

  opaque
    Type-coconeвҶҗspan-is-retraction
      : Type-coconeвҶҗspan
      вҲҳ spanвҶҗType-cocone
      ~ id
    Type-coconeвҶҗspan-is-retraction
      (mk-cocone P-left P-right filler)
      = ap (mk-cocone P-left P-right)
           (funextвҶ’ О» _ вҶ’ ap ua (вүғ-pathвҶ’ refl) вҲҷ ua-coeвүғ)

  opaque
    spanвҶҗType-cocone-is-section
      : spanвҶҗType-cocone вҲҳ Type-coconeвҶҗspan ~ id
    spanвҶҗType-cocone-is-section
      (mk-span-diagramбөҲ P-left P-right P-centre e-left e-right)
      = ap
        ( О» R
          вҶ’ mk-span-diagramбөҲ
              P-left
              P-right
              (R .cartesian-spanбөҲ.Centre)
              (R .cartesian-spanбөҲ.Leftвүғ)
              (R .cartesian-spanбөҲ.Rightвүғ))
        ( unap-equiv
          ( О -swap-cartesian-spanбөҲ P-left P-right ._вүғ_.fwd-is-equiv)
          ( funextвҶ’ О» s
            вҶ’ equiv-J
                ( О» P-left' e-left'
                  вҶ’ (e-right' : P-centre s вүғ P-right (Span.right S s))
                  вҶ’ Id
                    ( ОЈ[ P-centre' вҲ¶ Type рқ“ӣ ]
                      ( (P-centre' вүғ P-left')
                      Г— (P-centre' вүғ P-right (Span.right S s))))
                    ( P-left' , idвүғ , coeвүғ (ua (e-left' eвҒ»В№ вҲҷвүғ e-right')))
                    ( P-centre s , e-left' , e-right'))
                ( О» _ вҶ’ ОЈ-pathвҶ’ (refl , Г—-pathвҶ’ (refl , coeвүғ-ua вҲҷ вүғ-pathвҶ’ refl)))
                (P-left (Span.left S s))
                (e-left s)
                (e-right s)))

  spanвҶҗType-cocone-is-equiv
    : is-equiv spanвҶҗType-cocone
  spanвҶҗType-cocone-is-equiv
    = is-equivвҶҗqinv
        ( Type-coconeвҶҗspan
        , Type-coconeвҶҗspan-is-retraction
        , spanвҶҗType-cocone-is-section)

  Type-coconeвүғspan : Cocone S (Type рқ“ӣ) вүғ span-diagramбөҲ S рқ“ӣ рқ“ӣ рқ“ӣ
  Type-coconeвүғspan = mkвүғ spanвҶҗType-cocone spanвҶҗType-cocone-is-equiv
}
}

\subtree[fre-0002]{
\title{Descent for pushouts}
\taxon{Theorem}
\author{fredrikbakke}

\p{
Families over pushouts are equivalent to displayed cartesian span diagrams over their
pushout spans.
}

\agda{
module _ {рқ“Ө рқ“Ҙ рқ“Ұ рқ“ӣ} {S : Span рқ“Ө рқ“Ҙ рқ“Ұ} {X : Type рқ“ӣ} (c : Cocone S X) where

  spanвҶҗfamily-up-pushout
    : вҲҖ {рқ“ң} вҶ’ (X вҶ’ Type рқ“ң) вҶ’ span-diagramбөҲ S рқ“ң рқ“ң рқ“ң
  spanвҶҗfamily-up-pushout = spanвҶҗType-cocone вҲҳ cocone-map S c

module _
  {рқ“Ө рқ“Ҙ рқ“Ұ рқ“ӣ} {S : Span рқ“Ө рқ“Ҙ рқ“Ұ} {X : Type рқ“ӣ}
  {c : Cocone S X} (up-c : up-pushout S c)
  where

  descent-up-pushout
    : вҲҖ {рқ“ң} вҶ’ is-equiv (spanвҶҗfamily-up-pushout c {рқ“ң})
  descent-up-pushout
    = is-equiv-вҲҳ spanвҶҗType-cocone-is-equiv up-c

  descent-up-pushoutвүғ
    : вҲҖ {рқ“ң} вҶ’ (X вҶ’ Type рқ“ң) вүғ span-diagramбөҲ S рқ“ң рқ“ң рқ“ң
  descent-up-pushoutвүғ
    = mkвүғ (spanвҶҗfamily-up-pushout c) (descent-up-pushout)

module _
  {рқ“Ө рқ“Ҙ рқ“Ұ рқ“ӣ рқ“ң} {S : Span рқ“Ө рқ“Ҙ рқ“Ұ}
  {X : Type рқ“ӣ} {c : Cocone S X} (up-c : up-pushout S c)
  (P : span-diagramбөҲ S рқ“ң рқ“ң рқ“ң)
  (open span-diagramбөҲ)
  where

  uniqueness-descent-up-pushout
    : is-singleton (fibre (spanвҶҗfamily-up-pushout c) P)
  uniqueness-descent-up-pushout
    = has-singleton-fibresвҶҗis-equiv (descent-up-pushout up-c) P

  family-descent-up-pushout : X вҶ’ Type рқ“ң
  family-descent-up-pushout
    = uniqueness-descent-up-pushout .centre .fst

  compute-family-descent-up-pushout
    : spanвҶҗfamily-up-pushout c family-descent-up-pushout пјқ P
  compute-family-descent-up-pushout
    = uniqueness-descent-up-pushout .centre .snd

  compute-left-descent-up-pushout
    : (a : Span.Left S)
    вҶ’ family-descent-up-pushout (Cocone.p c a)
    вүғ P .Left a
  compute-left-descent-up-pushout
    = coeвүғ
    вҲҳ happly (ap span-diagramбөҲ.Left compute-family-descent-up-pushout)

  compute-right-descent-up-pushout
    : (b : Span.Right S)
    вҶ’ family-descent-up-pushout (Cocone.q c b)
    вүғ P .Right b
  compute-right-descent-up-pushout
    = coeвүғ
    вҲҳ happly (ap span-diagramбөҲ.Right compute-family-descent-up-pushout)

  compute-centre-descent-up-pushout
    : (s : Span.Centre S)
    вҶ’ family-descent-up-pushout (Cocone.p c (Span.left S s))
    вүғ P .Centre s
  compute-centre-descent-up-pushout
    = coeвүғ
    вҲҳ happly (ap span-diagramбөҲ.Centre compute-family-descent-up-pushout)
}
}

}

\subtree[stt-00DG]{
\taxon{Lemma}
\title{Precategories are left Segal}

\p{A [simplicial type](stt-00AC) is [Segal](stt-00AI) iff it
is [left Segal](stt-00DA).}

\proof{

\p{We factorise the defining map for left Segal types as follows:}

\quiver{
\begin{tikzcd}
	{\Lambda^2_1} && {\Delta^2} \\
	\\
	\\
	{1 \ltimes \Delta^1 \simeq \square +^{\Delta^1}1} && {\ttt +^{\Delta^1}1}
	\arrow["{\sim_{\textit{Segal}}}", from=1-1, to=1-3]
	\arrow[from=1-1, to=4-1]
	\arrow["{\sim_{\textit{Segal}}}", from=1-3, to=4-3]
	\arrow["{\sim_{\textit{simp}}}", from=4-3, to=4-1]
\end{tikzcd}
}

\p{The top map is a Segal equivalence by definition. Likewise the bottom map
is a simplicial equivalence, which follows from \ref{stt-00DC}. Finally,
\ref{stt-00DI} gives the right most map as a Segal equivalence.}
}

%```agda
\agda{
1‚čČőĒ¬Ļ‚Üźcone : Pushout {B = ‚Ė°^ 2} (_, i0) (! {A = őĒ¬Ļ}) ‚Üí ūĚüô ‚čČ őĒ¬Ļ
1‚čČőĒ¬Ļ‚Üźcone = Pushout‚āĀ
  (mk-span-map
    (őĽ (a , b) ‚Üí b , tt , a)
    (őĽ i ‚Üí ‚ąāőĒ¬Ļ-0 , tt , i)
    inl
    ~refl
    ~refl)

1‚čČőĒ¬Ļ-is-cone : quasi-iso 1‚čČőĒ¬Ļ‚Üźcone
1‚čČőĒ¬Ļ-is-cone .fst = ‚ÜĎ-rec (mk-right-cocone őĻ‚āā (őĻ‚āĀ ‚ąė (_, i1))
                           őĽ where (_ , i) ‚Üí mk-hom (őĻ‚āĀ ‚ąė (i ,_))
                                                    (glue i)
                                                    refl)
1‚čČőĒ¬Ļ-is-cone .snd .fst = pushout-ind _
  (mk-coconeŠĶą ~refl ~refl
    (őĽ i ‚Üí IdŠĶą-func‚ÜźSquare
               {f = (1‚čČőĒ¬Ļ-is-cone .fst ‚ąė 1‚čČőĒ¬Ļ‚Üźcone)} {id} (glue i) refl refl
               (Square-degen-hor _ _
                 (ap-‚ąė (1‚čČőĒ¬Ļ-is-cone .fst) 1‚čČőĒ¬Ļ‚Üźcone (glue i)
                 ‚ąô ap (ap (1‚čČőĒ¬Ļ-is-cone .fst)) (pushout-rec-apő≤ _ ‚ąô ‚ąô-reflr _)
                 ‚ąô pushout-rec-apő≤ _ ‚ąô sym (ap-id (glue i))))))
1‚čČőĒ¬Ļ-is-cone .snd .snd = pushout-ind _
  (mk-coconeŠĶą ~refl (‚äé-ind (~refl , (őĽ i ‚Üí glue (‚ąāőĒ¬Ļ-1 , tt , i))))
    őĽ { (mk-lift true , _ , i)
           ‚Üí IdŠĶą-func‚ÜźSquare (glue (‚ąāőĒ¬Ļ-1 , tt , i)) refl (glue (‚ąāőĒ¬Ļ-1 , tt , i))
               (coe
                 (Square-functorial-bot (sym (ap-id (glue (‚ąāőĒ¬Ļ-1 , _ , i)))))
                 (Square-flatten-vert
                   (sym (ap-‚ąė 1‚čČőĒ¬Ļ‚Üźcone (1‚čČőĒ¬Ļ-is-cone .fst) (glue _)
                   ‚ąô ap (ap 1‚čČőĒ¬Ļ‚Üźcone) (pushout-rec-apő≤ _)))))
      ; (mk-lift false , _ , i)
           ‚Üí IdŠĶą-func‚ÜźSquare (glue (‚ąāőĒ¬Ļ-0 , tt , i)) refl refl
               (Square-degen-hor _ _
                 (ap-‚ąė 1‚čČőĒ¬Ļ‚Üźcone (1‚čČőĒ¬Ļ-is-cone .fst) (glue (‚ąāőĒ¬Ļ-0 , tt , i))
                 ‚ąô ap (ap 1‚čČőĒ¬Ļ‚Üźcone) (pushout-rec-apő≤ _) ‚ąô pushout-rec-apő≤ _
                 ‚ąô ‚ąô-reflr _ ‚ąô sym (ap-id (glue _)))) })

‚ßÖ-‚Ė°-degen-incl
  : Pushout {B = ‚ßÖ} (őĻ‚āā ‚ąė (_, i0)) ! ‚Üí Pushout {B = ‚Ė°^ 2} (_, i0) !
‚ßÖ-‚Ė°-degen-incl
  = Pushout‚āĀ (mk-span-map ‚ßÖ-incl id id ~refl ~refl)

strong-segal-factorisation
  : 1‚čČőĒ¬Ļ‚Üźcone ‚ąė ‚ßÖ-‚Ė°-degen-incl ‚ąė ‚ßÖ-degen‚ÜźőĒ¬≤ ‚ąė őõ[2,1]-incl ~ weird-horn-inclusion
strong-segal-factorisation
  = pushout-rec-unique _ _
      ~refl
      (őĽ i ‚Üí glue (‚ąāőĒ¬Ļ-1 , tt , i))
      őĽ _ ‚Üí ap (_‚ąô glue (‚ąāőĒ¬Ļ-1 , tt , i0))
              ( ap-‚ąė (1‚čČőĒ¬Ļ‚Üźcone ‚ąė ‚ßÖ-‚Ė°-degen-incl ‚ąė ‚ßÖ-degen‚ÜźőĒ¬≤)
                     őõ[2,1]-incl (glue tt)
              ‚ąô ap (ap (1‚čČőĒ¬Ļ‚Üźcone ‚ąė ‚ßÖ-‚Ė°-degen-incl ‚ąė ‚ßÖ-degen‚ÜźőĒ¬≤))
                   (pushout-rec-apő≤ tt)
              ‚ąô ap-‚ąė őĻ‚āĀ _ őĒ¬≤-refl
              ‚ąô ap (ap őĻ‚āĀ) (is-set‚Üźis-truncated
                    (Trunc.√ó‚ąąS car-is-set (Trunc.√ó‚ąąS Trunc.ūĚüô‚ąąS car-is-set))
                     _ _ _ refl))


is-based-triangulated
  : ‚ąÄ {ūĚď§} {A : Type ūĚď§}
    ‚Üí  ‚ßÖ-incl ‚ä• A ‚Üí ‚ßÖ-‚Ė°-degen-incl ‚ä• A
is-based-triangulated {A = A} ttA
  = left-orthogonal-type-pushout‚āĀ map .snd (lem ‚ąė ev tt)  where
  -- A map colim(‚ßÖ ‚Üź őĒ¬Ļ ‚Üí ūĚüô) ‚Üí colim(‚Ė° ‚Üź őĒ¬Ļ ‚Üí ūĚüô)
  -- is equivalently a map in the coslice under őĒ¬Ļ from ‚ßÖ ‚Üí ‚Ė°
  map : Coslice-map {A = őĒ¬Ļ} (őĻ‚āā ‚ąė (_, i0)) (_, i0)
  map .fst = ‚ßÖ-incl
  map .snd = ~refl

  lem : ‚ąÄ x ‚Üí map ‚ä• (őĽ _ ‚Üí x)
  lem x = coslice-orthogonality map .fst ttA (őĽ _ ‚Üí x)

1‚čČőĒ¬Ļ‚ÜźőĒ¬≤-is-simplicial-equiv
  : is-precategory-equiv (1‚čČőĒ¬Ļ‚Üźcone ‚ąė ‚ßÖ-‚Ė°-degen-incl ‚ąė ‚ßÖ-degen‚ÜźőĒ¬≤)
1‚čČőĒ¬Ļ‚ÜźőĒ¬≤-is-simplicial-equiv {_} {Q} Qsi Qse
  = is-equiv-‚ąė
      {f = precomp Q ‚ßÖ-degen‚ÜźőĒ¬≤}
      {g = precomp Q ‚ßÖ-‚Ė°-degen-incl ‚ąė precomp Q 1‚čČőĒ¬Ļ‚Üźcone}
      (‚ßÖ-degen‚ÜźőĒ¬≤-is-segal-equiv Qse)
      (is-equiv-‚ąė
        (is-based-triangulated (simp-is-triangulated Qsi tt))
        (precomp-equiv (is-equiv‚Üźqiso 1‚čČőĒ¬Ļ-is-cone)))

opaque
  is-left-segal‚Üźis-segal
    : ‚ąÄ {ūĚď§} {A : Type ūĚď§} ‚Üí is-simplicial A ‚Üí is-segal A
      ‚Üí is-left-segal A
  is-left-segal‚Üźis-segal {A = A} asimp apc tt
    = is-equiv~‚ąė (őĽ h ‚Üí funext‚Üí őĽ a ‚Üí ap h (sym (strong-segal-factorisation a)))
        (apc tt)
        (1‚čČőĒ¬Ļ‚ÜźőĒ¬≤-is-simplicial-equiv asimp apc)

hom-fam-is-cov‚áĒis-precategory
  : ‚ąÄ {ūĚď§} {A : Type ūĚď§} ‚Üí is-simplicial A
    ‚Üí is-segal A ‚áĒ (‚ąÄ x ‚Üí is-covariant (Hom A x))
hom-fam-is-cov‚áĒis-precategory Asimp
  = (is-left-segal‚Üźis-segal Asimp , is-segal‚Üźis-left-segal)
  ‚ąô‚áĒ (hom-fam-is-cov‚áĒis-left-segal ‚áĒ‚ĀĽ¬Ļ)

coslice-is-left‚áĒis-precategory
  : ‚ąÄ {ūĚď§} {A : Type ūĚď§} ‚Üí is-simplicial A
    ‚Üí is-segal A ‚áĒ (‚ąÄ x ‚Üí is-left-fibration {A = Coslice A (őĽ (_ : ūĚüô) ‚Üí x)} fst)
coslice-is-left‚áĒis-precategory Asimp
  = hom-fam-is-cov‚áĒis-precategory Asimp
  ‚ąô‚áĒ postcomp-ő†-‚áĒ (őĽ a ‚Üí hom-fam-is-cov‚áĒis-left-fibration a)
}
%```
}

\subtree[stt-00GB]{
\title{Characterisation of the covariant action of #{\Hom}}
\date{2026-03-20}
\author{fredrikbakke}
\taxon{Theorem}

\p{
Given a [left Segal](stt-00DA) type #{A}, the covariant action of
the family #{(a : A) \mapsto \Hom_A(a,{-})} is given by postcomposition.
}

\proof{
\p{
By [covariance of representable families](stt-00D9), the family
#{\Hom_A(a,-)} is covariant. Since [left Segal](stt-00DA) types are
[Segal](stt-00AI) by \ref{stt-00DB}, composition is unique. For
composable morphisms #{f : \Hom_A(a,b)} and #{g : \Hom_A(b,c)}, choose a 2-simplex
#{\sigma} witnessing their composition. Restricting that 2-simplex along the map
#{(s,t) \mapsto (s,s \wedge t)} produces a dependent homotopy over #{g} from #{f} to
#{g \circ f}. Since covariant transport is defined as the centre of the contractible
type of such dependent lifts, this point must coincide with the transport of #{f}
along #{g}. Hence transporting along #{g} sends #{f} to #{g \circ f}, as claimed.
}
}

%```agda
\agda{
module CovariantActionPostcomp
  {ūĚď§ : Level} {A : Type ūĚď§} (Alseg : is-left-segal A)
  (let ūĚźī = is-segal‚Üźis-left-segal Alseg)
  where

  hom-fam-cov : (a : A) ‚Üí is-covariant (Hom A a)
  hom-fam-cov = hom-fam-is-cov‚áĒis-left-segal .snd Alseg

  tr-cov-hom-is-comp
    : {a b c : A}
      (g : Hom A b c) (f : Hom A a b)
    ‚Üí tr-cov-hom (hom-fam-cov _) g f
      ÔľĚ g ‚ąė[ ūĚźī ] f
  tr-cov-hom-is-comp {a} (mk-hom gh refl refl) f@(mk-hom fh refl fh1)
    = ap fst (hom-fam-cov a gh f .central (gf , comp-hov))
    where
    g = mk-hom gh refl refl
    gf = g ‚ąė[ ūĚźī ] f
    ŌÉ = ‚ąė[_]-is-composite {f = g} {g = f} ūĚźī

    bd : (x : ‚ąāőĒ¬≤) ‚Üí ŌÉ .fst (‚ąāőĒ¬≤-incl x) ÔľĚ make-‚ąāőĒ¬≤ g f gf x
    bd = happly (ŌÉ .snd)

    face2 : (s : őĒ¬Ļ) ‚Üí ŌÉ .fst (s , i0) ÔľĚ fh s
    face2 s = bd (őĻ‚āĀ (őĻ‚āĀ s))

    face0 : (t : őĒ¬Ļ) ‚Üí ŌÉ .fst (i1 , t) ÔľĚ gh t
    face0 t = bd (őĻ‚āĀ (őĻ‚āā t))

    diag : (s : őĒ¬Ļ) ‚Üí ŌÉ .fst (s , s) ÔľĚ gf .HomŠĶą.hom s
    diag s = bd (őĻ‚āā s)

    wedge-hom : (t : őĒ¬Ļ) ‚Üí Hom A (fh i0) (gh t)
    wedge-hom t = mk-hom
      (őĽ s ‚Üí ŌÉ .fst ((s , s ‚ąß t) ‚¶É ‚ąß-‚Č§-eliml auto! ‚¶Ą))
      (ap (ŌÉ .fst) (őĒ¬≤-ext (refl , 0-init)) ‚ąô face2 i0)
      (ap (ŌÉ .fst) (őĒ¬≤-ext (refl , ‚ąß-comm ‚ąô 1-top)) ‚ąô face0 t)

    horn-glue : őĻ‚āĀ {f = point i1} {g = point i0} i1
              ÔľĚ őĻ‚āā i0
    horn-glue = glue tt

    horn-cocone : Cocone (mk-span ūĚüô (point i1) (point i0)) A
    horn-cocone = mk-cocone fh gh (őĽ _ ‚Üí fh1 ‚ąô sym refl)

    diag-glue0
      : face2 i0
        ÔľĚ (ap (ŌÉ .fst ‚ąė ‚ąāőĒ¬≤-incl) (glue ‚ąāőĒ¬Ļ-0) ‚ąô diag i0) ‚ąô gf .HomŠĶą.hom0
    diag-glue0
      = sym (homotopy-cancel bd (glue ‚ąāőĒ¬Ļ-0))
      ‚ąô ap ((ap (ŌÉ .fst ‚ąė ‚ąāőĒ¬≤-incl) (glue ‚ąāőĒ¬Ļ-0) ‚ąô diag i0) ‚ąô_)
           (ap sym (pushout-rec-apő≤ ‚ąāőĒ¬Ļ-0)
           ‚ąô ap sym (‚ąô-refll (sym (gf .HomŠĶą.hom0)))
           ‚ąô sym-sym)

    diag-glue1
      : face0 i1
        ÔľĚ (ap (ŌÉ .fst ‚ąė ‚ąāőĒ¬≤-incl) (glue ‚ąāőĒ¬Ļ-1) ‚ąô diag i1) ‚ąô gf .HomŠĶą.hom1
    diag-glue1
      = sym (homotopy-cancel bd (glue ‚ąāőĒ¬Ļ-1))
      ‚ąô ap ((ap (ŌÉ .fst ‚ąė ‚ąāőĒ¬≤-incl) (glue ‚ąāőĒ¬Ļ-1) ‚ąô diag i1) ‚ąô_)
           (ap sym (pushout-rec-apő≤ ‚ąāőĒ¬Ļ-1)
           ‚ąô ap sym (‚ąô-refll (sym (gf .HomŠĶą.hom1)))
           ‚ąô sym-sym)

    comp-hov-hom0-path : Hom-path (wedge-hom i0) f
    comp-hov-hom0-path
      = ( (őĽ s ‚Üí ap (ŌÉ .fst) (őĒ¬≤-ext (refl , ‚ąß-comm ‚ąô 0-init)) ‚ąô face2 s)
        , ‚ąô-reflr _ ‚ąô ap (őĽ p ‚Üí ap (ŌÉ .fst) p ‚ąô face2 i0) (őĒ¬≤-is-set _ _ _ _)
        , ‚ąô-assoc (ap (ŌÉ .fst) (őĒ¬≤-ext (refl , ‚ąß-comm ‚ąô 0-init))) (face2 i1) fh1
          ‚ąô ap (ap (ŌÉ .fst) (őĒ¬≤-ext (refl , ‚ąß-comm ‚ąô 0-init)) ‚ąô_)
                (ap (face2 i1 ‚ąô_)
                    (sym (‚ąô-reflr fh1)
                    ‚ąô sym (pushout-rec-apő≤ {c = horn-cocone} tt)
                    ‚ąô ap-‚ąė (make-‚ąāőĒ¬≤ g f gf) ‚ąāőĒ¬≤‚Üźőõ[2,1] horn-glue)
                ‚ąô homotopy-natural bd (ap ‚ąāőĒ¬≤‚Üźőõ[2,1] horn-glue))
          ‚ąô sym (‚ąô-assoc (ap (ŌÉ .fst) (őĒ¬≤-ext (refl , ‚ąß-comm ‚ąô 0-init)))
                          (ap (ŌÉ .fst ‚ąė ‚ąāőĒ¬≤-incl) (ap ‚ąāőĒ¬≤‚Üźőõ[2,1] horn-glue))
                          (face0 i0))
          ‚ąô ap (_‚ąô face0 i0)
               (ap (ap (ŌÉ .fst) (őĒ¬≤-ext (refl , ‚ąß-comm ‚ąô 0-init)) ‚ąô_)
                    (ap-‚ąė (ŌÉ .fst) ‚ąāőĒ¬≤-incl (ap ‚ąāőĒ¬≤‚Üźőõ[2,1] horn-glue))
               ‚ąô sym (ap-‚ąô (ŌÉ .fst) (őĒ¬≤-ext (refl , ‚ąß-comm ‚ąô 0-init))
                                     (ap ‚ąāőĒ¬≤-incl (ap ‚ąāőĒ¬≤‚Üźőõ[2,1] horn-glue)))
               ‚ąô ap (ap (ŌÉ .fst)) (őĒ¬≤-is-set _ _ _ _)))

    comp-hov-hom1-path : Hom-path (wedge-hom i1) gf
    comp-hov-hom1-path
      = ( (őĽ s ‚Üí ap (ŌÉ .fst) (őĒ¬≤-ext (refl , 1-top)) ‚ąô diag s)
        , ‚ąô-assoc (ap (ŌÉ .fst) (őĒ¬≤-ext (refl , 1-top))) (diag i0) (gf .HomŠĶą.hom0)
          ‚ąô ap (_‚ąô (diag i0 ‚ąô gf .HomŠĶą.hom0))
               (ap (ap (ŌÉ .fst))
                   (őĒ¬≤-is-set _ _
                     (őĒ¬≤-ext (refl , 1-top))
                     (őĒ¬≤-ext (refl , 0-init) ‚ąô ap ‚ąāőĒ¬≤-incl (glue ‚ąāőĒ¬Ļ-0)))
               ‚ąô ap-‚ąô (ŌÉ .fst) (őĒ¬≤-ext (refl , 0-init)) (ap ‚ąāőĒ¬≤-incl (glue ‚ąāőĒ¬Ļ-0))
               ‚ąô ap (ap (ŌÉ .fst) (őĒ¬≤-ext (refl , 0-init)) ‚ąô_)
                    (sym (ap-‚ąė (ŌÉ .fst) ‚ąāőĒ¬≤-incl (glue ‚ąāőĒ¬Ļ-0))))
          ‚ąô ‚ąô-assoc (ap (ŌÉ .fst) (őĒ¬≤-ext (refl , 0-init)))
                    (ap (ŌÉ .fst ‚ąė ‚ąāőĒ¬≤-incl) (glue ‚ąāőĒ¬Ļ-0))
                    (diag i0 ‚ąô gf .HomŠĶą.hom0)
          ‚ąô ap (ap (ŌÉ .fst) (őĒ¬≤-ext (refl , 0-init)) ‚ąô_)
               (sym (‚ąô-assoc (ap (ŌÉ .fst ‚ąė ‚ąāőĒ¬≤-incl) (glue ‚ąāőĒ¬Ļ-0))
                             (diag i0) (gf .HomŠĶą.hom0))
               ‚ąô sym diag-glue0)
        , ‚ąô-assoc (ap (ŌÉ .fst) (őĒ¬≤-ext (refl , 1-top))) (diag i1) (gf .HomŠĶą.hom1)
          ‚ąô ap (_‚ąô (diag i1 ‚ąô gf .HomŠĶą.hom1))
               (ap (ap (ŌÉ .fst))
                   (őĒ¬≤-is-set _ _
                     (őĒ¬≤-ext (refl , 1-top))
                     (őĒ¬≤-ext (refl , ‚ąß-comm ‚ąô 1-top) ‚ąô ap ‚ąāőĒ¬≤-incl (glue ‚ąāőĒ¬Ļ-1)))
               ‚ąô ap-‚ąô (ŌÉ .fst)
                      (őĒ¬≤-ext (refl , ‚ąß-comm ‚ąô 1-top))
                      (ap ‚ąāőĒ¬≤-incl (glue ‚ąāőĒ¬Ļ-1))
               ‚ąô ap (ap (ŌÉ .fst) (őĒ¬≤-ext (refl , ‚ąß-comm ‚ąô 1-top)) ‚ąô_)
                    (sym (ap-‚ąė (ŌÉ .fst) ‚ąāőĒ¬≤-incl (glue ‚ąāőĒ¬Ļ-1))))
          ‚ąô ‚ąô-assoc (ap (ŌÉ .fst) (őĒ¬≤-ext (refl , ‚ąß-comm ‚ąô 1-top)))
                    (ap (ŌÉ .fst ‚ąė ‚ąāőĒ¬≤-incl) (glue ‚ąāőĒ¬Ļ-1))
                    (diag i1 ‚ąô gf .HomŠĶą.hom1)
          ‚ąô ap (ap (ŌÉ .fst) (őĒ¬≤-ext (refl , ‚ąß-comm ‚ąô 1-top)) ‚ąô_)
               (sym (‚ąô-assoc (ap (ŌÉ .fst ‚ąė ‚ąāőĒ¬≤-incl) (glue ‚ąāőĒ¬Ļ-1))
                             (diag i1) (gf .HomŠĶą.hom1))
               ‚ąô sym diag-glue1))

    comp-hov : HomŠĶą (Hom A (fh i0) ‚ąė gh) f gf
    comp-hov .HomŠĶą.hom = wedge-hom
    comp-hov .HomŠĶą.hom0 = Hom-ext‚Üí comp-hov-hom0-path
    comp-hov .HomŠĶą.hom1 = Hom-ext‚Üí comp-hov-hom1-path
}

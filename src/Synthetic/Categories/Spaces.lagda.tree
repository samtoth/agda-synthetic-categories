        {F = О» (F' , G' , Оұ') вҶ’ вҲҖ i вҶ’ is-equiv (Оұ' i)}
        {G = О» (F' , G' , Оұ') вҶ’ вҲҖ i вҶ’ is-equiv (Оұ' (point-О” i))}
        (О» _ вҶ’ precomp-О  _ point-О”)
        (О» {m} FGa вҶ’ {!lem {m} (О» x вҶ’ FGa x .fst)
                          (О» x вҶ’ FGa x .snd .fst)
                          (О» x вҶ’ FGa x .snd .snd) !})
        (F , G , Оұ))
  where
  @вҷӯ lem
    : вҲҖ {@вҷӯ m} (@вҷӯ F G : в–Ў^ m вҶ’ О”^ n вҶ’ Space рқ“Ө)

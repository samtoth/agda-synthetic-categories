\subtree[stt-009T]{
\title{Lattices}
\taxon{Definition}
\p{A lattice #{L} is an algebraic structure with a pair of commutative monoids
#{\wedge,\vee}, satisfying absorption laws.  Equivalently this
structure can be described by a poset, with operations taking binary meets
(#{\land}) and joins (#{\lor}) for each pair of elements.}

\agda{
record is-lattice {𝓤} {L : Type 𝓤} (0l 1l : L) (_∧_ : L → L → L)
                  (_∨_ : L → L → L) : Type 𝓤 where
  no-eta-equality
  field
    carrier-is-0-truncated : is-truncated 0 L
    ∧-assoc : {x y z : L} → x ∧ (y ∧ z) ＝ (x ∧ y) ∧ z
    ∨-assoc : {x y z : L} → x ∨ (y ∨ z) ＝ (x ∨ y) ∨ z
    ∧-comm : {x y : L} → x ∧ y ＝ y ∧ x
    ∨-comm : {x y : L} → x ∨ y ＝ y ∨ x
    ∨-∧-abs : {x y : L} → x ∨ (x ∧ y) ＝ x
    ∧-∨-abs : {x y : L} → x ∧ (x ∨ y) ＝ x
    0-bottom : {x : L} → x ∨ 0l ＝ x
    1-top    : {x : L} → x ∧ 1l ＝ x

  instance
    Carrier-is-truncated : ∀ {k} → Is-truncated (𝕋←ℕ k) L
    Carrier-is-truncated = truncation-instance _ carrier-is-0-truncated

  carrier-is-set : is-set L
  carrier-is-set = is-set←is-truncated carrier-is-0-truncated

record Lattice {ℓ} (L : Type ℓ) : Type ℓ where
  field
    0l 1l : L
    _∧_ : L → L → L
    _∨_ : L → L → L
    str-is-lattice : is-lattice 0l 1l (_∧_) (_∨_)
  infixr 40 _∧_
  infixr 35 _∨_

  _≤_ : L → L → Type ℓ
  x ≤ y = x ∧ y ＝ x

  open is-lattice str-is-lattice public

  1-coinit : ∀ {x} → x ∨ 1l ＝ 1l
  1-coinit {x}
    =   x ∨ 1l
      ＝⟨ ap (_∨ 1l) (sym 1-top ∙ ∧-comm) ⟩
        (1l ∧ x) ∨ 1l
      ＝⟨ ∨-comm ∙ ∨-∧-abs ⟩
        1l ∎

  0-init : ∀ {x} → 0l ∧ x ＝ 0l
  0-init {x}
    =   0l ∧ x
      ＝⟨ ap (0l ∧_) (sym (∨-comm ∙ 0-bottom)) ⟩
        (0l ∧ (0l ∨ x))
      ＝⟨ ∧-∨-abs ⟩
        0l ∎

  ∧-idem : ∀ {x : L} → x ∧ x ＝ x
  ∧-idem {x} = x ∧ x             ＝⟨ ap (x ∧_) (sym ∨-∧-abs) ⟩
               x ∧ (x ∨ (x ∧ x)) ＝⟨ ∧-∨-abs ⟩
               x ∎

  ∨-idem : ∀ {x : L} → x ∨ x ＝ x
  ∨-idem {x} = (x ∨ x)        ＝⟨ ap (x ∨_) (sym 1-top) ⟩
               (x ∨ (x ∧ 1l)) ＝⟨ ∨-∧-abs ⟩
               x ∎

  ∨-∧-abs' : ∀ {a b} → (a ∨ b) ∧ b ＝ b
  ∨-∧-abs' = ap (_∧ _) ∨-comm ∙ ∧-comm ∙ ∧-∨-abs

  ∧-∨-abs' : ∀ {a b} → (a ∧ b) ∨ b ＝ b
  ∧-∨-abs' = ap (_∨ _) ∧-comm ∙ ∨-comm ∙ ∨-∧-abs

  =∨←= : ∀ {a b} → a ＝ b → a ＝ a ∨ b
  =∨←= {a} {b} p = sym ∨-idem ∙ ap (a ∨_) p

  =∨'←= : ∀ {a b} → a ＝ b → a ＝ b ∨ a
  =∨'←= {a} {b} p = sym ∨-idem ∙ ap (_∨ a) p

  ≤-is-poset : is-poset (_≤_)
  ≤-is-poset =
    record { ≤-is-prop = ≤-is-prop
           ; ≤-refl = ≤-refl
           ; ≤-trans = ≤-trans
           ; ≤-antisym = ≤-antisym }
    where
      ≤-is-prop : {x y : L} → is-prop (x ≤ y)
      ≤-is-prop = carrier-is-set _ _

      ≤-refl : {x : L} → x ≤ x
      ≤-refl = ∧-idem

      ≤-trans : {x y z : L} → x ≤ y → y ≤ z → x ≤ z
      ≤-trans {x} {y} {z} p q =  x ∧ z        ＝⟨ ap (_∧ z) (sym p) ⟩
                                  (x ∧ y) ∧ z ＝⟨ sym ∧-assoc ⟩
                                  x ∧ (y ∧ z) ＝⟨ ap (x ∧_) q ⟩
                                  x ∧ y       ＝⟨ p ⟩
                                  x ∎

      ≤-antisym : {x y : L} → x ≤ y → y ≤ x → x ＝ y
      ≤-antisym {x} {y} p q = sym p ∙ ∧-comm ∙ q

  ≤-poset : Poset ℓ L
  ≤-poset = mk-poset {_≤_ = _≤_} ≤-is-poset

  open is-poset ≤-is-poset public

  ≤←＝ : ∀ {a b} → a ＝ b → a ≤ b
  ≤←＝ refl = ≤-refl

  ≥←＝ : ∀ {a b} → a ＝ b → b ≤ a
  ≥←＝ refl = ≤-refl

  ≤-max : ∀ {a b} → a ≤ b → a ∨ b ＝ b
  ≤-max {a} {b} p
    = a ∨ b             ＝⟨ ap (_∨ b) (sym p) ⟩
      (a ∧ b) ∨ b       ＝⟨ ∧-∨-abs' ⟩
      b ∎

  ≤-max' : ∀ {a b} → b ≤ a → a ∨ b ＝ a
  ≤-max' b≤a = ∨-comm ∙ ≤-max b≤a

  ≤←∨ : ∀ {a b} → a ∨ b ＝ b → a ≤ b
  ≤←∨ {a} {b} p
    = a ∧ b           ＝⟨ ap (a ∧_) (sym p) ⟩
      a ∧ (a ∨ b)     ＝⟨ ∧-∨-abs ⟩
      a ∎

  ∨-UP : ∀ {a b c} → a ≤ c × b ≤ c → (a ∨ b ≤ c)
  ∨-UP {a} {b} {c} (f , g)
    = ≤←∨ (sym ∨-assoc ∙ ≤-max (ap (a ∧_) (≤-max g) ∙ f) ∙ ≤-max g)

  ∨-UP-is-equiv : ∀ {a b c} → is-equiv (∨-UP {a} {b} {c})
  ∨-UP-is-equiv {a} {b} {c} = is-equiv←inverse
                    (×-is-prop (carrier-is-set _ _) (carrier-is-set _ _))
                    (carrier-is-set _ _)
                    λ x → ap (_∧ _) (sym (∧-∨-abs {a} {b}))
                          ∙ sym ∧-assoc ∙ ap (a ∧_) x
                          ∙ ∧-∨-abs
                        , ap (_∧ _) (sym (∧-∨-abs {b} {a}))
                          ∙ sym ∧-assoc
                          ∙ ap (b ∧_) (ap (_∧ c) ∨-comm ∙ x ∙ ∨-comm)
                          ∙ ∧-∨-abs

  ∨-≤-introl : ∀ {a b c} → a ≤ b → a ≤ (b ∨ c)
  ∨-≤-introl p = ≤-trans p ∧-∨-abs

  ∨-≤-intror : ∀ {a b c} → a ≤ c → a ≤ (b ∨ c)
  ∨-≤-intror p = ≤-trans p (ap (_ ∧_) ∨-comm ∙ ∧-∨-abs)

  ∧-UP : ∀ {a b c} → a ≤ b × a ≤ c → a ≤ b ∧ c
  ∧-UP (p , q) = ∧-assoc ∙ ap (_∧ _) p ∙ q

  ∧-≤-eliml : ∀ {a b c} → a ≤ c → (a ∧ b) ≤ c
  ∧-≤-eliml {a} {b} {c} p = ∧-comm ∙ ∧-assoc ∙ ap (_∧ b) (∧-comm ∙ p)

  ∧-≤-elimr : ∀ {a b c} → b ≤ c → (a ∧ b) ≤ c
  ∧-≤-elimr {a} {b} {c} q = sym ∧-assoc ∙ ap (a ∧_) q

  instance
    ≤-bot : ∀ {i} → 0l ≤ i
    ≤-bot = 0-init

    ≤-refl-inst : ∀ {i} → i ≤ i
    ≤-refl-inst = ≤-refl

    ≤-top = 1-top
    {-# INCOHERENT ≤-refl-inst ≤-top #-}

    ≤-∧
      : ∀ {a b c d} → ⦃ _ : a ≤ b ⦄ → ⦃ _ : c ≤ d ⦄
        → (a ∧ c) ≤ (b ∧ d)
    ≤-∧ = ∧-UP (∧-≤-eliml auto! , ∧-≤-elimr auto!)

    ≤-∨
      : ∀ {a b c d} → ⦃ _ : a ≤ b ⦄ → ⦃ _ : c ≤ d ⦄
        → (a ∨ c) ≤ (b ∨ d)
    ≤-∨ = ∨-UP (∨-≤-introl auto! , ∨-≤-intror auto!)
}
}

\subtree[stt-00A4]{
\title{Lattice homomorphisms}
\taxon{Definition}

\p{Given [lattice structures](stt-009T) #{L} and #{M} over sets #{A} and #{B}, we say
that a function #{f : A \to B} is a \strong{lattice homomorphism} when it
preserves the lattice operations. Being a lattice homomorphisms is a
[property](stt-0009) of a function.}

\agda{
record is-lattice-hom
        {𝓤} {𝓤'} {A : Type 𝓤} {B : Type 𝓤'}
        (L : Lattice A) (M : Lattice B) (f : A → B) : Type (𝓤 ⊔ 𝓤') where
  private
    module A = Lattice L
    module B = Lattice M
  field
    pres-∨ : {x y : A} → f (x A.∨ y) ＝ f x B.∨ f y
    pres-∧ : {x y : A} → f (x A.∧ y) ＝ f x B.∧ f y
    pres-0 : f A.0l ＝ B.0l
    pres-1 : f A.1l ＝ B.1l

  pres-≤ : {x y : A} → ⦃ x A.≤ y ⦄ → f x B.≤ f y
  pres-≤ ⦃ p ⦄ = sym pres-∧ ∙ ap f p

unquoteDecl lattice-hom-repr≊ lattice-hom-repr≃
  = make-record-repr lattice-hom-repr≊ lattice-hom-repr≃
                     (quote is-lattice-hom)

is-lattice-hom-∘
  : {𝓤 𝓥 𝓦 : Level}
    {A : Type 𝓤} {B : Type 𝓥} {C : Type 𝓦}
    {L : Lattice A} {M : Lattice B} {N : Lattice C}
    {g : B → C} → is-lattice-hom M N g
  → {f : A → B} → is-lattice-hom L M f
  → is-lattice-hom L N (g ∘ f)
is-lattice-hom-∘ {g = g} g-hom {f} f-hom =
  record { pres-∨ = ap g f.pres-∨ ∙ g.pres-∨
         ; pres-∧ = ap g f.pres-∧ ∙ g.pres-∧
         ; pres-0 = ap g f.pres-0 ∙ g.pres-0
         ; pres-1 = ap g f.pres-1 ∙ g.pres-1 }
  where
    module f = is-lattice-hom f-hom
    module g = is-lattice-hom g-hom


is-lattice-hom-is-prop
  : ∀ {𝓤 𝓥} {A : Type 𝓤} {B : Type 𝓥}
      (L : Lattice A) (M : Lattice B) (f : A → B)
    → is-prop (is-lattice-hom L M f)
is-lattice-hom-is-prop {A = A} {B} L M f
  = is-prop←equiv-to-prop
      (lattice-hom-repr≃ e⁻¹) (is-prop←is-truncated trunc!) where
   open Lattice L
   open Lattice M
}
}

\subtree[stt-009Z]{
\taxon{Definition}
\title{Lattice algebras and algebra morphisms}

\p{Fixing a lattice #{L}, we say that a lattice #{M} with a map of sets from
#{L} (that is - an object of the [coslice category](stt-0062) under #{L}) is a
lattice algebra if the underlying function is a
[lattice homomorphism](stt-009Y). Given a pair of coslices #{f} and #{g} under
#{L} which are lattice algebras, we say that a [coslice map](stt-0062) #{f \to
g} is a lattice algebra homomorphism if the underlying map is a
[lattice homomorphism](stt-009Y). }

\agda{
is-lattice-algebra
  : ∀ {𝓤 𝓥 : Level} {A : Type 𝓤} {B : Type 𝓥}
      (L : Lattice A) (M : Lattice B) (f : A → B)
    → Type (𝓤 ⊔ 𝓥)
is-lattice-algebra = is-lattice-hom


record Algebra {𝓤 𝓥} {A : Type 𝓤} (L : Lattice A) (B : Type 𝓥) : Type (𝓤 ⊔ 𝓥) where
  no-eta-equality
  field
    str-Lattice : Lattice B
    ι : A → B
    ι-alg : is-lattice-algebra L str-Lattice ι
  open Lattice str-Lattice public


Algebra-res
  : ∀ {𝓤 𝓥 𝓦}
      {X : Type 𝓤} {L : Lattice X}
      {Y : Type 𝓥} (A : Algebra L Y)
      {Z : Type 𝓦} (B : Algebra (A .Algebra.str-Lattice) Z)
    → Algebra L Z
Algebra-res A B =
  record
    { str-Lattice = B.str-Lattice
    ; ι = B.ι ∘ A.ι
    ; ι-alg = is-lattice-hom-∘ B.ι-alg A.ι-alg }
  where
    module A = Algebra A
    module B = Algebra B

opaque
  is-lattice-alg-hom
    : ∀ {𝓤 𝓥 𝓦} {A : Type 𝓤} {L : Lattice A}
        {B : Type 𝓥} (AB : Algebra L B)
        {C : Type 𝓦} (AC : Algebra L C)
      → Coslice-map (AB .Algebra.ι) (AC .Algebra.ι) → Type (𝓥 ⊔ 𝓦)
  is-lattice-alg-hom AB AC f =
    is-lattice-hom (AB .Algebra.str-Lattice) (AC .Algebra.str-Lattice) (fst f)

  mk-is-lattice-alg-hom
    : ∀ {𝓤 𝓥 𝓦} {A : Type 𝓤} {L : Lattice A}
        {B : Type 𝓥} {AB : Algebra L B}
        {C : Type 𝓦} {AC : Algebra L C}
      → {f : Coslice-map (AB .Algebra.ι) (AC .Algebra.ι)}
      → is-lattice-hom
          (AB .Algebra.str-Lattice)
          (AC .Algebra.str-Lattice)
          (fst f)
      → is-lattice-alg-hom AB AC f
  mk-is-lattice-alg-hom = id

  un-is-lattice-alg-hom
    : ∀ {𝓤 𝓥 𝓦} {A : Type 𝓤} {L : Lattice A}
        {B : Type 𝓥} {AB : Algebra L B}
        {C : Type 𝓦} {AC : Algebra L C}
      → {f : Coslice-map (AB .Algebra.ι) (AC .Algebra.ι)}
      → is-lattice-alg-hom AB AC f
      → is-lattice-hom
          (AB .Algebra.str-Lattice)
          (AC .Algebra.str-Lattice)
          (fst f)
  un-is-lattice-alg-hom = id

  is-lattice-alg-hom-is-prop
    : ∀ {𝓤 𝓥 𝓦} {A : Type 𝓤} {L : Lattice A}
        {B : Type 𝓥} {AB : Algebra L B}
        {C : Type 𝓦} {AC : Algebra L C}
        {f : Coslice-map (AB .Algebra.ι) (AC .Algebra.ι)}
      → is-prop (is-lattice-alg-hom AB AC f)
  is-lattice-alg-hom-is-prop = is-lattice-hom-is-prop _ _ _


LatticeAlgHom
  : ∀ {𝓤 𝓥 𝓦}
      {A : Type 𝓤} {L : Lattice A}
      {B : Type 𝓥} (AB : Algebra L B)
      {C : Type 𝓦} (AC : Algebra L C)
    → Type (𝓤 ⊔ 𝓥 ⊔ 𝓦)
LatticeAlgHom {B} AB {C} AC =
  Σ[ f ∶ Coslice-map (Algebra.ι AB) (Algebra.ι AC) ]
    (is-lattice-alg-hom AB AC f)
  where
    module AB = Algebra AB
    module AC = Algebra AC


LatticeAlgHom-id
  : ∀ {𝓤 𝓥}
      {X : Type 𝓤} {L : Lattice X}
      {B : Type 𝓥} (A : Algebra L B)
    → LatticeAlgHom A A
LatticeAlgHom-id A .fst .fst = id
LatticeAlgHom-id A .fst .snd = λ a → refl
LatticeAlgHom-id A .snd =
  mk-is-lattice-alg-hom
    (record { pres-∨ = refl
            ; pres-∧ = refl
            ; pres-0 = refl
            ; pres-1 = refl })


LatticeAlgHom-∘
  : ∀ {𝓤 𝓥 𝓦 𝓧}
      {A : Type 𝓤} {L : Lattice A}
      {B : Type 𝓥} {C : Type 𝓦} {D : Type 𝓧}
      {A1 : Algebra L B} {A2 : Algebra L C} {A3 : Algebra L D}
    → LatticeAlgHom A2 A3 → LatticeAlgHom A1 A2 → LatticeAlgHom A1 A3
LatticeAlgHom-∘ (g , b) (f , a) .fst = Coslice-map-∘ _ _ _ g f
LatticeAlgHom-∘ (g , b) (f , a) .snd =
  mk-is-lattice-alg-hom
    (is-lattice-hom-∘ (un-is-lattice-alg-hom b) (un-is-lattice-alg-hom a))
}
}

\subtree[stt-00TB]{
\taxon{Module}
\title{Identifying Algebra Homomorphisms}


\p{Being an algebra homomorphism is a property of a map, and hence
  there is an identity system identifying identities of algebra homomorphisms
  with the identities of the underlying maps.}

\agda{
is-LatticeAlgHom-equiv
  : ∀ {𝓤 𝓥 𝓦}
      {A : Type 𝓤} {L : Lattice A}
      {B : Type 𝓥} {C : Type 𝓦}
      {A1 : Algebra L B} {A2 : Algebra L C}
    → LatticeAlgHom A1 A2 → Type (𝓥  ⊔ 𝓦)
is-LatticeAlgHom-equiv (f , _) = is-coslice-equiv f

LatticeAlgHom-~
  : ∀ {𝓤 𝓥 𝓦}
      {A : Type 𝓤} {L : Lattice A}
      {B : Type 𝓥} {C : Type 𝓦}
      {A1 : Algebra L B} {A2 : Algebra L C}
    → LatticeAlgHom A1 A2 → LatticeAlgHom A1 A2 → Type (𝓥 ⊔ 𝓦)
LatticeAlgHom-~ ((p , _) , _) ((q , _) , _) = p ~ q


LatticeAlgHom-~＝
  : ∀ {𝓤 𝓥 𝓦}
      {A : Type 𝓤} {L : Lattice A}
      {B : Type 𝓥} {C : Type 𝓦}
      {A1 : Algebra L B} {A2 : Algebra L C}
      (p q :  LatticeAlgHom A1 A2)
    → p ＝ q → LatticeAlgHom-~  p q
LatticeAlgHom-~＝ p .p refl = λ a → refl


opaque
  LatticeAlgHom-~-is-torsorial
    : {𝓤 𝓥 𝓦 : Level}
      {A : Type 𝓤} {L : Lattice A}
      {B : Type 𝓥} {C : Type 𝓦}
      {A1 : Algebra L B} {A2 : Algebra L C}
    → (p : LatticeAlgHom A1 A2)
    → is-singleton (Σ[ q ∶ LatticeAlgHom A1 A2  ] (LatticeAlgHom-~ p q))
  LatticeAlgHom-~-is-torsorial p .centre = p , (λ a → refl)
  LatticeAlgHom-~-is-torsorial {A2 = A2} p .central (q , r) =
    ext! (((r
           , λ a → is-prop←is-truncated trunc! _ _)
           , is-lattice-alg-hom-is-prop _ _)
           , λ a → is-prop←is-truncated trunc! _ _)
    where
      open Algebra A2

instance
  LatticeAlgHom-equiv-IdS
    : ∀ {𝓤 𝓥 𝓦}
        {A : Type 𝓤} {L : Lattice A}
        {B : Type 𝓥} {C : Type 𝓦}
        {A1 : Algebra L B} {A2 : Algebra L C}
      → Identity-system (LatticeAlgHom A1 A2) (𝓥 ⊔ 𝓦)
  LatticeAlgHom-equiv-IdS .Identity-system.IdS
    = LatticeAlgHom-~
  LatticeAlgHom-equiv-IdS .Identity-system.IdS←Id
    = LatticeAlgHom-~＝ _ _
  LatticeAlgHom-equiv-IdS  .Identity-system.IdS←Id-is-equiv
    p  = fundamental-Id _ (LatticeAlgHom-~-is-torsorial p) _



LatticeAlgHom-quasi-inv
  : ∀ {𝓤 𝓥 𝓦}
      {A : Type 𝓤} {L : Lattice A}
      {B : Type 𝓥} {C : Type 𝓦}
      {A1 : Algebra L B} {A2 : Algebra L C}
    → LatticeAlgHom A1 A2 → Type (𝓤 ⊔ 𝓥 ⊔ 𝓦)
LatticeAlgHom-quasi-inv {A1 = A1} {A2} f =
  Σ[ g ∶ LatticeAlgHom A2 A1 ]
    ((LatticeAlgHom-∘ g f ＝ LatticeAlgHom-id A1)
      × (LatticeAlgHom-∘ f g ＝ LatticeAlgHom-id A2 ))

module _
  {𝓤 𝓥 𝓦}
  {A : Type 𝓤} {L : Lattice A}
  {B : Type 𝓥} {C : Type 𝓦}
  {A1 : Algebra L B} {A2 : Algebra L C}
  {f : LatticeAlgHom A1 A2}
  (fE : is-LatticeAlgHom-equiv f)
  (let module f = is-lattice-hom (un-is-lattice-alg-hom (f .snd)))
  (let module A1 = Algebra A1)
  (let module A2 = Algebra A2)
  (open Algebra A1 using (Carrier-is-truncated))
  (open Algebra A2 using (Carrier-is-truncated))
  (open is-equiv fE)
  (let fwd = f .fst .fst)
  (let H = f .fst .snd)
  where

  is-LatticeAlgHom-equiv-bwd : LatticeAlgHom A2 A1
  is-LatticeAlgHom-equiv-bwd .fst .fst = bwd
  is-LatticeAlgHom-equiv-bwd .fst .snd = bwd ◂ (H h⁻¹) ∙h η ▸ A1.ι
  is-LatticeAlgHom-equiv-bwd .snd = mk-is-lattice-alg-hom lhom
    where
      lhom : is-lattice-hom A2.str-Lattice A1.str-Lattice bwd
      lhom .is-lattice-hom.pres-∨ {x} {y}
        = bwd (x A2.∨ y) ＝⟨  ap bwd (ap₂ A2._∨_ (ε⁻¹ x) (ε⁻¹ y) )  ⟩
          bwd (fwd (bwd x) A2.∨ fwd (bwd y)) ＝⟨ ap bwd (sym f.pres-∨) ⟩
          bwd (fwd (bwd x A1.∨ bwd y)) ＝⟨ η _ ⟩
          bwd x A1.∨ bwd y ∎
      lhom .is-lattice-hom.pres-∧ {x} {y}
        = bwd (x A2.∧ y) ＝⟨  ap bwd (ap₂ A2._∧_ (ε⁻¹ x) (ε⁻¹ y) )  ⟩
          bwd (fwd (bwd x) A2.∧ fwd (bwd y)) ＝⟨ ap bwd (sym f.pres-∧) ⟩
          bwd (fwd (bwd x A1.∧ bwd y)) ＝⟨ η _ ⟩
          bwd x A1.∧ bwd y ∎
      lhom .is-lattice-hom.pres-0 = ap bwd (sym f.pres-0) ∙ η A1.0l
      lhom .is-lattice-hom.pres-1 = ap bwd (sym f.pres-1) ∙ η A1.1l

  quasi-inv←is-LatticeAlgHom-equiv : LatticeAlgHom-quasi-inv f
  quasi-inv←is-LatticeAlgHom-equiv .fst = is-LatticeAlgHom-equiv-bwd
  quasi-inv←is-LatticeAlgHom-equiv .snd .fst = ext! η
  quasi-inv←is-LatticeAlgHom-equiv .snd .snd = ext! ε
}
}

\subtree[stt-00UO]{
\title{Precomposition by equivalences of algebras}
\author{fredrikbakke}
\date{2026-06-26}

\agda{
module _
  {𝓤 𝓥 𝓦 𝓧}
  {A : Type 𝓤} {L : Lattice A}
  {B : Type 𝓥} {C : Type 𝓦} {D : Type 𝓧}
  {A1 : Algebra L B} {A2 : Algebra L C} {A3 : Algebra L D}
  where

  LatticeAlgHom-precomp
    : LatticeAlgHom A1 A2
    → LatticeAlgHom A2 A3
    → LatticeAlgHom A1 A3
  LatticeAlgHom-precomp f g
    = LatticeAlgHom-∘ g f

  LatticeAlgHom-precomp-is-equiv
    : (f : LatticeAlgHom A1 A2)
    → is-LatticeAlgHom-equiv f
    → is-equiv (LatticeAlgHom-precomp f)
  LatticeAlgHom-precomp-is-equiv f fE = is-equiv←qinv qinv
    where
    qinv : quasi-inv (LatticeAlgHom-precomp f)
    qinv .fst g
      = LatticeAlgHom-∘ g (quasi-inv←is-LatticeAlgHom-equiv {f = f} fE .fst)
    qinv .snd .fst g
      = ext! λ x
        → ap (λ ψ → g .fst .fst (ψ .fst .fst x))
             (quasi-inv←is-LatticeAlgHom-equiv {f = f} fE .snd .snd)
    qinv .snd .snd g
      = ext! λ x
        → ap (λ ψ → g .fst .fst (ψ .fst .fst x))
             (quasi-inv←is-LatticeAlgHom-equiv {f = f} fE .snd .fst)

  LatticeAlgHom-precomp≃
    : (f : LatticeAlgHom A1 A2)
    → is-LatticeAlgHom-equiv f
    → LatticeAlgHom A2 A3 ≃ LatticeAlgHom A1 A3
  LatticeAlgHom-precomp≃ f fE =
    mk≃ (LatticeAlgHom-precomp f) (LatticeAlgHom-precomp-is-equiv f fE)
}
}

\subtree[stt-00A0]{
\taxon{Theorem}
\title{The initial lattice algebra}

\p{The initial coslice (the identity function) is also the initial lattice
algebra.}

\agda{
initial-lattice-algebra
  : ∀ {𝓤} {A : Type 𝓤} (L : Lattice A)
    → is-lattice-algebra L L id
initial-lattice-algebra L .is-lattice-hom.pres-∨ = refl
initial-lattice-algebra L .is-lattice-hom.pres-∧ = refl
initial-lattice-algebra L .is-lattice-hom.pres-0 = refl
initial-lattice-algebra L .is-lattice-hom.pres-1 = refl

initial-Algebra
  : ∀ {𝓤} {A : Type 𝓤} (L : Lattice A)
    → Algebra L A
initial-Algebra L .Algebra.str-Lattice = L
initial-Algebra L .Algebra.ι           = id
initial-Algebra L .Algebra.ι-alg       = initial-lattice-algebra L

initial-Algebra-is-initial
  : ∀ {𝓤 𝓥} {A : Type 𝓤} (L : Lattice A)
      {X : Type 𝓥} (AX : Algebra L X)
    → is-singleton (LatticeAlgHom (initial-Algebra L) AX)
initial-Algebra-is-initial  L AX
  = mk-singl ((initial-coslice AX.ι .centre) , mk-is-lattice-alg-hom AX.ι-alg)
             (Σ-is-prop (is-prop←is-single (initial-coslice _))
                        (λ a → is-lattice-alg-hom-is-prop) _)
  where
    module AX = Algebra AX
}
}

\subtree[stt-009S]{
\title{Congruences}
\taxon{Definition}
\p{An equivalence relation #{\sim} on a lattice #{L} is a congruence if it
respects all lattice operations}

\agda{
module Congruence where


record LatticeCongruence {𝓤 𝓥} {A : Type 𝓤} (L : Lattice A)
                         (_~_ : A → A → Type 𝓥) : Type (𝓤 ⊔ 𝓥) where
  open Lattice L
  field
    ~-equivalence : is-equivalence-relation (_~_)
    ~-∨ : {a1 a2 b1 b2 : A} → a1 ~ b1 → a2 ~ b2 → a1 ∨ a2 ~ b1 ∨ b2
    ~-∧ : {a1 a2 b1 b2 : A} → a1 ~ b1 → a2 ~ b2 → a1 ∧ a2 ~ b1 ∧ b2

  open is-equivalence-relation (~-equivalence) public


module _ {𝓤} {𝓥} {A : Type 𝓤} {L : Lattice A} where
  open Lattice L

  data ⟪⟫-rel-untrunc (R : A → A → Type 𝓥) : A → A → Type (𝓤 ⊔ 𝓥) where
    ⟪⟫-inc  : {a b : A} → R a b → ⟪⟫-rel-untrunc R a b
    ⟪⟫-refl : {a : A} → ⟪⟫-rel-untrunc R a a
    ⟪⟫-sym  : {a b : A}
            → ⟪⟫-rel-untrunc R a b
            → ⟪⟫-rel-untrunc R b a
    ⟪⟫-trans : {a b c : A}
             → ⟪⟫-rel-untrunc R a b
             → ⟪⟫-rel-untrunc R b c
             → ⟪⟫-rel-untrunc R a c
    ⟪⟫-∨ : {a1 a2 b1 b2 : A}
         → ⟪⟫-rel-untrunc R a1 b1
         → ⟪⟫-rel-untrunc R a2 b2
         → ⟪⟫-rel-untrunc R (a1 ∨ a2) (b1 ∨ b2)
    ⟪⟫-∧ : {a1 a2 b1 b2 : A}
         → ⟪⟫-rel-untrunc R a1 b1
         → ⟪⟫-rel-untrunc R a2 b2
         → ⟪⟫-rel-untrunc R (a1 ∧ a2) (b1 ∧ b2)


  ⟪⟫-rel : (R : A → A → Type 𝓥) → (x y : A) → Type (𝓤 ⊔ 𝓥)
  ⟪⟫-rel R = λ x y → ║ ⟪⟫-rel-untrunc R x y ║

  ⟪_⟫ : (R : A → A → Type 𝓥)
                → LatticeCongruence L (⟪⟫-rel R)
  ⟪ R ⟫ = l-con where
    open LatticeCongruence
    open Trunc {n = -1}
    module E = is-equivalence-relation

    l-eq : is-equivalence-relation (⟪⟫-rel R)
    l-eq .E.~-is-prop = is-prop←is-truncated ○∈S
    l-eq .E.reflexive = η ⟪⟫-refl
    l-eq .E.symmetric a = do
      rxy ← a
      return (⟪⟫-sym rxy)
    l-eq .E.transitive a b = do
      rxy ← a
      ryz ← b
      return (⟪⟫-trans rxy ryz)

    l-con : LatticeCongruence L (⟪⟫-rel R)
    l-con .~-equivalence = l-eq
    l-con .~-∨ p q = do
      r1 ← p
      r2 ← q
      return (⟪⟫-∨ r1 r2)
    l-con .~-∧ p q = do
      r1 ← p
      r2 ← q
      return (⟪⟫-∧ r1 r2)
}
}


\subtree[stt-00A3]{
\title{Distributive lattices}
\taxon{Definition}

\agda{
record is-distributive {𝓤} {L : Type 𝓤} (Lat : Lattice L)  : Type 𝓤 where
  open Lattice Lat

  field
    distrib-∨-∧ : ∀ {x y z} → x ∨ (y ∧ z) ＝ (x ∨ y) ∧ (x ∨ z)

  distrib-∨-∧' : ∀ {x y z} → (x ∧ y) ∨ z ＝ (x ∨ z) ∧ (y ∨ z)
  distrib-∨-∧' = ∨-comm ∙ distrib-∨-∧ ∙ ap₂ (_∧_) ∨-comm ∨-comm

  distrib-∧-∨ : ∀ {x y z} → x ∧ (y ∨ z) ＝ (x ∧ y) ∨ (x ∧ z)
  distrib-∧-∨ {x} {y} {z}
    = ⌜ x ⌝ ∧ (y ∨ z)             ＝⟨ ap! (sym ∧-∨-abs) ⟩
      ((x ∧ (x ∨ z)) ∧ (y ∨ z))   ＝⟨ sym ∧-assoc ⟩
      (x ∧ (x ∨ z) ∧ (y ∨ z))     ＝⟨ ap₂ (_∧_)
                                         (sym ∨-∧-abs ∙ ∨-comm)
                                         (sym (distrib-∨-∧')) ⟩
      ((x ∧ y ∨ x) ∧ (x ∧ y ∨ z)) ＝⟨ sym distrib-∨-∧ ⟩
      ((x ∧ y) ∨ (x ∧ z)) ∎

  distrib-∧-∨' : ∀ {x y z} → (x ∨ y) ∧ z ＝ (x ∧ z) ∨ (y ∧ z)
  distrib-∧-∨' = ∧-comm ∙ distrib-∧-∨ ∙ ap₂ (_∨_) ∧-comm ∧-comm

  distrib₂-∧-∨
    : ∀ {x y z w}
      → x ∧ (y ∨ z ∨ w) ＝ x ∧ y ∨ x ∧ z ∨ x ∧ w
  distrib₂-∧-∨ {x} {y} {z} {w}
    = distrib-∧-∨ ∙ ap (x ∧ y ∨_) distrib-∧-∨

  distrib₂-∧-∨'
    : ∀ {x y z w}
      → (y ∨ z ∨ w) ∧ x ＝ y ∧ x ∨ z ∧ x ∨ w ∧ x
  distrib₂-∧-∨' {x} {y} {z} {w}
    = ∧-comm ∙ distrib₂-∧-∨ ∙ ap₃ (λ x y z → x ∨ (y ∨ z)) ∧-comm ∧-comm ∧-comm

  opaque
    polynomial-mult
      : ∀ {a₀ a₁ b₀ b₁} x →
          (a₀ ∨ (a₁ ∧ x)) ∧ (b₀ ∨ (b₁ ∧ x))
        ＝ (a₀ ∧ b₀) ∨ (((a₁ ∧ b₀) ∨ (a₀ ∧ b₁) ∨ (a₁ ∧ b₁)) ∧ x)
    polynomial-mult {a₀} {a₁} {b₀} {b₁} x
      = (a₀ ∨ a₁ ∧ x) ∧ (b₀ ∨ b₁ ∧ x)
          ＝⟨ distrib-∧-∨ ⟩
        ((a₀ ∨ a₁ ∧ x) ∧ b₀ ∨ ⌜ (a₀ ∨ a₁ ∧ x) ∧ b₁ ∧ x ⌝)
          ＝⟨ ap! (∧-assoc ∙ ap (_∧ x) distrib-∧-∨' ∙ distrib-∧-∨') ⟩
        ((a₀ ∨ a₁ ∧ x) ∧ b₀ ∨ (a₀ ∧ b₁) ∧ x ∨ ⌜ ((a₁ ∧ x) ∧ b₁) ∧ x ⌝)
          ＝⟨ ap! (ap (_∧ x) (sym ∧-assoc ∙ ap (a₁ ∧_) ∧-comm) ∙ sym ∧-assoc
                     ∙ ap (a₁ ∧_) (sym ∧-assoc ∙ ap (b₁ ∧_) ∧-idem)) ⟩
        (⌜ (a₀ ∨ a₁ ∧ x) ∧ b₀ ⌝ ∨ (a₀ ∧ b₁) ∧ x ∨ a₁ ∧ b₁ ∧ x)
          ＝⟨ ap! (distrib-∧-∨'
                 ∙ ap (a₀ ∧ b₀ ∨_) (sym ∧-assoc ∙ ap (a₁ ∧_) ∧-comm)) ⟩
        ((a₀ ∧ b₀ ∨ (a₁ ∧ b₀ ∧ x)) ∨ (a₀ ∧ b₁) ∧ x ∨ a₁ ∧ b₁ ∧ x)
          ＝⟨ ap₂ (_∨_) (ap (a₀ ∧ b₀ ∨_) ∧-assoc)
                      (ap ((a₀ ∧ b₁) ∧ x ∨_) ∧-assoc ∙ sym distrib-∧-∨') ⟩
        ((a₀ ∧ b₀) ∨ ((a₁ ∧ b₀) ∧ x)) ∨ (a₀ ∧ b₁ ∨ a₁ ∧ b₁) ∧ x
          ＝⟨ sym ∨-assoc ∙ ap (a₀ ∧ b₀ ∨_) (sym distrib-∧-∨') ⟩
        (a₀ ∧ b₀ ∨ (a₁ ∧ b₀ ∨ a₀ ∧ b₁ ∨ a₁ ∧ b₁) ∧ x) ∎

    polynomial-mult'
      : ∀ {a₀ a₁ b₀ b₁} x →
           ((a₀ ∧ x) ∨ a₁) ∧ ((b₀ ∧ x) ∨ b₁)
        ＝ (((a₀ ∧ b₁) ∨ (a₁ ∧ b₀) ∨ (a₀ ∧ b₀)) ∧ x) ∨ (a₁ ∧ b₁)
    polynomial-mult' {a₀} {a₁} {b₀} {b₁} x
      = ((a₀ ∧ x ∨ a₁) ∧ (b₀ ∧ x ∨ b₁))
          ＝⟨ ap₂ (_∧_) ∨-comm ∨-comm ⟩
        ((a₁ ∨ a₀ ∧ x) ∧ (b₁ ∨ b₀ ∧ x))
          ＝⟨ polynomial-mult x ⟩
        (a₁ ∧ b₁ ∨ (a₀ ∧ b₁ ∨ a₁ ∧ b₀ ∨ a₀ ∧ b₀) ∧ x)
          ＝⟨ ∨-comm ⟩
        ((a₀ ∧ b₁ ∨ a₁ ∧ b₀ ∨ a₀ ∧ b₀) ∧ x ∨ a₁ ∧ b₁) ∎

    polynomial-mult'-≤
      : ∀ {a₀ a₁ b₀ b₁} → ⦃ a₁ ≤ a₀ ⦄ → ⦃ b₁ ≤ b₀ ⦄ → ∀ x
        → ((a₀ ∧ x) ∨ a₁) ∧ ((b₀ ∧ x) ∨ b₁)
        ＝ ((a₀ ∧ b₀) ∧ x) ∨ (a₁ ∧ b₁)
    polynomial-mult'-≤ {a₀} {a₁} {b₀} {b₁} x
      = ((a₀ ∧ x) ∨ a₁) ∧ ((b₀ ∧ x) ∨ b₁)
          ＝⟨ polynomial-mult' x ⟩
        (⌜ (a₀ ∧ b₁) ∨ (a₁ ∧ b₀) ∨ (a₀ ∧ b₀) ⌝ ∧ x) ∨ (a₁ ∧ b₁)
          ＝⟨ ap! lemma ⟩
        ((a₀ ∧ b₀) ∧ x) ∨ (a₁ ∧ b₁) ∎
      where
      lemma : (a₀ ∧ b₁) ∨ (a₁ ∧ b₀) ∨ (a₀ ∧ b₀) ＝ (a₀ ∧ b₀)
      lemma
        = ((a₀ ∧ b₁) ∨ ⌜ (a₁ ∧ b₀) ∨ (a₀ ∧ b₀) ⌝)
            ＝⟨ ap! (≤-max auto!) ⟩
          ((a₀ ∧ b₁) ∨ (a₀ ∧ b₀))
            ＝⟨ ≤-max auto! ⟩
          (a₀ ∧ b₀) ∎

is-distributive-algebra
  : ∀ {𝓤 𝓥} {L : Type 𝓤} {Lat : Lattice L}
      {A : Type 𝓥} (Alg : Algebra Lat A) → Type 𝓥
is-distributive-algebra Alg = is-distributive (Algebra.str-Lattice Alg)

Dist-Algebra
  : ∀ {𝓤 𝓥} {L : Type 𝓤}
      (Lat : Lattice L) (A : Type 𝓥)
    → Type (𝓤 ⊔ 𝓥)
Dist-Algebra Lat A = Σ (Algebra Lat A) (is-distributive-algebra)
}
}

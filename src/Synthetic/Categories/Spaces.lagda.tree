      вҶ’ is-equiv (вҷӯ-map (precomp-О  (О» a вҶ’ is-equiv (Оұ (a .fst) (a .snd)))
                                   (total-map О» _ вҶ’ point-О”)))
  lem {m} F G Оұ
    = is-equivвҶҗinverse

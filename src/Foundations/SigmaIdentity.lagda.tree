\date{2025-02-24}
\title{Characterising identity in #{ОЈ}-types}
\taxon{Module}

\import{stt-macros}

\agda{
module Foundations.SigmaIdentity where

open import Foundations.Universes
open import Foundations.Sigma
open import Foundations.Identity
open import Foundations.DependentIdentity
open import Foundations.Functions
open import Foundations.Homotopy
open import Foundations.FunctionInverses
open import Foundations.Equivalences
open import Foundations.QuasiEquivalences
}


\subtree[stt-0025]{
\taxon{Theorem}
\title{Identity in [#{ОЈ}-types](stt-001A)}

\p{
Given two elements #{(x_1 , x_2) , (y_1 , y_2) : \Sigma_{(a:A)}B(a)}, we have
#{(x_1,x_2) = (y_1,y_2) \simeq \Sigma_{(p : x_1 = y_1)}(x_2 =_B^p y_2)}
}

\agda{
infix 6 _пјқОЈ_
_пјқОЈ_ : вҲҖ {рқ“Ө рқ“Ҙ} {A : Type рқ“Ө} {B : A вҶ’ Type рқ“Ҙ} вҶ’ ОЈ A B вҶ’ ОЈ A B вҶ’ Type (рқ“Ө вҠ” рқ“Ҙ)
_пјқОЈ_ {B = B} x y = ОЈ (x .fst пјқ y .fst) (О» p вҶ’ Idб¶  B p (x .snd) (y .snd))

ОЈ-path-refl : вҲҖ {рқ“Ө рқ“Ҙ} {A : Type рқ“Ө} {B : A вҶ’ Type рқ“Ҙ} {x : ОЈ A B} вҶ’ x пјқОЈ x
ОЈ-path-refl = (refl , refl)

JОЈ
  : вҲҖ {рқ“Ө рқ“Ҙ рқ“Ұ} {A : Type рқ“Ө} {B : A вҶ’ Type рқ“Ҙ} {x : ОЈ A B}
      (P : вҲҖ y вҶ’ x пјқОЈ y вҶ’ Type рқ“Ұ)
    вҶ’ P x ОЈ-path-refl
    вҶ’ вҲҖ {y} (q : x пјқОЈ y) вҶ’ P y q
JОЈ P pвӮҖ (refl , refl) = pвӮҖ

JОЈ-refl
  : вҲҖ {рқ“Ө рқ“Ҙ рқ“Ұ} {A : Type рқ“Ө} {B : A вҶ’ Type рқ“Ҙ} {x : ОЈ A B}
      (P : вҲҖ y вҶ’ x пјқОЈ y вҶ’ Type рқ“Ұ)
    вҶ’ {pвӮҖ : P x ОЈ-path-refl}
    вҶ’ JОЈ P pвӮҖ ОЈ-path-refl пјқ pвӮҖ
JОЈ-refl P = refl

ОЈ-path-fst
  : вҲҖ {рқ“Ө рқ“Ҙ} {A : Type рқ“Ө} {B : A вҶ’ Type рқ“Ҙ} {x y : ОЈ A B}
    вҶ’ x пјқ y вҶ’ x .fst пјқ y .fst
ОЈ-path-fst refl = refl

ОЈ-path-snd
  : вҲҖ {рқ“Ө рқ“Ҙ} {A : Type рқ“Ө} {B : A вҶ’ Type рқ“Ҙ} {x y : ОЈ A B}
    вҶ’ (p : x пјқ y) вҶ’ Idб¶  B (ap fst p) (x .snd) (y .snd)
ОЈ-path-snd refl = refl

ОЈ-path
  : вҲҖ {рқ“Ө рқ“Ҙ} {A : Type рқ“Ө} {B : A вҶ’ Type рқ“Ҙ} {x y : ОЈ A B}
    вҶ’ (x пјқОЈ y) вүғ (x пјқ y)
ОЈ-path {B = B} {x = x1 , x2} {y1 , y2}
  = equivвҶҗqequiv (mkвүҠ to-path (from-path , ret , sec)) module ОЈ-path where
  to-path : ОЈ (x1 пјқ y1) (О» p вҶ’ Idб¶  B p x2 y2) вҶ’ Id (ОЈ _ B) (x1 , x2) (y1 , y2)
  to-path (refl , refl) = refl

  from-path : (x1 , x2) пјқ (y1 , y2) вҶ’ (x1 , x2) пјқОЈ (y1 , y2)
  from-path p = (ap fst p , ОЈ-path-snd p)

  sec : section-witness to-path from-path
  sec refl = refl

  ret : retraction-witness to-path from-path
  ret (refl , refl) = refl

ОЈ-pathвҶ’
  : вҲҖ {рқ“Ө рқ“Ҙ} {A : Type рқ“Ө} {B : A вҶ’ Type рқ“Ҙ} {x y : ОЈ A B}
    вҶ’ x пјқОЈ y вҶ’ (x пјқ y)
ОЈ-pathвҶ’ = ОЈ-path ._вүғ_.fwd

{-# DISPLAY ОЈ-path.to-path = ОЈ-pathвҶ’ #-}

ОЈ-path-ap-fst
  : вҲҖ {рқ“Ө рқ“Ҙ} {A : Type рқ“Ө} {B : A вҶ’ Type рқ“Ҙ} {x y : ОЈ A B}
      {p : x .fst пјқ y .fst}
      {q : IdбөҲ (ap B p) (x .snd) (y .snd)}
    вҶ’ ap fst (ОЈ-pathвҶ’ (p , q)) пјқ p
ОЈ-path-ap-fst {p = refl} {refl} = refl

ОЈ-path-ap-fstsnd
  : вҲҖ {рқ“Ө рқ“Ҙ рқ“Ұ} {A : Type рқ“Ө} {A' : Type рқ“Ҙ} {B : A вҶ’ A' вҶ’ Type рқ“Ұ}
      {x : A} {a b : A'}
      {y : B x a} {y' : B x b}
    вҶ’ (p : a пјқ b) вҶ’ (q : IdбөҲ (ap (B x) p) y y')
    вҶ’ ap {A = ОЈ[ a вҲ¶ A ] ОЈ A' (B a)} (fst вҲҳ snd) (ОЈ-pathвҶ’ (refl , ОЈ-pathвҶ’ (p , q)))
    пјқ p
ОЈ-path-ap-fstsnd refl refl = refl

ОЈ-path-ap-snd
  : вҲҖ {рқ“Ө рқ“Ҙ} {A : Type рқ“Ө} {B : A вҶ’ Type рқ“Ҙ} {x : A}
    вҶ’ {y y' : B x}
    вҶ’ {q : y пјқ y'}
    вҶ’ ap snd (ОЈ-pathвҶ’ {x = x , y} (refl , q)) пјқ q
ОЈ-path-ap-snd {q = refl} = refl
}
}

\subtree[stt-0026]{
\taxon{Corollary}
\title{Paths in [products](stt-001C)}

\agda{
infix 6 _пјқГ—_
_пјқГ—_ : вҲҖ {рқ“Ө рқ“Ҙ} {A : Type рқ“Ө} {B : Type рқ“Ҙ} вҶ’ A Г— B вҶ’ A Г— B вҶ’ Type (рқ“Ө вҠ” рқ“Ҙ)
x пјқГ— y =  (x .fst пјқ y .fst) Г— (x .snd пјқ y .snd)

Г—-path-refl : вҲҖ {рқ“Ө рқ“Ҙ} {A : Type рқ“Ө} {B : Type рқ“Ҙ} {x : A Г— B} вҶ’ x пјқГ— x
Г—-path-refl = (refl , refl)

JГ—
  : вҲҖ {рқ“Ө рқ“Ҙ рқ“Ұ} {A : Type рқ“Ө} {B : Type рқ“Ҙ} {x : A Г— B}
      (P : вҲҖ y вҶ’ x пјқГ— y вҶ’ Type рқ“Ұ)
    вҶ’ P x Г—-path-refl
    вҶ’ вҲҖ {y} (q : x пјқГ— y) вҶ’ P y q
JГ— P pвӮҖ (refl , refl) = pвӮҖ

JГ—-refl
  : вҲҖ {рқ“Ө рқ“Ҙ рқ“Ұ} {A : Type рқ“Ө} {B : Type рқ“Ҙ} {x : A Г— B}
      (P : вҲҖ y вҶ’ x пјқГ— y вҶ’ Type рқ“Ұ)
    вҶ’ {pвӮҖ : P x Г—-path-refl}
    вҶ’ JГ— P pвӮҖ Г—-path-refl пјқ pвӮҖ
JГ—-refl P = refl

Г—-path
  : вҲҖ {рқ“Ө рқ“Ҙ} {A : Type рқ“Ө} {B : Type рқ“Ҙ} {x y : A Г— B}
    вҶ’ (x пјқГ— y) вүғ (x пјқ y)
Г—-path {x = (x , x')} {y , y'} = equivвҶҗqequiv (mkвүҠ f q) where
  f : (x пјқ y) Г— (x' пјқ y') вҶ’ (x , x') пјқ (y , y')
  f (refl , refl) = refl

  q : quasi-inv f
  q .fst refl = refl , refl
  q .snd .fst (refl , refl) = refl
  q .snd .snd refl = refl

Г—-pathвҶ’ : вҲҖ {рқ“Ө рқ“Ҙ} {A : Type рқ“Ө} {B : Type рқ“Ҙ} {x y : A Г— B} вҶ’ (x пјқГ— y) вҶ’ (x пјқ y)
Г—-pathвҶ’ = Г—-path ._вүғ_.fwd

Г—-path-ap-fst
  : вҲҖ {рқ“Ө рқ“Ҙ} {A : Type рқ“Ө} {B : Type рқ“Ҙ} {x y : A Г— B}
    вҶ’ {p : x .fst пјқ y .fst} {q : x .snd пјқ y .snd}
    вҶ’ ap fst (Г—-pathвҶ’ (p , q)) пјқ p
Г—-path-ap-fst {p = refl} {refl} = refl

Г—-path-ap-snd
  : вҲҖ {рқ“Ө рқ“Ҙ} {A : Type рқ“Ө} {B : Type рқ“Ҙ} {x y : A Г— B}
    вҶ’ {p : x .fst пјқ y .fst} {q : x .snd пјқ y .snd}
    вҶ’ ap snd (Г—-pathвҶ’ (p , q)) пјқ q
Г—-path-ap-snd {p = refl} {refl} = refl

Г—~
  : вҲҖ {рқ“Ө рқ“Ө' рқ“Ҙ рқ“Ҙ'} {A : Type рқ“Ө} {A' : Type рқ“Ө'} {B : Type рқ“Ҙ} {B' : Type рқ“Ҙ'}
      {f g : A вҶ’ A'} {h k : B вҶ’ B'}
    вҶ’ ((f ~ g) Г— (h ~ k)) вҶ’ ((f вҠ— h) ~ (g вҠ— k))
Г—~ (L , R) (a , b) = Г—-pathвҶ’ (L a , R b)

ap-вҠ—-Г—-path
  : {рқ“Ө рқ“Ҙ рқ“Ұ рқ“ң : Level}
    {A : Type рқ“Ө} {B : Type рқ“Ҙ}
    {C : Type рқ“Ұ} {D : Type рқ“ң}
    {f : A вҶ’ B} {g : C вҶ’ D}
    {x y : A Г— C}
    (p : x .fst пјқ y .fst)
    (q : x .snd пјқ y .snd)
  вҶ’ ap (f вҠ— g) (Г—-pathвҶ’ (p , q))
  пјқ Г—-pathвҶ’ (ap f p , ap g q)
ap-вҠ—-Г—-path refl refl = refl
}
}

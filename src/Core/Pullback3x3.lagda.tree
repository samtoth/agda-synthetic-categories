\title{The 3x3 lemma for Pullbacks}
\taxon{Module}
\date{2026-04-18}
\import{stt-macros}


%```agda
\agda{
{-# OPTIONS --lossy-unification #-}
module Core.Pullback3x3 where

open import Foundations.Prelude

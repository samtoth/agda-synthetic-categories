\taxon{Module}
\date{2025-04-18}
\title{Sigma representations for records}

\import{stt-macros}

\agda{
module Ergonomics.Representation where
}

\agda-imports{
\agda{
open import Foundations.Universes
open import Foundations.List
open import Foundations.Unit
open import Foundations.Sigma
open import Foundations.Equivalences
open import Foundations.QuasiEquivalences

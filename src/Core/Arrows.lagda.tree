\subtree[stt-0038]{
\taxon{Definition}
\title{Walking morphisms in #{\Type}}
\date{2025-04-18}
\author{samueltoth}
\contributor{fredrikbakke}

\p{
An \em{arrow} of types is the bundled data of a function of types. I.e., it is
the data consisting of two types #{A}, #{B}, and a function between them
#{f : A \to B}.
}

\agda{
record Arrow (рЭУ§ рЭУ• : Level) : Type (lsuc рЭУ§ вКФ lsuc рЭУ•) where
  constructor mk-arrow
  no-eta-equality
  field
    {dom} : Type рЭУ§
    {cod} : Type рЭУ•
    f : dom вЖТ cod
}
}

\subtree[stt-00EF]{
\taxon{Definition}
\date{2026-02-20}
\title{Dependent morphisms of arrows}

\p{
Given an arrow #{f : A \to B}, a \em{dependent arrow} over #{f} is a family of arrows
over its domain, #{g : (b : B) \to X(b) \to Y(b)}. Given such a dependent arrow, then a
\em{dependent morphism of arrows} is a pair of dependent functions
#{i : (b : B) \to Y(b)} and #{j : (a : A) \to X (f(a))} so that #{i \circ f \sim g \circ j}.
}

\agda{
module _
  {рЭУ§1 рЭУ§2 рЭУ§3 рЭУ§4 : Level}
  {A : Type рЭУ§1}
  {B : Type рЭУ§2}
  (f : A вЖТ B)
  {X : B вЖТ Type рЭУ§3}
  {Y : B вЖТ Type рЭУ§4}
  (g : (b : B) вЖТ X b вЖТ Y b)
  where

  record Arrow-ќ† : Type (рЭУ§1 вКФ рЭУ§2 вКФ рЭУ§3 вКФ рЭУ§4) where
    constructor mk-amap
    field
      top : (a : A) вЖТ X (f a)
      bot : (b : B) вЖТ Y b
      comm : precomp-ќ† Y f bot ~ postcomp-ќ† (ќї a вЖТ g (f a)) top

  unquoteDecl Arrow-ќ†-reprвЙК Arrow-ќ†-reprвЙГ
    = make-record-repr Arrow-ќ†-reprвЙК Arrow-ќ†-reprвЙГ (quote Arrow-ќ†)
}
}

\subtree[stt-003U]{
\taxon{Definition}
\title{Morphisms of arrows}

\p{
Given a pair of arrows, we define a morphism between them to be a commutative square,
that is, a pair of a maps and a homotopy witnessing that the square commutes.
}

\agda{
module _
  {рЭУ§ рЭУ• рЭУ¶ рЭУЫ}
  {A : Type рЭУ§} {B : Type рЭУ•} (f : A вЖТ B)
  {C : Type рЭУ¶} {D : Type рЭУЫ} (f' : C вЖТ D)
  where

  Arrow-map : Type (рЭУ§ вКФ рЭУ• вКФ рЭУ¶ вКФ рЭУЫ)
  Arrow-map = Arrow-ќ† f (ќї _ вЖТ f')

  Arrow-map-reprвЙК : Arrow-map вЙК _
  Arrow-map-reprвЙК = Arrow-ќ†-reprвЙК f (ќї _ вЖТ f')

  Arrow-map-reprвЙГ : Arrow-map вЙГ _
  Arrow-map-reprвЙГ = Arrow-ќ†-reprвЙГ f (ќї _ вЖТ f')

module Arrow-map = Arrow-ќ†
}
}

\subtree[stt-00EG]{
\taxon{Theorem}
\date{2026-02-20}
\title{The type of dependent morphisms of arrows as a pullback}
\author{fredrikbakke}

\p{The type #{\Hom^{\mathrm{d}}(f,g)} is the pullback of #{g \circ {-}} and
#{{-} \circ f}.}

\agda{
module _
  {рЭУ§1 рЭУ§2 рЭУ§3 рЭУ§4 : Level}
  {A : Type рЭУ§1}
  {B : Type рЭУ§2}
  {f : A вЖТ B}
  {X : B вЖТ Type рЭУ§3}
  {Y : B вЖТ Type рЭУ§4}
  {g : (b : B) вЖТ X b вЖТ Y b}
  where

  Arrow-ќ†-cone
    : Cone (mk-cospan ((a : A) вЖТ Y (f a))
                      (precomp-ќ† Y f)
                      (postcomp-ќ† (ќї a вЖТ g (f a))))
           (Arrow-ќ† f g)
  Arrow-ќ†-cone .Cone.i p = Arrow-ќ†.bot p
  Arrow-ќ†-cone .Cone.j p = Arrow-ќ†.top p
  Arrow-ќ†-cone .Cone.filler p = funextвЖТ (Arrow-ќ†.comm p)

  Arrow-ќ†вЙГpullback-repr
    : Arrow-ќ† f g
    вЙГ Pullback (precomp-ќ† Y f) (postcomp-ќ† (ќї a вЖТ g (f a)))
  Arrow-ќ†вЙГpullback-repr
    = Arrow-ќ† f g
        вЙГвЯ® Arrow-ќ†-reprвЙГ f g вЯ©
      ќ£[ t вИґ ((a : A) вЖТ X (f a)) ]
      ќ£[ b вИґ ((b : B) вЖТ Y b) ]
       (precomp-ќ† Y f b ~ postcomp-ќ† (ќї a вЖТ g (f a)) t)
        вЙГвЯ® ќ£-comm вЯ©
      ќ£[ b вИґ ((b : B) вЖТ Y b) ]
      ќ£[ t вИґ ((a : A) вЖТ X (f a)) ]
       (precomp-ќ† Y f b ~ postcomp-ќ† (ќї a вЖТ g (f a)) t)
        вЙГвЯ® ќ£-snd-вЙГ (ќї _ вЖТ ќ£-snd-вЙГ ќї _ вЖТ (funextвЙГ eвБї¬є)) вЯ©
      Pullback (precomp-ќ† Y f) (postcomp-ќ† (ќї a вЖТ g (f a)))
        вЙГвИО

  Arrow-ќ†вЙГpullback-repr~gap
    : Arrow-ќ†вЙГpullback-repr ._вЙГ_.fwd ~ gap Arrow-ќ†-cone
  Arrow-ќ†вЙГpullback-repr~gap = ~refl

  Arrow-ќ†-is-pullback : is-pullback Arrow-ќ†-cone
  Arrow-ќ†-is-pullback
    = is-equivвЖР~вБї¬є
        (Arrow-ќ†вЙГpullback-repr~gap)
        (Arrow-ќ†вЙГpullback-repr ._вЙГ_.fwd-is-equiv)

  Arrow-ќ†вЙГpullback
    : Arrow-ќ† f g
    вЙГ Pullback (precomp-ќ† Y f) (postcomp-ќ† (ќї a вЖТ g (f a)))
  Arrow-ќ†вЙГpullback
    = mkвЙГ (gap Arrow-ќ†-cone) (Arrow-ќ†-is-pullback)
}
}

\subtree[stt-004H]{
\taxon{Theorem}
\date{2025-05-17}
\title{The type of morphisms of arrows as a pullback}

\p{The type #{\Hom(f,g)} is the pullback of #{g \circ {-}} and #{{-} \circ f}.}

\agda{
module _ {рЭУ§ рЭУ•} {A : Type рЭУ§} {B : Type рЭУ•} {f : A вЖТ B}
         {рЭУ¶ рЭУЫ} {C : Type рЭУ¶} {D : Type рЭУЫ} {g : C вЖТ D} where

  Arrow-mapвЙГpullback' : Arrow-map f g вЙГ Pullback (_вИШ f) (g вИШ_)
  Arrow-mapвЙГpullback' = Arrow-ќ†вЙГpullback {f = f} {g = ќї _ вЖТ g}

  Arrow-mapвЙГpullback : Arrow-map f g вЙГ Pullback (g вИШ_) (_вИШ f)
  Arrow-mapвЙГpullback = Arrow-mapвЙГpullback' вИЩe pullback-swap

  pullbackвЖРarrow' : Arrow-map f g вЖТ Pullback (_вИШ f) (g вИШ_)
  pullbackвЖРarrow' = Arrow-mapвЙГpullback' ._вЙГ_.fwd

  pullbackвЖРarrow : Arrow-map f g вЖТ Pullback (g вИШ_) (_вИШ f)
  pullbackвЖРarrow = Arrow-mapвЙГpullback ._вЙГ_.fwd

  arrowвЖРpullback' : Pullback (_вИШ f) (g вИШ_) вЖТ Arrow-map f g
  arrowвЖРpullback' = _вЙГ_.bwd Arrow-mapвЙГpullback'

  arrowвЖРpullback : Pullback (g вИШ_) (_вИШ f) вЖТ Arrow-map f g
  arrowвЖРpullback = _вЙГ_.bwd Arrow-mapвЙГpullback

  arrowвЖРpullback-is-equiv : is-equiv (arrowвЖРpullback)
  arrowвЖРpullback-is-equiv
    = is-equivвБї¬є (_вЙГ_.fwd-is-equiv Arrow-mapвЙГpullback)
}
}

\subtree[stt-004I]{
\title{Characterising the paths of morphisms of arrows}
\taxon{Theorem}

\agda{
module _ {рЭУ§ рЭУ•} {A : Type рЭУ§} {B : Type рЭУ•} {f : A вЖТ B}
         {рЭУ¶ рЭУЫ} {C : Type рЭУ¶} {D : Type рЭУЫ} {f' : C вЖТ D} where

  Arrow-map-path : вИА (G H : Arrow-map f f') вЖТ Type (рЭУ§ вКФ рЭУ• вКФ рЭУ¶ вКФ рЭУЫ)
  Arrow-map-path (mk-amap t b H) (mk-amap t' b' H')
    = ќ£[ p вИґ t ~ t' ] ќ£[ q вИґ b ~ b' ]
      (H вИЩh (f' вЧВ p) ~ q вЦЄ f вИЩh H')

  Arrow-map-path-refl : {G : Arrow-map f f'} вЖТ Arrow-map-path G G
  Arrow-map-path-refl = ~refl , ~refl , вИЩh-reflr _

  Arrow-map-path-is-Rppred
    : вИА (G : Arrow-map f f')
      вЖТ Reflexive-ppred _ G _
  Arrow-map-path-is-Rppred G = (Arrow-map-path G) , Arrow-map-path-refl

  Arrow-map-pathвЖРid : вИА {G H : Arrow-map f f'} вЖТ (G пЉЭ H) вЖТ Arrow-map-path G H
  Arrow-map-pathвЖРid refl = Arrow-map-path-refl

  opaque
    Arrow-map-pathвЙГ : вИА (G H : Arrow-map f f') вЖТ (G пЉЭ H) вЙГ Arrow-map-path G H
    Arrow-map-pathвЙГ G@(mk-amap t b h) H
      = mkвЙГ Arrow-map-pathвЖРid
            (fundamental-Id
              (Arrow-map-path G)
              (is-singleвЖРequiv-to-single
                (ќ£-fst-вЙГ (Arrow-map-reprвЙГ _ _ eвБї¬є))
                (is-singleton-structureвЖРparts (SingS-is-single t)
                  (t , ~refl)
                  (is-singleton-structureвЖРparts (SingS-is-single b)
                    (b , ~refl)
                    (SingS-is-single ќї a вЖТ h a вИЩ refl))))
              (ќї _ вЖТ Arrow-map-pathвЖРid) H)

    Arrow-map-pathвЖТ
      : вИА {G H : Arrow-map f f'} вЖТ Arrow-map-path G H
        вЖТ (G пЉЭ H)
    Arrow-map-pathвЖТ = _вЙГ_.bwd (Arrow-map-pathвЙГ _ _)

    Arrow-map-pathвЖТ-refl
      : вИА {G : Arrow-map f f'}
        вЖТ Arrow-map-pathвЖТ (Arrow-map-path-refl {G = G}) пЉЭ refl
    Arrow-map-pathвЖТ-refl
      = unap-equiv (Arrow-map-pathвЙГ _ _ ._вЙГ_.fwd-is-equiv)
                   (is-equiv.ќµ (Arrow-map-pathвЙГ _ _ ._вЙГ_.fwd-is-equiv) _)
}
}

\subtree[stt-003X]{
\taxon{Theorem}
\title{Arrows and squares form a category}

\agda{
id-square
  : вИА {рЭУ§ рЭУ•} {A : Type рЭУ§} {B : Type рЭУ•} {f : A вЖТ B}
    вЖТ Arrow-map f f
id-square = mk-amap id id ~refl

infix 25 id-square:_
id-square:_ : вИА {рЭУ§ рЭУ•} {A : Type рЭУ§} {B : Type рЭУ•} (f : A вЖТ B) вЖТ Arrow-map f f
id-square: f = id-square
{-# INLINE id-square:_ #-}

module _ {рЭУ§ рЭУ•} {A : Type рЭУ§} {B : Type рЭУ•} {f : A вЖТ B}
         {рЭУ§' рЭУ•'} {A' : Type рЭУ§'} {B' : Type рЭУ•'} {f' : A' вЖТ B'}
         {рЭУ§'' рЭУ•''} {A'' : Type рЭУ§''} {B'' : Type рЭУ•''} {f'' : A'' вЖТ B''} where

  paste-squares
    : Arrow-map f' f''
    вЖТ Arrow-map f f'
    вЖТ Arrow-map f f''
  paste-squares (mk-amap g' h' comm') (mk-amap g h comm)
    = mk-amap (g' вИШ g) (h' вИШ h) (h' вЧВ comm вИЩh comm' вЦЄ g)
}
}

\subtree[stt-00LU]{
\title{Associativity and unit laws for pasting squares}
\taxon{Lemma}
\author{fredrikbakke}
\date{2026-04-05}

\agda{
paste-squares-assoc
  : {рЭУ§1 рЭУ•1 рЭУ§2 рЭУ•2 рЭУ§3 рЭУ•3 рЭУ§4 рЭУ•4 : Level}
    {A1 : Type рЭУ§1} {B1 : Type рЭУ•1} {f1 : A1 вЖТ B1}
    {A2 : Type рЭУ§2} {B2 : Type рЭУ•2} {f2 : A2 вЖТ B2}
    {A3 : Type рЭУ§3} {B3 : Type рЭУ•3} {f3 : A3 вЖТ B3}
    {A4 : Type рЭУ§4} {B4 : Type рЭУ•4} {f4 : A4 вЖТ B4}
  вЖТ (H : Arrow-map f3 f4)
  вЖТ (G : Arrow-map f2 f3)
  вЖТ (F : Arrow-map f1 f2)
  вЖТ Arrow-map-path
    (paste-squares H (paste-squares G F))
    (paste-squares (paste-squares H G) F)
paste-squares-assoc H G F .fst = ~refl
paste-squares-assoc H G F .snd .fst = ~refl
paste-squares-assoc H G F .snd .snd a
  = let
      p = Arrow-map.comm F a
      q = Arrow-map.comm G (Arrow-map.top F a)
      r = Arrow-map.comm H (Arrow-map.top G (Arrow-map.top F a))
    in вИЩ-reflr _
     вИЩ ap (_вИЩ r) (ap-вИЩ (Arrow-map.bot H) (ap (Arrow-map.bot G) p) q)
     вИЩ вИЩ-assoc
         (ap (Arrow-map.bot H) (ap (Arrow-map.bot G) p))
         (ap (Arrow-map.bot H) q)
         (r)
     вИЩ ap
         (_вИЩ ap (Arrow-map.bot H) q вИЩ r)
         (sym (ap-вИШ (Arrow-map.bot H) (Arrow-map.bot G) p))

paste-squares-left-id
  : {рЭУ§1 рЭУ•1 рЭУ§2 рЭУ•2 : Level}
    {A1 : Type рЭУ§1} {B1 : Type рЭУ•1} {f : A1 вЖТ B1}
    {A2 : Type рЭУ§2} {B2 : Type рЭУ•2} {g : A2 вЖТ B2}
  вЖТ (F : Arrow-map f g)
  вЖТ Arrow-map-path (paste-squares (id-square: g) F) F
paste-squares-left-id F .fst = ~refl
paste-squares-left-id F .snd .fst = ~refl
paste-squares-left-id F .snd .snd a
  = вИЩ-reflr _
  вИЩ вИЩ-reflr _
  вИЩ ap-id (Arrow-map.comm F a)

paste-squares-right-id
  : {рЭУ§1 рЭУ•1 рЭУ§2 рЭУ•2 : Level}
    {A1 : Type рЭУ§1} {B1 : Type рЭУ•1} {f : A1 вЖТ B1}
    {A2 : Type рЭУ§2} {B2 : Type рЭУ•2} {g : A2 вЖТ B2}
  вЖТ (F : Arrow-map f g)
  вЖТ Arrow-map-path (paste-squares F (id-square: f)) F
paste-squares-right-id F .fst = ~refl
paste-squares-right-id F .snd .fst = ~refl
paste-squares-right-id F .snd .snd a = вИЩ-reflr _
}
}



\subtree[stt-002Z]{
\taxon{Theorem}
\title{Arrow morphisms are squares}

\p{We now have (at least) three things that can be called squares. We give functions
to convert from arrow-map squares, to either cones over cospans or cocones over spans.}

\agda{
CoconeвЖРArrow-map
  : вИА {рЭУ§ рЭУ•} {A : Type рЭУ§} {B : Type рЭУ•} {f : A вЖТ B}
      {рЭУ¶ рЭУЫ} {C : Type рЭУ¶} {D : Type рЭУЫ} {f' : C вЖТ D}
    вЖТ Arrow-map f f' вЖТ ќ£[ S вИґ  Span рЭУ§ рЭУ• рЭУ¶ ] Cocone S D
CoconeвЖРArrow-map {f = f} {f' = f'} (mk-amap g g' comm)
  = (mk-span _ f g) , mk-cocone g' f' comm

Arrow-mapвЖРCocone
  : вИА {рЭУ§ рЭУ• рЭУ¶ рЭУЬ} {S : Span рЭУ§ рЭУ• рЭУ¶} {D : Type рЭУЬ}
    вЖТ (C : Cocone S D)
    вЖТ Arrow-map (Span.left S) (Cocone.q C)
Arrow-mapвЖРCocone {S = S} C = mk-amap S.right C.p C.filler where
  module S = Span S
  module C = Cocone C

ConeвЖРArrow-map
  : вИА {рЭУ§ рЭУ•} {A : Type рЭУ§} {B : Type рЭУ•} {f : A вЖТ B}
      {рЭУ¶ рЭУЫ} {C : Type рЭУ¶} {D : Type рЭУЫ} {f' : C вЖТ D}
    вЖТ Arrow-map f f' вЖТ ќ£[ S вИґ Cospan рЭУЫ рЭУ• рЭУ¶ ] Cone S A
ConeвЖРArrow-map {f = f} {f' = f'} (mk-amap top bot comm)
  = (mk-cospan _ bot f') , mk-cone f top comm
}
}

\subtree[stt-004E]{
\taxon{Definition}

\title{(co)gap maps from squares}

\agda{
gap-mapвЖРsquare
  : вИА {рЭУ§ рЭУ•} {A : Type рЭУ§} {B : Type рЭУ•} {f : A вЖТ B}
      {рЭУ¶ рЭУЫ} {C : Type рЭУ¶} {D : Type рЭУЫ} {f' : C вЖТ D}
    вЖТ (g : Arrow-map f f')
    вЖТ A вЖТ Pullback (g .Arrow-map.bot) f'
gap-mapвЖРsquare g = gap (ConeвЖРArrow-map g .snd)

cogap-mapвЖРsquare
  : вИА {рЭУ§ рЭУ•} {A : Type рЭУ§} {B : Type рЭУ•} {f : A вЖТ B}
      {рЭУ¶ рЭУЫ} {C : Type рЭУ¶} {D : Type рЭУЫ} {f' : C вЖТ D}
    вЖТ (g : Arrow-map f f')
    вЖТ Pushout f (g .Arrow-map.top) вЖТ D
cogap-mapвЖРsquare g = cogap (CoconeвЖРArrow-map g .snd)
}
}


\subtree[stt-003P]{
\taxon{Definition}
\title{Squares from pre/post-composition}

\p{Given a square of the form:}

\quiver{
\begin{tikzcd}
	A && C \\
	\\
	B && D
	\arrow["g", from=1-1, to=1-3]
	\arrow["f"', from=1-1, to=3-1]
	\arrow["{f'}", from=1-3, to=3-3]
	\arrow["{g'}"', from=3-1, to=3-3]
\end{tikzcd}
}

\p{For all types #{Q}, we obtain squares:}

\quiver{
\begin{tikzcd}
	{Q \to A} && {Q \to C} \\
	\\
	{Q \to B} && {Q \to D}
	\arrow["{g \circ {-}}", from=1-1, to=1-3]
	\arrow["{f \circ {-}}"', from=1-1, to=3-1]
	\arrow["{f' \circ {-}}", from=1-3, to=3-3]
	\arrow["{g' \circ {-}}"', from=3-1, to=3-3]
\end{tikzcd}
}

\p{and}

\quiver{
\begin{tikzcd}
	{D \to Q} && {B \to Q} \\
	\\
	{C \to Q} && {A \to Q}
	\arrow["{{-} \circ g'}", from=1-1, to=1-3]
	\arrow["{{-} \circ f'}"', from=1-1, to=3-1]
	\arrow["{{-} \circ f'}", from=1-3, to=3-3]
	\arrow["{{-} \circ g}"', from=3-1, to=3-3]
\end{tikzcd}
}

\agda{
precomp-square
  : вИА {рЭУ§ рЭУ• рЭУ¶ рЭУЬ}
      {A : Type рЭУ§} {B : Type рЭУ•} {f : A вЖТ B}
      {C : Type рЭУ¶} {D : Type рЭУЬ} {f' : C вЖТ D}
      (g : Arrow-map f f')
    вЖТ вИА {рЭУЫ} (C : Type рЭУЫ) вЖТ Arrow-map (precomp C f') (precomp C f)
precomp-square (mk-amap top bot p) C
 = mk-amap (_вИШ bot) (_вИШ top) ќї f вЖТ funextвЖТ (f вЧВ (p hвБї¬є))

postcomp-square
  : вИА {рЭУ§ рЭУ• рЭУ¶ рЭУЬ}
      {A : Type рЭУ§} {B : Type рЭУ•} {f : A вЖТ B}
      {C : Type рЭУ¶} {D : Type рЭУЬ} {f' : C вЖТ D}
      (g : Arrow-map f f')
    вЖТ вИА {рЭУЫ} (C : Type рЭУЫ) вЖТ Arrow-map (postcomp C f) (postcomp C f')
postcomp-square (mk-amap top bot p) C
  = mk-amap (top вИШ_) (bot вИШ_) ќї f вЖТ funextвЖТ (p вЦЄ f)
}
}

\remark{
\p{Precomposing squares gives the result of applying the functor
#{\Hom(Q,H)} to the square. It is a well known result that this functor preserves
pullback Likewise, postcomposition is given by #{\Hom({-},Q)}, and this functor turns
pushouts in to pullbacks.
}
}


\subtree[stt-00SC]{
\taxon{Construction}
\title{Transposition of squares}

\agda{
transpose-square
  : вИА {рЭУ§ рЭУ• рЭУ¶ рЭУЬ} {A : Type рЭУ§} {B : Type рЭУ•}
      {C : Type рЭУ¶} {D : Type рЭУЬ}
      {f : A вЖТ B} {g : C вЖТ D}
    вЖТ (F : Arrow-map f g)
    вЖТ Arrow-map (F .Arrow-map.top) (F .Arrow-map.bot)
transpose-square {f = f} {g = g} F
  = mk-amap f g (F .Arrow-map.comm hвБї¬є)

transpose-square-involution
  : вИА {рЭУ§ рЭУ• рЭУ¶ рЭУЬ} {A : Type рЭУ§} {B : Type рЭУ•}
      {C : Type рЭУ¶} {D : Type рЭУЬ}
      {f : A вЖТ B} {g : C вЖТ D}
    вЖТ (F : Arrow-map f g)
    вЖТ transpose-square (transpose-square F) пЉЭ F
transpose-square-involution F@(mk-amap top bot comm)
  = Arrow-map-pathвЖТ (~refl , ~refl , ќї a вЖТ вИЩ-reflr _ вИЩ sym-sym)
}
}


\subtree[stt-00BR]{
\title{Total squares}
\taxon{Construction}

\p{Given a family of squares, we can define the total square by taking the
sum types and total maps between them.}

\agda{
total-square
  : вИА {рЭУШ рЭУ§ рЭУ• рЭУ¶ рЭУЬ} {I : Type рЭУШ}
      {A : I вЖТ Type рЭУ§} {B : I вЖТ Type рЭУ•} {f : (i : I) вЖТ A i вЖТ B i}
      {C : I вЖТ Type рЭУ¶} {D : I вЖТ Type рЭУЬ} {g : (i : I) вЖТ C i вЖТ D i}
    вЖТ (F : (i : I) вЖТ Arrow-map (f i) (g i))
    вЖТ Arrow-map (total-map f) (total-map g)
total-square F .Arrow-map.top = total-map (Arrow-map.top вИШ F)
total-square F .Arrow-map.bot = total-map (Arrow-map.bot вИШ F)
total-square F .Arrow-map.comm (i , a)
  = ќ£-pathвЖТ (refl , Arrow-map.comm (F i) a)
}
}

\subtree[stt-00BY]{
\title{Dependent precomposition square}
\taxon{Construction}

\p{Given a family of squares #{F_i : f_i \to g_i}, we can form the product square
#{\Pi_i F_i : \Pi_i f_i \to \Pi_i g_i}}

\agda{
ќ†-square
  : вИА {рЭУШ рЭУ§ рЭУ• рЭУ¶ рЭУЬ} {I : Type рЭУШ}
      {A : I вЖТ Type рЭУ§} {B : I вЖТ Type рЭУ•} {f : (i : I) вЖТ A i вЖТ B i}
      {C : I вЖТ Type рЭУ¶} {D : I вЖТ Type рЭУЬ} {g : (i : I) вЖТ C i вЖТ D i}
    вЖТ (F : (i : I) вЖТ Arrow-map (f i) (g i))
    вЖТ Arrow-map (postcomp-ќ† f) (postcomp-ќ† g)
ќ†-square F .Arrow-map.top h i = Arrow-map.top (F i) (h i)
ќ†-square F .Arrow-map.bot h i = Arrow-map.bot (F i) (h i)
ќ†-square F .Arrow-map.comm h  = funextвЖТ (ќї a вЖТ Arrow-map.comm (F a) (h a))
}
}

\subtree[stt-00K7]{
\title{Paths in maps of families}
\taxon{Lemma}

\agda{
opaque
  Fam-map-homotopy-is-torsorial
    : вИА {рЭУ§ рЭУ• рЭУ¶ рЭУЬ} {F@(A , X) : Fam рЭУ§ рЭУ•} {G@(B , Y) : Fam рЭУ¶ рЭУЬ }
      вЖТ вИА (a : Fam-map F G)
      вЖТ is-singleton (ќ£ _ (Fam-map-homotopy {F = F} {G} a))
  Fam-map-homotopy-is-torsorial a
    = is-singleton-structureвЖРparts
        (SingS-is-single (a .fst))
        (_ , ~refl)
        (is-singleвЖРequiv-to-single
          (ќ£-ќ†-swapвЙГ _ _)
          (ќ†-is-single (ќї x вЖТ SingS-is-single (a .snd x))))

instance
  Fam-map-IdS
    : вИА {рЭУ§ рЭУ• рЭУ¶ рЭУЬ} {F : Fam рЭУ§ рЭУ•} {G : Fam рЭУ¶ рЭУЬ}
      вЖТ Identity-system (Fam-map F G) (рЭУ§ вКФ рЭУ• вКФ рЭУ¶ вКФ рЭУЬ)
  Fam-map-IdS .Identity-system.IdS = Fam-map-homotopy
  Fam-map-IdS .Identity-system.IdSвЖРId refl = Fam-map-refl~ _
  Fam-map-IdS .Identity-system.IdSвЖРId-is-equiv a
    = fundamental-Id _ (Fam-map-homotopy-is-torsorial a) _
}
}

\subtree[stt-00KQ]{
\title{Straightening arrow maps}
\taxon{Lemma}

\p{We show that there is an equivalence between maps of arrows
and maps of families.}

\agda{
module _
  {рЭУ§ рЭУ• рЭУ¶ рЭУЬ}
  {A : Type рЭУ§} {B : Type рЭУ•} {f : A вЖТ B}
  {X : Type рЭУ¶} {Y : Type рЭУЬ} {g : X вЖТ Y}
  where

  arrow-fibre
    : (gs : Arrow-map f g)
    вЖТ (b : B)
    вЖТ fibre f b вЖТ fibre g (gs .Arrow-map.bot b)
  arrow-fibre (mk-amap f' g' hom) b (a , p) = (f' a , sym (hom a) вИЩ ap g' p)

  fam-mapвЖРarrow-map
    : Arrow-map f g вЖТ Fam-map (fibre-fam f) (fibre-fam g)
  fam-mapвЖРarrow-map F = (F .Arrow-map.bot , arrow-fibre F)

  arrow-mapвЖРfam-map
    : Fam-map (fibre-fam f) (fibre-fam g)
    вЖТ Arrow-map f g
  arrow-mapвЖРfam-map (b , t)
    = mk-amap (ќї a вЖТ t (f a) (a , refl) .fst) b
              (ќї a вЖТ sym (t (f a) (a , refl) .snd))

  fam-mapвЖРarrow-map-is-equiv : is-equiv fam-mapвЖРarrow-map
  fam-mapвЖРarrow-map-is-equiv
    = is-equivвЖРqinv
        ( arrow-mapвЖРfam-map
        , (ќї x вЖТ Arrow-map-pathвЖТ (~refl , ~refl ,
                                 (  вИЩh-reflr _
                                 вИЩh (ap sym вИШ вИЩh-reflr _)
                                 вИЩh (ќї _ вЖТ sym-sym))))
        , section-fam-arr) where
    section-fam-arr
      : fam-mapвЖРarrow-map вИШ arrow-mapвЖРfam-map ~ id
    section-fam-arr (b , t)
      = ќ£-pathвЖТ (refl ,
          (funextвЖТ (ќї a вЖТ funextвЖТ
            (ќї where (x , refl) вЖТ ќ£-pathвЖТ (refl , (вИЩ-reflr _ вИЩ sym-sym))))))
}
}

\subtree[stt-00OB]{
\title{Half-straightened arrow maps}
\taxon{Definition}

\p{Given a map #{f : A \to B}, and a type family #{P : C \to \Type}, we define the
type of maps from #{f} to #{P}, which consists of the data:}

\ul{
\li{A map #{b : B \to A}}
\li{A section #{t : \Pi_{a} P(b(f(a))) }}
}

\agda{
record ArrFam-map
         {рЭУ§ рЭУ• рЭУ¶ рЭУЬ} {A : Type рЭУ§} {B : Type рЭУ•}
         {C : Type рЭУ¶} (f : A вЖТ B)
         (P : C вЖТ Type рЭУЬ) : Type (рЭУЬ вКФ рЭУ• вКФ рЭУ§ вКФ рЭУ¶) where
  constructor mk-afmap
  field
    bot : B вЖТ C
    top : вИА a вЖТ P (bot (f a))

unquoteDecl ArrFam-map-reprвЙК ArrFam-map-reprвЙГ
  = make-record-repr ArrFam-map-reprвЙК ArrFam-map-reprвЙГ (quote ArrFam-map)
}
}

\subtree[stt-00OC]{
\taxon{Lemma}

\p{A [half-straightened](stt-00OB) map from a map #{f} to a type family #{P} is equivalent
to an arrow map from #{f} to the unstraightening of #{P}.}

\agda{
unstr-ArrFam
  : вИА {рЭУ§ рЭУ• рЭУ¶ рЭУЬ} {A : Type рЭУ§} {B : Type рЭУ•} {f : A вЖТ B}
      {C : Type рЭУ¶} {P : C вЖТ Type рЭУЬ}
    вЖТ ArrFam-map f P вЖТ Arrow-map f (fst: P)
unstr-ArrFam {f = f} F .Arrow-ќ†.top a = (_ , F .ArrFam-map.top a)
unstr-ArrFam F .Arrow-ќ†.bot = F .ArrFam-map.bot
unstr-ArrFam F .Arrow-ќ†.comm = ~refl

str-ArrFam
  : вИА {рЭУ§ рЭУ• рЭУ¶ рЭУЬ} {A : Type рЭУ§} {B : Type рЭУ•} {f : A вЖТ B}
      {C : Type рЭУ¶} {P : C вЖТ Type рЭУЬ}
    вЖТ Arrow-map f (fst: P) вЖТ ArrFam-map f P
str-ArrFam F .ArrFam-map.bot = F .Arrow-map.bot
str-ArrFam {P = P} F .ArrFam-map.top a
  = tr P (sym (F .Arrow-map.comm a)) (F .Arrow-map.top a .snd)

str-ArrFam-is-equiv
  : вИА {рЭУ§ рЭУ• рЭУ¶ рЭУЬ} {A : Type рЭУ§} {B : Type рЭУ•} {f : A вЖТ B}
      {C : Type рЭУ¶} {P : C вЖТ Type рЭУЬ}
    вЖТ is-equiv (str-ArrFam {f = f} {P = P})
str-ArrFam-is-equiv = is-equivвЖРqinv
  ( unstr-ArrFam
  , (ќї {(mk-amap top bot comm) вЖТ Arrow-map-pathвЖТ
            ((ќї a вЖТ ќ£-pathвЖТ ( comm a
                            , trвИШtr-sym' (comm a) (top a .snd)))
            , ~refl
            , ќї a вЖТ ќ£-path-ap-fst)})
  , ~refl)
}
}

\subtree[stt-00RQ]{
\title{The type of morphisms into a terminal projection is equivalent to the type of maps of domains}
\taxon{Lemma}
\date{2026-05-21}
\author{fredrikbakke}

\agda{
arrow-map-to-top-is-equiv
  : вИА {рЭУ§ рЭУ• рЭУ¶} {A : Type рЭУ§} {B : Type рЭУ•} {X : Type рЭУ¶} {f : A вЖТ B}
    вЖТ is-equiv (ќї (F : Arrow-map f (!: X)) вЖТ Arrow-map.top F)
arrow-map-to-top-is-equiv =
  is-equivвЖРqinv
    ( (ќї t вЖТ mk-amap t (ќї _ вЖТ tt) ~refl)
    , (ќї (mk-amap t b H)
       вЖТ Arrow-map-pathвЖТ
           ( ~refl
           , (ќї y вЖТ is-propвЖРis-single рЭЯЩ-is-singleton _ _)
           , (ќї x вЖТ is-propвЖРis-single (пЉЭ-singletonвЖРis-single рЭЯЩ-is-singleton _ _) _ _)))
    , ~refl)
}
}

\subtree[stt-00KS]{
\title{Amazingly fibrant types}
\taxon{Theorem}

\p{For any tiny type #{I} and #{\mathcal{F}}, a class of [#{I}-relative](stt-00K1)
maps, we may construct universes #{U_{\mathcal{F}}} which classifies
#{\UU}-small maps in #{\mathcal{F}}.
}

\proof{
We use the dependent form of the amazing right adjoint, so that #{U_{\mathcal{F}}}
is defined to be #{\Sigma_{\UU} \sqrt[I]{{-} \in \mathcal{F}}}. The universal
property of #{\sqrt[I]{}} gives us that the family #{U_{\mathcal{F}} \to \UU} is itself
fibrant, and since every family #{A \to U_{\mathcal{F}}} is a pullback of this
universal one it must also be fibrant. On the other hand any covariant family
#{P : A \to \UU} can be shown to factor through #{U_{\mathcal{F}}}.
}

%```agda
\agda{
module AmazinglyFibrant {@έβφ ΏζΥα} (@έβφ I : Type ΏζΥα)
            (@έβφ έΙγ : έΙΑ {@έβφ ΏζΥν} έΗΤ @έβφ Type ΏζΥν έΗΤ Type ΏζΥν)
            (@έβφ έΙγ╬╡ : έΙΑ {@έβφ ΏζΥν} {@έβφ A : Type ΏζΥν} έΗΤ (I έΗΤ έΙγ A) έΗΤ A)
            (@έβφ is-tiny-str : έΙΑ {@έβφ ΏζΥν} {@έβφ A : Type ΏζΥν}
                              έΗΤ is-tiny-structure I A (έΙγ A) έΙγ╬╡)
            (@έβφ types-separate : έΙΑ {@έβφ ΏζΥν ΏζΥξ} {@έβφ A : Type ΏζΥν} {@έβφ B : Type ΏζΥξ}
                                   {@έβφ f : A έΗΤ B} έΗΤ Types-separate f)
            {@έβφ ╬▒ : Level έΗΤ Level έΗΤ Level}
            (@έβφ is-fib : έΙΑ {ΏζΥν ΏζΥξ} {A : Type ΏζΥν} (B : A έΗΤ Type ΏζΥξ) έΗΤ Type (╬▒ ΏζΥν ΏζΥξ))
            (@έβφ is-fib-is-prop
                  : έΙΑ {ΏζΥν ΏζΥξ} {A : Type ΏζΥν} (B : A έΗΤ Type ΏζΥξ) έΗΤ is-prop (is-fib B))
            (@έβφ rel-fib : is-relative-fam I is-fib)
            (open DependentέΙγ I έΙγ έΙγ╬╡ is-tiny-str types-separate)
            where
  open Tiny I έΙγ έΙγ╬╡ is-tiny-str types-separate  public
  private
    map : έΙΑ {ΏζΥν} έΗΤ Ώζθβ έΗΤ (Prop-U ΏζΥν)
    map _ = (ULift _ Ώζθβ , trunc!)

  is-afib : έΙΑ {@έβφ ΏζΥν} έΗΤ Type ΏζΥν έΗΤ Type (lsuc (╬▒ ΏζΥα ΏζΥν))
  is-afib = έΙγά╡Ι is-fib

  record UFib (@έβφ ΏζΥν) : Type (lsuc (╬▒ ΏζΥα ΏζΥν έΛΦ ΏζΥν)) where
    constructor mk-ufib
    field
      Car : Type ΏζΥν
      has-is-afib : is-afib Car

  UFibέΙβ : έΙΑ (@έβφ ΏζΥν) έΗΤ Type (lsuc (╬▒ ΏζΥα ΏζΥν έΛΦ ΏζΥν))
  UFibέΙβ ΏζΥν = ╬μ (UFib ΏζΥν) UFib.Car

  UFib-╧Α : έΙΑ {@έβφ ΏζΥν} έΗΤ UFibέΙβ ΏζΥν έΗΤ UFib ΏζΥν
  UFib-╧Α = fst

  UFib-╧Α-is-fib : έΙΑ {@έβφ ΏζΥν} έΗΤ is-fib (UFib.Car {ΏζΥν})
  UFib-╧Α-is-fib = rel-fib _ .snd
    (╬╡έβφ (relim (modέβφ (╬╗ a έΗΤ έΙγά╡Ι-naturalityέΗΤ _ UFib.Car a (a .UFib.has-is-afib)))))

  UFib-is-fib : έΙΑ {@έβφ ΏζΥν ΏζΥξ} {A : Type ΏζΥν} (P : A έΗΤ UFib ΏζΥξ)
                έΗΤ is-fib (UFib.Car έΙα P)
  UFib-is-fib P
    = is-base-change-stable-famέΗΡis-relative
        I is-fib rel-fib P UFib.Car
        UFib-╧Α-is-fib

  liftFib : έΙΑ {@έβφ ΏζΥν ΏζΥξ} {@έβφ A : Type ΏζΥν} {@έβφ P : A έΗΤ Type ΏζΥξ}
              έΗΤ έθρέβφ| is-fib P έθσ έΘΦ έθρέβφ| (έΙΑ a έΗΤ is-afib (P a)) έθσ
  liftFib {A = A} {P = P} .fst fib
    = έβφ-map (postcomp-╬ι (έΙγά╡Ι-naturalityέΗΡ _ _))
            (rintro (έβφ-map (rel-fib P .fst) fib))
  liftFib {A = A} {P = P} .snd
    = έβφ-map (UFib-is-fib έΙα (╬╗ af a έΗΤ (mk-ufib (P a) (af a))))
}
%```

\p{In order to show that being amazingly fibrant is a proposition, and therefore
that the universe we have constructed is univalent, we need that the tiny type
former preserves propositions. This is at the moment left for future work.}

%```agda
\agda{
  module UIdS
           (@έβφ έΙγά╡Ι-is-prop : έΙΑ {@έβφ ΏζΥν ΏζΥξ} {@έβφ ╬Υ : Type ΏζΥν}
                              (@έβφ A : (I έΗΤ ╬Υ) έΗΤ Type ΏζΥξ)
                            έΗΤ (έΙΑ g┬ιέΗΤ is-prop (A g)) έΗΤ έΙΑ g έΗΤ is-prop (έΙγά╡Ι A g))
           where
    is-afib-is-prop
      : έΙΑ {@έβφ ΏζΥν} {A : Type ΏζΥν} έΗΤ is-prop (is-afib A)
    is-afib-is-prop = έΙγά╡Ι-is-prop is-fib is-fib-is-prop _


    Car-is-emb : έΙΑ {@έβφ ΏζΥν} έΗΤ is-prop-map (UFib.Car {ΏζΥν})
    Car-is-emb X = is-propέΗΡequiv-to-prop
      (equivέΗΡqequiv
        (mkέΚΛ
         (╬╗ a έΗΤ (mk-ufib X a , refl))
         ( (╬╗ where (a , refl) έΗΤ a .UFib.has-is-afib)
         , ~refl
         , ╬╗ where (a , refl) έΗΤ refl)))
      (is-afib-is-prop {A = X})

    instance
      UFib-IdS : έΙΑ {@έβφ ΏζΥν} έΗΤ Identity-system (UFib ΏζΥν) ΏζΥν
      UFib-IdS {ΏζΥν} = IdSέΗΡEmbedding {f = UFib.Car} Car-is-emb (IdS-ua {ΏζΥν})
}
%```
}


\subtree[stt-00KE]{
\title{Amazing properties}

\p{We give a partial formalisation of an alternative construction for amazing
properties. Instead of using the small map classifier, we may use the small
embedding classifier, so that we directly get a function
#{\textrm{is-amazingly} : \flat(A^I \to \textrm{HProp}) \to A \to \textrm{HProp}}.}

\remark{This formalisation is incomplete for similar reasons to the previous
construction, in order to make use of the embedding classifier, we need to
show the map #{1 \to \textrm{HProp}_I} that picks out #{\top}, is an embedding,
which requires showing that (this time the non-dependent) tiny type former
preserves sets. This boils down to characterising the identity type in
amazing right adjoints.}

%```agda
\agda{
module Amazingly {@έβφ ΏζΥα} (@έβφ I : Type ΏζΥα)
            (@έβφ έΙγ : έΙΑ {@έβφ ΏζΥν} έΗΤ @έβφ Type ΏζΥν έΗΤ Type ΏζΥν)
            (@έβφ έΙγ╬╡ : έΙΑ {@έβφ ΏζΥν} {@έβφ A : Type ΏζΥν} έΗΤ (I έΗΤ έΙγ A) έΗΤ A)
            (@έβφ is-tiny-str : έΙΑ {@έβφ ΏζΥν} {@έβφ A : Type ΏζΥν}
                              έΗΤ is-tiny-structure I A (έΙγ A) έΙγ╬╡)
            (@έβφ types-separate : έΙΑ {@έβφ ΏζΥν ΏζΥξ} {@έβφ A : Type ΏζΥν} {@έβφ B : Type ΏζΥξ}
                                   {@έβφ f : A έΗΤ B} έΗΤ Types-separate f)
            (@έβφ έΙγprop-is-set : έΙΑ {@έβφ ΏζΥν} έΗΤ is-set (έΙγ (Prop-U ΏζΥν))) where
  open Tiny I έΙγ έΙγ╬╡ is-tiny-str types-separate
  open DependentέΙγ I έΙγ έΙγ╬╡ is-tiny-str types-separate

  global-έΙγ : έΙΑ {@έβφ ΏζΥν} {@έβφ A : Type ΏζΥν} έΗΤ έθρέβφ| A έθσ έΗΤ έθρέβφ| έΙγ A έθσ
  global-έΙγ = έβφ-map (ev tt) έΙα transpose έΙα έβφ-map (const _ _)

  global-έΙγ-is-equiv : έΙΑ {@έβφ ΏζΥν} {@έβφ A : Type ΏζΥν} έΗΤ is-equiv (global-έΙγ {A = A})
  global-έΙγ-is-equiv
    = is-equiv-έΙα
        (έβφ-map-is-equiv (unit-ev-is-equiv))
        (is-equiv-έΙα
          (is-equivέΒ╗┬╣ is-tiny-str)
          (έβφ-map-is-equiv (sing-const-is-equiv global-funext single!)))

  global-έΙγ-point : έΙΑ {@έβφ ΏζΥν} {@έβφ A : Type ΏζΥν} έΗΤ @έβφ A έΗΤ έΙγ A
  global-έΙγ-point a = ╬╡έβφ (global-έΙγ (modέβφ a))

  global-έΛν : έΙΑ (@έβφ ΏζΥν) έΗΤ έΙγ (Prop-U ΏζΥν)
  global-έΛν ΏζΥν = global-έΙγ-point (ULift ΏζΥν Ώζθβ , trunc!)

  prop-class : έΙΑ {@έβφ ΏζΥν} έΗΤ Ώζθβ έΗΤ έΙγ (Prop-U ΏζΥν)
  prop-class = point (global-έΛν _)

  classify-έΙγ-prop : έΙΑ {@έβφ ΏζΥν} έΗΤ έΙγ(Prop-U ΏζΥν) έΗΤ Prop-U (lsuc ΏζΥν)
  classify-έΙγ-prop x
    = ( fibre prop-class x
      , fibre-is-truncated'
          prop-class x
          trunc!
          (is-truncatedέΗΡis-prop (έΙγprop-is-set _ _)))

  is-amazingly-prop
    : έΙΑ {@έβφ ΏζΥν ΏζΥξ} {@έβφ ╬Υ : Type ΏζΥν}
      έΗΤ έθρέβφ| ((I έΗΤ ╬Υ) έΗΤ Prop-U ΏζΥξ) έθσ έΗΤ έθρέβφ| (╬Υ έΗΤ Prop-U (lsuc ΏζΥξ)) έθσ
  is-amazingly-prop = έβφ-map (postcomp _ classify-έΙγ-prop) έΙα transpose

  is-amazingly
    : έΙΑ {@έβφ ΏζΥν ΏζΥξ} {@έβφ ╬Υ : Type ΏζΥν}
      έΗΤ (@έβφ A : (I έΗΤ ╬Υ) έΗΤ Type ΏζΥξ)
      έΗΤ @έβφ (έΙΑ g έΗΤ is-prop (A g))
      έΗΤ (╬Υ έΗΤ Type (lsuc ΏζΥξ))
  is-amazingly A Ap
    = fst
    έΙα (╬╡έβφ (is-amazingly-prop
            (modέβφ ╬╗ g έΗΤ (A g , is-truncatedέΗΡis-prop (Ap g)))))

  is-amazingly-is-prop
    : έΙΑ {@έβφ ΏζΥν ΏζΥξ} {@έβφ ╬Υ : Type ΏζΥν} (@έβφ A : (I έΗΤ ╬Υ) έΗΤ Type ΏζΥξ)
        (@έβφ Ap : έΙΑ x έΗΤ is-prop (A x))
      έΗΤ έΙΑ g έΗΤ is-prop (is-amazingly A Ap g)
  is-amazingly-is-prop A Ap
    = is-propέΗΡis-truncated
    έΙα snd
    έΙα ╬╡έβφ (is-amazingly-prop (modέβφ (╬╗ g έΗΤ A g , is-truncatedέΗΡis-prop (Ap g))))
}
%```
}

\subtree[stt-00KK]{
\title{Paths in amazing right adjoints}
\taxon{Lemma}

\p{Given #{a, b : A_I}, the type #{\sqrt[I]{\epsilon a = \epsilon b}} is an
identity system for #{A}.}

\todo{This proof remains to be formalised}

\proof{
\p{We show #{\sqrt[I]{\epsilon a = \epsilon {-}}} is torsorial, or equivalently,
letting #{P := \Sigma_{a,b : A_I}}, that the first projection
#{P \to A_I} is an equivalence.

We may use the types separate principle so that it suffices to show the induced
map #{\flat(\Gamma \to P) \to \flat(\Gamma \to A_I)} is an equiv.

Finally, we may use the universal property of dependent and non-dependent
amazing right ajoints so that it is enough show the canonical map #{\flat(\Gamma^I \to
A) \to \flat(\Gamma^I \to \Sigma_{x, y} x =_A y)} is an equivalence.  }
}

%```agda
\agda{
  έΙγ-Path : έΙΑ {@έβφ ΏζΥν} {@έβφ A : Type ΏζΥν} έΗΤ έΙγ A έΗΤ έΙγ A έΗΤ Type (lsuc ΏζΥν)
  έΙγ-Path {_} {A} a b = έΙγά╡Ι ╧Δ (a , b) where
    @έβφ ╧Δ : (I έΗΤ έΙγ A ├Ω έΙγ A) έΗΤ Type _
    ╧Δ = uncurry _Ύ╝ζ_ έΙα (έΙγ╬╡ έΛΩ έΙγ╬╡) έΙα ╬μ-╬ι-swap (╬╗ _ έΗΤ έΙγ A) _

  έΙγ-Path-refl : έΙΑ {@έβφ ΏζΥν} {@έβφ A : Type ΏζΥν} (a : έΙγ A) έΗΤ έΙγ-Path a a
  έΙγ-Path-refl {A = A} a = έΙγά╡Ι-naturalityέΗΡ _ (╬Φ├Ω (έΙγ A)) a (╧Χ a) where
    @έβφ ╧Χ : ╬ι (έΙγ A) (έΙγά╡Ι (uncurry _Ύ╝ζ_ έΙα ╬Φ├Ω A έΙα έΙγ╬╡))
    ╧Χ = ╬╡έβφ (rintro {╬Υ = έΙγ A}{A = ╬╗ x έΗΤ έΙγ╬╡ x Ύ╝ζ έΙγ╬╡ x} (modέβφ ~refl))

  -- έΙγ-Path-is-torsorial
  --   : έΙΑ {@έβφ ΏζΥν} {@έβφ A : Type ΏζΥν} (a : έΙγ A) έΗΤ is-singleton (╬μ _ (έΙγ-Path a))
  -- έΙγ-Path-is-torsorial {A = A}
  --   = (╬╡έβφ: (έΙΑ a έΗΤ is-singleton (╬μ _ (έΙγ-Path a))))
  --      (έβφ-is-singleέΗΡequiv-to-single
  --       (modέβφ (╬╗ g έΗΤ {!mkέΚΔ (έΙγ-pres-╬μέΗΤ) ?!}))
  --       (έΙγά╡Ι-is-singleton (modέβφ (╬╗ a έΗΤ Sing-is-singleton {a = έΙγ╬╡ a}))))
  --      -- ({!έβφ-map (postcomp-╬ι ?)!}
  --      -- (╬╡έβφ (έΙγά╡Ι-is-singleton (modέβφ (╬╗ _ έΗΤ Sing-is-singleton)))))
}
%```
}

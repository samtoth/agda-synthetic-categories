\date{2026-03-20}
\title{Algebraic laws of composition}
\author{fredrikbakke}
\taxon{Module}
\import{stt-macros}

\p{
We formalise algebraic laws of composition in categories.
}

\transclude{stt-00AB}

\agda{
open import Foundations.Prelude
open import Algebra.Lattice

module Synthetic.Categories.AlgebraicLaws
  {рЭУШ} (ќФ¬є : Type рЭУШ) (I : Lattice ќФ¬є) (I-distr : is-distributive I)
  where

open import Synthetic.Categories.AssociativitySegal ќФ¬є I I-distr public using
  ( вИШ[_]-assoc
  ; вИШ-assocвЖРis-segal
  ; вИШ-assocвЖРis-precategory)

open import Axioms.UF

open Lattice I renaming (0l to i0; 1l to i1)
open is-distributive I-distr

open import Ergonomics.Extensionality

open import Synthetic.Hom ќФ¬є i0 i1
open import Synthetic.Simplicial ќФ¬є I I-distr
open import Synthetic.Categories.Precategories ќФ¬є I I-distr
open import Synthetic.Categories.Homotopy ќФ¬є I I-distr

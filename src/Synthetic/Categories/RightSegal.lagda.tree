\subtree[tot-00Z0]{
\taxon{Definition}
\title{Right Segal types}

\p{We call a type \em{right Segal} if it is local with respect to the map
#{\Lambda^2_1 \to \Delta^1 \bjoin 1}.}

\remark{See [[stt-00DA]] for the dual concept.}

\agda{
Оӣ[2,1]-inclв–» : Оӣ[2,1] вҶ’ О”В№ в–»
Оӣ[2,1]-inclв–» = cogap (mk-cocone вҶ‘-О№вӮҒ (вҶ‘-hom (i1 , tt) .HomбөҲ.hom)
                                (sym вҲҳ point (glue (вҲӮО”В№-0 , i1 , tt))))

Оӣ[2,1]-inclв–»вҲҷ : Coslice-map (point (О№вӮӮ i1)) О» _ вҶ’ вҶ‘-О№вӮӮ tt
Оӣ[2,1]-inclв–»вҲҷ = (Оӣ[2,1]-inclв–» , О» _ вҶ’ glue (вҲӮО”В№-1 , i1 , tt))

is-right-segal : вҲҖ {рқ“Ө} (A : Type рқ“Ө) вҶ’ Type (рқ“ҳ вҠ” рқ“Ө)
is-right-segal = is-local (point Оӣ[2,1]-inclв–»)
}
}

\subtree[tot-00Z1]{
\title{Right Segal types are Segal}
\taxon{Lemma}

\p{Any [right Segal](tot-00Z0) type is [Segal](stt-00AI).}

\proof{
\p{
We give a splitting of #{\Delta^2 \hookrightarrow \Delta^1 \bjoin 1},
which furthermore preserves the inner horn inclusion.
(Note the split embedding #{\Delta^2 \hookrightarrow \square^2} in
\ref{stt-00C7} factors through this map.)}
}

\agda{
О”ВІвҶҗО”В№в–»-cocone : Cocone (в–»-span О”В№) О”ВІ
О”ВІвҶҗО”В№в–»-cocone .Cocone.p (i , j , tt) = (j вҲЁ i , i) вҰғ вҲЁ-вүӨ-intror auto! вҰ„
О”ВІвҶҗО”В№в–»-cocone .Cocone.q (inl x) = (x , i0)
О”ВІвҶҗО”В№в–»-cocone .Cocone.q (inr x) = (i1 , i1)
О”ВІвҶҗО”В№в–»-cocone .Cocone.filler (вҲӮО”В№-1 , i , tt) = О”ВІ-ext (1-coinit , refl)
О”ВІвҶҗО”В№в–»-cocone .Cocone.filler (вҲӮО”В№-0 , i , tt) = О”ВІ-ext (0-bottom , refl)

О”ВІвҶҗО”В№в–» : О”В№ в–» вҶ’ О”ВІ
О”ВІвҶҗО”В№в–» = cogap О”ВІвҶҗО”В№в–»-cocone

О”ВІвҶҗО”В№в–»-resp-horn : О”ВІвҶҗО”В№в–» вҲҳ Оӣ[2,1]-inclв–» ~ Оӣ[2,1]-incl
О”ВІвҶҗО”В№в–»-resp-horn = pushout-ind _
  (mk-coconeбөҲ
    (О» l вҶ’ refl)
    (О» r вҶ’ О”ВІ-ext (вҲЁ-comm вҲҷ 1-coinit , refl))
    (О» _ вҶ’ О”ВІ-is-set _ _ _ _))

О”В№в–»вҶҗО”ВІ : О”ВІ вҶ’ О”В№ в–»
О”В№в–»вҶҗО”ВІ a = О№вӮҒ (Poly.О”ВІ.t a , Poly.О”ВІ.s a , tt)

О”В№в–»вҶҗО”ВІ-resp-horn
  : О”В№в–»вҶҗО”ВІ вҲҳ Оӣ[2,1]-incl ~ Оӣ[2,1]-inclв–»
О”В№в–»вҶҗО”ВІ-resp-horn = pushout-rec-unique _ _
  (О» a вҶ’ glue (вҲӮО”В№-0 , a , tt))
  ~refl
  О» a вҶ’ вҲҷ-reflr _
      вҲҷ ap-вҲҳ О”В№в–»вҶҗО”ВІ Оӣ[2,1]-incl (glue a)
      вҲҷ ap (ap О”В№в–»вҶҗО”ВІ) (pushout-rec-apОІ a)
      вҲҷ lem
      вҲҷ sym (вҲҷ-sym (glue (вҲӮО”В№-0 , i1 , tt))) where
  lem : ap (О”В№в–»вҶҗО”ВІ) О”ВІ-refl пјқ refl
  lem = ap-вҲҳ О№вӮҒ (О» where (i , j) вҶ’ (j , i , tt)) О”ВІ-refl
      вҲҷ ap (ap О№вӮҒ) prop!

Оӣ[2,1]вҶӘОӣ[2,1]в–» : Arrow-map Оӣ[2,1]-incl Оӣ[2,1]-inclв–»
Оӣ[2,1]вҶӘОӣ[2,1]в–» = mk-amap id О”В№в–»вҶҗО”ВІ О”В№в–»вҶҗО”ВІ-resp-horn

Оӣ[2,1]вҶӘОӣ[2,1]в–»-retraction : retraction-arrow-map Оӣ[2,1]вҶӘОӣ[2,1]в–»
Оӣ[2,1]вҶӘОӣ[2,1]в–»-retraction .fst = mk-amap id О”ВІвҶҗО”В№в–» О”ВІвҶҗО”В№в–»-resp-horn
Оӣ[2,1]вҶӘОӣ[2,1]в–»-retraction .snd .fst = ~refl
Оӣ[2,1]вҶӘОӣ[2,1]в–»-retraction .snd .snd .fst ((a , b) вҰғ p вҰ„)
  = О”ВІ-ext (вҲЁ-comm вҲҷ вүӨ-max p , refl)
Оӣ[2,1]вҶӘОӣ[2,1]в–»-retraction .snd .snd .snd _ = О”ВІ-is-set _ _ _ _

is-segalвҶҗis-right-segal
  : вҲҖ {рқ“Ө} {A : Type рқ“Ө}
    вҶ’ is-right-segal A
    вҶ’ is-segal A
is-segalвҶҗis-right-segal orth tt
  = is-orthogonalвҮ”orthogonal-! .fst
      (left-orthogonal-retraction Оӣ[2,1]-incl Оӣ[2,1]-inclв–»
        Оӣ[2,1]вҶӘОӣ[2,1]в–»
        Оӣ[2,1]вҶӘОӣ[2,1]в–»-retraction
        !
        (is-orthogonalвҮ”orthogonal-! .snd (orth tt)))
}
}

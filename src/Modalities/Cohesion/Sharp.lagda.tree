\subtree{
\title{The Sharp modal operator}
\taxon{Definition}

%```agda
\agda{
record ‚ü®‚ôĮ|_‚ü© {ūĚď§} (@‚ôĮ¬†A : Type ūĚď§) : Type ūĚď§ where
  constructor mod‚ôĮ
  field
    @‚ôĮ¬†counit‚ôĮ : A

open ‚ü®‚ôĮ|_‚ü©

unit-‚ôĮ : ‚ąÄ {ūĚď§} {A : Type ūĚď§} ‚Üí A ‚Üí ‚ü®‚ôĮ| A ‚ü©
unit-‚ôĮ a .counit‚ôĮ¬†= a

‚ôĮ-map : ‚ąÄ {ūĚď§ ūĚď•} {@‚ôĮ A : Type ūĚď§} {@‚ôĮ B : Type ūĚď•}
        ‚Üí (@‚ôĮ¬†f : A ‚Üí B) ‚Üí ‚ü®‚ôĮ| A ‚ü© ‚Üí ‚ü®‚ôĮ| B ‚ü©
‚ôĮ-map f x .counit‚ôĮ = f (x .counit‚ôĮ)

_ÔľĚ‚ôĮ_ : ‚ąÄ {ūĚď§} {@‚ôĮ A : Type ūĚď§} (@‚ôĮ a b : A) ‚Üí Type ūĚď§
a ÔľĚ‚ôĮ b = ‚ü®‚ôĮ| a ÔľĚ b ‚ü©

ap‚ôĮ : ‚ąÄ {ūĚď§ ūĚď•} {A : Type ūĚď§} {B : Type ūĚď•} {a b : A} (f : @‚ôĮ A ‚Üí B)
      ‚Üí a ÔľĚ b ‚Üí f a ÔľĚ f b
ap‚ôĮ f refl = refl

mapply‚ôĮ : ‚ąÄ {ūĚď§} {@‚ôĮ A : Type ūĚď§} {@‚ôĮ a b : A} ‚Üí mod‚ôĮ¬†a ÔľĚ mod‚ôĮ b ‚Üí a ÔľĚ‚ôĮ b
mapply‚ôĮ refl .counit‚ôĮ = refl

modext‚ôĮ‚Üí'' : ‚ąÄ {ūĚď§} {@‚ôĮ A : Type ūĚď§} {@‚ôĮ a b : A}
           ‚Üí a ÔľĚ‚ôĮ b ‚Üí mod‚ôĮ a ÔľĚ mod‚ôĮ b
modext‚ôĮ‚Üí'' x = {!!}

postulate
  modext‚ôĮ : ‚ąÄ {ūĚď§} {@‚ôĮ A : Type ūĚď§} {@‚ôĮ a b : A} ‚Üí is-equiv (mapply‚ôĮ {a = a}{b})

modext‚ôĮ‚Üí : ‚ąÄ {ūĚď§} {@‚ôĮ A : Type ūĚď§} {@‚ôĮ a b : A}
           ‚Üí a ÔľĚ‚ôĮ b ‚Üí mod‚ôĮ a ÔľĚ mod‚ôĮ b
modext‚ôĮ‚Üí = is-equiv.bwd modext‚ôĮ

modext‚ôĮ‚Üí' : ‚ąÄ {ūĚď§} {@‚ôĮ A : Type ūĚď§} {@‚ôĮ a b : A}
           ‚Üí @‚ôĮ¬†a ÔľĚ b ‚Üí mod‚ôĮ a ÔľĚ mod‚ôĮ b
modext‚ôĮ‚Üí' x = modext‚ôĮ‚Üí (mod‚ôĮ x)

refl‚ôĮ : ‚ąÄ {ūĚď§} {@‚ôĮ A : Type ūĚď§} {@‚ôĮ¬†a : A} ‚Üí a ÔľĚ‚ôĮ a
refl‚ôĮ = mod‚ôĮ refl

modext‚ôĮ-refl
  : ‚ąÄ {ūĚď§} {@‚ôĮ A : Type ūĚď§} {@‚ôĮ¬†a : A} ‚Üí modext‚ôĮ‚Üí (refl‚ôĮ {a = a}) ÔľĚ refl
modext‚ôĮ-refl = unap-equiv modext‚ôĮ (is-equiv.őĶ modext‚ôĮ refl‚ôĮ)

‚ôĮ-map-is-equiv
  : ‚ąÄ {ūĚď§ ūĚď•} {@‚ôĮ A : Type ūĚď§} {@‚ôĮ B : Type ūĚď•} {@‚ôĮ¬†f : A ‚Üí B}
    ‚Üí @‚ôĮ¬†is-equiv f ‚Üí is-equiv (‚ôĮ-map f)
‚ôĮ-map-is-equiv fe = is-equiv‚Üźqiso
  ( ‚ôĮ-map (bwd fe)
  , (őĽ x ‚Üí modext‚ôĮ‚Üí (mod‚ôĮ (ő∑ fe (x .counit‚ôĮ))))
  , őĽ x ‚Üí modext‚ôĮ‚Üí (mod‚ôĮ (őĶ fe (x .counit‚ôĮ)))) where open is-equiv

instance
  IdS-‚ôĮ : ‚ąÄ {ūĚď§ ūĚď•} {@‚ôĮ¬†A : Type ūĚď§} ‚¶É @‚ôĮ _ : Identity-system A ūĚď• ‚¶Ą
          ‚Üí Identity-system ‚ü®‚ôĮ| A ‚ü© ūĚď•
  IdS-‚ôĮ .Identity-system.IdS a b = ‚ü®‚ôĮ| IdS (a .counit‚ôĮ) (b .counit‚ôĮ) ‚ü©
  IdS-‚ôĮ .Identity-system.IdS‚ÜźId {mod‚ôĮ a} {mod‚ôĮ b} = ‚ôĮ-map IdS‚ÜźId ‚ąė mapply‚ôĮ
  IdS-‚ôĮ .Identity-system.has-is-ids a b
    = is-equiv-‚ąė (‚ôĮ-map-is-equiv (has-is-ids _ _)) modext‚ôĮ
}
%```
}

\subtree{
\title{Sharp is right adjoint to flat}
\taxon{Lemma}


%```agda
\agda{
‚ô≠‚ä£‚ôĮ-transpose : ‚ąÄ {ūĚď§ ūĚď•} {A : Type ūĚď§} {B : Type ūĚď•} ‚Üí
            ‚ü®‚ôĮ| (‚ü®‚ô≠| A ‚ü© ‚Üí B) ‚ü© ‚Üí (A ‚Üí ‚ü®‚ôĮ| B ‚ü©)
‚ô≠‚ä£‚ôĮ-transpose f a .counit‚ôĮ = f .counit‚ôĮ (mod‚ô≠ a)

‚ô≠‚ä£‚ôĮ-transpose-is-equiv
  : ‚ąÄ {ūĚď§ ūĚď•} {A : Type ūĚď§} {B : Type ūĚď•} ‚Üí is-equiv (‚ô≠‚ä£‚ôĮ-transpose {A = A} {B = B})
‚ô≠‚ä£‚ôĮ-transpose-is-equiv = is-equiv‚Üźqiso qiso where
  qiso : quasi-iso _
  qiso .fst f .counit‚ôĮ a = f (őĶ‚ô≠ a) .counit‚ôĮ
  qiso .snd .fst x = ext! (mod‚ôĮ (őĽ where (mod‚ô≠ x) ‚Üí refl))
  qiso .snd .snd x = refl

‚ô≠‚ä£‚ôĮ : ‚ąÄ {ūĚď§ ūĚď•} {A : Type ūĚď§} {B : Type ūĚď•} ‚Üí ‚ü®‚ôĮ| (‚ü®‚ô≠| A ‚ü© ‚Üí B)‚ü© ‚ČÉ (A ‚Üí ‚ü®‚ôĮ| B ‚ü©)
‚ô≠‚ä£‚ôĮ = mk‚ČÉ ‚ô≠‚ä£‚ôĮ-transpose ‚ô≠‚ä£‚ôĮ-transpose-is-equiv
}
%```
}


\subtree{
\title{Sharp types forms a reflective subuniverse}
\taxon{Lemma}

\p{We call a type codiscrete if #{\eta : A \to \mod{\sharp}{A}} is an
equivalence.}

%```agda
\agda{
is-‚ôĮ-codiscrete : ‚ąÄ {ūĚď§} ‚Üí Type ūĚď§ ‚Üí Type ūĚď§
is-‚ôĮ-codiscrete A = is-equiv (unit-‚ôĮ {A = A})

unmod‚ôĮ : ‚ąÄ {ūĚď§} {A : Type ūĚď§} ‚Üí is-‚ôĮ-codiscrete A ‚Üí ‚ü®‚ôĮ| A ‚ü© ‚Üí A
unmod‚ôĮ e = is-equiv.bwd e

‚ü®‚ôĮ|-‚ü©-is-‚ôĮ-codiscrete : ‚ąÄ {ūĚď§} {A : Type ūĚď§} ‚Üí is-‚ôĮ-codiscrete ‚ü®‚ôĮ| A ‚ü©
‚ü®‚ôĮ|-‚ü©-is-‚ôĮ-codiscrete = is-equiv‚Üźqiso
  ( (őĽ where x .counit‚ôĮ ‚Üí  x .counit‚ôĮ .counit‚ôĮ)
  , (őĽ a ‚Üí ext! (mod‚ôĮ refl))
  , őĽ _ ‚Üí refl)

is-‚ôĮ-codiscrete‚Üźis-equiv
  : ‚ąÄ {ūĚď§ ūĚď•} {A : Type ūĚď§} {B : Type ūĚď•} {f : A ‚Üí B} ‚Üí is-equiv f
    ‚Üí is-‚ôĮ-codiscrete A ‚Üí is-‚ôĮ-codiscrete B
is-‚ôĮ-codiscrete‚Üźis-equiv {f = f} fe ad
  = 3-for-2~' {k = ‚ôĮ-map f ‚ąė unit-‚ôĮ}
      (őĽ a ‚Üí ext! refl‚ôĮ)
      fe
      (is-equiv-‚ąė (‚ôĮ-map-is-equiv fe) ad)

‚ôĮ-induction
  : ‚ąÄ {ūĚď§} {A : Type ūĚď§} (P : ‚ü®‚ôĮ| A ‚ü© ‚Üí Type ūĚď§) ‚Üí ((a : A) ‚Üí ‚ü®‚ôĮ| P (unit-‚ôĮ a) ‚ü©)
    ‚Üí (x : ‚ü®‚ôĮ| A ‚ü©) ‚Üí ‚ü®‚ôĮ| P x ‚ü©
‚ôĮ-induction P sec x .counit‚ôĮ = counit‚ôĮ (sec (x .counit‚ôĮ))

‚ôĮ-GSU : GSU id
‚ôĮ-GSU .GSU.S .Subtype.family = is-‚ôĮ-codiscrete
‚ôĮ-GSU .GSU.S .Subtype.has-is-subtype _ = is-equiv-is-prop
‚ôĮ-GSU .GSU.S-equiv e = is-‚ôĮ-codiscrete‚Üźis-equiv (e ._‚ČÉ_.has-is-eqv)

‚ôĮ-is-reflective-GSU : is-globally-reflective ‚ôĮ-GSU
‚ôĮ-is-reflective-GSU .is-globally-reflective.‚óč A = ‚ü®‚ôĮ| A ‚ü©
‚ôĮ-is-reflective-GSU .is-globally-reflective.ő∑ = unit-‚ôĮ
‚ôĮ-is-reflective-GSU .is-globally-reflective.has-is-reflector {_} {A}
  = grf where
  open is-global-reflector
  grf : is-global-reflector ‚ôĮ-GSU A ‚ü®‚ôĮ| A ‚ü© unit-‚ôĮ
  grf .‚óč‚ąąS = ‚ü®‚ôĮ|-‚ü©-is-‚ôĮ-codiscrete
  grf .reflects Qdisc = is-equiv‚Üźqiso
    ( (őĽ f x ‚Üí unmod‚ôĮ Qdisc (mod‚ôĮ (f (x .counit‚ôĮ))))
    , (őĽ f ‚Üí funext‚Üí (őĽ a ‚Üí is-equiv.ő∑ Qdisc (f a)))
    , (őĽ f ‚Üí funext‚Üí (őĽ a ‚Üí is-equiv.ő∑ Qdisc (f a)))
    )

‚ôĮ-is-ő£-closed : is-globally-ő£-closed ‚ôĮ-GSU
‚ôĮ-is-ő£-closed {A = A} {B} a b
  = in-SubU‚Üźő∑-retract
      (is-globally-reflective.reflector ‚ôĮ-is-reflective-GSU (ő£ A B) )
      ((őĽ x ‚Üí let aa = unmod‚ôĮ a (mod‚ôĮ (x .counit‚ôĮ .fst))
              in (aa , unmod‚ôĮ (b aa)
                              (mod‚ôĮ (tr B (is-equiv.ő∑‚ĀĽ¬Ļ a (x .counit‚ôĮ .fst))
                                          (x .counit‚ôĮ .snd)))))
      , őĽ x ‚Üí ő£-path‚Üí ((is-equiv.ő∑ a (fst x)) , {!is-equiv.ő∑ (b (x .fst))!}))


‚ôĮ-is-lex : is-lex ‚ôĮ-is-reflective-GSU ‚ôĮ-is-ő£-closed
‚ôĮ-is-lex = is-equiv‚Üźqiso
  ( mapply‚ôĮ
  , (őĽ x ‚Üí ap mapply‚ôĮ {!!} ‚ąô {!!})
  , őĽ p ‚Üí {!!})
}
%```
}

\subtree{
\title{Sharp codiscrete and sharp connected maps}
\taxon{Definition}

\p{A map #{f : A \to B} is #{\sharp}-codiscrete if all of its fibres are.}

%```agda
\agda{
is-‚ôĮ-codiscrete-map
  : ‚ąÄ {ūĚď§ ūĚď•} {A : Type ūĚď§} {B : Type ūĚď•} ‚Üí (A ‚Üí B) ‚Üí Type (ūĚď§ ‚äĒ ūĚď•)
is-‚ôĮ-codiscrete-map f = is-modal-map (SubU‚Üźglobal ‚ôĮ-GSU) f
}
%```

\p{A map is #{\sharp}-connected if all of it's fibres are \{\sharp}-connected.}

%```agda
\agda{
is-‚ôĮ-connected-map
  : ‚ąÄ {ūĚď§ ūĚď•} {A : Type ūĚď§} {B : Type ūĚď•} ‚Üí (A ‚Üí B) ‚Üí Type (ūĚď§ ‚äĒ ūĚď•)
is-‚ôĮ-connected-map = is-connected-map (is-reflective‚Üźglobal ‚ôĮ-is-reflective-GSU)
}
%```
}

\subtree{
\title{Sharp equivalences}
\taxon{Definition}

\p{A map #{f : A \to B} is a #{\sharp}-equivalence if precomposition at all
#{\sharp} codiscrete types are equivalences.}

%```agda
\agda{
-- is-‚ôĮ-equiv
--   : ‚ąÄ {ūĚď§ ūĚď•} {A : Type ūĚď§} {B : Type ūĚď•} ‚Üí (A ‚Üí B) ‚Üí TypeŌČ
-- is-‚ôĮ-equiv f = ‚ąÄ {ūĚď†} {Q : Type ūĚď†} ‚Üí is-‚ôĮ-codiscrete Q ‚Üí is-equiv (precomp Q f)
is-‚ôĮ-equiv
  : ‚ąÄ {ūĚď§ ūĚď•} {A : Type ūĚď§} {B : Type ūĚď•} ‚Üí (A ‚Üí B) ‚Üí Type (ūĚď§ ‚äĒ ūĚď•)
is-‚ôĮ-equiv f = is-equiv (‚ôĮ-map f)

is-modal-equiv‚Üźis-‚ôĮ-equiv
  : ‚ąÄ {ūĚď§ ūĚď•} {A : Type ūĚď§} {B : Type ūĚď•} ‚Üí {f : A ‚Üí B}
    ‚Üí is-‚ôĮ-equiv f ‚Üí is-modal-equiv ‚ôĮ-is-reflective-GSU f
is-modal-equiv‚Üźis-‚ôĮ-equiv = homotopy-is-equiv őĽ where
  x ‚Üí modext‚ôĮ‚Üí (őĽ where .counit‚ôĮ ‚Üí help x) where
  help : ‚ąÄ {@‚ô≠ ūĚď§} {@‚ô≠ ūĚď•} {@‚ô≠ A : Set ūĚď§} {@‚ô≠ B : Set ūĚď•} {@‚ô≠ f : A ‚Üí B}
         (@‚ô≠ x : ‚ü®‚ôĮ| A ‚ü©) ‚Üí f (x .counit‚ôĮ)
         ÔľĚ GPiClosure.‚óč-map ‚ôĮ-is-reflective-GSU (mod‚ôĮ f) x .counit‚ôĮ
  help {f = f} (mod‚ôĮ x)
    = ap‚ô≠ counit‚ôĮ (sym (GPiClosure.‚óč-map-ő≤ ‚ôĮ-is-reflective-GSU {f = f} {a = x}))
}
%```

\p{For any crisp type, the counit #{\mod{\flat}{A} \to A} is a sharp equivalence.}

%```agda
\agda{
-- őĶ-is-‚ôĮ-equivalence
--   : ‚ąÄ {@‚ô≠ ūĚď§} {@‚ô≠ A : Type ūĚď§} ‚Üí is-‚ôĮ-equiv (őĶ‚ô≠ {A = A})
-- őĶ-is-‚ôĮ-equivalence Qcd = is-equiv‚Üźqiso
--   ( (őĽ f ‚Üí is-equiv.bwd Qcd ‚ąė ‚ô≠‚ä£‚ôĮ-transpose (mod‚ôĮ f))
--   , (őĽ f ‚Üí funext‚Üí (őĽ a ‚Üí unap-equiv Qcd (is-equiv.őĶ Qcd _)))
--   , őĽ f ‚Üí funext‚Üí (őĽ where (mod‚ô≠ a) ‚Üí unap-equiv Qcd (is-equiv.őĶ Qcd _)))

őĶ-is-‚ôĮ-equiv : ‚ąÄ {@‚ô≠ ūĚď§} {@‚ô≠ A : Type ūĚď§} ‚Üí is-‚ôĮ-equiv (őĶ‚ô≠ {A = A})
őĶ-is-‚ôĮ-equiv = is-equiv‚Üźqiso
  ( (őĽ x ‚Üí mod‚ôĮ (mod‚ô≠ (x .counit‚ôĮ)))
  , (őĽ x ‚Üí modext‚ôĮ‚Üí (mod‚ôĮ (help x)))
  , ~refl) where
  help : ‚ąÄ {@‚ô≠ ūĚď§} {@‚ô≠ A : Set ūĚď§} (@‚ô≠ x : ‚ü®‚ôĮ| ‚ü®‚ô≠| A ‚ü© ‚ü©) ‚Üí
      mod‚ô≠ (‚ôĮ-map őĶ‚ô≠ x .counit‚ôĮ) ÔľĚ x .counit‚ôĮ
  help (mod‚ôĮ (mod‚ô≠ x)) = refl

}
%```
}

\subtree{
\title{Sharp connected maps are sharp equivalences}

%```agda
\agda{
is-‚ôĮ-connected‚Üźis-‚ôĮ-equiv
  : ‚ąÄ {ūĚď§ ūĚď•} {A : Type ūĚď§} {B : Type ūĚď•} {f : A ‚Üí B}
    ‚Üí is-‚ôĮ-equiv f ‚Üí is-‚ôĮ-connected-map f
is-‚ôĮ-connected‚Üźis-‚ôĮ-equiv fs
  =  Lex.is-connected-map‚Üźis-modal-equiv
       ‚ôĮ-is-reflective-GSU
       ‚ôĮ-is-ő£-closed
       {!modext‚ôĮ!}
       (is-modal-equiv‚Üźis-‚ôĮ-equiv fs)
}
%```
}

\subtree{
\title{Sharp cordiscrete maps lift crisply against the flat counit}
\taxon{Theorem}

% \citek{MR2025}{3.1.2}

%```agda
\agda{
lifts-őĶ‚ô≠‚Üźis-‚ôĮ-codiscrete
  : ‚ąÄ {@‚ô≠ ūĚď§ ūĚď•} {@‚ô≠ A : Type ūĚď§} {@‚ô≠ B : Type ūĚď•} {@‚ô≠ f : A ‚Üí B}
    ‚Üí @‚ô≠ is-‚ôĮ-codiscrete-map f
    ‚Üí (‚ąÄ {@‚ô≠ ūĚď†} {@‚ô≠ Q : Type ūĚď†} ‚Üí are-‚ô≠-orthogonal (őĶ‚ô≠ {ūĚď†}{Q}) f)
lifts-őĶ‚ô≠‚Üźis-‚ôĮ-codiscrete {f = f} fcd {_}{Q}
  = ‚ô≠-is-cartesian (power-hom őĶ‚ô≠ f) {!!}
      (is-cartesian‚Üźorthogonal
        (connected‚ä•modal ‚ôĮ-is-reflective-GSU
          {!!}
          fcd))

module _ {@‚ô≠ ūĚď§}{@‚ô≠ A : Type ūĚď§}{@‚ô≠ a : A} where
 J‚ô≠' : ‚ąÄ {@‚ô≠ ūĚď•} (@‚ô≠ P : (@‚ô≠ x : A) ‚Üí @‚ô≠(a ÔľĚ x) ‚Üí Type ūĚď•)
      ‚Üí @‚ô≠ P a refl ‚Üí ‚ąÄ(@‚ô≠ b) ‚Üí (@‚ô≠ p : a ÔľĚ b) ‚Üí P b p
 J‚ô≠' {ūĚď•} P x b p  = test x b p .counit‚ôĮ where
   P' : (@‚ô≠ b : A) ‚Üí (p : a ÔľĚ b) ‚Üí Type ūĚď•
   P' b p = ‚ü®‚ôĮ| P b p ‚ü©

   test : (x : P a refl) ‚Üí (@‚ô≠ b : A) ‚Üí (p : a ÔľĚ b) ‚Üí P' b p
   test x b p .counit‚ôĮ = (J‚ô≠ P' (mod‚ôĮ x) p) .counit‚ôĮ

J‚ô≠'' : ‚ąÄ {@‚ô≠ ūĚď§} ‚Üí J-crisp-ind ūĚď§ ūĚď§
J‚ô≠'' P x p = J‚ô≠' P x _ p

}
%```
}

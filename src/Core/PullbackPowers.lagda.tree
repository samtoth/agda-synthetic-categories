  ő†Őā-unstraight-cod'‚ÜźArrow-ő†-is-equiv
    = homotopy-is-equiv
        ő†Őā-unstraight-cod'‚ÜźArrow-ő†~via-pullback
        (is-equiv-‚ąė
          (is-equiv‚Üźqinv ő†Őā-unstraight-cod'‚Üźpullback-qinv)
          (Arrow-ő†‚ČÉpullback ._‚ČÉ_.fwd-is-equiv))

  ő†Őā-unstraight-cod‚ÜźArrow-ő† : Arrow-ő† f g ‚Üí ő†Őā-unstraight-cod f g
  ő†Őā-unstraight-cod‚ÜźArrow-ő†
    = ő†Őā-unstraight-cod‚Üźő†Őā-unstraight-cod' ‚ąė ő†Őā-unstraight-cod'‚ÜźArrow-ő†

  ő†Őā-unstraight-cod‚ÜźArrow-ő†-is-equiv : is-equiv ő†Őā-unstraight-cod‚ÜźArrow-ő†
  ő†Őā-unstraight-cod‚ÜźArrow-ő†-is-equiv
    = is-equiv-‚ąė
        (ő†Őā-unstraight-cod'‚ČÉő†Őā-unstraight-cod ._‚ČÉ_.fwd-is-equiv)
        ő†Őā-unstraight-cod'‚ÜźArrow-ő†-is-equiv

  ő†Őā-unstraight-dom‚Üźő† : ((b : B) ‚Üí X b) ‚Üí ő†Őā-unstraight-dom f g
  ő†Őā-unstraight-dom‚Üźő† l = ő†Őā-unstraight-cod‚ÜźArrow-ő† (ő†Őā f g l) , m where
    y : (b : B) ‚Üí fibre (g b) (postcomp-ő† g l b)
    y b = l b , refl

    H : (b : B) ‚Üí const _ _ (y b) ~ ő†Őā-unstraight-cod‚ÜźArrow-ő† (ő†Őā f g l) .snd b
    H b (a , refl) = refl

    m : (b : B) ‚Üí null-homotopy (ő†Őā-unstraight-cod‚ÜźArrow-ő† (ő†Őā f g l) .snd b)
    m b = y b , H b

  ő†‚Üźő†Őā-unstraight-dom : ő†Őā-unstraight-dom f g ‚Üí ((b : B) ‚Üí X b)
  ő†‚Üźő†Őā-unstraight-dom (_ , m) b = fst (fst (m b))

  ő†‚Üźő†Őā-unstraight-dom‚ąėő†Őā-unstraight-dom‚Üźő†
    : ő†‚Üźő†Őā-unstraight-dom ‚ąė ő†Őā-unstraight-dom‚Üźő† ~ id
  ő†‚Üźő†Őā-unstraight-dom‚ąėő†Őā-unstraight-dom‚Üźő† l = refl

  PtŠĶą : B ‚Üí Type (ūĚď§1 ‚äĒ ūĚď§2 ‚äĒ ūĚď§3 ‚äĒ ūĚď§4)
  PtŠĶą b = fibre-pointed-total (fibre f b) (g b)

  ő†Őā-unstraight-dom‚ČÉptŠĶą-maps : ő†Őā-unstraight-dom f g ‚ČÉ ((b : B) ‚Üí PtŠĶą b)
  ő†Őā-unstraight-dom‚ČÉptŠĶą-maps
    = ő†Őā-unstraight-dom f g
        ‚ČÉ‚ü® ő£-assoc ‚ü©
      ő£[ i ‚ą∂ ((b : B) ‚Üí Y b) ]
      ő£[ j ‚ą∂ ((b : B) ‚Üí fibre f b ‚Üí fibre (g b) (i b)) ]
        ((b : B) ‚Üí null-homotopy (j b))
        ‚ČÉ‚ü® ő£-ap-‚ČÉ (őĽ i
                  ‚Üí ő£-ő†-swap‚ČÉ (őĽ b ‚Üí fibre f b ‚Üí fibre (g b) (i b))
                              (őĽ b jb ‚Üí null-homotopy jb)
                              e‚ĀĽ¬Ļ) ‚ü©
      ő£[ i ‚ą∂ ((b : B) ‚Üí Y b) ]
      ((b : B)
      ‚Üí ő£[ jb ‚ą∂ (fibre f b ‚Üí fibre (g b) (i b)) ] null-homotopy jb)
        ‚ČÉ‚ü® ő£-ő†-swap‚ČÉ (őĽ b ‚Üí Y b)
                     (őĽ b i ‚Üí ő£[ jb ‚ą∂ (fibre f b ‚Üí fibre (g b) i) ] null-homotopy jb)
                     e‚ĀĽ¬Ļ ‚ü©
      ((b : B) ‚Üí PtŠĶą b)
        ‚ČÉ‚ąé

  ő†Őā-unstraight-dom‚ČÉő† : ő†Őā-unstraight-dom f g ‚ČÉ ((b : B) ‚Üí X b)
  ő†Őā-unstraight-dom‚ČÉő†
    = ő†Őā-unstraight-dom‚ČÉptŠĶą-maps
    ‚ąôe ő†-ap-‚ČÉ (őĽ b ‚Üí fibre-pointed-total‚ČÉdomain (fibre f b) (g b))

  ő†‚Üźő†Őā-unstraight-dom-is-equiv : is-equiv ő†‚Üźő†Őā-unstraight-dom
  ő†‚Üźő†Őā-unstraight-dom-is-equiv
    = ő†Őā-unstraight-dom‚ČÉő† ._‚ČÉ_.fwd-is-equiv

  ő†Őā-unstraight-dom‚Üźő†-is-equiv : is-equiv ő†Őā-unstraight-dom‚Üźő†
  ő†Őā-unstraight-dom‚Üźő†-is-equiv
    = 3-for-2~ (ő†‚Üźő†Őā-unstraight-dom‚ąėő†Őā-unstraight-dom‚Üźő† h‚ĀĽ¬Ļ)
               (ő†‚Üźő†Őā-unstraight-dom-is-equiv)
               (id-is-equiv)

  ő†ŐāŠ∂†-unstraight‚Üźő†Őā : Arrow-map (ő†Őā f g) (ő†ŐāŠ∂†-unstraight f g)
  ő†ŐāŠ∂†-unstraight‚Üźő†Őā = mk-amap ő†Őā-unstraight-dom‚Üźő† ő†Őā-unstraight-cod‚ÜźArrow-ő† ~refl

  ő†ŐāŠ∂†-unstraight‚Üźő†Őā-is-Arrow-equiv : is-Arrow-equiv ő†ŐāŠ∂†-unstraight‚Üźő†Őā
  ő†ŐāŠ∂†-unstraight‚Üźő†Őā-is-Arrow-equiv
    = ő†Őā-unstraight-dom‚Üźő†-is-equiv , ő†Őā-unstraight-cod‚ÜźArrow-ő†-is-equiv

  ő†Őā-unstraighten-Arrow-equiv : Arrow-equiv (ő†Őā f g) (ő†ŐāŠ∂†-unstraight f g)
  ő†Őā-unstraighten-Arrow-equiv
    = ő†ŐāŠ∂†-unstraight‚Üźő†Őā , ő†ŐāŠ∂†-unstraight‚Üźő†Őā-is-Arrow-equiv

  ő†Őā-Arrow-equiv‚Üź‚ČÉŠ∂†
    : {ūĚď§5 ūĚď§6 : Level}
      (H : Fam ūĚď§5 ūĚď§6)
    ‚Üí ő†ŐāŠ∂†-unstraight-fibre-fam f g ‚ČÉŠ∂† H
    ‚Üí Arrow-equiv (ő†Őā f g) (arrow‚ÜźFam H)
  ő†Őā-Arrow-equiv‚Üź‚ČÉŠ∂† H
    = concat-Arrow-equiv-‚ČÉŠ∂†
        (ő†ŐāŠ∂†-unstraight-fibre-fam f g)
        (H)
        (ő†Őā-unstraighten-Arrow-equiv)

  ő†Őā-fibre-fam
    : Fam (ūĚď§1 ‚äĒ ūĚď§2 ‚äĒ ūĚď§3 ‚äĒ ūĚď§4)
          (ūĚď§1 ‚äĒ ūĚď§2 ‚äĒ ūĚď§3 ‚äĒ ūĚď§4)
  ő†Őā-fibre-fam
    = Arrow-ő† f g
    , fibre (ő†Őā f g)

  ő†Őā-unstraight-fibre-fam
    : Fam (ūĚď§1 ‚äĒ ūĚď§2 ‚äĒ ūĚď§3 ‚äĒ ūĚď§4)
          (ūĚď§1 ‚äĒ ūĚď§2 ‚äĒ ūĚď§3 ‚äĒ ūĚď§4)
  ő†Őā-unstraight-fibre-fam
    = ő†Őā-unstraight-cod f g
    , fibre (ő†ŐāŠ∂†-unstraight f g)

  ő†Őā-unstraighten‚ČÉŠ∂†
    : ő†Őā-fibre-fam ‚ČÉŠ∂† ő†Őā-unstraight-fibre-fam
  ő†Őā-unstraighten‚ČÉŠ∂†
    = mk‚ČÉ ő†Őā-unstraight-cod‚ÜźArrow-ő† ő†Őā-unstraight-cod‚ÜźArrow-ő†-is-equiv
    , (őĽ t
      ‚Üí mk‚ČÉ (arrow-fibre ő†ŐāŠ∂†-unstraight‚Üźő†Őā t)
            (is-cartesian‚Üźis-equiv ő†ŐāŠ∂†-unstraight‚Üźő†Őā
                                   ő†ŐāŠ∂†-unstraight‚Üźő†Őā-is-Arrow-equiv
                                   t))

  ő†Őā-unstraight-fibre-fam‚ČÉő†ŐāŠ∂†-unstraight-fibre-fam
    : ő†Őā-unstraight-fibre-fam ‚ČÉŠ∂† ő†ŐāŠ∂†-unstraight-fibre-fam f g
  ő†Őā-unstraight-fibre-fam‚ČÉő†ŐāŠ∂†-unstraight-fibre-fam
    = id‚ČÉ
    , (őĽ t ‚Üí coe‚ČÉ (ap (őĽ P ‚Üí P t) (straighten-ő†ŐāŠ∂†-unstraight-bundle f g)))

  ő†Őā-fibre-fam‚ČÉő†ŐāŠ∂†-unstraight-fibre-fam
    : ő†Őā-fibre-fam ‚ČÉŠ∂† ő†ŐāŠ∂†-unstraight-fibre-fam f g
  ő†Őā-fibre-fam‚ČÉő†ŐāŠ∂†-unstraight-fibre-fam
    = concat‚ČÉŠ∂†
        (ő†ŐāŠ∂†-unstraight-fibre-fam f g)
        (ő†Őā-unstraighten‚ČÉŠ∂†)
        (ő†Őā-unstraight-fibre-fam‚ČÉő†ŐāŠ∂†-unstraight-fibre-fam)
}
}

\subtree[stt-00ES]{
\taxon{Lemma}
\title{Changing the family in the base of #{\pulldpow^\rm{f}}}
\author{fredrikbakke}

\agda{
module _
  {ūĚď§1 ūĚď§2 ūĚď§3 ūĚď§4 ūĚď§5 : Level}
  {A : Type ūĚď§1} {B : A ‚Üí Type ūĚď§2} {C : A ‚Üí Type ūĚď§3}
  (Y'@(X , Y) : DepFam ūĚď§4 ūĚď§5 (A , B))
  (e : (a : A) ‚Üí B a ‚ČÉ C a) where

  ő†ŐāŠ∂†-ap-base-fam-base
    : base-ő†ŐāŠ∂† (A , B) Y' ‚ČÉ base-ő†ŐāŠ∂† (A , C) Y'
  ő†ŐāŠ∂†-ap-base-fam-base
    = ő£-ap-‚ČÉ (őĽ i ‚Üí ő†-ap-‚ČÉ (őĽ a ‚Üí precomp-‚ČÉ ((e a) e‚ĀĽ¬Ļ)))

  ő†ŐāŠ∂†-ap-base-fam-family
    : (fp : base-ő†ŐāŠ∂† (A , B) Y')
    ‚Üí fam-ő†ŐāŠ∂† (A , B) Y' fp
    ‚ČÉ fam-ő†ŐāŠ∂† (A , C) Y' (ő†ŐāŠ∂†-ap-base-fam-base ._‚ČÉ_.fwd fp)
  ő†ŐāŠ∂†-ap-base-fam-family (i , j)
    = ő†-ap-‚ČÉ (őĽ a ‚Üí null-homotopy-postcomp-‚ČÉ (e a) (j a))

  ő†ŐāŠ∂†-ap-base-fam : ő†ŐāŠ∂† (A , B) Y' ‚ČÉŠ∂† ő†ŐāŠ∂† (A , C) Y'
  ő†ŐāŠ∂†-ap-base-fam = ő†ŐāŠ∂†-ap-base-fam-base , ő†ŐāŠ∂†-ap-base-fam-family
}
}

\subtree[stt-00ET]{
\taxon{Theorem}
\title{The equivalence of straightened pullback powers}
\author{fredrikbakke}


\p{Given families #{B : A \to \UU} and #{Y : (a : A) \to X a \to \UV}, their
fibrewise dependent pullback power is equivalent, as a family, to the straightening
of the dependent pullback power of total space projections.

##{\pulldpow^{\mathrm f} B\ Y \simeq \pulldpow_{\text{straight}} B\ Y}
}

\agda{
module _
  {ūĚď§1 ūĚď§2 ūĚď§3 ūĚď§4}
  (B'@(A , B) : Fam ūĚď§1 ūĚď§2)
  (Y'@(X , Y) : DepFam ūĚď§3 ūĚď§4 B')
  (let fŠĶė = fst {A = A} {B = B})
  (let gŠĶė = őĽ a ‚Üí fst {A = X a} {B = Y a})
  (let BŠĶėňĘ = fibre-fam fŠĶė)
  (let YŠĶėňĘ = fibre-depfam gŠĶė)
  where

  ő†Őā-straight
    : Fam (ūĚď§1 ‚äĒ ūĚď§2 ‚äĒ ūĚď§3 ‚äĒ ūĚď§4) (ūĚď§1 ‚äĒ ūĚď§2 ‚äĒ ūĚď§3 ‚äĒ ūĚď§4)
  ő†Őā-straight = ő†Őā-fibre-fam fŠĶė gŠĶė

  ő†ŐāŠ∂†-fibre-fam-unstraight
    : Fam (ūĚď§1 ‚äĒ ūĚď§2 ‚äĒ ūĚď§3 ‚äĒ ūĚď§4) (ūĚď§1 ‚äĒ ūĚď§2 ‚äĒ ūĚď§4)
  ő†ŐāŠ∂†-fibre-fam-unstraight = ő†ŐāŠ∂† BŠĶėňĘ Y'

  ő†ŐāŠ∂†-unstraight-fibre-fam‚ČÉő†ŐāŠ∂†-fibre-fam-unstraight
    : ő†ŐāŠ∂†-unstraight-fibre-fam fŠĶė gŠĶė ‚ČÉŠ∂† ő†ŐāŠ∂†-fibre-fam-unstraight
  ő†ŐāŠ∂†-unstraight-fibre-fam‚ČÉő†ŐāŠ∂†-fibre-fam-unstraight
    = ő†ŐāŠ∂†-ap-‚ČÉŠĶąŠ∂† BŠĶėňĘ YŠĶėňĘ Y' (őĽ a ‚Üí (id‚ČÉ , fibre-straighten (Y a)))

  ő†ŐāŠ∂†-fibre-fam-unstraight‚ČÉő†ŐāŠ∂†
    : ő†ŐāŠ∂†-fibre-fam-unstraight ‚ČÉŠ∂† ő†ŐāŠ∂† B' Y'
  ő†ŐāŠ∂†-fibre-fam-unstraight‚ČÉő†ŐāŠ∂†
    = ő†ŐāŠ∂†-ap-base-fam Y' (fibre-straighten B)

  ő†ŐāŠ∂†-unstraight-fibre-fam‚ČÉő†ŐāŠ∂†
    : ő†ŐāŠ∂†-unstraight-fibre-fam fŠĶė gŠĶė ‚ČÉŠ∂† ő†ŐāŠ∂† B' Y'
  ő†ŐāŠ∂†-unstraight-fibre-fam‚ČÉő†ŐāŠ∂†
    = concat‚ČÉŠ∂†
        (ő†ŐāŠ∂† B' Y')
        (ő†ŐāŠ∂†-unstraight-fibre-fam‚ČÉő†ŐāŠ∂†-fibre-fam-unstraight)
        (ő†ŐāŠ∂†-fibre-fam-unstraight‚ČÉő†ŐāŠ∂†)

  ő†Őā-straight‚ČÉő†ŐāŠ∂†-unstraight-fibre-fam : ő†Őā-straight ‚ČÉŠ∂† ő†ŐāŠ∂†-unstraight-fibre-fam fŠĶė gŠĶė
  ő†Őā-straight‚ČÉő†ŐāŠ∂†-unstraight-fibre-fam
    = concat‚ČÉŠ∂†
        (ő†ŐāŠ∂†-unstraight-fibre-fam fŠĶė gŠĶė)
        (ő†Őā-unstraighten‚ČÉŠ∂† fŠĶė gŠĶė)
        (ő†Őā-unstraight-fibre-fam‚ČÉő†ŐāŠ∂†-unstraight-fibre-fam fŠĶė gŠĶė)

  ő†Őā-straighten‚ČÉŠ∂† : ő†Őā-straight ‚ČÉŠ∂† ő†ŐāŠ∂† B' Y'
  ő†Őā-straighten‚ČÉŠ∂†
    = concat‚ČÉŠ∂†
        (ő†ŐāŠ∂† B' Y')
        (ő†Őā-straight‚ČÉő†ŐāŠ∂†-unstraight-fibre-fam)
        (ő†ŐāŠ∂†-unstraight-fibre-fam‚ČÉő†ŐāŠ∂†)
}
}
}

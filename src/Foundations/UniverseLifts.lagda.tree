\subtree[stt-0077]{
\title{Lifting types up universe levels}
\taxon{Definition}

\p{In Agda Universes are not cumulative by definition. But we
can use a record type to lift a type in #{\UU} to a universe #{\UU \cup \UV}.
We also note that Lift has a functorial action on types.}

\agda{
record ULift {рЭУ§} рЭУ• (A : Type рЭУ§) : Type (рЭУ§ вКФ рЭУ•) where
  constructor mk-lift
  field
    unlift : A

open ULift public

ULift-map
  : вИА {рЭУ§ рЭУ• рЭУ¶} {A : Type рЭУ§} {B : Type рЭУ•}
    вЖТ (f : A вЖТ B) вЖТ ULift рЭУ¶ A вЖТ ULift рЭУ¶ B
ULift-map f (mk-lift a) = mk-lift (f a)
}
}

\subtree[stt-0078]{
\taxon{Theorem}
\title{Lift is an equivalence}

\agda{
lift-is-equiv : вИА {рЭУ§ рЭУ•} {A : Type рЭУ§} вЖТ is-equiv (mk-lift {рЭУ§} {рЭУ•} {A})
lift-is-equiv = is-equivвЖРqinv (ќї where
  .fst вЖТ unlift
  .snd .fst вЖТ ~refl
  .snd .snd вЖТ ~refl)

liftвЙГ : вИА {рЭУ§ рЭУ•} {A : Type рЭУ§} вЖТ A вЙГ ULift рЭУ• A
liftвЙГ = mkвЙГ mk-lift lift-is-equiv

unlift-is-equiv : вИА {рЭУ§ рЭУ•} {A : Type рЭУ§} вЖТ is-equiv (unlift {рЭУ§} {рЭУ•} {A = A})
unlift-is-equiv = is-equivвБї¬є lift-is-equiv

unliftвЙГ : вИА {рЭУ§ рЭУ•} {A : Type рЭУ§} вЖТ ULift рЭУ• A вЙГ A
unliftвЙГ = mkвЙГ unlift unlift-is-equiv
}
}

\subtree[fre-9D81]{
\taxon{Example}
\author{fredrikbakke}
\date{2026-04-29}

\agda{
рЭЯЩбіЄ: : (рЭУ§ : Level) вЖТ Type рЭУ§
рЭЯЩбіЄ: рЭУ§ = ULift рЭУ§ рЭЯЩ

рЭЯЩбіЄ : {рЭУ§ : Level} вЖТ Type рЭУ§
рЭЯЩбіЄ {рЭУ§} = рЭЯЩбіЄ: рЭУ§

!біЄ: : {рЭУ§ : Level} (рЭУ• : Level) (A : Type рЭУ§) вЖТ A вЖТ рЭЯЩбіЄ: рЭУ•
!біЄ: рЭУ• A = mk-lift вИШ (!: A)

!біЄ : {рЭУ§ рЭУ• : Level} {A : Type рЭУ§} вЖТ A вЖТ рЭЯЩбіЄ: рЭУ•
!біЄ {рЭУ§} {рЭУ•} {A} = !біЄ: рЭУ• A

рЭЯЩбіЄ-is-singleton : {рЭУ§ : Level} вЖТ is-singleton (рЭЯЩбіЄ: рЭУ§)
рЭЯЩбіЄ-is-singleton
  = is-singleвЖРequiv-to-single liftвЙГ рЭЯЩ-is-singleton
}

\agda{
вИЕбіЄ: : (рЭУ§ : Level) вЖТ Type рЭУ§
вИЕбіЄ: рЭУ§ = ULift рЭУ§ вИЕ

вИЕбіЄ : {рЭУ§ : Level} вЖТ Type рЭУ§
вИЕбіЄ {рЭУ§} = вИЕбіЄ: рЭУ§

¬°біЄ: : {рЭУ§ : Level} (рЭУ• : Level) (A : Type рЭУ§) вЖТ вИЕбіЄ: рЭУ• вЖТ A
¬°біЄ: рЭУ• A = (¬°: A) вИШ unlift

¬°біЄ : {рЭУ§ рЭУ• : Level} {A : Type рЭУ§} вЖТ вИЕбіЄ: рЭУ• вЖТ A
¬°біЄ {рЭУ§} {рЭУ•} {A} = ¬°біЄ: рЭУ• A
}
}

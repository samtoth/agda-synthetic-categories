
\title{The category of maps of types}
\taxon{Module}
\import{stt-macros}

% ```agda
\agda{
{-# OPTIONS --lossy-unification #-}

module Core.Arrows where

open import Foundations.Prelude
open import UF

open import Ergonomics.Representation
open import Ergonomics.Marker
open import Ergonomics.Extensionality

open import Core.Slices
open import Core.CanonicalPushouts
}
% ```

\subtree[stt-0038]{
\taxon{Definition}
\title{Walking morphisms in #{\Type}}
\date{2025-04-18}
\author{samueltoth}
\contributor{fredrikbakke}

\p{
An \em{arrow} of types is the bundled data of a function of types. I.e., it is
the data consisting of two types #{A}, #{B}, and a function between them
#{f : A \to B}.
}

% ```agda
\agda{
record Arrow (рқ“Ө рқ“Ҙ : Level) : Type (lsuc рқ“Ө вҠ” lsuc рқ“Ҙ) where
  constructor mk-arrow
  no-eta-equality
  field
    {dom} : Type рқ“Ө
    {cod} : Type рқ“Ҙ
    f : dom вҶ’ cod
}
% ```
}

\subtree[stt-00EF]{
\taxon{Definition}
\date{2026-02-20}
\title{Dependent morphisms of arrows}

\p{
Given an arrow #{f : A \to B}, a \em{dependent arrow} over #{f} is a family of arrows
over its domain, #{g : (b : B) \to X(b) \to Y(b)}. Given such a dependent arrow, then a
\em{dependent morphism of arrows} is a pair of dependent functions
#{i : (b : B) \to Y(b)} and #{j : (a : A) \to X (f(a))} so that #{i \circ f \sim g \circ j}.
}

% ```agda
\agda{
module _
  {рқ“Ө1 рқ“Ө2 рқ“Ө3 рқ“Ө4 : Level}
  {A : Type рқ“Ө1}
  {B : Type рқ“Ө2}
  (f : A вҶ’ B)
  {X : B вҶ’ Type рқ“Ө3}
  {Y : B вҶ’ Type рқ“Ө4}
  (g : (b : B) вҶ’ X b вҶ’ Y b)
  where

  record Arrow-О  : Type (рқ“Ө1 вҠ” рқ“Ө2 вҠ” рқ“Ө3 вҠ” рқ“Ө4) where
    constructor mk-amap
    field
      top : (a : A) вҶ’ X (f a)
      bot : (b : B) вҶ’ Y b
      comm : precomp-О  Y f bot ~ postcomp-О  (О» a вҶ’ g (f a)) top

  unquoteDecl Arrow-О -reprвүҠ Arrow-О -reprвүғ
    = make-record-repr Arrow-О -reprвүҠ Arrow-О -reprвүғ (quote Arrow-О )
}
% ```
}

\subtree[stt-003U]{
\taxon{Definition}
\title{Morphisms of arrows}

\p{
Given a pair of arrows, we define a morphism between them to be a commutative square,
that is, a pair of a maps and a homotopy witnessing that the square commutes.
}

% ```agda
\agda{
module _
  {рқ“Ө рқ“Ҙ рқ“Ұ рқ“ӣ}
  {A : Type рқ“Ө} {B : Type рқ“Ҙ} (f : A вҶ’ B)
  {C : Type рқ“Ұ} {D : Type рқ“ӣ} (f' : C вҶ’ D)
  where

  Arrow-map : Type (рқ“Ө вҠ” рқ“Ҙ вҠ” рқ“Ұ вҠ” рқ“ӣ)
  Arrow-map = Arrow-О  f (О» _ вҶ’ f')

  Arrow-map-reprвүҠ : Arrow-map вүҠ _
  Arrow-map-reprвүҠ = Arrow-О -reprвүҠ f (О» _ вҶ’ f')

  Arrow-map-reprвүғ : Arrow-map вүғ _
  Arrow-map-reprвүғ = Arrow-О -reprвүғ f (О» _ вҶ’ f')

module Arrow-map = Arrow-О 
}
% ```
}

\subtree[stt-00EG]{
\taxon{Theorem}
\date{2026-02-20}
\title{The type of dependent morphisms of arrows as a pullback}
\author{fredrikbakke}

\p{The type #{\Hom^{\mathrm{d}}(f,g)} is the pullback of #{g \circ {-}} and
#{{-} \circ f}.}

%```agda
\agda{
module _
  {рқ“Ө1 рқ“Ө2 рқ“Ө3 рқ“Ө4 : Level}
  {A : Type рқ“Ө1}
  {B : Type рқ“Ө2}
  {f : A вҶ’ B}
  {X : B вҶ’ Type рқ“Ө3}
  {Y : B вҶ’ Type рқ“Ө4}
  {g : (b : B) вҶ’ X b вҶ’ Y b}
  where

  Arrow-О -cone
    : Cone (mk-cospan ((a : A) вҶ’ Y (f a))
                      (precomp-О  Y f)
                      (postcomp-О  (О» a вҶ’ g (f a))))
           (Arrow-О  f g)
  Arrow-О -cone .Cone.i p = Arrow-О .bot p
  Arrow-О -cone .Cone.j p = Arrow-О .top p
  Arrow-О -cone .Cone.filler p = funextвҶ’ (Arrow-О .comm p)

  Arrow-О вүғpullback-repr
    : Arrow-О  f g
    вүғ Pullback (precomp-О  Y f) (postcomp-О  (О» a вҶ’ g (f a)))
  Arrow-О вүғpullback-repr
    = Arrow-О  f g
        вүғвҹЁ Arrow-О -reprвүғ f g вҹ©
      ОЈ[ t вҲ¶ ((a : A) вҶ’ X (f a)) ]
      ОЈ[ b вҲ¶ ((b : B) вҶ’ Y b) ]
       (precomp-О  Y f b ~ postcomp-О  (О» a вҶ’ g (f a)) t)
        вүғвҹЁ ОЈ-comm вҹ©
      ОЈ[ b вҲ¶ ((b : B) вҶ’ Y b) ]
      ОЈ[ t вҲ¶ ((a : A) вҶ’ X (f a)) ]
       (precomp-О  Y f b ~ postcomp-О  (О» a вҶ’ g (f a)) t)
        вүғвҹЁ ОЈ-ap-вүғ (О» _ вҶ’ ОЈ-ap-вүғ О» _ вҶ’ (funextвүғ eвҒ»В№)) вҹ©
      Pullback (precomp-О  Y f) (postcomp-О  (О» a вҶ’ g (f a)))
        вүғвҲҺ

  Arrow-О вүғpullback-repr~gap
    : Arrow-О вүғpullback-repr ._вүғ_.fwd ~ gap Arrow-О -cone
  Arrow-О вүғpullback-repr~gap = ~refl

  Arrow-О -gap-is-equiv : is-equiv (gap Arrow-О -cone)
  Arrow-О -gap-is-equiv
    = homotopy-is-equiv (Arrow-О вүғpullback-repr~gap)
                        (Arrow-О вүғpullback-repr ._вүғ_.has-is-eqv)

  Arrow-О вүғpullback
    : Arrow-О  f g
    вүғ Pullback (precomp-О  Y f) (postcomp-О  (О» a вҶ’ g (f a)))
  Arrow-О вүғpullback
    = mkвүғ (gap Arrow-О -cone) (Arrow-О -gap-is-equiv)
}
%```
}

\subtree[stt-004H]{
\taxon{Theorem}
\date{2025-05-17}
\title{The type of morphisms of arrows as a pullback}

\p{The type #{\Hom(f,g)} is the pullback of #{g \circ {-}} and #{{-} \circ f}.}

%```agda
\agda{
module _ {рқ“Ө рқ“Ҙ} {A : Type рқ“Ө} {B : Type рқ“Ҙ} {f : A вҶ’ B}
         {рқ“Ұ рқ“ӣ} {C : Type рқ“Ұ} {D : Type рқ“ӣ} {g : C вҶ’ D} where

  Arrow-mapвүғpullback' : Arrow-map f g вүғ Pullback (_вҲҳ f) (g вҲҳ_)
  Arrow-mapвүғpullback' = Arrow-О вүғpullback {f = f} {g = О» _ вҶ’ g}

  Arrow-mapвүғpullback : Arrow-map f g вүғ Pullback (g вҲҳ_) (_вҲҳ f)
  Arrow-mapвүғpullback = Arrow-mapвүғpullback' вҲҷвүғ pullback-swap

  pullbackвҶҗarrow' : Arrow-map f g вҶ’ Pullback (_вҲҳ f) (g вҲҳ_)
  pullbackвҶҗarrow' = Arrow-mapвүғpullback' ._вүғ_.fwd

  pullbackвҶҗarrow : Arrow-map f g вҶ’ Pullback (g вҲҳ_) (_вҲҳ f)
  pullbackвҶҗarrow = Arrow-mapвүғpullback ._вүғ_.fwd
}
%```
}

\subtree[stt-004I]{
\title{Characterising the paths of morphisms of arrows}
\taxon{Theorem}

%```agda
\agda{
module _ {рқ“Ө рқ“Ҙ} {A : Type рқ“Ө} {B : Type рқ“Ҙ} {f : A вҶ’ B}
         {рқ“Ұ рқ“ӣ} {C : Type рқ“Ұ} {D : Type рқ“ӣ} {f' : C вҶ’ D} where

  Arrow-map-path : вҲҖ (G H : Arrow-map f f') вҶ’ Type (рқ“Ө вҠ” рқ“Ҙ вҠ” рқ“Ұ вҠ” рқ“ӣ)
  Arrow-map-path (mk-amap t b H) (mk-amap t' b' H')
    = ОЈ[ p вҲ¶ t ~ t' ] ОЈ[ q вҲ¶ b ~ b' ]
      (H ~вҲҷ (f' в—Ӯ p) ~ q в–ё f ~вҲҷ H')

  Arrow-map-path-refl : {G : Arrow-map f f'} вҶ’ Arrow-map-path G G
  Arrow-map-path-refl = ~refl , ~refl , ~вҲҷ-reflr _

  Arrow-map-path-is-Rppred
    : вҲҖ (G : Arrow-map f f')
      вҶ’ Reflexive-ppred _ G _
  Arrow-map-path-is-Rppred G = (Arrow-map-path G) , Arrow-map-path-refl

  Arrow-map-pathвҶҗid : вҲҖ {G H : Arrow-map f f'} вҶ’ (G пјқ H) вҶ’ Arrow-map-path G H
  Arrow-map-pathвҶҗid refl = Arrow-map-path-refl

  opaque
    Arrow-map-pathвүғ : вҲҖ (G H : Arrow-map f f') вҶ’ (G пјқ H) вүғ Arrow-map-path G H
    Arrow-map-pathвүғ G@(mk-amap t b h) H
      = mkвүғ Arrow-map-pathвҶҗid
            (fundamental-Id
              (Arrow-map-path G)
              (is-singleвҶҗequiv-to-single
                (ОЈ-ap-вүғ-fst (Arrow-map-reprвүғ _ _ eвҒ»В№))
                (is-singleton-structureвҶҗparts (SingS-is-single t)
                  (t , ~refl)
                  (is-singleton-structureвҶҗparts (SingS-is-single b)
                    (b , ~refl)
                    (SingS-is-single О» a вҶ’ h a вҲҷ refl))))
              (О» _ вҶ’ Arrow-map-pathвҶҗid) H)

    Arrow-map-pathвҶ’
      : вҲҖ {G H : Arrow-map f f'} вҶ’ Arrow-map-path G H
        вҶ’ (G пјқ H)
    Arrow-map-pathвҶ’ = _вүғ_.bwd (Arrow-map-pathвүғ _ _)

    Arrow-map-pathвҶ’-refl
      : вҲҖ {G : Arrow-map f f'}
        вҶ’ Arrow-map-pathвҶ’ (Arrow-map-path-refl {G = G}) пјқ refl
    Arrow-map-pathвҶ’-refl
      = unap-equiv (Arrow-map-pathвүғ _ _ ._вүғ_.has-is-eqv)
                   (is-equiv.Оө (Arrow-map-pathвүғ _ _ ._вүғ_.has-is-eqv) _)
}
%```
}

\subtree[stt-003X]{
\taxon{Theorem}
\title{Arrows and squares form a category}

% ```agda
\agda{
id-square
  : вҲҖ {рқ“Ө рқ“Ҙ} {A : Type рқ“Ө} {B : Type рқ“Ҙ} {f : A вҶ’ B}
    вҶ’ Arrow-map f f
id-square = mk-amap id id ~refl

infix 30 id-square:_
id-square:_ : вҲҖ {рқ“Ө рқ“Ҙ} {A : Type рқ“Ө} {B : Type рқ“Ҙ} (f : A вҶ’ B) вҶ’ Arrow-map f f
id-square: f = id-square

module _ {рқ“Ө рқ“Ҙ} {A : Type рқ“Ө} {B : Type рқ“Ҙ} {f : A вҶ’ B}
         {рқ“Ө' рқ“Ҙ'} {A' : Type рқ“Ө'} {B' : Type рқ“Ҙ'} {f' : A' вҶ’ B'}
         {рқ“Ө'' рқ“Ҙ''} {A'' : Type рқ“Ө''} {B'' : Type рқ“Ҙ''} {f'' : A'' вҶ’ B''} where

  paste-squares
    : Arrow-map f' f''
    вҶ’ Arrow-map f f'
    вҶ’ Arrow-map f f''
  paste-squares (mk-amap g' h' comm') (mk-amap g h comm)
    = mk-amap (g' вҲҳ g) (h' вҲҳ h) (h' в—Ӯ comm ~вҲҷ comm' в–ё g)
}
% ```
}

\subtree[stt-00LU]{
\title{Associativity and unit laws for pasting squares}
\taxon{Lemma}
\author{fredrikbakke}
\date{2026-04-05}

%```agda
\agda{
paste-squares-assoc
  : {рқ“Ө1 рқ“Ҙ1 рқ“Ө2 рқ“Ҙ2 рқ“Ө3 рқ“Ҙ3 рқ“Ө4 рқ“Ҙ4 : Level}
    {A1 : Type рқ“Ө1} {B1 : Type рқ“Ҙ1} {f1 : A1 вҶ’ B1}
    {A2 : Type рқ“Ө2} {B2 : Type рқ“Ҙ2} {f2 : A2 вҶ’ B2}
    {A3 : Type рқ“Ө3} {B3 : Type рқ“Ҙ3} {f3 : A3 вҶ’ B3}
    {A4 : Type рқ“Ө4} {B4 : Type рқ“Ҙ4} {f4 : A4 вҶ’ B4}
  вҶ’ (H : Arrow-map f3 f4)
  вҶ’ (G : Arrow-map f2 f3)
  вҶ’ (F : Arrow-map f1 f2)
  вҶ’ Arrow-map-path
    (paste-squares H (paste-squares G F))
    (paste-squares (paste-squares H G) F)
paste-squares-assoc H G F .fst = ~refl
paste-squares-assoc H G F .snd .fst = ~refl
paste-squares-assoc H G F .snd .snd a
  = let
      p = Arrow-map.comm F a
      q = Arrow-map.comm G (Arrow-map.top F a)
      r = Arrow-map.comm H (Arrow-map.top G (Arrow-map.top F a))
    in вҲҷ-reflr _
     вҲҷ ap (_вҲҷ r) (ap-вҲҷ (Arrow-map.bot H) (ap (Arrow-map.bot G) p) q)
     вҲҷ вҲҷ-assoc
         (ap (Arrow-map.bot H) (ap (Arrow-map.bot G) p))
         (ap (Arrow-map.bot H) q)
         (r)
     вҲҷ ap
         (_вҲҷ ap (Arrow-map.bot H) q вҲҷ r)
         (sym (ap-вҲҳ (Arrow-map.bot H) (Arrow-map.bot G) p))

paste-squares-left-id
  : {рқ“Ө1 рқ“Ҙ1 рқ“Ө2 рқ“Ҙ2 : Level}
    {A1 : Type рқ“Ө1} {B1 : Type рқ“Ҙ1} {f : A1 вҶ’ B1}
    {A2 : Type рқ“Ө2} {B2 : Type рқ“Ҙ2} {g : A2 вҶ’ B2}
  вҶ’ (F : Arrow-map f g)
  вҶ’ Arrow-map-path (paste-squares (id-square: g) F) F
paste-squares-left-id F .fst = ~refl
paste-squares-left-id F .snd .fst = ~refl
paste-squares-left-id F .snd .snd a
  = вҲҷ-reflr _
  вҲҷ вҲҷ-reflr _
  вҲҷ ap-id (Arrow-map.comm F a)

paste-squares-right-id
  : {рқ“Ө1 рқ“Ҙ1 рқ“Ө2 рқ“Ҙ2 : Level}
    {A1 : Type рқ“Ө1} {B1 : Type рқ“Ҙ1} {f : A1 вҶ’ B1}
    {A2 : Type рқ“Ө2} {B2 : Type рқ“Ҙ2} {g : A2 вҶ’ B2}
  вҶ’ (F : Arrow-map f g)
  вҶ’ Arrow-map-path (paste-squares F (id-square: f)) F
paste-squares-right-id F .fst = ~refl
paste-squares-right-id F .snd .fst = ~refl
paste-squares-right-id F .snd .snd a = вҲҷ-reflr _
}
%```
}

\subtree[stt-003V]{
\taxon{Definition}
\title{Cartesian squares}

\p{Given a map of arrows #{f \to f'}, we can define a family of functions
from the fibre over #{f} to the fibre over #{f'}. If this map is a
fibrewise equivalence, then we say that the square is cartesian (or a pullback
square).
}

% ```agda
\agda{
module _ {рқ“Ө рқ“Ҙ} {A : Type рқ“Ө} {B : Type рқ“Ҙ} {f : A вҶ’ B}
         {рқ“Ұ рқ“ӣ} {C : Type рқ“Ұ} {D : Type рқ“ӣ} {f' : C вҶ’ D} where
  arrow-fibre
    : (gs : Arrow-map f f')
    вҶ’ (b : B)
    вҶ’ fibre f b вҶ’ fibre f' (gs .Arrow-map.bot b)
  arrow-fibre (mk-amap g g' hom) b (a , p) = (g a , sym (hom a) вҲҷ ap g' p)

  is-cartesian : Arrow-map f f' вҶ’ Type (рқ“Ө вҠ” рқ“Ҙ вҠ” рқ“Ұ вҠ” рқ“ӣ)
  is-cartesian a = is-fibrewise-equiv (arrow-fibre a)

  is-cartesian-is-prop
    : вҲҖ {F : Arrow-map f f'} вҶ’ is-prop (is-cartesian F)
  is-cartesian-is-prop
    = О -is-prop (О» a вҶ’ is-equiv-is-prop)
}
% ```
}

\subtree[stt-003W]{
\taxon{Theorem}
\title{Horizontal composition of cartesian squares}

% ```agda
\agda{
module _ {рқ“Ө рқ“Ҙ} {A : Type рқ“Ө} {B : Type рқ“Ҙ} {f : A вҶ’ B}
         {рқ“Ө' рқ“Ҙ'} {A' : Type рқ“Ө'} {B' : Type рқ“Ҙ'} {f' : A' вҶ’ B'}
        {рқ“Ө'' рқ“Ҙ''} {A'' : Type рқ“Ө''} {B'' : Type рқ“Ҙ''} {f'' : A'' вҶ’ B''} where

  arrow-fibre-вҲҳ
    : вҲҖ (F : Arrow-map f' f'') (G : Arrow-map f f')
      вҶ’ вҲҖ b
      вҶ’ arrow-fibre (paste-squares F G) b
      ~ arrow-fibre F (Arrow-map.bot G b) вҲҳ arrow-fibre G b
  arrow-fibre-вҲҳ F@(mk-amap f f' fcomm) G@(mk-amap g g' gcomm) b (a , p)
    = ОЈ-pathвҶ’ (refl , lem) where
       lem : sym (ap f' (gcomm a) вҲҷ fcomm (g a)) вҲҷ ap (f' вҲҳ g') p пјқ
              sym (fcomm (g a)) вҲҷ ap f' (sym (gcomm a) вҲҷ ap g' p)
       lem = вҢң sym (ap f' (gcomm a) вҲҷ fcomm (g a)) вҢқ вҲҷ ap (f' вҲҳ g') p
               пјқвҹЁ ap! (вҲҷ-symsym (ap f' (gcomm a)) _) вҹ©
             (sym (fcomm (g a)) вҲҷ вҢң sym (ap f' (gcomm a)) вҢқ) вҲҷ ap (f' вҲҳ g') p
               пјқвҹЁ ap! (sym (ap-sym f' _)) вҹ©
             (sym (fcomm (g a)) вҲҷ ap f' (sym (gcomm a))) вҲҷ ap (f' вҲҳ g') p
               пјқвҹЁ вҲҷ-assoc (sym (fcomm (g a))) _ _ вҹ©
             sym (fcomm (g a)) вҲҷ ap f' (sym (gcomm a)) вҲҷ вҢң ap (f' вҲҳ g') p вҢқ
               пјқвҹЁ ap! (ap-вҲҳ f' g' p) вҹ©
             sym (fcomm (g a)) вҲҷ вҢң ap f' (sym (gcomm a)) вҲҷ (ap f' (ap g' p)) вҢқ
               пјқвҹЁ ap! (sym (ap-вҲҷ f' (sym _) (ap g' p))) вҹ©
             sym (fcomm (g a)) вҲҷ ap f' (sym (gcomm a) вҲҷ ap g' p) вҲҺ

  compose-cartesian
    : вҲҖ {a : Arrow-map f' f''} {b : Arrow-map f f'}
      вҶ’ (ae : is-cartesian a) (be : is-cartesian b)
      вҶ’ is-cartesian (paste-squares a b)
  compose-cartesian {a} {b} ae be x
    = tr is-equiv (funextвҶ’ (arrow-fibre-вҲҳ a b x ~вҒ»В№))
       (is-equiv-вҲҳ {f = arrow-fibre a (b .Arrow-map.bot x)} {g = arrow-fibre b x}
         (ae (b .Arrow-map.bot x))
         (be x)) where
    module b = is-equiv (be x)
    module a = is-equiv (ae (b .Arrow-map.bot x))

    open Arrow-map

    II : (x : B) (fib : fibre f x) вҶ’
       sym (paste-squares a b .Arrow-map.comm (fib .fst)) вҲҷ
         ap (paste-squares a b .Arrow-map.bot) (fib .snd)
        пјқ
       (arrow-fibre a (b .Arrow-map.bot x) вҲҳ arrow-fibre b x)
         fib .snd
    II x (aa , p)
     = sym (paste-squares a b .comm aa) вҲҷ ap (paste-squares a b .bot) p
         пјқвҹЁвҹ©
       вҢң sym (ap (a .bot) (b .comm aa) вҲҷ a .comm (b .top aa)) вҢқ вҲҷ ap (a .bot вҲҳ b .bot) p
         пјқвҹЁ ap! (вҲҷ-symsym (ap (a .bot) (b .comm aa)) _) вҹ©
       (sym (a .comm (b .top aa)) вҲҷ sym (ap (a .bot) (b .comm aa))) вҲҷ ap (a .bot вҲҳ b .bot) p
         пјқвҹЁ вҲҷ-assoc (sym (a .comm (b .top aa))) _ (ap (a .bot вҲҳ b .bot) p) вҹ©
       sym (a .comm (b .top aa)) вҲҷ вҢң sym (ap (a .bot) (b .comm aa)) вҢқ вҲҷ ap (a .bot вҲҳ b .bot) p
         пјқвҹЁ ap! (sym (ap-sym (a .bot) _)) вҹ©
       sym (a .comm (b .top aa)) вҲҷ ap (a .bot) (sym (b .comm aa)) вҲҷ вҢң ap (a .bot вҲҳ b .bot) p вҢқ
         пјқвҹЁ ap! (ap-вҲҳ _ _ _) вҹ©
       sym (a .comm (b .top aa)) вҲҷ вҢң ap (a .bot) (sym (b .comm aa)) вҲҷ ap (a .bot) (ap (b .bot) p) вҢқ
         пјқвҹЁ ap! (sym (ap-вҲҷ (a .bot) (sym (b .comm aa)) _)) вҹ©
       sym (a .comm (b .top aa)) вҲҷ ap (a .bot) (sym (b .comm aa) вҲҷ ap (b .bot) p)
         пјқвҹЁвҹ©
       (arrow-fibre a (b .bot x) вҲҳ arrow-fibre b x) (aa , p) .snd вҲҺ

  3-for-2-cartesian
    : вҲҖ {a : Arrow-map f' f''} {b : Arrow-map f f'}
        {H : Arrow-map f f''}
      вҶ’ Arrow-map-path H (paste-squares a b)
      вҶ’ is-cartesian H
      вҶ’ is-cartesian a
      вҶ’ is-cartesian b
  3-for-2-cartesian {a = F@(mk-amap f f' fcomm)} {b = G@(mk-amap g g' gcomm)}
                    K abcart bcart b
    = 3-for-2~ (arrow-fibre-вҲҳ F G b)
               (bcart (g' b))
               (tr is-cartesian (Arrow-map-pathвҶ’ K) abcart b)
}
% ```
}

\subtree[stt-002Z]{
\taxon{Theorem}
\title{Arrow morphisms are squares}

\p{We now have (at least) three things that can be called squares. We give functions
to convert from arrow-map squares, to either cones over cospans or cocones over spans.}

% ```agda
\agda{
CoconeвҶҗArrow-map
  : вҲҖ {рқ“Ө рқ“Ҙ} {A : Type рқ“Ө} {B : Type рқ“Ҙ} {f : A вҶ’ B}
      {рқ“Ұ рқ“ӣ} {C : Type рқ“Ұ} {D : Type рқ“ӣ} {f' : C вҶ’ D}
    вҶ’ Arrow-map f f' вҶ’ ОЈ[ S вҲ¶  Span рқ“Ө рқ“Ҙ рқ“Ұ ] Cocone S D
CoconeвҶҗArrow-map {f = f} {f' = f'} (mk-amap g g' comm)
  = (mk-span _ f g) , mk-cocone g' f' comm

Arrow-mapвҶҗCocone
  : вҲҖ {рқ“Ө рқ“Ҙ рқ“Ұ рқ“ң} {S : Span рқ“Ө рқ“Ҙ рқ“Ұ} {D : Type рқ“ң}
    вҶ’ (C : Cocone S D)
    вҶ’ Arrow-map (Span.left S) (Cocone.q C)
Arrow-mapвҶҗCocone {S = S} C = mk-amap S.right C.p C.filler where
  module S = Span S
  module C = Cocone C

ConeвҶҗArrow-map
  : вҲҖ {рқ“Ө рқ“Ҙ} {A : Type рқ“Ө} {B : Type рқ“Ҙ} {f : A вҶ’ B}
      {рқ“Ұ рқ“ӣ} {C : Type рқ“Ұ} {D : Type рқ“ӣ} {f' : C вҶ’ D}
    вҶ’ Arrow-map f f' вҶ’ ОЈ[ S вҲ¶ Cospan рқ“ӣ рқ“Ҙ рқ“Ұ ] Cone S A
ConeвҶҗArrow-map {f = f} {f' = f'} (mk-amap top bot comm)
  = (mk-cospan _ bot f') , mk-cone f top comm
}
% ```
}

\subtree[stt-004E]{
\taxon{Defition}

\title{(co)gap maps from squares}

% ```agda
\agda{
gap-mapвҶҗsquare
  : вҲҖ {рқ“Ө рқ“Ҙ} {A : Type рқ“Ө} {B : Type рқ“Ҙ} {f : A вҶ’ B}
      {рқ“Ұ рқ“ӣ} {C : Type рқ“Ұ} {D : Type рқ“ӣ} {f' : C вҶ’ D}
    вҶ’ (g : Arrow-map f f')
    вҶ’ A вҶ’ Pullback (g .Arrow-map.bot) f'
gap-mapвҶҗsquare g = gap (ConeвҶҗArrow-map g .snd)

cogap-mapвҶҗsquare
  : вҲҖ {рқ“Ө рқ“Ҙ} {A : Type рқ“Ө} {B : Type рқ“Ҙ} {f : A вҶ’ B}
      {рқ“Ұ рқ“ӣ} {C : Type рқ“Ұ} {D : Type рқ“ӣ} {f' : C вҶ’ D}
    вҶ’ (g : Arrow-map f f')
    вҶ’ Pushout f (g .Arrow-map.top) вҶ’ D
cogap-mapвҶҗsquare g = cogap (CoconeвҶҗArrow-map g .snd)
}
% ```
}

\subtree[stt-003C]{
\title{Pullback squares from cartesian arrow maps}
\taxon{Theorem}
\p{We show that a [cartesian](stt-003V) arrow map gives a pullback square.
 That is, a square is cartesian iff the corresponding cone is a pullback cone.}

\proof{
\p{Suppose we have a square:}

\quiver{
\begin{tikzcd}
	A && C \\
	\\
	B && D
	\arrow["g", from=1-1, to=1-3]
	\arrow["f"', from=1-1, to=3-1]
	\arrow["{f'}", from=1-3, to=3-3]
	\arrow["{g'}"', from=3-1, to=3-3]
\end{tikzcd}
}

\p{such that the map #{\fibre{g'}{a} \toeq \fibre{g}{f'(a)}} is
an equivalence. Then to verify it is a pullback, then we need
to show that the induced map #{A \to C \times_D B} is also an equivalence.}

\p{We can view both of these maps as living in a slice over #{C}, and a
by [[stt-003D]], a map in the slice is in equivalence iff if is an equivalence
on fibres.}

\quiver{
\begin{tikzcd}
	A && {B \times_D C} \\
	& B
	\arrow["{\textit{gap}}", from=1-1, to=1-3]
	\arrow["f"', from=1-1, to=2-2]
	\arrow["{\pi_1}", from=1-3, to=2-2]
\end{tikzcd}
}

\p{So we need to show #{\fibre{f}{c} \to \fibre{\pi_1}{c}} is an equivalence. The
fibre of the projection is equivalent to the fibre of #{g} at #{f(c)}, and so by the
[3-for-2](Foundations.3for2) property of equivalences we have that the square is a
pullback.}

% ```agda
\agda{
is-pullbackвҶҗis-cartesian : вҲҖ {рқ“Ө рқ“Ҙ рқ“Ұ рқ“ң}
  {A : Type рқ“Ө} {B : Type рқ“Ҙ} {f : A вҶ’ B}
  {C : Type рқ“Ұ} {D : Type рқ“ң} {f' : C вҶ’ D}
  вҶ’ (g : Arrow-map f f')
  вҶ’ is-cartesian g
  вҶ’ let (s , c) = ConeвҶҗArrow-map g
  in is-pullbackПү s c
is-pullbackвҶҗis-cartesian {A = A} {B} {f = f} {C} {D} {f' = f'} G pbsq
  = is-pullbackвҶҗgap cone (is-equivвҶҗon-fibres slice-map slice-equiv) where
  cospan = ConeвҶҗArrow-map G .fst
  cone = ConeвҶҗArrow-map G .snd

  g : A вҶ’ C
  g = G .Arrow-map.top

  g' : B вҶ’ D
  g' = G .Arrow-map.bot

  open pb

  slice-map : Slice-map f ПҖвӮҒ
  slice-map .fst = gap cone
  slice-map .snd = ~refl

  lem : {a = b : B} вҶ’
      arrow-fibre G b ~
      fib-ПҖвӮҒ g' f' b ._вүғ_.fwd вҲҳ Slice-fibre (gap cone , ~refl) b
  lem (a , refl) = ОЈ-pathвҶ’ (refl , (вҲҷ-reflr _))

  slice-equiv : is-fibrewise-equiv (Slice-fibre {q = ПҖвӮҒ} (gap cone , ~refl))
  slice-equiv b = 3-for-2~ {f = fib-ПҖвӮҒ g' f' b ._вүғ_.fwd}
                           lem
                           (fib-ПҖвӮҒ g' f' b ._вүғ_.has-is-eqv)
                           (pbsq b)


is-cartesianвҶҗis-pullback : вҲҖ {рқ“Ө рқ“Ҙ рқ“Ұ рқ“ң}
  {A : Type рқ“Ө} {B : Type рқ“Ҙ} {f : A вҶ’ B}
  {C : Type рқ“Ұ} {D : Type рқ“ң} {f' : C вҶ’ D}
  вҶ’ (g : Arrow-map f f')
  вҶ’ let (s , c) = ConeвҶҗArrow-map g
  in is-pullbackПү s c
  вҶ’ is-cartesian g
is-cartesianвҶҗis-pullback {f = f} {f' = f'} g pb b
  = homotopy-is-equiv lem
                      (is-equiv-вҲҳ (fib-ПҖвӮҒ bot f' b ._вүғ_.has-is-eqv)
                                  (fibre-equivвҶҗis-equiv slice-map gap-is-equiv b)) where
  open Arrow-map g
  open pb

  cospan = ConeвҶҗArrow-map g .fst
  cone = ConeвҶҗArrow-map g .snd

  gap-is-equiv : is-equiv (gap (mk-cone f top comm))
  gap-is-equiv = gap-is-equivвҶҗis-pullback _ pb

  slice-map : Slice-map f ПҖвӮҒ
  slice-map .fst = gap cone
  slice-map .snd = ~refl

  lem : fib-ПҖвӮҒ bot f' b ._вүғ_.fwd вҲҳ
      Slice-fibre slice-map b
      ~ arrow-fibre g b
  lem (a , refl) = ОЈ-pathвҶ’ (refl , sym (вҲҷ-reflr _))

is-cartesianвҶҗgap-is-equiv
  : вҲҖ {рқ“Ө рқ“Ҙ рқ“Ұ рқ“ң} {A : Type рқ“Ө} {B : Type рқ“Ҙ} {f : A вҶ’ B}
      {C : Type рқ“Ұ} {D : Type рқ“ң} {g : C вҶ’ D}
    вҶ’ (F : Arrow-map f g)
    вҶ’ is-equiv (gap (ConeвҶҗArrow-map F .snd))
    вҶ’ is-cartesian F
is-cartesianвҶҗgap-is-equiv F gap
  = is-cartesianвҶҗis-pullback F (is-pullbackвҶҗgap _ gap)

gap-is-equivвҶҗis-cartesian
  : вҲҖ {рқ“Ө рқ“Ҙ рқ“Ұ рқ“ң} {A : Type рқ“Ө} {B : Type рқ“Ҙ} {f : A вҶ’ B}
      {C : Type рқ“Ұ} {D : Type рқ“ң} {g : C вҶ’ D}
    вҶ’ (F : Arrow-map f g)
    вҶ’ is-cartesian F
    вҶ’ is-equiv (gap (ConeвҶҗArrow-map F .snd))
gap-is-equivвҶҗis-cartesian F c
  = gap-is-equivвҶҗis-pullback _ (is-pullbackвҶҗis-cartesian F c)
}
% ```
}
}

\subtree[stt-003P]{
\taxon{Definition}
\title{Squares from pre/post-composition}

\p{Given a square of the form:}

\quiver{
\begin{tikzcd}
	A && C \\
	\\
	B && D
	\arrow["g", from=1-1, to=1-3]
	\arrow["f"', from=1-1, to=3-1]
	\arrow["{f'}", from=1-3, to=3-3]
	\arrow["{g'}"', from=3-1, to=3-3]
\end{tikzcd}
}

\p{For all types #{Q}, we obtain squares:}

\quiver{
\begin{tikzcd}
	{Q \to A} && {Q \to C} \\
	\\
	{Q \to B} && {Q \to D}
	\arrow["{g \circ {-}}", from=1-1, to=1-3]
	\arrow["{f \circ {-}}"', from=1-1, to=3-1]
	\arrow["{f' \circ {-}}", from=1-3, to=3-3]
	\arrow["{g' \circ {-}}"', from=3-1, to=3-3]
\end{tikzcd}
}

\p{and}

\quiver{
\begin{tikzcd}
	{D \to Q} && {B \to Q} \\
	\\
	{C \to Q} && {A \to Q}
	\arrow["{{-} \circ g'}", from=1-1, to=1-3]
	\arrow["{{-} \circ f'}"', from=1-1, to=3-1]
	\arrow["{{-} \circ f'}", from=1-3, to=3-3]
	\arrow["{{-} \circ g}"', from=3-1, to=3-3]
\end{tikzcd}
}

% ```agda
\agda{
precomp-square
  : вҲҖ {рқ“Ө рқ“Ҙ рқ“Ұ рқ“ң}
      {A : Type рқ“Ө} {B : Type рқ“Ҙ} {f : A вҶ’ B}
      {C : Type рқ“Ұ} {D : Type рқ“ң} {f' : C вҶ’ D}
      (g : Arrow-map f f')
    вҶ’ вҲҖ {рқ“ӣ} (C : Type рқ“ӣ) вҶ’ Arrow-map (precomp C f') (precomp C f)
precomp-square (mk-amap top bot p) C
 = mk-amap (_вҲҳ bot) (_вҲҳ top) О» f вҶ’ funextвҶ’ (f в—Ӯ (p ~вҒ»В№))

postcomp-square
  : вҲҖ {рқ“Ө рқ“Ҙ рқ“Ұ рқ“ң}
      {A : Type рқ“Ө} {B : Type рқ“Ҙ} {f : A вҶ’ B}
      {C : Type рқ“Ұ} {D : Type рқ“ң} {f' : C вҶ’ D}
      (g : Arrow-map f f')
    вҶ’ вҲҖ {рқ“ӣ} (C : Type рқ“ӣ) вҶ’ Arrow-map (postcomp C f) (postcomp C f')
postcomp-square (mk-amap top bot p) C
  = mk-amap (top вҲҳ_) (bot вҲҳ_) О» f вҶ’ funextвҶ’ (p в–ё f)
}
% ```
}

\remark{
\p{Precomposing squares gives the result of applying the functor
#{\Hom(Q,H)} to the square. It is a well known result that this functor preserves
pullback Likewise, postcomposition is given by #{\Hom({-},Q)}, and this functor turns
pushouts in to pullbacks.
}
}

\subtree[stt-003R]{
\title{Precomposition of cartesian squares}
\taxon{Theorem}

\p{Given a square of the following form:}

\quiver{
\begin{tikzcd}
	A && C \\
	\\
	B && D
	\arrow["g", from=1-1, to=1-3]
	\arrow["f"', from=1-1, to=3-1]
	\arrow["{f'}", from=1-3, to=3-3]
	\arrow["{g'}"', from=3-1, to=3-3]
\end{tikzcd}
}

\p{We show that the square obtained via precomposition
   is cartesian iff the original square is.
}

\proof{

\p{
First note that the type of cones on #{(Q \to B) \to (Q \to D) \leftarrow (Q \to C)}
is equivalent to the canonical pullback of #{B \to D \leftarrow C}. We can construct
the following triangle, and apply the three for two property for equivalences:
}

\quiver{
\begin{tikzcd}
	{(A \to Q)} &&& {(B \to Q)\times_{(C \to Q)} (D \to Q)} \\
	\\
	&& {\textrm{Cone}(f,g)}
	\arrow["{\textit{gap}}", from=1-1, to=1-4]
	\arrow["{\textrm{cone-map}}"', from=1-1, to=3-3]
	\arrow["\sim", from=1-4, to=3-3]
\end{tikzcd}
}

% ```agda
\agda{
postcomp-coneвүғpb
  : вҲҖ {рқ“Ө рқ“Ҙ рқ“Ұ рқ“ң}
      {A : Type рқ“Ө} {B : Type рқ“Ҙ}
      {C : Type рқ“Ұ} {f : A вҶ’ B}
      {g : C вҶ’ B} {D : Type рқ“ң}
    вҶ’ Cone (mk-cospan B f g) D вүғ Pullback (postcomp D f) (postcomp D g)
postcomp-coneвүғpb {f = f} {g = g} {D = D}
  =  Cone (mk-cospan _ f g) D
  вүғвҹЁ cone-reprвүғ (mk-cospan _ f g) вҹ©
      ОЈ[ f' вҲ¶ (D вҶ’ _) ] ОЈ[ g' вҲ¶ (D вҶ’ _) ]
          (postcomp D f f' ~ postcomp D g g')
  вүғвҹЁ ОЈ-ap-вүғ (О» f' вҶ’ ОЈ-ap-вүғ (О» g' вҶ’ funextвүғ eвҒ»В№)) вҹ©
      Pullback (postcomp D f) (postcomp D g)
  вүғвҲҺ


postcomp-cartesian
  : вҲҖ {рқ“Ө рқ“Ҙ рқ“Ұ рқ“ң}
      {A : Type рқ“Ө} {B : Type рқ“Ҙ} {f : A вҶ’ B}
      {C : Type рқ“Ұ} {D : Type рқ“ң} {f' : C вҶ’ D}
      (g : Arrow-map f f')
    вҶ’ is-cartesian g
    вҶ’ вҲҖ {рқ“ӣ} {C : Type рқ“ӣ}
    вҶ’ is-cartesian
      (postcomp-square g C)
postcomp-cartesian {A = A} {f = f} {f' = f'} G@(mk-amap g g' H) eq {_} {C}
  = is-cartesianвҶҗis-pullback _
      (is-pullbackвҶҗgap
        (cnвҲҳ C)
        (3-for-2
          {f = _вүғ_.bwd (postcomp-coneвүғpb)}
          {g = gap (cnвҲҳ C)}
          (is-equivвҒ»В№ (_вүғ_.has-is-eqv postcomp-coneвүғpb))
          (homotopy-is-equiv map-hom
            (cn-is-pb .is-pullbackПү.has-is-pb C)))) where
  cs : Cospan _ _ _
  cs = ConeвҶҗArrow-map G .fst

  cn : Cone cs _
  cn = ConeвҶҗArrow-map G .snd

  csвҲҳ : вҲҖ {рқ“ } (Q : Type рқ“ ) вҶ’ Cospan _ _ _
  csвҲҳ {рқ“ } Q = ConeвҶҗArrow-map (postcomp-square G Q) .fst

  cnвҲҳ : вҲҖ {рқ“ } (Q : Type рқ“ ) вҶ’ Cone (csвҲҳ Q) _
  cnвҲҳ {рқ“ } Q = ConeвҶҗArrow-map (postcomp-square G Q) .snd

  cn-is-pb : is-pullbackПү cs cn
  cn-is-pb = is-pullbackвҶҗis-cartesian G eq

  map-hom : cone-map cs cn ~ (_вүғ_.bwd postcomp-coneвүғpb вҲҳ gap (cnвҲҳ C))
  map-hom x = ap (mk-cone (f вҲҳ x) (g вҲҳ x)) (sym funext-redex)

  map : вҲҖ {рқ“ } {Q : Type рқ“ } вҶ’ (Q вҶ’ A) вҶ’ Cone cs Q
  map {_} {Q} = _вүғ_.bwd postcomp-coneвүғpb вҲҳ gap (cnвҲҳ Q)
}
% ```
}
}

%```agda
\agda{
transpose-square
  : вҲҖ {рқ“Ө рқ“Ҙ рқ“Ұ рқ“ң} {A : Type рқ“Ө} {B : Type рқ“Ҙ}
      {C : Type рқ“Ұ} {D : Type рқ“ң}
      {f : A вҶ’ B} {g : C вҶ’ D}
    вҶ’ (F : Arrow-map f g)
    вҶ’ Arrow-map (F .Arrow-map.top) (F .Arrow-map.bot)
transpose-square {f = f} {g = g} F
  = mk-amap f g (F .Arrow-map.comm ~вҒ»В№)

transpose-square-involution
  : вҲҖ {рқ“Ө рқ“Ҙ рқ“Ұ рқ“ң} {A : Type рқ“Ө} {B : Type рқ“Ҙ}
      {C : Type рқ“Ұ} {D : Type рқ“ң}
      {f : A вҶ’ B} {g : C вҶ’ D}
    вҶ’ (F : Arrow-map f g)
    вҶ’ transpose-square (transpose-square F) пјқ F
transpose-square-involution F@(mk-amap top bot comm)
  = Arrow-map-pathвҶ’ (~refl , ~refl , О» a вҶ’ вҲҷ-reflr _ вҲҷ sym-sym)

transpose-is-cartesian
  : вҲҖ {рқ“Ө рқ“Ҙ рқ“Ұ рқ“ң} {A : Type рқ“Ө} {B : Type рқ“Ҙ}
      {C : Type рқ“Ұ} {D : Type рқ“ң}
      {f : A вҶ’ B} {g : C вҶ’ D}
      (F : Arrow-map f g)
    вҶ’ is-cartesian F
    вҶ’ is-cartesian (transpose-square F)
transpose-is-cartesian {f = f} {g} F@(mk-amap top bot comm) fcart
  = is-cartesianвҶҗgap-is-equiv _
        (is-equiv-вҲҳ (pullback-swap ._вүғ_.has-is-eqv)
                    (gap-is-equivвҶҗis-pullback _
                      (is-pullbackвҶҗis-cartesian _ fcart)))

untranspose-is-cartesian
  : вҲҖ {рқ“Ө рқ“Ҙ рқ“Ұ рқ“ң} {A : Type рқ“Ө} {B : Type рқ“Ҙ}
      {C : Type рқ“Ұ} {D : Type рқ“ң}
      {f : A вҶ’ B} {g : C вҶ’ D}
      (F : Arrow-map f g)
    вҶ’ is-cartesian (transpose-square F)
    вҶ’ is-cartesian F
untranspose-is-cartesian F
  = tr is-cartesian (transpose-square-involution F)
  вҲҳ transpose-is-cartesian (transpose-square F)
}
%```

\subtree[stt-00BX]{
\title{The fibre of maps as a cartesian square}
\taxon{Example}

%```agda
\agda{
fibre-square
  : вҲҖ {рқ“Ө рқ“Ҙ} {A : Type рқ“Ө} {B : Type рқ“Ҙ} (f : A вҶ’ B) b
    вҶ’ Arrow-map (!: fibre f b) f
fibre-square f b .Arrow-map.top = fst
fibre-square f b .Arrow-map.bot = point b
fibre-square f b .Arrow-map.comm (x , p) = sym p

fibre-square-is-cartesian
  : вҲҖ {рқ“Ө рқ“Ҙ} {A : Type рқ“Ө} {B : Type рқ“Ҙ} (f : A вҶ’ B) b
    вҶ’ is-cartesian (fibre-square f b)
fibre-square-is-cartesian f b = is-cartesianвҶҗgap-is-equiv _ eq where
  map : fibre f b вҶ’ Pullback (point b) f
  map (x , p) = (tt , x , sym p)

  eq : is-equiv map
  eq = is-equivвҶҗqinv ((О» (_ , x , p) вҶ’ (x , sym p))
                     , (О» where (_ , refl) вҶ’ refl)
                     , О» where (_ , _ , refl) вҶ’ refl)
}
%```
}

\subtree[stt-00BR]{
\title{Total squares}
\taxon{Construction}

\p{Given a family of squares, we can define the total square by taking the
sum types and total maps between them.}

%```agda
\agda{
total-square
  : вҲҖ {рқ“ҳ рқ“Ө рқ“Ҙ рқ“Ұ рқ“ң} {I : Type рқ“ҳ}
      {A : I вҶ’ Type рқ“Ө} {B : I вҶ’ Type рқ“Ҙ} {f : (i : I) вҶ’ A i вҶ’ B i}
      {C : I вҶ’ Type рқ“Ұ} {D : I вҶ’ Type рқ“ң} {g : (i : I) вҶ’ C i вҶ’ D i}
    вҶ’ (F : (i : I) вҶ’ Arrow-map (f i) (g i))
    вҶ’ Arrow-map (total-map f) (total-map g)
total-square F .Arrow-map.top = total-map (Arrow-map.top вҲҳ F)
total-square F .Arrow-map.bot = total-map (Arrow-map.bot вҲҳ F)
total-square F .Arrow-map.comm (i , a)
  = ОЈ-pathвҶ’ (refl , Arrow-map.comm (F i) a)
}
%```agda
}

\subtree[stt-00BY]{
\title{Dependent precomposition square}
\taxon{Construction}

\p{Given a family of squares #{F_i : f_i \to g_i}, we can form the product square
#{\Pi_i F_i : \Pi_i f_i \to \Pi_i g_i}}

%```agda
\agda{
О -square
  : вҲҖ {рқ“ҳ рқ“Ө рқ“Ҙ рқ“Ұ рқ“ң} {I : Type рқ“ҳ}
      {A : I вҶ’ Type рқ“Ө} {B : I вҶ’ Type рқ“Ҙ} {f : (i : I) вҶ’ A i вҶ’ B i}
      {C : I вҶ’ Type рқ“Ұ} {D : I вҶ’ Type рқ“ң} {g : (i : I) вҶ’ C i вҶ’ D i}
    вҶ’ (F : (i : I) вҶ’ Arrow-map (f i) (g i))
    вҶ’ Arrow-map (postcomp-О  f) (postcomp-О  g)
О -square F .Arrow-map.top h i = Arrow-map.top (F i) (h i)
О -square F .Arrow-map.bot h i = Arrow-map.bot (F i) (h i)
О -square F .Arrow-map.comm h  = funextвҶ’ (О» a вҶ’ Arrow-map.comm (F a) (h a))
}
%```

\p{#{\Pi_i F_i} is cartesian iff each square #{F_i} is.}

\proof{

\p{We use 3-for-2 in the red triangle of the following diagram:}

\quiver{
\begin{tikzcd}[cramped]
	& {\Pi_i(B_i\times_{D_i}C_i)} \\
	{\Pi_i A_i} &&& {\Pi_iC_i} \\
	& {\Pi_iB_i\times_{\Pi_i D_i}\Pi_i c_i} \\
	\\
	{\Pi_iB_i} &&& {\Pi_iD_i}
	\arrow["\sim"{pos=0.3}, color={rgb,255:red,214;green,92;blue,92}, from=1-2, to=3-2]
	\arrow["{\Pi_i(\textrm{gap})}"{pos=0.3}, color={rgb,255:red,214;green,92;blue,92}, from=2-1, to=1-2]
	\arrow[from=2-1, to=2-4]
	\arrow[color={rgb,255:red,214;green,92;blue,92}, from=2-1, to=3-2]
	\arrow[from=2-1, to=5-1]
	\arrow[from=2-4, to=5-4]
	\arrow[from=3-2, to=2-4]
	\arrow[from=3-2, to=5-1]
	\arrow["\lrcorner"{anchor=center, pos=0.125}, draw=none, from=3-2, to=5-4]
	\arrow[from=5-1, to=5-4]
\end{tikzcd}
}
}

%```agda
\agda{
opaque
  О -square-is-cartesian
    : вҲҖ {рқ“ҳ рқ“Ө рқ“Ҙ рқ“Ұ рқ“ң} {I : Type рқ“ҳ}
        {A : I вҶ’ Type рқ“Ө} {B : I вҶ’ Type рқ“Ҙ} {f : (i : I) вҶ’ A i вҶ’ B i}
        {C : I вҶ’ Type рқ“Ұ} {D : I вҶ’ Type рқ“ң} {g : (i : I) вҶ’ C i вҶ’ D i}
      вҶ’ (F : (i : I) вҶ’ Arrow-map (f i) (g i))
      вҶ’ (вҲҖ i вҶ’ is-cartesian (F i))
      вҶ’ is-cartesian (О -square F)
  О -square-is-cartesian {I = I} {g = g} F cart
    = is-cartesianвҶҗgap-is-equiv _ eq where
    curry-pb
      : Pullback (Arrow-map.bot (О -square F)) (postcomp-О  g)
      вҶ’ О  I (О» z вҶ’ Pullback (Arrow-map.bot (F z)) (g z))
    curry-pb (f , g , H) i = (f i , g i , happly H i)

    curry-pb-qinv : quasi-inv curry-pb
    curry-pb-qinv .fst f = (pb.ПҖвӮҒ вҲҳ f , pb.ПҖвӮӮ вҲҳ f , funextвҶ’ (pb.filler вҲҳ f))
    curry-pb-qinv .snd .fst (f , g , p)
      = pullback-pathвҶ’ (refl , refl , sym (funext.О· p) вҲҷ sym (вҲҷ-reflr _))
    curry-pb-qinv .snd .snd f
      = funextвҶ’ О» i вҶ’ pullback-pathвҶ’
          (refl , refl , вҲҷ-refll _ вҲҷ sym (happly funext-redex i) вҲҷ sym (вҲҷ-reflr _))

    htpy : postcomp-О  (О» i вҶ’ gap-mapвҶҗsquare (F i)) ~ curry-pb вҲҳ gap-mapвҶҗsquare (О -square F)
    htpy a = funextвҶ’ О» i вҶ’ pullback-pathвҶ’
      (refl , refl , вҲҷ-refll _ вҲҷ happly funext-redex i вҲҷ sym (вҲҷ-reflr _))

    eq : is-equiv (gap (ConeвҶҗArrow-map (О -square F) .snd))
    eq = (3-for-2~
            {f = curry-pb}
            {g = gap-mapвҶҗsquare (О -square F)}
            {k = postcomp-О  (О» i вҶ’ gap-mapвҶҗsquare (F i))}
            (htpy)
            (is-equivвҶҗqinv curry-pb-qinv)
            (postcomp-О -equiv
              (О» {i} вҶ’ gap-is-equivвҶҗis-pullback _
                (is-pullbackвҶҗis-cartesian _ (cart i)))))
}
%```
}

\subtree[stt-00JM]{
\title{Maps between equivalences are cartesian}
\taxon{Lemma}

%```agda
\agda{
is-cartesianвҶҗdom+cod-is-equiv
  : вҲҖ {рқ“Ө рқ“Ҙ рқ“Ұ рқ“ң} {X : Type рқ“Ө} {Y : Type рқ“Ҙ} {A : Type рқ“Ұ} {B : Type рқ“ң}
      {f : X вҶ’ Y} {g : A вҶ’ B}
    вҶ’ (F : Arrow-map f g)
    вҶ’ is-equiv f вҶ’ is-equiv g
    вҶ’ is-cartesian F
is-cartesianвҶҗdom+cod-is-equiv F feq geq a
  = is-equivвҶҗsingle-to-prop
      (has-singleton-fibresвҶҗis-equiv feq a)
      (is-propвҶҗis-single (has-singleton-fibresвҶҗis-equiv geq _))
      _
}
%```
}

\subtree[stt-00K7]{
\title{Paths in maps of families}
\taxon{Lemma}

%```agda
\agda{
opaque
  Fam-map-homotopy-is-torsorial
    : вҲҖ {рқ“Ө рқ“Ҙ рқ“Ұ рқ“ң} {F@(A , X) : Fam рқ“Ө рқ“Ҙ} {G@(B , Y) : Fam рқ“Ұ рқ“ң }
      вҶ’ вҲҖ (a : Fam-map F G)
      вҶ’ is-singleton (ОЈ _ (Fam-map-homotopy {F = F} {G} a))
  Fam-map-homotopy-is-torsorial a
    = is-singleton-structureвҶҗparts
        (SingS-is-single (a .fst))
        (_ , ~refl)
        (is-singleвҶҗequiv-to-single
          (ОЈ-О -swapвүғ _ _)
          (О -is-single (О» x вҶ’ SingS-is-single (a .snd x))))

instance
  Fam-map-IdS
    : вҲҖ {рқ“Ө рқ“Ҙ рқ“Ұ рқ“ң} {F : Fam рқ“Ө рқ“Ҙ} {G : Fam рқ“Ұ рқ“ң}
      вҶ’ Identity-system (Fam-map F G) (рқ“Ө вҠ” рқ“Ҙ вҠ” рқ“Ұ вҠ” рқ“ң)
  Fam-map-IdS .Identity-system.IdS = Fam-map-homotopy
  Fam-map-IdS .Identity-system.IdSвҶҗId refl = Fam-map-refl~ _
  Fam-map-IdS .Identity-system.has-is-ids a
    = fundamental-Id _ (Fam-map-homotopy-is-torsorial a) _
}
%```
}

\subtree[stt-00KQ]{
\title{Straightening (cartesian) arrow maps}
\taxon{Lemma}

\p{We show that there is an equivalence between maps of arrows
and maps of families. We also show that an arrow map is cartesian
iff the corresponding map of families is cartesian.}

%```agda
\agda{
fam-mapвҶҗarrow-map
  : вҲҖ {рқ“Ө рқ“Ҙ рқ“Ұ рқ“ң} {A : Type рқ“Ө} {B : Type рқ“Ҙ}
      {f : A вҶ’ B} {X : Type рқ“Ұ} {Y : Type рқ“ң} {g : X вҶ’ Y}
    вҶ’ Arrow-map f g вҶ’ Fam-map (fibre-fam f) (fibre-fam g)
fam-mapвҶҗarrow-map F = (F .Arrow-map.bot , arrow-fibre F)

arrow-mapвҶҗfam-map
  : вҲҖ {рқ“Ө рқ“Ҙ рқ“Ұ рқ“ң} {A : Type рқ“Ө} {B : Type рқ“Ҙ}
      {f : A вҶ’ B} {X : Type рқ“Ұ} {Y : Type рқ“ң} {g : X вҶ’ Y}
    вҶ’ Fam-map (fibre-fam f) (fibre-fam g)
    вҶ’ Arrow-map f g
arrow-mapвҶҗfam-map {f = f} {g = g} (b , t)
  = mk-amap (О» a вҶ’ t (f a) (a , refl) .fst) b
            (О» a вҶ’ sym (t (f a) (a , refl) .snd))

fam-mapвҶҗarrow-map-is-equiv
  : вҲҖ {рқ“Ө рқ“Ҙ рқ“Ұ рқ“ң} {A : Type рқ“Ө} {B : Type рқ“Ҙ}
      {f : A вҶ’ B} {X : Type рқ“Ұ} {Y : Type рқ“ң} {g : X вҶ’ Y}
    вҶ’ is-equiv (fam-mapвҶҗarrow-map {f = f} {g = g})
fam-mapвҶҗarrow-map-is-equiv
  = is-equivвҶҗqinv
      ( arrow-mapвҶҗfam-map
      , (О» x вҶ’ Arrow-map-pathвҶ’ (~refl , ~refl ,
                               (   ~вҲҷ-reflr _
                                ~вҲҷ ap sym вҲҳ ~вҲҷ-reflr _
                                ~вҲҷ О» _ вҶ’ sym-sym)))
      , section-fam-arr) where
  section-fam-arr
    : вҲҖ {рқ“Ө рқ“Ҙ рқ“Ұ рқ“ң} {A : Type рқ“Ө} {B : Type рқ“Ҙ}
        {f : A вҶ’ B} {X : Type рқ“Ұ} {Y : Type рқ“ң} {g : X вҶ’ Y}
      вҶ’ fam-mapвҶҗarrow-map вҲҳ arrow-mapвҶҗfam-map {f = f} {g = g} ~ id
  section-fam-arr {f = f} {g = g} (b , t)
    = ОЈ-pathвҶ’ (refl ,
        (funextвҶ’ (О» a вҶ’ funextвҶ’
          (О» where (x , refl) вҶ’ ОЈ-pathвҶ’ (refl , (вҲҷ-reflr _ вҲҷ sym-sym))))))

Cart-fam-mapвҶҗcart-arrow-map
  : вҲҖ {рқ“Ө рқ“Ҙ рқ“Ұ рқ“ң} {A : Type рқ“Ө} {B : Type рқ“Ҙ}
      {f : A вҶ’ B} {X : Type рқ“Ұ} {Y : Type рқ“ң} {g : X вҶ’ Y}
    вҶ’ ОЈ (Arrow-map f g) is-cartesian
    вҶ’ Cart-fam-map (fibre-fam f) (fibre-fam g)
Cart-fam-mapвҶҗcart-arrow-map
  = Cart-fam-mapвҶҗis-cartesian вҲҳ map-ОЈ fam-mapвҶҗarrow-map О» _ вҶ’ id

Cart-fam-mapвүғcart-arrow-map
  : вҲҖ {рқ“Ө рқ“Ҙ рқ“Ұ рқ“ң} {A : Type рқ“Ө} {B : Type рқ“Ҙ}
      {f : A вҶ’ B} {X : Type рқ“Ұ} {Y : Type рқ“ң} {g : X вҶ’ Y}
    вҶ’ ОЈ (Arrow-map f g) is-cartesian
    вүғ Cart-fam-map (fibre-fam f) (fibre-fam g)
Cart-fam-mapвүғcart-arrow-map = mkвүғ Cart-fam-mapвҶҗcart-arrow-map
  (is-equiv-вҲҳ
    Cart-fam-mapвҶҗis-cartesian-is-equiv
    (map-ОЈ-is-equiv
      fam-mapвҶҗarrow-map-is-equiv
      О» _ вҶ’ id-is-equiv))
}
%```
}

\subtree[stt-00B6]{
\title{Groupoids}
\taxon{Definition}

\p{A type is a \em{groupoid}, or \em{simplicially discrete}, if it is local with
respect to #{\Delta^1}. This forms a sigma closed reflective subuniverse.}

%```agda
\agda{
is-groupoid : вҲҖ {рқ“Ө} (A : Type рқ“Ө) вҶ’ Type (рқ“ҳ вҠ” рқ“Ө)
is-groupoid = is-null (point О”В№)

Grpd-SubU : вҲҖ {рқ“Ө} вҶ’ SubU рқ“Ө (рқ“Ө вҠ” рқ“ҳ)
Grpd-SubU = Null-SubU (point О”В№) _

Grpd-gSubU : gSubU (_вҠ” рқ“ҳ)
Grpd-gSubU = Null-gSubU (point О”В№)

Grpd-is-globally-reflective
  : is-globally-reflective Grpd-gSubU
Grpd-is-globally-reflective = Null-globally-reflective

Grpd-gRSubU : gRSubU (_вҠ” рқ“ҳ)
Grpd-gRSubU .gRSubU.GS = Grpd-gSubU
Grpd-gRSubU .gRSubU.has-is-globally-reflective = Grpd-is-globally-reflective

open gSubU Grpd-gSubU public using () renaming
  ( вҲҲSвҶҗequiv to is-groupoidвҶҗequiv)

open gReflectiveClosure Grpd-gRSubU public using () renaming
  ( О вҲҲS to О -is-groupoid
  ; ULiftвҲҲS to ULift-is-groupoid
  ; рқҹҷвҲҲS to рқҹҷ-is-groupoid
  ; вҲҲSвҶҗis-singleton to is-groupoidвҶҗis-singleton
  ; вҲҲSвҶҗretract to is-groupoidвҶҗretract
  ; PullbackвҲҲS to Pullback-is-groupoid
  ; fibreвҲҲS to fibre-is-groupoid
  ; Г—вҲҲS to Г—-is-groupoid
  ; пјқвҲҲS to пјқ-is-groupoid
  ; ~вҲҲS to ~-is-groupoid
  ; retractвҲҲS to retract-is-groupoid
  ; biinvвҲҲS to biinv-is-groupoid
  ; вүғвҲҲS to вүғ-is-groupoid
  ; EqualiserвҲҲS to Equaliser-is-groupoid
  ; Seq-limвҲҲS to Seq-lim-is-groupoid
  ; preidempotent-mapвҲҲS to preidempotent-map-is-groupoid
  ; qidempotent-mapвҲҲS to qidempotent-map-is-groupoid
  ; RetractsвҲҲS to Retracts-is-groupoid)

ОЈ-is-groupoid : is-globally-ОЈ-closed Grpd-gSubU
ОЈ-is-groupoid = Null-globally-ОЈ-closed

module Grpd where

  open gSubU Grpd-gSubU public using ()
  open gRSubUInduction Grpd-gRSubU ОЈ-is-groupoid public
  open gReflectiveClosure Grpd-gRSubU public
  open gRSubU Grpd-gRSubU public
}
%```

%```agda
\agda{
HomвҶҗId
  : вҲҖ {рқ“Ө} {A : Type рқ“Ө} вҶ’ вҲҖ {a b} вҶ’ a пјқ b вҶ’ Hom A a b
HomвҶҗId refl = idH _

Hom-gpd
  : вҲҖ {рқ“Ө} {A : Type рқ“Ө} вҶ’ is-groupoid A
  вҶ’ вҲҖ {a b} вҶ’ is-equiv (HomвҶҗId {_}{A}{a}{b})
Hom-gpd gpd {a} {b}
  = is-equiv~вҲҳ {f = _вүғ_.bwd HomбөҲ-reprвүғ} {g = g вҲҳ f}
      (О» where refl вҶ’ refl)
      (is-equivвҒ»В№ (_вүғ_.has-is-eqv HomбөҲ-reprвүғ))
      (is-equiv-вҲҳ {f = g} {g = f}
        (total-is-equivвҶҗfst-is-equiv (gpd tt))
        (is-equivвҒ»В№ (ОЈ-пјқsingl ._вүғ_.has-is-eqv))) where
  f : a пјқ b вҶ’ ОЈ[ c вҲ¶ _ ] ((c пјқ a) Г— (c пјқ b))
  f = _вүғ_.bwd ОЈ-пјқsingl
  g : ОЈ[ c вҲ¶ _ ] ((c пјқ a) Г— (c пјқ b))
    вҶ’ ОЈ[ g вҲ¶ (О”В№ вҶ’ _) ] ОЈ (g i0 пјқ a) (О» hom2 вҶ’ g i1 пјқ b)
  g (a , p , q) = (const _ _ a , p , q)
}
%```
}


\subtree[stt-00B7]{
\title{Groupoids are left(right)-local types}
\taxon{Theorem}

\p{A type is a groupoid iff it is local with respect to the map #{1 \to \Delta^1}
which picks out the left endpoint iff it is local to the map that picks out the
right endpoint.}

%```agda
\agda{
is-left-local : вҲҖ {рқ“Ө} (A : Type рқ“Ө) вҶ’ Type (рқ“ҳ вҠ” рқ“Ө)
is-left-local = is-local (О» (_ _ : рқҹҷ) вҶ’ i0)

is-groupoidвҶҗis-left : вҲҖ {рқ“Ө} {A : Type рқ“Ө} вҶ’ is-left-local A вҶ’ is-groupoid A
is-groupoidвҶҗis-left {_}{A} il x
  = is-equiv~вҲҳ lem (is-equivвҒ»В№ (il x))
                   point-is-equiv where
  open is-equiv (il x)

  lem : const A О”В№ ~ bwd вҲҳ point
  lem = il x в—Ӯeqv ((Оө в–ё point) ~вҒ»В№)


is-leftвҶҗis-groupoid : вҲҖ {рқ“Ө} {A : Type рқ“Ө} вҶ’ is-groupoid A вҶ’ is-left-local A
is-leftвҶҗis-groupoid {_} {A} gp x
  =  is-equiv~вҲҳ H point-is-equiv (is-equivвҒ»В№ (gp x)) where
  open is-equiv (gp x)

  H : precomp A (point i0) ~ point вҲҳ bwd
  H = ((point в—Ӯ О·) ~вҒ»В№) в–ёeqv (gp x)
}
%```
}

\subtree[fre-1337]{
\title{The Hom types of a Segal type are groupoids}
\date{2026-03-30}
\author{fredrikbakke}
\taxon{Theorem}

\p{
If #{A} is a [Segal type](stt-00AI), then every hom type #{\Hom_A(a,b)} is a
[groupoid](stt-00B6). In fact, any type whose left and right homotopies characterise
equality have groupoidal Hom-types.
}

\p{
First, we observe that any type that is equipped with a comparison map
\code{Hom A a b вҶ’ a пјқ b} for all #{a} and #{b} is a groupoid.
}

%```agda
\agda{
is-groupoidвҶҗIdвҶҗHom
  : {рқ“Ө : Level} {A : Type рқ“Ө}
  вҶ’ ({a b : A} вҶ’ Hom A a b вҶ’ a пјқ b)
  вҶ’ is-groupoid A
is-groupoidвҶҗIdвҶҗHom {A = A} homвҶ’id
  = is-groupoidвҶҗis-left О» _ вҶ’ precomp-i0-is-equiv where

    restrict : (h : О”В№ вҶ’ A) (t : О”В№) вҶ’ Hom A (h i0) (h t)
    restrict h t .HomбөҲ.hom j = h (j вҲ§ t)
    restrict h t .HomбөҲ.hom0 = ap h 0-init
    restrict h t .HomбөҲ.hom1 = ap h (вҲ§-comm вҲҷ 1-top)

    precomp-i0-is-equiv : is-equiv (precomp A (point i0))
    precomp-i0-is-equiv
      = is-equivвҶҗqiso
          ( const A О”В№ вҲҳ ev tt
          , (О» h вҶ’ funextвҶ’ О» t вҶ’ homвҶ’id (restrict h t))
          , ~refl)
}
%```

\p{
If left and right homotopies are extensional, then we can construct such a map on the
Hom-types themselves. Given #{f, g : \Hom_A(a,b)} and a morphism of morphisms
#{\alpha : \Hom_{\Hom_A(a,b)}(f,g)}, viewed as a square #{(i,j) \mapsto \alpha(i)(j)}
that is constantly #{a} on #{j = 0} and constantly #{b} on #{j = 1}, we apply
\ref{fre-1338} to #{\alpha} as a morphism over #{\mathrm{id}_b} to extract a diagonal
#{\delta(i) \coloneqq \alpha(i)(i)} together with two composition triangles:
\ul{
\li{The upper triangle #{(i,j) \mapsto \alpha(j)(i)} for #{i \leq j} fills
#{\mathrm{Hom}^2(\mathrm{id}_b, f, \delta)}, witnessing #{f \rhtpy \delta}.}
\li{The lower triangle #{(i,j) \mapsto \alpha(i)(j)} for #{i \leq j} fills
#{\mathrm{Hom}^2(g, \mathrm{id}_a, \delta)}, witnessing #{g \lhtpy \delta}.}
}
}

%```agda
\agda{
IdвҶҗHom-Hom
  : {рқ“Ө : Level} {A : Type рқ“Ө} {a b : A}
  вҶ’ ({f g : Hom A a b} вҶ’ f ~в–ө g вҶ’ f пјқ g)
  вҶ’ ({f g : Hom A a b} вҶ’ f в–ө~ g вҶ’ f пјқ g)
  вҶ’ {f g : Hom A a b}
  вҶ’ Hom (Hom A a b) f g
  вҶ’ f пјқ g
IdвҶҗHom-Hom {b = b} leftвҶ’id rightвҶ’id {f} {g} Оұ
  = rightвҶ’id (Hom2вҶҗHom-over (idH b) f {g} Оұ)
  вҲҷ sym (leftвҶ’id (~в–өвҶҗHom-over (idH b) f {g} Оұ))

Hom-is-groupoid
  : {рқ“Ө : Level} {A : Type рқ“Ө} {a b : A}
  вҶ’ ((f : Hom A a b) вҶ’ is-singleton (ОЈ[ g вҲ¶ Hom A a b ] (f ~в–ө g)))
  вҶ’ ((f : Hom A a b) вҶ’ is-singleton (ОЈ[ g вҲ¶ Hom A a b ] (f в–ө~ g)))
  вҶ’ is-groupoid (Hom A a b)
Hom-is-groupoid {рқ“Ө} {A} {a} {b} left-tors right-tors
  = is-groupoidвҶҗIdвҶҗHom (IdвҶҗHom-Hom leftвҶ’id rightвҶ’id) where
  leftвҶ’id : {f g : Hom A a b} вҶ’ f ~в–ө g вҶ’ f пјқ g
  leftвҶ’id {f} = fundamental-IdвҒ»В№ (f ~в–ө_) (left-tors f) (О» _ вҶ’ ~в–өвҶҗпјқ)

  rightвҶ’id : {f g : Hom A a b} вҶ’ f в–ө~ g вҶ’ f пјқ g
  rightвҶ’id {f} = fundamental-IdвҒ»В№ (f в–ө~_) (right-tors f) (О» _ вҶ’ в–ө~вҶҗпјқ)

Hom-is-groupoidвҶҗis-segal
  : {рқ“Ө : Level} {A : Type рқ“Ө}
  вҶ’ is-segal A
  вҶ’ {a b : A} вҶ’ is-groupoid (Hom A a b)
Hom-is-groupoidвҶҗis-segal рқҗҙ
  = Hom-is-groupoid (~в–ө-is-torsorial рқҗҙ) (в–ө~-is-torsorial рқҗҙ)
}
%```
}

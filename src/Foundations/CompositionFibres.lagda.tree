\subtree[stt-004P]{
\title{Fibres of the postcomposition map}
\taxon{Theorem}

%```agda
\agda{
module _
  {рЭУ§ рЭУ• рЭУ¶}
  {A : Type рЭУ§} {B : Type рЭУ•} {C : Type рЭУ¶}
  (f : A вЖТ B) (h : C вЖТ B)
  where

  fibre-postcompвЙГ
    : fibre (postcomp C f) h вЙГ ќ† C (fibre f вИШ h)
  fibre-postcompвЙГ
    = ќ£-ap-вЙГ (ќї _ вЖТ funextвЙГ) вИЩвЙГ ќ£-ќ†-swapвЙГ (ќї _ вЖТ A) (ќї c a вЖТ f a пЉЭ h c) eвБї¬є
}
%```
}

\subtree[stt-00MT]{
\date{2026-03-19}
\author{fredrikbakke}
\taxon{Theorem}
\title{Characterisation of fibres of dependent postcomposition}

%```agda
\agda{
module _
  {рЭУ§ рЭУ• рЭУ¶ : Level}
  {C : Type рЭУ§}
  {A : C вЖТ Type рЭУ•}
  {B : C вЖТ Type рЭУ¶}
  (f : (c : C) вЖТ A c вЖТ B c)
  (h : ќ† C B)
  where

  fibre-postcomp-ќ†вЙГ
    : fibre (postcomp-ќ† f) h вЙГ ќ† C (ќї c вЖТ fibre (f c) (h c))
  fibre-postcomp-ќ†вЙГ
    = ќ£-ap-вЙГ (ќї _ вЖТ funextвЙГ) вИЩвЙГ ќ£-ќ†-swapвЙГ A (ќї c a вЖТ f c a пЉЭ h c) eвБї¬є
}
%```
}

\subtree[stt-00MU]{
\date{2026-03-19}
\author{fredrikbakke}
\taxon{Theorem}
\title{Dependent functions as sections over fibres}

\p{
Given a family #{U} over #{B} and a map #{f : A \to B}, dependent functions
#{(a : A) \to U(f(a))} are equivalently families of functions out of each fibre
#{\fibre{f}{b}}.
}

%```agda
\agda{
module _
  {рЭУ§ рЭУ• рЭУ¶ : Level}
  {A : Type рЭУ§} {B : Type рЭУ•}
  (U : B вЖТ Type рЭУ¶)
  (f : A вЖТ B)
  where

  precomp-ќ†-over-fibres
    : ќ† A (U вИШ f) вЖТ ќ† B (ќї b вЖТ fibre f b вЖТ U b)
  precomp-ќ†-over-fibres h b (a , p) = tr U p (h a)

  precomp-ќ†-over-fibres-is-equiv
    : is-equiv precomp-ќ†-over-fibres
  precomp-ќ†-over-fibres-is-equiv
    = is-equivвЖРqiso (bwd , ~refl , ќµ) where
    bwd : ќ† B (ќї b вЖТ fibre f b вЖТ U b) вЖТ ќ† A (U вИШ f)
    bwd h a = h (f a) (a , refl)

    ќµ : precomp-ќ†-over-fibres вИШ bwd ~ id
    ќµ h = funextвЖТ (ќї _ вЖТ funextвЖТ (ќї where (a , refl) вЖТ refl))

  precomp-ќ†-over-fibresвЙГ
    : ќ† A (U вИШ f) вЙГ ќ† B (ќї b вЖТ fibre f b вЖТ U b)
  precomp-ќ†-over-fibresвЙГ
    = mkвЙГ precomp-ќ†-over-fibres precomp-ќ†-over-fibres-is-equiv
}
%```
}

\subtree[stt-00JL]{
\title{Fibres of the composition of maps}
\taxon{Lemma}

%```agda
\agda{
fibre-вИШ
  : вИА {рЭУ§ рЭУ• рЭУ¶} {A : Type рЭУ§} {B : Type рЭУ•} {C : Type рЭУ¶}
      {f : B вЖТ C} {g : A вЖТ B}
    вЖТ вИА a вЖТ fibre (f вИШ g) a вЙГ ќ£[ x вИґ fibre f a ] fibre g (fst x)
fibre-вИШ {f = f} {g = g} c = equivвЖРqiso qiso where
  qiso : fibre (f вИШ g) c вЙК ќ£ (fibre f c) (ќї x вЖТ fibre g (fst x))
  qiso ._вЙК_.fwd (x , p) = ((g x , p) , (x , refl))
  qiso ._вЙК_.fwd-qiso .fst ((x , p) , (y , refl)) = (y , p)
  qiso ._вЙК_.fwd-qiso .snd .fst (a , refl) = refl
  qiso ._вЙК_.fwd-qiso .snd .snd ((x , p) , (y , refl)) = refl
}
%```

\p{The following lemma is exercise 4.4 of \citek{HoTT}.}

%```agda
\agda{
unstable-octahedron-map
  : вИА {рЭУ§ рЭУ• рЭУ¶} {A : Type рЭУ§} {B : Type рЭУ•} {C : Type рЭУ¶}
      (f : B вЖТ C) (g : A вЖТ B)
    вЖТ вИА b вЖТ fibre (f вИШ g) (f b) вЖТ fibre f (f b)
unstable-octahedron-map f g b (x , p) = (g x , p)

fibre-unstable-octahedron
  : вИА {рЭУ§ рЭУ• рЭУ¶} {A : Type рЭУ§} {B : Type рЭУ•} {C : Type рЭУ¶}
      {f : B вЖТ C} {g : A вЖТ B}
    вЖТ вИА a вЖТ fibre g a вЙГ fibre (unstable-octahedron-map f g a) (a , refl)
fibre-unstable-octahedron {f = f} {g} a ._вЙГ_.fwd (x , refl)
  = ((_ , refl) , refl)
fibre-unstable-octahedron {f = f} {g} a ._вЙГ_.has-is-eqv
  .is-equiv.qiso .fst (_ , refl)  = (_ , refl)
fibre-unstable-octahedron {f = f} {g} a ._вЙГ_.has-is-eqv
  .is-equiv.qiso .snd .fst (_ , refl) = refl
fibre-unstable-octahedron {f = f} {g} a ._вЙГ_.has-is-eqv
  .is-equiv.qiso .snd .snd (_ , refl) = refl
fibre-unstable-octahedron {f = f} {g} a ._вЙГ_.has-is-eqv
  .is-equiv.coherent (_ , refl) = refl
}
%```
}

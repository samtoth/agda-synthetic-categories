\date{2025-02-28}
\author{samueltoth}
\contributor{fredrikbakke}
\title{Closure properties of being a singleton}

\import{stt-macros}

\p{
Ultimately we can establish that the property of being a singleton is a
specialisation of being a localisation and thus a sigma closed reflexive subuniverse
- giving us many closure properties for free. But for clarity, and for the technical
purpose of bootstrapping the formalisation, we give the explicit proofs of closure
here.
}

% ```agda
\agda{
module Foundations.SingletonClosure where

open import Foundations.Universes
open import Foundations.Functions
open import Foundations.FunctionInverses
open import Foundations.Homotopy
open import Foundations.Singletons
open import Foundations.EquivSingleton
open import Foundations.FibrewiseEquivalences
open import Foundations.Sigma
open import Foundations.SigmaIdentity
open import Foundations.Identity
open import Foundations.DependentIdentity
open import Foundations.FunExt
}
% ```


% ```agda
\agda{
ő£-is-single
  : ‚ąÄ {ūĚď§ ūĚď•} {A : Type ūĚď§} {B : A ‚Üí Type ūĚď•}
    ‚Üí is-singleton A
    ‚Üí (‚ąÄ a ‚Üí is-singleton (B a))
    ‚Üí is-singleton (ő£ A B)
ő£-is-single {B = B} sa sb
  = mk-singl (sa .centre , sb (sa .centre) .centre) őĽ where
     (a , b) ‚Üí ő£-path‚Üí ((sa .central a) , IdŠĶą-inr (sb (sa .centre) .central _))


ő£-is-single'
  : ‚ąÄ {ūĚď§ ūĚď•} {A : Type ūĚď§} {B : A ‚Üí Type ūĚď•}
    ‚Üí is-singleton A
    ‚Üí (a : A)
    ‚Üí is-singleton (B a)
    ‚Üí is-singleton (ő£ A B)
ő£-is-single' {B = B} sa a sb
  = mk-singl (a , sb .centre) őĽ where
     (a' , b) ‚Üí ő£-path‚Üí
               ( is-prop‚Üźis-single sa a a'
               , IdŠĶą-inr {A = B a} {B a'}
                   {ap B (is-prop‚Üźis-single sa a a')}
                         (is-prop‚Üźis-single sb _ _))
}
% ```


% ```agda
\agda{
ő†-is-single
  : ‚ąÄ {ūĚď§ ūĚď•} {A : Type ūĚď§} {B : A ‚Üí Type ūĚď•}
    ‚Üí FunExtŌČ ūĚď•
    ‚Üí (‚ąÄ a ‚Üí is-singleton (B a))
    ‚Üí is-singleton ((a : A) ‚Üí B a)
ő†-is-single {B = B} fe sb
  = mk-singl
      (őĽ a ‚Üí sb a .centre)
      (őĽ f ‚Üí WithFunExtŌČ.funext‚Üí fe (őĽ a ‚Üí sb a .central (f a)))
}
% ```

% ```agda
\agda{
ÔľĚ-is-single
  : ‚ąÄ {ūĚď§} {A : Type ūĚď§}
    ‚Üí is-singleton A
    ‚Üí ‚ąÄ x y ‚Üí is-singleton (x ÔľĚ y)
ÔľĚ-is-single sngl x y .centre = is-prop‚Üźis-single sngl x y
ÔľĚ-is-single sngl x y .central refl = ‚ąô-sym' (sngl .central x)
}
% ```

% ```agda
\agda{
htpy-is-torsorial
  : ‚ąÄ {ūĚď§ ūĚď•} {A : Type ūĚď§} {B : A ‚Üí Type ūĚď•}
    ‚Üí FunExtŌČ ūĚď•
    ‚Üí (f : (a : A) ‚Üí B a)
    ‚Üí is-singleton (ő£ ((a : A) ‚Üí B a) (őĽ g ‚Üí f ~ g))
htpy-is-torsorial {A = A} {B = B} fe f
  = is-single‚Üźequiv-to-single
      (ő£-ap-‚ČÉ őĽ g ‚Üí WithFunExtŌČ.funext‚ČÉ fe {A = A} {B = B} {f = f} {g = g})
      Sing-is-singleton
}
% ```

% ```agda
\agda{
is-single‚Üźsection-single
  : ‚ąÄ {ūĚď§ ūĚď•} {A : Type ūĚď§} {B : Type ūĚď•} (f : A ‚Üí B)
    ‚Üí section f ‚Üí is-singleton A ‚Üí is-singleton B
is-single‚Üźsection-single f s sa .centre
  = f (sa .centre)
is-single‚Üźsection-single f s sa .central x
  = f (sa .centre) ÔľĚ‚ü® ap f (sa .central _) ‚ü©
    f (s .fst x)   ÔľĚ‚ü® s .snd x ‚ü©
    x              ‚ąé

is-single‚Üźretraction-single
  : ‚ąÄ {ūĚď§ ūĚď•} {A : Type ūĚď§} {B : Type ūĚď•} (f : A ‚Üí B)
    ‚Üí retraction f ‚Üí is-singleton B ‚Üí is-singleton A
is-single‚Üźretraction-single f (r , ret) sb .centre
  = r (sb .centre)
is-single‚Üźretraction-single f (r , ret) sb .central a
  = ap r (sb .central (f a)) ‚ąô ret a
}
% ```

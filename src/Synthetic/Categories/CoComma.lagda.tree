\subtree[stt-00CT]{
\title{Right cocones over a span}
\taxon{Definition}

\p{Given a [span diagram](stt-0015) #{S}, we consider the right cocones over #{S}.
This is analogous to the type of [cocones over #{S}](stt-0016) but with the
filler now being a morphism, not a path. This dualises \ref{stt-00C1}}

%```agda
\agda{
record Right-cocone {𝓤 𝓥 𝓦} (S : Span 𝓤 𝓥 𝓦) {𝓛} (Carrier : Type 𝓛)
  : Type (𝓘 ⊔ 𝓤 ⊔ 𝓥 ⊔ 𝓦 ⊔ 𝓛) where
  constructor mk-right-cocone
  open Span S
  field
    i : Left → Carrier
    j : Right → Carrier
    filler : ∀ (a : Centre) → Hom Carrier (i (left a)) (j (right a))


unquoteDecl Right-cocone-repr≊ Right-cocone-repr≃
  = make-record-repr Right-cocone-repr≊ Right-cocone-repr≃ (quote Right-cocone)

Right-cocone-path
  : ∀ {𝓤 𝓥 𝓦} {S : Span 𝓤 𝓥 𝓦} {𝓛} {Carrier : Type 𝓛}
      (c c' : Right-cocone S Carrier) → Type (𝓘 ⊔ 𝓤 ⊔ 𝓥 ⊔ 𝓦 ⊔ 𝓛)
Right-cocone-path {S = S} c c'
  = Σ[ p ∶ c .i ~ c' .i ] Σ[ q ∶ c .j ~ c' .j ]
      (∀ a → Hom-pathᵈ (p (left a)) (q (right a)) (c .filler a) (c' .filler a))
  where
  open Right-cocone
  open Span S

opaque
  Right-cocone-path-is-torsorial
    : ∀ {𝓤 𝓥 𝓦} {S : Span 𝓤 𝓥 𝓦} {𝓛} {Carrier : Type 𝓛}
        (c : Right-cocone S Carrier) → is-singleton (Σ _ (Right-cocone-path c))
  Right-cocone-path-is-torsorial c
    = is-single←equiv-to-single (Σ-ap-≃-fst (Right-cocone-repr≃ e⁻¹))
        (is-singleton-structure←parts
          (SingS-is-single _)
          (_ , ~refl)
          (is-singleton-structure←parts
            (SingS-is-single _)
            (_ , ~refl)
            (is-single←equiv-to-single
              (Σ-Π-swap≃ _ λ a h → Hom-pathᵈ refl refl (c .Right-cocone.filler a) h)
              (Π-is-single (λ a
               → Hom-pathᵈ-is-torsorial)))))

Right-cocone-path-refl
  : ∀ {𝓤 𝓥 𝓦} {S : Span 𝓤 𝓥 𝓦} {𝓛} {Carrier : Type 𝓛}
      {c : Right-cocone S Carrier} → Right-cocone-path c c
Right-cocone-path-refl = (~refl , ~refl , λ a → Hom-pathᵈ-refl)

instance
  IdS-right-cocone
    : ∀ {𝓤 𝓥 𝓦} {S : Span 𝓤 𝓥 𝓦} {𝓛} {Carrier : Type 𝓛}
      → Identity-system (Right-cocone S Carrier) (𝓘 ⊔ 𝓤 ⊔ 𝓥 ⊔ 𝓦 ⊔ 𝓛)
  IdS-right-cocone .Identity-system.IdS = Right-cocone-path
  IdS-right-cocone .Identity-system.IdS←Id refl = Right-cocone-path-refl
  IdS-right-cocone .Identity-system.has-is-ids a
    = fundamental-Id _ (Right-cocone-path-is-torsorial a) _
}
%```
}


\subtree[stt-00CU]{
\title{Cocomma cocones}
\taxon{Definition}

\p{Again analogously to undirected pushouts, for any right cocone #{C}
over a span #{S}, we can define a canonical map #{(C \to Q) \to \mathrm{Cocone}_S(Q)}.
We call #{C} a (right) cocomma cone when this map is an equivalence.}

%```agda
\agda{
module _ {𝓤 𝓥 𝓦} {S : Span 𝓤 𝓥 𝓦} {𝓛} {Carrier : Type 𝓛} where
  right-cocone-map
    : Right-cocone S Carrier
    → ∀ {𝓠} {Q : Type 𝓠} → (Carrier → Q) → Right-cocone S Q
  right-cocone-map cc f = mk-right-cocone (f ∘ i) (f ∘ j) (ap-hom f ∘ filler) where
    open Right-cocone cc

  is-cocomma-cocone : Right-cocone S Carrier → Typeω
  is-cocomma-cocone cone
    = ∀ {𝓠} {Q : Type 𝓠} → is-equiv (right-cocone-map cone {𝓠} {Q})
}
%```
}

\subtree[stt-00CV]{
\title{Canonical cocomma types}
\taxon{Construction}

\p{The cocomma type of a [span diagram](stt-0015) is written
#{f \uparrow g}. If we had a notion of \em{directed} higher inductive
types, you might present it as the type generated by the following data:}

\ul{
\li{#{\iota_1 : A \to f \uparrow g}}
\li{#{\iota_2 : C \to f \uparrow g}}
\li{#{\mathit{gl} : \Pi_{b} \Hom_B(\iota_1(f(b)), \iota_2(g(b)))}}
}

\p{Whilst we don't have directed higher inductive types natively, we can
use [pushouts](stt-0017) to give an equivalent definition for cocomma types.}


\quiver{
    \begin{tikzcd}[cramped]
	{B\times\partial\Delta^1} && {A + C} \\
	\\
	{B \times \Delta^1} && \bullet
	\arrow["{\overline{[f,g]}}", from=1-1, to=1-3]
	\arrow[hook', from=1-1, to=3-1]
	\arrow[from=1-3, to=3-3]
	\arrow[from=3-1, to=3-3]
	\arrow["\lrcorner"{anchor=center, pos=0.125, rotate=180}, draw=none, from=3-3, to=1-1]
    \end{tikzcd}
}

%```agda
\agda{
↑-span
  : ∀ {𝓤 𝓥 𝓦} {A : Type 𝓤} {B : Type 𝓥} {C : Type 𝓦}
      (f : B → A) (g : B → C)
    → Span (𝓘 ⊔ 𝓥) (𝓘 ⊔ 𝓥) (𝓤 ⊔ 𝓦)
↑-span {B = B} f g
  = mk-span _ (∂Δ¹-incl ⊗1 B)
              (uncurry (∂Δ¹-UP→ (inl ∘ f , inr ∘ g)))

_↑_ : ∀ {𝓤 𝓥 𝓦} {A : Type 𝓤} {B : Type 𝓥} {C : Type 𝓦}
        (f : B → A) (g : B → C) → Type (𝓘 ⊔ 𝓤 ⊔ 𝓥 ⊔ 𝓦)
_↑_ f g = Pushout (↑-span f g .Span.left) (↑-span f g .Span.right)

↑-ι₁ : ∀ {𝓤 𝓥 𝓦} {A : Type 𝓤} {B : Type 𝓥} {C : Type 𝓦}
         {f : B → A} {g : B → C} → A → f ↑ g
↑-ι₁ = ι₂ ∘ inl

↑-ι₂ : ∀ {𝓤 𝓥 𝓦} {A : Type 𝓤} {B : Type 𝓥} {C : Type 𝓦}
         {f : B → A} {g : B → C} → C → f ↑ g
↑-ι₂ = ι₂ ∘ inr

↑-hom : ∀ {𝓤 𝓥 𝓦} {A : Type 𝓤} {B : Type 𝓥} {C : Type 𝓦}
          {f : B → A} {g : B → C} b → Hom (f ↑ g) (↑-ι₁ (f b)) (↑-ι₂ (g b))
↑-hom b .Homᵈ.hom = ι₁ ∘ (_, b)
↑-hom b .Homᵈ.hom0 = glue (∂Δ¹-0 , b)
↑-hom b .Homᵈ.hom1 = glue (∂Δ¹-1 , b)

↑-cocone : ∀ {𝓤 𝓥 𝓦} {A : Type 𝓤} {B : Type 𝓥} {C : Type 𝓦}
             (f : B → A) (g : B → C) → Right-cocone (mk-span _ f g) (f ↑ g)
↑-cocone f g .Right-cocone.i = ↑-ι₁
↑-cocone f g .Right-cocone.j = ↑-ι₂
↑-cocone f g .Right-cocone.filler = ↑-hom

↑-is-cocomma-cocone
  : ∀ {𝓤 𝓥 𝓦} {A : Type 𝓤} {B : Type 𝓥} {C : Type 𝓦} {f : B → A} {g : B → C}
    → is-cocomma-cocone (↑-cocone f g)
↑-is-cocomma-cocone {f = f} {g = g} = is-equiv←qinv qinv where
  open Right-cocone
  qinv : quasi-inv (right-cocone-map (↑-cocone f g))
  qinv .fst cone = pushout-rec
    (mk-cocone (uncurry (Homᵈ.hom ∘ cone .filler) ∘ ×-swap ._≃_.fwd)
               ⊎[ cone .i , cone .j ] λ
     { ((mk-lift true) ,  b) → filler cone b .Homᵈ.hom1
     ; ((mk-lift false) , b) → filler cone b .Homᵈ.hom0})
  qinv .snd .fst f = sym
    (funext→ (pushout-rec-unique _ _ ~refl
               (λ { (inl x) → refl
                  ; (inr x) → refl})
               λ { (mk-lift true , b) → ∙-reflr _
                 ; (mk-lift false , b) → ∙-reflr _}))
  qinv .snd .snd a = ext! (~refl , ~refl , λ b → Hom-pathᵈ←path
                            ( ~refl
                            , sym (pushout-rec-apβ _)
                            , sym (pushout-rec-apβ _)))

↑-rec : ∀ {𝓤 𝓥 𝓦} {S : Span 𝓤 𝓥 𝓦} {𝓠} {Q : Type 𝓠}
        → let open Span S
        in Right-cocone S Q → (left ↑ right → Q)
↑-rec = is-equiv.bwd (↑-is-cocomma-cocone)

↑-rec-unique
  : ∀ {𝓤 𝓥 𝓦} {S : Span 𝓤 𝓥 𝓦} {𝓠} {Q : Type 𝓠}
      {c : Right-cocone S Q} {f : Span.left S ↑ Span.right S → Q}
    → IdS (right-cocone-map (↑-cocone (Span.left S) (Span.right S)) f) c
    → f ~ ↑-rec c
↑-rec-unique (p , q , r) = pushout-rec-unique _ _
  (λ (i , c) → r c .fst i)
  (λ { (inl x) → p x
     ; (inr x) → q x })
  λ { (mk-lift true  , c) → sym (un-square (r c .snd .snd))
    ; (mk-lift false , c) → sym (un-square (r c .snd .fst))}

↑-UP
  : ∀ {𝓤 𝓥 𝓦} {S : Span 𝓤 𝓥 𝓦} {𝓠} {Q : Type 𝓠}
    → (Span.left S ↑ Span.right S → Q) ≃ Right-cocone S Q
↑-UP = mk≃ (right-cocone-map _) ↑-is-cocomma-cocone
}
%```
}



\subtree[stt-00CW]{
\title{Directed join}
\taxon{Example}

\p{An example of a comma type is the \em{directed join} of a pair of types.
This is sometimes also called the \em{blunt join}.}

\p{The interval is the join #{1 \bjoin 1}.}

%```agda
\agda{
◇-span
  : ∀ {𝓤 𝓥} (A : Type 𝓤) (B : Type 𝓥)
    → Span (𝓘 ⊔ 𝓤 ⊔ 𝓥) (𝓘 ⊔ 𝓤 ⊔ 𝓥) (𝓤 ⊔ 𝓥)
◇-span A B = ↑-span {B = A × B} fst snd

_◇_ : ∀ {𝓤 𝓥} → Type 𝓤 → Type 𝓥 → Type (𝓘 ⊔ 𝓤 ⊔ 𝓥)
A ◇ B = _↑_ {B = A × B} fst snd

Δ¹-is-join : is-cocomma-cocone {S = mk-span (𝟙 × 𝟙) fst snd}
               (mk-right-cocone (point i0) (point i1) λ _ → 0≤1)
Δ¹-is-join = is-equiv←qinv qinv where
  qinv : quasi-inv _
  qinv .fst cc = cc .Right-cocone.filler _ .Homᵈ.hom
  qinv .snd .fst = ~refl
  qinv .snd .snd cc
    = ext! ((λ _ → hom0) , (λ _ → hom1)
           , λ _ → ( ~refl
                   , (Square-flatten-hor refl) , Square-flatten-hor refl)) where
    open Right-cocone cc
    open Homᵈ (filler _)

_▻ : ∀ {𝓤} → Type 𝓤 → Type (𝓘 ⊔ 𝓤)
A ▻ = A ◇ 𝟙

▻-span : ∀ {𝓤} (A : Type 𝓤) → Span (𝓘 ⊔ 𝓤) (𝓘 ⊔ 𝓤) 𝓤
▻-span A = ◇-span A 𝟙

_◅ : ∀ {𝓤} → Type 𝓤 → Type (𝓘 ⊔ 𝓤)
A ◅ = 𝟙 ◇ A

◅-span : ∀ {𝓤} (A : Type 𝓤) → Span (𝓘 ⊔ 𝓤) (𝓘 ⊔ 𝓤) 𝓤
◅-span A = ◇-span 𝟙 A
}
%```
}

\subtree[stt-00CX]{
\title{Functoriality of the directed join}
\taxon{Construction}

%```agda
\agda{
_◇₁_
  : ∀ {𝓤 𝓥 𝓦 𝓜}
      {A : Type 𝓤} {B : Type 𝓥} (f : A → B)
      {C : Type 𝓦} {D : Type 𝓜} (g : C → D)
    → A ◇ C → B ◇ D
f ◇₁ g = ↑-rec (mk-right-cocone (↑-ι₁ ∘ f) (↑-ι₂ ∘ g) (↑-hom ∘ (f ⊗ g)))

◇₁-id
  : ∀ {𝓤 𝓥} {A : Type 𝓤}  {B : Type 𝓥}
    → id ◇₁ id ~ id: (A ◇ A)
◇₁-id = sym ∘ ↑-rec-unique
  ( ~refl
  , ~refl
  , λ _ → Hom-pathᵈ←path (~refl , sym (ap-id _) , sym (ap-id _)))

◇₁-∘
  : ∀ {𝓤 𝓥 𝓦 𝓜 𝓝 𝓛}
      {A : Type 𝓤}  {B : Type 𝓥} {C : Type 𝓦}
      {D : Type 𝓜} {E : Type 𝓝} {F : Type 𝓛}
      (f : B → C) (g : A → B) (h : E → F) (j : D → E)
    → (f ∘ g) ◇₁ (h ∘ j) ~ (f ◇₁ h) ∘ (g ◇₁ j)
◇₁-∘ f g h j = sym ∘ ↑-rec-unique
  ( ~refl
  , ~refl
  , λ (a , d) → Hom-pathᵈ←path
     ( ~refl
     , sym (ap-∘ _ _ _ ∙ ap (ap _) (pushout-rec-apβ _) ∙ pushout-rec-apβ _)
     , sym (ap-∘ _ _ _ ∙ ap (ap _) (pushout-rec-apβ _) ∙ pushout-rec-apβ _)))
}
%```
}

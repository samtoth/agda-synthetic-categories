\title{Retracts}
\taxon{Module}

\import{stt-macros}

% ```agda
\agda{
open import Foundations.FunExt

module Foundations.Retract where

open import Foundations.Universes
open import Foundations.Functions
open import Foundations.Homotopy
open import Foundations.Identity
open import Foundations.IdentityEquiv
open import Foundations.Sigma
open import Foundations.FunctionInverses
open import Foundations.CoherentIsomorphism
open import Foundations.Singleton
open import Foundations.SingletonClosure
open import Foundations.EquivSingleton
open import Foundations.FibrewiseEquiv
open import Foundations.EquivContrFibre
open import Foundations.IdentitySystem
open import Foundations.Univalence
import Foundations.HomotopyEquiv as HEquiv
import Foundations.EquivProp as EProp
}
% ```

\subtree[fre-2115]{
\date{2026-03-11}
\author{fredrikbakke}
\taxon{Definition}
\title{Retracts}

\p{
A type #{A} is a \em{retract} of a type #{B} if there is a map #{f : A \to B}
equipped with a [retraction](stt-000I), i.e., another map #{r : B \to A} such that
#{r \circ f \sim \id}.
}

% ```agda
\agda{
retract : ∀ {𝓤 𝓥} → Type 𝓤 → Type 𝓥 → Type (𝓤 ⊔ 𝓥)
retract A B = Σ[ f ∶ (A → B) ] retraction f

module _
  {𝓤 𝓥 : Level} {A : Type 𝓤} {B : Type 𝓥} (R : retract A B)
  where

  inclusion-retract : A → B
  inclusion-retract = R .fst

  map-retraction-retract : B → A
  map-retraction-retract = R .snd .fst

  is-retraction-retract
    : map-retraction-retract ∘ inclusion-retract ~ id
  is-retraction-retract = R .snd .snd

retract←equiv
  : ∀ {𝓤 𝓥} {A : Type 𝓤} {B : Type 𝓥}
  → A ≃ B → retract A B
retract←equiv e
  = ( e ._≃_.fwd
    , is-equiv.bwd (e ._≃_.has-is-eqv)
    , is-equiv.η (e ._≃_.has-is-eqv))

idretract : ∀ {𝓤} {A : Type 𝓤} → retract A A
idretract = (id , id , ~refl)
}
% ```
}

\subtree[fre-1A1D]{
\taxon{Definition}
\date{2026-03-11}
\author{fredrikbakke}
\title{The universe of retracts of a type}

\p{
For a fixed type #{A}, we write #{\mathsf{Retracts}(A)} for the universe of
types equipped with a [retract](fre-2115) into #{A}.
}

% ```agda
\agda{
Retracts
  : (𝓥 : Level) {𝓤 : Level} → Type 𝓤 → Type (lsuc 𝓥 ⊔ 𝓤)
Retracts 𝓥 A = Σ[ X ∶ Type 𝓥 ] retract X A

module _
  {𝓤 𝓥 : Level} {A : Type 𝓤} (R : Retracts 𝓥 A)
  where

  carrier-Retracts : Type 𝓥
  carrier-Retracts = R .fst

  retract-Retracts : retract carrier-Retracts A
  retract-Retracts = R .snd
}
% ```
}

\subtree[fre-2116]{
\title{Retracts compose}
\taxon{Lemma}
\date{2026-03-11}
\author{fredrikbakke}

%```agda
\agda{
comp-retract : ∀ {𝓤 𝓥 𝓦} {A : Type 𝓤} {B : Type 𝓥} {C : Type 𝓦}
               → retract A B
               → retract B C
               → retract A C
comp-retract (i , Ri) (j , Rj) = (j ∘ i , retraction-∘ Rj Ri)
}
%```
}

\subtree[fre-2117]{
\title{Homotopies of retracts}
\taxon{Definition}
\date{2026-03-11}
\author{fredrikbakke}

%```agda
\agda{
module _ {𝓤 𝓥 : Level} {A : Type 𝓤} {B : Type 𝓥} where

  coherence-retract-htpy
    : (R S : retract A B)
      (I : inclusion-retract R ~ inclusion-retract S)
      (H : map-retraction-retract R ~ map-retraction-retract S)
    → Type 𝓤
  coherence-retract-htpy R S I H
    = is-retraction-retract R ~ ((H ~∘ I) ~∙ is-retraction-retract S)

  retract-htpy
    : retract A B → retract A B → Type (𝓤 ⊔ 𝓥)
  retract-htpy R S
    = Σ[ I ∶ inclusion-retract R ~ inclusion-retract S ]
      Σ[ H ∶ map-retraction-retract R ~ map-retraction-retract S ]
      coherence-retract-htpy R S I H

  refl-retract-htpy
    : (R : retract A B) → retract-htpy R R
  refl-retract-htpy R = (~refl , ~refl , ~refl)
}
%```
}

\subtree[fre-2118]{
\title{Equality of retracts}
\taxon{Theorem}
\date{2026-03-11}
\author{fredrikbakke}

\p{
We characterise equalities of
[retracts](fre-2115) #{H : r \circ i \sim \id} and #{H' : r' \circ i' \sim \id} as
homotopies #{R : r \sim r'}, #{I : i \sim i'} together with a coherence
#{H \sim ((R ◾ I) ∙ H')}.
}

%```agda
\agda{
module RetractWithFunExt (FE : FunExt-global) where
  open WithFunExt-global FE
  module EP = EProp FE
  open EP

  module _
    {𝓤 𝓥} {A : Type 𝓤} {B : Type 𝓥}
    (R : retract A B)
    where

    module HE = HEquiv {𝓤 = 𝓤} FE

    retract-htpy-is-torsorial
      : is-singleton (Σ[ S ∶ retract A B ] retract-htpy R S)
    retract-htpy-is-torsorial
      = is-singleton-structure←parts
          (htpy-is-torsorial FE (inclusion-retract R))
          (_ , ~refl)
          (is-singleton-structure←parts
            (htpy-is-torsorial FE (map-retraction-retract R))
            (_ , ~refl)
            (is-single←equiv-to-single
              (Σ-ap-≃ λ ρ' → funext≃ ∙≃ Π-ap-≃ (λ _ → sym≃))
              (is-contr-map←is-equiv
                (HE.~∙-is-equiv ~refl)
                (is-retraction-retract R))))

  retract-htpy←Id
    : ∀ {𝓤 𝓥} {A : Type 𝓤} {B : Type 𝓥}
        {R S : retract A B}
      → R ＝ S
      → retract-htpy R S
  retract-htpy←Id refl = refl-retract-htpy _

  retract-htpy-is-equiv
    : ∀ {𝓤 𝓥} {A : Type 𝓤} {B : Type 𝓥}
        (R S : retract A B)
      → is-equiv (retract-htpy←Id {R = R} {S = S})
  retract-htpy-is-equiv R
    = fundamental-Id
        (retract-htpy R)
        (retract-htpy-is-torsorial R)
        (λ _ → retract-htpy←Id)

  Id≃retract-htpy
    : ∀ {𝓤 𝓥} {A : Type 𝓤} {B : Type 𝓥}
        (R S : retract A B)
      → (R ＝ S) ≃ retract-htpy R S
  Id≃retract-htpy R S = mk≃ retract-htpy←Id (retract-htpy-is-equiv R S)

  Id←retract-htpy
    : ∀ {𝓤 𝓥} {A : Type 𝓤} {B : Type 𝓥}
        {R S : retract A B}
      → retract-htpy R S
      → R ＝ S
  Id←retract-htpy {R = R} {S = S} = _≃_.bwd (Id≃retract-htpy R S)
}
%```
}

\subtree[fre-1A1A]{
\title{Unit laws for composition of retracts}
\taxon{Theorem}
\date{2026-03-11}
\author{fredrikbakke}

%```agda
\agda{
module _ {𝓤 𝓥 : Level} {A : Type 𝓤} {B : Type 𝓥} where

  comp-retract-unit-l-htpy
    : (R : retract A B)
    → retract-htpy (comp-retract idretract R) R
  comp-retract-unit-l-htpy R@(s , r , rs)
    = (~refl , ~refl , (λ a → ∙-reflr (ap id (rs a)) ∙ ap-id (rs a)))

  comp-retract-unit-r-htpy
    : (R : retract A B)
    → retract-htpy (comp-retract R idretract) R
  comp-retract-unit-r-htpy R@(s , r , rs) = (~refl , ~refl , ∙-refll ∘ rs)

module RetractWithFunExt' (FE : FunExt-global) where
  module RE = RetractWithFunExt FE

  module _ {𝓤 𝓥 : Level} {A : Type 𝓤} {B : Type 𝓥} where

    comp-retract-unit-l
      : (R : retract A B)
      → comp-retract idretract R ＝ R
    comp-retract-unit-l R
      = RE.Id←retract-htpy (comp-retract-unit-l-htpy R)

    comp-retract-unit-r
      : (R : retract A B) → comp-retract R idretract ＝ R
    comp-retract-unit-r R
      = RE.Id←retract-htpy (comp-retract-unit-r-htpy R)
}
%```
}

\subtree[fre-1A1B]{
\title{Equivalences in the universe of retracts of a type}
\taxon{Definition}
\date{2026-03-11}
\author{fredrikbakke}

\p{
An \em{equivalence} in [the universe of retracts of a type](fre-1A1D) #{R} and #{S}
is an [equivalence](stt-001U) #{e} of the carrier types  together with a
[homotopy of retracts](fre-2117) #{R \sim e \circ S}.
}

%```agda
\agda{
Retracts-equiv
  : ∀ {𝓤 𝓥 𝓦} {A : Type 𝓤}
  → Retracts 𝓥 A
  → Retracts 𝓦 A
  → Type (𝓤 ⊔ 𝓥 ⊔ 𝓦)
Retracts-equiv (X , R) (Y , S)
  = Σ[ e ∶ X ≃ Y ] retract-htpy R (comp-retract (retract←equiv e) S)

id-Retracts-equiv
  : ∀ {𝓤 𝓥} {A : Type 𝓤}
    (R : Retracts 𝓥 A)
  → Retracts-equiv R R
id-Retracts-equiv (_ , R@(s , r , rs)) = idequiv , (~refl , ~refl , coh) where
  coh : coherence-retract-htpy R (comp-retract idretract R) ~refl ~refl
  coh a
    = rs a                ＝⟨ sym (ap-id (rs a)) ⟩
      ap id (rs a)        ＝⟨ sym (∙-reflr (ap id (rs a))) ⟩
      ap id (rs a) ∙ refl ∎
}
%```
}
\subtree[fre-1A1C]{
\title{Equality in the universe of retracts of a type}
\taxon{Theorem}
\date{2026-03-11}
\author{fredrikbakke}

\p{
Equalities in [the universe of retracts of a type](fre-1A1D) are characterised by
[equivalences in the universe of retracts of a type](fre-1A1B), i.e., by an
[equivalence](stt-001U) of carrier types together with a
[homotopy of retracts](fre-2117) over that equivalence.
}

%```agda
\agda{
module RetractsWithFunExtUnivalence
  (FE : FunExt-global)
  (UA : Univalence)
  where

  open RetractWithFunExt' FE
  open RetractWithFunExt FE
  open WithGlobalUnivalence UA

  module _
    {𝓤 𝓥} {A : Type 𝓤}
    (R : Retracts 𝓥 A)
    where

    Retracts-equiv-is-torsorial
      : is-singleton (Σ[ S ∶ Retracts 𝓥 A ] Retracts-equiv R S)
    Retracts-equiv-is-torsorial
      = is-singleton-structure←parts
          (equiv-is-torsorial (carrier-Retracts R))
          (_ , idequiv)
          (is-single←equiv-to-single
            (Σ-ap-≃ λ S → equiv←Id
              (ap
                (λ T → retract-htpy (retract-Retracts R) T)
                (sym (comp-retract-unit-l S))))
            (retract-htpy-is-torsorial (retract-Retracts R)))

  Retracts-equiv←Id
    : ∀ {𝓤 𝓥} {A : Type 𝓤}
      {R S : Retracts 𝓥 A}
    → R ＝ S
    → Retracts-equiv R S
  Retracts-equiv←Id refl = id-Retracts-equiv _

  Retracts-equiv←Id-is-equiv
    : ∀ {𝓤 𝓥} {A : Type 𝓤}
      (R S : Retracts 𝓥 A)
    → is-equiv (Retracts-equiv←Id {R = R} {S = S})
  Retracts-equiv←Id-is-equiv R
    = fundamental-Id
        (Retracts-equiv R)
        (Retracts-equiv-is-torsorial R)
        (λ _ → Retracts-equiv←Id)

  Id≃Retracts-equiv
    : ∀ {𝓤 𝓥} {A : Type 𝓤}
      (R S : Retracts 𝓥 A)
    → (R ＝ S) ≃ Retracts-equiv R S
  Id≃Retracts-equiv R S = mk≃ Retracts-equiv←Id (Retracts-equiv←Id-is-equiv R S)

  Id←Retracts-equiv
    : ∀ {𝓤 𝓥} {A : Type 𝓤}
      {R S : Retracts 𝓥 A}
    → Retracts-equiv R S
    → R ＝ S
  Id←Retracts-equiv {R = R} {S = S} = _≃_.bwd (Id≃Retracts-equiv R S)
}
%```
}

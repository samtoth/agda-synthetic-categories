\subtree[stt-00D6]{
\title{Unstraightening hom families}
\taxon{Remark}

\p{The unstraightening of the family #{\Hom(x,-)} is #{X_{x/} \to X}. Thus
representable families are covariant iff #{X_{x/} \to X} are all left fibrations.}


%```agda
\agda{
hom-fam-is-cov‚áîis-left-fibration
  : ‚àÄ {ùì§} {X : Type ùì§} x
  ‚Üí is-covariant (Œª a ‚Üí Hom X x a)
  ‚áî is-left-fibration {A = Coslice X (point x)} fst
hom-fam-is-cov‚áîis-left-fibration x
  = is-covariant‚áîis-left-fibration (Œª a ‚Üí Hom _ x a)
  ‚àô‚áî right-orthogonal-iff‚Üêequiv (Œª _ ‚Üí i0) amap amap-eq where
  amap : Arrow-map (fst {B = Œª c ‚Üí (i : ùüô) ‚Üí Hom _ x c})
                   (fst {B = Œª a ‚Üí Hom _ x a})
  amap .Arrow-map.top = total-map (Œª a ‚Üí ev tt)
  amap .Arrow-map.bot = id
  amap .Arrow-map.comm = ~refl

  amap-eq : is-Arrow-equiv amap
  amap-eq .fst = is-total-equiv‚Üêis-fibrewise-equiv (Œª a ‚Üí unit-ev-is-equiv)
  amap-eq .snd = id-is-equiv
}
%```
}

\subtree[stt-00DA]{
\taxon{Definition}
\title{Left Segal types}
\contributor{fredrikbakke}

\p{We call a type \em{left Segal} if it is local with respect to the
map #{\Lambda^2_1 \to 1 \rtimes \Delta^1}.
}

%```agda
\agda{
weird-horn-inclusion : Œõ[2,1] ‚Üí ùüô ‚ãâ Œî¬π
weird-horn-inclusion = cogap (mk-cocone (‚Üë-hom (tt , i0) .Hom·µà.hom) ‚Üë-Œπ‚ÇÇ
                             Œª a ‚Üí glue (‚àÇŒî¬π-1 , tt , i0))

weird-horn-inclusion‚àô : Coslice-map (point (Œπ‚ÇÅ i0)) Œª _ ‚Üí ‚Üë-Œπ‚ÇÅ tt
weird-horn-inclusion‚àô = (weird-horn-inclusion , Œª _ ‚Üí glue (‚àÇŒî¬π-0 , tt , i0))

is-left-segal : ‚àÄ {ùì§} (A : Type ùì§) ‚Üí Type (ùìò ‚äî ùì§)
is-left-segal A = is-local (point weird-horn-inclusion) A
}
%```
}

\subtree[stt-00DB]{
\title{Left Segal types are Segal}
\taxon{Lemma}

\p{Any [left Segal](stt-00DA) type is [Segal](stt-00AI).}

\proof{
\p{We give a splitting of #{\Delta^2 \hookrightarrow 1 \rtimes \Delta^1},
   which furthermore preserves the inner horn inclusion.
   (Note the split embedding #{\Delta^2 \hookrightarrow \square^2} in
   \ref{stt-00C7} factors through this map.)}
}

%```agda
\agda{
retraction-weird : ùüô ‚ãâ Œî¬π ‚Üí Œî¬≤
retraction-weird
  = cogap (mk-cocone
            (Œª {(i , tt , j) ‚Üí (i , i ‚àß j) ‚¶É ‚àß-‚â§-eliml auto! ‚¶Ñ})
            ‚äé[ (Œª _ ‚Üí (i0 , i0)) , (i1 ,_) ]
            Œª { (mk-lift true  , tt , b) ‚Üí Œî¬≤-ext (refl , ‚àß-comm ‚àô 1-top)
              ; (mk-lift false , tt , b) ‚Üí Œî¬≤-ext (refl , 0-init) })

retraction-weird-resp-horn
  : retraction-weird ‚àò weird-horn-inclusion ~ Œõ[2,1]-incl
retraction-weird-resp-horn = pushout-ind _
  (mk-cocone·µà
    (Œª l ‚Üí Œî¬≤-ext (refl , ‚àß-comm ‚àô 0-init))
    (Œª r ‚Üí refl)
    (Œª _ ‚Üí Œî¬≤-is-set _ _ _ _))

section-weird : Œî¬≤ ‚Üí ùüô ‚ãâ Œî¬π
section-weird a = Œπ‚ÇÅ (Poly.Œî¬≤.s a , tt , Poly.Œî¬≤.t a)

section-weird-resp-horn
  : section-weird ‚àò Œõ[2,1]-incl ~ weird-horn-inclusion
section-weird-resp-horn = pushout-rec-unique _ _
  ~refl
  (Œª a ‚Üí glue (‚àÇŒî¬π-1 , tt , a))
  Œª a ‚Üí ap (_‚àô glue (‚àÇŒî¬π-1 , tt , i0))
           ( ap-‚àò section-weird Œõ[2,1]-incl (glue a)
           ‚àô ap (ap section-weird) (pushout-rec-apŒ≤ _)
           ‚àô lem) where
  lem : ap (section-weird) Œî¬≤-refl Ôºù refl
  lem = ap-‚àò Œπ‚ÇÅ (Œª where (i , j) ‚Üí (i , tt , j)) Œî¬≤-refl
      ‚àô ap (ap Œπ‚ÇÅ) (is-set‚Üêis-truncated
                     (√ó-is-truncated car-is-set (√ó-is-truncated ùüô-is-truncated car-is-set))
                     _ _ _ _)

sec-weird-is-sec : retraction-weird ‚àò section-weird ~ id
sec-weird-is-sec (a , b) = Œî¬≤-ext (refl , (‚àß-comm ‚àô auto!))

is-segal‚Üêis-left-segal
  : ‚àÄ {ùì§} {A : Type ùì§}
    ‚Üí is-left-segal A
    ‚Üí is-segal A
is-segal‚Üêis-left-segal orth tt
  = is-orthogonal‚áîorthogonal-! .fst
      (left-orthogonal-retraction Œõ[2,1]-incl weird-horn-inclusion
        (mk-amap id section-weird section-weird-resp-horn)
        ((mk-amap id retraction-weird retraction-weird-resp-horn) ,
          (~refl , ((Œª (i , j) ‚Üí Œî¬≤-ext (refl , ‚àß-comm ‚àô auto!))
          , Œª _ ‚Üí Œî¬≤-is-set _ _ _ _)))
        !
        (is-orthogonal‚áîorthogonal-! .snd (orth tt)))
}

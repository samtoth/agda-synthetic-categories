\subtree[stt-00F8]{
\title{Type families and dependent type families}
\taxon{Definition}

\p{
A \em{type family} is a function #{B : A \to \UU}. A \em{dependent type family} over the
type family #{B : A \to \UU} is a function #{Y : (a : A) \to X(a) \to \UV}.
}

%```agda
\agda{
Fam : (рқ“Ө1 рқ“Ө2 : Level) вҶ’ Type (lsuc рқ“Ө1 вҠ” lsuc рқ“Ө2)
Fam рқ“Ө1 рқ“Ө2 = ОЈ (Type рқ“Ө1) (О» X вҶ’ X вҶ’ Type рқ“Ө2)

{-#В NOINLINE Fam #-}

DepFam
  : {рқ“Ө1 рқ“Ө2 : Level}
  вҶ’ (рқ“Ө3 рқ“Ө4 : Level)
  вҶ’ Fam рқ“Ө1 рқ“Ө2
  вҶ’ Type (рқ“Ө1 вҠ” lsuc рқ“Ө3 вҠ” lsuc рқ“Ө4)
DepFam рқ“Ө3 рқ“Ө4 (A , B)
  = ОЈ (A вҶ’ Type рқ“Ө3)
      (О» X вҶ’ (a : A) вҶ’ X a вҶ’ Type рқ“Ө4)

DepВІFam
  : {рқ“Ө1 рқ“Ө2 рқ“Ө3 рқ“Ө4 : Level}
  вҶ’ (рқ“Ө5 рқ“Ө6 : Level)
  вҶ’ (F : Fam рқ“Ө1 рқ“Ө2)
  вҶ’ DepFam рқ“Ө3 рқ“Ө4 F
  вҶ’ Type (рқ“Ө1 вҠ” рқ“Ө3 вҠ” lsuc рқ“Ө5 вҠ” lsuc рқ“Ө6)
DepВІFam рқ“Ө5 рқ“Ө6 (A , B) (X , Y)
  = ОЈ ((a : A) вҶ’ X a вҶ’ Type рқ“Ө5)
      (О» U вҶ’ (a : A) (x : X a) вҶ’ U a x вҶ’ Type рқ“Ө6)
}
%```
}

\subtree[stt-00KO]{
\title{Maps of type families}
\author{samueltoth}
\date{2026-03-23}

%```agda
\agda{
module _ {рқ“Ө1 рқ“Ө2 рқ“Ө3 рқ“Ө4 : Level}
         (F@(A , B) : Fam рқ“Ө1 рқ“Ө2)
         (G@(X , Y) : Fam рқ“Ө3 рқ“Ө4) where
  Fam-map : Type (рқ“Ө1 вҠ” рқ“Ө2 вҠ” рқ“Ө3 вҠ” рқ“Ө4)
  Fam-map = ОЈ[ f вҲ¶ (A вҶ’ X) ] (вҲҖ a вҶ’ B a вҶ’ Y (f a))

  Cart-fam-map : Type (рқ“Ө1 вҠ” рқ“Ө2 вҠ” рқ“Ө3 вҠ” рқ“Ө4)
  Cart-fam-map = ОЈ[ f вҲ¶ (A вҶ’ X) ] (вҲҖ a вҶ’ B a вүғ Y (f a))

module _ {рқ“Ө1 рқ“Ө2 рқ“Ө3 рқ“Ө4 : Level}
         {F@(A , B) : Fam рқ“Ө1 рқ“Ө2}
         {G@(X , Y) : Fam рқ“Ө3 рқ“Ө4} where
  Fam-map-homotopy
    : Fam-map F G вҶ’ Fam-map F G вҶ’ Type (рқ“Ө1 вҠ” рқ“Ө2 вҠ” рқ“Ө3 вҠ” рқ“Ө4)
  Fam-map-homotopy (f , g) (f' , g')
    = ОЈ[ H вҲ¶ (f ~ f')] (вҲҖ a вҶ’ tr Y (H a) вҲҳ g a ~ g' a)

  Fam-map-refl~
    : вҲҖ (a : Fam-map F G) вҶ’ Fam-map-homotopy a a
  Fam-map-refl~ a = (~refl , (О» _ вҶ’ ~refl))

  is-cartesianб¶ 
    : Fam-map F G вҶ’ Type (рқ“Ө1 вҠ” рқ“Ө2 вҠ” рқ“Ө4)
  is-cartesianб¶  F = вҲҖ a вҶ’ is-equiv (F .snd a)

  Cart-fam-mapвҶҗis-cartesian
    : ОЈ (Fam-map F G) is-cartesianб¶  вҶ’ Cart-fam-map F G
  Cart-fam-mapвҶҗis-cartesian (a , b)
    = (a .fst , О» x вҶ’ mkвүғ (a .snd x) (b x))

  Cart-fam-mapвҶҗis-cartesian-is-equiv
    : is-equiv Cart-fam-mapвҶҗis-cartesian
  Cart-fam-mapвҶҗis-cartesian-is-equiv .is-equiv.qinv .fst (a , b)
    = ((a , _вүғ_.fwd вҲҳ b) , _вүғ_.has-is-eqv вҲҳ b)
  Cart-fam-mapвҶҗis-cartesian-is-equiv .is-equiv.qinv .snd .fst _ = refl
  Cart-fam-mapвҶҗis-cartesian-is-equiv .is-equiv.qinv .snd .snd _ = refl
  Cart-fam-mapвҶҗis-cartesian-is-equiv .is-equiv.coherent _ = refl
}
%```
}

\subtree[stt-00FA]{
\title{Equivalences of type families}
\taxon{Definition}

%```agda
\agda{
module _
  {рқ“Ө1 рқ“Ө2 рқ“Ө3 рқ“Ө4 : Level}
  (F@(A , B) : Fam рқ“Ө1 рқ“Ө2)
  (G@(X , Y) : Fam рқ“Ө3 рқ“Ө4)
  where

  infix 7 _вүғб¶ _
  _вүғб¶ _ : Type (рқ“Ө1 вҠ” рқ“Ө2 вҠ” рқ“Ө3 вҠ” рқ“Ө4)
  _вүғб¶ _ = ОЈ[ (mkвүғ e _) вҲ¶ A вүғ X ] ((a : A) вҶ’ B a вүғ Y (e a))
}
%```
}

\subtree[stt-00FB]{
\title{StraighteningвҖ“unstraightening for type families}
\taxon{Construction}

%```agda
\agda{
arrowвҶҗFam
  : {рқ“Ө1 рқ“Ө2 : Level}
    (F : Fam рқ“Ө1 рқ“Ө2)
  вҶ’ ОЈ (fst F) (snd F) вҶ’ fst F
arrowвҶҗFam F = fst

arrowвҶҗFam-fibre-fam
  : {рқ“Ө1 рқ“Ө2 : Level}
    {A : Type рқ“Ө1}
    {B : Type рқ“Ө2}
    (f : A вҶ’ B)
  вҶ’ arrowвҶҗFam (fibre-fam f) пјқ fst
arrowвҶҗFam-fibre-fam f = refl

fibre-fam-arrowвҶҗFamвүғб¶ 
  : {рқ“Ө1 рқ“Ө2 : Level}
    (F : Fam рқ“Ө1 рқ“Ө2)
  вҶ’ fibre-fam (arrowвҶҗFam F) вүғб¶  F
fibre-fam-arrowвҶҗFamвүғб¶  (A , B)
  = idequiv , fibre-straighten B
}
%```
}

\subtree[stt-00FC]{
\title{Dependent type families from nondependent type families}
\taxon{Definition}

%```agda
\agda{
module _
  {рқ“Ө1 рқ“Ө2 рқ“Ө3 рқ“Ө4 : Level}
  (F@(A , B) : Fam рқ“Ө1 рқ“Ө2)
  (G@(X , Y) : Fam рқ“Ө3 рқ“Ө4)
  where

  FamвҶ’DepFam : DepFam рқ“Ө3 рқ“Ө4 F
  FamвҶ’DepFam = ((О» _ вҶ’ X) , (О» _ вҶ’ Y))

  FamвҶ’DepВІFam
    : {рқ“Ө5 рқ“Ө6 : Level}
    вҶ’ Fam рқ“Ө5 рқ“Ө6
    вҶ’ DepВІFam рқ“Ө5 рқ“Ө6 F FamвҶ’DepFam
  FamвҶ’DepВІFam (U , V)
    = ((О» _ _ вҶ’ U) , (О» _ _ вҶ’ V))

  DepFamвҶ’DepВІFam
    : {рқ“Ө5 рқ“Ө6 : Level}
    вҶ’ DepFam рқ“Ө5 рқ“Ө6 G
    вҶ’ DepВІFam рқ“Ө5 рқ“Ө6 F FamвҶ’DepFam
  DepFamвҶ’DepВІFam (U , V)
    = ((О» _ вҶ’ U) , (О» _ вҶ’ V))
}
%```
}

\subtree[stt-00FD]{
\title{Identity and composition of equivalences of type families}
\taxon{Definition}

%```agda
\agda{
idвүғб¶  : вҲҖ {рқ“Ө1 рқ“Ө2} (F : Fam рқ“Ө1 рқ“Ө2) вҶ’ F вүғб¶  F
idвүғб¶  (A , B) = idequiv , (О» _ вҶ’ idequiv)

concatвүғб¶ 
  : вҲҖ {рқ“Ө1 рқ“Ө2 рқ“Ө3 рқ“Ө4 рқ“Ө5 рқ“Ө6}
      {F : Fam рқ“Ө1 рқ“Ө2}
      {G : Fam рқ“Ө3 рқ“Ө4}
      (H : Fam рқ“Ө5 рқ“Ө6)
    вҶ’ F вүғб¶  G
    вҶ’ G вүғб¶  H
    вҶ’ F вүғб¶  H
concatвүғб¶  H (e , ef) (e' , eg)
  = e вҲҷвүғ e'
  , (О» a вҶ’ ef a вҲҷвүғ eg (e ._вүғ_.fwd a))

}
%```
}


\subtree[stt-00KU]{
\taxon{Lemma}
\author{samueltoth}
\date{2026-03-24}

%```agda
\agda{
postcomp-вүғб¶ 
  : вҲҖ {рқ“Ө рқ“Ҙ рқ“Ұ рқ“ң рқ“Ұ' рқ“ң'} {F : Fam рқ“Ө рқ“Ҙ} {G : Fam рқ“Ұ рқ“ң} {H : Fam рқ“Ұ' рқ“ң'}
    вҶ’ G вүғб¶  H вҶ’ Cart-fam-map F G вҶ’ Cart-fam-map F H
postcomp-вүғб¶  (x , y)
  = map-ОЈ (x ._вүғ_.fwd вҲҳ_) О» a вҶ’ postcomp-О  (О» i вҶ’ _вҲҷвүғ y (a i))
}
%```
}

\subtree[stt-00FE]{
\title{Equivalences of dependent type families over a fixed base}
\taxon{Definition}

%```agda
\agda{
вүғбөҲб¶ -over
  : {рқ“Ө1 рқ“Ө2 рқ“Ө3 рқ“Ө4 рқ“Ө5 рқ“Ө6 : Level}
    (F@(A , B) : Fam рқ“Ө1 рқ“Ө2)
    (G@(X , Y) : DepFam рқ“Ө3 рқ“Ө4 F)
    (H@(U , V) : DepFam рқ“Ө5 рқ“Ө6 F)
  вҶ’ Type (рқ“Ө1 вҠ” рқ“Ө3 вҠ” рқ“Ө4 вҠ” рқ“Ө5 вҠ” рқ“Ө6)
вүғбөҲб¶ -over F (X , Y) (U , V)
  = (a : fst F) вҶ’ (X a , Y a) вүғб¶  (U a , V a)

syntax вүғбөҲб¶ -over F G H = G вүғбөҲб¶ вҹҰ F вҹ§ H
}
%```
}

\subtree[stt-00FF]{
\title{Identity and composition of dependent family equivalences}
\taxon{Definition}

%```agda
\agda{
idвүғбөҲб¶ 
  : {рқ“Ө1 рқ“Ө2 рқ“Ө3 рқ“Ө4 : Level}
    (F : Fam рқ“Ө1 рқ“Ө2)
    (G@(X , Y) : DepFam рқ“Ө3 рқ“Ө4 F)
  вҶ’ G вүғбөҲб¶ вҹҰ F вҹ§ G
idвүғбөҲб¶  F (X , Y) a = idвүғб¶  (X a , Y a)

concatвүғбөҲб¶ 
  : {рқ“Ө1 рқ“Ө2 рқ“Ө3 рқ“Ө4 рқ“Ө5 рқ“Ө6 рқ“Ө7 рқ“Ө8 : Level}
    (F : Fam рқ“Ө1 рқ“Ө2)
    (G : DepFam рқ“Ө3 рқ“Ө4 F)
    (H : DepFam рқ“Ө5 рқ“Ө6 F)
    (K : DepFam рқ“Ө7 рқ“Ө8 F)
  вҶ’ G вүғбөҲб¶ вҹҰ F вҹ§ H
  вҶ’ H вүғбөҲб¶ вҹҰ F вҹ§ K
  вҶ’ G вүғбөҲб¶ вҹҰ F вҹ§ K
concatвүғбөҲб¶  F (X , Y) (U , V) (P , Q) e e' a
  = concatвүғб¶  (P a , Q a) (e a) (e' a)
}
%```
}

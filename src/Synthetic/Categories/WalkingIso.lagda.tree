\date{2026-04-30}
\title{The walking isomorphism}
\author{fredrikbakke}
\taxon{Module}
\import{stt-macros}

\transclude{stt-00AB}

\agda{
open import Foundations.Prelude
open import Algebra.Lattice

module Synthetic.Categories.WalkingIso
  {рЭУШ} (ќФ¬є : Type рЭУШ) (I : Lattice ќФ¬є) (I-distr : is-distributive I)
  where

open import Axioms.UF

open Lattice I renaming (0l to i0; 1l to i1)
import Algebra.Lattice.Instances.Polynomial as Poly
open Poly hiding (L[x]; ќФ¬≤)

private
  ќФ¬≤ = Poly.ќФ¬≤ I

open import Core.CanonicalPushouts
open import Core.FunctorialityPullbacks
open import Core.Orthogonal
open notation

open import Ergonomics.Notations.Orthogonality

open import Synthetic.Hom ќФ¬є i0 i1
open import Synthetic.Horns ќФ¬є I I-distr
open import Synthetic.Boundaries ќФ¬є I I-distr
open import Synthetic.Triangles ќФ¬є I I-distr
open import Synthetic.Categories.Precategories ќФ¬є I I-distr
open import Synthetic.Categories.Homotopy ќФ¬є I I-distr
open import Synthetic.Categories.Groupoids ќФ¬є I I-distr
open import Synthetic.Categories.AlgebraicLaws ќФ¬є I I-distr
open import Synthetic.Categories.SplitMonomorphisms ќФ¬є I I-distr
open import Synthetic.Categories.WalkingSplitHom ќФ¬є I I-distr
open import Synthetic.Categories.Isomorphisms ќФ¬є I I-distr
}

\subtree[fre-00N0]{
\title{The walking isomorphism}
\author{fredrikbakke}
\taxon{Definition}

\p{
The \em{walking isomorphism} #{\mathfrak{I}} is the gluing of a walking split
monomorphism with a walking split epimorphism. Since the
[walking split morphism](Synthetic.Categories.SplitMonomorphisms) classifies both, we
formalise #{\mathfrak{I}} as [the pushout](Core.CanonicalPushouts)
}

\quiver{
\begin{tikzcd}
{\Delta^1} && {\mathfrak{M}} \\
\\
{\mathfrak{M}} && {\mathfrak{I}}
\arrow["{\mathrm{sec}_{\mathfrak{M}}}", from=1-1, to=1-3]
\arrow["{\mathrm{ret}_{\mathfrak{M}}}"', from=1-1, to=3-1]
\arrow[from=1-3, to=3-3]
\arrow[from=3-1, to=3-3]
\arrow[phantom, from=1-1, to=3-3, "\ulcorner" very near end]
\end{tikzcd}
}

\agda{
вДС : Type рЭУШ
вДС = Pushout sec-arr-рЭФР ret-arr-рЭФР

left-вДС : рЭФР вЖТ вДС
left-вДС = ќєвВБ

right-вДС : рЭФР вЖТ вДС
right-вДС = ќєвВВ

src-вДС : вДС
src-вДС = ќєвВБ src-рЭФР

tgt-вДС : вДС
tgt-вДС = ќєвВБ tgt-рЭФР

arrow-вДС : ќФ¬є вЖТ вДС
arrow-вДС = ќєвВБ вИШ sec-arr-рЭФР

left-inv-вДС : ќФ¬є вЖТ вДС
left-inv-вДС = ќєвВБ вИШ ret-arr-рЭФР

right-inv-вДС : ќФ¬є вЖТ вДС
right-inv-вДС = ќєвВВ вИШ sec-arr-рЭФР

hom-вДС : Hom вДС src-вДС tgt-вДС
hom-вДС = ap-hom ќєвВБ sec-рЭФР

left-inv-hom-вДС : Hom вДС tgt-вДС src-вДС
left-inv-hom-вДС = ap-hom ќєвВБ ret-рЭФР

right-diagonal-bd-вДС
  : (i : ќФ¬є) вЖТ right-вДС (рЭФРвЖРвИВќФ¬≤ (ќєвВВ i)) пЉЭ tgt-вДС
right-diagonal-bd-вДС i
  = ap right-вДС (glue i вИЩ sym (glue i1))
  вИЩ ap right-вДС (ap рЭФРвЖРќФ¬≤ (sym ќФ¬≤-refl))
  вИЩ sym (glue i1)

right-edge-bd-вДС
  : right-вДС вИШ рЭФРвЖРќЫ[2,1] вИШ ќєвВВ ~ hom-вДС .HomбµИ.hom
right-edge-bd-вДС i = sym (glue i)

right-inv-hom-вДС : Hom вДС tgt-вДС src-вДС
right-inv-hom-вДС
  = mk-hom right-inv-вДС
      ( ap (right-вДС вИШ рЭФРвЖРвИВќФ¬≤) (glue вИВќФ¬є-0) вИЩ right-diagonal-bd-вДС i0)
      ( (ap (right-вДС вИШ рЭФРвЖРќЫ[2,1]) ќЫ[2,1]-glue вИЩ right-edge-bd-вДС i0)
      вИЩ hom-вДС .HomбµИ.hom0)

left-inv-Hom2-вДС
  : Hom2 left-inv-hom-вДС hom-вДС (idH src-вДС)
left-inv-Hom2-вДС
  = ap-hom2 ќєвВБ ret-рЭФР sec-рЭФР (idH src-рЭФР) hom2-рЭФР

right-inv-Hom2-вДС
  : Hom2 hom-вДС right-inv-hom-вДС (idH tgt-вДС)
right-inv-Hom2-вДС .fst = right-вДС вИШ рЭФРвЖРќФ¬≤
right-inv-Hom2-вДС .snd
  = pushout-rec-unique _ (right-вДС вИШ рЭФРвЖРвИВќФ¬≤)
      horn-bd
      right-diagonal-bd-вДС
      ќї where
        вИВќФ¬є-0 вЖТ sym (вИЩ-reflr _)
        вИВќФ¬є-1 вЖТ top-coh
  where
  horn-bd
    : right-вДС вИШ рЭФРвЖРќЫ[2,1]
    ~ make-horn hom-вДС right-inv-hom-вДС
  horn-bd
    = pushout-rec-unique _ (right-вДС вИШ рЭФРвЖРќЫ[2,1])
        ~refl
        right-edge-bd-вДС
        ќї _ вЖТ вИЩ.insertl _ (вИЩ-sym (hom-вДС .HomбµИ.hom0))

  right-diagonal-top-bd-вДС
    : ap right-вДС (ap рЭФРвЖРќФ¬≤ ќФ¬≤-refl)
    вИЩ right-diagonal-bd-вДС i1
    пЉЭ sym (glue i1)
  right-diagonal-top-bd-вДС =
    top-cancel
      (ap рЭФРвЖРќФ¬≤ ќФ¬≤-refl)
      (ap рЭФРвЖРќФ¬≤ (sym ќФ¬≤-refl))
      (ap-sym рЭФРвЖРќФ¬≤ ќФ¬≤-refl)
      (glue i1)
      (sym (glue i1))
    where
    top-cancel
      : {x y z : рЭФР}
      вЖТ (r : x пЉЭ y)
      вЖТ (r' : y пЉЭ x)
      вЖТ r' пЉЭ sym r
      вЖТ (p : y пЉЭ z)
      вЖТ (q : right-вДС x пЉЭ tgt-вДС)
      вЖТ ap right-вДС r вИЩ (ap right-вДС (p вИЩ sym p) вИЩ ap right-вДС r' вИЩ q) пЉЭ q
    top-cancel refl .refl refl refl q = refl

  top-coh
    : ap (right-вДС вИШ рЭФРвЖРвИВќФ¬≤) (glue вИВќФ¬є-1)
    вИЩ right-diagonal-bd-вДС i1
    пЉЭ horn-bd (вИВќЫ[2,1]-incl вИВќФ¬є-1)
    вИЩ (hom-вДС .HomбµИ.hom1 вИЩ sym ((idH tgt-вДС) .HomбµИ.hom1))
  top-coh =
    ap (_вИЩ right-diagonal-bd-вДС i1)
      ( ap-вИШ right-вДС рЭФРвЖРвИВќФ¬≤ (glue вИВќФ¬є-1)
      вИЩ ap (ap right-вДС) (ap-вИШ рЭФРвЖРќФ¬≤ вИВќФ¬≤-incl (glue вИВќФ¬є-1))
      вИЩ ap (ap right-вДС вИШ ap рЭФРвЖРќФ¬≤) (pushout-rec-apќ≤ вИВќФ¬є-1))
    вИЩ right-diagonal-top-bd-вДС
    вИЩ sym (вИЩ-reflr (sym (glue i1)))

iso-вДС : Iso src-вДС tgt-вДС
iso-вДС
  = hom-вДС
  , left-inv-hom-вДС
  , right-inv-hom-вДС
  , left-inv-Hom2-вДС
  , right-inv-Hom2-вДС
}
}

\subtree[fre-00OV]{
\title{The walking isomorphism classifies isomorphisms}
\author{fredrikbakke}
\taxon{Theorem}

\agda{
module _  {рЭУ§} {A : Type рЭУ§} where

  вДС-map-cospan : Cospan (рЭУШ вКФ рЭУ§) (рЭУШ вКФ рЭУ§) (рЭУШ вКФ рЭУ§)
  вДС-map-cospan
    = mk-cospan (ќФ¬є вЖТ A) (precomp A ret-arr-рЭФР) (precomp A sec-arr-рЭФР)

  вДС-map-pullback-repr
    : (вДС вЖТ A) вЙГ Pullback (precomp A ret-arr-рЭФР) (precomp A sec-arr-рЭФР)
  вДС-map-pullback-repr = Pushout-UPвЙГ вИЩвЙГ precomp-coconeвЙГpb'

  вДС-repвЖТ
    : (вДС вЖТ A) вЖТ ќ£[ a вИґ A ] ќ£[ b вИґ A ] Iso a b
  вДС-repвЖТ ѕХ
    = ѕХ src-вДС
    , ѕХ tgt-вДС
    , ap-hom ѕХ hom-вДС
    , ap-hom ѕХ left-inv-hom-вДС
    , ap-hom ѕХ right-inv-hom-вДС
    , ap-hom2 ѕХ left-inv-hom-вДС hom-вДС (idH src-вДС) left-inv-Hom2-вДС
    , ap-hom2 ѕХ hom-вДС right-inv-hom-вДС (idH tgt-вДС) right-inv-Hom2-вДС

  вДС-repвЖР
    : ќ£[ a вИґ A ] ќ£[ b вИґ A ] Iso a b вЖТ (вДС вЖТ A)
  вДС-repвЖР (a , b , f , g , h , ќЈ , ќµ)
    = pushout-rec (mk-cocone
        (рЭФР-split-mono-reprвЖР (a , b , f , g , ќЈ))
        (рЭФР-split-mono-reprвЖР (b , a , h , f , ќµ))
        (ќї i вЖТ ќЈ .snd (ќєвВБ (ќєвВБ i)) вИЩ sym (ќµ .snd (ќєвВБ (ќєвВВ i)))))

  вДС-repвЖТconst-fwd
    : (a : A) вЖТ fwd-Iso (вДС-repвЖТ (const A вДС a) .snd .snd) пЉЭ HomвЖРId refl
  вДС-repвЖТconst-fwd a = ap-hom-const a hom-вДС

  вДС-repвЖТconst-left-inv
    : (a : A) вЖТ вДС-repвЖТ (const A вДС a) .snd .snd .snd .fst пЉЭ idH a
  вДС-repвЖТconst-left-inv a = ap-hom-const a left-inv-hom-вДС

  вДС-repвЖТconst-right-inv
    : (a : A) вЖТ вДС-repвЖТ (const A вДС a) .snd .snd .snd .snd .fst пЉЭ idH a
  вДС-repвЖТconst-right-inv a = ap-hom-const a right-inv-hom-вДС

  left-inv-Hom2-diagonal-вДС
    : ap left-вДС вИШ glue ~ left-inv-Hom2-вДС .snd вИШ ќєвВВ
  left-inv-Hom2-diagonal-вДС i
    = ap (ap left-вДС) (sym (hom2-рЭФР-diagonal i))
    вИЩ sym (вИЩ-reflr _)
    вИЩ ap (ap left-вДС (hom2-рЭФР .snd (ќєвВВ i)) вИЩ_)
        (sym (ap-вИВќФ¬≤-diagonal left-вДС i))

  вДС-repвЖРвЖТ-left-htpy
    : (ѕХ : вДС вЖТ A) вЖТ ѕХ вИШ left-вДС ~ вДС-repвЖР (вДС-repвЖТ ѕХ) вИШ left-вДС
  вДС-repвЖРвЖТ-left-htpy ѕХ
    = pushout-rec-unique _ (ѕХ вИШ left-вДС) ~refl ~refl ќї i вЖТ
      вИЩ-reflr _
      вИЩ ap-вИШ ѕХ left-вДС (glue i)
      вИЩ ap (ap ѕХ) (left-inv-Hom2-diagonal-вДС i)
      вИЩ sym (ap-hom2-diagonal ѕХ left-inv-hom-вДС hom-вДС (idH src-вДС) left-inv-Hom2-вДС i)

  вДС-repвЖРвЖТ-right-htpy
    : (ѕХ : вДС вЖТ A) вЖТ ѕХ вИШ right-вДС ~ вДС-repвЖР (вДС-repвЖТ ѕХ) вИШ right-вДС
  вДС-repвЖРвЖТ-right-htpy ѕХ
    = pushout-rec-unique _ (ѕХ вИШ right-вДС) ~refl pt ќї i
      вЖТ ap (_вИЩ pt tt) (ap-вИШ ѕХ right-вДС (glue i))
      вИЩ sym (ap-вИЩ ѕХ (ap right-вДС (glue i)) (ptвВА))
      вИЩ ap (ap ѕХ) (right-inv-Hom2-diagonal i)
      вИЩ sym (ap-hom2-diagonal ѕХ hom-вДС right-inv-hom-вДС (idH tgt-вДС) right-inv-Hom2-вДС i)
    where
    ptвВА : right-вДС (ќєвВВ tt) пЉЭ tgt-вДС
    ptвВА
      = sym (ap right-вДС (glue i1))
      вИЩ ap right-вДС (ap рЭФРвЖРќФ¬≤ (sym ќФ¬≤-refl))
      вИЩ sym (glue i1)

    pt : ѕХ вИШ right-вДС вИШ ќєвВВ ~ const A рЭЯЩ (ѕХ tgt-вДС)
    pt tt = ap ѕХ ptвВА

    right-inv-Hom2-diagonal
      : (i : ќФ¬є)
      вЖТ ap right-вДС (glue i) вИЩ ptвВА пЉЭ right-inv-Hom2-вДС .snd (ќєвВВ i)
    right-inv-Hom2-diagonal i
      = sym (вИЩ-assoc (ap right-вДС (glue i)) (sym (ap right-вДС (glue i1))) _)
      вИЩ ap (_вИЩ (ap right-вДС (ap рЭФРвЖРќФ¬≤ (sym ќФ¬≤-refl)) вИЩ sym (glue i1)))
           ( ap (ap right-вДС (glue i) вИЩ_) (sym (ap-sym right-вДС (glue i1)))
           вИЩ sym (ap-вИЩ right-вДС (glue i) (sym (glue i1))))

  opaque
    unfolding hom2-рЭФР-boundary

    left-inv-Hom2-left-вДС
      : (i : ќФ¬є) вЖТ left-inv-Hom2-вДС .snd (ќєвВБ (ќєвВБ i)) пЉЭ refl
    left-inv-Hom2-left-вДС i
      = apвВВ (_вИЩ_) refl (ap-вИВќФ¬≤-left left-вДС i)
      вИЩ вИЩ-reflr _

  right-inv-Hom2-right-вДС
    : (i : ќФ¬є)
    вЖТ right-inv-Hom2-вДС .snd (ќєвВБ (ќєвВВ i)) пЉЭ sym (glue i)
  right-inv-Hom2-right-вДС i = refl

  left-inv-Hom2-left-refl-вДС
    : (ѕХ : вДС вЖТ A) (i : ќФ¬є)
    вЖТ ap-hom2 ѕХ left-inv-hom-вДС hom-вДС (idH src-вДС) left-inv-Hom2-вДС .snd (ќєвВБ (ќєвВБ i))
    пЉЭ refl
  left-inv-Hom2-left-refl-вДС ѕХ i
    = apвВВ (_вИЩ_) (ap (ap ѕХ) (left-inv-Hom2-left-вДС i)) (ap-вИВќФ¬≤-left ѕХ i)
    вИЩ вИЩ-reflr _

  right-inv-Hom2-right-sym-вДС
    : (ѕХ : вДС вЖТ A) (i : ќФ¬є)
    вЖТ ap-hom2 ѕХ hom-вДС right-inv-hom-вДС (idH tgt-вДС) right-inv-Hom2-вДС .snd (ќєвВБ (ќєвВВ i))
    пЉЭ sym (ap ѕХ (glue i))
  right-inv-Hom2-right-sym-вДС ѕХ i
    = apвВВ (_вИЩ_) (ap (ap ѕХ) (right-inv-Hom2-right-вДС i)) (ap-вИВќФ¬≤-right ѕХ i)
    вИЩ вИЩ-reflr _
    вИЩ ap-sym ѕХ (glue i)

  вДС-repвЖРвЖТ-glue
    : (ѕХ : вДС вЖТ A) (i : ќФ¬є)
    вЖТ ap ѕХ (glue i)
    пЉЭ ap-hom2 ѕХ left-inv-hom-вДС hom-вДС (idH src-вДС) left-inv-Hom2-вДС .snd (ќєвВБ (ќєвВБ i))
    вИЩ sym (ap-hom2 ѕХ hom-вДС right-inv-hom-вДС (idH tgt-вДС) right-inv-Hom2-вДС .snd (ќєвВБ (ќєвВВ i)))
  вДС-repвЖРвЖТ-glue ѕХ i
    = apвВВ (_вИЩ_)
        (sym (left-inv-Hom2-left-refl-вДС ѕХ i))
        (sym (ap sym (right-inv-Hom2-right-sym-вДС ѕХ i) вИЩ sym-sym))

  opaque
    вДС-repвЖРвЖТ : вДС-repвЖР вИШ вДС-repвЖТ ~ id
    вДС-repвЖРвЖТ ѕХ
      = sym (funextвЖТ (pushout-rec-unique _ ѕХ
          (вДС-repвЖРвЖТ-left-htpy ѕХ)
          (вДС-repвЖРвЖТ-right-htpy ѕХ)
          (ќї i вЖТ вИЩ-reflr (ap ѕХ (glue i)) вИЩ вДС-repвЖРвЖТ-glue ѕХ i)))

  opaque
    unfolding рЭФР-split-mono-reprвЖРid

    вДС-repвЖРid
      : вДС-repвЖР вИШ id-TotalIso ~ const A вДС
    вДС-repвЖРid a
      = sym (funextвЖТ
          (pushout-rec-unique _ (const A вДС a)
            (рЭФР-split-mono-reprвЖРid a)
            (рЭФР-split-mono-reprвЖРid a)
            ќї i вЖТ вИЩ-reflr _ вИЩ ap-const (glue i)))
}

\p{
We have yet to formalise that \code{вДС-repвЖР} is a section of \code{вДС-repвЖТ} for
arbitrary types.
}
}

\subtree[fre-00P0]{
\title{The walking isomorphism classifies isomorphisms in Segal types}
\author{fredrikbakke}
\taxon{Proposition}

\p{
To make our lives easier we show that \code{вДС-repвЖР} is a section of \code{вДС-repвЖТ} in
[Segal types](stt-00AI), using that \code{is-iso} is a proposition.
}

\agda{
module _ {рЭУ§} {A : Type рЭУ§} where opaque

  вДС-repвЖТвЖР-src
    : (x : ќ£[ a вИґ A ] ќ£[ b вИґ A ] Iso a b)
    вЖТ вДС-repвЖТ (вДС-repвЖР x) .fst пЉЭ x .fst
  вДС-repвЖТвЖР-src (a , b , f , g , h , ќЈ , ќµ)
    = sym (fwd-Iso (вДС-repвЖТ (вДС-repвЖР (a , b , f , g , h , ќЈ , ќµ)) .snd .snd) .HomбµИ.hom0)
    вИЩ ќЈ .snd (ќєвВБ (ќєвВБ i0))
    вИЩ f .HomбµИ.hom0

  вДС-repвЖТвЖР-tgt
    : (x : ќ£[ a вИґ A ] ќ£[ b вИґ A ] Iso a b)
    вЖТ вДС-repвЖТ (вДС-repвЖР x) .snd .fst пЉЭ x .snd .fst
  вДС-repвЖТвЖР-tgt (a , b , f , g , h , ќЈ , ќµ)
    = sym (fwd-Iso (вДС-repвЖТ (вДС-repвЖР (a , b , f , g , h , ќЈ , ќµ)) .snd .snd) .HomбµИ.hom1)
    вИЩ ќЈ .snd (ќєвВБ (ќєвВБ i1))
    вИЩ f .HomбµИ.hom1

  вДС-repвЖТвЖР-fwd
    : (x : ќ£[ a вИґ A ] ќ£[ b вИґ A ] Iso a b)
    вЖТ adjust-hom (вДС-repвЖТвЖР-src x) (вДС-repвЖТвЖР-tgt x) (fwd-Iso (вДС-repвЖТ (вДС-repвЖР x) .snd .snd))
         пЉЭ fwd-Iso (x .snd .snd)
  вДС-repвЖТвЖР-fwd (a , b , f , g , h , ќЈ , ќµ)
    = Hom-extвЖТ
        ( ќЈ .snd вИШ ќєвВБ вИШ ќєвВБ
        , вИЩ.insertr _
            {h = sym (fwd-Iso (вДС-repвЖТ (вДС-repвЖР (a , b , f , g , h , ќЈ , ќµ)) .snd .snd) .HomбµИ.hom0)}
            {i = fwd-Iso (вДС-repвЖТ (вДС-repвЖР (a , b , f , g , h , ќЈ , ќµ)) .snd .snd) .HomбµИ.hom0}
            (вИЩ-sym
              (fwd-Iso (вДС-repвЖТ (вДС-repвЖР (a , b , f , g , h , ќЈ , ќµ)) .snd .snd) .HomбµИ.hom0))
            {f = ќЈ .snd (ќєвВБ (ќєвВБ i0)) вИЩ f .HomбµИ.hom0}
        , вИЩ.insertr _
            {h = sym (fwd-Iso (вДС-repвЖТ (вДС-repвЖР (a , b , f , g , h , ќЈ , ќµ)) .snd .snd) .HomбµИ.hom1)}
            {i = fwd-Iso (вДС-repвЖТ (вДС-repвЖР (a , b , f , g , h , ќЈ , ќµ)) .snd .snd) .HomбµИ.hom1}
            (вИЩ-sym
              (fwd-Iso (вДС-repвЖТ (вДС-repвЖР (a , b , f , g , h , ќЈ , ќµ)) .snd .snd) .HomбµИ.hom1))
            {f = ќЈ .snd (ќєвВБ (ќєвВБ i1)) вИЩ f .HomбµИ.hom1})

  BasedIso-pathбµИвЖТ
    : (рЭРі : is-segal A)
      {a a' b b' : A}
    вЖТ (p : a пЉЭ a') (q : b пЉЭ b')
    вЖТ {f : Iso a b} {g : Iso a' b'}
    вЖТ adjust-hom p q (fwd-Iso f) пЉЭ fwd-Iso g
    вЖТ IdбµИ (ap (ќї x вЖТ ќ£[ y вИґ A ] Iso x y) p) (b , f) (b' , g)
  BasedIso-pathбµИвЖТ рЭРі refl refl {f = f} h
    = IdбµИ-inl
        {P = ap (ќї x вЖТ ќ£[ y вИґ A ] Iso x y) refl}
        (ќ£-pathвЖТ (refl , Iso-pathвЖТ рЭРі (adjust-hom-refl (fwd-Iso f) вИЩ h)))

  вДС-repвЖТвЖР
    : (рЭРі : is-segal A)
      (x : ќ£[ a вИґ A ] ќ£[ b вИґ A ] Iso a b)
    вЖТ вДС-repвЖТ (вДС-repвЖР x) пЉЭ x
  вДС-repвЖТвЖР рЭРі (a , b , f , f-iso)
    = ќ£-pathвЖТ
        ( вДС-repвЖТвЖР-src (a , b , f , f-iso)
        , BasedIso-pathбµИвЖТ рЭРі
            (вДС-repвЖТвЖР-src (a , b , f , f-iso))
            (вДС-repвЖТвЖР-tgt (a , b , f , f-iso))
            (вДС-repвЖТвЖР-fwd (a , b , f , f-iso)))
}

\p{
Hence \code{вДС-repвЖТ} and \code{вДС-repвЖР} form a mutual inverse pair, at least for Segal
types.
}

\agda{
module _ {рЭУ§} {A : Type рЭУ§} (рЭРі :  is-segal A) where

  вДС-repвЖТ-is-equiv : is-equiv вДС-repвЖТ
  вДС-repвЖТ-is-equiv = is-equivвЖРqinv (вДС-repвЖР , вДС-repвЖРвЖТ , вДС-repвЖТвЖР рЭРі)

  вДС-repвЙГ : (вДС вЖТ A) вЙГ TotalIso A
  вДС-repвЙГ = mkвЙГ вДС-repвЖТ вДС-repвЖТ-is-equiv

  вДС-repвЖР-is-equiv : is-equiv вДС-repвЖР
  вДС-repвЖР-is-equiv = bwd-is-equiv вДС-repвЙГ

  вДС-repвЖТconst
    : (a : A) вЖТ вДС-repвЖТ (const A вДС a) пЉЭ id-TotalIso a
  вДС-repвЖТconst a
    = ќ£-pathвЖТ (refl , ќ£-pathвЖТ (refl , Iso-pathвЖТ рЭРі (вДС-repвЖТconst-fwd a)))

}
}

  classify-έΙγ
    = Type-is-universal.arrow-map {f = ╬╡έβφ (έΙγTypeέΙβ-╧Α)}
                                  (╬╗ _ έΗΤ self-is-small) .Arrow-map.bot

  έΙγά╡Ι : έΙΑ {@έβφ ΏζΥν ΏζΥξ} {@έβφ ╬Υ : Type ΏζΥν} έΗΤ @έβφ ((I έΗΤ ╬Υ) έΗΤ Type ΏζΥξ) έΗΤ ╬Υ έΗΤ Type (lsuc ΏζΥξ)
  έΙγά╡Ι A = classify-έΙγ έΙα ╬╡έβφ (transpose (modέβφ A))

  {-# INLINE έΙγά╡Ι #-}

  opaque

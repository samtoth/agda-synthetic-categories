\date{2025-02-24}
\title{Characterising identity in fibre types}
\taxon{Module}
\author{samueltoth}
\import{stt-macros}

\agda{
module Foundations.FibreIdentity where

open import Foundations.Universes
open import Foundations.Sigma
open import Foundations.SigmaIdentity
open import Foundations.FibrewiseEquivalences
open import Foundations.Functions
open import Foundations.QuasiEquivalences
open import Foundations.CoherentEquivalences
open import Foundations.Identity
open import Foundations.DependentIdentity
}

\p{Although [fibres](stt-000M) are defined as sigma types - [who's path types can be characterised](Foundations.SigmaIdentity) - we can give a
particular special charecterisation of the path space of fibre types that will come in handy especially in proving that certain maps
have contractible or propositional fibres.
}

\subtree[stt-000N]{
\taxon{Theorem}


\p{Given two terms #{(x,p),(y,q)} of #{\fibre{f}{y}}, we characterise the path type as follows:}

##{
 ((x,p) = (y,q)) \simeq (\Sigma_{(\gamma : x = y)} f(\gamma) \cdot q = p)
}


\proof{
We reason in a chain of equivalences:

##{
\begin{align}
(x,p) = (y,q) &\simeq && \Sigma_{(\gamma : x = y)} \gamma^* p = q \\
      	      &\simeq && \Sigma_{(\gamma : x = y)} f(\gamma) \cdot q = p
\end{align}
}

\ol{
\li{is the characterisation of paths in sigma types}
\li{follows directly from path induction on #{\gamma} and the fact path inversion is an equivalence}
}

\agda{
fibre-pathтЙГ
  : тИА {ЁЭУд ЁЭУе} {A : Type ЁЭУд} {B : Type ЁЭУе} {f : A тЖТ B} {b : B} тЖТ тИА {x y : fibre f b}
    тЖТ (x я╝Э y) тЙГ (╬г (x .fst я╝Э y .fst) ╬╗ ╬│ тЖТ ap f ╬│ тИЩ y .snd я╝Э x .snd)
fibre-pathтЙГ {x = a@(x , p)} {b@(y , q)}
  = (a я╝Э b)                              тЙГтЯи ╬г-path eтБ╗┬╣ тЯй
    ╬г (x я╝Э y) (╬╗ ╬│ тЖТ Idс╢а _ ╬│ p q)   тЙГтЯи ╬г-ap-тЙГ lem тЯй
    ╬г (x я╝Э y) (╬╗ ╬│ тЖТ ap _ ╬│ тИЩ q я╝Э p)    тЙГтИО where

  lem2 : тИА {ЁЭУд} {A : Type ЁЭУд} {x y : A} (p : x я╝Э y) (q : x я╝Э y) тЖТ (p я╝Э q) тЙГ (q я╝Э p)
  lem2 p q = equivтЖРqequiv (mkтЙК sym (sym , (╬╗ _ тЖТ sym-sym) , (╬╗ _ тЖТ sym-sym)))

  lem : (╬│ : x я╝Э y) тЖТ (Idс╢а _ ╬│ p q) тЙГ (ap _ ╬│ тИЩ q я╝Э p)
  lem refl = lem2 p q

fibre-pathтЖТ
  : тИА {ЁЭУд ЁЭУе} {A : Type ЁЭУд} {B : Type ЁЭУе} {f : A тЖТ B} {b : B} тЖТ тИА {x y : fibre f b}
    тЖТ (╬г (x .fst я╝Э y .fst) ╬╗ ╬│ тЖТ ap f ╬│ тИЩ y .snd я╝Э x .snd) тЖТ (x я╝Э y)
fibre-pathтЖТ = _тЙГ_.bwd fibre-pathтЙГ

fibre-pathтЖРId
  : тИА {ЁЭУд ЁЭУе} {A : Type ЁЭУд} {B : Type ЁЭУе} {f : A тЖТ B} {b : B} тЖТ тИА {x y : fibre f b}
    тЖТ (x я╝Э y) тЖТ (╬г (x .fst я╝Э y .fst) ╬╗ ╬│ тЖТ ap f ╬│ тИЩ y .snd я╝Э x .snd)
fibre-pathтЖРId = _тЙГ_.fwd fibre-pathтЙГ
}
}
}

\subtree[stt-00B2]{
\title{Commuting cube}
\taxon{Definition}

\p{Given a pair of arrow maps #{F : f \to g} and #{G : h \to k}, we define the
type of commuting cubes, consisting of a quadruple of maps, fillers for each
of the resulting faces, and a coherence that fills in the solid area of the
cube. Alternatively, this data can be packages up as pair of arrow maps
#{L : f \to h} and #{R : g \to k} together with a homotopy of arrow maps
#{GL \sim RF}.}

\quiver{
\begin{tikzcd}[cramped]
	& X && Z \\
	A && C \\
	& Y && W \\
	B && D
	\arrow[from=1-2, to=1-4]
	\arrow[from=1-2, to=3-2]
	\arrow[from=1-4, to=3-4]
	\arrow[from=2-1, to=1-2]
	\arrow[from=2-1, to=2-3]
	\arrow[from=2-1, to=4-1]
	\arrow[from=2-3, to=1-4]
	\arrow[from=2-3, to=4-3]
	\arrow[from=3-2, to=3-4]
	\arrow[from=4-1, to=3-2]
	\arrow[from=4-1, to=4-3]
	\arrow[from=4-3, to=3-4]
\end{tikzcd}
}

%```agda
\agda{
record Cube {𝓤 𝓥 𝓦 𝓧 𝓛 𝓜 𝓝 𝓞}
            {A : Type 𝓤} {B : Type 𝓥} {f : A → B}
            {C : Type 𝓦} {D : Type 𝓧} {g : C → D}
            (F : Arrow-map f g)
            {X : Type 𝓛} {Y : Type 𝓜} {h  : X → Y}
            {Z : Type 𝓝} {W : Type 𝓞} {k : Z → W}
            (G : Arrow-map h k) : Type (𝓤 ⊔ 𝓥 ⊔ 𝓦 ⊔ 𝓧 ⊔ 𝓛 ⊔ 𝓜 ⊔ 𝓝 ⊔ 𝓞) where
  constructor mk-cube
  module F = Arrow-map F
  module G = Arrow-map G
  field
    left : Arrow-map f h
    right : Arrow-map g k
    comm : Arrow-map-path (paste-squares G left) (paste-squares right F)

  module left = Arrow-map left
  module right = Arrow-map right

  topl : A → X
  topl = left .Arrow-map.top

  topr : C → Z
  topr = right .Arrow-map.top

  botl : B → Y
  botl = left .Arrow-map.bot

  botr : D → W
  botr = right .Arrow-map.bot

  bot : G.bot ∘ botl ~ botr ∘ F.bot
  bot = comm .snd .fst

  top : G.top ∘ topl ~ topr ∘ F.top
  top = comm .fst


  top-amap : Arrow-map F.top G.top
  top-amap .Arrow-map.top = topl
  top-amap .Arrow-map.bot = topr
  top-amap .Arrow-map.comm = top ~⁻¹

  bot-amap : Arrow-map F.bot G.bot
  bot-amap .Arrow-map.top = botl
  bot-amap .Arrow-map.bot = botr
  bot-amap .Arrow-map.comm = bot ~⁻¹

  fill-hex
    : ∀ a → Hexagon
              (ap G.bot (left.comm a)) (G.comm (left.top a)) (ap k (top a))
              (bot (f a)) (ap right.bot (F.comm a)) (right.comm (F.top a))
  fill-hex a .Hexagon.un-hex
    = sym (∙-assoc (ap G.bot (left.comm a)) _ (ap k (top a)))
    ∙ comm .snd .snd a
}
%```
}


\subtree[stt-00B3]{
\title{Cartesian commuting cubes preserve pullbacks}
\taxon{Theorem}

\p{Consider a commuting cube where the left and right squares are cartesian,}
\quiver{
\begin{tikzcd}[cramped]
	& X && Z \\
	A && C \\
	& Y && W \\
	B && D
	\arrow[from=1-2, to=1-4]
	\arrow[from=1-2, to=3-2]
	\arrow[from=1-4, to=3-4]
	\arrow[from=2-1, to=1-2]
	\arrow[from=2-1, to=2-3]
	\arrow[from=2-1, to=4-1]
	\arrow[from=2-3, to=1-4]
	\arrow[from=2-3, to=4-3]
	\arrow[from=3-2, to=3-4]
	\arrow[from=4-1, to=3-2]
	\arrow[from=4-1, to=4-3]
	\arrow[from=4-3, to=3-4]
\end{tikzcd}
}

\p{then the front square is cartesian if the back square is.}

\proof{
\p{Follows from the 3 for 2 property for cartesian squares.}
}


%```agda
\agda{
front-cartesian←cartesian-cube
  : ∀ {𝓤 𝓥 𝓦 𝓧 𝓛 𝓜 𝓝 𝓞}
      {A : Type 𝓤} {B : Type 𝓥} {f : A → B}
      {C : Type 𝓦} {D : Type 𝓧} {g : C → D}
      (F : Arrow-map f g)
      {X : Type 𝓛} {Y : Type 𝓜} {h  : X → Y}
      {Z : Type 𝓝} {W : Type 𝓞} {k : Z → W}
      (G : Arrow-map h k)
    → (cube : Cube F G) → let open Cube cube
    in is-cartesian left → is-cartesian right
    → is-cartesian G → is-cartesian F
front-cartesian←cartesian-cube {f = f} F {k = k} G cube leftCart rightCart GCart
  = 3-for-2-cartesian
      comm
      (compose-cartesian GCart leftCart)
      rightCart where
  open Cube cube
}
%```
}

\subtree[stt-00BP]{
\title{Equivalences of squares preserve pullbacks}
\taxon{Corollary}

\p{We define square-equivalences in the obvious way, just asking both the left
and right squares to be [arrow equivalences](stt-004R). Since arrow equivalences
are in particular cartesian squares, this result follows trivially from
\ref{stt-00B3}.}

%```agda
\agda{
is-Cube-equiv
  : ∀ {𝓤 𝓥 𝓦 𝓧 𝓛 𝓜 𝓝 𝓞}
      {A : Type 𝓤} {B : Type 𝓥} {f : A → B}
      {C : Type 𝓦} {D : Type 𝓧} {g : C → D}
      {F : Arrow-map f g}
      {X : Type 𝓛} {Y : Type 𝓜} {h  : X → Y}
      {Z : Type 𝓝} {W : Type 𝓞} {k : Z → W}
      {G : Arrow-map h k}
    → Cube F G → Type (𝓤 ⊔ 𝓥 ⊔ 𝓦 ⊔ 𝓧 ⊔ 𝓛 ⊔ 𝓜 ⊔ 𝓝 ⊔ 𝓞)
is-Cube-equiv α = is-Arrow-equiv left × is-Arrow-equiv right where
  open Cube α

opaque
  front-cartesian←equiv-cube
    : ∀ {𝓤 𝓥 𝓦 𝓧 𝓛 𝓜 𝓝 𝓞}
        {A : Type 𝓤} {B : Type 𝓥} {f : A → B}
        {C : Type 𝓦} {D : Type 𝓧} {g : C → D}
        {F : Arrow-map f g}
        {X : Type 𝓛} {Y : Type 𝓜} {h  : X → Y}
        {Z : Type 𝓝} {W : Type 𝓞} {k : Z → W}
        {G : Arrow-map h k}
      → (α : Cube F G)
      → is-Cube-equiv α
      → is-cartesian G
      → is-cartesian F
  front-cartesian←equiv-cube {F = F} {G = G} α (le , re)
    = front-cartesian←cartesian-cube
        F G α
        (is-cartesian←is-equiv _ le)
        (is-cartesian←is-equiv _ re)

  back-cartesian←equiv-cube
    : ∀ {𝓤 𝓥 𝓦 𝓧 𝓛 𝓜 𝓝 𝓞}
        {A : Type 𝓤} {B : Type 𝓥} {f : A → B}
        {C : Type 𝓦} {D : Type 𝓧} {g : C → D}
        {F : Arrow-map f g}
        {X : Type 𝓛} {Y : Type 𝓜} {h  : X → Y}
        {Z : Type 𝓝} {W : Type 𝓞} {k : Z → W}
        {G : Arrow-map h k}
      → (α : Cube F G)
      → is-Cube-equiv α
      → is-cartesian F
      → is-cartesian G
  back-cartesian←equiv-cube {F = F} {G = G} α αe cart
    = right-cancel-cartesian
        {a = G} {left} {paste-squares right F}
        (Arrow-map-path←id (sym (Arrow-map-path→ comm)))
        (compose-cartesian (is-cartesian←is-equiv right (αe .snd)) cart)
        (αe .fst)   where
    open Cube α

  front⇔back-cartesian←equiv-cube
    : ∀ {𝓤 𝓥 𝓦 𝓧 𝓛 𝓜 𝓝 𝓞}
        {A : Type 𝓤} {B : Type 𝓥} {f : A → B}
        {C : Type 𝓦} {D : Type 𝓧} {g : C → D}
        {F : Arrow-map f g}
        {X : Type 𝓛} {Y : Type 𝓜} {h  : X → Y}
        {Z : Type 𝓝} {W : Type 𝓞} {k : Z → W}
        {G : Arrow-map h k}
      → (α : Cube F G)
      → is-Cube-equiv α
      → is-cartesian F
      ⇔ is-cartesian G
  front⇔back-cartesian←equiv-cube α eq
    = (back-cartesian←equiv-cube α eq , front-cartesian←equiv-cube α eq)
}
%```
}


\subtree[stt-00BF]{
\taxon{Construction}
\title{Gap map square from cubes}

\p{There is a forgetful functor from the category of squares to the
category of cospan maps. On objects, we have already shown that [a square
is comprised of a cospan together with a cone over it](stt-002Z), now we give
(part of) the action on morhpisms: each cube gives rise to a
[map of cospans](stt-00BG).}

%```agda
\agda{
module _ where
  open Cube
  cospan-map←cube
    : ∀ {𝓤 𝓥 𝓦 𝓧 𝓛 𝓜 𝓝 𝓞}
        {A : Type 𝓤} {B : Type 𝓥} {f : A → B}
        {C : Type 𝓦} {D : Type 𝓧} {g : C → D}
        {F : Arrow-map f g}
        {X : Type 𝓛} {Y : Type 𝓜} {h  : X → Y}
        {Z : Type 𝓝} {W : Type 𝓞} {k : Z → W}
        {G : Arrow-map h k}
      → (cube : Cube F G)
      → Cospan-map (Cone←Arrow-map F .fst) (Cone←Arrow-map G .fst)
  cospan-map←cube α .Cospan-map.h₁ = botl α
  cospan-map←cube α .Cospan-map.h₂ = botr α
  cospan-map←cube α .Cospan-map.h₃ = topr α
  cospan-map←cube α .Cospan-map.H = bot α ~⁻¹
  cospan-map←cube α .Cospan-map.K = right.comm α
}
%```

\p{Consequently, a map of squares (a cube) also induces a map of arrows between
the respective [gap maps](stt-003L).}

%```agda
\agda{
gap-map-square←cube
  : ∀ {𝓤 𝓥 𝓦 𝓧 𝓛 𝓜 𝓝 𝓞}
      {A : Type 𝓤} {B : Type 𝓥} {f : A → B}
      {C : Type 𝓦} {D : Type 𝓧} {g : C → D}
      (F : Arrow-map f g)
      {X : Type 𝓛} {Y : Type 𝓜} {h  : X → Y}
      {Z : Type 𝓝} {W : Type 𝓞} {k : Z → W}
      (G : Arrow-map h k)
    → (cube : Cube F G)
    → Arrow-map (gap-map←square F) (gap-map←square G)
gap-map-square←cube F G α .Arrow-map.top = α .Cube.left.top
gap-map-square←cube F G α .Arrow-map.bot = Pullback₁ (cospan-map←cube α)
gap-map-square←cube {f = f} F {k = k} G
   α@(mk-cube L R (lc , rc , fill)) .Arrow-map.comm a
  = pullback-path→ ( α .Cube.left.comm a
                   , sym (Cube.top α a)
                   , un-square
                       (coe
                         (ap (λ p → Square _ p _ _) (sym (ap-sym k (lc a))))
                         (Hexagon.Square-compress-left
                          (tr
                           (λ p →
                             Hexagon (ap (Arrow-map.bot G) (Arrow-map.comm L a))
                                     (Arrow-map.comm G (Arrow-map.top L a))
                                     (ap k (lc a))
                                     p
                                     (ap (Arrow-map.bot R) (Arrow-map.comm F a))
                                     (Arrow-map.comm R (Arrow-map.top F a)))
                           (sym sym-sym)
                           (Cube.fill-hex α a)))))
}
%```

\subtree[stt-00BI]{
\taxon{Conjecture}

\p{This map is an equivalence.}
}
}

\subtree[stt-00BH]{
\taxon{Definition}
\title{Partially coherent retracts of squares}

\p{A fully coherent notion of retract for a cube #{\alpha : F \to G} involves a
lot of data:}

\ul{
\li{A cube #{\beta : G \to F}}
\li{A path of cubes #{\beta \alpha = 1} - which itself involves:
\ul{
\li{Paths #{\beta_{tl} \alpha_{tl} = 1}, for each corner of the squares}
\li{Such that the fillers of the resulting squares are also equal to #{1}}
\li{And the result of pasting the fillers of the whole cubes together results
in the filler of the identity cube.}
}
}
}

\p{Recall that a [cube induces a map of gap maps](stt-00BF). It follows that a retract
of cubes should induce a retract of [gap maps](stt-003L) (retracts are preserved by
all functors after all). In HoTT, a retract of maps contains extra coherence data,
namely that the squares paste together to form the identity; however, we also
define a notion of [incoherent retracts](stt-00BJ), which are enough for certain results
[such as the fact incoherent retracts preserve equivalence](stt-00BK). Correspondingly,
we define
a \strong{1-coherent} or \strong{partially coherent} retract of squares to be
a cube in the opposite direction, together with a retract of the top-left map
and a (fully-coherent) retract of the induced cospan map. We show that this data
induces an incoherent retract of the gap maps. Under the [above conjecture](stt-00BI),
we expect the type of 1-coherent cube retracts to be equivalent to the type
of incoherent retracts of gap maps (although this has not been formalised).}

%```agda
\agda{
1-coherent-retraction-cube
  : ∀ {𝓤 𝓥 𝓦 𝓧 𝓛 𝓜 𝓝 𝓞}
    {A : Type 𝓤} {B : Type 𝓥} {f : A → B}
    {C : Type 𝓦} {D : Type 𝓧} {g : C → D}
    {F : Arrow-map f g}
    {X : Type 𝓛} {Y : Type 𝓜} {h  : X → Y}
    {Z : Type 𝓝} {W : Type 𝓞} {k : Z → W}
    {G : Arrow-map h k}
  → Cube F G
  → Type (𝓤 ⊔ 𝓥 ⊔ 𝓦 ⊔ 𝓧 ⊔ 𝓛 ⊔ 𝓜 ⊔ 𝓝 ⊔ 𝓞)
1-coherent-retraction-cube {F = F} {G = G} α@(mk-cube L R p)
  = Σ[ β ∶ Cube G F ]
     (retraction-witness (Cube.topl α) (Cube.topl β)
      ×
     retraction-witness-cospan (cospan-map←cube α) (cospan-map←cube β))
}
%```

\proof{
The fact that the induced gap map square is a retract follows from the
fact that [pullbacks are functorial with respect to their cospan](stt-00BN).
}

%```agda
\agda{
gap-map-square-ret←cube-partial-ret
  : ∀ {𝓤 𝓥 𝓦 𝓧 𝓛 𝓜 𝓝 𝓞}
      {A : Type 𝓤} {B : Type 𝓥} {f : A → B}
      {C : Type 𝓦} {D : Type 𝓧} {g : C → D}
      (F : Arrow-map f g)
      {X : Type 𝓛} {Y : Type 𝓜} {h  : X → Y}
      {Z : Type 𝓝} {W : Type 𝓞} {k : Z → W}
      (G : Arrow-map h k)
    → (cube : Cube F G)
    → (ret : 1-coherent-retraction-cube cube)
    → incoherent-retraction-arrow-map (gap-map-square←cube F G cube)
gap-map-square-ret←cube-partial-ret {g = g} F G α (β , tlr , cspr)
  = (ret  , tlr ,  ret2) where
  open Cube
  ret : Arrow-map (gap-map←square G) (gap-map←square F)
  ret = gap-map-square←cube _ _ β


  ret-cspn : Pullback₁
            (cospan-map-compose (cospan-map←cube β) (cospan-map←cube α))
         ~ Pullback₁ (id-cospan-map)
  ret-cspn
    = happly
        (ap Pullback₁ {cospan-map-compose (cospan-map←cube β) _} {id-cospan-map}
          (ext! (cospan-retraction-is-cospan-retraction (cospan-map←cube α)
                                                  (cospan-map←cube β , cspr))))

  ret2 : retraction-witness
           (gap-map-square←cube _ _ α .Arrow-map.bot)
           (ret .Arrow-map.bot)
  ret2 = Pullback₁-∘ (cospan-map←cube β) (cospan-map←cube α)
       ~∙ ret-cspn
       ~∙ Pullback₁-id
}
%```
}

\subtree[stt-00BE]{
\title{Retracts of cartesian squares are cartesian}
\taxon{Corollary}

\p{Given a [1-coherent retract of squares](stt-00BH) #{F \hookrightarrow G}, if
#{G} is cartesian, then so is #{F}.}

\proof{This follows from the fact that [1-coherent retracts of squares induce
incoherent retracts of the respective gap maps](stt-00BH), and that [retracts of
equivalences are equivalences](stt-00BK)}


%```agda
\agda{
opaque
  is-cartesian←1-coherent-retraction-cube
    : ∀ {𝓤 𝓥 𝓦 𝓧 𝓛 𝓜 𝓝 𝓞}
        {A : Type 𝓤} {B : Type 𝓥} {f : A → B}
        {C : Type 𝓦} {D : Type 𝓧} {g : C → D}
        {F : Arrow-map f g}
        {X : Type 𝓛} {Y : Type 𝓜} {h  : X → Y}
        {Z : Type 𝓝} {W : Type 𝓞} {k : Z → W}
        {G : Arrow-map h k}
      → (cube : Cube F G)
      → 1-coherent-retraction-cube cube
      → is-cartesian G
      → is-cartesian F
  is-cartesian←1-coherent-retraction-cube α β gcart
    = is-cartesian←gap-is-equiv _
        (is-equiv←incoherent-retraction-equiv
          (gap-map-square←cube _ _ α)
          (gap-map-square-ret←cube-partial-ret _ _ α β)
          (gap-is-equiv←is-pullback _
            (is-pullback←is-cartesian _ gcart)))
}
%```
}

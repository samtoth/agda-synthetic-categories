\subtree[stt-00M5]{
\date{2026-03-28}
\author{fredrikbakke}
\taxon{Corollary}
\title{Pointed fibre criterion for connected maps with sections}

\p{
If a map #{f : A \to B} is equipped with a [section](stt-000H), then each fibre is
canonically pointed. In this case we can use the characterisation of pointed
connected types to obtain another characterisation of connectedness of #{f}.
Namely, #{f} is #{K}-connected if for every #{K}-valued family of pointed types #{U}
over #{B}, and every #{b : B}, the type of pointed maps
#{\Hom_{*}((\fibre{f}{b}, s(b)),U)} is contractible.
}

\agda{
module _
  {╬▒ ЁЭУд ЁЭУе} (K : gSubU ╬▒)
  {A : Type ЁЭУд} {B : Type ЁЭУе}
  (f : A тЖТ B)
  where

  pointed-up-connected-fibres
    : section f
    тЖТ Type╧Й
  pointed-up-connected-fibres (s , sec)
    = (b : B) тЖТ up-connectedтИЧ K (mk-typeтИЧ (fibre f b) (s b , sec b))

  up-connected-fibresтЖРpointed-up-connected-fibres
    : (╧Г : section f)
    тЖТ pointed-up-connected-fibres ╧Г
    тЖТ up-connected-fibres K f
  up-connected-fibresтЖРpointed-up-connected-fibres (s , sec) pconn b
    = up-connectedтЖРup-connectedтИЧ K (mk-typeтИЧ (fibre f b) (s b , sec b)) (pconn b)

  pointed-up-connected-fibresтЖРup-connected-fibres
    : (╧Г : section f)
    тЖТ up-connected-fibres K f
    тЖТ pointed-up-connected-fibres ╧Г
  pointed-up-connected-fibresтЖРup-connected-fibres (s , sec) fconn b
    = up-connectedтИЧтЖРup-connected K (mk-typeтИЧ (fibre f b) (s b , sec b)) (fconn b)

  up-connected-mapтЖРpointed-up-connected-fibres
    : (╧Г : section f)
    тЖТ pointed-up-connected-fibres ╧Г
    тЖТ up-connected-map K f
  up-connected-mapтЖРpointed-up-connected-fibres ╧Г pconn
    = up-connected-mapтЖРup-connected-fibres K f
        (up-connected-fibresтЖРpointed-up-connected-fibres ╧Г pconn)
}
}

\subtree[stt-00M7]{
\date{2026-03-19}
\author{fredrikbakke}
\taxon{Theorem}
\title{Reflectors of #{╬г}-closed reflective global subuniverses are connected}

\p{
Given a #{\Sigma}-closed reflective global subuniverse #{K} and a #{K}-reflector
#{\eta : A \to KA}, then #{\eta} is a #{K}-connected map.
}

\agda{
module gRSubUReflectorConnected {╬▒}
    (RS : gRSubU ╬▒)
    (S╬г : is-globally-╬г-closed (RS .gRSubU.GS)) where
  open gRSubU RS
  open gReflectiveClosure RS
  open gReflectiveReasoning RS
  open gRSubUInduction RS S╬г

  ╬╖-up-connected-map
    : тИА {ЁЭУд} {A : Type ЁЭУд}
      тЖТ up-connected-map GS (╬╖ {A = A})
  ╬╖-up-connected-map {A = A} {U = U} UтИИS
    = is-equivтБ╗┬╣ (ind-is-equiv UтИИS)

  ╬╖тИШ-connected-mapтЖРup-modal-equiv
    : тИА {ЁЭУд ЁЭУе} {A : Type ЁЭУд} {B : Type ЁЭУе}
        (f : A тЖТ B)
      тЖТ up-modal-equiv GS f
      тЖТ up-connected-map GS (╬╖ {A = B} тИШ f)
  ╬╖тИШ-connected-mapтЖРup-modal-equiv {A = A} {B = B} f feq {U = U} UтИИS
    = homotopy-is-equiv (╬╗ h тЖТ funextтЖТ ╬╗ a тЖТ (apс╢а h (тЧЛтВБ-╬▓ f a))) eqv where

    eqv
      : is-equiv
          ( postcomp-╬а (╬╗ a тЖТ tr U (тЧЛтВБ-╬▓ f a))
          тИШ precomp-╬а (U тИШ тЧЛтВБ f) ╬╖ тИШ precomp-╬а U (тЧЛтВБ f))
    eqv
      = is-equiv-тИШ
          (postcomp-╬а-equiv ╬╗ {a} тЖТ coe-is-equiv (ap U (тЧЛтВБ-╬▓ f a)))
          (is-equiv-тИШ
            (╬╖-up-connected-map (UтИИS тИШ тЧЛтВБ f))
            (precomp-╬а-is-equiv (is-modal-equivтЖРup-modal-equiv RS feq)))

  is-modal-equivтЖРup-connected-map
    : тИА {ЁЭУд ЁЭУе} {A : Type ЁЭУд} {B : Type ЁЭУе}
        (f : A тЖТ B)
      тЖТ up-connected-map GS f
      тЖТ is-modal-equiv RS f
  is-modal-equivтЖРup-connected-map f fconn
    = is-modal-equivтЖРup-modal-equiv RS
        (up-modal-equivтЖРup-connected-map GS f fconn)
}
}

\subtree[stt-00MI]{
\date{2026-03-19}
\author{fredrikbakke}
\taxon{Lemma}
\title{Connections between certain fibre conditions on a map with #{K}-reflections}

\agda{
module gReflectorFibres
    {╬▒ ЁЭУд ЁЭУе} {GS : gSubU ╬▒}
    {A : Type ЁЭУд} {B : Type ЁЭУе}
    (f : A тЖТ B)
    (Rf : (b : B) тЖТ gReflector GS (fibre f b)) where

  ╬╖-fibre-section
    : ╬а A (╬╗ a тЖТ gReflector.тЧЛ (Rf (f a)))
  ╬╖-fibre-section a = gReflector.╬╖ (Rf (f a)) (a , refl)

  fibre-local-centreтЖРover
    : (b : B)
    тЖТ null-homotopy
        (precomp-╬а-over-fibres (╬╗ b тЖТ gReflector.тЧЛ (Rf b)) f ╬╖-fibre-section b)
    тЖТ ╬г[ u тИ╢ gReflector.тЧЛ (Rf b) ]
        ((x : fibre f b) тЖТ u я╝Э gReflector.╬╖ (Rf b) x)
  fibre-local-centreтЖРover b (u , H)
    = u , ╬╗ where (a , refl) тЖТ H (a , refl)

  reflected-fibre-singletonтЖРlocal-centre
    : {b : B}
    тЖТ ╬г[ u тИ╢ gReflector.тЧЛ (Rf b) ]
        ((x : fibre f b) тЖТ u я╝Э gReflector.╬╖ (Rf b) x)
    тЖТ is-singleton (gReflector.тЧЛ (Rf b))
  reflected-fibre-singletonтЖРlocal-centre {b} (u , H)
    = mk-singl u (happly p) where
    module Fb = gReflector (Rf b)

    p : const Fb.тЧЛ Fb.тЧЛ u я╝Э id
    p = unap
          (is-embeddingтЖРis-equiv (Fb.reflects Fb.тЧЛтИИS))
          (funextтЖТ H)

  fibre-precomp-╬а-╬╖-fibreтЙГ╬а-local-centre-over
    : fibre (precomp-╬а (╬╗ b тЖТ gReflector.тЧЛ (Rf b)) f) ╬╖-fibre-section
    тЙГ ((b : B)
      тЖТ null-homotopy
          (precomp-╬а-over-fibres (╬╗ b тЖТ gReflector.тЧЛ (Rf b)) f
            ╬╖-fibre-section b))
  fibre-precomp-╬а-╬╖-fibreтЙГ╬а-local-centre-over
    = fibre-precomp-╬а-null-homotopyтЙГ
        (╬╗ b тЖТ gReflector.тЧЛ (Rf b)) f ╬╖-fibre-section

  merely-fibre-local-centreтЖРsurjective-precomp-╬а
    : (тИА {ЁЭУЪ} {U : B тЖТ Type ЁЭУЪ}
    тЖТ ((b : B) тЖТ U b тИИ gSubU.S GS)
    тЖТ is-surjective (precomp-╬а U f))
    тЖТ ((b : B)
    тЖТ тХС ╬г[ u тИ╢ gReflector.тЧЛ (Rf b) ]
        ((x : fibre f b) тЖТ u я╝Э gReflector.╬╖ (Rf b) x) тХС)
  merely-fibre-local-centreтЖРsurjective-precomp-╬а surj b
    = Trunc.тЧЛ-rec Trunc.тЧЛтИИS
        (Trunc.╬╖ тИШ fibre-local-centreтЖРover b тИШ ev b)
        (Trunc.тЧЛ-rec Trunc.тЧЛтИИS
          (Trunc.╬╖ тИШ fibre-precomp-╬а-╬╖-fibreтЙГ╬а-local-centre-over ._тЙГ_.fwd)
          (surj (╬╗ b тЖТ gReflector.тЧЛтИИS (Rf b)) ╬╖-fibre-section))
}
}

\subtree[stt-00MJ]{
\date{2026-03-19}
\author{fredrikbakke}
\taxon{Theorem}
\title{Fibre reflection conditions for #{K}-connected maps}

\agda{
module gReflectorConnectedCharacterisation
    {╬▒ ЁЭУд ЁЭУе} {GS : gSubU ╬▒}
    {A : Type ЁЭУд} {B : Type ЁЭУе}
    (f : A тЖТ B)
    (RЁЭЯЩ : gReflector GS ЁЭЯЩ)
    (тЧЛЁЭЯЩ-singleton : is-singleton (gReflector.тЧЛ RЁЭЯЩ))
    (Rf : (b : B) тЖТ gReflector GS (fibre f b)) where
  open gReflectorConnectedMaps f RЁЭЯЩ тЧЛЁЭЯЩ-singleton Rf
  open gReflectorFibres f Rf

  reflected-fibres-singletonтЖРmerely-local-centre
    : ((b : B)
    тЖТ тХС ╬г[ u тИ╢ gReflector.тЧЛ (Rf b) ]
          ((x : fibre f b) тЖТ u я╝Э gReflector.╬╖ (Rf b) x) тХС)
    тЖТ reflected-fibres-singleton
  reflected-fibres-singletonтЖРmerely-local-centre mere b
    = Trunc.тЧЛ-rec
        (is-truncatedтЖРis-prop is-single-is-prop)
        reflected-fibre-singletonтЖРlocal-centre
        (mere b)

  up-connected-!-fibreтЖРmerely-local-centre
    : ((b : B)
    тЖТ тХС ╬г[ u тИ╢ gReflector.тЧЛ (Rf b) ]
          ((x : fibre f b) тЖТ u я╝Э gReflector.╬╖ (Rf b) x) тХС)
    тЖТ up-connected-!-fibre GS f
  up-connected-!-fibreтЖРmerely-local-centre mere
    = up-connected-!-fibreтЖРreflected-fibres-singleton
        (reflected-fibres-singletonтЖРmerely-local-centre mere)

  up-connected-mapтЖРmerely-local-centre
    : ((b : B)
    тЖТ тХС ╬г[ u тИ╢ gReflector.тЧЛ (Rf b) ]
         ((x : fibre f b) тЖТ u я╝Э gReflector.╬╖ (Rf b) x) тХС)
    тЖТ up-connected-map GS f
  up-connected-mapтЖРmerely-local-centre mere
    = up-connected-mapтЖРfibre-terminal-equiv GS f
        (up-connected-!-fibreтЖРmerely-local-centre mere)

  up-connected-mapтЖРsurjective-precomp-╬а
    : (тИА {ЁЭУЪ} {U : B тЖТ Type ЁЭУЪ}
    тЖТ ((b : B) тЖТ U b тИИ gSubU.S GS)
    тЖТ is-surjective (precomp-╬а U f))
    тЖТ up-connected-map GS f
  up-connected-mapтЖРsurjective-precomp-╬а surj
    = up-connected-mapтЖРmerely-local-centre
        (merely-fibre-local-centreтЖРsurjective-precomp-╬а surj)
}
}

\subtree[stt-00M8]{
\date{2026-03-19}
\author{fredrikbakke}
\taxon{Corollary}
\title{Equivalent conditions for connected maps in reflective global subuniverses}

\agda{
module gRSubUConnectedCharacterisation {╬▒} (RS : gRSubU ╬▒) where
  open gRSubU RS
  open gReflectiveReasoning RS
  open gReflectiveClosure RS

  module _ {ЁЭУд ЁЭУе} {A : Type ЁЭУд} {B : Type ЁЭУе} (f : A тЖТ B) where
    module Ch = gReflectorConnectedCharacterisation

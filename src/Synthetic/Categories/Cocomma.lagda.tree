\subtree[stt-00CT]{
\title{Right cocones over a span}
\taxon{Definition}

\p{Given a [span diagram](stt-0015) #{S}, we consider the directed cocones over #{S}.
This is analogous to the type of [cocones over #{S}](stt-0016) but with the
filler now being a morphism, not a path. This dualises \ref{stt-00C1}}

\agda{
record directed-cocone {𝓤 𝓥 𝓦} (S : Span 𝓤 𝓥 𝓦) {𝓛} (Carrier : Type 𝓛)
  : Type (𝓘 ⊔ 𝓤 ⊔ 𝓥 ⊔ 𝓦 ⊔ 𝓛) where
  constructor mk-directed-cocone
  open Span S
  field
    i : Left → Carrier
    j : Right → Carrier
    filler : ∀ (a : Centre) → Hom Carrier (i (left a)) (j (right a))


unquoteDecl directed-cocone-repr≊ directed-cocone-repr≃
  = make-record-repr directed-cocone-repr≊ directed-cocone-repr≃ (quote directed-cocone)

directed-cocone-path
  : ∀ {𝓤 𝓥 𝓦} {S : Span 𝓤 𝓥 𝓦} {𝓛} {Carrier : Type 𝓛}
      (c c' : directed-cocone S Carrier) → Type (𝓘 ⊔ 𝓤 ⊔ 𝓥 ⊔ 𝓦 ⊔ 𝓛)
directed-cocone-path {S = S} c c'
  = Σ[ p ∶ c .i ~ c' .i ] Σ[ q ∶ c .j ~ c' .j ]
      (∀ a → Hom-pathᵈ (p (left a)) (q (right a)) (c .filler a) (c' .filler a))
  where
  open directed-cocone
  open Span S

opaque
  directed-cocone-path-is-torsorial
    : ∀ {𝓤 𝓥 𝓦} {S : Span 𝓤 𝓥 𝓦} {𝓛} {Carrier : Type 𝓛}
        (c : directed-cocone S Carrier) → is-singleton (Σ _ (directed-cocone-path c))
  directed-cocone-path-is-torsorial c
    = is-single←equiv-to-single (Σ-fst-≃ (directed-cocone-repr≃ e⁻¹))
        (is-singleton-structure←parts
          (SingS-is-single _)
          (_ , ~refl)
          (is-singleton-structure←parts
            (SingS-is-single _)
            (_ , ~refl)
            (is-single←equiv-to-single
              (Σ-Π-swap≃ _ λ a h → Hom-pathᵈ refl refl (c .directed-cocone.filler a) h)
              (Π-is-single (λ a
               → Hom-pathᵈ-is-torsorial)))))

directed-cocone-path-refl
  : ∀ {𝓤 𝓥 𝓦} {S : Span 𝓤 𝓥 𝓦} {𝓛} {Carrier : Type 𝓛}
      {c : directed-cocone S Carrier} → directed-cocone-path c c
directed-cocone-path-refl = (~refl , ~refl , λ a → Hom-pathᵈ-refl)

instance
  IdS-directed-cocone
    : ∀ {𝓤 𝓥 𝓦} {S : Span 𝓤 𝓥 𝓦} {𝓛} {Carrier : Type 𝓛}
      → Identity-system (directed-cocone S Carrier) (𝓘 ⊔ 𝓤 ⊔ 𝓥 ⊔ 𝓦 ⊔ 𝓛)
  IdS-directed-cocone .Identity-system.IdS = directed-cocone-path
  IdS-directed-cocone .Identity-system.IdS←Id refl = directed-cocone-path-refl
  IdS-directed-cocone .Identity-system.IdS←Id-is-equiv a
    = fundamental-Id _ (directed-cocone-path-is-torsorial a) _
}
}


\subtree[stt-00CU]{
\title{Cocomma cocones}
\taxon{Definition}

\p{Again analogously to undirected pushouts, for any directed cocone #{C}
over a span #{S}, we can define a canonical map #{(C \to Q) \to \mathrm{Cocone}_S(Q)}.
We call #{C} a (right) cocomma cone when this map is an equivalence.}

\agda{
module _ {𝓤 𝓥 𝓦} {S : Span 𝓤 𝓥 𝓦} {𝓛} {Carrier : Type 𝓛} where
  directed-cocone-map
    : directed-cocone S Carrier
    → ∀ {𝓠} {Q : Type 𝓠} → (Carrier → Q) → directed-cocone S Q
  directed-cocone-map cc f = mk-directed-cocone (f ∘ i) (f ∘ j) (ap-hom f ∘ filler) where
    open directed-cocone cc

  up-cocomma' : directed-cocone S Carrier → ∀ 𝓠 → Type (𝓘 ⊔ 𝓤 ⊔ 𝓥 ⊔ 𝓦 ⊔ 𝓛 ⊔ lsuc 𝓠)
  up-cocomma' cone 𝓠
    = {Q : Type 𝓠} → is-equiv (directed-cocone-map cone {𝓠} {Q})

  up-cocomma : directed-cocone S Carrier → Typeω
  up-cocomma cone
    = ∀ {𝓠} {Q : Type 𝓠} → is-equiv (directed-cocone-map cone {𝓠} {Q})
}
}

\subtree[stt-00CV]{
\title{Canonical cocomma types}
\taxon{Construction}

\p{The cocomma type of a [span diagram](stt-0015) is written
#{f \uparrow g}. If we had a notion of \em{directed} higher inductive
types, you might present it as the type generated by the following data:}

\ul{
\li{#{\iota_1 : A \to f \uparrow g}}
\li{#{\iota_2 : C \to f \uparrow g}}
\li{#{\mathit{gl} : \Pi_{b} \Hom_B(\iota_1(f(b)), \iota_2(g(b)))}}
}

\p{Whilst we don't have directed higher inductive types natively, we can
use [pushouts](stt-0017) to give an equivalent definition for cocomma types.}


\quiver{
    \begin{tikzcd}[cramped]
	{B\times\partial\Delta^1} && {A + C} \\
	\\
	{B \times \Delta^1} && \bullet
	\arrow["{\overline{[f,g]}}", from=1-1, to=1-3]
	\arrow[hook', from=1-1, to=3-1]
	\arrow[from=1-3, to=3-3]
	\arrow[from=3-1, to=3-3]
	\arrow["\lrcorner"{anchor=center, pos=0.125, rotate=180}, draw=none, from=3-3, to=1-1]
    \end{tikzcd}
}

\agda{
↑-span
  : ∀ {𝓤 𝓥 𝓦} {A : Type 𝓤} {B : Type 𝓥} {C : Type 𝓦}
      (f : B → A) (g : B → C)
    → Span (𝓘 ⊔ 𝓥) (𝓘 ⊔ 𝓥) (𝓤 ⊔ 𝓦)
↑-span {B = B} f g
  = mk-span _ (∂Δ¹-incl ⊗1 B)
              (uncurry (∂Δ¹-UP→ (inl ∘ f , inr ∘ g)))

_↑_ : ∀ {𝓤 𝓥 𝓦} {A : Type 𝓤} {B : Type 𝓥} {C : Type 𝓦}
        (f : B → A) (g : B → C) → Type (𝓘 ⊔ 𝓤 ⊔ 𝓥 ⊔ 𝓦)
_↑_ f g = Pushout (↑-span f g .Span.left) (↑-span f g .Span.right)

↑-ι₁ : ∀ {𝓤 𝓥 𝓦} {A : Type 𝓤} {B : Type 𝓥} {C : Type 𝓦}
         {f : B → A} {g : B → C} → A → f ↑ g
↑-ι₁ = ι₂ ∘ inl

↑-ι₂ : ∀ {𝓤 𝓥 𝓦} {A : Type 𝓤} {B : Type 𝓥} {C : Type 𝓦}
         {f : B → A} {g : B → C} → C → f ↑ g
↑-ι₂ = ι₂ ∘ inr

↑-hom : ∀ {𝓤 𝓥 𝓦} {A : Type 𝓤} {B : Type 𝓥} {C : Type 𝓦}
          {f : B → A} {g : B → C} b → Hom (f ↑ g) (↑-ι₁ (f b)) (↑-ι₂ (g b))
↑-hom b .Homᵈ.hom = ι₁ ∘ (_, b)
↑-hom b .Homᵈ.hom0 = glue (∂Δ¹-0 , b)
↑-hom b .Homᵈ.hom1 = glue (∂Δ¹-1 , b)

↑-cocone : ∀ {𝓤 𝓥 𝓦} {A : Type 𝓤} {B : Type 𝓥} {C : Type 𝓦}
             (f : B → A) (g : B → C) → directed-cocone (mk-span _ f g) (f ↑ g)
↑-cocone f g .directed-cocone.i = ↑-ι₁
↑-cocone f g .directed-cocone.j = ↑-ι₂
↑-cocone f g .directed-cocone.filler = ↑-hom

↑-up-cocomma
  : ∀ {𝓤 𝓥 𝓦} {A : Type 𝓤} {B : Type 𝓥} {C : Type 𝓦} {f : B → A} {g : B → C}
    → up-cocomma (↑-cocone f g)
↑-up-cocomma {f = f} {g = g} = is-equiv←qinv qinv where
  open directed-cocone
  qinv : quasi-inv (directed-cocone-map (↑-cocone f g))
  qinv .fst cone = pushout-rec
    (mk-cocone (uncurry (Homᵈ.hom ∘ cone .filler) ∘ ×-swap ._≃_.fwd)
               ⊎[ cone .i , cone .j ] λ
     { (∂Δ¹-1 ,  b) → filler cone b .Homᵈ.hom1
     ; (∂Δ¹-0 , b) → filler cone b .Homᵈ.hom0})
  qinv .snd .fst f = sym
    (funext→ (pushout-rec-unique _ _ ~refl
               (λ { (inl x) → refl
                  ; (inr x) → refl})
               λ { (∂Δ¹-1 , b) → ∙-reflr _
                 ; (∂Δ¹-0 , b) → ∙-reflr _}))
  qinv .snd .snd a = ext! (~refl , ~refl , λ b → Hom-pathᵈ←path
                            ( ~refl
                            , sym (pushout-rec-apβ _)
                            , sym (pushout-rec-apβ _)))

↑-rec : ∀ {𝓤 𝓥 𝓦} {S : Span 𝓤 𝓥 𝓦} {𝓠} {Q : Type 𝓠}
        → let open Span S
        in directed-cocone S Q → (left ↑ right → Q)
↑-rec = is-equiv.bwd (↑-up-cocomma)

↑-rec-unique
  : ∀ {𝓤 𝓥 𝓦} {S : Span 𝓤 𝓥 𝓦} {𝓠} {Q : Type 𝓠}
      {c : directed-cocone S Q} {f : Span.left S ↑ Span.right S → Q}
    → IdS (directed-cocone-map (↑-cocone (Span.left S) (Span.right S)) f) c
    → f ~ ↑-rec c
↑-rec-unique (p , q , r) = pushout-rec-unique _ _
  (λ (i , c) → r c .fst i)
  (λ { (inl x) → p x
     ; (inr x) → q x })
  λ { (∂Δ¹-1 , c) → sym (un-square (r c .snd .snd))
    ; (∂Δ¹-0 , c) → sym (un-square (r c .snd .fst))}

↑-UP≃
  : ∀ {𝓤 𝓥 𝓦} {S : Span 𝓤 𝓥 𝓦} {𝓠} {Q : Type 𝓠}
    → (Span.left S ↑ Span.right S → Q) ≃ directed-cocone S Q
↑-UP≃ = mk≃ (directed-cocone-map _) ↑-up-cocomma
}
}

\subtree[stt-00CW]{
\title{Directed join}
\taxon{Example}

\p{An example of a comma type is the \em{directed join} of a pair of types.
This is sometimes also called the \em{blunt join}.}

\p{The interval is the join #{1 \bjoin 1}.}

\agda{
◇-span
  : ∀ {𝓤 𝓥} (A : Type 𝓤) (B : Type 𝓥)
    → Span (𝓘 ⊔ 𝓤 ⊔ 𝓥) (𝓘 ⊔ 𝓤 ⊔ 𝓥) (𝓤 ⊔ 𝓥)
◇-span A B = ↑-span {B = A × B} fst snd

_◇_ : ∀ {𝓤 𝓥} → Type 𝓤 → Type 𝓥 → Type (𝓘 ⊔ 𝓤 ⊔ 𝓥)
A ◇ B = _↑_ {B = A × B} fst snd

Δ¹-is-join : up-cocomma {S = mk-span (𝟙 × 𝟙) fst snd}
               (mk-directed-cocone (point i0) (point i1) λ _ → 0≤1)
Δ¹-is-join = is-equiv←qinv qinv where
  qinv : quasi-inv _
  qinv .fst cc = cc .directed-cocone.filler _ .Homᵈ.hom
  qinv .snd .fst = ~refl
  qinv .snd .snd cc
    = ext! ((λ _ → hom0) , (λ _ → hom1)
           , λ _
             → ( ~refl
               , (Square-flatten-hor refl) , Square-flatten-hor refl)) where
    open directed-cocone cc
    open Homᵈ (filler _)

_▻ : ∀ {𝓤} → Type 𝓤 → Type (𝓘 ⊔ 𝓤)
A ▻ = A ◇ 𝟙

▻-span : ∀ {𝓤} (A : Type 𝓤) → Span (𝓘 ⊔ 𝓤) (𝓘 ⊔ 𝓤) 𝓤
▻-span A = ◇-span A 𝟙

_◅ : ∀ {𝓤} → Type 𝓤 → Type (𝓘 ⊔ 𝓤)
A ◅ = 𝟙 ◇ A

◅-span : ∀ {𝓤} (A : Type 𝓤) → Span (𝓘 ⊔ 𝓤) (𝓘 ⊔ 𝓤) 𝓤
◅-span A = ◇-span 𝟙 A
}
}

\subtree[stt-00CX]{
\title{Functoriality of the directed join}
\taxon{Construction}

\agda{
_◇₁_
  : ∀ {𝓤 𝓥 𝓦 𝓜}
      {A : Type 𝓤} {B : Type 𝓥} (f : A → B)
      {C : Type 𝓦} {D : Type 𝓜} (g : C → D)
    → A ◇ C → B ◇ D
f ◇₁ g = ↑-rec (mk-directed-cocone (↑-ι₁ ∘ f) (↑-ι₂ ∘ g) (↑-hom ∘ (f ⊗ g)))

◇₁-id
  : ∀ {𝓤 𝓥} {A : Type 𝓤}  {B : Type 𝓥}
    → id ◇₁ id ~ id: (A ◇ A)
◇₁-id = sym ∘ ↑-rec-unique
  ( ~refl
  , ~refl
  , λ _ → Hom-pathᵈ←path (~refl , sym (ap-id _) , sym (ap-id _)))

◇₁-∘
  : ∀ {𝓤 𝓥 𝓦 𝓜 𝓝 𝓛}
      {A : Type 𝓤}  {B : Type 𝓥} {C : Type 𝓦}
      {D : Type 𝓜} {E : Type 𝓝} {F : Type 𝓛}
      (f : B → C) (g : A → B) (h : E → F) (j : D → E)
    → (f ∘ g) ◇₁ (h ∘ j) ~ (f ◇₁ h) ∘ (g ◇₁ j)
◇₁-∘ f g h j = sym ∘ ↑-rec-unique
  ( ~refl
  , ~refl
  , λ (a , d) → Hom-pathᵈ←path
     ( ~refl
     , sym (ap-∘ _ _ _ ∙ ap (ap _) (pushout-rec-apβ _) ∙ pushout-rec-apβ _)
     , sym (ap-∘ _ _ _ ∙ ap (ap _) (pushout-rec-apβ _) ∙ pushout-rec-apβ _)))
}
}

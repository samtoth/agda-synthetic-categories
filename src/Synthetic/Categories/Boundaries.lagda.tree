\date{2025-12-18}
\title{The boundary of simplices}
\author{samueltoth}
\taxon{Module}
\import{stt-macros}

%```agda
\agda{
open import Foundations.Prelude
open import Algebra.Lattice

module Synthetic.Categories.Boundaries
  {рқ“ҳ} (О”В№ : Type рқ“ҳ) (I : Lattice О”В№) (I-distr : is-distributive I)
  where

open import ufAxioms

open Lattice I renaming (0l to i0; 1l to i1)
import Algebra.Lattice.Instances.Polynomial as Poly
open Poly  hiding (L[x]; О”ВІ)
open is-distributive I-distr

private
  О”ВІ = Poly.О”ВІ I
  I[x] = Poly.L[x] I


open import Synthetic.Hom О”В№ i0 i1
open import Synthetic.Cubes О”В№ i0 i1
open import Synthetic.Categories.Horns О”В№ I I-distr

open import Ergonomics.Extensionality

open import Modalities.Instances.Truncation

open import Data.Bool

open import Core.CanonicalPushouts
open import Core.Join
open import Core.FlatteningPushouts
open import Core.FunctorialPushout
open import Core.SpanMap
}
%```

\subtree[stt-00CK]{
\title{Boundary of the interval}
\taxon{Definition}

\p{The boundary of the interval (#{\Delta^1}) is just the type of Booleans. For
the sake of uniformity, we lift it into the same universe that the interval
lives in. We define the inclusion #{\delta\Delta^1 \to \Delta^1} and show that
it is an embedding exactly when the lattice of the interval #{I} is non-trivial.}

%```agda
\agda{
вҲӮО”В№ : Type рқ“ҳ
вҲӮО”В№ = ULift _ Bool

вҲӮО”В№-0 вҲӮО”В№-1 : вҲӮО”В№
вҲӮО”В№-0 = mk-lift false
вҲӮО”В№-1 = mk-lift true

make-вҲӮО”В№ : вҲҖ {рқ“Ө} {A : Type рқ“Ө} вҶ’ A вҶ’ A вҶ’ вҲӮО”В№ вҶ’ A
make-вҲӮО”В№ a b (mk-lift true) = a
make-вҲӮО”В№ a b (mk-lift false) = b

вҲӮО”В№-UPвҶ’ : вҲҖ {рқ“Ө} {A : вҲӮО”В№ вҶ’ Type рқ“Ө} вҶ’ (A вҲӮО”В№-0 Г— A вҲӮО”В№-1) вҶ’ О  _ A
вҲӮО”В№-UPвҶ’ x (mk-lift false) = x .fst
вҲӮО”В№-UPвҶ’ x (mk-lift true)  = x .snd

вҲӮО”В№-UP : вҲҖ {рқ“Ө} {A : вҲӮО”В№ вҶ’ Type рқ“Ө} вҶ’ (A вҲӮО”В№-0 Г— A вҲӮО”В№-1) вүғ О  _ A
вҲӮО”В№-UP = mkвүғ вҲӮО”В№-UPвҶ’ (is-equivвҶҗqiso ((О» x вҶ’ (x вҲӮО”В№-0 , x вҲӮО”В№-1))
                                    , ~refl
                                    , (О» f вҶ’ funextвҶ’ (вҲӮО”В№-UPвҶ’ (refl , refl)))))

вҲӮО”В№-incl : вҲӮО”В№ вҶ’ О”В№
вҲӮО”В№-incl (mk-lift false) = i0
вҲӮО”В№-incl (mk-lift true) = i1

вҲӮО”В№-embeds : ((i0 пјқ i1) вҶ’ вҲ…) вҶ’ is-embedding (вҲӮО”В№-incl)
вҲӮО”В№-embeds nt = is-equivвҶҗinverse
                  (is-setвҶҗis-truncated
                      (ULift-is-truncated
                           (is-truncatedвҶҗis-set Bool-is-set)) _ _)
                  (is-setвҶҗis-truncated car-is-2-truncated _ _) map where
  map : вҲҖ {x y} вҶ’ вҲӮО”В№-incl x пјқ вҲӮО”В№-incl y вҶ’ x пјқ y
  map {mk-lift true} {mk-lift true} _ = refl
  map {mk-lift true} {mk-lift false} p = ВЎ (nt (sym p))
  map {mk-lift false} {mk-lift true} p = ВЎ (nt p)
  map {mk-lift false} {mk-lift false} _ = refl

вҲӮОӣ[2,1]-incl : вҲӮО”В№ вҶ’ Оӣ[2,1]
вҲӮОӣ[2,1]-incl (mk-lift false) = О№вӮҒ i0
вҲӮОӣ[2,1]-incl (mk-lift true ) = О№вӮӮ i1
}
%```
}

\subtree[stt-00CR]{
\title{Boundary of the 2-simplex}
\taxon{Definition}

\p{We define the boundary of the 2 simplex by glueing an interval along the
endpoints of the inner horn. (This reflects it's typical use as in connection
to the [Segal condition](stt-00AI) of precategories)}


\p{We show that there is an embedding #{\delta\Delta^2 \to \Delta^2} which
identifies this boundary with the subtype of #{(i,j) : \Delta^2} where
#{i = 1 \lor j = 0 \lor i = j}.}


%```agda
\agda{
вҲӮО”ВІ : Type рқ“ҳ
вҲӮО”ВІ = Pushout {A = вҲӮО”В№} {B = Оӣ[2,1]} {C = О”В№} вҲӮОӣ[2,1]-incl вҲӮО”В№-incl

вҲӮО”ВІ-О”ВІ-cocone : Cocone (mk-span _ вҲӮОӣ[2,1]-incl вҲӮО”В№-incl) О”ВІ
вҲӮО”ВІ-О”ВІ-cocone = (mk-cocone Оӣ[2,1]-incl О”ВІ-diagonal О» where
                         (mk-lift true) вҶ’ О”ВІ-refl
                         (mk-lift false) вҶ’ О”ВІ-refl)

вҲӮО”ВІ-incl : вҲӮО”ВІ вҶ’ О”ВІ
вҲӮО”ВІ-incl = pushout-rec вҲӮО”ВІ-О”ВІ-cocone

вҲӮО”ВІвҶҗОӣ[2,1] : Оӣ[2,1] вҶ’ вҲӮО”ВІ
вҲӮО”ВІвҶҗОӣ[2,1] = О№вӮҒ

вҲӮвҲӮОӣ[2,1]-incl : О”ВІ-diagonal вҲҳ вҲӮО”В№-incl ~ Оӣ[2,1]-incl вҲҳ вҲӮОӣ[2,1]-incl
вҲӮвҲӮОӣ[2,1]-incl (mk-lift true) = О”ВІ-refl
вҲӮвҲӮОӣ[2,1]-incl (mk-lift false) = О”ВІ-refl

вҲӮО”ВІ-sub : Subtype О”ВІ рқ“ҳ
вҲӮО”ВІ-sub .Subtype.family t@(i , j) = (t вҲҲ Оӣ[2,1]Sub) * (j пјқ i)
вҲӮО”ВІ-sub .Subtype.has-is-subtype a@(i , j)
  = *-is-prop (вҲҲ-is-prop Оӣ[2,1]Sub a) (is-prop-separated _ _)

вҲӮО”ВІ-as-subtype : (i0 пјқ i1 вҶ’ вҲ…) вҶ’ вҲҖ a вҶ’ fibre вҲӮО”ВІ-incl a вүғ a вҲҲ вҲӮО”ВІ-sub
вҲӮО”ВІ-as-subtype non-triv a@(i , j)
  = fibre вҲӮО”ВІ-incl a вүғвҹЁ cogap-fibre _ a вҹ©
    Pushout (total-fibre-span .left) (total-fibre-span .right)
        вүғвҹЁ Pushout-equivвҶҗlogical total-span-is-prop intended-span-is-prop sle вҹ©
    Pushout (intended-span .left) (intended-span .right)
                              вүғвҹЁвҹ©
    (a вҲҲ вҲӮО”ВІ-sub)             вүғвҲҺ where
  open Span

  total-fibre-span : Span рқ“ҳ рқ“ҳ рқ“ҳ
  total-fibre-span = total-span вҲӮОӣ[2,1]-incl вҲӮО”В№-incl
                                (Fibre-family вҲӮО”ВІ-О”ВІ-cocone a)

  intended-span : Span рқ“ҳ рқ“ҳ рқ“ҳ
  intended-span = mk-span ((a вҲҲ Оӣ[2,1]Sub) Г— (j пјқ i)) fst snd

  intended-span-is-prop : is-prop-span intended-span
  intended-span-is-prop .fst = вҲҲ-is-prop Оӣ[2,1]Sub (i , j)
  intended-span-is-prop .snd .fst
    = is-prop-ОЈ (вҲҲ-is-prop Оӣ[2,1]Sub (i , j)) О» _ вҶ’ is-prop-separated _ _
  intended-span-is-prop .snd .snd = is-prop-separated _ _

  total-fibre-span' : Span рқ“ҳ рқ“ҳ рқ“ҳ
  total-fibre-span' = mk-span (fibre (О”ВІ-diagonal вҲҳ вҲӮО”В№-incl) (i , j))
                              {Left = fibre Оӣ[2,1]-incl (i , j)}
                              _
                              {Right = fibre О”ВІ-diagonal (i , j)}
                              (total-map-fst вҲӮО”В№-incl)

  _ : total-fibre-span пјқ total-fibre-span'
  _ = refl

  total-span-is-prop : is-prop-span total-fibre-span
  total-span-is-prop .fst = Оӣ[2,1]-is-prop-map (i , j)
  total-span-is-prop .snd .fst
    = is-prop-mapвҶҗis-embedding
        (is-embedding-вҲҳ О”ВІ-diagonal-is-embedding (вҲӮО”В№-embeds non-triv))
        (i , j)
  total-span-is-prop .snd .snd
    = is-prop-mapвҶҗis-embedding О”ВІ-diagonal-is-embedding (i , j)


  sle : Span-logical-equiv total-fibre-span intended-span
  sle .fst = logicalвҶҗequiv (Оӣ[2,1]-as-subtype (i , j))
  sle .snd .fst .fst (mk-lift true , refl) = (О№вӮӮ refl , refl)
  sle .snd .fst .fst (mk-lift false , refl) = (О№вӮҒ refl , refl)
  sle .snd .fst .snd (x , refl)
    = pushout-rec (mk-cocone (О» where refl вҶ’ (вҲӮО”В№-0 , О”ВІ-refl))
                             (О» where refl вҶ’ (вҲӮО”В№-1 , О”ВІ-refl))
                             (О» (p , q) вҶ’ ВЎ (non-triv (p вҲҷ sym q)))) x
  sle .snd .snd .fst (x , refl) = refl
  sle .snd .snd .snd refl = (i , О”ВІ-refl)

вҲӮО”ВІвүғSub : (i0 пјқ i1 вҶ’ вҲ…) вҶ’ вҲӮО”ВІ вүғ Subtype.ОЈМғ вҲӮО”ВІ-sub
вҲӮО”ВІвүғSub nt
  = вҲӮО”ВІ                               вүғвҹЁ totalвүғtotal-fibre вҲӮО”ВІ-incl eвҒ»В№ вҹ©
    total-fibre вҲӮО”ВІ-incl              вүғвҹЁвҹ©
    (ОЈ[ a вҲ¶ О”ВІ ] fibre вҲӮО”ВІ-incl a)    вүғвҹЁ ОЈ-ap-вүғ (вҲӮО”ВІ-as-subtype nt) вҹ©
    (ОЈ[ a вҲ¶ О”ВІ ] (a вҲҲ вҲӮО”ВІ-sub))       вүғвҹЁвҹ©
    Subtype.ОЈМғ вҲӮО”ВІ-sub                 вүғвҲҺ

make-вҲӮО”ВІ : вҲҖ {рқ“Ө} {A : Type рқ“Ө} {x y z}
          вҶ’ Hom A y z вҶ’ Hom A x y вҶ’ Hom A x z
          вҶ’ вҲӮО”ВІ вҶ’ A
make-вҲӮО”ВІ f@(mk-hom fh f0 f1) g@(mk-hom gh g0 g1) h@(mk-hom hh h0 h1)
  = pushout-rec (mk-cocone (make-horn f g) (h .HomбөҲ.hom) О» where
                               (mk-lift false) вҶ’ g0 вҲҷ sym h0
                               (mk-lift true ) вҶ’ f1 вҲҷ sym h1)
}
%```
}


\subtree[stt-00CP]{
\title{Boundaries of squares}
\taxon{Definition}

\p{We define the boundary of a square by glueing a pair of horns together.}

%```agda
\agda{
вҲӮв–ЎВІ : Type рқ“ҳ
вҲӮв–ЎВІ = Pushout вҲӮОӣ[2,1]-incl вҲӮОӣ[2,1]-incl

вҲӮв–ЎВІ-incl : вҲӮв–ЎВІ вҶ’ в–Ў^ 2
вҲӮв–ЎВІ-incl
  = cogap (mk-cocone ((О» (x , y) вҶ’ x , y) вҲҳ Оӣ[2,1]-incl)
                     ((О» (x , y) вҶ’ y , x) вҲҳ Оӣ[2,1]-incl)
                     О» { (mk-lift true)  вҶ’ refl
                       ; (mk-lift false) вҶ’ refl})

вҲӮв–ЎВІ-Sub : Subtype (в–Ў^ 2) рқ“ҳ
вҲӮв–ЎВІ-Sub .Subtype.family (i , j) = ((i0 пјқ j) * (i1 пјқ i)) Г— ((i0 пјқ i) * (i1 пјқ j))
вҲӮв–ЎВІ-Sub .Subtype.has-is-subtype _
  = is-prop-ОЈ
      (*-is-prop
        (is-prop-separated _ _)
        (is-prop-separated _ _))
      (О» _ вҶ’
       *-is-prop
        (is-prop-separated _ _)
        (is-prop-separated _ _))

mk-вҲӮв–ЎВІ : вҲҖ {рқ“Ө} {A : Type рқ“Ө} {x y z w}
         вҶ’ Hom A x y вҶ’ Hom A y z вҶ’ Hom A x w вҶ’ Hom A w z
         вҶ’ (вҲӮв–ЎВІ вҶ’ A)
mk-вҲӮв–ЎВІ f g h k = cogap (mk-cocone (make-horn g f) (make-horn k h)
                        О» { (mk-lift true)  вҶ’ HomбөҲ.hom1 g вҲҷ sym (HomбөҲ.hom1 k)
                          ; (mk-lift false) вҶ’ HomбөҲ.hom0 f вҲҷ sym (HomбөҲ.hom0 h) })
  where open HomбөҲ
}
%```
}

\subtree[fre-9C37]{
\title{Hom types as extension types}
\taxon{Proposition}
\author{fredrikbakke}
\date{2026-03-31}

\p{
Synthetic hom types can be presented as extension types along the inclusion of
the boundary of the interval.
}

%```agda
\agda{
HomвүғExt-вҲӮО”В№-incl
  : вҲҖ {рқ“Ө} {A : Type рқ“Ө} {a b : A}
  вҶ’ Hom A a b вүғ Ext вҲӮО”В№-incl (make-вҲӮО”В№ b a)
HomвүғExt-вҲӮО”В№-incl {A = A} {a} {b}
  = Hom A a b
      вүғвҹЁ HomбөҲ-reprвүғ вҹ©
    ОЈ[ f вҲ¶ (О”В№ вҶ’ A) ] ((f i0 пјқ a) Г— (f i1 пјқ b))
      вүғвҹЁ ОЈ-ap-вүғ (О» f вҶ’ вҲӮО”В№-UP) вҹ©
    ОЈ[ f вҲ¶ (О”В№ вҶ’ A) ] (f вҲҳ вҲӮО”В№-incl ~ make-вҲӮО”В№ b a)
      вүғвҹЁвҹ©
    Ext вҲӮО”В№-incl (make-вҲӮО”В№ b a) вүғвҲҺ
}
%```
}

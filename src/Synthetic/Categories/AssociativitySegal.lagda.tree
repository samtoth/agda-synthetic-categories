      composite-square-bottom i1 вҲҷ f .HomбөҲ.hom1 вҲҺ
    where
      p-bot = О”ВІ-ext (0-bottom , вҲ§-comm вҲҷ 0-init)
      p-tgt = О”ВІ-ext (вҲЁ-comm вҲҷ 1-coinit , вҲ§-comm вҲҷ 1-top)

  composite-square-sourceпјқbottom-i0
    : composite-square-source i0
    пјқ composite-square-bottom i0
  composite-square-sourceпјқbottom-i0
    = ap (_вҲҷ K .snd (О№вӮҒ (О№вӮҒ i0))) (ap (ap (K .fst)) (О”ВІ-is-set _ _ p-src p-bot))
    where
      p-src = О”ВІ-ext (вҲЁ-comm вҲҷ 0-bottom , 0-init)
      p-bot = О”ВІ-ext (0-bottom , вҲ§-comm вҲҷ 0-init)

  composite-square-targetпјқright-i1
    : composite-square-target i1
    пјқ composite-square-right i1
  composite-square-targetпјқright-i1
    = ap (_вҲҷ K .snd (О№вӮҒ (О№вӮӮ i1))) (ap (ap (K .fst)) (О”ВІ-is-set _ _ p-tgt p-right))
    where
      p-tgt = О”ВІ-ext (вҲЁ-comm вҲҷ 1-coinit , вҲ§-comm вҲҷ 1-top)

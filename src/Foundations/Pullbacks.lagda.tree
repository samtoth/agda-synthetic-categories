\subtree[stt-003I]{
\taxon{Definition}
\title{Universal property of pullbacks}

\p{
  Given a cospan of types #{B \xrightarrow{f} A \xleftarrow{g} C}, we say that a cone
  over the cospan satisfies the universal property of its pullback when it is the
  \em{universal} such cone. Spelling this
  out as a diagram:
}

  \quiver{
  \begin{tikzcd}
        Q \\
	& D && C \\
	\\
	& B && A
	\arrow[dashed, from=1-1, to=2-2]
	\arrow["p", bend left, from=1-1, to=2-4]
	\arrow["q"', bend right, from=1-1, to=4-2]
	\arrow[from=2-2, to=2-4]
	\arrow[from=2-2, to=4-2]
	\arrow["\lrcorner"{anchor=center, pos=0.125}, draw=none, from=2-2, to=4-4]
	\arrow["g", from=2-4, to=4-4]
	\arrow["f"', from=4-2, to=4-4]
  \end{tikzcd}
  }

  \p{Given a particular span #{S}, #{S}-cone with centre #{D} and any other type #{Q},
     we can define a map #{(Q \to D) \to \textrm{Cone}_S(Q)} by post-composition.}

\agda{
cone-map
  : вҲҖ {рқ“Ө рқ“Ҙ рқ“Ұ рқ“ӣ рқ“ } (S : Cospan рқ“Ө рқ“Ҙ рқ“Ұ)
    вҶ’ {D : Type рқ“ӣ} вҶ’ (C : Cone S D)
    вҶ’ {Q : Type рқ“ } вҶ’ (Q вҶ’ D)
    вҶ’ Cone S Q
cone-map S C f = mk-cone (i вҲҳ f) (j вҲҳ f) (filler в–ё f) where open Cone C

module _ {рқ“Ө рқ“Ҙ рқ“Ұ} (S : Cospan рқ“Ө рқ“Ҙ рқ“Ұ) where
  open Cospan S

  cone-reprвүғ
    : {рқ“ӣ : Level} {D : Type рқ“ӣ}
    вҶ’ Cone S D
    вүғ ОЈ[ i вҲ¶ (D вҶ’ Left) ] ОЈ[ j вҲ¶ (D вҶ’ Right) ] (left вҲҳ i ~ right вҲҳ j)
  cone-reprвүғ = mkвүғ
    (О» (mk-cone i j filler) вҶ’ i , j , filler)
    (mk-eqv ((О» (i , j , filler) вҶ’ mk-cone i j filler) , ~refl , ~refl) ~refl)
}

\p{We use the abbreviation \code{up} for "universal property".}

\agda{
up-pullback'
  : вҲҖ {рқ“Ө рқ“Ҙ рқ“Ұ рқ“ң} (S : Cospan рқ“Ө рқ“Ҙ рқ“Ұ)
    вҶ’ {D : Type рқ“ң} вҶ’ (C : Cone S D)
    вҶ’ (рқ“  : Level)
    вҶ’ Type (lsuc (рқ“Ө вҠ” рқ“Ҙ вҠ” рқ“Ұ вҠ” рқ“ ) вҠ” рқ“ң)
up-pullback' S C рқ“  = вҲҖ {Q : Type рқ“ } вҶ’ is-equiv (cone-map S C {Q})

record up-pullback {рқ“Ө рқ“Ҙ рқ“Ұ рқ“ӣ} (S : Cospan рқ“Ө рқ“Ҙ рқ“Ұ)
                    {D : Type рқ“ӣ} (C : Cone S D)
               : TypeПү where
  constructor mk-up-pullback
  field
    cone-map-is-equiv :  вҲҖ {рқ“ } (Q : Type рқ“ ) вҶ’ is-equiv (cone-map S C {Q})

  rec : вҲҖ {рқ“ } {Q : Type рқ“ } вҶ’ Cone S Q вҶ’ (Q вҶ’ D)
  rec {Q = Q} = is-equiv.bwd (cone-map-is-equiv Q)

  rec-ОІвӮҒ
    : вҲҖ {рқ“ } {Q : Type рқ“ } {C' : Cone S Q}
      вҶ’ C .Cone.i вҲҳ rec {рқ“ } {Q} C' пјқ C' .Cone.i
  rec-ОІвӮҒ {Q = Q} {C'} = ap Cone.i (is-equiv.Оө (cone-map-is-equiv Q) C')

  rec-ОІвӮӮ
    : вҲҖ {рқ“ } {Q : Type рқ“ } {C' : Cone S Q}
      вҶ’ C .Cone.j вҲҳ rec {рқ“ } {Q} C' пјқ C' .Cone.j
  rec-ОІвӮӮ {Q = Q} {C'} = ap Cone.j (is-equiv.Оө (cone-map-is-equiv Q) C')
}
}

\subtree[stt-00GN]{
\date{2026-03-10}
\author{fredrikbakke}
\title{A precomposition criterion for pullbacks}
\taxon{Lemma}

\p{
Given a cospan #{f : A \to B \leftarrow C : g} and a map #{u : X \to Y} such that
#{A^u} and #{C^u} are equivalences, and its right whiskering map #{{-}\mathbin{в–ё} h}
is an equivalence, then the cone map induced by #{u}
##{\textrm{Cone}((f,g),Y) \to \textrm{Cone}((f,g),X)}
is an equivalence.
}

\agda{
module _
  {рқ“Ө рқ“Ҙ рқ“Ұ рқ“ӣ рқ“ң : Level}
  (S : Cospan рқ“Ө рқ“Ҙ рқ“Ұ)
  {X : Type рқ“ӣ} {Y : Type рқ“ң}
  where

  cone-map-is-equiv
    : (u : X вҶ’ Y)
    вҶ’ is-equiv (precomp (Cospan.Left S) u)
    вҶ’ is-equiv (precomp (Cospan.Right S) u)
    вҶ’ ((i : Y вҶ’ Cospan.Left S) (j : Y вҶ’ Cospan.Right S) вҶ’ is-equiv (_в–ё u))
    вҶ’ is-equiv (О» (c : Cone S Y) вҶ’ cone-map S c u)
  cone-map-is-equiv u leq req heq
    = is-equiv-вҲҳ
        (bwd-is-equiv (cone-reprвүғ S))
        (is-equiv-вҲҳ
          (_вүғ_.fwd-is-equiv repr-precomp-equiv)
          (_вүғ_.fwd-is-equiv (cone-reprвүғ S))) where
    open Cospan S

    repr-precomp-equiv
      : ОЈ[ i вҲ¶ (Y вҶ’ Left) ] ОЈ[ j вҲ¶ (Y вҶ’ Right) ] (left вҲҳ i ~ right вҲҳ j)
      вүғ ОЈ[ i вҲ¶ (X вҶ’ Left) ] ОЈ[ j вҲ¶ (X вҶ’ Right) ] (left вҲҳ i ~ right вҲҳ j)
    repr-precomp-equiv
      = ОЈ[ i вҲ¶ (Y вҶ’ Left) ] ОЈ[ j вҲ¶ (Y вҶ’ Right) ] (left вҲҳ i ~ right вҲҳ j)
          вүғвҹЁ ОЈ-snd-вүғ
              ( О» i
                вҶ’ ОЈ-snd-вүғ (О» j вҶ’ mkвүғ (_в–ё u) (heq i j))
                вҲҷe ОЈ-fst-вүғ (mkвүғ (precomp Right u) req)) вҹ©
        ОЈ[ i вҲ¶ (Y вҶ’ Left) ] ОЈ[ j вҲ¶ (X вҶ’ Right) ] (left вҲҳ i вҲҳ u ~ right вҲҳ j)
          вүғвҹЁ ОЈ-fst-вүғ (mkвүғ (precomp Left u) leq) вҹ©
        ОЈ[ i вҲ¶ (X вҶ’ Left) ] ОЈ[ j вҲ¶ (X вҶ’ Right) ] ( left вҲҳ i ~ right вҲҳ j)
          вүғвҲҺ

  precomp-is-equivвҶҗcone-precomp-is-equiv
    : (u : X вҶ’ Y)
      (C : Cone S X)
    вҶ’ up-pullback S C
    вҶ’ is-equiv (О» (C' : Cone S Y) вҶ’ cone-map S C' u)
    вҶ’ is-equiv (precomp X u)
  precomp-is-equivвҶҗcone-precomp-is-equiv u C pb ceq
    = 3-for-2
        (pb .up-pullback.cone-map-is-equiv X)
        (is-equiv-вҲҳ ceq (pb .up-pullback.cone-map-is-equiv Y))
}
}



\subtree[stt-006K]{
\date{2025-06-26}
\title{Identity types are pullbacks}
\taxon{Example}

\agda{
Identity-pullback
  : вҲҖ {рқ“Ө} {A : Type рқ“Ө} {x y : A}
    вҶ’ up-pullback
        (mk-cospan _ (point x) (point y))
        (mk-cone ! ! id)
Identity-pullback = mk-up-pullback О» Q вҶ’ is-equivвҶҗqinv О» where
  .fst (mk-cone i j filler) q вҶ’ filler q
  .snd .fst a вҶ’ refl
  .snd .snd (mk-cone i j filler) вҶ’ refl
}
}

\subtree[stt-002S]{
\taxon{Definition}
\title{Joins of types}

\p{The join of types #{A} and #{B}, written #{A * B} is
the pushout of the span
#{A \xleftarrow{\pi_1} A \times B \xrightarrow{\pi_2} B}}

\quiver{
\begin{tikzcd}
	{A \times B} && A \\
	\\
	B && {A * B}
	\arrow[from=1-1, to=1-3]
	\arrow[from=1-1, to=3-1]
	\arrow[from=1-3, to=3-3]
	\arrow[from=3-1, to=3-3]
	\arrow["\lrcorner"{anchor=center, pos=0.125, rotate=180}, draw=none, from=3-3, to=1-1]
\end{tikzcd}
}

\agda{
infixl 15 _*_

_*_ : ‚ąÄ {ūĚď§ ūĚď•} ‚Üí Type ūĚď§ ‚Üí Type ūĚď• ‚Üí Type (ūĚď§ ‚äĒ ūĚď•)
A * B = Pushout {A = A √ó B} fst snd
}
}


\subtree[stt-002V]{
\title{Singleton joins}

\p{The join of a singleton with any type is also a singleton}

\proof{
\p{This follows from the fact that [pushing an equivalence out gives
an equivalence](stt-0080).}
}

\agda{
*-comm : ‚ąÄ {ūĚď§ ūĚď•} {A : Type ūĚď§} {B : Type ūĚď•} ‚Üí A * B ‚ČÉ B * A
*-comm {A = A} {B} = pushout-comm ‚ąôe (Pushout-adjust-equiv √ó-swap)


*-single'
  : ‚ąÄ {ūĚď§ ūĚď•} {A : Type ūĚď§} {B : Type ūĚď•}
    ‚Üí is-singleton B ‚Üí is-singleton (A * B)
*-single' {A = A} {B} sb
  = is-single‚Üźequiv-to-single (mk‚ČÉ _ őĻ‚āā-is-equiv) sb where
  őĻ‚āā-is-equiv : is-equiv {B = A * B} őĻ‚āā
  őĻ‚āā-is-equiv = dom-is-equiv‚Üźcocartesian
                  (mk-amap snd őĻ‚āĀ glue)
                  (singleton-fst-is-equiv (őĽ _ ‚Üí sb))
                  (up-cocartesian‚Üźup-pushout Pushout-has-up-pushout)

*-single
  : ‚ąÄ {ūĚď§ ūĚď•} {A : Type ūĚď§} {B : Type ūĚď•}
    ‚Üí is-singleton A ‚Üí is-singleton (A * B)
*-single sa
  = is-single‚Üźequiv-to-single *-comm (*-single' sa)
}
}

\subtree[stt-002W]{
\taxon{Theorem}
\title{Joins of propositions}

\p{The universal property for joins of propositions says that
for propositions #{P} and #{Q}, to eliminate into a proposition #{R},
it suffices to supply #{P \to R}, and #{Q \to R}}

\p{As an easy corollary, we have that the join of two propositions
is again a proposition.}

\agda{
*-prop-disj
  : ‚ąÄ {ūĚď§ ūĚď• ūĚď¶} {A : Type ūĚď§} {B : Type ūĚď•}
      {Q : Type ūĚď¶}
    ‚Üí is-prop A ‚Üí is-prop B
    ‚Üí is-prop Q
    ‚Üí (A * B ‚Üí Q) ‚Üí (A ‚Üí Q) √ó (B ‚Üí Q)
*-prop-disj a b q f = (f ‚ąė őĻ‚āĀ , f ‚ąė őĻ‚āā)


*-prop-disj‚ČÉ
  : ‚ąÄ {ūĚď§ ūĚď• ūĚď¶}
      {A : Type ūĚď§} {B : Type ūĚď•} {Q : Type ūĚď¶}
    ‚Üí (pq : is-prop Q)
    ‚Üí (A * B ‚Üí Q) ‚ČÉ ((A ‚Üí Q) √ó (B ‚Üí Q))
*-prop-disj‚ČÉ {A = A} {B} {Q} pq
 = (A * B ‚Üí Q)
      ‚ČÉ‚ü® Pushout-UP‚ČÉ ‚ü©
   Cocone (mk-span _ fst snd) Q
      ‚ČÉ‚ü® cocone-repr‚ČÉ ‚ü©
   ő£[ f ‚ą∂ (A ‚Üí Q) ] ő£[ g ‚ą∂ (B ‚Üí Q) ] (f ‚ąė fst ~ g ‚ąė snd)
      ‚ČÉ‚ü® ő£-snd-‚ČÉ (őĽ f ‚Üí ő£-snd-‚ČÉ (őĽ g ‚Üí curry‚ČÉ)) ‚ü©
   ő£[ f ‚ą∂ (A ‚Üí Q) ] ő£[ g ‚ą∂ (B ‚Üí Q) ] ((a : A) (b : B) ‚Üí f a ÔľĚ g b)
      ‚ČÉ‚ü® ő£-snd-‚ČÉ (őĽ a ‚Üí ő£-singleton (őĽ x ‚Üí ő†-is-single őĽ
                     b ‚Üí ő†-is-single (őĽ
                       c ‚Üí ÔľĚ-is-single‚Üźis-prop pq _ _))) ‚ü©
   ((A ‚Üí Q) √ó (B ‚Üí Q)) ‚ČÉ‚ąé

*-prop-UP
  : ‚ąÄ {ūĚď§ ūĚď• ūĚď¶} {A : Type ūĚď§} {B : Type ūĚď•}
      {Q : Type ūĚď¶}
      (ap : is-prop A) (bp : is-prop B)
      (qp : is-prop Q)
    ‚Üí is-equiv (*-prop-disj ap bp qp)
*-prop-UP ap bp qp = *-prop-disj‚ČÉ qp ._‚ČÉ_.fwd-is-equiv

opaque
  *-prop-rec
    : ‚ąÄ {ūĚď§ ūĚď• ūĚď¶}
        {A : Type ūĚď§} {B : Type ūĚď•} {Q : Type ūĚď¶}
      ‚Üí (pq : is-prop Q)
      ‚Üí (A ‚Üí Q) ‚Üí (B ‚Üí Q) ‚Üí (A * B ‚Üí Q)
  *-prop-rec pq f g = _‚ČÉ_.bwd (*-prop-disj‚ČÉ pq) (f , g)
{-# NOINLINE *-prop-rec #-}

*-is-prop
  : ‚ąÄ {ūĚď§ ūĚď•} {A : Type ūĚď§} {B : Type ūĚď•}
    ‚Üí is-prop A ‚Üí is-prop B
    ‚Üí is-prop (A * B)
*-is-prop aprop bprop = is-prop‚Üźis-single-if-inhabited
  (*-prop-rec is-single-is-prop
    (őĽ a ‚Üí *-single (mk-singl a (aprop a)))
    (őĽ b ‚Üí *-single' (mk-singl b (bprop b))))
}
}


\subtree[stt-009U]{
\title{Joins with the empty type}

\p{The join #{A * 0} for any type #{A} is equivalent to #{A}.}

\proof{The map #{A \times 0 \to 0} is an equivalence so by
\ref{stt-008O}, so must #{A \to A * 0}.}

\agda{
*-‚ąÖ : ‚ąÄ {ūĚď§} {A : Type ūĚď§} ‚Üí A ‚ČÉ ‚ąÖ * A
*-‚ąÖ = mk‚ČÉ őĻ‚āā (dom-is-equiv‚Üźcocartesian (mk-amap snd őĻ‚āĀ glue)
             (√ó-‚ąÖ ._‚ČÉ_.fwd-is-equiv) (up-cocartesian‚Üźup-pushout
                                     Pushout-has-up-pushout))
}
}

\subtree[stt-009L]{
\title{Functoriality of the join}
\taxon{Theorem}

\p{The join operator on types defines a functor
#{\SS \times \SS \to \SS}. We define the action of #{*} on functions,
and show that it preserves equivalences.}

\agda{
_*‚āĀ_
  : ‚ąÄ {ūĚď§ ūĚďú ūĚď• ūĚď¶} {A : Type ūĚď§} {A' : Type ūĚďú}
      {B : Type ūĚď•} {B' : Type ūĚď¶}
    ‚Üí (A ‚Üí A') ‚Üí (B ‚Üí B') ‚Üí A * B ‚Üí A' * B'
f *‚āĀ g = pushout-rec (mk-cocone (őĻ‚āĀ ‚ąė f) (őĻ‚āā ‚ąė g) (glue ‚ąė (f ‚äó g)))

*‚āĀ-is-equiv
  : ‚ąÄ {ūĚď§ ūĚďú ūĚď• ūĚď¶} {A : Type ūĚď§} {A' : Type ūĚďú}
      {B : Type ūĚď•} {B' : Type ūĚď¶}
    ‚Üí {f : A ‚Üí A'} {g : B ‚Üí B'}
    ‚Üí is-equiv f ‚Üí is-equiv g
    ‚Üí is-equiv (f *‚āĀ g)
*‚āĀ-is-equiv {A = A} {B = B} {f = f} {g} feq geq = is-equiv‚Üźqinv qinv where
  module f = is-equiv feq
  module g = is-equiv geq


  opaque
    sec : ‚ąÄ a ‚Üí
        Square (ap ((f *‚āĀ g) ‚ąė (f.bwd *‚āĀ g.bwd)) (glue a))
               (ap id (glue a))
               (((őĻ‚āĀ ‚óā f.őĶ) ‚ąė fst) a)
               (((őĻ‚āā ‚óā g.őĶ) ‚ąė snd) a)
    sec p@(a , b) = mk-square (
      ‚Ćú ap ((f *‚āĀ g) ‚ąė (f.bwd *‚āĀ g.bwd)) (glue p) ‚ĆĚ ‚ąô ((őĻ‚āā ‚óā g.őĶ) b)
                                    ÔľĚ‚ü® ap! (ap-‚ąė _ _ (glue p)) ‚ü©
      ap (f *‚āĀ g) ‚Ćú ap (f.bwd *‚āĀ g.bwd) (glue p) ‚ĆĚ ‚ąô ((őĻ‚āā ‚óā g.őĶ) b)
                                    ÔľĚ‚ü® ap! (pushout-rec-apő≤ p) ‚ü©
      ‚Ćú ap (f *‚āĀ g) (glue (f.bwd a , g.bwd b)) ‚ĆĚ ‚ąô ((őĻ‚āā ‚óā g.őĶ) b)
                                    ÔľĚ‚ü® ap! (pushout-rec-apő≤ ((f.bwd ‚äó g.bwd) p)) ‚ü©
      (glue ‚ąė (f ‚äó g) ‚ąė (f.bwd ‚äó g.bwd)) p ‚ąô (‚Ćú őĻ‚āā ‚óā g.őĶ ‚Ėł snd ‚ĆĚ) p
                                    ÔľĚ‚ü® ap! ( sym (ap-‚ąė őĻ‚āā snd (√ó-path‚Üí (f.őĶ a , g.őĶ b))
                                            ‚ąô ap (ap őĻ‚āā) √ó-path-ap-snd)) ‚ü©
      ((glue ‚ąė (f ‚äó g) ‚ąė (f.bwd ‚äó g.bwd)) ‚ąôh ((őĻ‚āā ‚ąė snd) ‚óā √ó~ (f.őĶ , g.őĶ))) p
                                    ÔľĚ‚ü®‚ü©
      (glue ‚óĺ (√ó~ (f.őĶ , g.őĶ))) p   ÔľĚ‚ü® switch-‚óĺ glue (√ó~ (f.őĶ , g.őĶ)) p ‚ü©
      (glue ‚óĺ' (√ó~ (f.őĶ , g.őĶ))) p  ÔľĚ‚ü® ap (_‚ąô glue p) (ap-‚ąė őĻ‚āĀ fst (√ó~ (f.őĶ , g.őĶ) p)) ‚ü©
       ((őĻ‚āĀ ‚óā fst ‚óā √ó~ (f.őĶ , g.őĶ)) ‚ąôh glue) p
                                    ÔľĚ‚ü® ap (őĽ x ‚Üí (ap őĻ‚āĀ x) ‚ąô glue p) √ó-path-ap-fst ‚ü©
      ap őĻ‚āĀ (f.őĶ a) ‚ąô ‚Ćú glue p ‚ĆĚ    ÔľĚ‚ü® ap! (sym (ap-id (glue p))) ‚ü©
      ap őĻ‚āĀ (f.őĶ a) ‚ąô ap id (glue p) ‚ąé)

    -- I wanted to generalise sec, and then give f.bwd and g.bwd
    -- but because is-equiv‚ĀĽ¬Ļ goes via composing quasi-inverses it
    -- messes with the őĶ
    ret : ‚ąÄ a ‚Üí
        Square (ap ((f.bwd *‚āĀ g.bwd) ‚ąė (f *‚āĀ g)) (glue a))
               (ap id (glue a))
               (((őĻ‚āĀ ‚óā f.ő∑) ‚ąė fst) a)
               (((őĻ‚āā ‚óā g.ő∑) ‚ąė snd) a)
    ret p@(a , b) = mk-square (
        ‚Ćú ap ((f.bwd *‚āĀ g.bwd) ‚ąė (f *‚āĀ g)) (glue p) ‚ĆĚ ‚ąô ((őĻ‚āā ‚óā g.ő∑) b)
                                      ÔľĚ‚ü® ap! (ap-‚ąė _ _ (glue p)) ‚ü©
        ap (f.bwd *‚āĀ g.bwd) ‚Ćú ap (f *‚āĀ g) (glue p) ‚ĆĚ ‚ąô ((őĻ‚āā ‚óā g.ő∑) b)
                                      ÔľĚ‚ü® ap! (pushout-rec-apő≤ p) ‚ü©
        ‚Ćú ap (f.bwd *‚āĀ g.bwd) (glue (f a , g b)) ‚ĆĚ ‚ąô ((őĻ‚āā ‚óā g.ő∑) b)
                                      ÔľĚ‚ü® ap! (pushout-rec-apő≤ ((f ‚äó g) p)) ‚ü©
        (glue ‚ąė (f.bwd ‚äó g.bwd) ‚ąė (f ‚äó g)) p ‚ąô (‚Ćú őĻ‚āā ‚óā g.ő∑ ‚Ėł snd ‚ĆĚ) p
                                      ÔľĚ‚ü® ap! ( sym (ap-‚ąė őĻ‚āā snd (√ó-path‚Üí (f.ő∑ a , g.ő∑ b))
                                              ‚ąô ap (ap őĻ‚āā) √ó-path-ap-snd)) ‚ü©
        ((glue ‚ąė (f.bwd ‚äó g.bwd) ‚ąė (f ‚äó g)) ‚ąôh ((őĻ‚āā ‚ąė snd) ‚óā √ó~ (f.ő∑ , g.ő∑))) p
                                      ÔľĚ‚ü® refl ‚ü©
        (glue ‚óĺ (√ó~ (f.ő∑ , g.ő∑))) p   ÔľĚ‚ü® switch-‚óĺ glue {h = (f.bwd ‚äó g.bwd) ‚ąė (f ‚äó g)} (√ó~ (f.ő∑ , g.ő∑)) p ‚ü©
        (glue ‚óĺ' (√ó~ (f.ő∑ , g.ő∑))) p  ÔľĚ‚ü® ap (_‚ąô glue p) (ap-‚ąė őĻ‚āĀ fst (√ó~ (f.ő∑ , g.ő∑) p)) ‚ü©
         ((őĻ‚āĀ ‚óā fst ‚óā √ó~ (f.ő∑ , g.ő∑)) ‚ąôh glue) p
                                      ÔľĚ‚ü® ap (őĽ x ‚Üí (ap őĻ‚āĀ x) ‚ąô glue p) √ó-path-ap-fst ‚ü©
        ap őĻ‚āĀ (f.ő∑ a) ‚ąô ‚Ćú glue p ‚ĆĚ    ÔľĚ‚ü® ap! (sym (ap-id (glue p))) ‚ü©
        ap őĻ‚āĀ (f.ő∑ a) ‚ąô ap id (glue p) ‚ąé)

  qinv : quasi-inv (f *‚āĀ g)
  qinv .fst = f.bwd *‚āĀ g.bwd
  qinv .snd .fst = pushout-ind _ (mk-coconeŠĶą (őĻ‚āĀ ‚óā f.ő∑) (őĻ‚āā ‚óā g.ő∑)
                    őĽ a ‚Üí IdŠĶą-func‚ÜźSquare
                           {f = (f.bwd *‚āĀ g.bwd) ‚ąė (f *‚āĀ g)}
                           {id} (glue a)
                           (ap őĻ‚āĀ (f.ő∑ (fst a))) ((őĻ‚āā ‚óā g.ő∑) (snd a))
                           (ret a))
  qinv .snd .snd = pushout-ind _ (mk-coconeŠĶą (őĻ‚āĀ ‚óā f.őĶ) (őĻ‚āā ‚óā g.őĶ)
                   (őĽ a ‚Üí IdŠĶą-func‚ÜźSquare {f = (f *‚āĀ g) ‚ąė (f.bwd *‚āĀ g.bwd)} {id}
                               (glue a) _ _
                               (sec a)))

*-‚ČÉ
  : ‚ąÄ {ūĚď§ ūĚď• ūĚď¶ ūĚďú} {A : Type ūĚď§} {B : Type ūĚď•} {C : Type ūĚď¶} {D : Type ūĚďú}
    ‚Üí A ‚ČÉ C ‚Üí B ‚ČÉ D ‚Üí A * B ‚ČÉ C * D
*-‚ČÉ (mk‚ČÉ l le) (mk‚ČÉ r re)
  = mk‚ČÉ (l *‚āĀ r) (*‚āĀ-is-equiv le re)
}
}

\subtree[stt-00FH]{
\taxon{Theorem}
\date{2026-03-06}
\author{fredrikbakke}
\title{Null-homotopies of maps out of a join}

\p{
Given a map #{q : A * B \to Q}, each point #{a : A} determines a
[null-homotopy](stt-00F3) of the restriction #{q \circ \iota_2 : B \to Q}. Moreover,
null-homotopies of #{q} are equivalent to null-homotopies of this induced family over
#{A}.
}

\agda{
join-null-homotopy-at
  : {ūĚď§ ūĚď• ūĚď¶ : Level}
    {A : Type ūĚď§} {B : Type ūĚď•} {Q : Type ūĚď¶}
  ‚Üí (q : A * B ‚Üí Q)
  ‚Üí A
  ‚Üí null-homotopy (q ‚ąė őĻ‚āā)
join-null-homotopy-at q a .fst = q (őĻ‚āĀ a)
join-null-homotopy-at q a .snd b = ap q (glue (a , b))

join-rec‚ČÉnull-homotopies
  : {ūĚď§ ūĚď• ūĚď¶ : Level}
    {A : Type ūĚď§} {B : Type ūĚď•} {Q : Type ūĚď¶}
  ‚Üí (A * B ‚Üí Q)
  ‚ČÉ ő£[ r ‚ą∂ (B ‚Üí Q) ] ((a : A) ‚Üí null-homotopy r)
join-rec‚ČÉnull-homotopies {A = A} {B} {Q}
  = (A * B ‚Üí Q)
      ‚ČÉ‚ü® Pushout-UP‚ČÉ ‚ü©
    Cocone (mk-span _ fst snd) Q
      ‚ČÉ‚ü® cocone-repr‚ČÉ ‚ü©
    ő£[ l ‚ą∂ (A ‚Üí Q) ] ő£[ r ‚ą∂ (B ‚Üí Q) ] (l ‚ąė fst ~ r ‚ąė snd)
      ‚ČÉ‚ü® ő£-snd-‚ČÉ (őĽ l ‚Üí ő£-snd-‚ČÉ (őĽ r ‚Üí curry‚ČÉ)) ‚ü©
    ő£[ l ‚ą∂ (A ‚Üí Q) ] ő£[ r ‚ą∂ (B ‚Üí Q) ] ((a : A) (b : B) ‚Üí l a ÔľĚ r b)
      ‚ČÉ‚ü® ő£-comm ‚ü©
    ő£[ r ‚ą∂ (B ‚Üí Q) ] ő£[ l ‚ą∂ (A ‚Üí Q) ] ((a : A) (b : B) ‚Üí l a ÔľĚ r b)
      ‚ČÉ‚ü® ő£-snd-‚ČÉ (őĽ r ‚Üí ő£-ő†-swap‚ČÉ (őĽ _ ‚Üí Q) (őĽ a q ‚Üí (b : B) ‚Üí q ÔľĚ r b) e‚ĀĽ¬Ļ) ‚ü©
    ő£[ r ‚ą∂ (B ‚Üí Q) ] ((a : A) ‚Üí ő£[ q ‚ą∂ Q ] ((b : B) ‚Üí q ÔľĚ r b))
      ‚ČÉ‚ü®‚ü©
    ő£[ r ‚ą∂ (B ‚Üí Q) ] ((a : A) ‚Üí null-homotopy r)
      ‚ČÉ‚ąé

join-recŠĶą‚ČÉnull-homotopies
  : {ūĚď§1 ūĚď§2 ūĚď§3 ūĚď§4 ūĚď§5 : Level}
    {A : Type ūĚď§1}
    {X : A ‚Üí Type ūĚď§2}
    {B : A ‚Üí Type ūĚď§3}
    {Y : (a : A) ‚Üí X a ‚Üí Type ūĚď§4}
    {Q : (a : A) (x : X a) ‚Üí Type ūĚď§5}
  ‚Üí ((a : A) (x : X a) ‚Üí B a * Y a x ‚Üí Q a x)
  ‚ČÉ ő£[ r ‚ą∂ ((a : A) (x : X a) ‚Üí Y a x ‚Üí Q a x) ]
     ((a : A) (b : B a) (x : X a) ‚Üí null-homotopy (r a x))
join-recŠĶą‚ČÉnull-homotopies
  {A = A} {X} {B} {Y} {Q}
  = ((a : A) (x : X a) ‚Üí B a * Y a x ‚Üí Q a x)
      ‚ČÉ‚ü® ő†-fam-‚ČÉ (őĽ a ‚Üí ő†-fam-‚ČÉ (őĽ _ ‚Üí join-rec‚ČÉnull-homotopies)) ‚ü©
    ((a : A) (x : X a) ‚Üí ő£[ r ‚ą∂ (Y a x ‚Üí Q a x) ] ((b : B a) ‚Üí null-homotopy r))
      ‚ČÉ‚ü® ő†-fam-‚ČÉ
            ( őĽ a
              ‚Üí ő£-ő†-swap‚ČÉ
                  (őĽ x ‚Üí Y a x ‚Üí Q a x)
                  (őĽ x r ‚Üí (b : B a) ‚Üí null-homotopy r)) ‚ü©
    ((a : A)
      ‚Üí ő£[ r ‚ą∂ ((x : X a) ‚Üí Y a x ‚Üí Q a x) ]
          ((x : X a) ‚Üí (b : B a) ‚Üí null-homotopy (r x)))
      ‚ČÉ‚ü® ő£-ő†-swap‚ČÉ
            (őĽ a ‚Üí (x : X a) ‚Üí Y a x ‚Üí Q a x)
            (őĽ a r ‚Üí (x : X a) (b : B a) ‚Üí null-homotopy (r x)) ‚ü©

fundamental-Cov
  : ∀ {𝓤 𝓥} {A : Type 𝓤} {F : A → Type 𝓥} (Fc : is-covariant F)
      x
    → (f : ∀ a → Hom A x a → F a)
    → is-initial {A = Σ A F} (x , f x (idH x))
    ⇔ is-fibrewise-equiv f
fundamental-Cov Fc x f = {!!}



Hom𝟙-is-single : is-singleton (Hom 𝟙 tt tt)
Hom𝟙-is-single = is-single←equiv-to-single
  (total-hom ∙≃ Σ-singl 𝟙-is-singleton tt ∙≃ Σ-singl 𝟙-is-singleton tt)
  (is-singleton-Π {A = Δ¹} {B = λ _ → 𝟙} λ _ → 𝟙-is-singleton)

tr-cov-is-equiv
  : ∀ {𝓤 𝓥} {A : Type 𝓤}
      (Asimp : is-simplicial A)
      (Apc : is-segal A)
      {F : A → Type 𝓥}
    → (Fc : is-covariant F)
    → is-fibrewise-equiv (ev-id {F = F})
tr-cov-is-equiv Asimp Apc {F = F} Fc a = {!!}

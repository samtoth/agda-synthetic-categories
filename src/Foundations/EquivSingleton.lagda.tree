\date{2025-02-26}
\taxon{Module}
\author{samueltoth}
\title{Types equivalent to (sub)singleton types are (sub)singleton}

\import{stt-macros}


\agda{
module Foundations.EquivSingleton where
}

\agda-imports{
\agda{
open import Foundations.Universes
open import Foundations.Identity
open import Foundations.Functions
open import Foundations.Sigma
open import Foundations.Unit
open import Foundations.FunctionInverses
open import Foundations.QuasiEquivalences
open import Foundations.Equivalences
open import Foundations.Singletons
}
}

\proof{
\p{Suppose we have an equivalence #{f : A \toeq B}, and #{A} is a
singleton, then we need to show for any two terms #{x,y : B}, we need
an identification #{x = y}. But because #{f} is an equivalence, it
suffices to consider two terms #{a,b : A}, and find an identification
#{f(a) = f(b)}.}

\agda{
is-single‚Üźretraction
  : ‚ąÄ {ūĚď§ ūĚď•} {A : Type ūĚď§} {B : Type ūĚď•} (f : A ‚Üí B)
  ‚Üí retraction f ‚Üí is-singleton B ‚Üí is-singleton A
is-single‚Üźretraction f (r , ret) sb .centre
  = r (sb .centre)
is-single‚Üźretraction f (r , ret) sb .central a
  = ap r (sb .central (f a)) ‚ąô ret a

is-single‚Üźequiv-to-single
  : ‚ąÄ {ūĚď§ ūĚď•} {A : Type ūĚď§} {B : Type ūĚď•} ‚Üí (A ‚ČÉ B) ‚Üí is-singleton A ‚Üí is-singleton B
is-single‚Üźequiv-to-single (mk‚ČÉ f e)
  = is-single‚Üźretraction (is-equiv.bwd e) (f , is-equiv.őĶ e)

is-prop‚Üźretraction
  : ‚ąÄ {ūĚď§ ūĚď•} {A : Type ūĚď§} {B : Type ūĚď•} (f : A ‚Üí B)
  ‚Üí retraction f ‚Üí is-prop B ‚Üí is-prop A
is-prop‚Üźretraction f (r , ret) Bpr x y
  = sym (ret x) ‚ąô ap r (Bpr (f x) (f y)) ‚ąô ret y

is-prop‚Üźequiv-to-prop
  : ‚ąÄ {ūĚď§ ūĚď•} {A : Type ūĚď§} {B : Type ūĚď•} ‚Üí (A ‚ČÉ B) ‚Üí is-prop A ‚Üí is-prop B
is-prop‚Üźequiv-to-prop (mk‚ČÉ f e)
  = is-prop‚Üźretraction (is-equiv.bwd e) (f , is-equiv.őĶ e)

singleton‚ČÉūĚüô : ‚ąÄ {ūĚď§} {A : Type ūĚď§} ‚Üí is-singleton A ‚Üí A ‚ČÉ ūĚüô
singleton‚ČÉūĚüô {A = A} sa = mk‚ČÉ (őĽ _ ‚Üí tt) (mk-eqv qinv coh) where
  qinv : quasi-inv (őĽ (_ : A) ‚Üí tt)
  qinv .fst _ = sa .centre
  qinv .snd .fst a = sa .central a
  qinv .snd .snd _ = refl

  coh : qinv-coh qinv
  coh a = ap-const (sa .central a)
}
}

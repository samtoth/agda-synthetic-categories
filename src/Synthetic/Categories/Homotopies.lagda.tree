\date{2025-12-12}
\title{Homotopies of morphisms}
\author{samueltoth}
\taxon{Module}
\import{stt-macros}

\transclude{stt-00AB}

%```agda
\agda{
open import Foundations.Prelude
open import Algebra.Lattice
open import Data.Bool

module Synthetic.Categories.Homotopies
  {𝓘} (Δ¹ : Type 𝓘) (I : Lattice Δ¹) (I-distr : is-distributive I)
  where

open import ufAxioms

open Lattice I renaming (0l to i0; 1l to i1)
import Algebra.Lattice.Instances.Polynomial as Poly
open Poly  hiding (L[x]; Δ²)
open is-distributive I-distr

private
  Δ² = Poly.Δ² I
  I[x] = Poly.L[x] I

open import Modalities.Subuniverses
open import Modalities.GlobalSubuniverses
open import Modalities.GlobalReflectiveSubuniverses
open import Modalities.Instances.Localisation
open import Modalities.Instances.Nullification
open import Modalities.Instances.Truncation

open import Core.Orthogonal
open import Core.CanonicalPushouts
open import Core.Arrow
open import Core.ArrowEquiv
open import Core.Lifts
open import Core.FlatteningPushouts
open import Core.PiSection
open import Core.CocartesianSquare
open import Core.Postwhisker

open import Ergonomics.Notations.Orthogonality
open import Ergonomics.Extensionality
open Core.Orthogonal.notation

open import Synthetic.Hom Δ¹ i0 i1
open import Synthetic.Categories.Precategories Δ¹ I I-distr
open import Synthetic.Categories.Horns Δ¹ I I-distr
open import Synthetic.Categories.Boundaries Δ¹ I I-distr
}
%```


\subtree[stt-00CH]{
\title{Homotopies of synthetic morphisms}
\taxon{Definition}
\author{samueltoth}
\contributor{fredrikbakke}

\p{
We define \em{left} and \em{right homotopies} resp. #{f \lhtpy g} and
#{f \rhtpy g} of synthetic morphisms via commuting triangles

\quiver{
\begin{tikzcd}
  a && b \\
  & a
  \arrow[from=1-1, to=1-3, "f"]
  \arrow[from=1-1, to=2-2, equals]
  \arrow[from=2-2, to=1-3, "g"']
\end{tikzcd}
\quad\text{and}\quad
\begin{tikzcd}
  a && b \\
  & b
  \arrow[from=1-1, to=1-3, "f"]
  \arrow[from=1-1, to=2-2, "g"']
  \arrow[from=2-2, to=1-3, equals]
\end{tikzcd}
}
}

%```agda
\agda{
_~▵_ : ∀ {𝓤} {A : Type 𝓤} {a b : A} → (f g : Hom A a b) → Type (𝓘 ⊔ 𝓤)
f ~▵ g = Hom2 f (idH _) g

_▵~_ : ∀ {𝓤} {A : Type 𝓤} {a b : A} → (f g : Hom A a b) → Type (𝓘 ⊔ 𝓤)
f ▵~ g = Hom2 (idH _) f g

refl~▵ : ∀ {𝓤} {A : Type 𝓤} {a b : A} (f : Hom A a b) → f ~▵ f
refl~▵ f = (f .Homᵈ.hom ∘ Poly.Δ².t ,
           pushout-rec-unique _ _
             (pushout-rec-unique _ _
               (λ _ → f .Homᵈ.hom0)
               ~refl
               λ _ → ∙-reflr _
                   ∙ ap-∘ (f .Homᵈ.hom ∘ Poly.Δ².t) (pushout-rec _) (glue tt)
                   ∙ ap (ap _) (pushout-rec-apβ _)
                   ∙ ap-∘ (f .Homᵈ.hom) _ Δ²-refl
                   ∙ ap (ap _) (Δ²-ext-ap-t refl refl)
                   ∙ sym (∙-sym (f .Homᵈ.hom0)))
             ~refl
             (~∙-reflr _
             ~∙ ∂Δ¹-UP→ ( ap-∘ (f .Homᵈ.hom ∘ Poly.Δ².t) (pushout-rec _) (glue _)
                        ∙ ap (ap _) (pushout-rec-apβ _)
                        ∙ ap-∘ (f .Homᵈ.hom) _ Δ²-refl
                        ∙ ap (ap _) (Δ²-ext-ap-t refl refl)
                        ∙ sym (∙-sym (f .Homᵈ.hom0))
                        , ap-∘ (f .Homᵈ.hom ∘ Poly.Δ².t) (pushout-rec _) (glue _)
                        ∙ ap (ap _) (pushout-rec-apβ _)
                        ∙ ap-∘ (f .Homᵈ.hom) _ Δ²-refl
                        ∙ ap (ap _) (Δ²-ext-ap-t refl refl)
                        ∙ sym (∙-sym (f .Homᵈ.hom1)))))

refl▵~ : ∀ {𝓤} {A : Type 𝓤} {a b : A} (f : Hom A a b) → f ▵~ f
refl▵~ f = (f .Homᵈ.hom ∘ Poly.Δ².s ,
           pushout-rec-unique _ _
             (pushout-rec-unique _ _
               ~refl
               (λ _ → f .Homᵈ.hom1 ∙ refl)
               λ _ → ap (_∙ (f .Homᵈ.hom1 ∙ refl))
                        ( ap-∘ (f .Homᵈ.hom ∘ Poly.Δ².s) (pushout-rec _) (glue tt)
                        ∙ ap (ap _) (pushout-rec-apβ _)
                        ∙ ap-∘ (f .Homᵈ.hom) _ Δ²-refl
                        ∙ ap (ap _) (Δ²-ext-ap-s refl refl)
                        ∙ ap-refl (f .Homᵈ.hom)))
             ~refl
             (~∙-reflr _
             ~∙ ∂Δ¹-UP→ ( ap-∘ (f .Homᵈ.hom ∘ Poly.Δ².s) (pushout-rec _) (glue _)
                        ∙ ap (ap _) (pushout-rec-apβ _)
                        ∙ ap-∘ (f .Homᵈ.hom) _ Δ²-refl
                        ∙ ap (ap _) (Δ²-ext-ap-s refl refl)
                        ∙ ap-refl (f .Homᵈ.hom)
                        ∙ sym (∙-sym (f .Homᵈ.hom0))
                        , ap-∘ (f .Homᵈ.hom ∘ Poly.Δ².s) (pushout-rec _) (glue _)
                        ∙ ap (ap _) (pushout-rec-apβ _)
                        ∙ ap-∘ (f .Homᵈ.hom) _ Δ²-refl
                        ∙ ap (ap _) (Δ²-ext-ap-s refl refl)
                        ∙ ap-refl (f .Homᵈ.hom)
                        ∙ sym (∙-sym (f .Homᵈ.hom1))
                        ∙ sym (∙-assoc (f .Homᵈ.hom1) refl (sym (f .Homᵈ.hom1))))))

~▵←＝ : ∀ {𝓤} {A : Type 𝓤} {a b : A} {f g : Hom A a b} → f ＝ g → f ~▵ g
~▵←＝ {a = a} {_} {f} refl = refl~▵ f

▵~←＝ : ∀ {𝓤} {A : Type 𝓤} {a b : A} {f g : Hom A a b} → f ＝ g → f ▵~ g
▵~←＝ {a = a} {_} {f} refl = refl▵~ f
}
%```
}

\subtree[stt-00CI]{
\title{Homotopies are an identity system for morphisms}
\taxon{Theorem}

\p{
We show that when #{A} is a precategory, both left and right homotopies are
torsorial, and thus form identity systems for morphisms in #{A}. As a
consequence, left and right homotopy are equivalent.
}

%```agda
\agda{
opaque
  ~▵-is-torsorial
    : ∀ {𝓤} {A : Type 𝓤} {a b : A} → is-segal A
      → ∀ (f : Hom A a b) → is-singleton (Σ[ g ∶ Hom A a b ] (f ~▵ g))
  ~▵-is-torsorial apc f
    = is-single←equiv-to-single
        (mk≃ _ (composite←horn-extension-is-equiv f (idH _)))
        (segal-unique-composite apc f (idH _))

  ▵~-is-torsorial
    : ∀ {𝓤} {A : Type 𝓤} {a b : A} → is-segal A
      → ∀ (f : Hom A a b) → is-singleton (Σ[ g ∶ Hom A a b ] (f ▵~ g))
  ▵~-is-torsorial apc f
    = is-single←equiv-to-single
        (mk≃ _ (composite←horn-extension-is-equiv (idH _) f))
        (segal-unique-composite apc (idH _) f)

Hom-lhomotopy-IdS : ∀ {𝓤} {A : Type 𝓤} {a b : A} → is-segal A
                   → Identity-system (Hom A a b) (𝓤 ⊔ 𝓘)
Hom-lhomotopy-IdS apc .Identity-system.IdS = _~▵_
Hom-lhomotopy-IdS apc .Identity-system.IdS←Id = ~▵←＝
Hom-lhomotopy-IdS apc .Identity-system.has-is-ids f
  = fundamental-Id _ (~▵-is-torsorial apc f) _

Hom-rhomotopy-IdS : ∀ {𝓤} {A : Type 𝓤} {a b : A} → is-segal A
                    → Identity-system (Hom A a b) (𝓤 ⊔ 𝓘)
Hom-rhomotopy-IdS apc .Identity-system.IdS = _▵~_
Hom-rhomotopy-IdS apc .Identity-system.IdS←Id = ▵~←＝
Hom-rhomotopy-IdS apc .Identity-system.has-is-ids f
  = fundamental-Id _ (▵~-is-torsorial apc f) _

_ : ∀ {𝓤} {A : Type 𝓤} {a b : A} (apc : is-segal A)
              → is-equiv (λ (f : Hom A a b) → (f , f , refl~▵ f))
_ = λ apc → is-equiv⁻¹ (singleton-fst-is-equiv
                          (SingS-is-single ⦃ Hom-lhomotopy-IdS apc ⦄))

_ : ∀ {𝓤} {A : Type 𝓤} {a b : A} (apc : is-segal A)
              → is-equiv (λ (f : Hom A a b) → (f , f , refl▵~ f))
_ = λ apc → is-equiv⁻¹ (singleton-fst-is-equiv
                          (SingS-is-single ⦃ Hom-rhomotopy-IdS apc ⦄))

~▵≃▵~
  : ∀ {𝓤} {A : Type 𝓤} {a b : A} (apc : is-segal A)
    {f g : Hom A a b} → (f ~▵ g) ≃ (f ▵~ g)
~▵≃▵~ apc {f} {g}
  = mk≃
      (Identity-system.IdS←Id (Hom-rhomotopy-IdS apc)
      ∘ Identity-system.Id←IdS (Hom-lhomotopy-IdS apc))
      (is-equiv-∘
        (Identity-system.has-is-ids (Hom-rhomotopy-IdS apc) f g)
        (is-equiv⁻¹ (Identity-system.has-is-ids (Hom-lhomotopy-IdS apc) f g)))

▵~≃~▵
  : ∀ {𝓤} {A : Type 𝓤} {a b : A} (apc : is-segal A)
    {f g : Hom A a b} → (f ▵~ g) ≃ (f ~▵ g)
▵~≃~▵ apc = (~▵≃▵~ apc) e⁻¹
}
%```
}

\subtree[stt-00DK]{
\title{The walking left homotopy}
\taxon{Definition}
\date{2026-01-29}

\p{We define the walking homotopy #{\Delta_\sim} by taking the pushout
#{\Delta^2 +^{\Delta^1} 1}, that contracts the edge #{0 \leq 1}. We show that
a map #{\Delta_\sim \to A} is equivant to the type consisting of a pair of
morphisms and a homotopy between them.}

%```agda
\agda{
Δ~▵ : Type 𝓘
Δ~▵ = Pushout {B = Δ²} (_, i0) !

src-Δ~▵ : Δ¹ → Δ~▵
src-Δ~▵ = ι₁ ∘ Δ²-diagonal

tgt-Δ~▵ : Δ¹ → Δ~▵
tgt-Δ~▵ = ι₁ ∘ (i1 ,_)

Δ~▵-rep1
  : ∀ {𝓤} {A : Type 𝓤}
    → (Δ~▵ → A) ≃ Σ[ x ∶ A ] Ext (Λ[2,1]-incl ∘ ι₁) (const _ _ x)
Δ~▵-rep1 {A = A}
  = (Δ~▵ → A) ≃⟨ Pushout-UP≃ ∙≃ cocone-repr≃ ⟩
    Σ[ g ∶ (Δ² → A)]
     Σ[ x ∶ (𝟙 → A)] (g ∘ (_, i0) ~ x ∘ !)
       ≃⟨ Σ-comm ∙≃ (Σ-ap-≃-fst unit-UP≃) ⟩
    Σ[ x ∶ A ] (Ext (Λ[2,1]-incl ∘ ι₁) (const A Δ¹ x))    ≃∎

_ : ∀ {𝓤} {A : Type 𝓤} (f : Δ~▵ → A)
    → f ∘ src-Δ~▵ ~ Δ~▵-rep1 ._≃_.fwd f .snd .fst ∘ Δ²-diagonal
_ = λ _ → ~refl

Δ~▵-rep2
  : ∀ {𝓤} {A : Type 𝓤}
    → (Δ~▵ → A)
    ≃ Σ[ x ∶ A ]
       Σ[ f ∶ Ext {B = Λ[2,1]} ι₁ (const _ _ x) ]
         Ext Λ[2,1]-incl (f .fst)
Δ~▵-rep2 = Δ~▵-rep1 ∙≃ Σ-ap-≃ (λ a → Ext-compose global-funext Λ[2,1]-incl ι₁ (const _ _ a))

_ : ∀ {𝓤} {A : Type 𝓤} (f : Δ~▵ → A)
    → f ∘ src-Δ~▵ ~ Δ~▵-rep2 ._≃_.fwd f .snd .snd .fst ∘ Δ²-diagonal
_ = λ _ → ~refl

Λ[2,1]-ext-l
  : ∀ {𝓤} {A : Type 𝓤} (f : Δ¹ → A)
  → Ext {B = Λ[2,1]} ι₁ {λ _ → A} f ≃ Σ[ g ∶ (Δ¹ → A)] (g i0 ＝ f i1)
Λ[2,1]-ext-l {A = A} f = Ext {B = Λ[2,1]} ι₁ {λ _ → A} f
                   ≃⟨ Σ-ap-≃ (λ _ → funext≃ e⁻¹) ⟩
                 Σ[ x ∶ (Λ[2,1] → A) ] (x ∘ ι₁ ＝ f)
                   ≃⟨ Σ-ap-≃-fst {B = λ x → x .fst ＝ f} (Pushout-UP≃ ∙≃ cocone-repr≃) ⟩
                 _
                   ≃⟨ remove-singleton-structure Sing'-is-singleton (_ , refl) ⟩
                 _
                   ≃⟨ Σ-ap-≃ (λ a → unit-UP≃ ∙≃ sym≃) ⟩
                 Σ[ g ∶ (Δ¹ → A)] (g i0 ＝ f i1) ≃∎

Λ[2,1]-ext-l→
  : ∀ {𝓤} {A : Type 𝓤} (f : Δ¹ → A)
  → Ext {B = Λ[2,1]} ι₁ {λ _ → A} f → Σ[ g ∶ (Δ¹ → A)] (g i0 ＝ f i1)
Λ[2,1]-ext-l→ f (e , p) = (e ∘ ι₂ , sym (ap e (glue tt)) ∙ p i1)

Λ[2,1]-ext-l←
  : ∀ {𝓤} {A : Type 𝓤} (f : Δ¹ → A)
  → Σ[ g ∶ (Δ¹ → A)] (g i0 ＝ f i1) → Ext {B = Λ[2,1]} ι₁ {λ _ → A} f
Λ[2,1]-ext-l← f (g , k) = (cogap (mk-cocone f g (λ _ → sym k))) , ~refl

Λ[2,1]-ext-l-is-equiv
  : ∀ {𝓤} {A : Type 𝓤} (f : Δ¹ → A)
  → is-equiv (Λ[2,1]-ext-l→ f)
Λ[2,1]-ext-l-is-equiv {A = A} f
  = homotopy-is-equiv H
      (is-equiv-∘
        (Λ[2,1]-ext-l→=-is-equiv f)
        (is-equiv⁻¹ (_≃_.has-is-eqv (Σ-ap-≃ (λ _ → funext≃))))) where

    Λ[2,1]-ext-l→=
      : {𝓤 : Level} {A : Type 𝓤} (f : Δ¹ → A)
      → fibre (precomp-Π (λ _ → A) ι₁) f
      → Σ[ g ∶ (Δ¹ → A)] (g i0 ＝ f i1)
    Λ[2,1]-ext-l→= {A = A} .(precomp-Π (λ _ → A) ι₁ e) (e , refl)
      = (e ∘ ι₂ , sym (ap e (glue tt)))

    HJ : {e : Λ[2,1] → A} {f : Δ¹ → A}
         (q : e ∘ ι₁ ＝ f)
       → Λ[2,1]-ext-l→= f (e , q)
         ＝ (e ∘ ι₂ , sym (ap e (glue tt)) ∙ happly q i1)
    HJ refl = Σ-path→ (refl , sym (∙-reflr _))

    H : Λ[2,1]-ext-l→= f ∘ _≃_.bwd (Σ-ap-≃ (λ _ → funext≃))
        ~ Λ[2,1]-ext-l→ f
    H (e , p)
      = HJ (funext→ p)
      ∙ ap
          (λ r → (e ∘ ι₂ , sym (ap e (glue tt)) ∙ r))
          (happly (_≃_.ε funext≃ p) i1)

    Λ[2,1]-ext-l←=
      : ∀ {𝓤} {A : Type 𝓤} (f : Δ¹ → A)
      → Σ[ g ∶ (Δ¹ → A)] (g i0 ＝ f i1)
      → fibre (precomp-Π (λ _ → A) ι₁) f
    Λ[2,1]-ext-l←= f (g , k) = (cogap (mk-cocone f g (λ _ → sym k)) , refl)

    Λ[2,1]-ext-l→=-is-equiv
      : ∀ {𝓤} {A : Type 𝓤} (f : Δ¹ → A)
      → is-equiv (Λ[2,1]-ext-l→= f)
    Λ[2,1]-ext-l→=-is-equiv f = is-equiv←qiso
      ( Λ[2,1]-ext-l←= f
      , uncurry
          (λ where
             f refl → fibre-path→
               ( funext→
                   (sym ∘ pushout-rec-unique _ _ ~refl ~refl
                     (λ _ → ∙-reflr _ ∙ sym sym-sym))
               , ∙-reflr _ ∙ sym (commutes-prewhisker-funext _)
                 ∙ funext-refl))
      , uncurry (λ x y → Σ-path→ (refl , (ap sym (pushout-rec-apβ tt) ∙ sym-sym))))

Δ~▵-rep3
  : ∀ {𝓤} {A : Type 𝓤}
    → (Δ~▵ → A)
    ≃ Σ[ f ∶ (Δ¹ → A) ] Ext Λ[2,1]-incl (make-horn (λhom f) (idH _))
Δ~▵-rep3 {A = A}
  = (Δ~▵ → A) ≃⟨ Δ~▵-rep2 ⟩
    Σ[ x ∶ A ]
     (Σ (Ext ι₁ (const A Δ¹ x)) (Ext Λ[2,1]-incl ∘ fst))
             ≃⟨ Σ-assoc e⁻¹ ⟩
    Σ[ xe ∶ (Σ[ x ∶ A ] Ext ι₁ (const _ _ x)) ]
      (Ext Λ[2,1]-incl ∘ fst) (xe .snd)
             ≃⟨ mk≃ lem lem-is-eqv ⟩
    Σ[ f ∶ (Δ¹ → A) ]
     (Ext Λ[2,1]-incl (make-horn (λhom f) (idH (f _))))
             ≃∎ where

    H : ∀ (a : Σ[ x ∶ A ] Ext ι₁ (const _ _ x))
        → (fst (a .snd)) ~
          make-horn (λhom (a .snd .fst ∘ ι₂)) (idH _)
    H (x , a , p) = pushout-rec-unique _ _
      (λ i → p i ∙ sym (p i1) ∙ ap a (glue tt)) ~refl
      λ _ → ap (_∙ refl) (sym (sym∙ (p i1) (ap a (glue tt))))

    lem : Σ[ xe ∶ (Σ[ x ∶ A ] Ext ι₁ (const _ _ x)) ]
             (Ext Λ[2,1]-incl ∘ fst) (xe .snd)
          → Σ[ f ∶ (Δ¹ → A)] Ext Λ[2,1]-incl (make-horn (λhom f) (idH _))
    lem (a , b , p) = (a .snd .fst ∘ ι₂ , b , p ~∙ H a)

    lem-is-eqv : is-equiv lem
    lem-is-eqv
      = is-equiv-∘
          (total-is-equiv←fst-is-equiv
            (is-equiv-∘
                 (singleton-fst-is-equiv (λ _ → Sing-is-singleton))
                 (is-equiv-∘
                   (Σ-comm ._≃_.has-is-eqv)
                   (is-total-equiv←is-fibrewise-equiv
                     (λ a → Λ[2,1]-ext-l-is-equiv (const A Δ¹ a))))))
          (is-total-equiv←is-fibrewise-equiv
            λ a → is-total-equiv←is-fibrewise-equiv
              λ b → ~∙-is-equiv' (H a))

_ : ∀ {𝓤} {A : Type 𝓤} (f : Δ~▵ → A)
    → f ∘ src-Δ~▵ ~ Δ~▵-rep3 ._≃_.fwd f .snd .fst ∘ Δ²-diagonal
_ = λ f a → refl

Δ~▵-rep4
  : ∀ {𝓤} {A : Type 𝓤}
    → (Δ~▵ → A)
    ≃ Σ[ f ∶ (Δ¹ → A) ]
         Σ[ g ∶ Hom A (f i0) (f i1) ]
            Hom2 (λhom f) (idH _) g
Δ~▵-rep4 = Δ~▵-rep3
        ∙≃ Σ-ap-≃
            (λ f → Σ-ap-≃ (λ _ → funext≃ e⁻¹)
                ∙≃ mk≃ _ (composite←horn-extension-is-equiv (λhom f) (idH _)))

rep4-Δ~▵tgt
  : ∀ {𝓤} {A : Type 𝓤} → fst ∘ Δ~▵-rep4 ._≃_.fwd ~ precomp A (tgt-Δ~▵)
rep4-Δ~▵tgt = ~refl

rep4-Δ~▵src
  : ∀ {𝓤} {A : Type 𝓤}
    → Homᵈ.hom ∘ fst ∘ snd ∘ Δ~▵-rep4 ._≃_.fwd ~ precomp A (src-Δ~▵)
rep4-Δ~▵src f
  = composite←horn-extension-diagonal _ _
      (total-map (λ _ → funext→) (Δ~▵-rep3 ._≃_.fwd f .snd))
}
%```
}

\subtree[stt-00DL]{
\taxon{Corollary}
\date{2026-01-29}

\p{As a corollary of \ref{stt-00CH}, we have the the map map that picks out the
source (or the target) of the walking homotopy is a Segal equivalence.}


%```agda
\agda{
opaque
  tgt-is-segal-equiv
    : is-segal-equiv tgt-Δ~▵
  tgt-is-segal-equiv {Q = Q} qpc
    = is-equiv-∘
        {f = fst}
        {g = Δ~▵-rep4 ._≃_.fwd}
        (singleton-fst-is-equiv
          (λ f → SingS-is-single ⦃ Hom-lhomotopy-IdS qpc ⦄ _))
        (Δ~▵-rep4 ._≃_.has-is-eqv)

  src-is-segal-equiv
    : is-segal-equiv src-Δ~▵
  src-is-segal-equiv {Q = Q} qpc
    = is-equiv~∘
        {f = (Homᵈ.hom ∘ fst ∘ snd)}
        {g = Δ~▵-rep4 ._≃_.fwd}
        (rep4-Δ~▵src ~⁻¹)
        (is-equiv←qiso lemma)
        (Δ~▵-rep4 ._≃_.has-is-eqv) where
    lemma : quasi-iso {A = Σ[ f ∶ (Δ¹ → Q) ]
                             Σ[ g ∶ Hom Q (f i0) (f i1) ]
                               Hom2 (λhom f) (idH _) g}
                     {B = Δ¹ → Q} (Homᵈ.hom ∘ fst ∘ snd)
    lemma .fst a = (a , λhom a , refl~▵ (λhom a))
    lemma .snd .fst (a , b , p)
      = Σ-path→ ( sym (ap Homᵈ.hom (Id←IdS ⦃ Hom-lhomotopy-IdS qpc ⦄ p))
                , (composite-is-prop qpc _ _ _ _))
    lemma .snd .snd a = refl
}
%```
}

\subtree[fre-1338]{
\title{Homotopies from morphisms over morphisms}
\taxon{Construction}
\date{2026-03-30}
\author{fredrikbakke}

\p{
Given a morphism over #{g : \Hom_A(b,c)} from #{f : \Hom_A(a,b)} to #{h : \Hom_A(a,c)},
we extract a diagonal morphism #{k : \Hom_A(a,c)} together with a composition
triangle #{\delta = g \circ f} and a left homotopy #{h \lhtpy \delta}.
}

\p{
In particular, when #{g} is an identity morphism, this gives a left + right homotopy
decomposition of a morphism of morphisms: given two edges #{f\ h : \Hom_A(a,b)} and a
morphism #{\alpha : \Hom_{\Hom_A(a,b)}(f,h)}, then #{h \lhtpy \delta} and
#{f \rhtpy \delta}.
}
%```agda
\agda{
Hom2×~▵←Hom-over
  : ∀ {𝓤} {A : Type 𝓤} {a b c : A}
    (g : Hom A b c) (f : Hom A a b)
    {h : Hom A a c}
  → Hom-over g f h
  → Σ[ k ∶ Hom A a c ] (Hom2 g f k × (h ~▵ k))
Hom2×~▵←Hom-over {A = A} {a = a} {c = c} (g@(mk-hom gh refl refl)) f {h} α
  = (α▵ , Hom2←Hom-over , ~▵←Hom-over) where

  α0~ : Hom-path (α .Homᵈ.hom i0) f
  α0~ = IdS←Id ⦃ IdS-Hom ⦄ (α .Homᵈ.hom0)

  α1~ : Hom-path (α .Homᵈ.hom i1) h
  α1~ = IdS←Id ⦃ IdS-Hom ⦄ (α .Homᵈ.hom1)

  α▵ : Hom A a c
  α▵ .Homᵈ.hom i = α .Homᵈ.hom i .Homᵈ.hom i
  α▵ .Homᵈ.hom0 = α0~ .fst i0 ∙ f .Homᵈ.hom0
  α▵ .Homᵈ.hom1 = α1~ .fst i1 ∙ h .Homᵈ.hom1

  right-square : Δ² → A
  right-square p = α .Homᵈ.hom (p .Poly.Δ².t) .Homᵈ.hom (p .Poly.Δ².s)

  left-square : Δ² → A
  left-square p = α .Homᵈ.hom (p .Poly.Δ².s) .Homᵈ.hom (p .Poly.Δ².t)

  right-proof-ap
    : {i j : Δ¹} {p q : j ≤ i} → ap right-square Δ²-refl ＝ refl
  right-proof-ap {i} {j} {p} {q}
    = ap (ap right-square) (Δ²-is-set _ _ _ _)
    ∙ sym (ap-∘ right-square (λ m → (i , j) ⦃ m ⦄) (is-prop-separated _ _ p q))
    ∙ sym (∙-reflr _)
    ∙ ∙-reflr (ap (λ m → right-square ((i , j) ⦃ m ⦄)) (is-prop-separated _ _ p q))
    ∙ ap-const (is-prop-separated _ _ p q)

  left-proof-ap
    : {i j : Δ¹} {p q : j ≤ i} → ap left-square Δ²-refl ＝ refl
  left-proof-ap {i} {j} {p} {q}
    = ap (ap left-square) (Δ²-is-set _ _ _ _)
    ∙ sym (ap-∘ left-square (λ m → (i , j) ⦃ m ⦄) (is-prop-separated _ _ p q))
    ∙ sym (∙-reflr _)
    ∙ ∙-reflr (ap (λ m → left-square ((i , j) ⦃ m ⦄)) (is-prop-separated _ _ p q))
    ∙ ap-const (is-prop-separated _ _ p q)

  right-horn~ : right-square ∘ Λ[2,1]-incl ~ make-horn g f
  right-horn~
    = pushout-rec-unique
        (mk-cocone
          (f .Homᵈ.hom)
          (g .Homᵈ.hom)
          (λ _ → f .Homᵈ.hom1 ∙ sym (g .Homᵈ.hom0)))
        (right-square ∘ Λ[2,1]-incl)
        (α0~ .fst)
        (λ i → α .Homᵈ.hom i .Homᵈ.hom1)
        ( λ _ →
          ap (_∙ α .Homᵈ.hom i0 .Homᵈ.hom1)
             ( ap-∘ right-square Λ[2,1]-incl (glue tt)
             ∙ ap (ap right-square) (pushout-rec-apβ {c = Λ[2,1]-Δ²-cocone} tt)
             ∙ right-proof-ap)
        ∙ sym (α0~ .snd .snd)
        ∙ ap (α0~ .fst i1 ∙_) (sym (∙-reflr (f .Homᵈ.hom1))))

  left-horn~ : left-square ∘ Λ[2,1]-incl ~ make-horn h (idH a)
  left-horn~
    = pushout-rec-unique
        (mk-cocone (idH a .Homᵈ.hom) (h .Homᵈ.hom)
          (λ _ → sym (h .Homᵈ.hom0)))
        (left-square ∘ Λ[2,1]-incl)
        (λ i → α .Homᵈ.hom i .Homᵈ.hom0)
        (α1~ .fst)
        λ _ →
          ap (_∙ α1~ .fst i0)
             (ap-∘ left-square Λ[2,1]-incl (glue tt)
             ∙ ap (ap left-square) (pushout-rec-apβ {c = Λ[2,1]-Δ²-cocone} tt)
             ∙ left-proof-ap)
          ∙ sym (∙-reflr _)
          ∙ ap (α1~ .fst i0 ∙_) (sym (∙-sym (h .Homᵈ.hom0)))
          ∙ sym (∙-assoc (α1~ .fst i0) (h .Homᵈ.hom0) (sym (h .Homᵈ.hom0)))
          ∙ ap (_∙ sym (h .Homᵈ.hom0)) (α1~ .snd .fst)

  right-bd : make-horn g f ∘ ∂Λ[2,1]-incl ~ α▵ .Homᵈ.hom ∘ ∂Δ¹-incl
  right-bd (mk-lift false)  = f .Homᵈ.hom0 ∙ sym (α▵ .Homᵈ.hom0)
  right-bd (mk-lift true) = g .Homᵈ.hom1 ∙ sym (α▵ .Homᵈ.hom1)

  left-bd : make-horn h (idH a) ∘ ∂Λ[2,1]-incl ~ α▵ .Homᵈ.hom ∘ ∂Δ¹-incl
  left-bd (mk-lift false) = idH a .Homᵈ.hom0 ∙ sym (α▵ .Homᵈ.hom0)
  left-bd (mk-lift true) = h .Homᵈ.hom1 ∙ sym (α▵ .Homᵈ.hom1)

  right-make-∂Δ² : ∂Δ² → A
  right-make-∂Δ² = pushout-rec (mk-cocone (make-horn g f) (α▵ .Homᵈ.hom) right-bd)

  right-make-∂Δ²-path : right-make-∂Δ² ＝ make-∂Δ² g f α▵
  right-make-∂Δ²-path = funext→
    (pushout-rec-unique _ _ ~refl ~refl λ where
      (mk-lift false) → ∙-reflr _ ∙ pushout-rec-apβ (mk-lift false)
      (mk-lift true) → ∙-reflr _ ∙ pushout-rec-apβ (mk-lift true))

  left-make-∂Δ² : ∂Δ² → A
  left-make-∂Δ²
    = pushout-rec (mk-cocone (make-horn h (idH a)) (α▵ .Homᵈ.hom) left-bd)

  left-make-∂Δ²-path : left-make-∂Δ² ＝ make-∂Δ² h (idH a) α▵
  left-make-∂Δ²-path = funext→
    (pushout-rec-unique _ _ ~refl ~refl λ where
      (mk-lift false) → ∙-reflr _ ∙ pushout-rec-apβ (mk-lift false)
      (mk-lift true) → ∙-reflr _ ∙ pushout-rec-apβ (mk-lift true))

  Hom2←Hom-over : Hom2 g f α▵
  Hom2←Hom-over .fst = right-square
  Hom2←Hom-over .snd
    = pushout-rec-unique
        (mk-cocone (make-horn g f) (α▵ .Homᵈ.hom) right-bd)
        (right-square ∘ ∂Δ²-incl)
        (right-horn~)
        (~refl)
        (λ where
          (mk-lift false)
            → ap (_∙ refl)
                 ( ap-∘ right-square ∂Δ²-incl (glue ∂Δ¹-0)
                 ∙ ap (ap right-square) (pushout-rec-apβ ∂Δ¹-0)
                 ∙ right-proof-ap)
            ∙ sym (∙-sym (α▵ .Homᵈ.hom0))
            ∙ ∙-assoc (α0~ .fst i0) (f .Homᵈ.hom0) (sym (α▵ .Homᵈ.hom0))
          (mk-lift true)
            → ap (_∙ refl)
                 ( ap-∘ right-square ∂Δ²-incl (glue ∂Δ¹-1)
                 ∙ ap (ap right-square) (pushout-rec-apβ ∂Δ¹-1)
                 ∙ right-proof-ap)
            ∙ sym (∙-sym (α▵ .Homᵈ.hom1))
            ∙ ap (_∙ sym (α▵ .Homᵈ.hom1)) (α1~ .snd .snd))
      ~∙ happly right-make-∂Δ²-path

  ~▵←Hom-over : h ~▵ α▵
  ~▵←Hom-over .fst = left-square
  ~▵←Hom-over .snd
    = pushout-rec-unique
        (mk-cocone (make-horn h (idH a)) (α▵ .Homᵈ.hom) left-bd)
        (left-square ∘ ∂Δ²-incl)
        (left-horn~)
        (~refl)
        (λ where
          (mk-lift false)
            → ap (_∙ refl)
                 ( ap-∘ left-square ∂Δ²-incl (glue ∂Δ¹-0)
                 ∙ ap (ap left-square) (pushout-rec-apβ ∂Δ¹-0)
                 ∙ left-proof-ap)
            ∙ sym (∙-sym (α▵ .Homᵈ.hom0))
            ∙ ap (_∙ sym (α▵ .Homᵈ.hom0)) (α0~ .snd .fst)
          (mk-lift true)
            → ap (_∙ refl)
                 ( ap-∘ left-square ∂Δ²-incl (glue ∂Δ¹-1)
                 ∙ ap (ap left-square) (pushout-rec-apβ ∂Δ¹-1)
                 ∙ left-proof-ap)
            ∙ sym (∙-sym (α▵ .Homᵈ.hom1))
            ∙ ∙-assoc (α1~ .fst i1) (h .Homᵈ.hom1) (sym (α▵ .Homᵈ.hom1)))
      ~∙ happly left-make-∂Δ²-path

diag-hom←Hom-over
  : ∀ {𝓤} {A : Type 𝓤} {a b c : A}
    (g : Hom A b c) (f : Hom A a b)
    {h : Hom A a c}
  → Hom-over g f h
  → Hom A a c
diag-hom←Hom-over g f α = Hom2×~▵←Hom-over g f α .fst

Hom2←Hom-over
  : ∀ {𝓤} {A : Type 𝓤} {a b c : A}
    (g : Hom A b c) (f : Hom A a b)
    {h : Hom A a c}
  → (α : Hom-over g f h)
  → Hom2 g f (diag-hom←Hom-over g f α)
Hom2←Hom-over g f α = Hom2×~▵←Hom-over g f α .snd .fst

~▵←Hom-over
  : ∀ {𝓤} {A : Type 𝓤} {a b c : A}
    (g : Hom A b c) (f : Hom A a b)
    {h : Hom A a c}
  → (α : Hom-over g f h)
  → h ~▵ diag-hom←Hom-over g f α
~▵←Hom-over g f α = Hom2×~▵←Hom-over g f α .snd .snd
}
%```
}

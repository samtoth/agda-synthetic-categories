\date{2026-05-29}
\title{Dependent sums of celled types}
\author{fredrikbakke}
\import{stt-macros}
\taxon{Module}

\agda{
module Wild.Celled.Sums where

open import Wild.Celled.Types

open import Wild.PolynomialEndofunctors
open import Wild.FunctorialityPolynomialEndofunctors

open import Foundations.Universes
open import Foundations.Sigma
open import Foundations.Nat
open import Foundations.Functions
}

\subtree[fre-QWAB]{
\title{Dependent sums of celled types}
\taxon{Definition}
\author{fredrikbakke}
\date{2026-05-29}

\p{
The \em{dependent sum} of a dependent #{\mathit{S}}-celled type over an
#{\mathit{S}}-celled type is again an #{\mathit{S}}-celled type.
}

\agda{
Σ-CelledType
  : ∀ {𝓤 𝓥 𝓦1 𝓦2} {𝑺 : ℕ → 𝑃 𝓤 𝓥}
      (X : CelledType 𝑺 𝓦1)
    → DepCelledType 𝑺 𝓦2 X
    → CelledType 𝑺 (𝓦1 ⊔ 𝓦2)
Σ-CelledType {𝑺 = 𝑺} X Y .CelledType.carrier
  = Σ (CelledType.carrier X) (DepCelledType.carrier Y)
Σ-CelledType {𝑺 = 𝑺} X Y .CelledType.cells σ
  = Σ-CelledType (X .CelledType.cells (𝑃₁ (𝑺 0) fst σ)) (Y .DepCelledType.cells σ)
}
}

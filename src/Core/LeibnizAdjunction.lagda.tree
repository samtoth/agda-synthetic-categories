\subtree[fre-0005]{
\taxon{Definition}
\title{Iterated pullback powers and pushout sums}

%```agda
\agda{
module _
  {𝓤1 𝓤2 𝓤3 𝓤4 𝓤5 𝓤6 : Level}
  (F@(A , B) : Fam 𝓤1 𝓤2)
  (G@(X , Y) : DepFam 𝓤3 𝓤4 F)
  (H@(U , V) : Dep²Fam 𝓤5 𝓤6 F G)
  where

  Π̂Σ̂ᶠ : Fam (𝓤1 ⊔ 𝓤2 ⊔ 𝓤3 ⊔ 𝓤4 ⊔ 𝓤5 ⊔ 𝓤6)
            (𝓤1 ⊔ 𝓤2 ⊔ 𝓤3 ⊔ 𝓤4 ⊔ 𝓤6)
  Π̂Σ̂ᶠ = Π̂ᶠ (Σ̂ᶠ F G) (Σ̂ᵈᶠ F G H)

  Π̂ᵈᶠ : DepFam (𝓤3 ⊔ 𝓤4 ⊔ 𝓤5 ⊔ 𝓤6) (𝓤3 ⊔ 𝓤4 ⊔ 𝓤6) F
  Π̂ᵈᶠ
    = (λ a → fst (Π̂ᶠ (X a , Y a) (U a , V a)))
    , (λ a → snd (Π̂ᶠ (X a , Y a) (U a , V a)))

  Π̂Π̂ᶠ : Fam (𝓤1 ⊔ 𝓤2 ⊔ 𝓤3 ⊔ 𝓤4 ⊔ 𝓤5 ⊔ 𝓤6)
            (𝓤1 ⊔ 𝓤2 ⊔ 𝓤3 ⊔ 𝓤4 ⊔ 𝓤6)
  Π̂Π̂ᶠ = Π̂ᶠ F Π̂ᵈᶠ

module _
  {𝓤1 𝓤2 𝓤3 𝓤4 𝓤5 𝓤6 : Level}
  {A : Type 𝓤1}
  {B : Type 𝓤2}
  (f : A → B)
  {X : B → Type 𝓤3}
  {Y : B → Type 𝓤4}
  (g : (b : B) → X b → Y b)
  {U : (b : B) → Y b → Type 𝓤5}
  {V : (b : B) → Y b → Type 𝓤6}
  (h : (b : B) (y : Y b) → U b y → V b y)
  where

  Π̂Σ̂ : (((b , y) : Σ B Y) → U b y) → Arrow-Π (Σ̂ f g) (λ (b , y) → h b y)
  Π̂Σ̂ = Π̂ (Σ̂ f g) (λ (b , y) → h b y)

  Π̂Π̂ : ((b : B) (y : Y b) → U b y) → Arrow-Π f (λ b → Π̂ (g b) (h b))
  Π̂Π̂ = Π̂ f (λ b → Π̂ (g b) (h b))
}
%```
}

\subtree[fre-0006]{
\taxon{Theorem}
\title{The dependent Leibniz adjunction for families}

\p{
For all [type families](fre-0032) #{B : A \to \UU}, dependent type families
#{Y : (a : A)\to X(a) \to \UV} and doubly dependent type families
#{V : (a : A)\,(x : X(a)) \to U(a, x) \to \UW}, we have an
[equivalence of families](fre-0034)
##{
\pulldpow_{\pushsum_B Y}((a , x) \mapsto V(a, x))
\simeq \pulldpow_B {(a \mapsto \pulldpow_{Y(a)} V(a))}.
}
}
%```agda
\agda{
module _
  {𝓤1 𝓤2 𝓤3 𝓤4 𝓤5 𝓤6 : Level}
  (F@(A , B) : Fam 𝓤1 𝓤2)
  (G@(X , Y) : DepFam 𝓤3 𝓤4 F)
  (H@(U , V) : Dep²Fam 𝓤5 𝓤6 F G)
  (let ΠΣ = Π̂Σ̂ᶠ F G H)
  (let Π² = Π̂Π̂ᶠ F G H)
  where

  Π̂Π̂ᶠ←Π̂Σ̂ᶠ-base : fst ΠΣ → fst Π²
  Π̂Π̂ᶠ←Π̂Σ̂ᶠ-base (f , p) .fst a .fst x = f (a , x)
  Π̂Π̂ᶠ←Π̂Σ̂ᶠ-base (f , p) .fst a .snd x y = p (a , x) (ι₂ y)
  Π̂Π̂ᶠ←Π̂Σ̂ᶠ-base (f , p) .snd a b x .fst = p (a , x) (ι₁ b)
  Π̂Π̂ᶠ←Π̂Σ̂ᶠ-base (f , p) .snd a b x .snd y = ap (p (a , x)) (sym (glue (b , y)))

  Π̂Σ̂ᶠ←Π̂Π̂ᶠ-base : fst Π² → fst ΠΣ
  Π̂Σ̂ᶠ←Π̂Π̂ᶠ-base (f , p) .fst (a , x) = f a .fst x
  Π̂Σ̂ᶠ←Π̂Π̂ᶠ-base (f , p) .snd (a , x)
    = pushout-rec
        (mk-cocone
          (λ b → p a b x .fst)
          (λ y → f a .snd x y)
          (λ (b , y) → sym (p a b x .snd y)))

  Leibnizᵈᶠ-base-section-cocone
    : (fp : fst ΠΣ)
    → (ax : Σ A X)
    → Cocone (mk-span _ fst snd) (V (ax .fst) (ax .snd) (fp .fst ax))
  Leibnizᵈᶠ-base-section-cocone (f , p) ax
    = mk-cocone
        (λ b → p ax (ι₁ b))
        (λ y → p ax (ι₂ y))
        (λ (b , y) → sym (ap (p ax) (sym (glue (b , y)))))

  Leibnizᵈᶠ-base-section-coherence
    : (fp : fst ΠΣ)
    → (ax : Σ A X)
    → fp .snd ax ◂ glue ~∙ ~refl ▸ snd
    ~ ~refl ▸ fst ~∙ (Leibnizᵈᶠ-base-section-cocone fp ax) .Cocone.filler
  Leibnizᵈᶠ-base-section-coherence (f , p) ax (b , y)
    = ∙-reflr _
    ∙ sym (ap sym (ap-sym (p ax) (glue (b , y))) ∙ sym-sym)
    ∙ sym (∙-refll _)

  Π̂Σ̂ᶠ←Π̂Π̂ᶠ-base-is-retraction
    : (fp : fst ΠΣ) → Π̂Σ̂ᶠ←Π̂Π̂ᶠ-base (Π̂Π̂ᶠ←Π̂Σ̂ᶠ-base fp) ＝ fp
  Π̂Σ̂ᶠ←Π̂Π̂ᶠ-base-is-retraction (f , p)
    = Σ-path→ (refl , funext→ λ ax
              → funext→ λ j
              → (pushout-rec-unique (Leibnizᵈᶠ-base-section-cocone (f , p) ax) (p ax)
                  ~refl
                  ~refl
                  (Leibnizᵈᶠ-base-section-coherence (f , p) ax) ~⁻¹) j)

  Π̂Σ̂ᶠ←Π̂Π̂ᶠ-base-is-section-glue
    : (fq : fst Π²)
    → (a : A) (b : B a) (x : X a) (y : Y a x)
    → ap (Π̂Σ̂ᶠ←Π̂Π̂ᶠ-base fq .snd (a , x)) (sym (glue (b , y)))
    ＝ fq .snd a b x .snd y
  Π̂Σ̂ᶠ←Π̂Π̂ᶠ-base-is-section-glue (f , p) a b x y
    = ap-sym (Π̂Σ̂ᶠ←Π̂Π̂ᶠ-base (f , p) .snd (a , x)) (glue (b , y))
    ∙ ap sym (pushout-rec-apβ (b , y))
    ∙ sym-sym

  Π̂Σ̂ᶠ←Π̂Π̂ᶠ-base-is-section
    : (fq : fst Π²) → Π̂Π̂ᶠ←Π̂Σ̂ᶠ-base (Π̂Σ̂ᶠ←Π̂Π̂ᶠ-base fq) ＝ fq
  Π̂Σ̂ᶠ←Π̂Π̂ᶠ-base-is-section (f , p)
    = Σ-path→
        ( refl
        , funext→ λ a → funext→ λ b → funext→ λ x
        → Σ-path→ (refl
                  , funext→ (Π̂Σ̂ᶠ←Π̂Π̂ᶠ-base-is-section-glue (f , p) a b x)))

  Leibnizᵈᶠ≅-base : fst ΠΣ ≅ fst Π²
  Leibnizᵈᶠ≅-base ._≅_.fwd = Π̂Π̂ᶠ←Π̂Σ̂ᶠ-base
  Leibnizᵈᶠ≅-base ._≅_.fwd-iso .fst = Π̂Σ̂ᶠ←Π̂Π̂ᶠ-base
  Leibnizᵈᶠ≅-base ._≅_.fwd-iso .snd .fst = Π̂Σ̂ᶠ←Π̂Π̂ᶠ-base-is-retraction
  Leibnizᵈᶠ≅-base ._≅_.fwd-iso .snd .snd = Π̂Σ̂ᶠ←Π̂Π̂ᶠ-base-is-section

  Leibnizᵈᶠ≃-base : fst ΠΣ ≃ fst Π²
  Leibnizᵈᶠ≃-base = equiv←qiso Leibnizᵈᶠ≅-base

  Leibnizᵈᶠ-family-null-homotopy-at-curry
    : (fp : fst ΠΣ)
    → (a : A)
    → B a
    → (x : X a)
    → null-homotopy (fp .snd (a , x) ∘ ι₂)
  Leibnizᵈᶠ-family-null-homotopy-at-curry (f , p) a b x .fst
    = p (a , x) (ι₁ b)
  Leibnizᵈᶠ-family-null-homotopy-at-curry (f , p) a b x .snd y
    = ap (p (a , x)) (sym (glue (b , y)))

  Leibnizᵈᶠ-family-null-homotopy-at-uncurry
    : (fp : fst ΠΣ)
    → (ax : Σ A X)
    → B (ax .fst)
    → null-homotopy (fp .snd ax ∘ ι₂)
  Leibnizᵈᶠ-family-null-homotopy-at-uncurry fp (a , x) b
    = Leibnizᵈᶠ-family-null-homotopy-at-curry fp a b x

  module _
    (fp : fst ΠΣ) (a : A) (x : X a) (l : V a x (fp .fst (a , x)))
    where

    Leibnizᵈᶠ-family-cod-uncurry
      : B a * Y a x → V a x (fp .fst (a , x))
    Leibnizᵈᶠ-family-cod-uncurry = fp .snd (a , x)

    Leibnizᵈᶠ-family-cod-uncurry-sym
      : (b : B a) (y : Y a x)
      → Leibnizᵈᶠ-family-cod-uncurry (ι₂ y) ＝ Leibnizᵈᶠ-family-cod-uncurry (ι₁ b)
    Leibnizᵈᶠ-family-cod-uncurry-sym b y
      = ap Leibnizᵈᶠ-family-cod-uncurry (sym (glue (b , y)))

    Leibnizᵈᶠ-family-cod : B a * Y a x → Type 𝓤6
    Leibnizᵈᶠ-family-cod j
      = Leibnizᵈᶠ-family-cod-uncurry j ＝ l

    Leibnizᵈᶠ≃-family-cod-inner-over
      : (r : (y : Y a x) → Leibnizᵈᶠ-family-cod (ι₂ y))
      → (b : B a)
      → (Σ[ t ∶ Leibnizᵈᶠ-family-cod (ι₁ b) ]
          ((y : Y a x) → Idᵈ (ap (Leibnizᵈᶠ-family-cod) (glue (b , y))) t (r y)))
      ≃ (Leibnizᵈᶠ-family-null-homotopy-at-uncurry fp (a , x) b ＝ (l , r))
    Leibnizᵈᶠ≃-family-cod-inner-over r b
      = (Σ[ t ∶ Leibnizᵈᶠ-family-cod (ι₁ b) ]
          ((y : Y a x) → Idᵈ (ap (Leibnizᵈᶠ-family-cod) (glue (b , y))) t (r y)))
        ≃⟨ Σ-ap-≃ (λ t → Π-ap-≃ (λ y → Idᵈ-const-≃ Leibnizᵈᶠ-family-cod-uncurry (glue (b , y)) t (r y))) ⟩
        (Σ[ t ∶ Leibnizᵈᶠ-family-cod (ι₁ b) ]
          ((y : Y a x) → Leibnizᵈᶠ-family-cod-uncurry-sym b y ∙ t ＝ r y))
        ≃⟨ null-homotopy-path≃
              {f = Leibnizᵈᶠ-family-cod-uncurry ∘ ι₂}
              (Leibnizᵈᶠ-family-cod-uncurry-sym b)
              r e⁻¹ ⟩
        (Leibnizᵈᶠ-family-null-homotopy-at-uncurry fp (a , x) b ＝ (l , r))
        ≃∎

    Leibnizᵈᶠ≃-family-cod-inner
      : (r : (y : Y a x) → Leibnizᵈᶠ-family-cod (ι₂ y))
      → (Σ[ t ∶ ((b : B a) → Leibnizᵈᶠ-family-cod (ι₁ b)) ]
          (((b , y) : B a × Y a x) → Idᵈ (ap (Leibnizᵈᶠ-family-cod) (glue (b , y))) (t b) (r y)))
      ≃ ((b : B a) → Leibnizᵈᶠ-family-null-homotopy-at-uncurry fp (a , x) b ＝ (l , r))
    Leibnizᵈᶠ≃-family-cod-inner r
      = (Σ[ t ∶ ((b : B a) → Leibnizᵈᶠ-family-cod (ι₁ b)) ]
          (((b , y) : B a × Y a x) → Idᵈ (ap (Leibnizᵈᶠ-family-cod) (glue (b , y))) (t b) (r y)))
        ≃⟨ Σ-ap-≃ (λ t → curry≃) ⟩
        (Σ[ t ∶ ((b : B a) → Leibnizᵈᶠ-family-cod (ι₁ b)) ]
          ((b : B a) (y : Y a x) → Idᵈ (ap (Leibnizᵈᶠ-family-cod) (glue (b , y))) (t b) (r y)))
        ≃⟨ Σ-Π-swap≃ (λ b → Leibnizᵈᶠ-family-cod (ι₁ b))
                     (λ b t → (y : Y a x) → Idᵈ (ap (Leibnizᵈᶠ-family-cod) (glue (b , y))) t (r y))
                     e⁻¹ ⟩
        ((b : B a)
          → Σ[ t ∶ Leibnizᵈᶠ-family-cod (ι₁ b) ]
            ((y : Y a x) → Idᵈ (ap (Leibnizᵈᶠ-family-cod) (glue (b , y))) t (r y)))
        ≃⟨ Π-ap-≃ (Leibnizᵈᶠ≃-family-cod-inner-over r) ⟩
        ((b : B a) → Leibnizᵈᶠ-family-null-homotopy-at-uncurry fp (a , x) b ＝ (l , r))
        ≃∎

    Leibnizᵈᶠ≃-family-cod-main
      : (((j : B a * Y a x) → Leibnizᵈᶠ-family-cod-uncurry j ＝ l))
      ≃ (Σ[ r ∶ ((y : Y a x) → Leibnizᵈᶠ-family-cod-uncurry (ι₂ y) ＝ l) ]
          ((b : B a) → Leibnizᵈᶠ-family-null-homotopy-at-uncurry fp (a , x) b ＝ (l , r)))
    Leibnizᵈᶠ≃-family-cod-main
      = (((j : B a * Y a x) → Leibnizᵈᶠ-family-cod-uncurry j ＝ l))
        ≃⟨ Pushout-UPᵈ≃ e⁻¹ ⟩
        Coconeᵈ (mk-span _ fst snd) pushout (Leibnizᵈᶠ-family-cod)
        ≃⟨ coconeD-repr≃ ⟩
        (Σ[ t ∶ ((b : B a) → Leibnizᵈᶠ-family-cod (ι₁ b)) ]
          Σ[ r ∶ ((y : Y a x) → Leibnizᵈᶠ-family-cod (ι₂ y)) ]
            (((b , y) : B a × Y a x) → Idᵈ (ap (Leibnizᵈᶠ-family-cod) (glue (b , y))) (t b) (r y)))
        ≃⟨ Σ-comm ⟩
        (Σ[ r ∶ ((y : Y a x) → Leibnizᵈᶠ-family-cod (ι₂ y)) ]
          Σ[ t ∶ ((b : B a) → Leibnizᵈᶠ-family-cod (ι₁ b)) ]
            (((b , y) : B a × Y a x) → Idᵈ (ap (Leibnizᵈᶠ-family-cod) (glue (b , y))) (t b) (r y)))
        ≃⟨ Σ-ap-≃ Leibnizᵈᶠ≃-family-cod-inner ⟩
        (Σ[ r ∶ ((y : Y a x) → Leibnizᵈᶠ-family-cod (ι₂ y)) ]
        ((b : B a) → Leibnizᵈᶠ-family-null-homotopy-at-uncurry fp (a , x) b ＝ (l , r)))
        ≃∎

  Leibnizᵈᶠ≃-family-cod-null-homotopy
    : (fp : fst ΠΣ)
    → (ax : Σ A X)
    → null-homotopy (fp .snd ax) ≃ null-homotopy (Leibnizᵈᶠ-family-null-homotopy-at-uncurry fp ax)
  Leibnizᵈᶠ≃-family-cod-null-homotopy fp (a , x)
    = null-homotopy (fp .snd (a , x))
      ≃⟨ Σ-ap-≃ (Leibnizᵈᶠ≃-family-cod-main fp a x) ⟩
      (Σ[ l ∶ V a x (fp .fst (a , x)) ]
        Σ[ r ∶ ((y : Y a x) → fp .snd (a , x) (ι₂ y) ＝ l) ]
          ((b : B a) → Leibnizᵈᶠ-family-null-homotopy-at-uncurry fp (a , x) b ＝ (l , r)))
      ≃⟨ Σ-assoc e⁻¹ ⟩
      null-homotopy (Leibnizᵈᶠ-family-null-homotopy-at-uncurry fp (a , x))
      ≃∎

  Leibnizᵈᶠ≃-family-currying-swap-arguments
    : (fp : fst ΠΣ)
    → (a : A)
    → (m : (x : X a) → null-homotopy (fp .snd (a , x) ∘ ι₂))
    → (((x : X a) (b : B a) → Leibnizᵈᶠ-family-null-homotopy-at-uncurry fp (a , x) b ＝ m x))
    ≃ (((b : B a) → Leibnizᵈᶠ-family-null-homotopy-at-curry fp a b ＝ m))
  Leibnizᵈᶠ≃-family-currying-swap-arguments fp a m
    = (((x : X a) (b : B a) → Leibnizᵈᶠ-family-null-homotopy-at-uncurry fp (a , x) b ＝ m x))
      ≃⟨ flip≃ ⟩
      ((b : B a) (x : X a) → Leibnizᵈᶠ-family-null-homotopy-at-uncurry fp (a , x) b ＝ m x)
      ≃⟨ Π-ap-≃ (λ b → funext≃ e⁻¹) ⟩
      ((b : B a) → Leibnizᵈᶠ-family-null-homotopy-at-curry fp a b ＝ m)
      ≃∎

  Leibnizᵈᶠ≃-family-currying-at
    : (fp : fst ΠΣ)
    → (a : A)
    → ((x : X a) → null-homotopy (Leibnizᵈᶠ-family-null-homotopy-at-uncurry fp (a , x)))
    ≃ null-homotopy (Leibnizᵈᶠ-family-null-homotopy-at-curry fp a)
  Leibnizᵈᶠ≃-family-currying-at fp a
    = ((x : X a) → null-homotopy (Leibnizᵈᶠ-family-null-homotopy-at-uncurry fp (a , x)))
      ≃⟨ Σ-Π-swap≃ _ _ ⟩
      (Σ[ g ∶ ((x : X a) → null-homotopy (fp .snd (a , x) ∘ ι₂)) ]
        ((x : X a) (b : B a) → Leibnizᵈᶠ-family-null-homotopy-at-uncurry fp (a , x) b ＝ g x))
      ≃⟨ Σ-ap-≃ (Leibnizᵈᶠ≃-family-currying-swap-arguments fp a) ⟩
      null-homotopy (Leibnizᵈᶠ-family-null-homotopy-at-curry fp a)
      ≃∎

  Leibnizᵈᶠ≃-family-currying
    : (fp : fst ΠΣ)
    → ((ax : Σ A X) → null-homotopy (Leibnizᵈᶠ-family-null-homotopy-at-uncurry fp ax))
    ≃ ((a : A) → null-homotopy (Leibnizᵈᶠ-family-null-homotopy-at-curry fp a))
  Leibnizᵈᶠ≃-family-currying fp
    = ((ax : Σ A X) → null-homotopy (Leibnizᵈᶠ-family-null-homotopy-at-uncurry fp ax))
      ≃⟨ curry≃ ⟩
      ((a : A) (x : X a) → null-homotopy (Leibnizᵈᶠ-family-null-homotopy-at-uncurry fp (a , x)))
      ≃⟨ Π-ap-≃ (Leibnizᵈᶠ≃-family-currying-at fp) ⟩
      ((a : A) → null-homotopy (Leibnizᵈᶠ-family-null-homotopy-at-curry fp a))
      ≃∎

  Leibnizᵈᶠ≃-family
    : (fp : fst ΠΣ)
    → snd ΠΣ fp ≃ snd Π² (Π̂Π̂ᶠ←Π̂Σ̂ᶠ-base fp)
  Leibnizᵈᶠ≃-family fp
    = snd ΠΣ fp
      ≃⟨ Π-ap-≃ (Leibnizᵈᶠ≃-family-cod-null-homotopy fp) ⟩
      ((ax : Σ A X) → null-homotopy (Leibnizᵈᶠ-family-null-homotopy-at-uncurry fp ax))
      ≃⟨ Leibnizᵈᶠ≃-family-currying fp ⟩
      snd Π² (Π̂Π̂ᶠ←Π̂Σ̂ᶠ-base fp)
      ≃∎

  Leibnizᵈᶠ≃ : ΠΣ ≃ᶠ Π²
  Leibnizᵈᶠ≃ = Leibnizᵈᶠ≃-base , Leibnizᵈᶠ≃-family
}
%```
}

\subtree[fre-0007]{
\taxon{Corollary}
\title{The nondependent Leibniz adjunction for families}

\p{
For all triples of type families #{B : A \to \UU}, #{Y : X(a) \to \UV}, and
#{V : U(a, x) \to \UW}, we have an equivalence of families
##{\pullpow{B \pushprod Y}{V} \simeq \pullpow{B}{\pullpow{Y}{V}}.}
}

%```agda
\agda{
module _
  {𝓤1 𝓤2 𝓤3 𝓤4 𝓤5 𝓤6 : Level}
  (F : Fam 𝓤1 𝓤2)
  (G : Fam 𝓤3 𝓤4)
  (H : Fam 𝓤5 𝓤6)
  where

  Leibnizᶠ≃ : ⟨(F □ᶠ G) ,ᶠ H ⟩ ≃ᶠ ⟨ F ,ᶠ ⟨ G ,ᶠ H ⟩ ⟩
  Leibnizᶠ≃ = Leibnizᵈᶠ≃ F (Fam→DepFam F G) (Fam→Dep²Fam F G H)
}
%```
}

\subtree[fre-0008]{
\taxon{Corollary}
\title{The dependent Leibniz adjunction for arrows}

\p{
For all [arrows](fre-0001) #{f : A \to B}, dependent arrows
#{g : (b : B) \to X(b) \to Y(b)} and doubly dependent arrows
#{h : (b : B)\,(y : Y(b)) \to U(b, y) \to V(b, y)}, we have an
[equivalence of arrows](stt-004R)
##{
\pulldpow_{\pushsum_f g} ((b,y) \mapsto h(b, y))
\simeq \pulldpow_f {(b \mapsto \pulldpow_{g(b)} h(b))}.
}
}

%```agda
\agda{
module _
  {𝓤1 𝓤2 𝓤3 𝓤4 𝓤5 𝓤6 : Level}
  {A : Type 𝓤1}
  {B : Type 𝓤2}
  (f : A → B)
  {X : B → Type 𝓤3}
  {Y : B → Type 𝓤4}
  (g : (b : B) → X b → Y b)
  {U : (b : B) → Y b → Type 𝓤5}
  {V : (b : B) → Y b → Type 𝓤6}
  (h : (b : B) (y : Y b) → U b y → V b y)
  (let h-uncurry = λ (b , y) → h b y)
  (let F = fibre-fam f)
  (let G = fibre-depfam g)
  (let H = fibre-dep²fam h)
  (let Π̂Σ̂ᶠ-fibre-fam = Π̂Σ̂ᶠ F G H)
  (let Π̂Π̂ᶠ-fibre-fam = Π̂Π̂ᶠ F G H)
  where

  Π̂Σ̂-bridge≃
    : Arrow-equiv
        (Π̂Σ̂ f g h)
        (arrow←Fam Π̂Σ̂ᶠ-fibre-fam)
  Π̂Σ̂-bridge≃
    = Π̂-Arrow-equiv←≃ᶠ
        (Σ̂ f g)
        (h-uncurry)
        (Π̂Σ̂ᶠ-fibre-fam)
        (Π̂ᶠ-ap-base-fam (fibre-depfam h-uncurry) (Σ̂-unstraighten≃ᶠ f g .snd))

  Π̂Π̂-bridge≃
    : Arrow-equiv
        (Π̂Π̂ f g h)
        (arrow←Fam Π̂Π̂ᶠ-fibre-fam)
  Π̂Π̂-bridge≃
    = Π̂-Arrow-equiv←≃ᶠ
        (f)
        (λ b → Π̂ (g b) (h b))
        (Π̂Π̂ᶠ-fibre-fam)
        (Π̂ᶠ-ap-≃ᵈᶠ
          (F)
          (fibre-depfam (λ b → Π̂ (g b) (h b)))
          (Π̂ᵈᶠ F G H)
          (λ b → Π̂-fibre-fam≃Π̂ᶠ-unstraight-fibre-fam (g b) (h b)))

  Leibnizᵈ≃ : Arrow-equiv (Π̂Σ̂ f g h) (Π̂Π̂ f g h)
  Leibnizᵈ≃
    = concat-Arrow-equiv
        (concat-Arrow-equiv
          (Π̂Σ̂-bridge≃)
          (Arrow-equiv←≃ᶠ
            (Π̂Σ̂ᶠ-fibre-fam)
            (Π̂Π̂ᶠ-fibre-fam)
            (Leibnizᵈᶠ≃ F G H)))
        (inv-Arrow-equiv Π̂Π̂-bridge≃)
}
%```
}

\subtree[fre-0009]{
\taxon{Corollary}
\title{The nondependent Leibniz adjunction for arrows}

\p{
For all triples of [arrows](fre-0001) #{f : A \to B}, #{g : X \to Y}, and
#{h : U \to V}, we have an [equivalence of arrows](stt-004R)
##{\pullpow{f \pushprod g}{h} \simeq \pullpow{f}{\pullpow{g}{h}}.}
}

%```agda
\agda{
module _
  {𝓤1 𝓤2 𝓤3 𝓤4 𝓤5 𝓤6 : Level}
  {A : Type 𝓤1} {B : Type 𝓤2} (f : A → B)
  {C : Type 𝓤3} {D : Type 𝓤4} (g : C → D)
  {E : Type 𝓤5} {F : Type 𝓤6} (h : E → F)
  where

  Leibniz≃ : Arrow-equiv ⟨ (f □ g) , h ⟩ ⟨ f , ⟨ g , h ⟩ ⟩
  Leibniz≃ = Leibnizᵈ≃ f (λ _ → g) (λ _ _ → h)
}
%```
}

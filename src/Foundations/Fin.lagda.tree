\subtree[fre-002R]{
\title{Fin}
\taxon{Definition}
\author{fredrikbakke}
\contributor{samueltoth}

\p{
The \em{standard finite type} of order #{n}, #{\Fin n}, is an inductive type with
precisely #{n} elements.
}

\agda{
data Fin : ‚Ñï ‚Üí Type where
  fzero : {n : ‚Ñï} ‚Üí Fin (suc n)
  fsuc : {n : ‚Ñï} ‚Üí Fin n ‚Üí Fin (suc n)

Fin‚Üê‚Ñï : (m n : ‚Ñï) ‚Üí m <‚Ñï n ‚Üí Fin n
Fin‚Üê‚Ñï m 0 ()
Fin‚Üê‚Ñï 0 (suc n) _ = fzero
Fin‚Üê‚Ñï (suc m) (suc n) p = fsuc (Fin‚Üê‚Ñï m n p)

‚Ñï‚ÜêFin : {n : ‚Ñï} ‚Üí Fin n ‚Üí ‚Ñï
‚Ñï‚ÜêFin fzero = zero
‚Ñï‚ÜêFin (fsuc x) = suc (‚Ñï‚ÜêFin x)

Fin-0-is-empty : ¬¨ Fin 0
Fin-0-is-empty ()

Fin-1-is-single : is-singleton (Fin 1)
Fin-1-is-single = mk-singl fzero Œª where
  fzero ‚Üí refl
  (fsuc ())
}
}

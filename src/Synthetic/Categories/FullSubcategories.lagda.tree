\subtree[stt-2718281828]{
\title{Full subcategories}

\p{To write.}

\agda{
module _ {@♭ 𝓤 𝓥} {@♭ A : Type 𝓤} (S : Subtype ⟨♭| A ⟩ 𝓥) where

  full-subcat : Type (𝓤 ⊔ 𝓥)
  full-subcat = Σ A (λ a → ⟨♯| (S .Subtype.family) (mod♭ a) ⟩)

  full-subcat-incl : full-subcat → A
  full-subcat-incl = fst

  full-subcat-family : (a : A) → Type 𝓥
  full-subcat-family a = ⟨♯| (S .Subtype.family) (mod♭ a) ⟩

  is-prop-full-subcat-family : (a : A) → is-prop (full-subcat-family a)
  is-prop-full-subcat-family a x y = modext♯ (mod♯ (S .Subtype.family-is-subtype (mod♭ a) (x .counit♯) (y .counit♯)) )

}
}

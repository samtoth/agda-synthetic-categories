\subtree[stt-00E0]{
\title{Bi-pointed wedge sum}
\taxon{Definition}

\p{We extend the definition of [Wedge sum](stt-00E9) to the case of maps out of
the boundary of #{\Delta^1}. Given a type #{A}, equipped with
maps from #{\partial \Delta^1}, we call the source and target points #{A_s} and
#{A_t} repetitively. Given a pair of such types #{A} and #{B}, we say that their
wedge sum is the wedge sum #{A_t \vee B_s}, glueing the target of the first to
the source of the second. This is itself a bi-pointed type with src #{A_s} and
target #{B_t}.}

\p{We also remark that #{-\vee-} determines a bifunctor
##{\Type_{\partial\Delta^1 /} \times \Type_{\partial \Delta^1 /}
\to \Type_{\partial \Delta^1 /}}
}

%```agda
\agda{
∂Δ¹-Wedge : ∀ {𝓤 𝓥} {A : Type 𝓤} {B : Type 𝓥}
              (a : ∂Δ¹ → A) (b : ∂Δ¹ → B)
            → Σ[ X ∶ Type (𝓤 ⊔ 𝓥) ] (∂Δ¹ → X)
∂Δ¹-Wedge {A = A} {B} a b .fst = Pushout {A = 𝟙} (λ _ → a ∂Δ¹-1) (λ _ → b ∂Δ¹-0)
∂Δ¹-Wedge {A = A} {B} a b .snd = ∂Δ¹-UP→ (ι₁ (a ∂Δ¹-0) , ι₂ (b ∂Δ¹-1))

∂Δ¹-Wedge-map
  : ∀ {𝓤 𝓥 𝓦 𝓜} {A : Type 𝓤} {B : Type 𝓥} {A' : Type 𝓦} {B' : Type 𝓜}
      (a : ∂Δ¹ → A) (b : ∂Δ¹ → B) (a' : ∂Δ¹ → A') (b' : ∂Δ¹ → B')
    → Coslice-map a a' → Coslice-map b b'
    → Coslice-map (∂Δ¹-Wedge a b .snd) (∂Δ¹-Wedge a' b' .snd)
∂Δ¹-Wedge-map a b a' b' F G .fst
  = Pushout₁
      (mk-span-map
        (F .fst) id (G .fst)
        (λ _ → F .snd ∂Δ¹-1)
        (λ _ → G .snd ∂Δ¹-0))
∂Δ¹-Wedge-map a b a' b' F G .snd (mk-lift true)
  = ap ι₂ (G .snd ∂Δ¹-1)
∂Δ¹-Wedge-map a b a' b' F G .snd (mk-lift false)
  = ap ι₁ (F .snd ∂Δ¹-0)
}
%```

\p{Finally, we remark that this functor preserves inner anodyne maps.}

%```agda
\agda{
wedge-map-is-inner-anodyne
  : ∀ {𝓤 𝓥 𝓦 𝓜} {A : Type 𝓤} {B : Type 𝓥} {A' : Type 𝓦} {B' : Type 𝓜}
      (a : ∂Δ¹ → A) (b : ∂Δ¹ → B) (a' : ∂Δ¹ → A') (b' : ∂Δ¹ → B')
      (F : Coslice-map a a') (G : Coslice-map b b')
    → is-inner-anodyne (F .fst) → is-inner-anodyne (G .fst)
    → is-inner-anodyne (∂Δ¹-Wedge-map _ _ _ _ F G .fst)
wedge-map-is-inner-anodyne a b a' b' F G fia gia {U = U} {V} k ik
  = left-orthogonal-pushout₁
      (extend-coslice-map _ _ (const _ _ ∂Δ¹-1) F )
      (extend-coslice-map _ _ (const _ _ ∂Δ¹-0) G)
      k
      (fia  k ik)
      (gia k ik)
}
%```
}

\subtree[stt-00E4]{
\title{Spines}
\taxon{Definition}

\p{We construct the #{n}-spine, written #{\II_n}, as the result of gluing
#{n} copies of the interval end-to-end. By convention, #{\II_0} is the unit type,
and #{\II_1} is #{\Delta^1}. We also remark that the 2-spine #{\II_2} is
definitionally equal to the bespoke definition we already gave in the form
of the [inner horn](stt-00AD).}

%```agda
\agda{
Spine-coslice : ℕ → Σ[ X ∶ Type 𝓘 ] (∂Δ¹ → X)
Spine-coslice zero = (ULift 𝓘 𝟙 , mk-lift ∘ !)
Spine-coslice (suc zero) = (Δ¹ , ∂Δ¹-incl)
Spine-coslice (suc (suc n)) = ∂Δ¹-Wedge (Spine-coslice (suc n) .snd) ∂Δ¹-incl

Spine : ℕ → Type 𝓘
Spine = fst ∘ Spine-coslice

spine-agrees-[2,1]-horn : Spine-coslice 2 .snd ~ ∂Λ[2,1]-incl
spine-agrees-[2,1]-horn = ∂Δ¹-UP→ (refl , refl)
}
%```

\p{We show that there is an inclusion of the spine into the #{n}-cube, and
that this inclusion factors through #{\Delta^n}}

%```agda
\agda{
Spine-is-2-truncated : ∀ {n} → is-truncated 2 (Spine n)
Spine-is-2-truncated {zero} = trunc!
Spine-is-2-truncated {suc zero} = trunc!
Spine-is-2-truncated {suc (suc n)}
  = Wedge-is-2-truncated (Spine-is-2-truncated {suc n}) trunc!

Spine-is-set : ∀ {n} → is-set (Spine n)
Spine-is-set {n} = is-set←is-truncated (Spine-is-2-truncated {n})

Spine-incl-□ : ∀ {n} → Spine n → □^ n
Spine-incl-□ {zero} = id
Spine-incl-□ {suc zero} = id
Spine-incl-□ {suc (suc n)} = (Spine-incl-□ ⊗1 Δ¹) ∘ Wedge-embed

Spine-incl : ∀ {n} → Spine n → Δ^ n
Spine-top : ∀ {n} → Δ-path (Spine-incl (Spine-coslice n .snd ∂Δ¹-1)) (Δ-1 {n})

Spine-incl {zero} s = ·
Spine-incl {suc zero} i = (· :≥: i)
Spine-incl {suc (suc n)} = cogap
  (mk-cocone
    (λ s → Spine-incl s :≥: i0)
    (λ i → Δ-1 :≥: i)
    λ _ → Δ-ext (Spine-top :≥: refl))

Spine-top {zero} = ·
Spine-top {suc zero} = · :≥: refl
Spine-top {suc (suc n)} = Δ-refl :≥: refl :≥: refl

Spine-bot : ∀ {n} → Δ-path (Spine-incl (Spine-coslice n .snd ∂Δ¹-0)) (Δ-0 {n})
Spine-bot {zero} = ·
Spine-bot {suc zero} = · :≥: refl
Spine-bot {suc (suc zero)} = · :≥: refl :≥: refl
Spine-bot {suc (suc (suc n))} = Spine-bot :≥: refl :≥: refl

∂Δ^_ : ∀ n → ∂Δ¹ → Δ^ n
(∂Δ^ n) (mk-lift true) = Δ-1
(∂Δ^ n) (mk-lift false) = Δ-0

∂Δ¹-Spine-incl : ∀ n → Coslice-map (Spine-coslice n .snd) (∂Δ^ n)
∂Δ¹-Spine-incl n .fst = Spine-incl
∂Δ¹-Spine-incl n .snd (mk-lift true ) = Δ-ext Spine-top
∂Δ¹-Spine-incl n .snd (mk-lift false) = Δ-ext Spine-bot

□←Δ : ∀ {n} → Δ^ n → □^ n
□←Δ · = _
□←Δ (· :≥: j) = j
□←Δ (x :≥: i :≥: j) = □←Δ (x :≥: i) , j
}
%```
}


\subtree[stt-00E5]{
\taxon{Lemma}
\p{#{\Delta^{n + 2}} is a retract of #{\square^n \times \Delta^2}}

\p{We extend the obvious embedding #{\Delta^n \to \square^n}, to the map that
just forgets the first #{n} inequalities and preserves the latter two. The
retraction is defined as follows:
##{(\bar{i}, j \geq k) : \square^n \times \Delta^2 \mapsto
((\bigvee_{n} i_n \vee j) ≥ ... \ge (i_n \vee j) \ge j \ge k)}
It is a retraction since if #{i_n} were ordered in the first place, then taking
these successive joins would have no effect.
}

%```agda
\agda{
mutual
  Δ←□ : ∀ {n} → □^ n → Δ¹ → Δ^ n
  Δ←□-≤ : ∀ {n} (x : □^ n) i → i ≤ last-Δ (Δ←□ x i)

  Δ←□ {zero} x j = ·
  Δ←□ {suc zero} x j = · :≥: x ∨ j
  Δ←□ {suc (suc n)} (x , i) j = (Δ←□ x (i ∨ j) :≥: i ∨ j) ⦃ Δ←□-≤ x (i ∨ j) ⦄

  Δ←□-≤ {zero} x i = auto!
  Δ←□-≤ {suc zero} x i = ∨-≤-intror auto!
  Δ←□-≤ {suc (suc n)} x i = ∨-≤-intror auto!

Δ←□-1 : ∀ {n} (x : □^ n) {i} → (i ＝ i1) → Δ-path (Δ←□ x i) Δ-1
Δ←□-1 {zero} x _ = ·
Δ←□-1 {suc zero} x refl = · :≥: (≤-max auto!)
Δ←□-1 {suc (suc n)} (x , i) refl
  = Δ←□-1 {suc n} x (≤-max auto!) :≥: (≤-max auto!)

include-Δ-n+2 : ∀ {n} → Δ^ (n + 2) → □^ n × Δ²
include-Δ-n+2 (x :≥: i :≥: j) = □←Δ x , (i , j)

ret-Δ-n+2 : ∀ {n} → □^ n × Δ² → Δ^ (n + 2)
ret-Δ-n+2 (x , (i , j)) = ((Δ←□ x i :≥: i) ⦃ Δ←□-≤ x i ⦄ :≥: j)

□←Δ-ret : ∀ {n} (p : Δ^ n) i ⦃ k : i ≤ last-Δ p ⦄ → Δ-path (Δ←□ (□←Δ p) i) p
□←Δ-ret · i = ·
□←Δ-ret (· :≥: j) i = · :≥: ∨-comm ∙ ≤-max auto!
□←Δ-ret (p :≥: i :≥: j) k
  = □←Δ-ret (p :≥: i) (j ∨ k) ⦃ ∨-UP (auto! , (≤-trans {b = j}auto! auto!)) ⦄
  :≥: (∨-comm ∙ ≤-max auto!)

is-ret-Δ-□ : ∀ {n} → ret-Δ-n+2 {n} ∘ include-Δ-n+2 ~ id
is-ret-Δ-□ (p :≥: i :≥: j) = Δ-ext (□←Δ-ret p i :≥: refl :≥: refl)

Δ←Δ² : Δ² → Δ^ 2
Δ←Δ² (i , j) = (· :≥: i :≥: j)

Δ←Δ²-is-equiv : is-equiv Δ←Δ²
Δ←Δ²-is-equiv = is-equiv←qiso
  ( (λ { (· :≥: i :≥: j) → (i , j) })
  , (λ { (i , j) → refl})
  , λ { (· :≥: i :≥: j) → Δ-ext (· :≥: refl :≥: refl)})
}
%```
}

\subtree[stt-00E6]{
\taxon{Theorem}
\title{Spine lifting}
\date{2026-02-04}

\p{For all #{n \ge 2}, the inclusion #{\II_n \hookrightarrow \Delta^n} is inner
anodyne.}

\proof{
We proceed by induction on #{n}. The base case is trivial, so we need to show
that the map #{\II_{n + 1} \to \Delta^{n + 1}} is inner anodyne. Firstly,
we note that we can factorise this map as follows:

##{\II_{n} \vee \Delta^1 \to \Delta^n \vee \Delta^1 \to \Delta^{n+1}}

By the induction hypothesis and [closure properties of left orthogonal
maps](stt-00E7), we have the first map is inner anodyne. To show the second
map is inner anodyne, we show it is a retraction of
#{\square^{n-1} \times \Lambda^2_1 \to \square^{n-1} \times \Delta^2}, which is
trivially left anodyne by closure of orthogonal maps under products. The
retraction is a pair of squares as follows:

\quiver{
\begin{tikzcd}
	{\Delta^n\vee\Delta^1} && {\square^{n-1}\times\Lambda^2_1} && {\Delta^n\vee\Delta^1} \\
	\\
	{\Delta^{n+1}} && {\square^{n-1}\times\Delta^2} && {\Delta^{n+1}}
	\arrow[hook, from=1-1, to=1-3]
	\arrow[hook, from=1-1, to=3-1]
	\arrow[two heads, from=1-3, to=1-5]
	\arrow[hook, from=1-3, to=3-3]
	\arrow[hook, from=1-5, to=3-5]
	\arrow[hook, from=3-1, to=3-3]
	\arrow[two heads, from=3-3, to=3-5]
\end{tikzcd}
}

\p{\ref{stt-00E5} gives the bottom maps. It is clear that this retraction should
restrict to the appropriate subtypes.}

}

%```agda
\agda{
spine-incl-factor-1 : ∀ n → ∂Δ¹-Wedge (∂Δ^ n) ∂Δ¹-incl .fst → Δ^ (suc n)
spine-incl-factor-1 n
  = cogap (mk-cocone (λ x → x :≥: i0) (λ i → (Δ-1 :≥: i)⦃ Δ-1-≤ {n = n} ⦄)
           λ a → Δ-ext (Δ-refl :≥: refl))

spine-incl-factor-2 : ∀ n → Spine (suc n) → ∂Δ¹-Wedge (∂Δ^ n) ∂Δ¹-incl .fst
spine-incl-factor-2 zero i = ι₂ i
spine-incl-factor-2 (suc n) = ∂Δ¹-Wedge-map
                        (Spine-coslice (suc n) .snd) ∂Δ¹-incl
                        (∂Δ^ (suc n)) ∂Δ¹-incl
                        (Spine-incl ,
                        (λ {
                          (mk-lift true ) → Δ-ext Spine-top
                        ; (mk-lift false) → Δ-ext Spine-bot}))
                        (id , ~refl) .fst

private
  factorisation
    : ∀ n → spine-incl-factor-1 n ∘ spine-incl-factor-2 n ~ Spine-incl {suc n}
  factorisation zero = ~refl
  factorisation (suc n) = pushout-rec-unique _ _
    ~refl ~refl λ _ → prop!

opaque
  fat-spine-lifts
    : ∀ {n} → is-inner-anodyne (spine-incl-factor-1 (suc n))
  fat-spine-lifts {n} f finn
    = left-orthogonal-retraction
        (spine-incl-factor-1 (suc n)) _
        (amap2 n) (amap2-ret n)
        f (incl-mid-inner-anodyne f finn) where
    incl-mid : ∀ n → □^ n × Λ[2,1] → □^ n × Δ²
    incl-mid n = (□^ n) 1⊗ Λ[2,1]-incl

    incl-mid-inner-anodyne : ∀ {n} → is-inner-anodyne (incl-mid n)
    incl-mid-inner-anodyne k = left-orthogonal-× id Λ[2,1]-incl k (id⊥ k)

    amap2 : ∀ n → Arrow-map (spine-incl-factor-1 (suc n)) (incl-mid n)
    amap2 n .Arrow-map.top = cogap
      (mk-cocone
        (λ { (x :≥: i) → (□←Δ x , ι₁ i)})
        (λ i → □←Δ Δ-1 , ι₂ i)
        λ a → ×-path→ (refl , glue tt))
    amap2 n .Arrow-map.bot = include-Δ-n+2
    amap2 n .Arrow-map.comm = pushout-ind _
      (mk-coconeᵈ
        (λ { (x :≥: j) → refl})
        ~refl
        λ _ → is-set←is-truncated
                (×-is-truncated (□-is-truncated trunc!) Δ²-is-2-truncated)
                _ _ _ _)

    amap2-ret : ∀ n → retraction-arrow-map (amap2 n)
    amap2-ret n .fst .Arrow-map.top = uncurry (λ x → cogap
      (mk-cocone
        (λ i → ι₁ ((Δ←□ x i :≥: i) ⦃ Δ←□-≤ x i ⦄))
        (λ i → ι₂ i)
        λ _ → ap ι₁ (Δ-ext (Δ←□-1 x refl :≥: refl)) ∙ glue tt))
    amap2-ret n .fst .Arrow-map.bot = ret-Δ-n+2
    amap2-ret n .fst .Arrow-map.comm = uncurry (λ x → pushout-ind _
      (mk-coconeᵈ
        ~refl
        (λ i → Δ-ext (Δ←□-1 x refl :≥: refl :≥: refl))
        λ _ → prop!))
    amap2-ret n .snd .fst = pushout-ind _
      (mk-coconeᵈ
        (λ { (l :≥: j) → ap ι₁ (Δ-ext (□←Δ-ret l j :≥: refl))})
        ~refl
        λ _ → prop!)
    amap2-ret n .snd .snd .fst = is-ret-Δ-□
    amap2-ret n .snd .snd .snd x = prop!

opaque
  Spine-lifting : ∀ n → is-inner-anodyne (Spine-incl {suc (suc n)})
  Spine-lifting zero k ko
    = left-orthogonal-equiv
       Λ[2,1]-incl Spine-incl
       (mk-amap id (λ where (i , j) → · :≥: i :≥: j)
       (pushout-ind _
         (mk-coconeᵈ ~refl ~refl
           (λ _ → prop!))))
       (id-is-equiv , Δ←Δ²-is-equiv)
       k ko
  Spine-lifting (suc n)
    = is-anodyne-homotopy
        {f = spine-incl-factor-1 (n + 2) ∘ spine-incl-factor-2 (n + 2)}
        {g = Spine-incl}
        Λ[2,1]-incl
        (factorisation (n + 2))
        (is-anodyne-∘
          {f = spine-incl-factor-1 (n + 2)}
          {g = spine-incl-factor-2 (n + 2)}
          Λ[2,1]-incl
          fat-spine-lifts
          (wedge-map-is-inner-anodyne
            (Spine-coslice (suc (suc n)) .snd) ∂Δ¹-incl
            (∂Δ^ (n + 2)) ∂Δ¹-incl
            (∂Δ¹-Spine-incl (n + 2))
            (id , ~refl)
            (Spine-lifting n)
            λ k _ → id⊥ k))
}
%```
}

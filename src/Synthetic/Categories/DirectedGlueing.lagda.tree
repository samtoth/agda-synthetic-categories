\title{Directed glueing types}
\author{samueltoth}
\date{2026-06-04}
\taxon{Module}
\import{stt-macros}

\agda{
open import Foundations.Universes
open import Foundations.Identity
open import Foundations.Empty
open import Algebra.Lattice
open import Synthetic.Quasicoherence

module Synthetic.Categories.DirectedGlueing
  {𝓘} (Δ¹ : Type 𝓘) (I : Lattice Δ¹) (I-distr : is-distributive I)
  (open Lattice I renaming (0l to i0; 1l to i1))
  (non-triv : i1 ＝ i0 → ∅)
  (phoa : Δ¹-endos-are-mono Δ¹ I I-distr)
  where

open import Axioms.UF
}

\agda-imports{
\agda{
open import Foundations.Prelude

open import Ergonomics.Extensionality
open import Ergonomics.Auto

open import Modalities.Instances.Truncation

open import Core.Arrows
open import Core.ArrowEquiv

open import Algebra.Lattice.Instances.Free.Inductive Δ¹ I

open import Synthetic.Hom Δ¹ i0 i1
open import Synthetic.Boundaries Δ¹ I
open import Synthetic.Categories.CovariantFamilies Δ¹ I
open import Synthetic.Categories.CovariantClosure Δ¹ I I-distr
}
}

\subtree[tot-L001]{
\p{Define #{\textrm{Cov}(F,G)} to be the type of morphisms...}
\agda{
Cov-map
  : ∀ {𝓤 𝓥} {B : Type 𝓤} (F : B → Type 𝓥) (G : B → Type 𝓥) → Type (𝓘 ⊔ 𝓤 ⊔ lsuc 𝓥)
Cov-map {_}{𝓥}{B} F G
  = Σ[ α ∶ Hom (B → Type 𝓥) F G ]
       is-covariant (uncurry (α .Homᵈ.hom))
}
}

\subtree[tot-L002]{
\title{The glueing of a fibrewise map}
\taxon{Contruction}

\p{Given a pair of type families #{F\ G : B \to \Type} and a fibrewise map
#{\alpha_b F_b \to G_b}, then we construct the glueing family
#{\textrm{Gl}(\alpha) : B \times \Delta^1 \to \Type}.
##{\textrm{Gl}(\alpha)(b, i) := \Sigma_{g : G_b} i = 0 \to \fibre{\alpha_b}{g}}}

\agda{
Gl : ∀ {𝓤 𝓥} {B : Type 𝓤} (F : B → Type 𝓥) (G : B → Type 𝓥)
     → (α : ∀ b → F b → G b) → B × Δ¹ → Type (𝓘 ⊔ 𝓥)
Gl F G α (b , i) = Σ[ a ∶ G b ] ((i ＝ i0) → fibre (α b) a)
}

\p{#{\textrm{Gl}(\alpha)(b,0) = F(b)} and #{\textrm{Gl}(\alpha)(b,1) = G(b)}}

\agda{
Gl-0
  : ∀ {𝓤 𝓥} {B : Type 𝓤} (F : B → Type 𝓥) (G : B → Type 𝓥) (α : ∀ b → F b → G b)
    → ∀ b → Gl F G α (b , i0) → F b
Gl-0 F G α b = fst ∘ ev refl ∘ snd

Gl-0-is-equiv
  : ∀ {𝓤 𝓥} {B : Type 𝓤} (F : B → Type 𝓥) (G : B → Type 𝓥) (α : ∀ b → F b → G b)
    → is-fibrewise-equiv (Gl-0 F G α)
Gl-0-is-equiv F G α b
  = is-equiv-∘
      (total≃total-fibre _ ._≃_.fwd-is-equiv)
      (is-total-equiv←is-fibrewise-equiv
        (λ _ → sing-ev-is-equiv global-funext
                 (mk-singl refl (J-set! _ refl))))

Gl-1
  : ∀ {𝓤 𝓥} {B : Type 𝓤} (F : B → Type 𝓥) (G : B → Type 𝓥) (α : ∀ b → F b → G b)
    → ∀ b → Gl F G α (b , i1) → G b
Gl-1 F G α b = fst

Gl-1-is-equiv
  : ∀ {𝓤 𝓥} {B : Type 𝓤} (F : B → Type 𝓥) (G : B → Type 𝓥) (α : ∀ b → F b → G b)
    → is-fibrewise-equiv (Gl-1 F G α)
Gl-1-is-equiv F G α b = singleton-fst-is-equiv (λ _ → Π-is-single (¡ ∘ non-triv))
}

\p{We may also define a map from
#{\textrm{Gl}(\alpha)(0,b) \to \textrm{Gl}(\alpha)(1,b)}, which is equivalent as a
map to #{\alpha_b}.}

\agda{
module _
  {𝓤 𝓥}{B : Type 𝓤} {F G : B → Type 𝓥} (α : ∀ b → F b → G b)
  where

  Gl-map : ∀ b → Gl F G α (b , i0) → Gl F G α (b , i1)
  Gl-map b = total-map (λ a → precomp-Π _ (¡ ∘ non-triv))

  Gl-naturality : ∀ b → Arrow-equiv (Gl-map b) (α b)
  Gl-naturality b .fst .Arrow-Π.top  = Gl-0 F G α b
  Gl-naturality b .fst .Arrow-Π.bot  = Gl-1 F G α b
  Gl-naturality b .fst .Arrow-Π.comm = sym ∘ snd ∘ ev refl ∘ snd
  Gl-naturality b .snd .fst = Gl-0-is-equiv F G α b
  Gl-naturality b .snd .snd = Gl-1-is-equiv F G α b
}
}

\subtree[tot-L003]{
\title{Covariance of the directed glueing}
\taxon{Lemma}

\p{If #{F} and #{G} are covariant families over #{B}, then the directed glueing of any
map #{\alpha} is also covariant over #{B \times \Delta^1}.}

\agda{
opaque
  Gl-is-covariant
    : ∀ {𝓤 𝓥} {B : Type 𝓤}
        (F : B → Type 𝓥) (G : B → Type 𝓥) (α : ∀ b → F b → G b)
      → is-covariant F → is-covariant G
      → is-covariant (Gl F G α)
  Gl-is-covariant {B = B} F G α Fc Gc
    = Σ-is-covariant
        {B = G ∘ fst}
        {C = λ bi a → (bi .snd ＝ i0) → fibre (α (bi .fst)) a}
        (covariant-base-change {P = G} (fst: λ _ → Δ¹) Gc)
        (covariant-base-change
          {P = λ x → x .snd ＝ i0
                   → fibre (α (x .fst .fst)) (x .fst .snd)}
          (λ ((b , i) , g) → ((b , g) , i))
          (exp-●-is-covariant
            phoa
            (uncurry (λ b g → fibre (α b) g) ∘ fst)
            (covariant-base-change
              {P = uncurry (λ b g → fibre (α b) g)}
              fst
              (fibre-is-covariant _ _ Fc Gc α))
            snd))
}
}


\subtree[stt-00KF]{
\title{Paths in Glue types}
\taxon{Lemma}

\agda{
Gl-path
  : ∀ {𝓤 𝓥}{B : Type 𝓤} {F G : B → Type 𝓥} {f : ∀ b → F b → G b} i
    → Gl F G f i → Gl F G f i → Type (𝓘 ⊔ 𝓥)
Gl-path {B = B}{F}{G}{f} (b , i) x y
  = Σ[ p ∶ x .fst ＝ y .fst ]
     (∀ pi → Σ[ q ∶ x .snd pi .fst ＝ y .snd pi .fst ]
               (Square (x .snd pi .snd) (y .snd pi .snd) (ap (f b) q) p))

Gl-path-refl
  : ∀ {𝓤 𝓥}{B : Type 𝓤} {F G : B → Type 𝓥} {f : ∀ b → F b → G b} i
    → (x : Gl F G f i) → Gl-path {B = B}{F}{G}{f} i x x
Gl-path-refl i x = (refl , (λ pi → refl , Square-degen-hor _ _ refl))

opaque
  Gl-path-is-torsorial
    : ∀ {𝓤 𝓥}{B : Type 𝓤} {F G : B → Type 𝓥} {f : ∀ b → F b → G b} i
      → (x : Gl F G f i) → is-singleton (Σ _ (Gl-path {B = B}{F}{G}{f} i x))
  Gl-path-is-torsorial i x
    = is-singleton-structure←parts
        Sing-is-singleton
        (_ , refl)
        (is-single←equiv-to-single
          (Σ-Π-swap≃ _ λ p y → Σ[ q ∶ x .snd p .fst ＝ y .fst ]
                                 Square (x .snd p .snd) (y .snd) (ap _ q) refl)
          (Π-is-single (λ where
            refl → is-singleton-structure←parts
                     Sing-is-singleton
                     (_ , refl)
                     (Square-degen-hor-is-torsorial
                       (x .snd refl .snd)))))

IdS-Gl
  : ∀ {𝓤 𝓥}{B : Type 𝓤} {F G : B → Type 𝓥} {f : ∀ b → F b → G b} i
    → Identity-system (Gl F G f i) (𝓘 ⊔ 𝓥)
IdS-Gl {F = F}{G}{f} i .Identity-system.IdS = Gl-path {F = F}{G}{f} i
IdS-Gl {F = F}{G}{f} i .Identity-system.IdS←Id refl
  = Gl-path-refl {F = F}{G = G}{f}  i _
IdS-Gl {f = f} i .Identity-system.IdS←Id-is-equiv a
  = fundamental-Id _ (Gl-path-is-torsorial {f = f} i a) _

Gl-path→
  : ∀ {𝓤 𝓥}{B : Type 𝓤} {F G : B → Type 𝓥} (f : ∀ b → F b → G b) i
    → {x y : Gl F G f i} → Gl-path {f = f} i x y → x ＝ y
Gl-path→ f i = Id←IdS ⦃ IdS-Gl {f = f} i ⦄
}
}

\subtree[tot-L201]{
\title{The data of a covariant fibration over #{\Delta^1}}
\taxon{Definition}

\agda{
Cov-Δ¹-bundle
  : ∀ {𝓤} 𝓥 (B : Type 𝓤) → Type (𝓘 ⊔ 𝓤 ⊔ lsuc 𝓥)
Cov-Δ¹-bundle 𝓥 B
  = Σ[ X Y ∶ Σ (B → Type 𝓥) is-covariant ] (∀ b → X .fst b → Y .fst b)
}
}

\subtree[tot-L00P]{
\title{Characterising the identity type of a covariant bundle over #{\Delta^1}}
\taxon{Lemma}

\agda{
cov-Δ¹-bundle-Path
  : ∀ {𝓤 𝓥} {B : Type 𝓤} (x y : Cov-Δ¹-bundle 𝓥 B)
    → Type (𝓤 ⊔ 𝓥)
cov-Δ¹-bundle-Path ((A , _) , (B , _) , f) ((X , _) , (Y , _) , g)
  = Σ[ e ∶ (∀ b → A b ≃ X b) ] Σ[ p ∶ (∀ b → B b ≃ Y b) ]
      (∀ b → p b ._≃_.fwd ∘ f b ~ g b ∘ e b ._≃_.fwd)

cov-Δ¹-bundle-Path-refl
  : ∀ {𝓤 𝓥} {B : Type 𝓤} (x : Cov-Δ¹-bundle 𝓥 B)
    → cov-Δ¹-bundle-Path x x
cov-Δ¹-bundle-Path-refl x = ((λ _ → id≃) , (λ _ → id≃) , λ _ → ~refl)

instance
  IdS-cov-fam
    : ∀ {𝓤 𝓥} {A : Type 𝓤} → Identity-system (Σ (A → Type 𝓥) is-covariant) (𝓤 ⊔ 𝓥)
  IdS-cov-fam = IdS←Subtype is-covariant-is-prop auto!

opaque
  cov-Δ¹-bundle-Path-is-torsorial
    : ∀ {𝓤 𝓥} {B : Type 𝓤} (x : Cov-Δ¹-bundle 𝓥 B)
      → is-singleton (Σ _ (cov-Δ¹-bundle-Path x))
  cov-Δ¹-bundle-Path-is-torsorial (A , B , f)
    = is-singleton-structure←parts
       (SingS-is-single A)
       (A , λ _ → id≃)
       (is-singleton-structure←parts
         (SingS-is-single B)
         (B , λ _ → id≃)
         (SingS-is-single _))

instance
  cov-Δ¹-bundle-IdS
    : ∀ {𝓤 𝓥} {B : Type 𝓤} → Identity-system (Cov-Δ¹-bundle 𝓥 B) (𝓤 ⊔ 𝓥)
  cov-Δ¹-bundle-IdS .Identity-system.IdS = cov-Δ¹-bundle-Path
  cov-Δ¹-bundle-IdS .Identity-system.IdS←Id {a = A} refl = cov-Δ¹-bundle-Path-refl A
  cov-Δ¹-bundle-IdS .Identity-system.IdS←Id-is-equiv x
    = fundamental-Id _ (cov-Δ¹-bundle-Path-is-torsorial x) _
}
}

\subtree[tot-L007]{
\title{The induced transport of a covariant family over #{Δ¹}}
\taxon{Contruction}

\p{Given a covariant type family #{B \times \Delta^1}, we can construct a pair of
covariant families #{B \to \Type} together with a fibrewise map between them. We
call this collection of data a covariant bundle over #{\Delta^1}.}

\agda{
trΣ : ∀ {𝓤 𝓥} {B : Type 𝓤}
      → (Σ (B × Δ¹ → Type 𝓥) is-covariant)
      → Cov-Δ¹-bundle 𝓥 B
trΣ (F , Fcov)
  = ( (F ∘ (_, i0) , covariant-base-change {P = F} (_, i0) Fcov)
    , (F ∘ (_, i1) , covariant-base-change {P = F} (_, i1) Fcov)
    , (λ b → tr-cov {P = F ∘ (b ,_)} (covariant-base-change {P = F} (b ,_) Fcov) id))
}
}

\subtree[tot-L034]{
\title{Directed univalence for covariant families}
\taxon{Theorem}

\p{The map defined in \ref{tot-L007} induces an equivalence between covariant
families over #{B \times \Delta^1} and the type consisting of a pair of covariant
families over #{B} and a fibrewise map between them.}

\proof{
\p{We first define a putative inverse: }

\agda{
module _
  {𝓤 𝓥} {B : Type 𝓤}
  where

  trΣ-inv
    : Cov-Δ¹-bundle 𝓥 B
    → (Σ (B × Δ¹ → Type (𝓥 ⊔ 𝓘)) is-covariant)
  trΣ-inv ((A , Ac) , (B , Bc) , α)
    = (Gl A B α , Gl-is-covariant A B α Ac Bc)
}

\subtree[tot-LL01]{
\title{Left inverse}
\taxon{Lemma}

\p{Under no assumptions, this map is a left inverse.}

\agda{
module _
  {𝓤 𝓥} {B : Type 𝓤}
  where

  tr-Gl-hom
    : ∀ {X Y : B → Type (𝓘 ⊔ 𝓥)}
        (α : ∀ b → X b → Y b)
      → ∀ b x → Homᵈ (Gl X Y α ∘ (b ,_)) x (Gl-map α b x)
  tr-Gl-hom α b x .Homᵈ.hom i = (x .fst , λ p → x .snd refl)
  tr-Gl-hom α b x .Homᵈ.hom0  = Σ-path→ (refl , (funext→ (J-set! _ refl)))
  tr-Gl-hom α b x .Homᵈ.hom1  = Σ-path→ (refl , (funext→ (¡ ∘ non-triv)))

  tr-Gl
    : ∀ {X Y : B → Type (𝓘 ⊔ 𝓥)}
        (α : ∀ b → X b → Y b)
        (Xc : is-covariant X) (Yc : is-covariant Y)
      → ∀ b
      → tr-cov {P = Gl X Y α} (Gl-is-covariant X Y α Xc Yc) (b ,_)
      ~ Gl-map α b
  tr-Gl α Xc Yc b x
    = ap fst
         (Gl-is-covariant _ _ α Xc Yc (b ,_) x
           .central (Gl-map α b x , tr-Gl-hom α b x))

  trΣ-section : ∀ x → cov-Δ¹-bundle-Path {𝓤} {𝓘 ⊔ 𝓥} {B} (trΣ (trΣ-inv x)) x
  trΣ-section ((X , _) , (Y , _) , F) .fst b
    = mk≃ (Gl-0 X Y F b) (Gl-0-is-equiv X Y F b)
  trΣ-section ((X , _) , (Y , _) , F) .snd .fst b
    = mk≃ (Gl-1 X Y F b) (Gl-1-is-equiv X Y F b)
  trΣ-section ((X , Ac) , (Y , Bc) , F) .snd .snd b x@(y , p)
    = (fst ∘ tr-cov {P = Gl X Y F} (Gl-is-covariant X Y F Ac Bc) (b ,_)) x
    ＝⟨ ap fst (tr-Gl F Ac Bc b x) ⟩
      x .fst
    ＝⟨ sym (p refl .snd) ⟩
      F b (p refl .fst)
    ∎
}
}

\subtree[tot-LP01]{
\taxon{Lemma}
\title{A right inverse}

\p{To show that this map is an equivalences we assume an additional axiom; namely that
for a fibrewise map #{\alpha} between covariant families over #{B \times \Delta^1}, to check it
is an equivalence, it suffices to check that for all #{b}, #{\alpha_0} and #{\alpha_1}
is an equivalence.}

\remark{
This axiom follows from the pair of axioms that [cubes separate]() and the booleans
cover the global points of #{\Delta^1}.
}

\agda{
module _
  {𝓤 𝓥} {B : Type 𝓤}
  (Cov-Nat-is-equiv
    : ∀ {𝓤} (F G : B × Δ¹ → Type 𝓤)
        (Fc : is-covariant F) (Gc : is-covariant G)
        (α : ∀ i → F i → G i)
      → (∀ x → is-equiv (α ((id ⊗ ∂Δ¹-incl) x)))
      → is-fibrewise-equiv α)
  where

  trΣ-retraction→ : ∀ F i → F .fst i → trΣ-inv {𝓤}{𝓥 ⊔ 𝓘}{B} (trΣ F) .fst i
  trΣ-retraction→ FF@(F , Fc) (b , i) x .fst
    = coe-cov (F ∘ (b ,_)) (covariant-base-change {P = F} (b ,_) Fc) 1-top x
  trΣ-retraction→ (F , Fc) (b , i) x .snd refl
    = (x , sym (happly (coe-cov-0≤1 (F ∘ (b ,_))
                                    (covariant-base-change {P = F} (b ,_) Fc)
                                    1-top) x))

  trΣ-retraction : ∀ F i → F .fst i ≃ trΣ-inv {𝓤}{𝓥 ⊔ 𝓘}{B} (trΣ F) .fst i
  trΣ-retraction F i ._≃_.fwd = trΣ-retraction→ F i
  trΣ-retraction FF@(F , Fc) i ._≃_.fwd-is-equiv
    = Cov-Nat-is-equiv F _
      Fc
      (trΣ-inv {𝓤}{𝓥 ⊔ 𝓘}{B} (trΣ FF) .snd)
      (trΣ-retraction→ (F , Fc))
      (uncurry λ b →
        ∂Δ¹-UP→
          ( is-equiv←qinv (fr0 b)
          , is-equiv←qinv (fr1 b))) i where
    fr0 : ∀ b → quasi-inv (trΣ-retraction→ FF (b , i0))
    fr0 b .fst x = x .snd refl .fst
    fr0 b .snd .fst = ~refl
    fr0 b .snd .snd a
      = Gl-path→ {B = B} {F ∘ (_, i0)} {F ∘ (_, i1)}
                 (trΣ FF .snd .snd)
                 (b , i0)
                 ( happly
                      (coe-cov-0≤1
                         (F ∘ (b ,_))
                          (covariant-base-change {P = F} (b ,_) Fc)
                          1-top)
                     (fr0 b .fst a)
                 ∙ a .snd refl .snd
                 ,  J-set! _
                      ( refl
                      , mk-square
                          (sym'∙ (happly
                                   (coe-cov-0≤1
                                     (F ∘ (b ,_))
                                     (covariant-base-change {P = F} (b ,_) Fc)
                                     1-top)
                                   (a .snd refl .fst))
                                 (a .snd refl .snd))))

    fr1 : ∀ b →  quasi-inv (trΣ-retraction→ FF (b , i1))
    fr1 b .fst x = x .fst
    fr1 b .snd .fst x = coe-cov-id (λ a → F (b , a))
                          (covariant-base-change {P = F} (λ i → (b , i)) Fc) _ x
    fr1 b .snd .snd (a , _)
      = Σ-path→
          ( (coe-cov-id
               (λ i → F (b , i))
               (covariant-base-change {P = F} (b ,_) Fc)
               _
               a)
          , funext→ (λ x → ¡ (non-triv x)))
}
}

\agda{
  trΣ-is-equiv
    : is-equiv (trΣ {𝓤}{𝓥 ⊔ 𝓘}{B})
  trΣ-is-equiv = is-equiv←qinv
    ( trΣ-inv
    , (λ a → Σ-path→ ( funext→ (λ i → ua (trΣ-retraction a i e⁻¹))
                     , is-covariant-is-prop (a .fst) _ _))
    , (λ a → ext! (trΣ-section {𝓤} {𝓥} a)))
}
}
}

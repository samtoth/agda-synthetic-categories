\subtree[stt-00C1]{
\title{Right cones over a cospan}
\taxon{Definition}

\p{Given a [cospan diagram](stt-0039) #{S}, we consider the right cones over #{S}.
This is analogous to the type of [cones over #{S}](stt-003A) but with the filler now
being a morphism, not a path.}

%```agda
\agda{
record Right-cone {ūĚď§ ūĚď• ūĚď¶} (S : Cospan ūĚď§ ūĚď• ūĚď¶) {ūĚďõ} (Carrier : Type ūĚďõ)
  : Type (ūĚďė ‚äĒ ūĚď§ ‚äĒ ūĚď• ‚äĒ ūĚď¶ ‚äĒ ūĚďõ) where
  constructor mk-right-cone
  open Cospan S
  field
    p : Carrier ‚Üí Left
    q : Carrier ‚Üí Right
    filler : ‚ąÄ (a : Carrier) ‚Üí Hom Centre (left (p a)) (right (q a))
}
%```
}


\subtree[stt-00C2]{
\title{Comma cones}
\taxon{Definition}

\p{Again analogously to undirected pullbacks, for any lax cone #{C} over a cospan
#{S}, we can define a canonical map #{(Q \to C) \to \mathrm{Cone}_S(Q)}.
We call #{C} a (right) comma cone when this map is an equivalence.}

%```agda
\agda{
module _ {ūĚď§ ūĚď• ūĚď¶} {S : Cospan ūĚď§ ūĚď• ūĚď¶} {ūĚďõ} {Carrier : Type ūĚďõ} where
  right-cone-map : Right-cone S Carrier
               ‚Üí ‚ąÄ {ūĚď†} {Q : Type ūĚď†} ‚Üí (Q ‚Üí Carrier) ‚Üí Right-cone S Q
  right-cone-map cone f = mk-right-cone (p ‚ąė f) (q ‚ąė f) (filler ‚ąė f) where
    open Right-cone cone

  is-comma-cone : Right-cone S Carrier ‚Üí TypeŌČ
  is-comma-cone cone
    = ‚ąÄ {ūĚď†} {Q : Type ūĚď†} ‚Üí is-equiv (right-cone-map cone {ūĚď†}{Q})
}
%```
}

\subtree[stt-00C3]{
\title{Canonical comma types}
\taxon{Construction}

\p{The comma type of a [cospan diagram](stt-0039) is written
#{f \downarrow g}. It can be constructed as the type:}

##{\Sigma_{a : A} \Sigma_{c : C} \Hom_B(f(a), g(c))}


%```agda
\agda{
_‚Üď_ : ‚ąÄ {ūĚď§ ūĚď• ūĚď¶} {A : Type ūĚď§} {B : Type ūĚď•} {C : Type ūĚď¶}
        (f : A ‚Üí B) (g : C ‚Üí B) ‚Üí Type (ūĚďė ‚äĒ ūĚď§ ‚äĒ ūĚď• ‚äĒ ūĚď¶)
f ‚Üď g = ő£[ a ‚ą∂ _ ] ő£[ c ‚ą∂ _ ] Hom _ (f a) (g c)

‚Üď-cone : ‚ąÄ {ūĚď§ ūĚď• ūĚď¶} {A : Type ūĚď§} {B : Type ūĚď•} {C : Type ūĚď¶}
        (f : A ‚Üí B) (g : C ‚Üí B) ‚Üí Right-cone (mk-cospan _ f g) (f ‚Üď g)
‚Üď-cone f g = mk-right-cone fst (fst ‚ąė snd) (snd ‚ąė snd)

‚Üď-is-comma-cone
  : ‚ąÄ {ūĚď§ ūĚď• ūĚď¶} {A : Type ūĚď§} {B : Type ūĚď•} {C : Type ūĚď¶} {f : A ‚Üí B} {g : C ‚Üí B}
    ‚Üí is-comma-cone (‚Üď-cone f g)
‚Üď-is-comma-cone = is-equiv‚Üźqiso qiso where
  open Right-cone
  qiso : quasi-iso (right-cone-map (‚Üď-cone _ _))
  qiso .fst cone x = (cone .p x , cone .q x , cone .filler x)
  qiso .snd .fst = ~refl
  qiso .snd .snd = ~refl
}
%```
}

\subtree[stt-00C4]{
\title{Slice and coslice categories as lax pullbacks}
\taxon{Example}

\p{A common example of a comma category is a slice category. Given a type
#{C} and #{c}, an object of #{C}, we consider the category #{C/c} of which
the objects consists of pairs of objects of #{C} together with maps into #{c}.
}

\p{We generalise this notation slightly, to consider any diagram
#{F : \mathcal{I}\to C}, which gives rise to the slice category #{C/F} for which
the objects consists of pairs of objects of #{c}, now with a natural transformation
#{\Delta_c \to F}. This type #{C/F} is the lax pullback of the following diagram:}

\quiver{
\begin{tikzcd}[cramped]
	{C/F} && C \\
	\\
	1 && {C^I}
	\arrow[from=1-1, to=1-3]
	\arrow[from=1-1, to=3-1]
	\arrow["\lrcorner"{anchor=center, pos=0.125}, draw=none, from=1-1, to=3-3]
	\arrow["\Delta", from=1-3, to=3-3]
	\arrow["F"', from=3-1, to=3-3]
\end{tikzcd}
}

\p{We retain the original notion of slice category by taking the slice of an
object #{c} considered as a function #{1 \to C}.}

%```agda
\agda{
Slice : ‚ąÄ {ūĚď§ ūĚď•} (C : Type ūĚď§) {I : Type ūĚď•} (F : I ‚Üí C) ‚Üí Type (ūĚďė ‚äĒ ūĚď§ ‚äĒ ūĚď•)
Slice C f = ő£[ c ‚ą∂ C ] ‚ąÄ i ‚Üí Hom _ c (f i)

Slice-cone : ‚ąÄ {ūĚď§ ūĚď•} {C : Type ūĚď§} {I : Type ūĚď•}
           (F : I ‚Üí C) ‚Üí Right-cone (mk-cospan _ (const C I) (point F)) (Slice _ F)
Slice-cone F .Right-cone.p (c , _) = c
Slice-cone F .Right-cone.q (c , g) = tt
Slice-cone F .Right-cone.filler (_ , f) = Hom‚ÜźNT f

Slice-is-comma : ‚ąÄ {ūĚď§ ūĚď•} {C : Type ūĚď§} {I : Type ūĚď•} (F : I ‚Üí C)
                    ‚Üí is-comma-cone (Slice-cone F)
Slice-is-comma F = is-equiv‚Üźqiso qiso where
  qiso : quasi-iso (right-cone-map (Slice-cone F))
  qiso .fst cone x = (cone .Right-cone.p x , NT‚ÜźHom (cone .Right-cone.filler x))
  qiso .snd .fst f = funext‚Üí (őĽ q ‚Üí ő£-path‚Üí (refl , _‚ČÉ_.őĶ NT‚ČÉHom (f q .snd)))
  qiso .snd .snd c = ap (mk-right-cone (Right-cone.p c) (őĽ _ ‚Üí tt))
                        (funext‚Üí (_‚ČÉ_.ő∑ NT‚ČÉHom ‚ąė Right-cone.filler c))


Coslice : ‚ąÄ {ūĚď§ ūĚď•} (C : Type ūĚď§) {I : Type ūĚď•} (F : I ‚Üí C) ‚Üí Type (ūĚďė ‚äĒ ūĚď§ ‚äĒ ūĚď•)
Coslice C f = ő£[ c ‚ą∂ C ] ‚ąÄ i ‚Üí Hom _ (f i) c

Coslice-cone
  : ‚ąÄ {ūĚď§ ūĚď•} {C : Type ūĚď§} {I : Type ūĚď•}
      (F : I ‚Üí C)
    ‚Üí Right-cone (mk-cospan _ (point F) (const C I)) (Coslice C F)
Coslice-cone F .Right-cone.p = !
Coslice-cone F .Right-cone.q (c , _) = c
Coslice-cone F .Right-cone.filler (_ , őĪ) = Hom‚ÜźNT őĪ

Coslice-is-comma : ‚ąÄ {ūĚď§ ūĚď•} {C : Type ūĚď§} {I : Type ūĚď•} (F : I ‚Üí C)
                    ‚Üí is-comma-cone (Coslice-cone F)
Coslice-is-comma F = is-equiv‚Üźqiso qiso where
  qiso : quasi-iso (right-cone-map (Coslice-cone F))
  qiso .fst cone x = (cone .Right-cone.q x , NT‚ÜźHom (cone .Right-cone.filler x))
  qiso .snd .fst f =  funext‚Üí (őĽ q ‚Üí ő£-path‚Üí (refl , _‚ČÉ_.őĶ NT‚ČÉHom (f q .snd)))
  qiso .snd .snd c =  ap (mk-right-cone _ (Right-cone.q c))
                        (funext‚Üí (_‚ČÉ_.ő∑ NT‚ČÉHom ‚ąė Right-cone.filler c))


Slice-path
  : ‚ąÄ {ūĚď§ ūĚď•} {C : Type ūĚď§} {I : Type ūĚď•} {F : I ‚Üí C}
  ‚Üí Slice C F ‚Üí Slice C F ‚Üí Type (ūĚďė ‚äĒ ūĚď§ ‚äĒ ūĚď•)
Slice-path a b
  = ő£[ p ‚ą∂ (a .fst ÔľĚ b .fst) ]
       (‚ąÄ i ‚Üí Hom-pathŠĶą p refl (a .snd i) (b .snd i))

Slice-path-refl
  : ‚ąÄ {ūĚď§ ūĚď•} {C : Type ūĚď§} {I : Type ūĚď•} {F : I ‚Üí C}
    ‚Üí (F : Slice C F) ‚Üí Slice-path F F
Slice-path-refl F
  = (refl , őĽ i ‚Üí Hom-pathŠĶą-refl)

opaque
  Slice-path-is-torsorial
    : ‚ąÄ {ūĚď§ ūĚď•} {C : Type ūĚď§} {I : Type ūĚď•} {F : I ‚Üí C}
      ‚Üí (F : Slice C F) ‚Üí is-singleton (ő£ _ (Slice-path F))
  Slice-path-is-torsorial F
    = is-singleton-structure‚Üźparts
        Sing-is-singleton
        (_ , refl)
        (SingS-is-single ‚¶É IdS-ő† ‚¶É Hom-IdSŠĶą ‚¶Ą ‚¶Ą _)

instance
  Slice-IdS
    : ‚ąÄ {ūĚď§ ūĚď•} {C : Type ūĚď§} {I : Type ūĚď•} {F : I ‚Üí C}
      ‚Üí Identity-system (Slice C F) (ūĚďė ‚äĒ ūĚď§ ‚äĒ ūĚď•)
  Slice-IdS .Identity-system.IdS = Slice-path
  Slice-IdS .Identity-system.IdS‚ÜźId refl = Slice-path-refl _
  Slice-IdS .Identity-system.has-is-ids a
    = fundamental-Id _ (Slice-path-is-torsorial _) _

Coslice-path
  : ‚ąÄ {ūĚď§ ūĚď•} {C : Type ūĚď§} {I : Type ūĚď•} {F : I ‚Üí C}
  ‚Üí Coslice C F ‚Üí Coslice C F ‚Üí Type (ūĚďė ‚äĒ ūĚď§ ‚äĒ ūĚď•)
Coslice-path a b
  = ő£[ p ‚ą∂ (a .fst ÔľĚ b .fst) ]
       (‚ąÄ i ‚Üí Hom-pathŠĶą refl p (a .snd i) (b .snd i))

Coslice-path-refl
  : ‚ąÄ {ūĚď§ ūĚď•} {C : Type ūĚď§} {I : Type ūĚď•} {F : I ‚Üí C}
  ‚Üí (p : Coslice C F) ‚Üí Coslice-path p p
Coslice-path-refl a = (refl , őĽ _ ‚Üí Hom-pathŠĶą-refl)

opaque
  Coslice-path-is-torsorial
    : ‚ąÄ {ūĚď§ ūĚď•} {C : Type ūĚď§} {I : Type ūĚď•} {F : I ‚Üí C}
      ‚Üí (F : Coslice C F) ‚Üí is-singleton (ő£ _ (Coslice-path F))
  Coslice-path-is-torsorial F
    = is-singleton-structure‚Üźparts
        Sing-is-singleton
        (_ , refl)
        (SingS-is-single ‚¶É IdS-ő† ‚¶É Hom-IdSŠĶą ‚¶Ą ‚¶Ą _)

instance
  Coslice-IdS
    : ‚ąÄ {ūĚď§ ūĚď•} {C : Type ūĚď§} {I : Type ūĚď•} {F : I ‚Üí C}
      ‚Üí Identity-system (Coslice C F) (ūĚďė ‚äĒ ūĚď§ ‚äĒ ūĚď•)
  Coslice-IdS .Identity-system.IdS = Coslice-path
  Coslice-IdS .Identity-system.IdS‚ÜźId refl = Coslice-path-refl _
  Coslice-IdS .Identity-system.has-is-ids a
    = fundamental-Id _ (Coslice-path-is-torsorial a) _

opaque
  Coslice-path‚Üí
    : ‚ąÄ {ūĚď§ ūĚď•} {C : Type ūĚď§} {I : Type ūĚď•} {F : I ‚Üí C}
    ‚Üí {x y : Coslice C F}
    ‚Üí Coslice-path x y ‚Üí x ÔľĚ y
  Coslice-path‚Üí = Id‚ÜźIdS ‚¶É Coslice-IdS ‚¶Ą

  Coslice-path-is-equiv
    : ‚ąÄ {ūĚď§ ūĚď•} {C : Type ūĚď§} {I : Type ūĚď•} {F : I ‚Üí C}
    ‚Üí {x y : Coslice C F}
    ‚Üí is-equiv (Coslice-path‚Üí {x = x} {y})
  Coslice-path-is-equiv
    = is-equiv‚ĀĽ¬Ļ (Coslice-IdS .Identity-system.has-is-ids _ _)

  Coslice-path-ap-fst
    : ‚ąÄ {ūĚď§ ūĚď•} {C : Type ūĚď§} {I : Type ūĚď•} {F : I ‚Üí C} {a b : Coslice C F}
      ‚Üí (p : Coslice-path a b) ‚Üí ap fst (Coslice-path‚Üí p) ÔľĚ fst p
  Coslice-path-ap-fst
    = IdSJ ‚¶É Coslice-IdS ‚¶Ą (őĽ x ‚Üí ap fst (Id‚ÜźIdS (x .snd)) ÔľĚ fst (x .snd))
           (ap (ap fst) (Id‚ÜźIdS‚ÜźId refl))
}
%```


\p{We also remark that in the simple case of a (co)slice over (under) an object,
there is a 'more coherent' representation:}

##{A_{/x} \simeq \Sigma_{f : A^{\Delta^1}} f(1) = x}

%```agda
\agda{
Coslice-object-repr‚Čä
  : ‚ąÄ {ūĚď§} {A : Type ūĚď§} a
    ‚Üí (Coslice A (point a)) ‚Čä (ő£[ f ‚ą∂ (őĒ¬Ļ ‚Üí A)] (f i0 ÔľĚ a))
Coslice-object-repr‚Čä a ._‚Čä_.fwd (b , f) = (f tt .HomŠĶą.hom , f tt .HomŠĶą.hom0)
Coslice-object-repr‚Čä a ._‚Čä_.fwd-iso .fst (f , p) = (f i1 , őĽ _ ‚Üí mk-hom f p refl)
Coslice-object-repr‚Čä a ._‚Čä_.fwd-iso .snd .fst (x , y)
  = Coslice-path‚Üí
      ( y tt .HomŠĶą.hom1
      , (őĽ _ ‚Üí ~refl , Square-degen-vert _ _ refl , Square-flatten-vert refl))
Coslice-object-repr‚Čä a ._‚Čä_.fwd-iso .snd .snd = ~refl

Coslice-object-repr‚ČÉ
  : ‚ąÄ {ūĚď§} {A : Type ūĚď§} a
    ‚Üí (Coslice A (point a)) ‚ČÉ (ő£[ f ‚ą∂ (őĒ¬Ļ ‚Üí A)] (f i0 ÔľĚ a))
Coslice-object-repr‚ČÉ a = equiv‚Üźqiso (Coslice-object-repr‚Čä a)
}
%```
}

\subtree[stt-00CG]{
\title{Paths in comma types}

%```agda
\agda{
Comma-path
  : ‚ąÄ {ūĚď§ ūĚď• ūĚď¶} {a : Type ūĚď§} {b : Type ūĚď•} {c : Type ūĚď¶}
      {f : a ‚Üí b} {g : c ‚Üí b}
    ‚Üí (x y : f ‚Üď g) ‚Üí Type (ūĚď§ ‚äĒ ūĚď• ‚äĒ ūĚď¶ ‚äĒ ūĚďė)
Comma-path {f = F} {g = G} (a , b , f) (a' , b' , f')
  = ő£[ p ‚ą∂ a ÔľĚ a' ] ő£[ q ‚ą∂ b ÔľĚ b' ] Hom-pathŠĶą (ap F p) (ap G q) f f'

Comma-path-refl
  : ‚ąÄ {ūĚď§ ūĚď• ūĚď¶} {a : Type ūĚď§} {b : Type ūĚď•} {c : Type ūĚď¶}
      {f : a ‚Üí b} {g : c ‚Üí b}
    ‚Üí {x : f ‚Üď g} ‚Üí Comma-path x x
Comma-path-refl = (refl , refl , Hom-pathŠĶą-refl)

opaque
  Comma-path-is-torsorial
    : ‚ąÄ {ūĚď§ ūĚď• ūĚď¶} {a : Type ūĚď§} {b : Type ūĚď•} {c : Type ūĚď¶}
        {f : a ‚Üí b} {g : c ‚Üí b}
      ‚Üí {x : f ‚Üď g} ‚Üí is-singleton (ő£ (f ‚Üď g) (Comma-path x))
  Comma-path-is-torsorial
    = is-singleton-structure‚Üźparts
        Sing-is-singleton
        (_ , refl)
        (is-singleton-structure‚Üźparts
          Sing-is-singleton
          (_ , refl)
          Hom-pathŠĶą-is-torsorial)

instance
  IdS-Comma
    : ‚ąÄ {ūĚď§ ūĚď• ūĚď¶} {a : Type ūĚď§} {b : Type ūĚď•} {c : Type ūĚď¶}
        {F : a ‚Üí b} {G : c ‚Üí b} ‚Üí Identity-system (F ‚Üď G) (ūĚďė ‚äĒ ūĚď§ ‚äĒ ūĚď• ‚äĒ ūĚď¶)
  IdS-Comma .Identity-system.IdS = Comma-path
  IdS-Comma .Identity-system.IdS‚ÜźId refl = Comma-path-refl
  IdS-Comma .Identity-system.has-is-ids x
    = fundamental-Id _ Comma-path-is-torsorial _
}
%```
}

\subtree[stt-00CF]{
\title{Comma types are functorial in their cospan}
\taxon{Construction}


%```agda
\agda{
Comma‚āÄ : ‚ąÄ {ūĚď§ ūĚď• ūĚď¶} ‚Üí Cospan ūĚď§ ūĚď• ūĚď¶ ‚Üí Type (ūĚď§ ‚äĒ ūĚď• ‚äĒ ūĚď¶ ‚äĒ ūĚďė)
Comma‚āÄ C = left ‚Üď right where open Cospan C

Comma‚āĀ : ‚ąÄ {ūĚď§ ūĚď• ūĚď¶ ūĚď§' ūĚď•' ūĚď¶'}
           {S : Cospan ūĚď§ ūĚď• ūĚď¶} {T : Cospan ūĚď§' ūĚď•' ūĚď¶'}
         ‚Üí Cospan-map S T ‚Üí Comma‚āÄ S ‚Üí Comma‚āÄ T
Comma‚āĀ F (x , y , h)
  = (h‚āĀ x , h‚āÉ y , adjust-hom (H x) (K y) (ap-hom h‚āā h))
  where open Cospan-map F

Comma-id
  : ‚ąÄ {ūĚď§ ūĚď• ūĚď¶} {S : Cospan ūĚď§ ūĚď• ūĚď¶}
    ‚Üí Comma‚āĀ (id-cospan-map {S = S}) ~ id
Comma-id (x , y , f) = ext!
  (refl , refl
  , (~refl
    , Square-degen-vert _ _ (‚ąô-reflr _ ‚ąô ap-id _)
    , Square-degen-vert _ _ (‚ąô-reflr _ ‚ąô ap-id _)))

Comma-‚ąė
  : ‚ąÄ {ūĚď§ ūĚď• ūĚď¶ ūĚď§' ūĚď•' ūĚď¶' ūĚď§'' ūĚď•'' ūĚď¶''}
      {A : Cospan ūĚď§ ūĚď• ūĚď¶} {B : Cospan ūĚď§' ūĚď•' ūĚď¶'} {C : Cospan ūĚď§'' ūĚď•'' ūĚď¶''}
      (F : Cospan-map B C) (G : Cospan-map A B)
    ‚Üí Comma‚āĀ (cospan-map-compose F G) ~ Comma‚āĀ F ‚ąė Comma‚āĀ G
Comma-‚ąė F G (x , y , f) = ext!
  (refl , refl
  , ( ~refl
    , (Square-degen-vert _ _
        (‚ąô.pullr _
          {a = ap (F .h‚āā) (G .H x)}
          {b = ap (F .h‚āā ‚ąė G .h‚āā) (f .hom0)}
          {c = ap (F .h‚āā) _}
          (ap (_‚ąô ap (F .h‚āā) (G .H x)) (ap-‚ąė (F .h‚āā) (G .h‚āā) (f .hom0))
          ‚ąô sym (ap-‚ąô (F .h‚āā) _ (G .H x)))))
    , Square-degen-vert _ _
        (‚ąô.pullr _
          {a = ap (h‚āā F) (G .K y)}
          {b = ap (F .h‚āā ‚ąė G .h‚āā) (f .hom1)}
          {c = ap (F .h‚āā) (ap (G .h‚āā) _ ‚ąô G .K y)}
          ((ap (_‚ąô ap (F .h‚āā) (G .K y)) (ap-‚ąė (F .h‚āā) (G .h‚āā) (f .hom1))
          ‚ąô sym (ap-‚ąô (F .h‚āā) _ (G .K y)))))))
  where
  open Cospan-map
  open HomŠĶą
}
%```
}

\subtree[stt-00CJ]{
\title{Functoriality of the slice construction}
\taxon{Corollary}

\p{The functoriality of somewhat of the (co)slice construction is somewhat
more subtle to express. The operation #{-_{/-}} can be considered a functor
#{\Sigma_{A : \UU}((\UU_{/A})^{op}) \to \UU}. In the first argument, we can express
functoriality as follows: given a map #{f : A \to B}, there is a function
#{f_{/p} : A_{/p} \to B_{/fp}}. In the second argument, we fix a type #{A},
and consider a pair of arrows into #{A}, #{p} and #{q}. Now a
[map in the slice](Core.Slice) #{t : p \to q} determines a function #{A_{/q} \to A_{/p}}
(note the contravariance). We also provide a bespoke function for the trivial
slice map, for any #{t : K \to L}, we have #{(pt \xrightarrow{t} p) \mapsto
#{A_{/p} \to A_{/pt}}}, we also
refer to this as (co)slice postcomposition.}

%```agda
\agda{
postcompose-slice
  : ‚ąÄ {ūĚď§ ūĚď• ūĚďö} {A : Type ūĚď§} {K : Type ūĚďö} (p : K ‚Üí A)
      {B : Type ūĚď•} (f : A ‚Üí B)
    ‚Üí Slice A p ‚Üí Slice B (f ‚ąė p)
postcompose-slice p f (a , h) = (f a , ap-hom f ‚ąė h)

postcompose-coslice
  : ‚ąÄ {ūĚď§ ūĚď• ūĚďö} {A : Type ūĚď§} {K : Type ūĚďö} (p : K ‚Üí A)
      {B : Type ūĚď•} (f : A ‚Üí B)
    ‚Üí Coslice A p ‚Üí Coslice B (f ‚ąė p)
postcompose-coslice p f (a , h) = (f a , ap-hom f ‚ąė h)

slice-map-slice
  : ‚ąÄ {ūĚď§ ūĚďö ūĚďö'} {A : Type ūĚď§}
      {K : Type ūĚďö} (p : K ‚Üí A)
      {K' : Type ūĚďö'} (q : K' ‚Üí A)
      (t : Slice-map p q)
    ‚Üí Slice A q ‚Üí Slice A p
slice-map-slice p q (t , H) (a , h) = (a , adjust-hom refl (H _) ‚ąė h ‚ąė t)

precompose-slice
  : ‚ąÄ {ūĚď§ ūĚďö ūĚďö'} {A : Type ūĚď§}
      {K : Type ūĚďö} (p : K ‚Üí A)
      {K' : Type ūĚďö'} (t : K' ‚Üí K)
    ‚Üí Slice A p ‚Üí Slice A (p ‚ąė t)
precompose-slice p t (a , h) = (a , h ‚ąė t)

coslice-map-slice
  : ‚ąÄ {ūĚď§ ūĚďö ūĚďö'} {A : Type ūĚď§}
      {K : Type ūĚďö} (p : K ‚Üí A)
      {K' : Type ūĚďö'} (q : K' ‚Üí A)
      (t : Slice-map q p)
    ‚Üí Coslice A p ‚Üí Coslice A q
coslice-map-slice p q (t , H) (a , h) = (a , adjust-hom (H _) refl ‚ąė h ‚ąė t)

precompose-coslice
  : ‚ąÄ {ūĚď§ ūĚďö ūĚďö'} {A : Type ūĚď§}
      {K : Type ūĚďö} (p : K ‚Üí A)
      {K' : Type ūĚďö'} (t : K' ‚Üí K)
    ‚Üí Coslice A p ‚Üí Coslice A (p ‚ąė t)
precompose-coslice p t (a , h) = (a , h ‚ąė t)
}
%```
}

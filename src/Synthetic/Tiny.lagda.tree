\subtree[stt-00KC]{
\title{Idea}


\p{Let #{I} be some object in a cartesian-closed set-category #{C}, then we
say #{I} is \em{tiny} or \em{atomic} if there is a further right adjoint to
exponentiation #{({-})^I}. In \citek{LOPS2018}, it was demonstrated that this
right adjoint can be internalised and used to construct universes. The recent
work by Gratzer, Weinberger and Buchholtz use the same idea to construct
universes of spaces \citek{GWB2024} and of categories \citek{GWB26}.
Internalising tiny types is made difficult by the fact that we may prove a no-go
theorem that states that, internally, if #{({-})^I} has a right adjoint, then
this right adjoint must be the identity, and hence #{I} must be contractible.
This bad situation may be fixed by using the #{\flat} modality, which in our
intended model is modelled by the global sections functor.}
}


\subtree[stt-00JY]{
\title{Tiny types}
\taxon{Definition}

\p{
We say that a type #{I} is \em{tiny} if for each crisp type #{A}, there exists:
\ul{
  \li{A crisp type #{A_I}}
  \li{A crisp map #{\epsilon : (A_I)^I \to A}}
}
Subject to the condition that for any crisp type #{X}, the induced map
#{\flat(X \to A_I) \to \flat(X^I \to A)} is an equivalence.
}

%```agda
\agda{
is-tiny-structure
  : έΙΑ {@έβφ ΏζΥν ΏζΥξ} (@έβφ I : Type ΏζΥν) (@έβφ A : Type ΏζΥξ)
      (@έβφ έΙγA : Type ΏζΥξ) (@έβφ έΙγ╬╡ : (I έΗΤ έΙγA) έΗΤ A) έΗΤ Type╧Κ
is-tiny-structure I A έΙγA έΙγ╬╡
  = έΙΑ {@έβφ ΏζΥν} {@έβφ X : Type ΏζΥν}
    έΗΤ is-equiv {A = έθρέβφ| (X έΗΤ έΙγA) έθσ} {B = έθρέβφ| ((I έΗΤ X) έΗΤ A) έθσ}
               (έβφ-map (postcomp _ έΙγ╬╡ έΙα postcomp I))
}
%```
}

\subtree[fre-F2FC]{
\title{Tiny types are closed under cartesian products}
\taxon{Proposition}
\author{fredrikbakke}
\date{2026-04-24}

%```agda
\agda{
├Ω-is-tiny-structure
  : έΙΑ {@έβφ ΏζΥα ΏζΥν ΏζΥξ} {@έβφ I : Type ΏζΥα}
      {@έβφ A : Type ΏζΥν} {@έβφ έΙγA : Type ΏζΥν} {@έβφ έΙγ╬╡A : (I έΗΤ έΙγA) έΗΤ A}
      {@έβφ B : Type ΏζΥξ} {@έβφ έΙγB : Type ΏζΥξ} {@έβφ έΙγ╬╡B : (I έΗΤ έΙγB) έΗΤ B}
    έΗΤ is-tiny-structure I A έΙγA έΙγ╬╡A
    έΗΤ is-tiny-structure I B έΙγB έΙγ╬╡B
    έΗΤ is-tiny-structure I (A ├Ω B) (έΙγA ├Ω έΙγB)
        (╬╗ f έΗΤ (έΙγ╬╡A (fst έΙα f) , έΙγ╬╡B (snd έΙα f)))
├Ω-is-tiny-structure {I = I} {A = A} {έΙγA} {έΙγ╬╡A} {B} {έΙγB} {έΙγ╬╡B} A-tiny B-tiny {X = X}
  = homotopy-is-equiv
      (╬╗ where (modέβφ f) έΗΤ refl)
      ((έβφέΚΔ (╬μ-╬ι-swapέΚΔ (╬╗ _ έΗΤ έΙγA) (╬╗ _ _ έΗΤ έΙγB))
        έΙβέΚΔ έβφ-pres-├Ω
        έΙβέΚΔ (mkέΚΔ _ A-tiny ├ΩέΚΔ mkέΚΔ _ B-tiny)
        έΙβέΚΔ έβφ-pres-├Ω eέΒ╗┬╣
        έΙβέΚΔ έβφέΚΔ (╬μ-╬ι-swapέΚΔ (╬╗ _ έΗΤ A) (╬╗ _ _ έΗΤ B)) eέΒ╗┬╣) ._έΚΔ_.has-is-eqv)
}
%```
}

\subtree[stt-00KP]{
\title{The tiny adjunction}

\p{We expose an interfaces into the basic properties of tiny types.}

%```agda
\agda{
module Tiny {@έβφ ΏζΥα} (@έβφ I : Type ΏζΥα)
            (@έβφ έΙγ : έΙΑ {@έβφ ΏζΥν} έΗΤ @έβφ Type ΏζΥν έΗΤ Type ΏζΥν)
            (@έβφ έΙγ╬╡ : έΙΑ {@έβφ ΏζΥν} {@έβφ A : Type ΏζΥν} έΗΤ (I έΗΤ έΙγ A) έΗΤ A)
            (@έβφ is-tiny-str : έΙΑ {@έβφ ΏζΥν} {@έβφ A : Type ΏζΥν}
                              έΗΤ is-tiny-structure I A (έΙγ A) έΙγ╬╡)
            (@έβφ types-separate : έΙΑ {@έβφ ΏζΥν ΏζΥξ} {@έβφ A : Type ΏζΥν} {@έβφ B : Type ΏζΥξ}
                                   {@έβφ f : A έΗΤ B} έΗΤ Types-separate f)
            where
  module is-tiny {@έβφ ΏζΥν ΏζΥξ} {@έβφ A : Type ΏζΥν} {@έβφ X : Type ΏζΥξ}
    = is-equiv (is-tiny-str {ΏζΥν} {A} {ΏζΥξ} {X})

  transpose : έΙΑ {@έβφ ΏζΥν ΏζΥξ} {@έβφ ╬Υ : Type ΏζΥν} {@έβφ A : Type ΏζΥξ}
              έΗΤ έθρέβφ| ((I έΗΤ ╬Υ) έΗΤ A)έθσ έΗΤ έθρέβφ| (╬Υ έΗΤ έΙγ A) έθσ
  transpose = is-equiv.bwd is-tiny-str

  untranspose : έΙΑ {@έβφ ΏζΥν ΏζΥξ} {@έβφ ╬Υ : Type ΏζΥν} {@έβφ A : Type ΏζΥξ}
              έΗΤ (╬Υ έΗΤ έΙγ A) έΗΤ ((I έΗΤ ╬Υ) έΗΤ A)
  untranspose = postcomp _ έΙγ╬╡ έΙα postcomp I

  transpose-unique'
    : έΙΑ {@έβφ ΏζΥν ΏζΥξ} {@έβφ ╬Υ : Type ΏζΥν} {@έβφ A : Type ΏζΥξ}
        {f : έθρέβφ| ((I έΗΤ ╬Υ) έΗΤ A)έθσ} {g : έθρέβφ| (╬Υ έΗΤ έΙγ A) έθσ}
      έΗΤ έβφ-map untranspose g Ύ╝ζ f
      έΗΤ g Ύ╝ζ transpose f
  transpose-unique' {f = f} H = unap-equiv is-tiny-str (H έΙβ is-tiny.╬╡έΒ╗┬╣ f)

  transpose-unique'-is-equiv
    : έΙΑ {@έβφ ΏζΥν ΏζΥξ} {@έβφ ╬Υ : Type ΏζΥν} {@έβφ A : Type ΏζΥξ}
        {f : έθρέβφ| ((I έΗΤ ╬Υ) έΗΤ A)έθσ} {g : έθρέβφ| (╬Υ έΗΤ έΙγ A) έθσ}
      έΗΤ is-equiv (transpose-unique' {f = f}{g})
  transpose-unique'-is-equiv{f = f}{g}
    = is-equiv-έΙα
        (unap-equiv-is-equiv is-tiny-str)
        (έΙβ-is-equiv' (is-tiny.╬╡έΒ╗┬╣ f))

  transpose-unique
    : έΙΑ {@έβφ ΏζΥν ΏζΥξ} {@έβφ ╬Υ : Type ΏζΥν} {@έβφ A : Type ΏζΥξ}
        {@έβφ f : ((I έΗΤ ╬Υ) έΗΤ A)} {@έβφ g : ╬Υ έΗΤ έΙγ A}
      έΗΤ έθρέβφ| (untranspose g) Ύ╝ζ f έθσ
      έΗΤ έθρέβφ| g Ύ╝ζ ╬╡έβφ (transpose (modέβφ f)) έθσ
  transpose-unique {g = g}
    = έβφ-map (ap ╬╡έβφ έΙα transpose-unique' {g = modέβφ g}) έΙα apέβφ' modέβφ

  transpose-unique-is-equiv
    : έΙΑ {@έβφ ΏζΥν ΏζΥξ} {@έβφ ╬Υ : Type ΏζΥν} {@έβφ A : Type ΏζΥξ}
        {@έβφ f : ((I έΗΤ ╬Υ) έΗΤ A)} {@έβφ g : ╬Υ έΗΤ έΙγ A}
      έΗΤ is-equiv (transpose-unique {f = f}{g})
  transpose-unique-is-equiv {╬Υ = ╬Υ} {A} {f} {g}
    = is-equivέΗΡArrow-equivέΒ╗┬╣
        {F = test}
        test-is-equiv
        (έβφ-map-is-equiv transpose-unique'-is-equiv) where
    lemma : έΙΑ {@έβφ ΏζΥν} {@έβφ A : Type ΏζΥν} {@έβφ x : A} {@έβφ y : έθρέβφ| A έθσ}
            έΗΤ modέβφ (╬╡έβφ y) Ύ╝ζ y
    lemma {y = modέβφ y} = refl

    lemmaέΒ╗┬╣ : έΙΑ {@έβφ ΏζΥν} {@έβφ A : Type ΏζΥν} {@έβφ x : A}{@έβφ y}
            έΗΤ έθρέβφ| x Ύ╝ζ ╬╡έβφ y έθσ έΗΤ έθρέβφ| (modέβφ x Ύ╝ζ y) έθσ
    lemmaέΒ╗┬╣ {x = x} {y} = έβφ-map ((_έΙβ lemma {x = x}) έΙα mapplyέβφ) έΙα comult

    lemmaέΒ╗┬╣-refl : έΙΑ {@έβφ ΏζΥν} {@έβφ A : Type ΏζΥν} {@έβφ x}{@έβφ y : έθρέβφ| A έθσ}
                   έΗΤ (@έβφ p : modέβφ x Ύ╝ζ y)
                   έΗΤ lemmaέΒ╗┬╣ {y = y} (modέβφ (ap ╬╡έβφ p)) Ύ╝ζ modέβφ p
    lemmaέΒ╗┬╣-refl {y = modέβφ y}
      = strong-Jέβφ (╬╗ _ p έΗΤ lemmaέΒ╗┬╣ (modέβφ (ap ╬╡έβφ p)) Ύ╝ζ modέβφ p) refl

    map : έΙΑ {@έβφ ΏζΥν} {@έβφ A : Type ΏζΥν} {@έβφ a b : A}
          έΗΤ έθρέβφ| a Ύ╝ζ b έθσ έΗΤ έθρέβφ| modέβφ a Ύ╝ζ modέβφ b έθσ
    map (modέβφ p) = modέβφ (apέβφ modέβφ p)

    map-is-equiv : έΙΑ {@έβφ ΏζΥν} {@έβφ A : Type ΏζΥν} {@έβφ a b : A}
                   έΗΤ is-equiv (map {a = a}{b})
    map-is-equiv
      = homotopy-is-equiv
          {f = έβφ-map mapplyέβφ έΙα comult }
          (έβφ-ind _
            (strong-Jέβφ
              (╬╗ b p έΗΤ (έβφ-map mapplyέβφ έΙα comult) (modέβφ p) Ύ╝ζ modέβφ (apέβφ modέβφ p))
              refl))
          (is-equiv-έΙα
            (έβφ-map-is-equiv mapplyέβφ-is-equiv)
            comult-is-equiv)

    test : Arrow-map (transpose-unique {╬Υ = ╬Υ} {A}{f}{g})
                     (έβφ-map (transpose-unique' {╬Υ = ╬Υ} {A}{modέβφ f}{modέβφ g}))
    test .Arrow-╬ι.top = map
    test .Arrow-╬ι.bot = lemmaέΒ╗┬╣
    test .Arrow-╬ι.comm (modέβφ p) = lemmaέΒ╗┬╣-refl _


    test-is-equiv : is-Arrow-equiv test
    test-is-equiv .fst = map-is-equiv
    test-is-equiv .snd = is-equiv-έΙα
      (έβφ-map-is-equiv (is-equiv-έΙα (έΙβ-is-equiv' lemma) mapplyέβφ-is-equiv))
      comult-is-equiv

  transpose-naturality
    : έΙΑ {@έβφ ΏζΥν ΏζΥξ ΏζΥο} {@έβφ ╬Υ : Type ΏζΥν} {@έβφ ╬Φ : Type ΏζΥο} {@έβφ A : Type ΏζΥξ}
      έΗΤ (P : έθρέβφ| ((I έΗΤ ╬Υ) έΗΤ A)έθσ)
      έΗΤ (@έβφ ╧Δ : ╬Φ έΗΤ ╬Υ)
      έΗΤ transpose (έβφ-map (precomp _ (postcomp I ╧Δ)) P)
      Ύ╝ζ έβφ-map (precomp _ ╧Δ) (transpose P)
  transpose-naturality (modέβφ P) ╧Δ = sym (transpose-unique'
    ( (έβφ-map untranspose έΙα έβφ-map (precomp (έΙγ _) ╧Δ)) (transpose (modέβφ P))
    Ύ╝ζέθρ sym (έβφ-έΙα untranspose (precomp _ ╧Δ) _) έθσ
       έβφ-map (untranspose έΙα precomp _ ╧Δ) (transpose (modέβφ P))
    Ύ╝ζέθρέθσ
       έβφ-map (precomp _  (postcomp _ ╧Δ) έΙα untranspose) (transpose (modέβφ P))
    Ύ╝ζέθρ έβφ-έΙα _ untranspose (transpose (modέβφ P)) έθσ
       έβφ-map (precomp _  (postcomp _ ╧Δ)) (έβφ-map untranspose (transpose (modέβφ P)))
    Ύ╝ζέθρ ap (έβφ-map _) (is-tiny.╬╡ (modέβφ P)) έθσ
      έβφ-map (precomp _ (postcomp I ╧Δ)) (modέβφ P) έΙΟ))

  untranspose-naturality
    : έΙΑ {@έβφ ΏζΥν ΏζΥν' ΏζΥξ} {@έβφ ╬Υ : Type ΏζΥν} {@έβφ ╬Φ : Type ΏζΥν'} {@έβφ A : Type ΏζΥξ}
       έΗΤ (╧Δ : ╬Φ έΗΤ ╬Υ)
       έΗΤ (f : ╬Υ έΗΤ έΙγ A)
       έΗΤ untranspose (f έΙα ╧Δ) Ύ╝ζ untranspose f έΙα postcomp _ ╧Δ
  untranspose-naturality ╧Δ f = refl

  expέΛμέΙγ : έΙΑ {@έβφ ΏζΥν ΏζΥξ} {@έβφ A : Type ΏζΥν} {@έβφ B : Type ΏζΥξ}
          έΗΤ έθρέβφ| ((I έΗΤ A) έΗΤ B) έθσ έΚΔ έθρέβφ| (A έΗΤ έΙγ B) έθσ
  expέΛμέΙγ ._έΚΔ_.fwd = _
  expέΛμέΙγ ._έΚΔ_.has-is-eqv = is-equivέΒ╗┬╣ is-tiny-str
}
%```
}

\subtree[stt-00KR]{
\title{Functoriality of the amazing right adjoint}
\taxon{Lemma}

%```agda
\agda{
  έΙγέΓΒ : έΙΑ {@έβφ ΏζΥν ΏζΥξ} {@έβφ A : Type ΏζΥν} {@έβφ B : Type ΏζΥξ} έΗΤ έθρέβφ| (A έΗΤ B) έθσ έΗΤ έθρέβφ| (έΙγ A έΗΤ έΙγ B)έθσ
  έΙγέΓΒ {B = B} = transpose έΙα έβφ-map (precomp B έΙγ╬╡)

  έΙγέΓΒ-id : έΙΑ {@έβφ ΏζΥν} {@έβφ A : Type ΏζΥν} έΗΤ έΙγέΓΒ (modέβφ id) Ύ╝ζ modέβφ (id: έΙγ A)
  έΙγέΓΒ-id = sym (transpose-unique' refl)


  έΙγέΓΒ-nat : έΙΑ {@έβφ ΏζΥν ΏζΥξ ΏζΥξ'} {@έβφ ╬Υ : Type ΏζΥν} {@έβφ A : Type ΏζΥξ} {@έβφ B : Type ΏζΥξ'}
          έΗΤ (f : έθρέβφ| (B έΗΤ A)έθσ)
          έΗΤ untranspose {╬Υ = ╬Υ} {A} έΙα postcomp _ (╬╡έβφ (έΙγέΓΒ f))
          Ύ╝ζ postcomp _ (╬╡έβφ f) έΙα untranspose
  έΙγέΓΒ-nat {╬Υ = ╬Υ} {A} (modέβφ f)
    =     untranspose έΙα postcomp ╬Υ (╬╡έβφ (έΙγέΓΒ (modέβφ f)))
    Ύ╝ζέθρέθσ
          untranspose έΙα postcomp ╬Υ (╬╡έβφ (transpose (έβφ-map (precomp _ έΙγ╬╡) (modέβφ f))))
    Ύ╝ζέθρέθσ
          (╬╗ x έΗΤ untranspose (╬╡έβφ (transpose (modέβφ (f έΙα έΙγ╬╡))) έΙα x))
    Ύ╝ζέθρέθσ
         postcomp _ (untranspose (╬╡έβφ (transpose (modέβφ (f έΙα έΙγ╬╡))))) έΙα postcomp I
    Ύ╝ζέθρ ap (_έΙα postcomp I)
           (ap (postcomp _) (sym (╬╡έβφ-natural (transpose (modέβφ (f έΙα έΙγ╬╡)))) )) έθσ
         postcomp _ (╬╡έβφ (έβφ-map untranspose (transpose (modέβφ (f έΙα έΙγ╬╡)))))
       έΙα postcomp I
    Ύ╝ζέθρ ap (_έΙα postcomp I) (ap (postcomp _) (ap ╬╡έβφ (is-tiny.╬╡ (modέβφ (f έΙα έΙγ╬╡))))) έθσ
          postcomp _ (f έΙα έΙγ╬╡) έΙα postcomp I
    Ύ╝ζέθρέθσ
          postcomp (I έΗΤ _) f έΙα untranspose
    έΙΟ

  έβφ-map' : έΙΑ {@έβφ ΏζΥν ΏζΥξ} {@έβφ A : Type ΏζΥν} {@έβφ B : Type ΏζΥξ}
             (f : έθρέβφ| (A έΗΤ B)έθσ) έΗΤ έθρέβφ| A έθσ έΗΤ έθρέβφ| B έθσ
  έβφ-map' (modέβφ f) = έβφ-map f

  _έΙαέβφ_ : έΙΑ {@έβφ ΏζΥν ΏζΥξ ΏζΥο} {@έβφ A : Type ΏζΥν} {@έβφ B : Type ΏζΥξ} {@έβφ C : Type ΏζΥο}
           (f : έθρέβφ| (B έΗΤ C) έθσ) (g : έθρέβφ| (A έΗΤ B)έθσ) έΗΤ έθρέβφ| (A έΗΤ C)έθσ
  _έΙαέβφ_ f = έβφ-map' (έβφ-map (postcomp _) f)

  έβφ-map-έΙαέβφ
    : έΙΑ {@έβφ ΏζΥν ΏζΥξ ΏζΥο} {@έβφ A : Type ΏζΥν} {@έβφ B : Type ΏζΥξ} {@έβφ C : Type ΏζΥο}
        (f : έθρέβφ| (B έΗΤ C)έθσ) (g : έθρέβφ| (A έΗΤ B)έθσ)
      έΗΤ έβφ-map' (f έΙαέβφ g) ~ έβφ-map' f έΙα έβφ-map' g
  έβφ-map-έΙαέβφ (modέβφ f) (modέβφ g) (modέβφ a) = refl
}
%```
}


\subtree[stt-00KI]{
\title{Naturality of the counit}
\taxon{Lemma}

\p{The counit map is a natural transformation.}

%```agda
\agda{
  opaque
    έΙγ╬╡-nat
      : έΙΑ {@έβφ ΏζΥν ΏζΥξ} {@έβφ ╬Υ : Type ΏζΥν} {@έβφ A : Type ΏζΥξ}
          {@έβφ f : ╬Υ έΗΤ A}
        έΗΤ έβφ-map έΙγ╬╡ έΙα έβφ-map' (έβφ-map (postcomp I) (έΙγέΓΒ (modέβφ f)))
        ~ έβφ-map f έΙα έβφ-map έΙγ╬╡
    έΙγ╬╡-nat {f = f}
      = έβφ-map' (modέβφ έΙγ╬╡) έΙα έβφ-map' (έβφ-map (postcomp I) (έΙγέΓΒ (modέβφ f)))
      ~έθρ έβφ-map-έΙαέβφ (modέβφ έΙγ╬╡) (έβφ-map (postcomp I) (έΙγέΓΒ (modέβφ f))) ~έΒ╗┬╣ έθσ
        έβφ-map' (modέβφ έΙγ╬╡ έΙαέβφ έβφ-map (postcomp I) (έΙγέΓΒ (modέβφ f)))
      ~έθρέθσ
        έβφ-map' (((modέβφ έΙγ╬╡ έΙαέβφ_) έΙα έβφ-map (postcomp I)) (έΙγέΓΒ (modέβφ f)))
      ~έθρ happly (ap έβφ-map'
                ( happly (ap (_έΙα έβφ-map (postcomp I)) (funextέΗΤ lemma)) (έΙγέΓΒ (modέβφ f))
                έΙβ sym (έβφ-έΙα (postcomp _ έΙγ╬╡) (postcomp I) (έΙγέΓΒ (modέβφ f))))) έθσ
        έβφ-map' (έβφ-map (postcomp _ έΙγ╬╡ έΙα postcomp I) (έΙγέΓΒ (modέβφ f)))
      ~έθρ happly (ap έβφ-map' (is-equiv.╬╡ is-tiny-str (modέβφ (f έΙα έΙγ╬╡)))) έθσ
        έβφ-map' (modέβφ (f έΙα έΙγ╬╡))
      ~έθρέθσ
        έβφ-map (f έΙα έΙγ╬╡)
      ~έθρ έβφ-έΙα f έΙγ╬╡ έθσ
        έβφ-map f έΙα έβφ-map έΙγ╬╡
      ~έΙΟ where
      lemma : έΙΑ {@έβφ ΏζΥν ΏζΥξ} {@έβφ A : Type ΏζΥν} {@έβφ B : Type ΏζΥξ}
               έΗΤ (_έΙαέβφ_ (modέβφ έΙγ╬╡)) ~ έβφ-map {B = A έΗΤ B} (postcomp A έΙγ╬╡)
      lemma (modέβφ x) = refl


  έΙγ╬╡-naturality-square

\date{2026-04-29}
\title{Functoriality of coproducts}
\taxon{Module}
\author{fredrikbakke}
\import{stt-macros}

\agda{
module Foundations.CoproductFunctoriality where

open import Foundations.Coproducts
open import Foundations.Sigma
open import Foundations.Universes
}

\subtree[fre-AA13]{
\title{Functorial action of coproducts}
\taxon{Definition}
\author{fredrikbakke}

\agda{
infixl 20 _⨄₁_
_⨄₁_
  : ∀ {𝓤 𝓥 𝓦 𝓣}
      {A : Type 𝓤} {B : Type 𝓥}
      {C : Type 𝓦} {D : Type 𝓣}
    → (A → B)
    → (C → D)
    → A ⊎ C → B ⊎ D
(f ⨄₁ g) (inl x) = inl (f x)
(f ⨄₁ g) (inr y) = inr (g y)
}
}

\subtree[fre-5867]{
\title{Coproducts of families}
\taxon{Definition}
\author{fredrikbakke}

\agda{
infixl 10 _⨄ᶠ_
_⨄ᶠ_
  : ∀ {𝓘 𝓙 𝓤}
      {I : Type 𝓘} {J : Type 𝓙}
      (A : I → Type 𝓤) (B : J → Type 𝓤)
    → I ⊎ J → Type 𝓤
(A ⨄ᶠ C) (inl i) = A i
(A ⨄ᶠ B) (inr j) = B j
}
}

\subtree[fre-91OJ]{
\title{Coproducts of families of maps}
\taxon{Definition}
\author{fredrikbakke}

\agda{
module _
  {𝓘 𝓙 𝓤 𝓥}
  {I : Type 𝓘} {J : Type 𝓙}
  {A : I → Type 𝓤} {B : I → Type 𝓥}
  {C : J → Type 𝓤} {D : J → Type 𝓥}
  (f : (i : I) → A i → B i)
  (g : ((j : J) → C j → D j))
  where

  ⨄₁ᶠ-carrier : Type (𝓘 ⊔ 𝓙 ⊔ 𝓤 ⊔ 𝓥)
  ⨄₁ᶠ-carrier = (k : I ⊎ J) → (A ⨄ᶠ C) k → (B ⨄ᶠ D) k

  infixl 10 _⨄₁ᶠ_
  _⨄₁ᶠ_ : ⨄₁ᶠ-carrier
  _⨄₁ᶠ_ = ⊎-ind (f , g)
}
}

\date{2025-04-14}
\title{Fibrewise equivalences}
\taxon{Module}

\import{stt-macros}

% ```agda
\agda{
module Foundations.FibrewiseEquiv where

open import Foundations.Universes
open import Foundations.Sigma
open import Foundations.SigmaPath
open import Foundations.Identity
open import Foundations.DependentIdentity
open import Foundations.Functions
open import Foundations.QuasiIsomorphism
open import Foundations.CoherentIsomorphism
}
% ```

\subtree[stt-0029]{
\taxon{Definition}
\title{Fibrewise equivalence}

% ```agda
\agda{
is-fibrewise-equiv : тИА {ЁЭУд ЁЭУе ЁЭУж} {A : Type ЁЭУд} {B : A тЖТ Type ЁЭУе} {B' : A тЖТ Type ЁЭУж} тЖТ (тИА a тЖТ B a тЖТ B' a) тЖТ Type (ЁЭУд тКФ ЁЭУе тКФ ЁЭУж)
is-fibrewise-equiv f = тИА a тЖТ is-equiv (f a)
}
% ```
}


\subtree[stt-0030]{
\taxon{Theorem}
\title{Equivalences on fibres give equivalences on the total}

% ```agda
\agda{
total-map : тИА {ЁЭУд ЁЭУе ЁЭУж} {A : Type ЁЭУд} {B : A тЖТ Type ЁЭУе} {B' : A тЖТ Type ЁЭУж}
               тЖТ (f : тИА a тЖТ B a тЖТ B' a) тЖТ ╬г A B тЖТ ╬г A B'
total-map f (a , b) = (a , f a b)

is-total-equivтЖРis-fibrewise-equiv : тИА {ЁЭУд ЁЭУе ЁЭУж} {A : Type ЁЭУд}
   {B : A тЖТ Type ЁЭУе} {B' : A тЖТ Type ЁЭУж} тЖТ {f : тИА a тЖТ B a тЖТ B' a}
   тЖТ is-fibrewise-equiv f тЖТ is-equiv (total-map f)
is-total-equivтЖРis-fibrewise-equiv {f = f} feq = is-equivтЖРqiso iso where
  module A x = is-equiv (feq x)
  open A

  iso : quasi-iso (total-map f)
  iso .fst (a , b) = a , bwd a b
  iso .snd .fst (a , b) = ╬г-pathтЖТ (refl , retraction-fwd a .snd b)
  iso .snd .snd (a , b) = ╬г-pathтЖТ (refl , section-fwd a .snd b)

╬г-ap-тЙГ : тИА {ЁЭУд ЁЭУе ЁЭУж} {A : Type ЁЭУд} {B : A тЖТ Type ЁЭУе} {B' : A тЖТ Type ЁЭУж} тЖТ ((a : A) тЖТ B a тЙГ B' a) тЖТ  ╬г A B тЙГ ╬г A B'
╬г-ap-тЙГ eq = mkтЙГ (total-map (_тЙГ_.fwd тИШ eq))
                (is-total-equivтЖРis-fibrewise-equiv (_тЙГ_.has-is-eqv тИШ eq))
}
% ```
}

\subtree[stt-008R]{
\title{Characterising fibrewise equivalences}
\taxon{Corollary}

%```agda
\agda{
fibrewise-equivтЙГ : тИА {ЁЭУд ЁЭУе ЁЭУж} {A : Type ЁЭУд} {B : A тЖТ Type ЁЭУе}
                     {B' : A тЖТ Type ЁЭУж}
                   тЖТ (╬г[ f тИ╢ (тИА a тЖТ B a тЖТ B' a)] is-fibrewise-equiv f)
                   тЙГ (тИА a тЖТ B a тЙГ B' a)
fibrewise-equivтЙГ {B = B} {B'} = mkтЙГ map (is-equivтЖРqiso qiso) where
  map : ╬г (тИА a тЖТ B a тЖТ B' a) is-fibrewise-equiv тЖТ тИА a тЖТ B a тЙГ B' a
  map (f , feq) a = mkтЙГ (f a) (feq a)

  qiso : quasi-iso map
  qiso .fst fe = ( (╬╗ a x тЖТ fe a ._тЙГ_.fwd x)
                 , (╬╗ a тЖТ fe a ._тЙГ_.has-is-eqv))
  qiso .snd .fst _ = refl
  qiso .snd .snd _ = refl
}
%```
}

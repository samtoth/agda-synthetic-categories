\date{2025-04-17}
\taxon{Module}
\title{Universal property of the [unit type](Foundations.Unit)}
\import{stt-macros}



% ```agda
\agda{
module Foundations.UnitUP where

open import Foundations.Universes
open import Foundations.Unit
open import Foundations.Identity
open import Foundations.QuasiIsomorphism
open import Foundations.CoherentIsomorphism
open import Foundations.IdentityEquiv
open import Foundations.EquivHomotopy
open import Foundations.Sigma
open import Foundations.SigmaProperties
open import Foundations.Functions
open import Foundations.Singleton
open import Foundations.DependentIdentity
open import Foundations.FunExt
}
% ```

\subtree[stt-002Q]{
\taxon{Theorem}

% ```agda
\agda{
unit-ev-is-equiv : ‚ąÄ {ūĚď§} {A : ūĚüô ‚Üí Type ūĚď§} ‚Üí is-equiv (ev {B = A} tt)
unit-ev-is-equiv = is-equiv‚Üźqiso iso where
  iso : quasi-iso (ev tt)
  iso .fst a _ = a
  iso .snd .fst _ = refl
  iso .snd .snd _ = refl

unit-UP‚ČÉ : ‚ąÄ {ūĚď§} {A : ūĚüô ‚Üí Type ūĚď§} ‚Üí ((a : ūĚüô) ‚Üí A a) ‚ČÉ A tt
unit-UP‚ČÉ = mk‚ČÉ (ev tt) unit-ev-is-equiv

point-is-equiv : ‚ąÄ {ūĚď§} {A : Type ūĚď§} ‚Üí is-equiv (point {A = A})
point-is-equiv = is-equiv‚ĀĽ¬Ļ unit-ev-is-equiv

fibre-point‚ČÉ
  : ‚ąÄ {ūĚď§} {A : Type ūĚď§}
  ‚Üí (a b : A)
  ‚Üí fibre (point a) b ‚ČÉ (a ÔľĚ b)
fibre-point‚ČÉ a b = ő£-singl ūĚüô-is-singleton tt
}
% ```
}

\subtree[stt-00D8]{
\taxon{Remark}

\p{The fact that unit has definitional eta allows us to do without
  funext in the above theorem. When generalising to arbitrary singletons
  (or if we were to disable unit-eta) we require funext.
}
}

\subtree[stt-006S]{
\date{2025-06-27}
\author{samueltoth}
\date{2025-03-09}
\author{fredrikbakke}
\title{Universal property for singleton types}
\taxon{Theorem}

% ```agda
\agda{
sing-evŠĶą-is-equiv : ‚ąÄ {ūĚď§ ūĚď•} {A : Type ūĚď§} {B : A ‚Üí Type ūĚď•}
                    ‚Üí FunExtŌČ ūĚď•
                    ‚Üí (s : is-singleton A)
                    ‚Üí is-equiv (ev {B = B} (centre s))
sing-evŠĶą-is-equiv {B = B} FE s = is-equiv‚Üźqiso qiso where
  qiso : quasi-iso (ev {B = B} (centre s))
  qiso .fst x a = tr B (central s a) x
  qiso .snd .fst f = WithFunExtŌČ.funext‚Üí FE (őĽ a ‚Üí apŠĶą f (central s a))
  qiso .snd .snd x
    = ap (őĽ q ‚Üí tr B q x)
         (is-set‚Üźis-single s (centre s) (centre s)
           (central s (centre s))
           (refl))

sing-ev-is-equiv : ‚ąÄ {ūĚď§ ūĚď•} {A : Type ūĚď§} {B : Type ūĚď•}
                   ‚Üí FunExtŌČ ūĚď•
                   ‚Üí (s : is-singleton A)
                   ‚Üí is-equiv (ev {B = őĽ _ ‚Üí B} (centre s))
sing-ev-is-equiv FE s = is-equiv‚Üźqiso qiso where
  qiso : quasi-iso (ev (centre s))
  qiso .fst a _ = a
  qiso .snd .fst f = WithFunExtŌČ.funext‚Üí FE (őĽ a ‚Üí ap f (central s a))
  qiso .snd .snd _ = refl

sing-UP‚ČÉ : ‚ąÄ {ūĚď§ ūĚď•} {A : Type ūĚď§} {B : Type ūĚď•}
           ‚Üí FunExtŌČ ūĚď•
           ‚Üí (s : is-singleton A)
           ‚Üí (A ‚Üí B) ‚ČÉ B
sing-UP‚ČÉ FE sing = mk‚ČÉ (ev (sing .centre)) (sing-ev-is-equiv FE sing)

sing-const-is-equiv : ‚ąÄ {ūĚď§ ūĚď•} {A : Type ūĚď§} {B : Type ūĚď•}
                      ‚Üí FunExtŌČ ūĚď•
                      ‚Üí (s : is-singleton A)
                      ‚Üí is-equiv (const B A)
sing-const-is-equiv FE s = is-equiv‚ĀĽ¬Ļ (sing-ev-is-equiv FE s)

sing-!-is-equiv : ‚ąÄ {ūĚď§} {A : Type ūĚď§} ‚Üí is-singleton A ‚Üí is-equiv (!: A)
sing-!-is-equiv as .is-equiv.qiso .fst = const _ _ (as .centre)
sing-!-is-equiv as .is-equiv.qiso .snd .fst = as .central
sing-!-is-equiv as .is-equiv.qiso .snd .snd _ = refl
sing-!-is-equiv as .is-equiv.coherent x
  = is-prop‚Üźis-single (ÔľĚ-singleton‚Üźis-single (ūĚüô-is-singleton) _ _) _  _

sing‚ČÉūĚüô : ‚ąÄ {ūĚď§} {A : Type ūĚď§} ‚Üí is-singleton A ‚Üí A ‚ČÉ ūĚüô
sing‚ČÉūĚüô as ._‚ČÉ_.fwd = !
sing‚ČÉūĚüô as ._‚ČÉ_.has-is-eqv = sing-!-is-equiv as
}
% ```
}

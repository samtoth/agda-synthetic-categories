\subtree[stt-007V]{
\title{Co-cartesian squares}
\taxon{Definition}

\p{Given a square:}

\quiver{
\begin{tikzcd}
	A && X \\
	\\
	B && Y
	\arrow["{f'}", from=1-1, to=1-3]
	\arrow["f"', from=1-1, to=3-1]
	\arrow["g", from=1-3, to=3-3]
	\arrow["{g'}"', from=3-1, to=3-3]
\end{tikzcd}
}

\p{we say that the square is cocartesian if the square [given by
precomposition](stt-003P) is a [cartesian square](stt-003V).}

\agda{
up-cocartesian'
  : тИА {ЁЭУд ЁЭУе ЁЭУж ЁЭУЬ} {A : Type ЁЭУд} {B : Type ЁЭУе}
      {X : Type ЁЭУж} {Y : Type ЁЭУЬ}
      {f : A тЖТ B} {g : X тЖТ Y}
    тЖТ Arrow-map f g тЖТ (ЁЭУа : Level)
    тЖТ Type (ЁЭУд тКФ ЁЭУе тКФ ЁЭУж тКФ ЁЭУЬ тКФ lsuc ЁЭУа)
up-cocartesian' F ЁЭУа = тИА (Q : Type ЁЭУа)
                     тЖТ is-cartesian (precomp-square F Q)


up-cocartesian
  : тИА {ЁЭУд ЁЭУе ЁЭУж ЁЭУЬ} {A : Type ЁЭУд} {B : Type ЁЭУе}
      {X : Type ЁЭУж} {Y : Type ЁЭУЬ}
      {f : A тЖТ B} {g : X тЖТ Y}
    тЖТ Arrow-map f g
    тЖТ Type╧Й
up-cocartesian F = тИА {ЁЭУа} (Q : Type ЁЭУа)
                    тЖТ is-cartesian (precomp-square F Q)
}
}

\subtree[stt-007W]{
\title{Cocartesian squares are pushouts}
\taxon{Theorem}

\proof{An easy consequence of \ref{stt-003C} and \ref{stt-007Y}}

\agda{
up-pushoutтЖРup-cocartesian
  : тИА {ЁЭУд ЁЭУе ЁЭУж ЁЭУЬ} {A : Type ЁЭУд} {B : Type ЁЭУе}
      {X : Type ЁЭУж} {Y : Type ЁЭУЬ}
      {f : A тЖТ B} {g : X тЖТ Y}
      (F : Arrow-map f g)
    тЖТ up-cocartesian F тЖТ up-pushout _ (CoconeтЖРArrow-map F .snd)
up-pushoutтЖРup-cocartesian {f = f} {g} F cc
  = up-pushoutтЖРprecomp-pullback _
       (╬╗ Q тЖТ up-pullbackтЖРis-cartesian (precomp-square F Q) (cc Q))

up-cocartesianтЖРup-pushout
  : тИА {ЁЭУд ЁЭУе ЁЭУж ЁЭУЬ} {S : Span ЁЭУд ЁЭУе ЁЭУж} {D : Type ЁЭУЬ} {C : Cocone S D}
    тЖТ up-pushout S C тЖТ up-cocartesian (Arrow-mapтЖРCocone C)
up-cocartesianтЖРup-pushout po Q
  = is-cartesianтЖРup-pullback
      (precomp-square (Arrow-mapтЖРCocone _) Q)
      (precomp-pullbackтЖРup-pushout _ po Q)
}
}


\subtree[stt-00CQ]{
\title{The mirror of a cocartesian square is cocartesian}
\taxon{Lemma}

\agda{
transpose-square-has-up-cocartesian
  : тИА {ЁЭУд ЁЭУе ЁЭУж ЁЭУЬ} {A : Type ЁЭУд} {B : Type ЁЭУе}
      {X : Type ЁЭУж} {Y : Type ЁЭУЬ}
      {f : A тЖТ B} {g : X тЖТ Y}
      (F : Arrow-map f g)
    тЖТ up-cocartesian F тЖТ up-cocartesian (transpose-square F)
transpose-square-has-up-cocartesian F cocart
  = up-cocartesianтЖРup-pushout
     (up-pushoutтЖРis-pushout _
      (is-equiv-~тИШ
        {f = cogap-mapтЖРsquare F}
        {g = pushout-flip}
        (sym тИШ pushout-rec-unique _ _ ~refl ~refl
          (╬╗ a тЖТ тИЩ-reflr _ тИЩ ap-тИШ (cogap-mapтЖРsquare F) (pushout-flip) (glue a)
          тИЩ ap (ap _) (pushout-rec-ap╬▓ a) тИЩ ap-sym _ (glue a)
          тИЩ ap sym (pushout-rec-ap╬▓ a)))
        (is-pushoutтЖРup-pushout _ (up-pushoutтЖРup-cocartesian _ cocart))
        (pushout-comm ._тЙГ_.fwd-is-equiv)))

transpose-is-idempotent-cube
  : тИА {ЁЭУд ЁЭУе ЁЭУж ЁЭУЬ} {A : Type ЁЭУд} {B : Type ЁЭУе}
      {X : Type ЁЭУж} {Y : Type ЁЭУЬ}
      {f : A тЖТ B} {g : X тЖТ Y}
      (F : Arrow-map f g)
      {ЁЭУа} (Q : Type ЁЭУа)
    тЖТ Cube
        (precomp-square (transpose-square (transpose-square F)) Q)
        (precomp-square F Q)
transpose-is-idempotent-cube F Q .Cube.left = id-square
transpose-is-idempotent-cube F Q .Cube.right = id-square
transpose-is-idempotent-cube F Q .Cube.comm .fst = ~refl
transpose-is-idempotent-cube F Q .Cube.comm .snd .fst = ~refl
transpose-is-idempotent-cube F Q .Cube.comm .snd .snd a
  = ap (_тИЩ refl)
       (sym (ap-id _ тИЩ ap funextтЖТ (funextтЖТ (╬╗ x тЖТ ap (ap a) sym-sym))))

transpose-is-idempotent
  : тИА {ЁЭУд ЁЭУе ЁЭУж ЁЭУЬ} {A : Type ЁЭУд} {B : Type ЁЭУе}
      {X : Type ЁЭУж} {Y : Type ЁЭУЬ}
      {f : A тЖТ B} {g : X тЖТ Y}
      (F : Arrow-map f g)
      {ЁЭУа} (Q : Type ЁЭУа)
    тЖТ is-Cube-equiv (transpose-is-idempotent-cube F Q)
transpose-is-idempotent {f = f} {g} F Q .fst
  = id-square-is-equiv {f = precomp Q g}
transpose-is-idempotent {f = f} {g} F Q .snd
  = id-square-is-equiv {f = precomp Q f}

untranspose-square-has-up-cocartesian
  : тИА {ЁЭУд ЁЭУе ЁЭУж ЁЭУЬ} {A : Type ЁЭУд} {B : Type ЁЭУе}
      {X : Type ЁЭУж} {Y : Type ЁЭУЬ}
      {f : A тЖТ B} {g : X тЖТ Y}
      (F : Arrow-map f g)
    тЖТ up-cocartesian (transpose-square F)
    тЖТ up-cocartesian F
untranspose-square-has-up-cocartesian F rFcc Q
  = back-cartesianтЖРequiv-cube
      {F = (precomp-square (transpose-square (transpose-square F)) Q)}
      {G = precomp-square F Q}
      (transpose-is-idempotent-cube F Q)
      (transpose-is-idempotent F Q)
      (transpose-square-has-up-cocartesian _ rFcc Q)
}
}

\subtree[stt-00BT]{
\title{Canonical pushouts are cocartesian squares}
\taxon{Corollary}

\agda{
Pushout-square
  : тИА {ЁЭУд ЁЭУе ЁЭУж} (S : Span ЁЭУд ЁЭУе ЁЭУж) тЖТ let open Span S
    in Arrow-map left {D = Pushout left right} ╬╣тВВ
Pushout-square S .Arrow-map.top = S .Span.right
Pushout-square S .Arrow-map.bot = ╬╣тВБ
Pushout-square S .Arrow-map.comm = glue

Pushout-square-has-up-cocartesian
  : тИА {ЁЭУд ЁЭУе ЁЭУж} (S : Span ЁЭУд ЁЭУе ЁЭУж) тЖТ up-cocartesian (Pushout-square S)
Pushout-square-has-up-cocartesian S = up-cocartesianтЖРup-pushout Pushout-has-up-pushout

Pushout-square'
  : тИА {ЁЭУд ЁЭУе ЁЭУж} (S : Span ЁЭУд ЁЭУе ЁЭУж) тЖТ let open Span S
    in Arrow-map right {D = Pushout left right} ╬╣тВБ
Pushout-square' S = transpose-square (Pushout-square S)

Pushout-square'-has-up-cocartesian
  : тИА {ЁЭУд ЁЭУе ЁЭУж} (S : Span ЁЭУд ЁЭУе ЁЭУж) тЖТ up-cocartesian (Pushout-square' S)
Pushout-square'-has-up-cocartesian S = transpose-square-has-up-cocartesian _
                                     (up-cocartesianтЖРup-pushout
                                       Pushout-has-up-pushout)
}
}

\subtree[stt-0080]{
\title{Pushouts squares of equivalences}
\taxon{Theorem}

\p{Given an equivalence #{f} and any map #{g}, together with a
square #{f \to g}, the square is cocartesian iff #{g} is an
equivalence.}

\proof{
\p{We have the following square given by precomposition:}
\quiver{
\begin{tikzcd}
	{Q^Y} &&& {Q^B} \\
	& \bullet \\
	\\
	{Q^X} &&& {Q^A}
	\arrow["{Q^b}", from=1-1, to=1-4]
	\arrow["{\rm{gap}}", dashed, from=1-1, to=2-2]
	\arrow["{Q^g}"', from=1-1, to=4-1]
	\arrow["{Q^f}", from=1-4, to=4-4]
	\arrow[from=2-2, to=1-4]
	\arrow["\sim", from=2-2, to=4-1]
	\arrow["\lrcorner"{anchor=center, pos=0.125}, draw=none, from=2-2, to=4-4]
	\arrow["{Q^t}"', from=4-1, to=4-4]
\end{tikzcd}
}

\p{By \ref{stt-007Z}, the projection from the pullback to #{Q^X} is an
equivalence because #{Q^f} is. Then we have a triangle which, by the
[3 for 2](stt-003E) property, shows that #{Q^g} is an equivalence iff
the gap map is.}
}

\agda{
cocartesianтЖРequiv-map
  : тИА {ЁЭУд ЁЭУе ЁЭУж ЁЭУЬ} {A : Type ЁЭУд} {B : Type ЁЭУе} {X : Type ЁЭУж}
      {Y : Type ЁЭУЬ} {f : A тЖТ B} {g : X тЖТ Y}
      (F : Arrow-map f g)
    тЖТ is-equiv f
    тЖТ is-equiv g
    тЖТ up-cocartesian F
cocartesianтЖРequiv-map F feq geq Q
  = is-cartesianтЖРup-pullback (precomp-square F Q)
      (up-pullbackтЖРis-pullback (ConeтЖРArrow-map (precomp-square F Q) .snd)
        (3-for-2
           (pullback-equivтВБ (precomp-equiv feq))
           (precomp-equiv geq))) where
  module F = Arrow-map F

dom-is-equivтЖРcocartesian
  : тИА {ЁЭУд ЁЭУе ЁЭУж ЁЭУЬ} {A : Type ЁЭУд} {B : Type ЁЭУе} {X : Type ЁЭУж}
      {Y : Type ЁЭУЬ} {f : A тЖТ B} {g : X тЖТ Y}
      (F : Arrow-map f g)
    тЖТ is-equiv f
    тЖТ up-cocartesian F
    тЖТ is-equiv g
dom-is-equivтЖРcocartesian F feq cart = is-equivтЖРprecomp _
  ╬╗ {_} {Q} тЖТ is-equiv-тИШ
      (pullback-equivтВБ (precomp-equiv feq))
      (is-pullbackтЖРup-pullback
        (ConeтЖРArrow-map (precomp-square F Q) .snd)
        (up-pullbackтЖРis-cartesian _ (cart Q)))
}
}

\subtree[stt-00EC]{
\title{Pasting for cocartesian squares}
\taxon{Lemma}

\p{Given a pair of squares, as follows: }

\quiver{
\begin{tikzcd}
	\bullet && \bullet && \bullet \\
	\\
	\bullet && \bullet && \bullet
	\arrow[from=1-1, to=1-3]
	\arrow[from=1-1, to=3-1]
	\arrow[from=1-3, to=1-5]
	\arrow[from=1-3, to=3-3]
	\arrow[from=1-5, to=3-5]
	\arrow[from=3-1, to=3-3]
	\arrow["\lrcorner"{anchor=center, pos=0.125, rotate=180}, draw=none, from=3-3, to=1-1]
	\arrow[from=3-3, to=3-5]
\end{tikzcd}
}

\p{The right square is a pushout iff the whole square is.}

\proof{
\p{Call the first square #{F} and the second #{G}. Then we first prove that
#{Q^{F \circ G} \sim Q^G \circ Q^F}. Then the result follows from the
[analogous theorem](stt-003W) for [cartesian squares](stt-003V). Note however,
that the contravariance of taking the postcomposition square means that
cartesian squares are right cancelative, so cocartesian squares must be left
cancelative.}
}

\agda{
precomp-square-тИШ
  : тИА {ЁЭУд ЁЭУе ЁЭУж ЁЭУЬ ЁЭУЭ ЁЭУЫ} {A : Type ЁЭУд} {B : Type ЁЭУе} {X : Type ЁЭУж} {Y : Type ЁЭУЬ}
      {U : Type ЁЭУЭ} {V : Type ЁЭУЫ} {f : A тЖТ B} {g : X тЖТ Y} {h : U тЖТ V}
      (F : Arrow-map g h) (G : Arrow-map f g)
      {ЁЭУа} (Q : Type ЁЭУа)
    тЖТ Arrow-map-path
        (paste-squares (precomp-square G Q) (precomp-square F Q))
        (precomp-square (paste-squares F G) Q)
precomp-square-тИШ F G Q .fst = ~refl
precomp-square-тИШ F G Q .snd .fst = ~refl
precomp-square-тИШ {f = f} {g} {h} F G Q .snd .snd
 = comm (paste-squares (precomp-square G Q) (precomp-square F Q)) ~тИЩ ~refl
       ~тЯи ~тИЩ-reflr _ тЯй
   comm (paste-squares (precomp-square G Q) (precomp-square F Q))
       ~тЯитЯй
    (precomp Q (G .top) тЧВ precomp-square F Q .comm
    ~тИЩ precomp-square G Q .comm тЦ╕ precomp Q (F .bot))
       ~тЯитЯй
    (precomp Q (G .top) тЧВ funextтЖТ тИШ (_тЧВ (comm F ~тБ╗┬╣))
    ~тИЩ funextтЖТ тИШ (_тЧВ (comm G ~тБ╗┬╣)) тЦ╕ precomp Q (F .bot))
       ~тЯи (╬╗ a тЖТ ap (_тИЩ funextтЖТ _)
         (sym (commutes-prewhisker-funext (a тЧВ (comm F ~тБ╗┬╣))))
         тИЩ sym (funext-тИЩ _ _)) тЯй
   funextтЖТ тИШ (╬╗ a тЖТ a тЧВ (sym тИШ comm F тИШ top G) ~тИЩ (a тИШ F .bot) тЧВ (sym тИШ comm G))
       ~тЯи (╬╗ a тЖТ ap funextтЖТ (funextтЖТ ╬╗ x
         тЖТ ap (ap a (sym (comm F _)) тИЩ_)
             ( тЧВтИШ  a (bot F) (sym тИШ comm G) x)
             тИЩ sym (ap-тИЩ a (sym (comm F (top G x))) (ap (bot F) _))
             тИЩ ap (ap a) (sym (тИЩ-symsym (ap (bot F) (comm G x)) _
             тИЩ ap (sym (comm F (top G x)) тИЩ_)
                  (sym (ap-sym (bot F) (comm G x))))))) тЯй
   funextтЖТ тИШ (╬╗ a тЖТ a тЧВ ((F .bot тЧВ comm G ~тИЩ comm F тЦ╕ G .top) ~тБ╗┬╣))
       ~тЯитЯй
   comm (precomp-square (paste-squares F G) Q) ~тИО where open Arrow-map

opaque
  cocartesian-square-тИШ
    : тИА {ЁЭУд ЁЭУе ЁЭУж ЁЭУЬ ЁЭУЭ ЁЭУЫ} {A : Type ЁЭУд} {B : Type ЁЭУе} {X : Type ЁЭУж} {Y : Type ЁЭУЬ}
        {U : Type ЁЭУЭ} {V : Type ЁЭУЫ} {f : A тЖТ B} {g : X тЖТ Y} {h : U тЖТ V}
        {F : Arrow-map g h} {G : Arrow-map f g}
      тЖТ up-cocartesian F тЖТ up-cocartesian G
      тЖТ up-cocartesian (paste-squares F G)
  cocartesian-square-тИШ {F = F} {G} fc gc Q
    = tr is-cartesian (Arrow-map-pathтЖТ (precomp-square-тИШ F G Q))
        (compose-cartesian (gc Q) (fc Q))

  cocartesian-square-cancel
    : тИА {ЁЭУд ЁЭУе ЁЭУж ЁЭУЬ ЁЭУЭ ЁЭУЫ} {A : Type ЁЭУд} {B : Type ЁЭУе} {X : Type ЁЭУж} {Y : Type ЁЭУЬ}
        {U : Type ЁЭУЭ} {V : Type ЁЭУЫ} {f : A тЖТ B} {g : X тЖТ Y} {h : U тЖТ V}
        {F : Arrow-map g h} {G : Arrow-map f g}
      тЖТ up-cocartesian G тЖТ up-cocartesian (paste-squares F G)
      тЖТ up-cocartesian F
  cocartesian-square-cancel {F = F} {G = G} Gc FGc Q
    = 3-for-2-cartesian
        {a = precomp-square G Q}
        {b = precomp-square F Q}
        (Arrow-map-pathтЖРid (sym (Arrow-map-pathтЖТ (precomp-square-тИШ F G Q))))
        (FGc Q)
        (Gc Q)
}
}

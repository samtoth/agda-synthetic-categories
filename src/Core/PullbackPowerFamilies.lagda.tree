\taxon{Module}
\import{stt-macros}

\title{The pullback power of families}

%```agda
\agda{
module Core.PullbackPowerFamilies where

open import Foundations.Prelude
open import ufAxioms

open import Core.Arrow
open import Core.ArrowEquiv
open import Core.LiftingSquares
open import Ergonomics.Extensionality
}
%```

\subtree[stt-00EO]{
\taxon{Definition}
\title{Dependent pullback powers}

\p{
Given a type family #{B : A \to \UU} and a dependent type family over #{B},
#{Y : (a : A) \to X(a) \to \UV}, then the
\em{dependent pullback power family} #{\pulldpow_B Y} is the family

##{
\pulldpow_B Y
\coloneqq
((i , j) : \Sigma_{(i : (a : A) \to X(a))} (\Pi_{(a : A)}(B(a) \to Y(a, i(a)))))
\mapsto
(\Pi_{(a : A)} \nullhtpy(j(a)))
}

This is precisely the straightening of the
[dependent pullback power of arrows](stt-00EN).
}

%```agda
\agda{
module _ {𝓤1 𝓤2 𝓤3 𝓤4 : Level}
         (F@(A , B) : Fam 𝓤1 𝓤2)
         (G@(X , Y) : DepFam 𝓤3 𝓤4 F) where

  Fam-Π : Type (𝓤1 ⊔ 𝓤2 ⊔ 𝓤3 ⊔ 𝓤4)
  Fam-Π = Σ ((a : A) → X a) (λ i → (a : A) → B a → Y a (i a))

  base-Π̂ᶠ : Type (𝓤1 ⊔ 𝓤2 ⊔ 𝓤3 ⊔ 𝓤4)
  base-Π̂ᶠ = Fam-Π

  fam-Π̂ᶠ : base-Π̂ᶠ → Type (𝓤1 ⊔ 𝓤2 ⊔ 𝓤4)
  fam-Π̂ᶠ (i , j)
    = (a : A) → null-homotopy (j a)

  Π̂ᶠ : Fam (𝓤1 ⊔ 𝓤2 ⊔ 𝓤3 ⊔ 𝓤4) (𝓤1 ⊔ 𝓤2 ⊔ 𝓤4)
  Π̂ᶠ = (base-Π̂ᶠ , fam-Π̂ᶠ)
}
%```
}

\subtree[stt-00EQ]{
\taxon{Definition}
\title{The nondependent pullback power for families}

%```agda
\agda{
infixl 40 ⟨_,ᶠ_⟩

⟨_,ᶠ_⟩
  : {𝓤1 𝓤2 𝓤3 𝓤4 : Level}
  → Fam 𝓤1 𝓤2
  → Fam 𝓤3 𝓤4
  → Fam (𝓤1 ⊔ 𝓤2 ⊔ 𝓤3 ⊔ 𝓤4) (𝓤1 ⊔ 𝓤2 ⊔ 𝓤4)
⟨ F ,ᶠ H ⟩ = Π̂ᶠ F (Fam→DepFam F H)
}
%```
}

\subtree[stt-00ER]{
\taxon{Lemma}
\title{#{\pulldpow} preserves equivalences of dependent type families over a fixed base family}

\p{
For a fixed base type family #{F}, any equivalence between dependent families over
#{F}, #{G \simeq H} gives an equivalence #{\pulldpow_F G \simeq \pulldpow_F H}.
}
%```agda
\agda{
module _ {𝓤1 𝓤2 𝓤3 𝓤4 𝓤5 𝓤6 : Level}
         (F@(A , B) : Fam 𝓤1 𝓤2)
         (G@(X , Y) : DepFam 𝓤3 𝓤4 F)
         (H@(U , V) : DepFam 𝓤5 𝓤6 F)
         (e : G ≃ᵈᶠ⟦ F ⟧ H) where

  Π̂ᶠ-ap-≃ᵈᶠ-base-over
    : (i : (a : A) → X a)
    → ((a : A) → B a → Y a (i a))
    ≃ ((a : A) → B a → V a (e a .fst ._≃_.fwd (i a)))
  Π̂ᶠ-ap-≃ᵈᶠ-base-over i
    = Π-ap-≃ (λ a → Π-ap-≃ (λ _ → e a .snd (i a)))

  Π̂ᶠ-ap-≃ᵈᶠ-base
    : base-Π̂ᶠ F G ≃ base-Π̂ᶠ F H
  Π̂ᶠ-ap-≃ᵈᶠ-base
    = Σ-ap-≃ Π̂ᶠ-ap-≃ᵈᶠ-base-over
    ∙≃ Σ-ap-≃-fst (Π-ap-≃ (λ a → e a .fst))

  Π̂ᶠ-ap-≃ᵈᶠ-family-over
    : (i : (a : A) → X a)
    → (j : (a : A) → B a → Y a (i a))
    → ((a : A) → null-homotopy (j a))
    ≃ ((a : A) → null-homotopy (λ b → e a .snd (i a) ._≃_.fwd (j a b)))
  Π̂ᶠ-ap-≃ᵈᶠ-family-over i j
    = Π-ap-≃ (λ a → null-homotopy-map-codomain-≃ (e a .snd (i a)) (j a))

  Π̂ᶠ-ap-≃ᵈᶠ-family
    : (fp : base-Π̂ᶠ F G)
    → fam-Π̂ᶠ F G fp ≃ fam-Π̂ᶠ F H (Π̂ᶠ-ap-≃ᵈᶠ-base ._≃_.fwd fp)
  Π̂ᶠ-ap-≃ᵈᶠ-family (i , j)
    = Π̂ᶠ-ap-≃ᵈᶠ-family-over i j

  Π̂ᶠ-ap-≃ᵈᶠ : Π̂ᶠ F G ≃ᶠ Π̂ᶠ F H
  Π̂ᶠ-ap-≃ᵈᶠ = Π̂ᶠ-ap-≃ᵈᶠ-base , Π̂ᶠ-ap-≃ᵈᶠ-family
}
%```
}

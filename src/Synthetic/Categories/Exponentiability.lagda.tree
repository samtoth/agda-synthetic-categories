\title{Precategory exponentiability}
\author{fredrikbakke}
\taxon{Module}
\import{stt-macros}

\transclude{stt-00AB}

%```agda
\agda{
open import Foundations.Prelude
open import Algebra.Lattice

module Synthetic.Categories.Exponentiability
  {𝓘} (Δ¹ : Type 𝓘) (I : Lattice Δ¹) (I-distr : is-distributive I)
  where

open Lattice I renaming (0l to i0; 1l to i1)

open import Synthetic.Categories.Simplicial Δ¹ I I-distr
open import Synthetic.Categories.Horns Δ¹ I I-distr
open import Synthetic.Categories.Disjunctive Δ¹ I I-distr
open import Synthetic.Exponentiability
import Synthetic.PhoasPrinciple Δ¹ I I-distr as Phoa
}
%```

\subtree[fre-Q006]{
\date{2026-03-21}
\author{fredrikbakke}
\title{Precategory exponentiability}
\taxon{Definition}

\p{
A map #{p : E \to B} is \em{precategory-exponentiable} if it is
Segal-exponentiable at [simplicial types](stt-00AC). That is, given a diagram of the

form

\quiver{
\begin{tikzcd}
  U && V && E \\
  \\
  \Lambda^2_1 && \Delta^2 && B
	\arrow["p", from=1-5, to=3-5]
	\arrow[from=3-1, to=3-3]
	\arrow["q", from=1-1, to=1-3]
	\arrow[from=3-3, to=3-5]
	\arrow[from=1-1, to=3-1]
	\arrow["\iota", from=3-1, to=3-3]
	\arrow[from=1-3, to=1-5]
	\arrow["\alpha", from=3-3, to=3-5]
	\arrow[from=1-3, to=3-5, "\lrcorner" very near start, phantom]
	\arrow[from=1-1, to=3-3, "\lrcorner" very near start, phantom]
\end{tikzcd}
}

then every precategory #{\mathcal{C}} is #{q}-local.
}

%```agda
\agda{
module PrecategoryExponentiability
  = ExponentiabilityAt Simplicial-gSubU (point Λ[2,1]-incl)

is-precategory-exponentiable
  : {𝓤 𝓥 : Level} (𝓦 𝓛 𝓜 : Level)
    {A : Type 𝓤} {B : Type 𝓥}
  → (f : A → B)
  → Type (𝓘 ⊔ 𝓤 ⊔ 𝓥 ⊔ lsuc 𝓦 ⊔ lsuc 𝓛 ⊔ lsuc 𝓜)
is-precategory-exponentiable = PrecategoryExponentiability.is-exponentiable-at

is-precategory-exponentiable-is-prop
  : {𝓤 𝓥 : Level} (𝓦 𝓛 𝓜 : Level)
    {A : Type 𝓤} {B : Type 𝓥}
  → (f : A → B)
  → is-prop (is-precategory-exponentiable 𝓦 𝓛 𝓜 f)
is-precategory-exponentiable-is-prop
  = PrecategoryExponentiability.is-exponentiable-at-is-prop

is-globally-precategory-exponentiable
  : {𝓤 𝓥 : Level}
    {A : Type 𝓤} {B : Type 𝓥}
  → (f : A → B)
  → Typeω
is-globally-precategory-exponentiable
  = PrecategoryExponentiability.is-globally-exponentiable-at
}
%```
}

\subtree[fre-7823]{
\date{2026-03-21}
\author{fredrikbakke}
\title{The right end point inclusion of the interval is precategory exponentiable}
\taxon{corollary}

%```agda
\agda{
module _
  (phoa : Phoa.phoas-principle)
  where

  point-i1-is-globally-precategory-exponentiable
    : is-globally-precategory-exponentiable (point i1)
  point-i1-is-globally-precategory-exponentiable simp-X
    = point-i1-is-globally-exponentiable-at-disjunctive-types phoa
        (simp-is-disjunctive simp-X)
}
%```
}

\subtree[fre-LMAB]{
\taxon{Definition}
\title{Universal property of #{K}-connected maps}

\p{
Given a global subuniverse #{K} and a map #{f : A \to B}, then #{f} satisfies the
\em{universal property of #{K}-connected maps} if for every #{K}-valued family of
types #{U} over #{B}, the dependent precomposition map
#{\prod_{b : B} U(b) \to \prod_{a : A} U(f(a))} is an equivalence.
}

% ```agda
\agda{
up-gconnected-map : вҲҖ {Оұ рқ“Ө рқ“Ҙ} (K : gSubU Оұ)
                    вҶ’ {A : Type рқ“Ө} {B : Type рқ“Ҙ}
                    вҶ’ (A вҶ’ B)
                    вҶ’ TypeПү
up-gconnected-map K f
  = вҲҖ {рқ“ҡ} {U : _ вҶ’ Type рқ“ҡ}
  вҶ’ (вҲҖ b вҶ’ U b вҲҲ gSubU.S K)
  вҶ’ is-equiv (precomp-О  U f)

gconnected-map-!-fibre
  : вҲҖ {Оұ рқ“Ө рқ“Ҙ} (K : gSubU Оұ)
      {A : Type рқ“Ө} {B : Type рқ“Ҙ}
      (f : A вҶ’ B)
  вҶ’ TypeПү
gconnected-map-!-fibre K f
  = вҲҖ b вҶ’ up-gmodal-equiv K (!: fibre f b)

gconnected-fibres
  : вҲҖ {Оұ рқ“Ө рқ“Ҙ} (K : gSubU Оұ)
      {A : Type рқ“Ө} {B : Type рқ“Ҙ}
      (f : A вҶ’ B)
  вҶ’ TypeПү
gconnected-fibres K f
  = вҲҖ b {рқ“ҡ} {U : Type рқ“ҡ}
    вҶ’ U вҲҲ gSubU.S K
    вҶ’ is-equiv (const U (fibre f b))
}
%```
}


\subtree{
\date{2026-03-19}
\author{fredrikbakke}
\taxon{Definition}
\title{#{K}-Connected maps}

\p{
If #{K} is a reflective subuniverse, a map is \em{#{K}-connected} if all of its
fibres have contractible reflections.
}

\agda{
module _ {Оұ} (RS : gRSubU Оұ) where
  open gRSubU RS

  is-gconnected-map
    : вҲҖ {рқ“Ө рқ“Ҙ} {A : Type рқ“Ө} {B : Type рқ“Ҙ}
    вҶ’ (A вҶ’ B) вҶ’ Type _
  is-gconnected-map {B = B} f = (b : B) вҶ’ is-singleton (в—Ӣ (fibre f b))

is-connected-map : вҲҖ {рқ“Ө рқ“Ҙ рқ“ң} {A : Type рқ“Ө} {B : Type рқ“Ҙ}
                     {S : SubU (рқ“Ө вҠ” рқ“Ҙ) рқ“ң}
                   вҶ’ is-reflective S
                   вҶ’ (A вҶ’ B) вҶ’ Type (рқ“Ө вҠ” рқ“Ҙ)
is-connected-map rfl f = вҲҖ b вҶ’ is-connected rfl (fibre f b)
}
%```
}

\subtree{
\date{2026-03-19}
\author{fredrikbakke}
\taxon{Lemma}
\title{Closure of #{K}-connected maps under composition}

% ```agda
\agda{
up-gconnected-map-вҲҳ
  : вҲҖ {Оұ рқ“Ө рқ“Ҙ рқ“Ұ}
      (K : gSubU Оұ)
      {A : Type рқ“Ө} {B : Type рқ“Ҙ} {C : Type рқ“Ұ}
      (f : A вҶ’ B) (g : B вҶ’ C)
  вҶ’ up-gconnected-map K f
  вҶ’ up-gconnected-map K g
  вҶ’ up-gconnected-map K (g вҲҳ f)
up-gconnected-map-вҲҳ K f g fconn gconn UвҲҲK
  = is-equiv-вҲҳ (fconn (UвҲҲK вҲҳ g)) (gconn UвҲҲK)

up-gconnected-map-right-cancel
  : вҲҖ {Оұ рқ“Ө рқ“Ҙ рқ“Ұ}
      (K : gSubU Оұ)
      {A : Type рқ“Ө} {B : Type рқ“Ҙ} {C : Type рқ“Ұ}
      (f : A вҶ’ B) (g : B вҶ’ C)
  вҶ’ up-gconnected-map K f
  вҶ’ up-gconnected-map K (g вҲҳ f)
  вҶ’ up-gconnected-map K g
up-gconnected-map-right-cancel K f g fconn gfconn UвҲҲK
  = 3-for-2 (fconn (UвҲҲK вҲҳ g)) (gfconn UвҲҲK)
}
%```
}

\subtree{
\date{2026-03-19}
\author{fredrikbakke}
\taxon{Theorem}
\title{Connected maps are left orthogonal to modal maps}

% ```agda
\agda{
up-gconnected-mapвҮ”orthogonal-map
  : вҲҖ {Оұ рқ“Ө рқ“Ҙ} (K : gSubU Оұ)
      {A : Type рқ“Ө} {B : Type рқ“Ҙ}
      (f : A вҶ’ B)
  вҶ’ up-gconnected-map K f
  вҶ’ {рқ“Ұ рқ“ӣ : Level} {C : Type рқ“Ұ} {D : Type рқ“ӣ}
    (g : C вҶ’ D)
  вҶ’ is-gmodal-map K g
  вҶ’ are-orthogonal f g
up-gconnected-mapвҮ”orthogonal-map K f fconn g gвҲҲK
  = orthogonalвҶҗprecomp-О  О» h вҶ’ fconn (О» b вҶ’ gвҲҲK (h b))

up-gconnected-mapвҶҗorthogonal-map
  : вҲҖ {Оұ рқ“Ө рқ“Ҙ} (K : gSubU Оұ)
      {A : Type рқ“Ө} {B : Type рқ“Ҙ}
      (f : A вҶ’ B)
    вҶ’ (вҲҖ {рқ“Ұ рқ“ӣ} {C : Type рқ“Ұ} {D : Type рқ“ӣ}
        (g : C вҶ’ D)
        вҶ’ is-gmodal-map K g
        вҶ’ are-orthogonal f g)
    вҶ’ up-gconnected-map K f
up-gconnected-mapвҶҗorthogonal-map K f orth {U = U} UвҲҲK
  = is-equivвҶҗArrow-equivвҒ»В№ {F = eq .fst} (eq .snd)
      (precomp-О вҶҗorthogonal id (orth fst fstвҲҲK)) where

  fstвҲҲK : is-gmodal-map K (fst {B = U})
  fstвҲҲK b = gSubU.вҲҲSвҶҗequiv K (fibre-straighten U b eвҒ»В№) (UвҲҲK b)

  eq = precomp-О -straighten-Arrow-equiv U f
}
%```
}

\subtree{
\date{2026-03-20}
\author{fredrikbakke}
\taxon{Proposition}
\title{Closure properties of #{K}-connected maps}

\p{
Connected maps are stable under homotopies, retracts of arrows, and cobase change.
}

% ```agda
\agda{
up-gconnected-map-homotopy
  : вҲҖ {Оұ рқ“Ө рқ“Ҙ}
      (K : gSubU Оұ)
      {A : Type рқ“Ө} {B : Type рқ“Ҙ}
      {f g : A вҶ’ B}
    вҶ’ f ~ g
    вҶ’ up-gconnected-map K f
    вҶ’ up-gconnected-map K g
up-gconnected-map-homotopy K {f = f} {g = g} H fconn
  = up-gconnected-mapвҶҗorthogonal-map K g О» h hmodal
      вҶ’ left-orthogonal-homotopy h H
          (up-gconnected-mapвҮ”orthogonal-map K f fconn h hmodal)

up-gconnected-map-вҲҳ~
  : вҲҖ {Оұ рқ“Ө рқ“Ҙ рқ“Ұ}
      (K : gSubU Оұ)
      {A : Type рқ“Ө} {B : Type рқ“Ҙ} {C : Type рқ“Ұ}
      {h : A вҶ’ C}
      (f : A вҶ’ B) (g : B вҶ’ C)
    вҶ’ h ~ g вҲҳ f
    вҶ’ up-gconnected-map K f
    вҶ’ up-gconnected-map K g
    вҶ’ up-gconnected-map K h
up-gconnected-map-вҲҳ~ K f g H fconn gconn
  = up-gconnected-map-homotopy K (H ~вҒ»В№)
      (up-gconnected-map-вҲҳ K f g fconn gconn)

up-gconnected-map-right-cancel~
  : вҲҖ {Оұ рқ“Ө рқ“Ҙ рқ“Ұ}
      (K : gSubU Оұ)
      {A : Type рқ“Ө} {B : Type рқ“Ҙ} {C : Type рқ“Ұ}
      {h : A вҶ’ C}
      (f : A вҶ’ B) (g : B вҶ’ C)
    вҶ’ h ~ g вҲҳ f
    вҶ’ up-gconnected-map K f
    вҶ’ up-gconnected-map K h
    вҶ’ up-gconnected-map K g
up-gconnected-map-right-cancel~ K f g H fconn hconn
  = up-gconnected-map-right-cancel K f g fconn
      (up-gconnected-map-homotopy K H hconn)

up-gconnected-mapвҶҗretraction-arrow-map
  : вҲҖ {Оұ рқ“Ө рқ“Ҙ рқ“Ұ рқ“ӣ}
      (K : gSubU Оұ)
      {A : Type рқ“Ө} {B : Type рқ“Ҙ} {f : A вҶ’ B}
      {X : Type рқ“Ұ} {Y : Type рқ“ӣ} {g : X вҶ’ Y}
      (F : Arrow-map f g)
    вҶ’ retraction-arrow-map F
    вҶ’ up-gconnected-map K g
    вҶ’ up-gconnected-map K f
up-gconnected-mapвҶҗretraction-arrow-map K {f = f} {g = g} F R gconn
  = up-gconnected-mapвҶҗorthogonal-map K f О» h hmodal
      вҶ’ left-orthogonal-retraction f g F R h
          (up-gconnected-mapвҮ”orthogonal-map K g gconn h hmodal)

up-gconnected-mapвҶҗcocartesian
  : вҲҖ {Оұ рқ“Ө рқ“Ҙ рқ“Ұ рқ“ӣ}
      (K : gSubU Оұ)
      {A : Type рқ“Ө} {B : Type рқ“Ҙ} {f : A вҶ’ B}
      {X : Type рқ“Ұ} {Y : Type рқ“ӣ} {g : X вҶ’ Y}
      (F : Arrow-map f g)
    вҶ’ is-cocartesianПү F
    вҶ’ up-gconnected-map K f
    вҶ’ up-gconnected-map K g
up-gconnected-mapвҶҗcocartesian K {f = f} {g = g} F cocart fconn
  = up-gconnected-mapвҶҗorthogonal-map K g О» h hmodal
      вҶ’ left-orthogonal-pushout F cocart h
          (up-gconnected-mapвҮ”orthogonal-map K f fconn h hmodal)

up-gconnected-map-О№вӮӮ
  : вҲҖ {Оұ рқ“Ө рқ“Ҙ рқ“Ұ}
      (K : gSubU Оұ)
      {A : Type рқ“Ө} {B : Type рқ“Ҙ} {C : Type рқ“Ұ}
      (f : A вҶ’ B) (g : A вҶ’ C)
    вҶ’ up-gconnected-map K f
    вҶ’ up-gconnected-map K (О№вӮӮ {f = f} {g = g})
up-gconnected-map-О№вӮӮ K f g
  = up-gconnected-mapвҶҗcocartesian K
      (Pushout-square (mk-span _ f g))
      (Pushout-square-is-cocartesian (mk-span _ f g))
}
%```
}

\subtree{
\date{2026-03-19}
\author{fredrikbakke}
\taxon{Lemma}
\title{#{K}-connected maps are #{K}-equivalences}

% ```agda
\agda{
up-gmodal-equivвҶҗup-gconnected-map
  : вҲҖ {Оұ рқ“Ө рқ“Ҙ} (K : gSubU Оұ)
      {A : Type рқ“Ө} {B : Type рқ“Ҙ}
      (f : A вҶ’ B)
  вҶ’ up-gconnected-map K f
  вҶ’ up-gmodal-equiv K f
up-gmodal-equivвҶҗup-gconnected-map K f fconn UвҲҲK = fconn (О» _ вҶ’ UвҲҲK)

module gRSubUConnectedModalEquivalences {Оұ} (RS : gRSubU Оұ) where
  open gRSubU RS
  open gRSubUModalEquivalences RS

}
%```
}


\subtree{
\date{2026-03-19}
\author{fredrikbakke}
\taxon{Theorem}
\title{Unique dependent extension property of #{K}-connected maps}

\p{
#{K}-Connectedness is equivalent to saying every section of a #{K}-valued
family over the domain uniquely extends along the map.
}

% ```agda
\agda{
up-gconnected-mapвҮ”unique-extensions
  : вҲҖ {Оұ рқ“Ө рқ“Ҙ} (K : gSubU Оұ)
      {A : Type рқ“Ө} {B : Type рқ“Ҙ}
      (f : A вҶ’ B)
    вҶ’ up-gconnected-map K f
    вҶ’ вҲҖ {рқ“ҡ} {U : B вҶ’ Type рқ“ҡ}
    вҶ’ (вҲҖ b вҶ’ U b вҲҲ gSubU.S K)
    вҶ’ (h : О  A (U вҲҳ f))
    вҶ’ is-singleton (Ext f h)
up-gconnected-mapвҮ”unique-extensions K f fconn UвҲҲK h
  = is-contr-mapвҶҗis-equiv (fconn UвҲҲK) h

up-gconnected-mapвҶҗunique-extensions
  : вҲҖ {Оұ рқ“Ө рқ“Ҙ} (K : gSubU Оұ)
      {A : Type рқ“Ө} {B : Type рқ“Ҙ}
      (f : A вҶ’ B)
    вҶ’ (вҲҖ {рқ“ҡ} {U : B вҶ’ Type рқ“ҡ}
        вҶ’ (вҲҖ b вҶ’ U b вҲҲ gSubU.S K)
        вҶ’ (h : О  A (U вҲҳ f))
        вҶ’ is-singleton (Ext f h))
  вҶ’ up-gconnected-map K f
up-gconnected-mapвҶҗunique-extensions K f ext {U = U} UвҲҲK
  = is-equivвҶҗis-contr-map О» h вҶ’ ext UвҲҲK h
}
%```
}

\subtree{
\date{2026-03-19}
\author{fredrikbakke}
\taxon{Lemma}
\title{Terminal projection and constant-map criteria on fibres}

\p{
For the fibres of a map, asking that the terminal projections be #{K}-equivalences is
equivalent to asking that the fibres satisfy the universal property of
#{K}-connected types.
}

% ```agda
\agda{
gconnected-map-!-fibresвҮ”gconnected-fibres
  : вҲҖ {Оұ рқ“Ө рқ“Ҙ} (K : gSubU Оұ)
      {A : Type рқ“Ө} {B : Type рқ“Ҙ}
      (f : A вҶ’ B)
  вҶ’ gconnected-map-!-fibre K f
  вҶ’ gconnected-fibres K f
gconnected-map-!-fibresвҮ”gconnected-fibres K f fib-eq b UвҲҲK
  = is-equiv-constвҶҗprecomp-! (fib-eq b UвҲҲK)

gconnected-map-!-fibresвҶҗgconnected-fibres
  : вҲҖ {Оұ рқ“Ө рқ“Ҙ} (K : gSubU Оұ)
      {A : Type рқ“Ө} {B : Type рқ“Ҙ}
      (f : A вҶ’ B)
  вҶ’ gconnected-fibres K f
  вҶ’ gconnected-map-!-fibre K f
gconnected-map-!-fibresвҶҗgconnected-fibres K f fib-const b UвҲҲK
  = is-equiv-precomp-!вҶҗconst (fib-const b UвҲҲK)
}
%```
}

\subtree{
\date{2026-03-19}
\author{fredrikbakke}
\taxon{Theorem}
\title{Fibrewise connected maps are connected}

\p{
If each fibre of #{f} is #{K}-connected, i.e., for each #{b} and each #{K}-type #{U},
the constant map #{U \to (\fibre{f}{b} \to U)} is an equivalence, then #{f} is
#{K}-connected.
}

% ```agda
\agda{
up-gconnected-mapвҶҗgconnected-fibres
  : вҲҖ {Оұ рқ“Ө рқ“Ҙ} (K : gSubU Оұ)
      {A : Type рқ“Ө} {B : Type рқ“Ҙ}
      (f : A вҶ’ B)
  вҶ’ gconnected-fibres K f
  вҶ’ up-gconnected-map K f
up-gconnected-mapвҶҗgconnected-fibres K f fibre-const {U = U} UвҲҲK
  = is-equivвҶҗArrow-equivвҒ»В№ {F = eq .fst} (eq .snd)
      (postcomp-О -equiv О» {b} вҶ’ fibre-const b (UвҲҲK b)) where
  eq = precomp-О -fibre-const-Arrow-equiv U f

up-gconnected-mapвҶҗfibre-terminal-equiv
  : вҲҖ {Оұ рқ“Ө рқ“Ҙ} (K : gSubU Оұ)
      {A : Type рқ“Ө} {B : Type рқ“Ҙ}
      (f : A вҶ’ B)
  вҶ’ gconnected-map-!-fibre K f
  вҶ’ up-gconnected-map K f
up-gconnected-mapвҶҗfibre-terminal-equiv K f fibterm
  = up-gconnected-mapвҶҗgconnected-fibres K f
      (gconnected-map-!-fibresвҮ”gconnected-fibres K f fibterm)
}
%```
}


\subtree[fre-0315]{
\date{2026-03-19}
\author{fredrikbakke}
\title{#{K}-Connected maps, given reflections of fibres}

\agda{
module gReflectorConnectedMaps
    {Оұ рқ“Ө рқ“Ҙ} {GS : gSubU Оұ}
    {A : Type рқ“Ө} {B : Type рқ“Ҙ}
    (f : A вҶ’ B)
    (Rрқҹҷ : gReflector GS рқҹҷ)
    (в—Ӣрқҹҷ-singleton : is-singleton (gReflector.в—Ӣ Rрқҹҷ))
    (Rf : (b : B) вҶ’ gReflector GS (fibre f b)) where
  module One = gReflector Rрқҹҷ

  reflected-fibres-singleton
    : Type _
  reflected-fibres-singleton = вҲҖ b вҶ’ is-singleton (gReflector.в—Ӣ (Rf b))

  reflected-fibres-singletonвҶҗgconnected-map-!-fibre
    : gconnected-map-!-fibre GS f
    вҶ’ reflected-fibres-singleton
  reflected-fibres-singletonвҶҗgconnected-map-!-fibre fibterm b
    = is-singleвҶҗequiv-to-single
        (mkвүғ (gReflectorMap.в—ӢвӮҒ (Rf b) Rрқҹҷ (! {A = fibre f b}))
          (gReflectorModalEquivalences.is-gmodal-equivвҶҗup-gmodal-equiv
            (Rf b) Rрқҹҷ (! {A = fibre f b}) (fibterm b))
          eвҒ»В№)
        в—Ӣрқҹҷ-singleton

  gconnected-map-!-fibreвҶҗreflected-fibres-singleton
    : reflected-fibres-singleton
    вҶ’ gconnected-map-!-fibre GS f
  gconnected-map-!-fibreвҶҗreflected-fibres-singleton sing b
    = gReflectorModalEquivalences.up-gmodal-equivвҶҗis-gmodal-equiv
        (Rf b) Rрқҹҷ (! {A = fibre f b})
        (is-equivвҶҗsingle-to-prop
          (sing b)
          (is-propвҶҗis-single в—Ӣрқҹҷ-singleton)
          (gReflectorMap.в—ӢвӮҒ (Rf b) Rрқҹҷ (! {A = fibre f b})))
}
%```
}

\subtree[fre-0316]{
\date{2026-03-19}
\author{fredrikbakke}
\taxon{Theorem}
\title{Reflectors of #{\Sigma}-closed reflective global subuniverses are connected}

\agda{
module gRSubUReflectorConnected {Оұ}
    (RS : gRSubU Оұ)
    (SОЈ : is-globally-ОЈ-closed (RS .gRSubU.GS)) where
  open gRSubU RS
  open gReflectiveClosure RS
  open gRSubUEquivMap RS
  open gRSubUInduction RS SОЈ
  open gRSubUModalEquivalences RS

  О·-connected-map
    : вҲҖ {рқ“Ө} {A : Type рқ“Ө}
    вҶ’ up-gconnected-map GS (О· {A = A})
  О·-connected-map {A = A} {U = U} UвҲҲS
    = is-equivвҒ»В№ (ind-is-equiv UвҲҲS)

  О·вҲҳ-connected-mapвҶҗup-gmodal-equiv
    : вҲҖ {рқ“Ө рқ“Ҙ} {A : Type рқ“Ө} {B : Type рқ“Ҙ}
      (f : A вҶ’ B)
    вҶ’ up-gmodal-equiv GS f
    вҶ’ up-gconnected-map GS (О· {A = B} вҲҳ f)
  О·вҲҳ-connected-mapвҶҗup-gmodal-equiv {A = A} {B = B} f feq {U = U} UвҲҲS
    = homotopy-is-equiv {f = rhs} {g = precomp-О  U (О· вҲҳ f)}
        (comm ~вҒ»В№) rhs-is-equiv where
    mid
      : О  (в—Ӣ B) U
      вҶ’ О  A (О» a вҶ’ U (в—ӢвӮҒ f (О· a)))
    mid = precomp-О  (U вҲҳ в—ӢвӮҒ f) О· вҲҳ precomp-О  U (в—ӢвӮҒ f)

    rhs
      : О  (в—Ӣ B) U вҶ’ О  A (U вҲҳ О· вҲҳ f)
    rhs = postcomp-О  (О» a вҶ’ tr U (в—ӢвӮҒ-ОІ f a)) вҲҳ mid

    rhs-is-equiv
      : is-equiv rhs
    rhs-is-equiv
      = is-equiv-вҲҳ
          (postcomp-О -equiv О» {a} вҶ’ coe-is-equiv (ap U (в—ӢвӮҒ-ОІ f a)))
          (is-equiv-вҲҳ
            (О·-connected-map (UвҲҲS вҲҳ в—ӢвӮҒ f))
            (precomp-О -is-equiv (is-gmodal-equivвҶҗup-gmodal-equiv f feq)))

    comm
      : precomp-О  U (О· вҲҳ f)
      ~ rhs
    comm h = funextвҶ’ О» a вҶ’ sym (apбөҲ h (в—ӢвӮҒ-ОІ f a))

  is-gmodal-equivвҶҗup-gconnected-map
    : вҲҖ {рқ“Ө рқ“Ҙ} {A : Type рқ“Ө} {B : Type рқ“Ҙ}
      (f : A вҶ’ B)
    вҶ’ up-gconnected-map GS f
    вҶ’ is-gmodal-equiv f
  is-gmodal-equivвҶҗup-gconnected-map f fconn
    = is-gmodal-equivвҶҗup-gmodal-equiv f
        (up-gmodal-equivвҶҗup-gconnected-map GS f fconn)
}
%```
}

\subtree{
\date{2026-03-19}
\author{fredrikbakke}
\taxon{Lemma}
\title{Connections between certain fibre conditions on a map with #{K}-reflections}

%```agda
\agda{
module gReflectorFibres
    {Оұ рқ“Ө рқ“Ҙ} {GS : gSubU Оұ}
    {A : Type рқ“Ө} {B : Type рқ“Ҙ}
    (f : A вҶ’ B)
    (Rf : (b : B) вҶ’ gReflector GS (fibre f b)) where

  О·-fibre-section
    : О  A (О» a вҶ’ gReflector.в—Ӣ (Rf (f a)))
  О·-fibre-section a = gReflector.О· (Rf (f a)) (a , refl)

  fibre-local-centreвҶҗover
    : (b : B)
    вҶ’ null-homotopy
        (precomp-О -over-fibres (О» b вҶ’ gReflector.в—Ӣ (Rf b)) f О·-fibre-section b)
    вҶ’ ОЈ[ u вҲ¶ gReflector.в—Ӣ (Rf b) ]
        ((x : fibre f b) вҶ’ u пјқ gReflector.О· (Rf b) x)
  fibre-local-centreвҶҗover b (u , H)
    = u , О» where (a , refl) вҶ’ H (a , refl)

  reflected-fibre-singletonвҶҗlocal-centre
    : {b : B}
    вҶ’ ОЈ[ u вҲ¶ gReflector.в—Ӣ (Rf b) ]
        ((x : fibre f b) вҶ’ u пјқ gReflector.О· (Rf b) x)
    вҶ’ is-singleton (gReflector.в—Ӣ (Rf b))
  reflected-fibre-singletonвҶҗlocal-centre {b} (u , H)
    = mk-singl u (happly p) where
    module Fb = gReflector (Rf b)

    p : const Fb.в—Ӣ Fb.в—Ӣ u пјқ id
    p = unap
          (is-embeddingвҶҗis-equiv (Fb.reflects Fb.в—ӢвҲҲS))
          (funextвҶ’ H)

  fibre-precomp-О -О·-fibreвүғО -local-centre-over
    : fibre (precomp-О  (О» b вҶ’ gReflector.в—Ӣ (Rf b)) f) О·-fibre-section
      вүғ ((b : B)
        вҶ’ null-homotopy
            (precomp-О -over-fibres (О» b вҶ’ gReflector.в—Ӣ (Rf b)) f
              О·-fibre-section b))
  fibre-precomp-О -О·-fibreвүғО -local-centre-over
    = fibre-precomp-О -null-homotopyвүғ
        (О» b вҶ’ gReflector.в—Ӣ (Rf b)) f О·-fibre-section

  merely-fibre-local-centreвҶҗsurjective-precomp-О 
    : (вҲҖ {рқ“ҡ} {U : B вҶ’ Type рқ“ҡ}
        вҶ’ ((b : B) вҶ’ U b вҲҲ gSubU.S GS)
        вҶ’ is-surjective (precomp-О  U f))
    вҶ’ ((b : B)
      вҶ’ в•‘ ОЈ[ u вҲ¶ gReflector.в—Ӣ (Rf b) ]
            ((x : fibre f b) вҶ’ u пјқ gReflector.О· (Rf b) x) в•‘)
  merely-fibre-local-centreвҶҗsurjective-precomp-О  surj b
    = Trunc.в—Ӣ-rec Trunc.в—ӢвҲҲS
        (Trunc.О· вҲҳ fibre-local-centreвҶҗover b вҲҳ ev b)
        (Trunc.в—Ӣ-rec Trunc.в—ӢвҲҲS
          (Trunc.О· вҲҳ fibre-precomp-О -О·-fibreвүғО -local-centre-over ._вүғ_.fwd)
          (surj (О» b вҶ’ gReflector.в—ӢвҲҲS (Rf b)) О·-fibre-section))
}
%```
}

\subtree{
\date{2026-03-19}
\author{fredrikbakke}
\taxon{Theorem}
\title{Fibre reflection conditions for #{K}-connected maps}

%```agda
\agda{
module gReflectorConnectedCharacterisation
    {Оұ рқ“Ө рқ“Ҙ} {GS : gSubU Оұ}
    {A : Type рқ“Ө} {B : Type рқ“Ҙ}
    (f : A вҶ’ B)
    (Rрқҹҷ : gReflector GS рқҹҷ)
    (в—Ӣрқҹҷ-singleton : is-singleton (gReflector.в—Ӣ Rрқҹҷ))
    (Rf : (b : B) вҶ’ gReflector GS (fibre f b)) where
  open gReflectorConnectedMaps f Rрқҹҷ в—Ӣрқҹҷ-singleton Rf
  open gReflectorFibres f Rf

  reflected-fibres-singletonвҶҗmerely-local-centre
    : ((b : B)
      вҶ’ в•‘ ОЈ[ u вҲ¶ gReflector.в—Ӣ (Rf b) ]
            ((x : fibre f b) вҶ’ u пјқ gReflector.О· (Rf b) x) в•‘)
    вҶ’ reflected-fibres-singleton
  reflected-fibres-singletonвҶҗmerely-local-centre mere b
    = Trunc.в—Ӣ-rec
        (is-truncatedвҶҗis-prop is-single-is-prop)
        reflected-fibre-singletonвҶҗlocal-centre
        (mere b)

  gconnected-map-!-fibreвҶҗmerely-local-centre
    : ((b : B)
      вҶ’ в•‘ ОЈ[ u вҲ¶ gReflector.в—Ӣ (Rf b) ]
            ((x : fibre f b) вҶ’ u пјқ gReflector.О· (Rf b) x) в•‘)
    вҶ’ gconnected-map-!-fibre GS f
  gconnected-map-!-fibreвҶҗmerely-local-centre mere
    = gconnected-map-!-fibreвҶҗreflected-fibres-singleton
        (reflected-fibres-singletonвҶҗmerely-local-centre mere)

  up-gconnected-mapвҶҗmerely-local-centre
    : ((b : B)
      вҶ’ в•‘ ОЈ[ u вҲ¶ gReflector.в—Ӣ (Rf b) ]
           ((x : fibre f b) вҶ’ u пјқ gReflector.О· (Rf b) x) в•‘)
    вҶ’ up-gconnected-map GS f
  up-gconnected-mapвҶҗmerely-local-centre mere
    = up-gconnected-mapвҶҗfibre-terminal-equiv GS f
        (gconnected-map-!-fibreвҶҗmerely-local-centre mere)
}
%```
}

\subtree[fre-0319]{
\date{2026-03-19}
\author{fredrikbakke}
\taxon{Corollary}
\title{Equivalent conditions for connected maps in reflective global subuniverses}

%```agda
\agda{
module gRSubUConnectedCharacterisation {Оұ} (RS : gRSubU Оұ) where
  open gRSubU RS
  open gRSubUEquivMap RS
  open gRSubUModalEquivalences RS

  module _ {рқ“Ө рқ“Ҙ} {A : Type рқ“Ө} {B : Type рқ“Ҙ} (f : A вҶ’ B) where
    module Ch = gReflectorConnectedCharacterisation
      f
      (gReflectorвҶҗgRSubU RS рқҹҷ)
      (в—Ӣрқҹҷ-is-single RS)
      (О» b вҶ’ gReflectorвҶҗgRSubU RS (fibre f b))
    open Ch
    module LC = gReflectorFibres f (О» b вҶ’ gReflectorвҶҗgRSubU RS (fibre f b))

    gconnected-map-!-fibreвҶҗfibre-connected
      : is-gconnected-map RS f
      вҶ’ gconnected-map-!-fibre GS f
    gconnected-map-!-fibreвҶҗfibre-connected fconn
      = gconnected-map-!-fibresвҶҗgconnected-fibres GS f fib-const where

      fib-const : gconnected-fibres GS f
      fib-const b UвҲҲS
        = (is-equiv-вҲҳ
            (reflects {A = fibre f b} UвҲҲS)
            (sing-const-is-equiv global-funext (fconn b)))

    is-gconnected-mapвҶҗgconnected-map-!-fibre
      : gconnected-map-!-fibre GS f
      вҶ’ is-gconnected-map RS f
    is-gconnected-mapвҶҗgconnected-map-!-fibre fibterm b
      = is-singleвҶҗequiv-to-single
          (mkвүғ (в—ӢвӮҒ (! {A = fibre f b}))
            (is-gmodal-equivвҶҗup-gmodal-equiv (! {A = fibre f b}) (fibterm b))
            eвҒ»В№)
          (в—Ӣрқҹҷ-is-single RS)

    is-gconnected-mapвҶҗup-gconnected-map
      : up-gconnected-map GS f
      вҶ’ is-gconnected-map RS f
    is-gconnected-mapвҶҗup-gconnected-map fconn
      = reflected-fibres-singletonвҶҗmerely-local-centre
          (LC.merely-fibre-local-centreвҶҗsurjective-precomp-О 
            (О» UвҲҲK y вҶ’ Trunc.О·
              ( is-equiv.bwd (fconn UвҲҲK) y
              , is-equiv.Оө (fconn UвҲҲK) y)))

    up-gconnected-mapвҶҗis-gconnected-map
      : is-gconnected-map RS f
      вҶ’ up-gconnected-map GS f
    up-gconnected-mapвҶҗis-gconnected-map fconn
      = up-gconnected-mapвҶҗfibre-terminal-equiv GS f
          (gconnected-map-!-fibreвҶҗfibre-connected fconn)
}
%```
}

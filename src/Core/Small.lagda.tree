\date{2026-03-13}
\author{fredrikbakke}
\taxon{Module}
\title{Small types}
\import{stt-macros}

% ```agda
\agda{
module Core.Small where

open import Foundations.Prelude
open import Foundations.Idempotent
open import Foundations.IdentitySystem

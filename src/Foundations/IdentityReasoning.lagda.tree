\title{Identity reasoning}
\taxon{Module}
\author{samueltoth}

\import{stt-macros}

\agda{
open import Foundations.Universes
open import Foundations.Identity

module Foundations.IdentityReasoning where

import Foundations.Reasoning as FR
infixr 2 _⟩∙⟨_

module ∙ {𝓤} (A : Type 𝓤)
  = FR A _＝_ refl (λ x y → y ∙ x) ∙-reflr ∙-refll (λ r q p → ∙-assoc p q r)

_⟩∙⟨_
  : ∀ {𝓤} {A : Type 𝓤} {x y z : A}
      {p q : x ＝ y} {r s : y ＝ z}
    → p ＝ q → r ＝ s → p ∙ r ＝ q ∙ s
p ⟩∙⟨ q = ∙._⟩⊙⟨_ _ q p
}

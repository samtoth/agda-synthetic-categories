\date{2026-01-09}
\title{Synthetic cubes}
\taxon{Module}
\author{samueltoth}
\import{stt-macros}


%```agda
\agda{
open import Foundations.Prelude

module Synthetic.Cubes {𝓘} (I : Type 𝓘) (i0 i1 : I) where

open import Foundations.IdentitySystem

open import Ergonomics.Representation
open import Ergonomics.Extensionality

open import Modalities.Instances.Truncation

open import Synthetic.Hom
}
%```

\subtree[stt-00CB]{
\title{The type of cubes}
\taxon{Definition}

\p{Given a bi-pointed type #{I}, we define the type of #{n}-dimensionl cubes
to be the #{n}-fold product of #{I} with itself.}

%```agda
\agda{
□^_ : ℕ → Type 𝓘
□^ zero = ULift _ 𝟙
□^ suc zero = I
□^ suc (suc n) = □^ (suc n) × I

□-is-truncated : ∀ {n r} → is-truncated r I → is-truncated r (□^ n)
□-is-truncated {zero} t = ULift-is-truncated 𝟙-is-truncated
□-is-truncated {suc zero} t = t
□-is-truncated {suc (suc n)} t = ×-is-truncated (□-is-truncated t) t

instance
  □-Is-truncated : ∀ {n r} → ⦃ _ : Is-truncated r I ⦄
                   → Is-truncated r (□^ (suc (suc n)))
  □-Is-truncated .Is-truncated.has-is-truncated = □-is-truncated trunc!

  {-# INCOHERENT □-Is-truncated #-}

□-appendl : ∀ {n} → I → □^ n → □^ (suc n)
□-appendl {zero} i sq = i
□-appendl {suc zero} i sq = (i , sq)
□-appendl {suc (suc n)} i (sq , j) = (□-appendl i sq , j)

□-incl-top : ∀ {n} → □^ n → □^ (suc n)
□-incl-top {zero} sq = i0
□-incl-top {suc n} sq = (sq , i0)

□-incl-bot : ∀ {n} → □^ n → □^ (suc n)
□-incl-bot {zero} sq = i1
□-incl-bot {suc n} sq = (sq , i1)

□²-incl-left : □^ 1 → □^ 2
□²-incl-left i = (i0 , i)

□²-incl-right : □^ 1 → □^ 2
□²-incl-right i = (i1 , i)

□-0 : ∀ {n} → □^ n
□-0 {zero} = mk-lift tt
□-0 {suc zero} = i0
□-0 {suc (suc n)} = □-0 , i0
}
%```
}

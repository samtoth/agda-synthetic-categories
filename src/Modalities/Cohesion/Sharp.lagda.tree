\subtree{
\title{The Sharp modal operator}
\taxon{Definition}

%```agda
\agda{
record вҹЁвҷҜ|_вҹ© {рқ“Ө} (@вҷҜВ A : Type рқ“Ө) : Type рқ“Ө where
  constructor modвҷҜ
  field
    @вҷҜВ counitвҷҜ : A

open вҹЁвҷҜ|_вҹ©

unit-вҷҜ : вҲҖ {рқ“Ө} {A : Type рқ“Ө} вҶ’ A вҶ’ вҹЁвҷҜ| A вҹ©
unit-вҷҜ a .counitвҷҜВ = a

вҷҜ-map : вҲҖ {рқ“Ө рқ“Ҙ} {@вҷҜ A : Type рқ“Ө} {@вҷҜ B : Type рқ“Ҙ}
        вҶ’ (@вҷҜВ f : A вҶ’ B) вҶ’ вҹЁвҷҜ| A вҹ© вҶ’ вҹЁвҷҜ| B вҹ©
вҷҜ-map f x .counitвҷҜ = f (x .counitвҷҜ)

_пјқвҷҜ_ : вҲҖ {рқ“Ө} {@вҷҜ A : Type рқ“Ө} (@вҷҜ a b : A) вҶ’ Type рқ“Ө
a пјқвҷҜ b = вҹЁвҷҜ| a пјқ b вҹ©

mapplyвҷҜ : вҲҖ {рқ“Ө} {@вҷҜ A : Type рқ“Ө} {@вҷҜ a b : A} вҶ’ modвҷҜВ a пјқ modвҷҜ b вҶ’ a пјқвҷҜ b
mapplyвҷҜ refl .counitвҷҜ = refl

postulate
  modextвҷҜ : вҲҖ {рқ“Ө} {@вҷҜ A : Type рқ“Ө} {@вҷҜ a b : A} вҶ’ is-equiv (mapplyвҷҜ {a = a}{b})

modextвҷҜвҶ’ : вҲҖ {рқ“Ө} {@вҷҜ A : Type рқ“Ө} {@вҷҜ a b : A}
           вҶ’ a пјқвҷҜ b вҶ’ modвҷҜ a пјқ modвҷҜ b
modextвҷҜвҶ’ = is-equiv.bwd modextвҷҜ

modextвҷҜвҶ’' : вҲҖ {рқ“Ө} {@вҷҜ A : Type рқ“Ө} {@вҷҜ a b : A}
           вҶ’ @вҷҜВ a пјқ b вҶ’ modвҷҜ a пјқ modвҷҜ b
modextвҷҜвҶ’' x = modextвҷҜвҶ’ (modвҷҜ x)

reflвҷҜ : вҲҖ {рқ“Ө} {@вҷҜ A : Type рқ“Ө} {@вҷҜВ a : A} вҶ’ a пјқвҷҜ a
reflвҷҜ = modвҷҜ refl

modextвҷҜ-refl
  : вҲҖ {рқ“Ө} {@вҷҜ A : Type рқ“Ө} {@вҷҜВ a : A} вҶ’ modextвҷҜвҶ’ (reflвҷҜ {a = a}) пјқ refl
modextвҷҜ-refl = unap-equiv modextвҷҜ (is-equiv.Оө modextвҷҜ reflвҷҜ)

вҷҜ-map-is-equiv
  : вҲҖ {рқ“Ө рқ“Ҙ} {@вҷҜ A : Type рқ“Ө} {@вҷҜ B : Type рқ“Ҙ} {@вҷҜВ f : A вҶ’ B}
    вҶ’ @вҷҜВ is-equiv f вҶ’ is-equiv (вҷҜ-map f)
вҷҜ-map-is-equiv fe = is-equivвҶҗqiso
  ( вҷҜ-map (bwd fe)
  , (О» x вҶ’ modextвҷҜвҶ’ (modвҷҜ (О· fe (x .counitвҷҜ))))
  , О» x вҶ’ modextвҷҜвҶ’ (modвҷҜ (Оө fe (x .counitвҷҜ)))) where open is-equiv

instance
  IdS-вҷҜ : вҲҖ {рқ“Ө рқ“Ҙ} {@вҷҜВ A : Type рқ“Ө} вҰғ @вҷҜ _ : Identity-system A рқ“Ҙ вҰ„
          вҶ’ Identity-system вҹЁвҷҜ| A вҹ© рқ“Ҙ
  IdS-вҷҜ .Identity-system.IdS a b = вҹЁвҷҜ| IdS (a .counitвҷҜ) (b .counitвҷҜ) вҹ©
  IdS-вҷҜ .Identity-system.IdSвҶҗId {modвҷҜ a} {modвҷҜ b} = вҷҜ-map IdSвҶҗId вҲҳ mapplyвҷҜ
  IdS-вҷҜ .Identity-system.has-is-ids a b
    = is-equiv-вҲҳ (вҷҜ-map-is-equiv (has-is-ids _ _)) modextвҷҜ
}
%```
}

\subtree{
\title{Sharp is right adjoint to flat}
\taxon{Lemma}


%```agda
\agda{
вҷӯвҠЈвҷҜ-transpose : вҲҖ {рқ“Ө рқ“Ҙ} {A : Type рқ“Ө} {B : Type рқ“Ҙ} вҶ’
            вҹЁвҷҜ| (вҹЁвҷӯ| A вҹ© вҶ’ B) вҹ© вҶ’ (A вҶ’ вҹЁвҷҜ| B вҹ©)
вҷӯвҠЈвҷҜ-transpose f a .counitвҷҜ = f .counitвҷҜ (modвҷӯ a)

вҷӯвҠЈвҷҜ-transpose-is-equiv
  : вҲҖ {рқ“Ө рқ“Ҙ} {A : Type рқ“Ө} {B : Type рқ“Ҙ} вҶ’ is-equiv (вҷӯвҠЈвҷҜ-transpose {A = A} {B = B})
вҷӯвҠЈвҷҜ-transpose-is-equiv = is-equivвҶҗqiso qiso where
  qiso : quasi-iso _
  qiso .fst f .counitвҷҜ a = f (Оөвҷӯ a) .counitвҷҜ
  qiso .snd .fst x = ext! (modвҷҜ (О» where (modвҷӯ x) вҶ’ refl))
  qiso .snd .snd x = refl

вҷӯвҠЈвҷҜ : вҲҖ {рқ“Ө рқ“Ҙ} {A : Type рқ“Ө} {B : Type рқ“Ҙ} вҶ’ вҹЁвҷҜ| (вҹЁвҷӯ| A вҹ© вҶ’ B)вҹ© вүғ (A вҶ’ вҹЁвҷҜ| B вҹ©)
вҷӯвҠЈвҷҜ = mkвүғ вҷӯвҠЈвҷҜ-transpose вҷӯвҠЈвҷҜ-transpose-is-equiv
}
%```
}


\subtree{
\title{Sharp types forms a reflective subuniverse}
\taxon{Lemma}

\p{We call a type codiscrete if #{\eta : A \to \mod{\sharp}{A}} is an
equivalence.}

%```agda
\agda{
is-вҷҜ-codiscrete : вҲҖ {рқ“Ө} вҶ’ Type рқ“Ө вҶ’ Type рқ“Ө
is-вҷҜ-codiscrete A = is-equiv (unit-вҷҜ {A = A})

unmodвҷҜ : вҲҖ {рқ“Ө} {A : Type рқ“Ө} вҶ’ is-вҷҜ-codiscrete A вҶ’ вҹЁвҷҜ| A вҹ© вҶ’ A
unmodвҷҜ e = is-equiv.bwd e

вҹЁвҷҜ|-вҹ©-is-вҷҜ-codiscrete : вҲҖ {рқ“Ө} {A : Type рқ“Ө} вҶ’ is-вҷҜ-codiscrete вҹЁвҷҜ| A вҹ©
вҹЁвҷҜ|-вҹ©-is-вҷҜ-codiscrete = is-equivвҶҗqiso
  ( (О» where x .counitвҷҜ вҶ’  x .counitвҷҜ .counitвҷҜ)
  , (О» a вҶ’ ext! (modвҷҜ refl))
  , О» _ вҶ’ refl)

is-вҷҜ-codiscreteвҶҗis-equiv
  : вҲҖ {рқ“Ө рқ“Ҙ} {A : Type рқ“Ө} {B : Type рқ“Ҙ} {f : A вҶ’ B} вҶ’ is-equiv f
    вҶ’ is-вҷҜ-codiscrete A вҶ’ is-вҷҜ-codiscrete B
is-вҷҜ-codiscreteвҶҗis-equiv {f = f} fe ad
  = 3-for-2~' {k = вҷҜ-map f вҲҳ unit-вҷҜ}
      (О» a вҶ’ ext! reflвҷҜ)
      fe
      (is-equiv-вҲҳ (вҷҜ-map-is-equiv fe) ad)

вҷҜ-induction
  : вҲҖ {рқ“Ө} {A : Type рқ“Ө} (P : вҹЁвҷҜ| A вҹ© вҶ’ Type рқ“Ө) вҶ’ ((a : A) вҶ’ вҹЁвҷҜ| P (unit-вҷҜ a) вҹ©)
    вҶ’ (x : вҹЁвҷҜ| A вҹ©) вҶ’ вҹЁвҷҜ| P x вҹ©
вҷҜ-induction P sec x .counitвҷҜ = counitвҷҜ (sec (x .counitвҷҜ))

вҷҜ-GSU : GSU id
вҷҜ-GSU .GSU.S .Subtype.family = is-вҷҜ-codiscrete
вҷҜ-GSU .GSU.S .Subtype.has-is-subtype _ = is-equiv-is-prop
вҷҜ-GSU .GSU.S-equiv e = is-вҷҜ-codiscreteвҶҗis-equiv (e ._вүғ_.has-is-eqv)

вҷҜ-is-reflective-GSU : is-globally-reflective вҷҜ-GSU
вҷҜ-is-reflective-GSU .is-globally-reflective.в—Ӣ A = вҹЁвҷҜ| A вҹ©
вҷҜ-is-reflective-GSU .is-globally-reflective.О· = unit-вҷҜ
вҷҜ-is-reflective-GSU .is-globally-reflective.has-is-reflector {_} {A}
  = grf where
  open is-global-reflector
  grf : is-global-reflector вҷҜ-GSU A вҹЁвҷҜ| A вҹ© unit-вҷҜ
  grf .в—ӢвҲҲS = вҹЁвҷҜ|-вҹ©-is-вҷҜ-codiscrete
  grf .reflects Qdisc = is-equivвҶҗqiso
    ( (О» f x вҶ’ unmodвҷҜ Qdisc (modвҷҜ (f (x .counitвҷҜ))))
    , (О» f вҶ’ funextвҶ’ (О» a вҶ’ is-equiv.О· Qdisc (f a)))
    , (О» f вҶ’ funextвҶ’ (О» a вҶ’ is-equiv.О· Qdisc (f a)))
    )

вҷҜ-is-ОЈ-closed : is-globally-ОЈ-closed вҷҜ-GSU
вҷҜ-is-ОЈ-closed {A = A} {B} a b
  = in-SubUвҶҗО·-retract
      (is-globally-reflective.reflector вҷҜ-is-reflective-GSU (ОЈ A B) )
      ((О» x вҶ’ let aa = unmodвҷҜ a (modвҷҜ (x .counitвҷҜ .fst))
              in (aa , unmodвҷҜ (b aa)
                              (modвҷҜ (tr B (is-equiv.О·вҒ»В№ a (x .counitвҷҜ .fst))
                                          (x .counitвҷҜ .snd)))))
      , О» x вҶ’ ОЈ-pathвҶ’ ((is-equiv.О· a (fst x)) , {!is-equiv.О· (b (x .fst))!}))



}
%```
}

\subtree{
\title{Sharp codiscrete and sharp connected maps}
\taxon{Definition}

\p{A map #{f : A \to B} is #{\sharp}-codiscrete if all of its fibres are.}

%```agda
\agda{
is-вҷҜ-codiscrete-map
  : вҲҖ {рқ“Ө рқ“Ҙ} {A : Type рқ“Ө} {B : Type рқ“Ҙ} вҶ’ (A вҶ’ B) вҶ’ Type (рқ“Ө вҠ” рқ“Ҙ)
is-вҷҜ-codiscrete-map f = is-modal-map (SubUвҶҗglobal вҷҜ-GSU) f
}
%```

\p{A map is #{\sharp}-connected if all of it's fibres are \{\sharp}-connected.}

%```agda
\agda{
is-вҷҜ-connected-map
  : вҲҖ {рқ“Ө рқ“Ҙ} {A : Type рқ“Ө} {B : Type рқ“Ҙ} вҶ’ (A вҶ’ B) вҶ’ Type (рқ“Ө вҠ” рқ“Ҙ)
is-вҷҜ-connected-map = is-connected-map (is-reflectiveвҶҗglobal вҷҜ-is-reflective-GSU)
}
%```
}

\subtree{
\title{Sharp equivalences}
\taxon{Definition}

\p{A map #{f : A \to B} is a #{\sharp}-equivalence if precomposition at all
#{\sharp} codiscrete types are equivalences.}

%```agda
\agda{
is-вҷҜ-equiv
  : вҲҖ {рқ“Ө рқ“Ҙ} {A : Type рқ“Ө} {B : Type рқ“Ҙ} вҶ’ (A вҶ’ B) вҶ’ TypeПү
is-вҷҜ-equiv f = вҲҖ {рқ“ } {Q : Type рқ“ } вҶ’ is-вҷҜ-codiscrete Q вҶ’ is-equiv (precomp Q f)
}
%```

\p{For any crisp type, the counit #{\mod{\flat}{A} \to A} is a sharp equivalence.}

%```agda
\agda{
Оө-is-вҷҜ-equivalence
  : вҲҖ {@вҷӯ рқ“Ө} {@вҷӯ A : Type рқ“Ө} вҶ’ is-вҷҜ-equiv (Оөвҷӯ {A = A})
Оө-is-вҷҜ-equivalence Qcd = is-equivвҶҗqiso
  ( (О» f вҶ’ is-equiv.bwd Qcd вҲҳ вҷӯвҠЈвҷҜ-transpose (modвҷҜ f))
  , (О» f вҶ’ funextвҶ’ (О» a вҶ’ unap-equiv Qcd (is-equiv.Оө Qcd _)))
  , О» f вҶ’ funextвҶ’ (О» where (modвҷӯ a) вҶ’ unap-equiv Qcd (is-equiv.Оө Qcd _)))

Оө-is-вҷҜ-equiv' : вҲҖ {@вҷӯ рқ“Ө} {@вҷӯ A : Type рқ“Ө} вҶ’ is-equiv (вҷҜ-map (Оөвҷӯ {A = A}))
Оө-is-вҷҜ-equiv' = {!!}
}
%```
}

\subtree{
\title{Sharp connected maps are sharp equivalences}

%```agda
\agda{
is-вҷҜ-equivвҶҗis-вҷҜ-connected
  : вҲҖ {рқ“Ө рқ“Ҙ} {A : Type рқ“Ө} {B : Type рқ“Ҙ} {f : A вҶ’ B}
    вҶ’ is-вҷҜ-connected-map f вҶ’ is-вҷҜ-equiv f
is-вҷҜ-equivвҶҗis-вҷҜ-connected fs {_} {Q} Qcd
  = is-equivвҶҗis-contr-map (О» b вҶ’ {!!})
}
%```
}

\subtree{
\title{Sharp cordiscrete maps lift crisply against the flat counit}
\taxon{Theorem}

% \citek{MR2025}{3.1.2}

%```agda
\agda{
lifts-ОөвҷӯвҶҗis-вҷҜ-codiscrete
  : вҲҖ {@вҷӯ рқ“Ө рқ“Ҙ} {@вҷӯ A : Type рқ“Ө} {@вҷӯ B : Type рқ“Ҙ} {@вҷӯ f : A вҶ’ B}
    вҶ’ @вҷӯ is-вҷҜ-codiscrete-map f
    вҶ’ (вҲҖ {@вҷӯ рқ“ } {@вҷӯ Q : Type рқ“ } вҶ’ are-вҷӯ-orthogonal (Оөвҷӯ {рқ“ }{Q}) f)
lifts-ОөвҷӯвҶҗis-вҷҜ-codiscrete {f = f} fcd {_}{Q}
  = вҷӯ-is-cartesian (power-hom Оөвҷӯ f) {!!}
      (is-cartesianвҶҗorthogonal
        (connectedвҠҘmodal вҷҜ-is-reflective-GSU
          {!!}
          fcd))
}
%```
}

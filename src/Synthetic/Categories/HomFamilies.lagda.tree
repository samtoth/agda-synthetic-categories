}

\subtree[stt-00DG]{
\taxon{Lemma}
\title{Precategories are strongly Segal}

\p{A [simplicial type](stt-00AC) is [Segal](stt-00AI) iff it
is [strongly Segal](stt-00DA).}

\proof{

\p{We factorise the defining map for strongly Segal types as follows:}

\quiver{
\begin{tikzcd}
	{\Lambda^2_1} && {\Delta^2} \\
	\\
	\\
	{1 \ltimes \Delta^1 \simeq \square +^{\Delta^1}1} && {\ttt +^{\Delta^1}1}
	\arrow["{\sim_{\textit{Segal}}}", from=1-1, to=1-3]
	\arrow[from=1-1, to=4-1]
	\arrow["{\sim_{\textit{Segal}}}", from=1-3, to=4-3]
	\arrow["{\sim_{\textit{simp}}}", from=4-3, to=4-1]
\end{tikzcd}
}

\p{The top map is a Segal equivalence by definition. Likewise the bottom map
is a simplicial equivalence, which follows from \ref{stt-00DC}. Finally,
\ref{stt-00DI} gives the right most map as a Segal equivalence.}
}

%```agda
\agda{
1‚čČőĒ¬Ļ‚Üźcone : Pushout {B = ‚Ė°^ 2} (_, i0) (! {A = őĒ¬Ļ}) ‚Üí ūĚüô ‚čČ őĒ¬Ļ
1‚čČőĒ¬Ļ‚Üźcone = Pushout‚āĀ
  (mk-span-map
    (őĽ (a , b) ‚Üí b , tt , a)
    (őĽ i ‚Üí őīőĒ¬Ļ-0 , tt , i)
    inl
    ~refl
    ~refl)

1‚čČőĒ¬Ļ-is-cone : quasi-iso 1‚čČőĒ¬Ļ‚Üźcone
1‚čČőĒ¬Ļ-is-cone .fst = ‚ÜĎ-rec (mk-right-cocone őĻ‚āā (őĻ‚āĀ ‚ąė (_, i1))
                           őĽ where (_ , i) ‚Üí mk-hom (őĻ‚āĀ ‚ąė (i ,_))
                                                    (glue i)
                                                    refl)
1‚čČőĒ¬Ļ-is-cone .snd .fst = pushout-ind _
  (mk-coconeŠĶą ~refl ~refl
    (őĽ i ‚Üí IdŠĶą-func‚ÜźSquare
               {f = (1‚čČőĒ¬Ļ-is-cone .fst ‚ąė 1‚čČőĒ¬Ļ‚Üźcone)} {id} (glue i) refl refl
               (Square-degen-hor _ _
                 (ap-‚ąė (1‚čČőĒ¬Ļ-is-cone .fst) 1‚čČőĒ¬Ļ‚Üźcone (glue i)
                 ‚ąô ap (ap (1‚čČőĒ¬Ļ-is-cone .fst)) (pushout-rec-apő≤ _ ‚ąô ‚ąô-reflr _)
                 ‚ąô pushout-rec-apő≤ _ ‚ąô sym (ap-id (glue i))))))
1‚čČőĒ¬Ļ-is-cone .snd .snd = pushout-ind _
  (mk-coconeŠĶą ~refl (‚äé-ind (~refl , (őĽ i ‚Üí glue (őīőĒ¬Ļ-1 , tt , i))))
    őĽ { (mk-lift true , _ , i)
           ‚Üí IdŠĶą-func‚ÜźSquare (glue (őīőĒ¬Ļ-1 , tt , i)) refl (glue (őīőĒ¬Ļ-1 , tt , i))
               (coe
                 (Square-functorial-bot (sym (ap-id (glue (őīőĒ¬Ļ-1 , _ , i)))))
                 (Square-flatten-vert
                   (sym (ap-‚ąė 1‚čČőĒ¬Ļ‚Üźcone (1‚čČőĒ¬Ļ-is-cone .fst) (glue _)
                   ‚ąô ap (ap 1‚čČőĒ¬Ļ‚Üźcone) (pushout-rec-apő≤ _)))))
      ; (mk-lift false , _ , i)
           ‚Üí IdŠĶą-func‚ÜźSquare (glue (őīőĒ¬Ļ-0 , tt , i)) refl refl
               (Square-degen-hor _ _
                 (ap-‚ąė 1‚čČőĒ¬Ļ‚Üźcone (1‚čČőĒ¬Ļ-is-cone .fst) (glue (őīőĒ¬Ļ-0 , tt , i))
                 ‚ąô ap (ap 1‚čČőĒ¬Ļ‚Üźcone) (pushout-rec-apő≤ _) ‚ąô pushout-rec-apő≤ _
                 ‚ąô ‚ąô-reflr _ ‚ąô sym (ap-id (glue _)))) })

‚ßÖ-‚Ė°-degen-incl
  : Pushout {B = ‚ßÖ} (őĻ‚āā ‚ąė (_, i0)) ! ‚Üí Pushout {B = ‚Ė°^ 2} (_, i0) !
‚ßÖ-‚Ė°-degen-incl
  = Pushout‚āĀ (mk-span-map ‚ßÖ-incl id id ~refl ~refl)

strong-segal-factorisation
  : 1‚čČőĒ¬Ļ‚Üźcone ‚ąė ‚ßÖ-‚Ė°-degen-incl ‚ąė ‚ßÖ-degen‚ÜźőĒ¬≤ ‚ąė őõ[2,1]-incl ~ weird-horn-inclusion
strong-segal-factorisation
  = pushout-rec-unique _ _
      ~refl
      (őĽ i ‚Üí glue (őīőĒ¬Ļ-1 , tt , i))
      őĽ _ ‚Üí ap (_‚ąô glue (őīőĒ¬Ļ-1 , tt , i0))
              ( ap-‚ąė (1‚čČőĒ¬Ļ‚Üźcone ‚ąė ‚ßÖ-‚Ė°-degen-incl ‚ąė ‚ßÖ-degen‚ÜźőĒ¬≤)
                     őõ[2,1]-incl (glue tt)
              ‚ąô ap (ap (1‚čČőĒ¬Ļ‚Üźcone ‚ąė ‚ßÖ-‚Ė°-degen-incl ‚ąė ‚ßÖ-degen‚ÜźőĒ¬≤))
                   (pushout-rec-apő≤ tt)
              ‚ąô ap-‚ąė őĻ‚āĀ _ őĒ¬≤-refl
              ‚ąô ap (ap őĻ‚āĀ) (is-set‚Üźis-truncated
                    (Trunc.√ó‚ąąS car-is-set (Trunc.√ó‚ąąS Trunc.ūĚüô‚ąąS car-is-set))
                     _ _ _ refl))

is-based-triangulated
  : ‚ąÄ {ūĚď§} {A : Type ūĚď§}
    ‚Üí  ‚ßÖ-incl ‚ä• A ‚Üí ‚ßÖ-‚Ė°-degen-incl ‚ä• A
is-based-triangulated {A = A} ttA
  = left-orthogonal-type-pushout‚āĀ map .snd (lem ‚ąė ev tt)  where
  -- A map colim(‚ßÖ ‚Üź őĒ¬Ļ ‚Üí ūĚüô) ‚Üí colim(‚Ė° ‚Üź őĒ¬Ļ ‚Üí ūĚüô)
  -- is equivalently a map in the coslice under őĒ¬Ļ from ‚ßÖ ‚Üí ‚Ė°
  map : Coslice-map {A = őĒ¬Ļ} (őĻ‚āā ‚ąė (_, i0)) (_, i0)
  map .fst = ‚ßÖ-incl
  map .snd = ~refl

  lem : ‚ąÄ x ‚Üí map ‚ä• (őĽ _ ‚Üí x)
  lem x = coslice-orthogonality map .fst ttA (őĽ _ ‚Üí x)

is-strongly-segal‚Üźis-segal
  : ‚ąÄ {ūĚď§} {A : Type ūĚď§} ‚Üí is-simplicial A ‚Üí is-segal A
    ‚Üí is-strongly-segal A
is-strongly-segal‚Üźis-segal {A = A} asimp apc tt
  = is-equiv~‚ąė (őĽ h ‚Üí funext‚Üí őĽ a ‚Üí ap h (sym (strong-segal-factorisation a)))
      (is-equiv-‚ąė
        (apc tt)
        (‚ßÖ-degen‚ÜźőĒ¬≤-is-segal-equiv apc))
      (is-equiv-‚ąė
        (is-based-triangulated (simp-is-triangulated asimp tt))
        (precomp-equiv (is-equiv‚Üźqiso 1‚čČőĒ¬Ļ-is-cone)))

hom-fam-is-cov‚áĒis-precategory
  : ‚ąÄ {ūĚď§} {A : Type ūĚď§} ‚Üí is-simplicial A
    ‚Üí is-segal A ‚áĒ (‚ąÄ x ‚Üí is-covariant (Hom A x))
hom-fam-is-cov‚áĒis-precategory Asimp
  = (is-strongly-segal‚Üźis-segal Asimp , is-segal‚Üźis-strongly-segal)
  ‚ąô‚áĒ (hom-fam-is-cov‚áĒis-strongly-segal ‚áĒ‚ĀĽ¬Ļ)

coslice-is-left‚áĒis-precategory
  : ‚ąÄ {ūĚď§} {A : Type ūĚď§} ‚Üí is-simplicial A
    ‚Üí is-segal A ‚áĒ (‚ąÄ x ‚Üí is-left-fibration {A = Coslice A (őĽ (_ : ūĚüô) ‚Üí x)} fst)
coslice-is-left‚áĒis-precategory Asimp
  = hom-fam-is-cov‚áĒis-precategory Asimp
  ‚ąô‚áĒ precomp-ő†-‚áĒ (őĽ a ‚Üí hom-fam-is-cov‚áĒis-left-fibration a)
}
%```
}


\subtree[tot-0002]{
\title{Computing transport in representable families}
\taxon{Prop}
\p{Given a precategory #{A}, the covariant transport of a morphism
#{f : \Hom(b,c)} is given by precomposition
#{f \circ - : \Hom(a,b) \to \Hom(a,c)}.}


%```agda
\agda{
module _ {ūĚď§} {A : Type ūĚď§} (Asimp : is-simplicial A) (Apc : is-segal A) where
  private
    homc = hom-fam-is-cov‚áĒis-precategory Asimp .fst Apc

  segal-comp-is-strong-segal-comp
    : ‚ąÄ {x y z} (f : Hom A y z) (g : Hom A x y)
      ‚Üí is-equiv.bwd (Apc tt) (make-horn f g)
      ÔľĚ is-equiv.bwd (is-strongly-segal‚Üźis-segal Asimp Apc tt) (make-horn f g)
        ‚ąė 1‚čČőĒ¬Ļ‚Üźcone ‚ąė ‚ßÖ-‚Ė°-degen-incl ‚ąė ‚ßÖ-degen‚ÜźőĒ¬≤
  segal-comp-is-strong-segal-comp f g = {!!}

  hom-cov-is-segal-comp
    : ‚ąÄ {x y z} {f : Hom A y z} (g : Hom A x y)
    ‚Üí (h : Hom A x z)
    ‚Üí (Hom-over f g h) ‚ČÉ (Hom2 f g h)
  hom-cov-is-segal-comp g h = {!!}

  tr-hom-cov
    : ‚ąÄ {x y z} (f : Hom A y z)
      ‚Üí tr-cov-hom {P = Hom A x} (homc x) f ~ (f ‚ąė[ Apc ]_)
  tr-hom-cov {x}{y}{z} f g
    = unique-composite Apc f g (tr-cov-hom (homc _) f g)
          (total-map (őĽ h ‚Üí hom-cov-is-segal-comp g h ._‚ČÉ_.fwd)
            (is-covariant-hom‚Üźis-covariant (Hom A x) (homc x) f g .centre) .snd)

}
%```
}

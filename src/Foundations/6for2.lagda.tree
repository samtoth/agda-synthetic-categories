\date{2026-03-10}
\author{fredrikbakke}
\taxon
\title{The 6-for-2 property for equivalences}

\import{stt-macros}

% ```agda
\agda{
module Foundations.6for2 where

open import Foundations.Universes
open import Foundations.Functions
open import Foundations.Homotopy
open import Foundations.Sigma
open import Foundations.FunctionInverses
open import Foundations.QuasiIsomorphism
open import Foundations.CoherentIsomorphism
open import Foundations.EquivHomotopy
open import Foundations.3for2
open import Foundations.BiinvertibleMap
}
% ```

\subtree[fre-6969]{
\date{2026-03-10}
\author{fredrikbakke}
\taxon{Theorem}
\title{6-for-2 property for equivalences}

\p{
Suppose given a commuting diagram of maps

\quiver{
\begin{tikzcd}
	A && C \\
	\\
	B && D
	\arrow["j", from=1-1, to=1-3]
	\arrow["f"', from=1-1, to=3-1]
	\arrow["h", from=1-3, to=3-3]
	\arrow["i"', from=3-1, to=3-3]
	\arrow["g"', from=3-1, to=1-3]
\end{tikzcd}
}

such that #{j} and #{i} are [equivalences](stt-001U), then all 6 maps (including the
composite #{h \circ g \circ f}) are equivalences.
}

% ```agda
\agda{
module _
  {𝓤 𝓥 𝓦 𝓧 : Level}
  {A : Type 𝓤} {B : Type 𝓥} {C : Type 𝓦} {D : Type 𝓧}
  {f : A → B} {g : B → C} {h : C → D} where

  6-for-2-middle
    : is-equiv (g ∘ f)
    → is-equiv (h ∘ g)
    → is-equiv g
  6-for-2-middle egf ehg = is-equiv←is-biinv
    ( (f ∘ is-equiv.bwd egf , is-equiv.ε egf)
    , (is-equiv.bwd ehg ∘ h , is-equiv.η ehg))

  6-for-2-left
    : is-equiv (g ∘ f)
    → is-equiv (h ∘ g)
    → is-equiv f
  6-for-2-left egf ehg
    = 3-for-2 (6-for-2-middle egf ehg) egf

  6-for-2-right
    : is-equiv (g ∘ f)
    → is-equiv (h ∘ g)
    → is-equiv h
  6-for-2-right egf ehg
    = 3-for-2' (6-for-2-middle egf ehg) ehg

  6-for-2-comp
    : is-equiv (g ∘ f)
    → is-equiv (h ∘ g)
    → is-equiv (h ∘ g ∘ f)
  6-for-2-comp egf ehg
    = is-equiv-∘ ehg (6-for-2-left egf ehg)

  6-for-2
    : is-equiv (g ∘ f)
    → is-equiv (h ∘ g)
    → is-equiv f × is-equiv g × is-equiv h × is-equiv (h ∘ g ∘ f)
  6-for-2 egf ehg
    = ( 6-for-2-left egf ehg
      , 6-for-2-middle egf ehg
      , 6-for-2-right egf ehg
      , 6-for-2-comp egf ehg)
}
% ```

% ```agda
\agda{
module _
  {𝓤 𝓥 𝓦 𝓧 : Level}
  {A : Type 𝓤} {B : Type 𝓥} {C : Type 𝓦} {D : Type 𝓧}
  {f : A → B} {g : B → C} {h : C → D} {i : A → C} {j : B → D} where

  6-for-2~
    : i ~ g ∘ f
    → j ~ h ∘ g
    → is-equiv i
    → is-equiv j
    → is-equiv f × is-equiv g × is-equiv h × is-equiv (h ∘ g ∘ f)
  6-for-2~ H K ei ej
    = 6-for-2 (homotopy-is-equiv H ei) (homotopy-is-equiv K ej)
}
% ```
}

\subtree[fre-A070]{
\date{2026-04-24}
\author{fredrikbakke}
\title{Truncation levels}
\taxon{Definition}

% ```agda
\agda{
data рќ•‹ : Type where
  -2рќ•‹ : рќ•‹
  sucрќ•‹ : рќ•‹ в†’ рќ•‹

-1рќ•‹ 0рќ•‹ : рќ•‹
-1рќ•‹ = sucрќ•‹ -2рќ•‹
0рќ•‹  = sucрќ•‹ -1рќ•‹

trunc-index : рќ•‹ в†’ в„•
trunc-index -2рќ•‹ = 0
trunc-index (sucрќ•‹ n) = suc (trunc-index n)

trunc-level : в„• в†’ рќ•‹
trunc-level 0 = -2рќ•‹
trunc-level (suc n) = sucрќ•‹ (trunc-level n)

itsuc-рќ•‹ : в„• в†’ рќ•‹ в†’ рќ•‹
itsuc-рќ•‹ zero t = t
itsuc-рќ•‹ (suc n) t = sucрќ•‹ (itsuc-рќ•‹ n t)

sucit-рќ•‹ : рќ•‹ в†’ в„• в†’ рќ•‹
sucit-рќ•‹ t n = itsuc-рќ•‹ n t

рќ•‹в†ђв„• : в„• в†’ рќ•‹
рќ•‹в†ђв„• = sucit-рќ•‹ 0рќ•‹

neg-рќ•‹ : в„• в†’ рќ•‹
neg-рќ•‹ 0 = 0рќ•‹
neg-рќ•‹ 1 = -1рќ•‹
neg-рќ•‹ (suc (suc n)) = -2рќ•‹
}
% ```
}

\date{2025-04-17}
\taxon{Module}
\title{Universal property of the [unit type](Foundations.Unit)}
\import{stt-macros}



% ```agda
\agda{
module Foundations.UnitUP where

open import Foundations.Universes
open import Foundations.Unit
open import Foundations.Identity
open import Foundations.QuasiIsomorphism
open import Foundations.CoherentIsomorphism
open import Foundations.EquivHomotopy
open import Foundations.Sigma
open import Foundations.Functions
open import Foundations.Singleton
open import Foundations.DependentIdentity
open import Foundations.FunExt
}
% ```

\subtree[stt-002Q]{
\taxon{Theorem}

% ```agda
\agda{
unit-ev-is-equiv : ∀ {𝓤} {A : 𝟙 → Type 𝓤} → is-equiv (evᵈ: A tt)
unit-ev-is-equiv = is-equiv←qinv qinv where
  qinv : quasi-inv (ev tt)
  qinv .fst a _ = a
  qinv .snd .fst _ = refl
  qinv .snd .snd _ = refl

unit-UP≃ : ∀ {𝓤} {A : 𝟙 → Type 𝓤} → ((a : 𝟙) → A a) ≃ A tt
unit-UP≃ = mk≃ (ev tt) unit-ev-is-equiv

point-is-equiv : ∀ {𝓤} {A : Type 𝓤} → is-equiv (point: A)
point-is-equiv = is-equiv⁻¹ unit-ev-is-equiv
}
% ```
}

\subtree[stt-00D8]{
\taxon{Remark}

\p{The fact that unit has definitional eta allows us to do without
  funext in the above theorem. When generalising to arbitrary singletons
  (or if we were to disable unit-eta) we require funext.
}
}

\subtree[stt-006S]{
\date{2025-06-27}
\author{samueltoth}
\date{2025-03-09}
\author{fredrikbakke}
\title{Universal property for singleton types}
\taxon{Theorem}

% ```agda
\agda{
sing-evᵈ-is-equiv : ∀ {𝓤 𝓥} {A : Type 𝓤} {B : A → Type 𝓥}
                    → FunExtω 𝓥
                    → (s : is-singleton A)
                    → is-equiv (ev {B = B} (centre s))
sing-evᵈ-is-equiv {B = B} FE s = is-equiv←qinv qinv where
  qinv : quasi-inv (ev {B = B} (centre s))
  qinv .fst x a = tr B (central s a) x
  qinv .snd .fst f = WithFunExtω.funext→ FE (λ a → apᶠ f (central s a))
  qinv .snd .snd x
    = ap (λ q → tr B q x)
         (is-set←is-single s (centre s) (centre s)
           (central s (centre s))
           (refl))

sing-ev-is-equiv : ∀ {𝓤 𝓥} {A : Type 𝓤} {B : Type 𝓥}
                   → FunExtω 𝓥
                   → (s : is-singleton A)
                   → is-equiv (ev: B (centre s))
sing-ev-is-equiv FE s = is-equiv←qinv qinv where
  qinv : quasi-inv (ev (centre s))
  qinv .fst a _ = a
  qinv .snd .fst f = WithFunExtω.funext→ FE (λ a → ap f (central s a))
  qinv .snd .snd _ = refl

sing-UP≃ : ∀ {𝓤 𝓥} {A : Type 𝓤} {B : Type 𝓥}
           → FunExtω 𝓥
           → (s : is-singleton A)
           → (A → B) ≃ B
sing-UP≃ FE sing = mk≃ (ev (sing .centre)) (sing-ev-is-equiv FE sing)

sing-const-is-equiv : ∀ {𝓤 𝓥} {A : Type 𝓤} {B : Type 𝓥}
                      → FunExtω 𝓥
                      → (s : is-singleton A)
                      → is-equiv (const B A)
sing-const-is-equiv FE s = is-equiv⁻¹ (sing-ev-is-equiv FE s)

sing-!-is-equiv : ∀ {𝓤} {A : Type 𝓤} → is-singleton A → is-equiv (!: A)
sing-!-is-equiv as .is-equiv.qinv .fst = const _ _ (as .centre)
sing-!-is-equiv as .is-equiv.qinv .snd .fst = as .central
sing-!-is-equiv as .is-equiv.qinv .snd .snd _ = refl
sing-!-is-equiv as .is-equiv.coherent x
  = is-prop←is-single (＝-singleton←is-single (𝟙-is-singleton) _ _) _  _

sing≃𝟙 : ∀ {𝓤} {A : Type 𝓤} → is-singleton A → A ≃ 𝟙
sing≃𝟙 as ._≃_.fwd = !
sing≃𝟙 as ._≃_.has-is-eqv = sing-!-is-equiv as
}
% ```
}

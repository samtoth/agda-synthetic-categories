\subtree[tot-AA01]{
\title{The data of a covariant fibration over #{Δ^2}}
\taxon{Definition}

\agda{
Cov-Δ²-bundle
  : ∀ {𝓤} (B : Type 𝓤) 𝓥 → Type (𝓘 ⊔ 𝓤 ⊔ lsuc 𝓥)
Cov-Δ²-bundle B 𝓥
  = Σ[ X Y Z ∶ Σ (B → Type 𝓥) is-covariant ]
    ((fibrewise-map (Y .fst) (Z .fst)) × (fibrewise-map (X .fst) (Y .fst)))
}

\agda{
Cov-Δ²-bundle'
  : ∀ {𝓤} (B : Type 𝓤) 𝓥 → Type (𝓘 ⊔ 𝓤 ⊔ lsuc 𝓥)
Cov-Δ²-bundle' B 𝓥
  = Σ[ X Y Y' Z ∶ Σ (B → Type 𝓥) is-covariant ]
    Σ[ e ∶ (∀ b → Y .fst b ≃ Y' .fst b) ]
    ((fibrewise-map (Y' .fst) (Z .fst)) × (fibrewise-map (X .fst) (Y .fst)))

Cov-Δ²-bundle-coh
  : ∀ {𝓤 𝓥} {B : Type 𝓤} → Cov-Δ²-bundle' B 𝓥 → Cov-Δ²-bundle B 𝓥
Cov-Δ²-bundle-coh (X , Y , Y' , Z , e , f , g)
  = ( X
    , Y
    , Z
    , (λ b → f b ∘ e b ._≃_.fwd)
    , g)

Cov-Δ²-bundle-decoh
  : ∀ {𝓤 𝓥} {B : Type 𝓤} → Cov-Δ²-bundle B 𝓥 → Cov-Δ²-bundle' B 𝓥
Cov-Δ²-bundle-decoh (A , B , C , f , g)
  = ( A
    , B
    , B
    , C
    , (λ _ → id≃)
    , f
    , g)
}
}

\subtree[tot-A002]{
\title{Characterising the identity type of a covariant bundle over #{Δ^2}}
\taxon{Lemma}

\agda{
cov-Δ²-bundle-Id
  : ∀ {𝓤 𝓥} {B : Type 𝓤} (x y : Cov-Δ²-bundle B 𝓥)
    → Type (𝓤 ⊔ 𝓥)
cov-Δ²-bundle-Id
  ((A , _) , (B , _) , (C , _) , f , g)
  ((X , _) , (Y , _) , (Z , _) , α , β)
  = Σ[ e ∶ (∀ a → A a ≃ X a)] Σ[ j ∶ (∀ b → B b ≃ Y b)] Σ[ k ∶ (∀ c → C c ≃ Z c)]
     ( (∀ x → k x ._≃_.fwd ∘ f x ~ α x ∘ j x ._≃_.fwd)
     × (∀ x → j x ._≃_.fwd ∘ g x ~ β x ∘ e x ._≃_.fwd))


cov-Δ²-bundle'-Id
  : ∀ {𝓤 𝓥} {B : Type 𝓤} (x y : Cov-Δ²-bundle' B 𝓥)
    → Type (𝓤 ⊔ 𝓥)
cov-Δ²-bundle'-Id
  ((A , _) , (B , _) , (B' , _) , (C , _) , H , f , g)
  ((X , _) , (Y , _) , (Y' , _) , (Z , _) , K , α , β)
  = Σ[ e ∶ (∀ a → A a ≃ X a)]
    Σ[ j ∶ (∀ b → B b ≃ Y b)]
    Σ[ l ∶ (∀ b → B' b ≃ Y' b) ]
    Σ[ k ∶ (∀ c → C c ≃ Z c)]
     ( (∀ x → l x ._≃_.fwd ∘ H x ._≃_.fwd ~ K x ._≃_.fwd ∘ j x ._≃_.fwd)
     × (∀ x → k x ._≃_.fwd ∘ f x ~ α x ∘ l x ._≃_.fwd)
     × (∀ x → j x ._≃_.fwd ∘ g x ~ β x ∘ e x ._≃_.fwd))

cov-Δ²-bundle-Id-refl
  : ∀ {𝓤 𝓥} {B : Type 𝓤} (x : Cov-Δ²-bundle B 𝓥)
    → cov-Δ²-bundle-Id x x
cov-Δ²-bundle-Id-refl x
  = ( (λ _ → id≃)
    , (λ _ → id≃)
    , (λ _ → id≃)
    , (λ _ → ~refl)
    , (λ _ → ~refl))

opaque
  cov-Δ²-bundle-Id-is-torsorial
    : ∀ {𝓤 𝓥} {B : Type 𝓤} (x : Cov-Δ²-bundle B 𝓥)
      → is-singleton (Σ _ (cov-Δ²-bundle-Id x))
  cov-Δ²-bundle-Id-is-torsorial (A , B , C , f , g)
    = is-singleton-structure←parts
        (SingS-is-single A)
        (A , (λ _ → id≃))
        (is-singleton-structure←parts
          (SingS-is-single B)
          (B , (λ _ → id≃))
          (is-singleton-structure←parts
            (SingS-is-single C)
            (C , (λ _ → id≃))
            (is-singleton-structure←parts
              (SingS-is-single f)
              (f , (λ _ → ~refl))
              (SingS-is-single g))))

instance
  cov-Δ²-bundle-IdS
    : ∀ {𝓤 𝓥} {B : Type 𝓤} → Identity-system (Cov-Δ²-bundle B 𝓥) (𝓤 ⊔ 𝓥)
  cov-Δ²-bundle-IdS .Identity-system.IdS = cov-Δ²-bundle-Id
  cov-Δ²-bundle-IdS .Identity-system.IdS←Id {x} refl = cov-Δ²-bundle-Id-refl x
  cov-Δ²-bundle-IdS .Identity-system.IdS←Id-is-equiv x
    = fundamental-Id _ (cov-Δ²-bundle-Id-is-torsorial x) _
}
}

\subtree[tot-R007]{
\title{The induced transport of a covariant family over #{Δ²}}
\taxon{Construction}

\p{Given a covariant type family over #{B \times \Delta^2}, we can construct a
[covariant bundle over #{Δ^2}](tot-A002).}

\agda{
tr²Σ' : ∀ {𝓤 𝓥} {B : Type 𝓤}
      → (Σ (B × Δ² → Type 𝓥) is-covariant)
      → Cov-Δ²-bundle' B 𝓥
tr²Σ' (F , Fcov)
  = ( (F ∘ (_, δ₂² i0) , covariant-base-change {P = F} (_, δ₂² i0) Fcov)
    , (F ∘ (_, δ₂² i1) , covariant-base-change {P = F} (_, δ₂² i1) Fcov)
    , (F ∘ (_, δ₀² i0) , covariant-base-change {P = F} (_, δ₀² i0) Fcov)
    , (F ∘ (_, δ₀² i1) , covariant-base-change {P = F} (_, δ₀² i1) Fcov)
    , (λ b → tr≃ (F ∘ (b ,_)) Δ²-refl)
    , (λ b → tr-cov {P = F ∘ (b ,_)} (covariant-base-change {P = F} (b ,_) Fcov) δ₀²)
    , (λ b → tr-cov {P = F ∘ (b ,_)} (covariant-base-change {P = F} (b ,_) Fcov) δ₂²))
}
}

\subtree[tot-R002]{
\title{The gluing of a composable pair of maps}


\agda{
module HornGluing
  {𝓤 𝓥} {B : Type 𝓤}
  (X Y Z : B → Type (𝓘 ⊔ 𝓥)) (β : ∀ b → Y b → Z b) (α : ∀ b → X b → Y b)
  where

  fibre-map : ∀ i → fibrewise-map (Gl X Y α ∘ (_, i)) Z
  fibre-map i b = β b ∘ fst

  fibre-map-at-1 : ∀ b → Arrow-equiv (fibre-map i1 b) (β b)
  fibre-map-at-1 b .fst .Arrow-Π.top = fst
  fibre-map-at-1 b .fst .Arrow-Π.bot = id
  fibre-map-at-1 b .fst .Arrow-Π.comm = ~refl
  fibre-map-at-1 b .snd .fst = Gl-1-is-equiv X Y α b
  fibre-map-at-1 b .snd .snd = id-is-equiv

  fibre-map-at-0 : ∀ b → Arrow-equiv (fibre-map i0 b) (β b ∘ α b)
  fibre-map-at-0 b .fst .Arrow-Π.top = Gl-0 X Y α b
  fibre-map-at-0 b .fst .Arrow-Π.bot = id
  fibre-map-at-0 b .fst .Arrow-Π.comm (y , p) = ap (β b) (sym (p refl .snd))
  fibre-map-at-0 b .snd .fst = Gl-0-is-equiv X Y α b
  fibre-map-at-0 b .snd .snd = id-is-equiv

  Gl² : B × Δ² → Type (𝓘 ⊔ 𝓥)
  Gl² (b , (i , j)) = Gl (λ b' → Gl X Y α (b' , i)) Z (fibre-map i) (b , j)

  Gl²' : (B × Δ¹) × Δ¹ → Type (𝓘 ⊔ 𝓥)
  Gl²' = Gl (Gl X Y α) (Z ∘ fst) (uncurry fibre-map ∘ ×-swap→)

  Gl²-as-base-change : Gl² ~ Gl²' ∘ _≃_.bwd ×-assoc ∘ (id ⊗ □←Δ²-upper)
  Gl²-as-base-change = ~refl

  Gl²-0 : fibrewise-map (Gl² ∘ (_, δ₂² i0)) X
  Gl²-0 b = Gl-0 X Y α b ∘ Gl-0 _ Z (fibre-map i0) b

  Gl²-0-is-equiv
    : is-fibrewise-equiv Gl²-0
  Gl²-0-is-equiv b
    = is-equiv-∘ (Gl-0-is-equiv X Y α b) (Gl-0-is-equiv _ Z (fibre-map i0) b)

  Gl²-1 : fibrewise-map (Gl² ∘ (_, δ₂² i1)) Y
  Gl²-1 b = Gl-1 X Y α b ∘ Gl-0 _ Z (fibre-map i1) b

  Gl²-1-is-equiv
    : is-fibrewise-equiv Gl²-1
  Gl²-1-is-equiv b
    = is-equiv-∘ (Gl-1-is-equiv X Y α b) (Gl-0-is-equiv _ Z (fibre-map i1) b)

  Gl²-1' : fibrewise-map (Gl² ∘ (_, δ₀² i0)) Y
  Gl²-1' = Gl²-1

  Gl²-2 : fibrewise-map (Gl² ∘ (_, δ₀² i1)) Z
  Gl²-2 = Gl-1 _ Z _

  Gl²-2-is-equiv : is-fibrewise-equiv Gl²-2
  Gl²-2-is-equiv = Gl-1-is-equiv _ Z _

  -- Gl-δ₀² : ∀ b → Arrow-equiv (Gl² ∘ (id ⊗ δ₀²)) (α b)
  -- Gl-δ₀² b .fst .Arrow-Π.top = {!!}
  -- Gl-δ₀² b .fst .Arrow-Π.bot = {!!}
  -- Gl-δ₀² b .fst .Arrow-Π.comm = {!!}
  -- Gl-δ₀² b .snd = {!!}
}
}

\subtree[tot-R003]{
\title{Covariance of directed horn glueing}
\taxon{Lemma}

\proof{
The directed horn glueing family arrises as a base-change of a directed gluing of
covariant families, which by \ref{tot-L003} is covariant.
}

\agda{
module _
  {𝓤 𝓥} {B : Type 𝓤}
  (X Y Z : B → Type (𝓘 ⊔ 𝓥)) (β : ∀ b → Y b → Z b) (α : ∀ b → X b → Y b)
  where
  open HornGluing {𝓤} {𝓥} X Y Z β α

  Gl²'-is-covariant
    : is-covariant X → is-covariant Y → is-covariant Z
    → is-covariant Gl²'
  Gl²'-is-covariant Xc Yc Zc
    = Gl-is-covariant
        (Gl X Y α)
        (Z ∘ fst)
        (uncurry fibre-map ∘ ×-swap→)
        (Gl-is-covariant X Y α Xc Yc)
        (covariant-base-change {P = Z} fst Zc)

  Gl²-is-covariant
    : is-covariant X → is-covariant Y → is-covariant Z
    → is-covariant Gl²
  Gl²-is-covariant Xc Yc Zc
    = covariant-base-change
        {P = Gl²'}
        (_≃_.bwd ×-assoc ∘ (id ⊗ □←Δ²-upper))
        (Gl²'-is-covariant Xc Yc Zc)
}
}


\subtree[tot-L034]{
\title{Directed #{\Delta^2} univalence for covariant families}
\taxon{Theorem}

\p{The map defined in \ref{tot-R007} induces an equivalence between covariant
families over #{B \times \Delta^2} and the type consisting of a tripple of covariant
families over #{B} and fibrewise maps between them.}

\agda{
module _
  {𝓤 𝓥} {B : Type 𝓤}
  where

  tr²Σ-inv
    : Cov-Δ²-bundle B (𝓥 ⊔ 𝓘)
    → (Σ (B × Δ² → Type (𝓥 ⊔ 𝓘)) is-covariant)
  tr²Σ-inv ((A , Ac) , (B , Bc) , (C , Cc) , β , α)
    = (HornGluing.Gl² {𝓤} {𝓥} A B C β α , Gl²-is-covariant {𝓤} {𝓥} A B C β α Ac Bc Cc)
}


\agda{
opaque
  unfolding tr-cov
  adjust-transport
    : ∀ {𝓤 𝓥 𝓦} {A : Type 𝓤} {F : A → Type 𝓥} {G : A → Type 𝓦}
        (Fc : is-covariant F) (Gc : is-covariant G)
        (e : ∀ a → F a ≃ G a)
        (h : Δ¹ → A)
      → Arrow-equiv (tr-cov {P = F} Fc h) (tr-cov {P = G} Gc h)
  adjust-transport {F = F} {G} Fc Gc e h .fst .Arrow-Π.top = e (h i0) ._≃_.fwd
  adjust-transport {F = F} {G} Fc Gc e h .fst .Arrow-Π.bot = e (h i1) ._≃_.fwd
  adjust-transport {F = F} {G} Fc Gc e h .fst .Arrow-Π.comm x
    = sym (ap fst (central (Gc h (e (h i0) ._≃_.fwd x))
                           ( e (h i1) ._≃_.fwd (tr-cov {P = F} Fc h x)
                           , apᵈ-hom
                              (λ {i} → e (h i) ._≃_.fwd)
                              (tr-cov-filler {P = F} Fc h x))))
  adjust-transport {F = F} {G} Fc Gc e h .snd .fst = e (h i0) ._≃_.fwd-is-equiv
  adjust-transport {F = F} {G} Fc Gc e h .snd .snd = e (h i1) ._≃_.fwd-is-equiv

  tr-cov-base-change
    : ∀ {𝓤 𝓥 𝓦} {A : Type 𝓤} {B : Type 𝓥} (f : A → B) (F : B → Type 𝓦)
        (Fc : is-covariant F)
        (h : Δ¹ → A)
      → tr-cov {P = F ∘ f} (covariant-base-change {P = F} f Fc) h
      ~ tr-cov {P = F} Fc (f ∘ h)
  tr-cov-base-change f F Fc h x = refl

module _
  {𝓤 𝓥} {B : Type 𝓤} (c@((X , Xc) , (Y , Yc) , (Z , Zc) , f , g) : Cov-Δ²-bundle B (𝓘 ⊔ 𝓥))
  where
  open HornGluing {𝓤} {𝓥} X Y Z f g

  opaque
    unfolding tr-cov
    -- tr (Gl² ∘ (id ⊗ δ₀²)) (b, _) ≃ tr (Gl (Gl X Y g) Z fibre-map) ≃ fibre-map i1 b ≃ f b
    tr-Gl²-δ₀²
      : ∀ b
        → Arrow-equiv
          (tr-cov
            {P = Gl²}
            (Gl²-is-covariant {𝓤} {𝓥} X Y Z f g Xc Yc Zc)
            (λ i → b , δ₀² i))
          (f b)
    tr-Gl²-δ₀² b
        = concat-Arrow-equiv
            (tr-Gl-0≤1
              {𝓘 ⊔ 𝓤} {𝓘 ⊔ 𝓥} {B = B × Δ¹} {X = Gl X Y g} {Z ∘ fst}
              (uncurry fibre-map ∘ ×-swap→)
              (Gl-is-covariant X Y g Xc Yc)
              (covariant-base-change {P = Z} fst Zc)
              (b , i1))
            ( (mk-amap (Gl-1 X Y g b) id ~refl)
            , (Gl-1-is-equiv X Y g b) , id-is-equiv)

    tr-Gl²-δ₂²
      : ∀ b
        → Arrow-equiv
          (tr-cov
            {P = Gl²}
            (Gl²-is-covariant {𝓤} {𝓥} X Y Z f g Xc Yc Zc)
            λ i → b , δ₂² i)
          (g b)
    tr-Gl²-δ₂² b
      = concat-Arrow-equiv
          {f = tr-cov
                 {P = Gl² ∘ (id ⊗ δ₂²)}
                 (covariant-base-change
                   {P = Gl²}
                   (id ⊗ δ₂²)
                   (Gl²-is-covariant {𝓤} {𝓥} X Y Z f g Xc Yc Zc))
                 (b ,_)}
          {g = tr-cov
                 {P = Gl X Y g}
                 (Gl-is-covariant X Y g Xc Yc)
                 (b ,_)}
          (adjust-transport
             {F = Gl² ∘ (id ⊗ δ₂²)}
             {Gl X Y g}
             (covariant-base-change
                   {P = Gl²}
                   (id ⊗ δ₂²)
                   (Gl²-is-covariant {𝓤} {𝓥} X Y Z f g Xc Yc Zc))
             (Gl-is-covariant X Y g Xc Yc)
             (λ b → mk≃ (Gl-0 (Gl X Y g) (Z ∘ fst) (uncurry fibre-map ∘ ×-swap→) b)
                        (Gl-0-is-equiv (Gl X Y g) (Z ∘ fst) (uncurry fibre-map ∘ ×-swap→) b))
             (b ,_))
          (tr-Gl-0≤1 {𝓤} {𝓥} g Xc Yc b)

  opaque
    unfolding tr-cov tr-Gl²-δ₂² tr-Gl²-δ₀² adjust-transport
    tr²Σ-section
      : cov-Δ²-bundle'-Id {𝓤} {𝓘 ⊔ 𝓥} {B}
                (tr²Σ' (tr²Σ-inv {𝓤} {𝓥} c))
                (Cov-Δ²-bundle-decoh c)
    tr²Σ-section .fst b
      = mk≃ (Gl²-0 b) (Gl²-0-is-equiv b)
    tr²Σ-section .snd .fst b
      = mk≃ (Gl²-1 b) (Gl²-1-is-equiv b)
    tr²Σ-section .snd .snd .fst b
      = mk≃ (Gl²-1 b) (Gl²-1-is-equiv b)
    tr²Σ-section .snd .snd .snd .fst b
      = mk≃ (Gl²-2 b) (Gl²-2-is-equiv b)
    tr²Σ-section .snd .snd .snd .snd .fst b x
      =  Gl²-1 b (tr (Gl² ∘ (b ,_)) Δ²-refl x)
      ＝⟨ ap (Gl²-1 b)
             ( tr (Gl² ∘ (b ,_)) Δ²-refl x
             ＝⟨  tr∘
                   (Gl²' ∘ _≃_.bwd ×-assoc)
                   ((b ,_) ∘ □←Δ²-upper)
                   Δ²-refl {x} ⟩
               tr (Gl²' ∘ _≃_.bwd ×-assoc)
                  (ap (λ i → (b , □←Δ²-upper i)) Δ²-refl)
                  x
             ＝⟨ sym (tr-refl _ x (ap-∘ (b ,_) □←Δ²-upper Δ²-refl  ∙ ap (ap (b ,_)) prop!)) ⟩
               x ∎) ⟩
        Gl²-1 b x ∎
    tr²Σ-section .snd .snd .snd .snd .snd .fst b = tr-Gl²-δ₀² b .fst .Arrow-map.comm
    tr²Σ-section .snd .snd .snd .snd .snd .snd b = tr-Gl²-δ₂² b .fst .Arrow-map.comm
}

\agda{
Δ²-point-incl : Fin 3 → Δ²
Δ²-point-incl fzero = (i0 , i0)
Δ²-point-incl (fsuc fzero) = (i1 , i0)
Δ²-point-incl (fsuc (fsuc x)) = (i1 , i1)

module _
  {@♭ 𝓤 𝓥} {@♭ B : Type 𝓤}
  (@♭ crisp-cov-Nat-is-equiv
        : ∀ {@♭ 𝓤} (@♭ F G : Σ (B × Δ² → Type 𝓤) is-covariant)
            (@♭ α : ∀ i → F .fst i → G .fst i)
          → @♭ (∀ x → is-equiv (α ((id ⊗ Δ²-point-incl) x)))
          → is-fibrewise-equiv α)
  where
  open HornGluing {𝓤} {𝓥}

  tr²Σ-retraction→
    : ∀ (F : Σ (B × Δ² → Type (𝓥 ⊔ 𝓘)) is-covariant) (b : B × Δ²)
      → F .fst b → tr²Σ-inv {𝓤} {𝓥 ⊔ 𝓘}{B} (Cov-Δ²-bundle-coh (tr²Σ' F)) .fst b
  tr²Σ-retraction→ (F , Fc) (b , i) fb .fst = {!!} -- coe F (i ≤ 2) fb
  tr²Σ-retraction→ (F , Fc) (b , (i , i0)) fb .snd refl .fst
    = {!trΣ-retraction→ ? (F ∘ (id ⊗ δ₂²) , ?) (b , i) ?!}
    -- trΣ-retraction→ : F (b , i , 0) →  Gl (F 0) (F 1) (tr F 0≤1) (b, i)
  tr²Σ-retraction→ (F , Fc) (b , (i , i0)) fb .snd refl .snd = {!!}

  opaque
    tr²Σ-is-♭-equiv
      : is-equiv (♭-map (tr²Σ' {𝓤}{𝓘 ⊔ 𝓥}{B}))
    tr²Σ-is-♭-equiv
      = is-equiv←qinv
          ( (♭-map (tr²Σ-inv {𝓤} {𝓘 ⊔ 𝓥} ∘ Cov-Δ²-bundle-coh))
          , ♭-ind (λ F → mapply♭ (mod♭ (ext! (λ b → mk≃ (tr²Σ-retraction→ F b) {!!} e⁻¹))))
          , ♭-ind (λ a → mapply♭ (mod♭ {!!})))
}
}

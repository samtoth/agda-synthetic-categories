\title{Synthetic Tiny objects}
\author{samueltoth}
\taxon{Module}
\import{stt-macros}



%```agda
\agda{
{-# OPTIONS --allow-unsolved-metas #-}
module Synthetic.Tiny2 where

open import Foundations.Prelude
open import ufAxioms

open import Modalities.Cohesion.Flat
open import Modalities.Cohesion.FlatLex
open import Modalities.Cohesion.Connectivity
open import Modalities.Instances.Truncation

open import Ergonomics.Extensionality

open import Core.Arrow
open import Core.PiSection
open import Core.UniversalFibration
open import Core.Small
}
%```


\translude{stt-00BC}

\subtree{
\title{Idea}

\p{In type theory, we can represent the situation where a type #{I} has a right
adjoint using with the following judgement (Where #{\mathcal{P}} represents
exponentiating the context by #{I}):}

##{
\frac{\mathcal{P}(\Gamma) \vdash A}{\Gamma \vdash \sqrt[I]{A}}
}

\p{In addition, you need rules expressing the unit and counit of the adjunction.
It is clearly not possible to introduce this type as an axiom inside of type
theory; but there have been structural extensions to type theory that allow this
type to be represented. Firstly, it fits within the general framework of
[multimode type theory](GKNB21) and this approach is taken in \citek{GWB2024} to
define the category of spaces. Secondly, Mitchel Riley \citek{MR2024} introduced a
bespoke type theory that incorporates a tiny object.}

\p{Seperately, \citek{LOPS2018} make use of the [flat
modality](Modalities.Flat.Flat) to postulate an amazing right adjoint. In this
module we formalise a similar construction, except instead of postulating the
adjunction directly, we postulate a type former with #{\beta} and #{\eta} laws
roughly based off Mitchel Riley's work.  }
}


\subtree[tot-0001]{
\title{Tiny types}
\taxon{Definition}

%```agda
\agda{
is-tiny-structure
  : вҲҖ {@вҷӯ рқ“Ө рқ“Ҙ} (@вҷӯ I : Type рқ“Ө) (@вҷӯ A : Type рқ“Ҙ)
      (@вҷӯ вҲҡA : Type рқ“Ҙ) (@вҷӯ вҲҡОө : (I вҶ’ вҲҡA) вҶ’ A) вҶ’ TypeПү
is-tiny-structure I A вҲҡA вҲҡОө
  = вҲҖ {@вҷӯ рқ“Ө} {@вҷӯ X : Type рқ“Ө}
    вҶ’ is-equiv {A = вҹЁвҷӯ| (X вҶ’ вҲҡA) вҹ©} {B = вҹЁвҷӯ| ((I вҶ’ X) вҶ’ A) вҹ©}
               (вҷӯ-map (postcomp _ вҲҡОө вҲҳ postcomp I))

record ОЈПү {рқ“Ө} (A : TypeВ рқ“Ө) (B : A вҶ’ TypeПү) : TypeПү where
  constructor _,_
  field
    fstПү : A
    sndПү : B fstПү

open ОЈПү

ОЈПүвҷӯ : вҲҖ {@вҷӯ рқ“Ө} (@вҷӯ A : Type рқ“Ө) (B : @вҷӯ A вҶ’ TypeПү)
     вҶ’ TypeПү
ОЈПүвҷӯ A B = ОЈПү вҹЁвҷӯ| A вҹ© О» where (modвҷӯ a) вҶ’ B a

@вҷӯ sndПүвҷӯ : вҲҖ {@вҷӯ рқ“Ө} {@вҷӯ A : Type рқ“Ө} {@вҷӯ B : @вҷӯ A вҶ’ TypeПү}
           вҶ’ (@вҷӯ x : ОЈПүвҷӯ A B) вҶ’ B (Оөвҷӯ (fstПү x))
sndПүвҷӯ (modвҷӯ x , y) = y

syntax ОЈПүвҷӯ A (О» x вҶ’ B) = ОЈПү[вҷӯ x вҲ¶ A ] B


is-tiny : вҲҖ {@вҷӯ рқ“ҳ} вҶ’ @вҷӯ Type рқ“ҳ вҶ’ TypeПү
is-tiny I
  = вҲҖ {@вҷӯ рқ“Ө} вҶ’ ОЈПү[вҷӯ вҲҡ вҲ¶ (вҲҖ (@вҷӯ A : Type рқ“Ө) вҶ’ Type рқ“Ө) ]
                 ОЈПү[вҷӯ вҲҡОө вҲ¶ (вҲҖ {@вҷӯ A : Type рқ“Ө} вҶ’ (I вҶ’ вҲҡ A) вҶ’ A) ]
                   (вҲҖ {@вҷӯ A : Type рқ“Ө} вҶ’ is-tiny-structure I A (вҲҡ A) вҲҡОө)

Types-separate
  : вҲҖ {@вҷӯ рқ“Ө рқ“Ҙ} {@вҷӯ A : Type рқ“Ө} {@вҷӯ B : Type рқ“Ҙ} (@вҷӯ f : A вҶ’ B) вҶ’ TypeПү
Types-separate f
  = @вҷӯ (вҲҖ {@вҷӯ рқ“Ө }{@вҷӯ О“ : Type рқ“Ө} вҶ’  is-equiv (вҷӯ-map (postcomp О“ f)))
    вҶ’ is-equiv f
}
%```
}

\subtree[tot-23JK]{

%```agda
\agda{
module Tiny {@вҷӯ рқ“ҳ} (@вҷӯ I : Type рқ“ҳ)
            (@вҷӯ вҲҡ : вҲҖ {@вҷӯ рқ“Ө} вҶ’ @вҷӯ Type рқ“Ө вҶ’ Type рқ“Ө)
            (@вҷӯ вҲҡОө : вҲҖ {@вҷӯ рқ“Ө} {@вҷӯ A : Type рқ“Ө} вҶ’ (I вҶ’ вҲҡ A) вҶ’ A)
            (@вҷӯ is-tiny-str : вҲҖ {@вҷӯ рқ“Ө} {@вҷӯ A : Type рқ“Ө}
                              вҶ’ is-tiny-structure I A (вҲҡ A) вҲҡОө)
            (@вҷӯ types-separate : вҲҖ {@вҷӯ рқ“Ө рқ“Ҙ} {@вҷӯ A : Type рқ“Ө} {@вҷӯ B : Type рқ“Ҙ}
                                   {@вҷӯ f : A вҶ’ B} вҶ’ Types-separate f)
            (@вҷӯ prop-is-disc : вҲҖ {@вҷӯ рқ“Ө} {@вҷӯ A : Type рқ“Ө} вҶ’ is-prop A вҶ’ is-вҷӯ-discrete A)
            where
  module is-tiny {@вҷӯ рқ“Ө рқ“Ҙ} {@вҷӯ A : Type рқ“Ө} {@вҷӯ X : Type рқ“Ҙ}
    = is-equiv (is-tiny-str {рқ“Ө} {A} {рқ“Ҙ} {X})

  transpose : вҲҖ {@вҷӯ рқ“Ө рқ“Ҙ} {@вҷӯ О“ : Type рқ“Ө} {@вҷӯ A : Type рқ“Ҙ}
              вҶ’ вҹЁвҷӯ| ((I вҶ’ О“) вҶ’ A)вҹ© вҶ’ вҹЁвҷӯ| (О“ вҶ’ вҲҡ A) вҹ©
  transpose = is-equiv.bwd is-tiny-str

  untranspose : вҲҖ {@вҷӯ рқ“Ө рқ“Ҙ} {@вҷӯ О“ : Type рқ“Ө} {@вҷӯ A : Type рқ“Ҙ}
              вҶ’ (О“ вҶ’ вҲҡ A) вҶ’ ((I вҶ’ О“) вҶ’ A)
  untranspose = postcomp _ вҲҡОө вҲҳ postcomp I

  transpose-unique'
    : вҲҖ {@вҷӯ рқ“Ө рқ“Ҙ} {@вҷӯ О“ : Type рқ“Ө} {@вҷӯ A : Type рқ“Ҙ}
        {f : вҹЁвҷӯ| ((I вҶ’ О“) вҶ’ A)вҹ©} {g : вҹЁвҷӯ| (О“ вҶ’ вҲҡ A) вҹ©}
      вҶ’ вҷӯ-map untranspose g пјқ f
      вҶ’ g пјқ transpose f
  transpose-unique' {f = f} H = unap-equiv is-tiny-str (H вҲҷ is-tiny.ОөвҒ»В№ f)

  transpose-unique'-is-equiv
    : вҲҖ {@вҷӯ рқ“Ө рқ“Ҙ} {@вҷӯ О“ : Type рқ“Ө} {@вҷӯ A : Type рқ“Ҙ}
        {f : вҹЁвҷӯ| ((I вҶ’ О“) вҶ’ A)вҹ©} {g : вҹЁвҷӯ| (О“ вҶ’ вҲҡ A) вҹ©}
      вҶ’ is-equiv (transpose-unique' {f = f}{g})
  transpose-unique'-is-equiv{f = f}{g}
    = is-equiv-вҲҳ
        (unap-equiv-is-equiv is-tiny-str)
        (вҲҷ-is-equiv' (is-tiny.ОөвҒ»В№ f))

  transpose-unique
    : вҲҖ {@вҷӯ рқ“Ө рқ“Ҙ} {@вҷӯ О“ : Type рқ“Ө} {@вҷӯ A : Type рқ“Ҙ}
        {@вҷӯ f : ((I вҶ’ О“) вҶ’ A)} {@вҷӯ g : О“ вҶ’ вҲҡ A}
      вҶ’ вҹЁвҷӯ| (untranspose g) пјқ f вҹ©
      вҶ’ вҹЁвҷӯ| g пјқ Оөвҷӯ (transpose (modвҷӯ f)) вҹ©
  transpose-unique {g = g}
    = вҷӯ-map (ap Оөвҷӯ вҲҳ transpose-unique' {g = modвҷӯ g}) вҲҳ apвҷӯ' modвҷӯ

  transpose-unique-is-equiv
    : вҲҖ {@вҷӯ рқ“Ө рқ“Ҙ} {@вҷӯ О“ : Type рқ“Ө} {@вҷӯ A : Type рқ“Ҙ}
        {@вҷӯ f : ((I вҶ’ О“) вҶ’ A)} {@вҷӯ g : О“ вҶ’ вҲҡ A}
      вҶ’ is-equiv (transpose-unique {f = f}{g})
  transpose-unique-is-equiv = {!!}

  transpose-naturality
    : вҲҖ {@вҷӯ рқ“Ө рқ“Ҙ рқ“Ұ} {@вҷӯ О“ : Type рқ“Ө} {@вҷӯ О” : Type рқ“Ұ} {@вҷӯ A : Type рқ“Ҙ}
      вҶ’ (P : вҹЁвҷӯ| ((I вҶ’ О“) вҶ’ A)вҹ©)
      вҶ’ (@вҷӯ Пғ : О” вҶ’ О“)
      вҶ’ transpose (вҷӯ-map (precomp _ (postcomp I Пғ)) P)
      пјқ вҷӯ-map (precomp _ Пғ) (transpose P)
  transpose-naturality (modвҷӯ P) Пғ = sym (transpose-unique'
    ( (вҷӯ-map untranspose вҲҳ вҷӯ-map (precomp (вҲҡ _) Пғ)) (transpose (modвҷӯ P))
    пјқвҹЁ sym (вҷӯ-вҲҳ untranspose (precomp _ Пғ) _) вҹ©
       вҷӯ-map (untranspose вҲҳ precomp _ Пғ) (transpose (modвҷӯ P))
    пјқвҹЁвҹ©
       вҷӯ-map (precomp _  (postcomp _ Пғ) вҲҳ untranspose) (transpose (modвҷӯ P))
    пјқвҹЁ вҷӯ-вҲҳ _ untranspose (transpose (modвҷӯ P)) вҹ©
       вҷӯ-map (precomp _  (postcomp _ Пғ)) (вҷӯ-map untranspose (transpose (modвҷӯ P)))
    пјқвҹЁ ap (вҷӯ-map _) (is-tiny.Оө (modвҷӯ P)) вҹ©
      вҷӯ-map (precomp _ (postcomp I Пғ)) (modвҷӯ P) вҲҺ))

  untranspose-naturality
    : вҲҖ {@вҷӯ рқ“Ө рқ“Ө' рқ“Ҙ} {@вҷӯ О“ : Type рқ“Ө} {@вҷӯ О” : Type рқ“Ө'} {@вҷӯ A : Type рқ“Ҙ}
       вҶ’ (Пғ : О” вҶ’ О“)
       вҶ’ (f : О“ вҶ’ вҲҡ A)
       вҶ’ untranspose (f вҲҳ Пғ) пјқ untranspose f вҲҳ postcomp _ Пғ
  untranspose-naturality Пғ f = refl

  expвҠЈвҲҡ : вҲҖ {@вҷӯ рқ“Ө рқ“Ҙ} {@вҷӯ A : Type рқ“Ө} {@вҷӯ B : Type рқ“Ҙ}
          вҶ’ вҹЁвҷӯ| ((I вҶ’ A) вҶ’ B) вҹ© вүғ вҹЁвҷӯ| (A вҶ’ вҲҡ B) вҹ©
  expвҠЈвҲҡ ._вүғ_.fwd = _
  expвҠЈвҲҡ ._вүғ_.has-is-eqv = is-equivвҒ»В№ is-tiny-str
}
%```
}

\subtree{
\title{Functoriality of the amazing right adjoint}
\taxon{Lemma}

%```agda
\agda{
  вҲҡвӮҒ : вҲҖ {@вҷӯ рқ“Ө рқ“Ҙ} {@вҷӯ A : Type рқ“Ө} {@вҷӯ B : Type рқ“Ҙ} вҶ’ вҹЁвҷӯ| (A вҶ’ B) вҹ© вҶ’ вҹЁвҷӯ| (вҲҡ A вҶ’ вҲҡ B)вҹ©
  вҲҡвӮҒ {B = B} = transpose вҲҳ вҷӯ-map (precomp B вҲҡОө)

  вҲҡвӮҒ-id : вҲҖ {@вҷӯ рқ“Ө} {@вҷӯ A : Type рқ“Ө} вҶ’ вҲҡвӮҒ (modвҷӯ id) пјқ modвҷӯ (id {A = вҲҡ A})
  вҲҡвӮҒ-id = sym (transpose-unique' refl)


  вҲҡвӮҒ-nat : вҲҖ {@вҷӯ рқ“Ө рқ“Ҙ рқ“Ҙ'} {@вҷӯ О“ : Type рқ“Ө} {@вҷӯ A : Type рқ“Ҙ} {@вҷӯ B : Type рқ“Ҙ'}
          вҶ’ (f : вҹЁвҷӯ| (B вҶ’ A)вҹ©)
          вҶ’ untranspose {О“ = О“} {A} вҲҳ postcomp _ (Оөвҷӯ (вҲҡвӮҒ f))
          пјқ postcomp _ (Оөвҷӯ f) вҲҳ untranspose
  вҲҡвӮҒ-nat {О“ = О“} {A} (modвҷӯ f)
    =     untranspose вҲҳ postcomp О“ (Оөвҷӯ (вҲҡвӮҒ (modвҷӯ f)))
    пјқвҹЁвҹ©
          untranspose вҲҳ postcomp О“ (Оөвҷӯ (transpose (вҷӯ-map (precomp _ вҲҡОө) (modвҷӯ f))))
    пјқвҹЁвҹ©
          (О» x вҶ’ untranspose (Оөвҷӯ (transpose (modвҷӯ (f вҲҳ вҲҡОө))) вҲҳ x))
    пјқвҹЁвҹ©
         postcomp _ (untranspose (Оөвҷӯ (transpose (modвҷӯ (f вҲҳ вҲҡОө))))) вҲҳ postcomp I
    пјқвҹЁ ap (_вҲҳ postcomp I)
           (ap (postcomp _) (sym (Оөвҷӯ-natural (transpose (modвҷӯ (f вҲҳ вҲҡОө)))) )) вҹ©
         postcomp _ (Оөвҷӯ (вҷӯ-map untranspose (transpose (modвҷӯ (f вҲҳ вҲҡОө)))))
       вҲҳ postcomp I
    пјқвҹЁ ap (_вҲҳ postcomp I) (ap (postcomp _) (ap Оөвҷӯ (is-tiny.Оө (modвҷӯ (f вҲҳ вҲҡОө))))) вҹ©
          postcomp _ (f вҲҳ вҲҡОө) вҲҳ postcomp I
    пјқвҹЁвҹ©
          postcomp (I вҶ’ _) f вҲҳ untranspose
    вҲҺ

  вҷӯ-map' : вҲҖ {@вҷӯ рқ“Ө рқ“Ҙ} {@вҷӯ A : Type рқ“Ө} {@вҷӯ B : Type рқ“Ҙ}
             (f : вҹЁвҷӯ| (A вҶ’ B)вҹ©) вҶ’ вҹЁвҷӯ| A вҹ© вҶ’ вҹЁвҷӯ| B вҹ©
  вҷӯ-map' (modвҷӯ f) = вҷӯ-map f

  _вҲҳвҷӯ_ : вҲҖ {@вҷӯ рқ“Ө рқ“Ҙ рқ“Ұ} {@вҷӯ A : Type рқ“Ө} {@вҷӯ B : Type рқ“Ҙ} {@вҷӯ C : Type рқ“Ұ}
           (f : вҹЁвҷӯ| (B вҶ’ C) вҹ©) (g : вҹЁвҷӯ| (A вҶ’ B)вҹ©) вҶ’ вҹЁвҷӯ| (A вҶ’ C)вҹ©
  _вҲҳвҷӯ_ f = вҷӯ-map' (вҷӯ-map (postcomp _) f)

  thing1 : вҲҖ {@вҷӯ рқ“Ө рқ“Ҙ} {@вҷӯ A : Type рқ“Ө} {@вҷӯ B : Type рқ“Ҙ}
           вҶ’ (_вҲҳвҷӯ_ (modвҷӯ вҲҡОө)) ~ вҷӯ-map {B = A вҶ’ B} (postcomp A вҲҡОө)
  thing1 (modвҷӯ x) = refl

  вҷӯ-map-вҲҳ
    : вҲҖ {@вҷӯ рқ“Ө рқ“Ҙ рқ“Ұ} {@вҷӯ A : Type рқ“Ө} {@вҷӯ B : Type рқ“Ҙ} {@вҷӯ C : Type рқ“Ұ}
        (@вҷӯ f : B вҶ’ C) (@вҷӯ g : A вҶ’ B) вҶ’ вҷӯ-map (f вҲҳ g) ~ вҷӯ-map f вҲҳ вҷӯ-map g
  вҷӯ-map-вҲҳ f g (modвҷӯ a) = refl

  вҷӯ-map-вҲҳвҷӯ
    : вҲҖ {@вҷӯ рқ“Ө рқ“Ҙ рқ“Ұ} {@вҷӯ A : Type рқ“Ө} {@вҷӯ B : Type рқ“Ҙ} {@вҷӯ C : Type рқ“Ұ}
        (f : вҹЁвҷӯ| (B вҶ’ C)вҹ©) (g : вҹЁвҷӯ| (A вҶ’ B)вҹ©)
      вҶ’ вҷӯ-map' (f вҲҳвҷӯ g) ~ вҷӯ-map' f вҲҳ вҷӯ-map' g
  вҷӯ-map-вҲҳвҷӯ (modвҷӯ f) (modвҷӯ g) (modвҷӯ a) = refl

  -- вҲҡвӮҒ-вҲҳ : вҲҖ {@вҷӯ рқ“Ө рқ“Ҙ рқ“Ұ} {@вҷӯ A : Type рқ“Ө} {@вҷӯ B : Type рқ“Ҙ} {@вҷӯ C : Type рқ“Ұ}
  --          {f : вҹЁвҷӯ| (B вҶ’ C) вҹ©} {g : вҹЁвҷӯ| (A вҶ’ B)вҹ©}
  --          вҶ’ вҲҡвӮҒ (f вҲҳвҷӯ g) пјқ вҲҡвӮҒ f вҲҳвҷӯ вҲҡвӮҒ g
  -- вҲҡвӮҒ-вҲҳ {f = fвҷӯ}{gвҷӯ}
  --   =    вҲҡвӮҒ (fвҷӯ вҲҳвҷӯ gвҷӯ)
  --   пјқвҹЁвҹ©
  --        transpose (вҷӯ-map (precomp _ вҲҡОө) (fвҷӯ вҲҳвҷӯ gвҷӯ))
  --   пјқвҹЁвҹ©
  --        transpose (вҷӯ-map (precomp _ вҲҡОө) (вҷӯ-map' (вҷӯ-map (postcomp _) fвҷӯ) gвҷӯ))
  --   пјқвҹЁ sym (ap transpose (вҷӯ-map-вҲҳвҷӯ (modвҷӯ (precomp _ вҲҡОө)) (вҷӯ-map (postcomp _) fвҷӯ) gвҷӯ)) вҹ©
  --        transpose (вҷӯ-map' (modвҷӯ (precomp _ вҲҡОө) вҲҳвҷӯ вҷӯ-map (postcomp _) fвҷӯ) gвҷӯ)
  --   пјқвҹЁ {!!} вҹ©
  --        вҷӯ-map' (вҷӯ-map (postcomp _) (вҲҡвӮҒ fвҷӯ)) (вҲҡвӮҒ gвҷӯ)
  --   пјқвҹЁвҹ©
  --        (вҲҡвӮҒ fвҷӯ вҲҳвҷӯ вҲҡвӮҒ gвҷӯ)
  --   вҲҺ

  opaque
    вҲҡОө-nat
      : вҲҖ {@вҷӯ рқ“Ө рқ“Ҙ} {@вҷӯ О“ : Type рқ“Ө} {@вҷӯ A : Type рқ“Ҙ}
          {@вҷӯ f : О“ вҶ’ A}
        вҶ’ вҷӯ-map' (modвҷӯ вҲҡОө) вҲҳ вҷӯ-map' (вҷӯ-map (postcomp I) (вҲҡвӮҒ (modвҷӯ f)))
        ~ вҷӯ-map f вҲҳ вҷӯ-map вҲҡОө
    вҲҡОө-nat {f = f}
      = вҷӯ-map' (modвҷӯ вҲҡОө) вҲҳ вҷӯ-map' (вҷӯ-map (postcomp I) (вҲҡвӮҒ (modвҷӯ f)))
      ~вҹЁ вҷӯ-map-вҲҳвҷӯ (modвҷӯ вҲҡОө) (вҷӯ-map (postcomp I) (вҲҡвӮҒ (modвҷӯ f))) ~вҒ»В№ вҹ©
        вҷӯ-map' (modвҷӯ вҲҡОө вҲҳвҷӯ вҷӯ-map (postcomp I) (вҲҡвӮҒ (modвҷӯ f)))
      ~вҹЁвҹ©
        вҷӯ-map' (((modвҷӯ вҲҡОө вҲҳвҷӯ_) вҲҳ вҷӯ-map (postcomp I)) (вҲҡвӮҒ (modвҷӯ f)))
      ~вҹЁ happly (ap вҷӯ-map'
                ( happly (ap (_вҲҳ вҷӯ-map (postcomp I)) (funextвҶ’ thing1)) (вҲҡвӮҒ (modвҷӯ f))
                вҲҷ sym (вҷӯ-map-вҲҳ (postcomp _ вҲҡОө) (postcomp I) (вҲҡвӮҒ (modвҷӯ f))))) вҹ©
        вҷӯ-map' (вҷӯ-map (postcomp _ вҲҡОө вҲҳ postcomp I) (вҲҡвӮҒ (modвҷӯ f)))
      ~вҹЁ happly (ap вҷӯ-map' (is-equiv.Оө is-tiny-str (modвҷӯ (f вҲҳ вҲҡОө)))) вҹ©
        вҷӯ-map' (modвҷӯ (f вҲҳ вҲҡОө))
      ~вҹЁвҹ©
        вҷӯ-map (f вҲҳ вҲҡОө)
      ~вҹЁ вҷӯ-map-вҲҳ f вҲҡОө вҹ©
        вҷӯ-map f вҲҳ вҷӯ-map вҲҡОө
      ~вҲҺ

  вҲҡОө-naturality-square
    : вҲҖ {@вҷӯ рқ“Ө рқ“Ҙ} {@вҷӯ О“ : Type рқ“Ө} {@вҷӯ A : Type рқ“Ҙ}
        {@вҷӯ f : О“ вҶ’ A}
      вҶ’ Arrow-map (вҷӯ-map' (вҷӯ-map (postcomp I) (вҲҡвӮҒ (modвҷӯ f)))) (вҷӯ-map f)
  вҲҡОө-naturality-square .Arrow-О .top = вҷӯ-map вҲҡОө
  вҲҡОө-naturality-square .Arrow-О .bot = вҷӯ-map вҲҡОө
  вҲҡОө-naturality-square {f = f} .Arrow-О .comm = вҲҡОө-nat
}
%```
}

\subtree{
\title{The amazing right adjoint preserves limits}
\taxon{Lemma}

%```agda
\agda{
  вҲҡ1-is-single : is-singleton (вҲҡ рқҹҷ)
  вҲҡ1-is-single = is-singleвҶҗequiv-to-single
    (mkвүғ _ (types-separate {f = вҲҡОө вҲҳ const _ _} lemma) eвҒ»В№)
    рқҹҷ-is-singleton where
    lemma : вҲҖ {@вҷӯ рқ“Ұ} {@вҷӯ X : Type рқ“Ұ} вҶ’ is-equiv (вҷӯ-map (postcomp X _))
    lemma
      = homotopy-is-equiv
          {f = вҷӯ-map (О» _ _ вҶ’ tt) вҲҳ (вҷӯ-map (postcomp _ вҲҡОө вҲҳ postcomp I)) }
          (О» a вҶ’ is-propвҶҗis-single (вҷӯ-is-single single!) _ _)
          (is-equiv-вҲҳ {f = вҷӯ-map (О» _ _ вҶ’ tt)}
            (вҷӯ-map-is-equiv
              (is-equivвҶҗsingle-to-prop single! (О» _ _ вҶ’ prop!) _))
            is-tiny-str)

  instance
    вҲҡрқҹҷ-Is-truncated : вҲҖ {n} вҶ’ Is-truncated n (вҲҡ рқҹҷ)
    вҲҡрқҹҷ-Is-truncated
      = truncation-instance 0 (is-truncatedвҶҗis-singleton вҲҡ1-is-single)

  вҲҡ-is-single' : вҲҖ {@вҷӯ рқ“Ө} {@вҷӯ A : Type рқ“Ө}
                вҶ’ @вҷӯ is-singleton A вҶ’ is-singleton (вҲҡ A)
  вҲҡ-is-single' {A = A} as
    = is-singleвҶҗequiv-to-single
        (mkвүғ _ (types-separate {f = вҲҡОө вҲҳ const _ _} lemma) eвҒ»В№)
        as where
    instance
      @вҷӯ _ : вҲҖ {n} вҶ’ Is-truncated n A
      _ = truncation-instance 0 (is-truncatedвҶҗis-singleton as)

    lemma : вҲҖ {@вҷӯ рқ“Ұ} {@вҷӯ X : Type рқ“Ұ}
            вҶ’ is-equiv (вҷӯ-map (postcomp X (вҲҡОө вҲҳ const _ _)))
    lemma
      = homotopy-is-equiv
          {f = вҷӯ-map (О» _ _ вҶ’ as .centre) вҲҳ (вҷӯ-map (postcomp _ вҲҡОө вҲҳ postcomp I))}
          (О» a вҶ’ is-propвҶҗis-single (вҷӯ-is-single single!) _ _)
          (is-equiv-вҲҳ
            (вҷӯ-map-is-equiv (is-equivвҶҗsingle-to-prop single! (О» _ _ вҶ’ prop!) _))
            is-tiny-str)

  вҲҡ-is-single : вҲҖ {@вҷӯ рқ“Ө} {@вҷӯ A : Type рқ“Ө}
                вҶ’ is-singleton A вҶ’ is-singleton (вҲҡ A)
  вҲҡ-is-single {A = A} as
    = вҷӯ-ind (О» _ вҶ’ is-singleton (вҲҡ A))
            (О» as' вҶ’ вҲҡ-is-single' as')
            (is-equiv.bwd (prop-is-disc is-single-is-prop) as)

  вҲҡ-is-prop : вҲҖ {@вҷӯ рқ“Ө} {@вҷӯ A : Type рқ“Ө} вҶ’ @вҷӯ is-prop A вҶ’ is-prop (вҲҡ A)
  вҲҡ-is-prop x = is-propвҶҗis-single-if-inhabited
    (вҲҡОө вҲҳ const _ _
    вҲҳ Оөвҷӯ (transpose (modвҷӯ О» a вҶ’ вҲҡ-is-single (mk-singl (вҲҡОө a) (x _)))))

  global-вҲҡ-pres-Г—
    : вҲҖ {@вҷӯ рқ“Ө рқ“Ҙ рқ“Ұ} {@вҷӯ О“ : Type рқ“Ө} {@вҷӯ A : Type рқ“Ҙ} {@вҷӯ B : Type рқ“Ұ}
      вҶ’ вҹЁвҷӯ| (О“ вҶ’ вҲҡ A Г— вҲҡ B)вҹ© вүғ вҹЁвҷӯ| (О“ вҶ’ вҲҡ(A Г— B))вҹ©
  global-вҲҡ-pres-Г— {О“ = О“}{A}{B}
    = вҹЁвҷӯ| (О“ вҶ’ вҲҡ A Г— вҲҡ B) вҹ©                    вүғвҹЁ вҷӯвүғ (ОЈ-О -swapвүғ (О» _ вҶ’ вҲҡ A) (О» _ _ вҶ’ вҲҡ B)) вҹ©
      вҹЁвҷӯ| (О“ вҶ’ вҲҡ A) Г— (О“ вҶ’ вҲҡ B)вҹ©               вүғвҹЁ вҷӯ-pres-Г— вҹ©
      вҹЁвҷӯ| (О“ вҶ’ вҲҡ A)вҹ© Г— вҹЁвҷӯ| (О“ вҶ’ вҲҡ B) вҹ©         вүғвҹЁ (expвҠЈвҲҡ Г—вүғ expвҠЈвҲҡ) eвҒ»В№ вҹ©
      вҹЁвҷӯ| ((I вҶ’ О“) вҶ’ A)вҹ© Г— вҹЁвҷӯ| ((I вҶ’ О“) вҶ’ B) вҹ© вүғвҹЁ вҷӯ-pres-Г— eвҒ»В№ вҹ©
      вҹЁвҷӯ| (((I вҶ’ О“) вҶ’ A) Г— ((I вҶ’ О“) вҶ’ B)) вҹ©    вүғвҹЁ вҷӯвүғ (ОЈ-О -swapвүғ (О» _ вҶ’ A) (О» _ _ вҶ’ B)) eвҒ»В№ вҹ©
      вҹЁвҷӯ| ((I вҶ’ О“) вҶ’ A Г— B) вҹ©                  вүғвҹЁ expвҠЈвҲҡ вҹ©
      вҹЁвҷӯ| (О“ вҶ’ вҲҡ (A Г— B)) вҹ©                    вүғвҲҺ

  pack-вҲҡГ—
    : вҲҖ {@вҷӯ рқ“Ө рқ“Ҙ} {@вҷӯ A : Type рқ“Ө} {@вҷӯ B : Type рқ“Ҙ}
      вҶ’ (вҲҡ A Г— вҲҡ B) вҶ’ вҲҡ(A Г— B)
  pack-вҲҡГ— = Оөвҷӯ (global-вҲҡ-pres-Г— ._вүғ_.fwd (modвҷӯ id))

  unpack-вҲҡГ—
    : вҲҖ {@вҷӯ рқ“Ө рқ“Ҙ} {@вҷӯ A : Type рқ“Ө}{@вҷӯ B : Type рқ“Ҙ}
      вҶ’ вҲҡ(A Г— B) вҶ’ вҲҡ A Г— вҲҡ B
  unpack-вҲҡГ— = Оөвҷӯ (_вүғ_.bwd global-вҲҡ-pres-Г— (modвҷӯ id))
}
%```
}

\subtree{
\title{The dependent amazing right adjoint}

%```agda
\agda{
module DependentвҲҡ {@вҷӯ рқ“ҳ} (@вҷӯ I : Type рқ“ҳ)
            (@вҷӯ вҲҡ : вҲҖ {@вҷӯ рқ“Ө} вҶ’ @вҷӯ Type рқ“Ө вҶ’ Type рқ“Ө)
            (@вҷӯ вҲҡОө : вҲҖ {@вҷӯ рқ“Ө} {@вҷӯ A : Type рқ“Ө} вҶ’ (I вҶ’ вҲҡ A) вҶ’ A)
            (@вҷӯ is-tiny-str : вҲҖ {@вҷӯ рқ“Ө} {@вҷӯ A : Type рқ“Ө}
                              вҶ’ is-tiny-structure I A (вҲҡ A) вҲҡОө)
            (@вҷӯ types-separate : вҲҖ {@вҷӯ рқ“Ө рқ“Ҙ} {@вҷӯ A : Type рқ“Ө} {@вҷӯ B : Type рқ“Ҙ}
                                   {@вҷӯ f : A вҶ’ B} вҶ’ Types-separate f)
            (@вҷӯ prop-is-disc : вҲҖ {@вҷӯ рқ“Ө} {@вҷӯ A : Type рқ“Ө}
                               вҶ’ is-prop A вҶ’ is-вҷӯ-discrete A) where
  open Tiny I вҲҡ вҲҡОө is-tiny-str types-separate prop-is-disc

  private
    вҲҡTypeвҲҷ-ПҖ : вҲҖ {@вҷӯ рқ“Ө} вҶ’ вҹЁвҷӯ| (вҲҡ(ОЈ (Type рқ“Ө) id) вҶ’ вҲҡ(Type рқ“Ө)) вҹ©
    вҲҡTypeвҲҷ-ПҖ = вҲҡвӮҒ (modвҷӯ (TypeвҲҷ-ПҖ _))

  classify-вҲҡ : вҲҖ {@вҷӯ рқ“Ө} вҶ’ вҲҡ(Type рқ“Ө) вҶ’ Type (lsuc рқ“Ө)
  classify-вҲҡ
    = Type-is-universal.arrow-map {f = Оөвҷӯ (вҲҡTypeвҲҷ-ПҖ)}
                                  (О» _ вҶ’ self-is-small) .Arrow-map.bot

  вҲҡбөҲ : вҲҖ {@вҷӯ рқ“Ө рқ“Ҙ} {@вҷӯ О“ : Type рқ“Ө} вҶ’ @вҷӯ ((I вҶ’ О“) вҶ’ Type рқ“Ҙ) вҶ’ О“ вҶ’ Type (lsuc рқ“Ҙ)
  вҲҡбөҲ A = classify-вҲҡ вҲҳ Оөвҷӯ (transpose (modвҷӯ A))

  {-# INLINE вҲҡбөҲ #-}

  opaque
    transpose-liftвҷӯ : вҲҖ {@вҷӯ рқ“Ө рқ“Ҙ} {@вҷӯ О“ : Type рқ“Ө} {@вҷӯ A : (I вҶ’ О“) вҶ’ Type рқ“Ҙ}
           вҶ’ вҹЁвҷӯ| Lift (TypeвҲҷ-ПҖ рқ“Ҙ) A вҹ©
           вүғ вҹЁвҷӯ| Lift (Оөвҷӯ (вҲҡTypeвҲҷ-ПҖ {рқ“Ҙ})) (Оөвҷӯ (transpose (modвҷӯ A))) вҹ©
    transpose-liftвҷӯ {рқ“Ө}{рқ“Ҙ}{О“}{A}
      =   вҹЁвҷӯ| Lift (TypeвҲҷ-ПҖ рқ“Ҙ) A вҹ©
      вүғвҹЁ вҷӯ-commОЈ _ eвҒ»В№ вҹ©
          (ОЈ[вҷӯ l вҲ¶ ((I вҶ’ О“) вҶ’ TypeвҲҷ рқ“Ҙ) ] вҹЁвҷӯ| fst вҲҳ l пјқ A  вҹ©)
      вүғвҹЁ ОЈ-ap-вүғ-fst-bwd expвҠЈвҲҡ eвҒ»В№ вҹ©
         ОЈ вҹЁвҷӯ| (О“ вҶ’ вҲҡ (TypeвҲҷ рқ“Ҙ)) вҹ©
          (вҷӯ-ind _ (О» (@вҷӯ l) вҶ’ вҹЁвҷӯ| fst вҲҳ l пјқ A вҹ©) вҲҳ вҷӯ-map untranspose)
      вүғвҹЁ ОЈ-ap-вүғ (О» {(modвҷӯ l) вҶ’ idequiv}) вҹ©
          (ОЈ[вҷӯ l вҲ¶ (О“ вҶ’ вҲҡ (TypeвҲҷ рқ“Ҙ)) ] вҹЁвҷӯ| fst вҲҳ untranspose l пјқ A вҹ©)
      вүғвҹЁ ОЈ-ap-вүғ (О» {(modвҷӯ l) вҶ’ mkвүғ (f l) (feq l)}) вҹ©
          (ОЈ[вҷӯ l вҲ¶ (О“ вҶ’ вҲҡ (TypeвҲҷ рқ“Ҙ)) ]
             вҹЁвҷӯ| (Оөвҷӯ вҲҡTypeвҲҷ-ПҖ) вҲҳ l пјқ Оөвҷӯ (transpose (modвҷӯ A)) вҹ©)
      вүғвҹЁ вҷӯ-commОЈ _ вҹ©
          вҹЁвҷӯ| Lift (Оөвҷӯ вҲҡTypeвҲҷ-ПҖ) (Оөвҷӯ (transpose (modвҷӯ A))) вҹ©
      вүғвҲҺ where
      @вҷӯ f : вҲҖ (@вҷӯ l : О“ вҶ’ вҲҡ (TypeвҲҷ рқ“Ҙ))
             вҶ’ вҹЁвҷӯ| fst вҲҳ untranspose l пјқ A вҹ©
             вҶ’ вҹЁвҷӯ| Оөвҷӯ вҲҡTypeвҲҷ-ПҖ вҲҳ l пјқ Оөвҷӯ (transpose (modвҷӯ A)) вҹ©
      f l  = transpose-unique вҲҳ вҷӯ-map ((happly (вҲҡвӮҒ-nat (modвҷӯ fst)) l вҲҷ_))

      @вҷӯ feq : вҲҖ (@вҷӯ l) вҶ’ is-equiv (f l)
      feq l = is-equiv-вҲҳ
        transpose-unique-is-equiv
        (вҷӯ-map-is-equiv (вҲҷ-is-equiv (happly (вҲҡвӮҒ-nat (modвҷӯ fst)) l)))

  О вҶҗlift : вҲҖ {@вҷӯ рқ“Ө рқ“Ҙ} {@вҷӯ О“ : Type рқ“Ө} {@вҷӯ A : (I вҶ’ О“) вҶ’ Type рқ“Ҙ}
         вҶ’ Lift (Оөвҷӯ (вҲҡTypeвҲҷ-ПҖ {рқ“Ҙ})) (Оөвҷӯ (transpose (modвҷӯ A)))
         вҶ’ О  О“ (вҲҡбөҲ A)
  О вҶҗlift {A = A} = universal-section (Оөвҷӯ (transpose (modвҷӯ A)))
                                     (О» _ вҶ’ self-is-small)

  opaque
    rintro
      : вҲҖ {@вҷӯ рқ“Ө рқ“Ҙ} {@вҷӯ О“ : Type рқ“Ө} {@вҷӯ A : (I вҶ’ О“) вҶ’ Type рқ“Ҙ}
        вҶ’ вҹЁвҷӯ| О  (I вҶ’ О“) A вҹ©
        вҶ’ вҹЁвҷӯ| О  О“ (вҲҡбөҲ A) вҹ©
    rintro {A = A}
      = вҷӯ-map О вҶҗlift вҲҳ transpose-liftвҷӯ ._вүғ_.fwd вҲҳ вҷӯ-map (extensionвҶҗО  A)

    rintro-is-equiv
      : вҲҖ {@вҷӯ рқ“Ө рқ“Ҙ} {@вҷӯ О“ : Type рқ“Ө} {@вҷӯ A : (I вҶ’ О“) вҶ’ Type рқ“Ҙ}
        вҶ’ is-equiv (rintro {A = A})
    rintro-is-equiv
      = is-equiv-вҲҳ
          (вҷӯ-map-is-equiv (universal-section-is-equiv _ (О» _ вҶ’ self-is-small)))
          (is-equiv-вҲҳ
            (transpose-liftвҷӯ ._вүғ_.has-is-eqv)
            (вҷӯ-map-is-equiv (extensionвҶҗО -is-equiv _)))


    relim
      : вҲҖ {@вҷӯ рқ“Ө рқ“Ҙ} {@вҷӯ О“ : Type рқ“Ө} {@вҷӯ A : (I вҶ’ О“) вҶ’ Type рқ“Ҙ}
        вҶ’ вҹЁвҷӯ| О  О“ (вҲҡбөҲ A) вҹ©
        вҶ’ вҹЁвҷӯ| О  (I вҶ’ О“) A вҹ©
    relim = is-equiv.bwd rintro-is-equiv

    вҲҡбөҲ-naturalityвҶ’
      : вҲҖ {@вҷӯ рқ“Ө рқ“Ө' рқ“Ҙ} {@вҷӯ О“ : Type рқ“Ө} {@вҷӯ О” : Type рқ“Ө'}
          (@вҷӯ A : (I вҶ’ О“) вҶ’ Type рқ“Ҙ)
        вҶ’ (@вҷӯ Пғ : О” вҶ’ О“)
        вҶ’ вҲҖ x вҶ’ (вҲҡбөҲ A вҲҳ Пғ) x вҶ’ (вҲҡбөҲ (A вҲҳ postcomp I Пғ)) x
    вҲҡбөҲ-naturalityвҶ’ A Пғ x = tr
      classify-вҲҡ
      (sym (happly (ap Оөвҷӯ (transpose-naturality (modвҷӯ A) Пғ)
                   вҲҷ Оөвҷӯ-natural (transpose (modвҷӯ A)))
                   x))

    вҲҡбөҲ-naturalityвҶҗ
      : вҲҖ {@вҷӯ рқ“Ө рқ“Ө' рқ“Ҙ} {@вҷӯ О“ : Type рқ“Ө} {@вҷӯ О” : Type рқ“Ө'}
          (@вҷӯ A : (I вҶ’ О“) вҶ’ Type рқ“Ҙ)
        вҶ’ (@вҷӯ Пғ : О” вҶ’ О“)
        вҶ’ вҲҖ x вҶ’ (вҲҡбөҲ (A вҲҳ postcomp I Пғ)) x вҶ’ (вҲҡбөҲ A вҲҳ Пғ) x
    вҲҡбөҲ-naturalityвҶҗ A Пғ x = tr
      classify-вҲҡ
      (happly (ap Оөвҷӯ (transpose-naturality (modвҷӯ A) Пғ)
                   вҲҷ Оөвҷӯ-natural (transpose (modвҷӯ A)))
                   x)

    вҲҡбөҲ-naturality-is-equiv'
      : вҲҖ {@вҷӯ рқ“Ө рқ“Ө' рқ“Ҙ} {@вҷӯ О“ : Type рқ“Ө} {@вҷӯ О” : Type рқ“Ө'} {@вҷӯ A : (I вҶ’ О“) вҶ’ Type рқ“Ҙ}
        вҶ’ (@вҷӯ Пғ : О” вҶ’ О“)
        вҶ’ is-fibrewise-equiv (вҲҡбөҲ-naturalityвҶҗ A Пғ)
    вҲҡбөҲ-naturality-is-equiv' Пғ a = tr-is-equiv _

    вҲҡбөҲ-naturality-is-equiv
      : вҲҖ {@вҷӯ рқ“Ө рқ“Ө' рқ“Ҙ} {@вҷӯ О“ : Type рқ“Ө} {@вҷӯ О” : Type рқ“Ө'} {@вҷӯ A : (I вҶ’ О“) вҶ’ Type рқ“Ҙ}
        вҶ’ (@вҷӯ Пғ : О” вҶ’ О“)
        вҶ’ is-fibrewise-equiv (вҲҡбөҲ-naturalityвҶ’ A Пғ)
    вҲҡбөҲ-naturality-is-equiv Пғ a = tr-is-equiv _


  -- вҲҡОөбөҲ : вҲҖ {@вҷӯ рқ“Ҙ}  {@вҷӯ B : I вҶ’ Type рқ“Ҙ}
  --       вҶ’ вҲҖ (@вҷӯ i) вҶ’ (О  I (вҲҡбөҲ (B вҲҳ ev i))) вҶ’ B i
  -- вҲҡОөбөҲ i f = {!relim!}

  -- вҲҡбөҲ-is-singleton
  --   : вҲҖ {@вҷӯ рқ“Ө рқ“Ҙ} {@вҷӯ О“ : Type рқ“Ө} {@вҷӯ A : (I вҶ’ О“) вҶ’  Type рқ“Ҙ}
  --     вҶ’ вҹЁвҷӯ| О  _ (is-singleton вҲҳ A) вҹ© вҶ’ вҹЁвҷӯ| О  _ (is-singleton вҲҳ вҲҡбөҲ A)вҹ©
  -- вҲҡбөҲ-is-singleton = {!!}

  -- вҷӯ-is-singleвҶҗequiv-to-single
  --   : вҲҖ {@вҷӯ рқ“Ө рқ“Ҙ} {@вҷӯ О“ : Type рқ“Ө} {@вҷӯ A : О“ вҶ’ Type рқ“Ҙ} {@вҷӯ B : О“ вҶ’ Type рқ“Ҙ}
  --     вҶ’ вҹЁвҷӯ| (вҲҖ g вҶ’ A g вүғ B g) вҹ©
  --     вҶ’ вҹЁвҷӯ| О  _ (is-singleton вҲҳ A)вҹ© вҶ’ вҹЁвҷӯ| О  _ (is-singleton вҲҳ B)вҹ©
  -- вҷӯ-is-singleвҶҗequiv-to-single (modвҷӯ e) (modвҷӯ x)
  --   = modвҷӯ О» a вҶ’ is-singleвҶҗequiv-to-single (e a) (x a)
}
%```
}

\subtree{
\title{Global points of the amazing right adjoint}

%```agda
\agda{
module Global {@вҷӯ рқ“ҳ} (@вҷӯ I : Type рқ“ҳ)
            (@вҷӯ вҲҡ : вҲҖ {@вҷӯ рқ“Ө} вҶ’ @вҷӯ Type рқ“Ө вҶ’ Type рқ“Ө)
            (@вҷӯ вҲҡОө : вҲҖ {@вҷӯ рқ“Ө} {@вҷӯ A : Type рқ“Ө} вҶ’ (I вҶ’ вҲҡ A) вҶ’ A)
            (@вҷӯ is-tiny-str : вҲҖ {@вҷӯ рқ“Ө} {@вҷӯ A : Type рқ“Ө}
                              вҶ’ is-tiny-structure I A (вҲҡ A) вҲҡОө)
            (@вҷӯ types-separate : вҲҖ {@вҷӯ рқ“Ө рқ“Ҙ} {@вҷӯ A : Type рқ“Ө} {@вҷӯ B : Type рқ“Ҙ}
                                   {@вҷӯ f : A вҶ’ B} вҶ’ Types-separate f)
            (@вҷӯ prop-is-disc : вҲҖ {@вҷӯ рқ“Ө} {@вҷӯ A : Type рқ“Ө}
                               вҶ’ is-prop A вҶ’ is-вҷӯ-discrete A)
            (@вҷӯ вҲҡprop-is-set : вҲҖ {@вҷӯ рқ“Ө} вҶ’ is-set (вҲҡ (Prop-U рқ“Ө))) where
  open Tiny I вҲҡ вҲҡОө is-tiny-str types-separate prop-is-disc
  open DependentвҲҡ I вҲҡ вҲҡОө is-tiny-str types-separate prop-is-disc

  lemm : вҲҖ {@вҷӯ рқ“Ө} {@вҷӯ A : Type рқ“Ө} вҶ’ вҹЁвҷӯ| A вҹ© вҶ’ вҹЁвҷӯ| вҲҡ A вҹ©
  lemm (modвҷӯ a) = вҷӯ-map (ev tt) (transpose (modвҷӯ (const _ _ a)))

  global-вҲҡ-point : вҲҖ {@вҷӯ рқ“Ө} {@вҷӯ A : Type рқ“Ө} вҶ’ @вҷӯ A вҶ’ вҲҡ A
  global-вҲҡ-point a = Оөвҷӯ (lemm (modвҷӯ a))

  global-вҠӨ : вҲҖ (@вҷӯ рқ“Ө) вҶ’ вҲҡ (Prop-U рқ“Ө)
  global-вҠӨ рқ“Ө = global-вҲҡ-point (ULift рқ“Ө рқҹҷ , trunc!)

  prop-class : вҲҖ {@вҷӯ рқ“Ө} вҶ’ рқҹҷ вҶ’ вҲҡ (Prop-U рқ“Ө)
  prop-class = point (global-вҠӨ _)

  classify-вҲҡ-prop : вҲҖ {@вҷӯ рқ“Ө} вҶ’ вҲҡ(Prop-U рқ“Ө) вҶ’ Prop-U (lsuc рқ“Ө)
  classify-вҲҡ-prop x
    = ( fibre prop-class x
      , fibre-is-truncated'
          prop-class x
          trunc!
          (is-truncatedвҶҗis-prop (вҲҡprop-is-set _ _)))
}
%```
}


\date{2025-02-24}
\title{Embeddings}
\import{stt-macros}

\p{Embeddings are the homotopy coherent generalisation of injective functions}

\agda{
module Foundations.Embeddings where

open import Foundations.Universes
open import Foundations.Functions
open import Foundations.Identity
open import Foundations.Homotopy
open import Foundations.CoherentEquivalences
open import Foundations.QuasiEquivalences
open import Foundations.Sigma
open import Foundations.SigmaIdentity
open import Foundations.FibreIdentity
open import Foundations.FibrewiseEquivalences
open import Foundations.FunctionInverses
open import Foundations.IdentityReasoning
open import Foundations.SingletonFibres
open import Foundations.Singletons
open import Foundations.SingletonClosure
open import Foundations.IdentitySystem
}

\subtree[stt-008I]{
\title{Embedding}
\taxon{Definition}

\p{A function #{f : A \to B} is an embedding if #{f^* : x = y \to f(x) = f(y)} is an embedding}

\agda{
is-embedding : вИА {рЭУ§ рЭУ•} {A : Type рЭУ§} {B : Type рЭУ•} (f : A вЖТ B) вЖТ Type (рЭУ§ вКФ рЭУ•)
is-embedding f = вИА {x y} вЖТ is-equiv (ap f {x} {y})

unap
  : вИА {рЭУ§ рЭУ•} {A : Type рЭУ§} {B : Type рЭУ•} {f : A вЖТ B}
    вЖТ is-embedding f вЖТ вИА {x y} вЖТ f x пЉЭ f y вЖТ x пЉЭ y
unap emb = is-equiv.bwd emb

_вЧВemb_
  : вИА {рЭУ§ рЭУ•} {A : Type рЭУ§} {B : Type рЭУ•} {f : A вЖТ B}
    вЖТ is-embedding f вЖТ вИА {рЭУ¶} {C : Type рЭУ¶} {g h : C вЖТ A}
    вЖТ f вИШ g ~ f вИШ h вЖТ g ~ h
(fe вЧВemb h) a = unap fe (h a)

embeddingвЙГ
  : вИА {рЭУ§ рЭУ•} {A : Type рЭУ§} {B : Type рЭУ•}
      {f : A вЖТ B}
    вЖТ is-embedding f
    вЖТ вИА x y
    вЖТ (f x пЉЭ f y)
    вЙГ (x пЉЭ y)
embeddingвЙГ emb _ _ = mkвЙГ (unap emb) (is-equivвБї¬є emb)
}
}

\subtree[stt-006D]{
\taxon{Theorem}
\title{Equivalences are embeddings}

\agda{
is-embeddingвЖРis-equiv
  : вИА {рЭУ§ рЭУ•} {A : Type рЭУ§} {B : Type рЭУ•} {f : A вЖТ B}
    вЖТ is-equiv f вЖТ is-embedding f
is-embeddingвЖРis-equiv {B = B} {f = f} eq {x} {y} = ap-equivвЖРequiv eq

opaque
  unap-equiv
    : вИА {рЭУ§ рЭУ•} {A : Type рЭУ§} {B : Type рЭУ•} {f : A вЖТ B}
      вЖТ is-equiv f вЖТ вИА {x y} вЖТ f x пЉЭ f y вЖТ x пЉЭ y
  unap-equiv eq = unap (is-embeddingвЖРis-equiv eq)

  unap-equiv-is-equiv
    : вИА {рЭУ§ рЭУ•} {A : Type рЭУ§} {B : Type рЭУ•} {f : A вЖТ B}
      вЖТ (fe : is-equiv f) вЖТ вИА {x y} вЖТ is-equiv (unap-equiv fe {x} {y})
  unap-equiv-is-equiv fe = is-equivвБї¬є (is-embeddingвЖРis-equiv fe)

  ap-unap-equiv
    : вИА {рЭУ§ рЭУ•} {A : Type рЭУ§} {B : Type рЭУ•} {f : A вЖТ B} (fe : is-equiv f)
      вЖТ вИА {x y} (p : f x пЉЭ f y) вЖТ ap f (unap-equiv fe p) пЉЭ p
  ap-unap-equiv fe = is-equiv.ќµ (is-embeddingвЖРis-equiv fe)

  unap-ap-equiv
    : вИА {рЭУ§ рЭУ•} {A : Type рЭУ§} {B : Type рЭУ•} {f : A вЖТ B} (fe : is-equiv f)
      вЖТ вИА {x y} (p : x пЉЭ y) вЖТ unap-equiv fe (ap f p) пЉЭ p
  unap-ap-equiv fe = is-equiv.ќЈ (is-embeddingвЖРis-equiv fe)

  unap-refl
    : вИА {рЭУ§ рЭУ•} {A : Type рЭУ§} {B : Type рЭУ•} {f : A вЖТ B}
      вЖТ (fe : is-equiv f) вЖТ вИА {x} вЖТ unap-equiv fe refl пЉЭ refl {a = x}
  unap-refl {f = f} fe
    = unap-equiv {f = ap f} (is-embeddingвЖРis-equiv fe) (ap-unap-equiv fe refl)

  sym-unap-equiv
    : вИА {рЭУ§ рЭУ•} {A : Type рЭУ§} {B : Type рЭУ•} {f : A вЖТ B} (fe : is-equiv f)
        {x y} (p : f x пЉЭ f y)
      вЖТ sym (unap-equiv fe p) пЉЭ unap-equiv fe (sym p)
  sym-unap-equiv {f = f} fe p
    = unap-equiv {f = ap f} (is-embeddingвЖРis-equiv fe)
        (ap-sym f (unap-equiv fe p) вИЩ ap sym (ap-unap-equiv fe p)
        вИЩ sym (ap-unap-equiv fe (sym p)))


infixr 32 _вЧВeqv_
infixl 33 _вЦЄeqv_

_вЧВeqv_
  : вИА {рЭУ§ рЭУ•} {A : Type рЭУ§} {B : Type рЭУ•} {f : A вЖТ B}
    вЖТ is-equiv f вЖТ вИА {рЭУ¶} {C : Type рЭУ¶} {g h : C вЖТ A}
    вЖТ f вИШ g ~ f вИШ h вЖТ g ~ h
_вЧВeqv_ {f = f} fe {g = g} {h} H = (ќЈ ~вБї¬є) вЦЄ g ~вИЩ bwd вЧВ H ~вИЩ ќЈ вЦЄ h
  where open is-equiv fe

_вЦЄeqv_
  : вИА {рЭУ§ рЭУ•} {A : Type рЭУ§} {B : Type рЭУ•} {f : A вЖТ B}
    вЖТ вИА {рЭУ¶} {C : Type рЭУ¶} {g h : B вЖТ C}
    вЖТ g вИШ f ~ h вИШ f вЖТ is-equiv f вЖТ g ~ h
(_вЦЄeqv_) {g = g} {h} H fe
  = (g вЧВ ќµ ~вБї¬є) ~вИЩ H вЦЄ bwd ~вИЩ h вЧВ ќµ where open is-equiv fe
}
}

\subtree[stt-00H1]{
\date{2026-03-10}
\author{fredrikbakke}
\title{A map whose #{\ap} has sections is an embedding}
\taxon{Theorem}

\agda{
is-embeddingвЖРsections-ap
  : {рЭУ§ рЭУ• : Level} {A : Type рЭУ§} {B : Type рЭУ•} {f : A вЖТ B}
  вЖТ ((x y : A) вЖТ section (ap f {x} {y}))
  вЖТ is-embedding f
is-embeddingвЖРsections-ap {A = A} {f = f} s {x} {y}
  = fundamental-Id (ќї z вЖТ f x пЉЭ f z) sing (ќї z вЖТ ap f {x} {z}) y where
  sec-total : section (total-map (ќї z вЖТ ap f {x} {z}))
  sec-total .fst (z , p) = (z , s x z .fst p)
  sec-total .snd (z , p) = ќ£-pathвЖТ (refl , s x z .snd p)

  sing : is-singleton (ќ£[ z вИґ A ] (f x пЉЭ f z))
  sing = is-singleвЖРsection-single
           (total-map (ќї z вЖТ ap f {x} {z}))
           (sec-total)
           (Sing-is-singleton)
}
}

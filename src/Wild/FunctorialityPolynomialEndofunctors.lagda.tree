\date{2026-05-27}
\title{Functoriality of polynomial endofunctors on types}
\import{stt-macros}
\taxon{Module}

\agda{
module Wild.FunctorialityPolynomialEndofunctors where

open import Wild.PolynomialEndofunctors

open import Foundations.Universes
open import Foundations.Sigma
open import Foundations.SigmaIdentity
open import Foundations.Functions
open import Foundations.Identity
open import Foundations.Equivalences
open import Foundations.FibrewiseEquivalences
open import Foundations.SigmaProperties
open import Foundations.TheoremOfChoice
open import Foundations.UnitUP
open import Foundations.Homotopy
open import Axioms.UF
}

\subtree[fre-QW12]{
\taxon{Definition}
\title{Functorial action of polynomial endofunctors}
\author{fredrikbakke}

\agda{
𝑃₀
  : {𝓤 𝓥 𝓦 : Level}
  → 𝑃 𝓤 𝓥 → Type 𝓦 → Type (𝓤 ⊔ 𝓥 ⊔ 𝓦)
𝑃₀ (A ◃ B) X = Σ[ a ∶ A ] (B a → X)

𝑃₁
  : {𝓤 𝓥 𝓦 𝓣 : Level}
  → (P : 𝑃 𝓤 𝓥) {X : Type 𝓦} {Y : Type 𝓣}
  → (X → Y) → 𝑃₀ P X → 𝑃₀ P Y
𝑃₁ P f (a , u) = (a , f ∘ u)

module PolyEndoSyntax where

  ⟦_⟧₀ : {𝓤 𝓥 𝓦 : Level} → 𝑃 𝓤 𝓥 → Type 𝓦 → Type (𝓤 ⊔ 𝓥 ⊔ 𝓦)
  ⟦_⟧₀ = 𝑃₀

  ⟦_⟧₁
    : {𝓤 𝓥 𝓦 𝓣 : Level}
    → (P : 𝑃 𝓤 𝓥) {X : Type 𝓦} {Y : Type 𝓣}
    → (X → Y) → ⟦ P ⟧₀ X → ⟦ P ⟧₀ Y
  ⟦_⟧₁ = 𝑃₁

  infix 1 ⟦_⟧₀ ⟦_⟧₁
}
}

\subtree[fre-QW13]{
\taxon{Proposition}
\title{Functoriality of polynomial endofunctors}
\author{fredrikbakke}

\agda{
𝑃₁-id
  : {𝓤 𝓥 𝓦 : Level}
  → (P : 𝑃 𝓤 𝓥) {X : Type 𝓦}
  → (x : 𝑃₀ P X) → 𝑃₁ P id x ＝ x
𝑃₁-id P = ~refl

𝑃₁-∘
  : {𝓤 𝓥 𝓦 𝓣 𝓢 : Level}
  → (P : 𝑃 𝓤 𝓥) {X : Type 𝓦} {Y : Type 𝓣} {Z : Type 𝓢}
  → (g : Y → Z) (f : X → Y)
  → (x : 𝑃₀ P X) → 𝑃₁ P (g ∘ f) x ＝ 𝑃₁ P g (𝑃₁ P f x)
𝑃₁-∘ P g f = ~refl
}
}

\subtree[fre-QW16]{
\taxon{Proposition}
\title{Computing the action of the identity polynomial endofunctor}
\author{fredrikbakke}

\agda{
id𝑃₀ : {𝓤 : Level} (X : Type 𝓤) → 𝑃₀ id𝑃 X ≃ X
id𝑃₀ X = Σ-𝟙 ∙e unit-UP≃
}
}

\subtree[fre-QW19]{
\taxon{Definition}
\title{The action on sections of polynomial endofunctors}
\author{fredrikbakke}

\agda{
𝑃₁ˢ
  : {𝓤 𝓥 𝓦 𝓣 : Level}
  → (P : 𝑃 𝓤 𝓥) {X : Type 𝓦} (Y : X → Type 𝓣)
  → ((x : X) → Y x) → 𝑃₀ P X → 𝑃₀ P (Σ X Y)
𝑃₁ˢ P Y f = 𝑃₁ P (λ x → x , f x)
}
}

\subtree[fre-QW20]{
\taxon{Lemma}
\title{The action on sections preserves homotopies}
\author{fredrikbakke}

\agda{
𝑃₁ˢ-homotopy
  : {𝓤 𝓥 𝓦 𝓣 : Level}
  → (P : 𝑃 𝓤 𝓥) {X : Type 𝓦} (Y : X → Type 𝓣)
  → {f g : (x : X) → Y x}
  → f ~ g
  → 𝑃₁ˢ P Y f ~ 𝑃₁ˢ P Y g
𝑃₁ˢ-homotopy (A ◃ B) Y H (a , u)
  = Σ-path→ (refl , funext→ (λ b → Σ-path→ (refl , H (u b))))

𝑃₁ˢ-homotopy-refl
  : {𝓤 𝓥 𝓦 𝓣 : Level}
  → (P : 𝑃 𝓤 𝓥) {X : Type 𝓦} (Y : X → Type 𝓣)
  → {f : (x : X) → Y x}
  → (σ : 𝑃₀ P X)
  → 𝑃₁ˢ-homotopy P Y (~refl {f = f}) σ ＝ refl
𝑃₁ˢ-homotopy-refl (A ◃ B) Y (a , u)
  = ap (λ q → Σ-path→ (refl , q)) funext-refl
}
}


\subtree[fre-QW17]{
\taxon{Definition}
\title{Polynomial endofunctors distribute over dependent products}
\author{fredrikbakke}

\agda{
𝑃₀-Π→
  : {𝓤 𝓥 𝓦 𝓣 : Level}
  → (P : 𝑃 𝓤 𝓥) {I : Type 𝓦} (X : I → Type 𝓣)
  → 𝑃₀ P (Π I X) → Π I (𝑃₀ P ∘ X)
𝑃₀-Π→ P X p i = 𝑃₁ P (ev i) p
}
}

\subtree[fre-QW18]{
\taxon{Proposition}
\title{Polynomial endofunctors commute with dependent sums}
\author{fredrikbakke}

\agda{
𝑃₀-Σ≃
  : {𝓤 𝓥 𝓦 𝓣 : Level}
  → (P@(A ◃ B) : 𝑃 𝓤 𝓥) {X : Type 𝓦} (Y : X → Type 𝓣)
  → 𝑃₀ P (Σ X Y)
  ≃ (Σ[ p ∶ 𝑃₀ P X ] ((b : B (p .fst)) → Y (p .snd b)))
𝑃₀-Σ≃ (A ◃ B) {X} Y
  = Σ-snd-≃ (λ a → Σ-Π-swap≃ (λ _ → X) (λ _ → Y)) ∙e Σ-assoc e⁻¹
}
}

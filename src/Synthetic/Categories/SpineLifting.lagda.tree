\subtree[fre-00E4]{
\title{The canonical inclusion of the #{n}-simplex into the #{n}-cube}
\taxon{Definition}

\agda{
□←Δ : ∀ {n} → Δ^ n → □^ n
□←Δ · = _
□←Δ (· :≥: j) = j
□←Δ (x :≥: i :≥: j) = □←Δ (x :≥: i) , j
}
}

\subtree[stt-00E5]{
\taxon{Lemma}
\author{samueltoth}

\p{#{\Delta^{n + 2}} is a retract of #{\square^n \times \Delta^2}}

\p{
We extend the canonical inclusion #{\Delta^n \to \square^n}, to the map that
just forgets the first #{n} inequalities and preserves the latter two. The
retraction is defined as follows:
##{(\bar{i}, j \geq k) : \square^n \times \Delta^2 \mapsto
((\bigvee_{n} i_n \vee j) ≥ ... \ge (i_n \vee j) \ge j \ge k)}
It is a retraction since if #{i_n} were ordered in the first place, then taking
these successive joins would have no effect.
}

\agda{
Δ←□-with-last
  : ∀ {n} → □^ n → (i : Δ¹) → Σ[ x ∶ Δ^ n ] (i ≤ last-Δ x)
Δ←□-with-last {0} x i = · , auto!
Δ←□-with-last {1} x i = · :≥: x ∨ i , ∨-≤-intror auto!
Δ←□-with-last {suc (suc n)} (x , j) i =
  let y = Δ←□-with-last x (j ∨ i)
  in (fst y :≥: j ∨ i) ⦃ snd y ⦄ , ∨-≤-intror auto!

Δ←□ : ∀ {n} → □^ n → Δ¹ → Δ^ n
Δ←□ x i = Δ←□-with-last x i .fst

Δ←□-≤ : ∀ {n} (x : □^ n) i → i ≤ last-Δ (Δ←□ x i)
Δ←□-≤ x i = Δ←□-with-last x i .snd

Δ←□-1 : ∀ {n} (x : □^ n) {i} → (i ＝ i1) → Δ-path (Δ←□ x i) Δ-1
Δ←□-1 {0} x _ = ·
Δ←□-1 {1} x refl = · :≥: (≤-max auto!)
Δ←□-1 {suc (suc n)} (x , i) refl
  = Δ←□-1 {suc n} x (≤-max auto!) :≥: (≤-max auto!)

include-Δ-n+2 : ∀ {n} → Δ^ (n +ℕ 2) → □^ n × Δ²
include-Δ-n+2 (x :≥: i :≥: j) = □←Δ x , (i , j)

ret-Δ-n+2 : ∀ {n} → □^ n × Δ² → Δ^ (n +ℕ 2)
ret-Δ-n+2 (x , (i , j)) = ((Δ←□ x i :≥: i) ⦃ Δ←□-≤ x i ⦄ :≥: j)

□←Δ-ret : ∀ {n} (p : Δ^ n) i ⦃ k : i ≤ last-Δ p ⦄ → Δ-path (Δ←□ (□←Δ p) i) p
□←Δ-ret · i = ·
□←Δ-ret (· :≥: j) i = · :≥: ∨-comm ∙ ≤-max auto!
□←Δ-ret (p :≥: i :≥: j) k
  = □←Δ-ret (p :≥: i) (j ∨ k) ⦃ ∨-UP (auto! , (≤-trans {b = j}auto! auto!)) ⦄
  :≥: (∨-comm ∙ ≤-max auto!)

is-ret-Δ-□ : ∀ {n} → ret-Δ-n+2 {n} ∘ include-Δ-n+2 ~ id
is-ret-Δ-□ (p :≥: i :≥: j) = Δ-ext (□←Δ-ret p i :≥: refl :≥: refl)
}
}

\subtree[fre-AEE2]{
\taxon{Lemma}
\date{2026-02-04}
\author{samueltoth}
\contributor{fredrikbakke}

\p{
For all #{n}, the inclusion #{\Delta^n \vee \Delta^1 \hookrightarrow \Delta^{n+1}}
is inner anodyne.
}

\proof{
We show #{\Delta^n \vee \Delta^1 \hookrightarrow \Delta^{n+1}} is a retraction of
#{\square^{n-1} \times \Lambda^2_1 \to \square^{n-1} \times \Delta^2}, which is
trivially left anodyne by closure of orthogonal maps under products. The
retraction is a pair of squares as follows:

\quiver{
\begin{tikzcd}
	{\Delta^n\vee\Delta^1} && {\square^{n-1}\times\Lambda^2_1} && {\Delta^n\vee\Delta^1} \\
	\\
	{\Delta^{n+1}} && {\square^{n-1}\times\Delta^2} && {\Delta^{n+1}}
	\arrow[hook, from=1-1, to=1-3]
	\arrow[hook, from=1-1, to=3-1]
	\arrow[two heads, from=1-3, to=1-5]
	\arrow[hook, from=1-3, to=3-3]
	\arrow[hook, from=1-5, to=3-5]
	\arrow[hook, from=3-1, to=3-3]
	\arrow[two heads, from=3-3, to=3-5]
\end{tikzcd}
}

\p{\ref{stt-00E5} gives the bottom maps. It is clear that this retraction should
restrict to the appropriate subtypes.}
}

\agda{
spine-incl-factor-1 : ∀ n → Type∗∗.carrier (Wedge∗∗ (Δ∗∗ n) Δ¹∗∗) → Δ^ (suc n)
spine-incl-factor-1 n
  = cogap (mk-cocone (λ x → x :≥: i0) (λ i → (Δ-1 :≥: i) ⦃ Δ-1-≤ {n = n} ⦄)
           λ a → Δ-ext (Δ-refl :≥: refl))

spine-incl-factor-2 : ∀ n → Spine (suc n) → Type∗∗.carrier (Wedge∗∗ (Δ∗∗ n) Δ¹∗∗)
spine-incl-factor-2 0 = ι₂
spine-incl-factor-2 (suc n)
  = map∗∗.hom (Wedge-map∗∗ (Spine-incl∗∗ (suc n)) (id∗∗ Δ¹∗∗))

spine-incl~factors
  : (n : ℕ)
  → spine-incl-factor-1 n ∘ spine-incl-factor-2 n
  ~ Spine-incl {suc n}
spine-incl~factors 0
  = ~refl
spine-incl~factors (suc n)
  = pushout-rec-unique _ _ ~refl ~refl λ _ → prop!

opaque
  fat-spine-lifts
    : ∀ {n} → is-inner-anodyne (spine-incl-factor-1 (suc n))
  fat-spine-lifts {n} f finn
    = left-orthogonal-retraction
        (spine-incl-factor-1 (suc n)) _
        (amap2 n) (amap2-ret n)
        f (incl-mid-inner-anodyne f finn) where
    incl-mid : ∀ n → □^ n × Λ[2,1] → □^ n × Δ²
    incl-mid n = (□^ n) 1⊗ Λ[2,1]-incl

    incl-mid-inner-anodyne : ∀ {n} → is-inner-anodyne (incl-mid n)
    incl-mid-inner-anodyne k = left-orthogonal-× id Λ[2,1]-incl k (id⊥ k)

    amap2 : ∀ n → Arrow-map (spine-incl-factor-1 (suc n)) (incl-mid n)
    amap2 n .Arrow-map.top = cogap
      (mk-cocone
        (λ where (x :≥: i) → (□←Δ x , ι₁ i))
        (λ i → □←Δ Δ-1 , ι₂ i)
        λ a → ×-path→ (refl , glue tt))
    amap2 n .Arrow-map.bot = include-Δ-n+2
    amap2 n .Arrow-map.comm = pushout-ind _
      (mk-coconeᵈ
        (λ where (x :≥: j) → refl)
        ~refl
        λ _ → is-set←is-truncated
                (×-is-truncated (□-is-truncated carrier-is-0-truncated) Δ²-is-0-truncated)
                _ _ _ _)

    amap2-ret : ∀ n → retraction-arrow-map (amap2 n)
    amap2-ret n .fst .Arrow-map.top = uncurry (λ x → cogap
      (mk-cocone
        (λ i → ι₁ ((Δ←□ x i :≥: i) ⦃ Δ←□-≤ x i ⦄))
        (λ i → ι₂ i)
        λ _ → ap ι₁ (Δ-ext (Δ←□-1 x refl :≥: refl)) ∙ glue tt))
    amap2-ret n .fst .Arrow-map.bot = ret-Δ-n+2
    amap2-ret n .fst .Arrow-map.comm = uncurry (λ x → pushout-ind _
      (mk-coconeᵈ
        ~refl
        (λ i → Δ-ext (Δ←□-1 x refl :≥: refl :≥: refl))
        λ _ → Δ-is-set _ _ _ _))
    amap2-ret n .snd .fst = pushout-ind _
      (mk-coconeᵈ
        (λ where (l :≥: j) → ap ι₁ (Δ-ext (□←Δ-ret l j :≥: refl)))
        ~refl
        λ _ → prop!)
    amap2-ret n .snd .snd .fst = is-ret-Δ-□
    amap2-ret n .snd .snd .snd x = prop!
}
}

\subtree[stt-00E6]{
\taxon{Theorem}
\title{Spine lifting}
\date{2026-02-04}
\author{samueltoth}
\contributor{fredrikbakke}

\p{For all #{n}, the inclusion #{\II_n \hookrightarrow \Delta^n} is inner anodyne.}

\proof{
The inclusions #{\II_0 \hookrightarrow \Delta^0} and
#{\II_1 \hookrightarrow \Delta^1} are equivalences and
#{\II_2 \hookrightarrow \Delta^2} is inner anodyne by definition.
We proceed by induction on #{n \ge 2}. We need to show that the map
#{\II_{n + 1} \to \Delta^{n + 1}} is inner anodyne. Firstly,
we note that we can factorise this map as follows:

##{\II_{n} \vee \Delta^1 \to \Delta^n \vee \Delta^1 \to \Delta^{n+1}}

By the induction hypothesis and [closure properties of left orthogonal
maps](stt-00E7), we have that the first map is inner anodyne. Since the second map is
inner  anodyne by the [previous lemma](fre-AEE2) we are done.
}

\agda{
opaque
  Spine-lifting : (n : ℕ) → is-inner-anodyne (Spine-incl {suc (suc n)})
  Spine-lifting 0
    = left-orthogonal-equiv
       Λ[2,1]-incl Spine-incl
       (mk-amap id (λ where (i , j) → · :≥: i :≥: j)
         (pushout-ind _ (mk-coconeᵈ ~refl ~refl (λ _ → prop!))))
       (id-is-equiv , Δ←Δ²-is-equiv)
  Spine-lifting (suc n)
    = is-anodyne-homotopy
        {f = spine-incl-factor-1 (n +ℕ 2) ∘ spine-incl-factor-2 (n +ℕ 2)}
        {g = Spine-incl}
        Λ[2,1]-incl
        (spine-incl~factors (n +ℕ 2))
        (is-anodyne-∘
          {f = spine-incl-factor-1 (n +ℕ 2)}
          {g = spine-incl-factor-2 (n +ℕ 2)}
          Λ[2,1]-incl
          fat-spine-lifts
          (Wedge-map-is-anodyne
            Λ[2,1]-incl
            (target-map∗ (Spine-incl∗∗ (n +ℕ 2)))
            (source-map∗ (id∗∗ Δ¹∗∗))
            (Spine-lifting n)
            (λ k _ → id⊥ k)))
}

\p{
Finally, we account for the 0- and 1-spine to obtain lifting against all spines.
}

\agda{
opaque
  Spine-incl-is-inner-anodyne : (n : ℕ) → is-inner-anodyne (Spine-incl {n})
  Spine-incl-is-inner-anodyne
    = λ where
        0 k _ → equiv⊥ 0-Spine-incl-is-equiv k
        1 k _ → equiv⊥ 1-Spine-incl-is-equiv k
        (suc (suc n)) → Spine-lifting n
}
}

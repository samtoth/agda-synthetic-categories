\subtree[stt-00MU]{
\date{2026-03-19}
\author{fredrikbakke}
\taxon{Theorem}
\title{Dependent functions as sections over fibres}

\p{
Given a family #{U} over #{B} and a map #{f : A \to B}, dependent functions
#{(a : A) \to U(f(a))} are equivalently families of functions out of each fibre
#{\fibre{f}{b}}.
}

\agda{
module _
  {ūĚď§ ūĚď• ūĚď¶ : Level}
  {A : Type ūĚď§} {B : Type ūĚď•}
  (U : B ‚Üí Type ūĚď¶)
  (f : A ‚Üí B)
  where

  precomp-ő†-over-fibres
    : ő† A (U ‚ąė f) ‚Üí ő† B (őĽ b ‚Üí fibre f b ‚Üí U b)
  precomp-ő†-over-fibres h b (a , p) = tr U p (h a)

  precomp-ő†-over-fibres-is-equiv
    : is-equiv precomp-ő†-over-fibres
  precomp-ő†-over-fibres-is-equiv
    = is-equiv‚Üźqinv (bwd , hrefl , őĶ) where
    bwd : ő† B (őĽ b ‚Üí fibre f b ‚Üí U b) ‚Üí ő† A (U ‚ąė f)
    bwd h a = h (f a) (a , refl)

    őĶ : precomp-ő†-over-fibres ‚ąė bwd ~ id
    őĶ h = funext‚Üí (őĽ _ ‚Üí funext‚Üí (őĽ where (a , refl) ‚Üí refl))

  precomp-ő†-over-fibres‚ČÉ
    : ő† A (U ‚ąė f) ‚ČÉ ő† B (őĽ b ‚Üí fibre f b ‚Üí U b)
  precomp-ő†-over-fibres‚ČÉ
    = mk‚ČÉ precomp-ő†-over-fibres precomp-ő†-over-fibres-is-equiv
}
}

\subtree[stt-00JL]{
\title{Fibres of the composition of maps}
\taxon{Lemma}

\agda{
fibre-‚ąė
  : ‚ąÄ {ūĚď§ ūĚď• ūĚď¶} {A : Type ūĚď§} {B : Type ūĚď•} {C : Type ūĚď¶}
      {f : B ‚Üí C} {g : A ‚Üí B}
    ‚Üí ‚ąÄ a ‚Üí fibre (f ‚ąė g) a ‚ČÉ ő£[ x ‚ą∂ fibre f a ] fibre g (fst x)
fibre-‚ąė {f = f} {g = g} c = equiv‚Üźqequiv qeqv where
  qeqv : fibre (f ‚ąė g) c ‚Čä ő£ (fibre f c) (őĽ x ‚Üí fibre g (fst x))
  qeqv ._‚Čä_.fwd (x , p) = ((g x , p) , (x , refl))
  qeqv ._‚Čä_.fwd-qinv .fst ((x , p) , (y , refl)) = (y , p)
  qeqv ._‚Čä_.fwd-qinv .snd .fst (a , refl) = refl
  qeqv ._‚Čä_.fwd-qinv .snd .snd ((x , p) , (y , refl)) = refl
}

\p{The following lemma is exercise 4.4 of \citek{HoTT}.}

\agda{
unstable-octahedron-map
  : ‚ąÄ {ūĚď§ ūĚď• ūĚď¶} {A : Type ūĚď§} {B : Type ūĚď•} {C : Type ūĚď¶}
      (f : B ‚Üí C) (g : A ‚Üí B)
    ‚Üí ‚ąÄ b ‚Üí fibre (f ‚ąė g) (f b) ‚Üí fibre f (f b)
unstable-octahedron-map f g b (x , p) = (g x , p)

fibre-unstable-octahedron
  : ‚ąÄ {ūĚď§ ūĚď• ūĚď¶} {A : Type ūĚď§} {B : Type ūĚď•} {C : Type ūĚď¶}
      {f : B ‚Üí C} {g : A ‚Üí B}
    ‚Üí ‚ąÄ a ‚Üí fibre g a ‚ČÉ fibre (unstable-octahedron-map f g a) (a , refl)
fibre-unstable-octahedron {f = f} {g} a ._‚ČÉ_.fwd (x , refl)
  = ((_ , refl) , refl)
fibre-unstable-octahedron {f = f} {g} a ._‚ČÉ_.fwd-is-equiv
  .is-equiv.qinv .fst (_ , refl)  = (_ , refl)
fibre-unstable-octahedron {f = f} {g} a ._‚ČÉ_.fwd-is-equiv
  .is-equiv.qinv .snd .fst (_ , refl) = refl
fibre-unstable-octahedron {f = f} {g} a ._‚ČÉ_.fwd-is-equiv
  .is-equiv.qinv .snd .snd (_ , refl) = refl
fibre-unstable-octahedron {f = f} {g} a ._‚ČÉ_.fwd-is-equiv
  .is-equiv.coherent (_ , refl) = refl
}
}

%```


\subtree[stt-008M]{
\date{2025-08-03}
\title{Maps of spans}
\taxon{Definition}

\p{A map between spans #{S} and #{S'} is a diagram as follows where
all the squares commute:}

\quiver{
\begin{tikzcd}
	A && S && B \\
	\\
	{A'} && {S'} && {B'}
	\arrow[from=1-1, to=3-1]
	\arrow[from=1-3, to=1-1]
	\arrow[from=1-3, to=1-5]
	\arrow[from=1-3, to=3-3]
	\arrow[from=1-5, to=3-5]
	\arrow[from=3-3, to=3-1]
	\arrow[from=3-3, to=3-5]
\end{tikzcd}
}


%```agda
\agda{
record Span-map {ūĚď§ ūĚď• ūĚď¶} (S : Span ūĚď§ ūĚď• ūĚď¶)
                {ūĚď§' ūĚď•' ūĚď¶'} (S' : Span ūĚď§' ūĚď•' ūĚď¶')
                : Type (ūĚď§ ‚äĒ ūĚď§' ‚äĒ ūĚď• ‚äĒ ūĚď•' ‚äĒ ūĚď¶ ‚äĒ ūĚď¶') where
   constructor mk-span-map
   module S = Span S
   module S' = Span S'
   field
     h‚āĀ : S.Left ‚Üí S'.Left
     h‚āā : S.Centre ‚Üí S'.Centre
     h‚āÉ : S.Right ‚Üí S'.Right
     H  : h‚āĀ ‚ąė S.left ~ S'.left ‚ąė h‚āā
     K  : h‚āÉ ‚ąė S.right ~ S'.right ‚ąė h‚āā

   amap-l‚Üď : Arrow-map S.left S'.left
   amap-l‚Üď = mk-amap h‚āā h‚āĀ H

   amap-l : Arrow-map h‚āā h‚āĀ
   amap-l = mk-amap S.left S'.left (H ~‚ĀĽ¬Ļ)

   amap-r‚Üď : Arrow-map S.right S'.right
   amap-r‚Üď = mk-amap h‚āā h‚āÉ K

   amap-r : Arrow-map h‚āā h‚āÉ
   amap-r = mk-amap S.right S'.right (K ~‚ĀĽ¬Ļ)

unquoteDecl Span-map-repr‚ČÖ Span-map-repr‚ČÉ
  = make-record-repr Span-map-repr‚ČÖ Span-map-repr‚ČÉ (quote Span-map)
}
%```

\p{Equivalently, a span map is a pair of arrow maps between the
left and right maps of each span, together with a homotopy between
the two maps between the centre of the spans.}

%```agda
\agda{
Arrow-maps‚ÜźSpan-map
  : ‚ąÄ {ūĚď§ ūĚď• ūĚď¶ ūĚď§' ūĚď•' ūĚď¶'} {S : Span ūĚď§ ūĚď• ūĚď¶}
      {S' : Span ūĚď§' ūĚď•' ūĚď¶'}
    ‚Üí Span-map S S'
    ‚Üí let module S = Span S ; module S' = Span S'
    in ő£[ F ‚ą∂ Arrow-map S.left S'.left ] ő£[ G ‚ą∂ Arrow-map S.right S'.right ]
         (F .Arrow-map.top ~ G .Arrow-map.top)
Arrow-maps‚ÜźSpan-map S = (amap-l‚Üď , amap-r‚Üď , ~refl) where open Span-map S

Span-map‚ÜźArrow-maps
  : ‚ąÄ {ūĚď§ ūĚď• ūĚď¶ ūĚď§' ūĚď•' ūĚď¶'} {S : Span ūĚď§ ūĚď• ūĚď¶}
      {S' : Span ūĚď§' ūĚď•' ūĚď¶'}
    ‚Üí let module S = Span S ; module S' = Span S'
    in ő£[ F ‚ą∂ Arrow-map S.left S'.left ] ő£[ G ‚ą∂ Arrow-map S.right S'.right ]
         (F .Arrow-map.top ~ G .Arrow-map.top)
    ‚Üí Span-map S S'
Span-map‚ÜźArrow-maps (F , G , H)
  = funext-rec (őĽ _ ‚Üí Span-map _ _) at-refl H module from-arrow-map where
  module F = Arrow-map F
  module G = Arrow-map G

  at-refl : F.top ÔľĚ G.top ‚Üí Span-map _ _
  at-refl refl = mk-span-map F.bot G.top G.bot F.comm G.comm

Span-map‚ČÉArrow-maps
  : ‚ąÄ {ūĚď§ ūĚď• ūĚď¶ ūĚď§' ūĚď•' ūĚď¶'} {S : Span ūĚď§ ūĚď• ūĚď¶}
      {S' : Span ūĚď§' ūĚď•' ūĚď¶'}
    ‚Üí let module S = Span S ; module S' = Span S'
    in (ő£[ F ‚ą∂ Arrow-map S.left S'.left ] ő£[ G ‚ą∂ Arrow-map S.right S'.right ]
         (F .Arrow-map.top ~ G .Arrow-map.top))
    ‚ČÉ Span-map S S'
Span-map‚ČÉArrow-maps = mk‚ČÉ Span-map‚ÜźArrow-maps (is-equiv‚Üźqiso qiso) where
  qiso : quasi-iso Span-map‚ÜźArrow-maps
  qiso .fst = Arrow-maps‚ÜźSpan-map
  qiso .snd .fst x@(F , G , HH)
    = funext-rec
        (őĽ HH'
          ‚Üí Arrow-maps‚ÜźSpan-map (Span-map‚ÜźArrow-maps (F , G , HH')) ÔľĚ (F , G , HH'))
        lem
        HH where
    open Span-map
    lem : (p : (Arrow-map.top F) ÔľĚ (Arrow-map.top G)) ‚Üí
           Arrow-maps‚ÜźSpan-map (Span-map‚ÜźArrow-maps (F , G , happly p)) ÔľĚ
           (F , G , happly p)
    lem refl =
      (Arrow-maps‚ÜźSpan-map ‚ąė Span-map‚ÜźArrow-maps) (F , G , ~refl) ÔľĚ‚ü®‚ü©
      Arrow-maps‚ÜźSpan-map (funext-rec (őĽ _ ‚Üí Span-map _ _)
        (from-arrow-map.at-refl _ _ _) ~refl)
      ÔľĚ‚ü® ap Arrow-maps‚ÜźSpan-map (funext-rec-~refl _ _) ‚ü©
      (F , G , ~refl) ‚ąé where open Span-map
  qiso .snd .snd F =  funext-rec-~refl _ _

span-map-pathŠĶą‚Üí
  : ‚ąÄ {ūĚď§ ūĚď• ūĚď¶ ūĚď§' ūĚď•' ūĚď¶'} {S : Span ūĚď§ ūĚď• ūĚď¶}
      {S' : Span ūĚď§' ūĚď•' ūĚď¶'}
      {S'' : Span ūĚď§' ūĚď•' ūĚď¶'}
      {f : Span-map S' S} {g : Span-map S'' S}
    ‚Üí let module S = Span S
          module S' = Span S'
          module S'' = Span S''
          module f = Span-map f
          module g = Span-map g
    in (p : S'.Centre ÔľĚ S''.Centre)
    ‚Üí (q : S'.Left ÔľĚ S''.Left)
    ‚Üí (r : S'.Right ÔľĚ S''.Right)
    ‚Üí (h : coe r ‚ąė S'.right ÔľĚ S''.right ‚ąė coe p)
    ‚Üí (k : coe q ‚ąė S'.left ÔľĚ S''.left ‚ąė coe p)
    ‚Üí (Q : f.h‚āĀ ÔľĚ g.h‚āĀ ‚ąė coe q)
    ‚Üí (P : f.h‚āā ÔľĚ g.h‚āā ‚ąė coe p)
    ‚Üí (R : f.h‚āÉ ÔľĚ g.h‚āÉ ‚ąė coe r)
    ‚Üí (H : f.H ÔľĚ   (happly Q ‚Ėł S'.left) ~‚ąô (g.h‚āĀ ‚óā happly k)
                  ~‚ąô (g.H ‚Ėł coe p) ~‚ąô (S.left ‚óā happly (sym P)))
    ‚Üí (K : f.K ÔľĚ (happly R ‚Ėł S'.right) ~‚ąô (g.h‚āÉ ‚óā happly h)
                 ~‚ąô (g.K ‚Ėł coe p) ~‚ąô S.right ‚óā (happly (sym P)))
    ‚Üí IdŠĶą (ap (őĽ P ‚Üí Span-map P S) (Span-path‚Üí p q r h k)) f g
span-map-pathŠĶą‚Üí refl refl refl refl refl refl refl refl refl refl
  = ap‚āā (őĽ P Q ‚Üí mk-span-map _ _ _ P Q)
        (funext‚Üí (őĽ a ‚Üí ‚ąô-reflr _))
        (funext‚Üí (őĽ a ‚Üí ‚ąô-reflr _))
}
%```
}

\subtree[stt-00B5]{
\title{Span equivalences}
\taxon{Theorem}

\p{We call a span map an equivalence if each component is an equivalence.
Span equivalences give rise to inverse span maps in the obvious way.}

%```agda
\agda{
is-Span-equiv
  : ‚ąÄ {ūĚď§ ūĚď• ūĚď¶ ūĚď§' ūĚď•' ūĚď¶'}
      {S : Span ūĚď§ ūĚď• ūĚď¶} {S' : Span ūĚď§' ūĚď•' ūĚď¶'}
    ‚Üí Span-map S S' ‚Üí Type (ūĚď§' ‚äĒ ūĚď•' ‚äĒ ūĚď¶' ‚äĒ ūĚď§ ‚äĒ ūĚď• ‚äĒ ūĚď¶)
is-Span-equiv F = is-equiv h‚āĀ
                    √ó is-equiv h‚āā
                    √ó is-equiv h‚āÉ where
  open Span-map F

l-is-arrow-equiv‚Üźis-span-equiv
  : ‚ąÄ {ūĚď§ ūĚď• ūĚď¶ ūĚď§' ūĚď•' ūĚď¶'}
      {S : Span ūĚď§ ūĚď• ūĚď¶} {S' : Span ūĚď§' ūĚď•' ūĚď¶'}
    ‚Üí (F : Span-map S S') ‚Üí is-Span-equiv F
    ‚Üí is-Arrow-equiv (Span-map.amap-l‚Üď F)
l-is-arrow-equiv‚Üźis-span-equiv F eq
  = (eq .snd .fst , eq .fst)

r-is-arrow-equiv‚Üźis-span-equiv
  : ‚ąÄ {ūĚď§ ūĚď• ūĚď¶ ūĚď§' ūĚď•' ūĚď¶'}
      {S : Span ūĚď§ ūĚď• ūĚď¶} {S' : Span ūĚď§' ūĚď•' ūĚď¶'}
    ‚Üí (F : Span-map S S') ‚Üí is-Span-equiv F
    ‚Üí is-Arrow-equiv (Span-map.amap-r‚Üď F)
r-is-arrow-equiv‚Üźis-span-equiv F eq
  = (eq .snd .fst , eq .snd .snd)

Span‚ĀĽ¬Ļ‚ÜźSpan-equiv
  : ‚ąÄ {ūĚď§ ūĚď• ūĚď¶ ūĚď§' ūĚď•' ūĚď¶'}
      {S : Span ūĚď§ ūĚď• ūĚď¶} {S' : Span ūĚď§' ūĚď•' ūĚď¶'}
    ‚Üí (F : Span-map S S') ‚Üí is-Span-equiv F
    ‚Üí Span-map S' S
Span‚ĀĽ¬Ļ‚ÜźSpan-equiv F (e1 , e2 , e3)
  = mk-span-map F‚āĀ.bwd F‚āā.bwd F‚āÉ.bwd H1 H2 module Span-inv where
  module F = Span-map F
  module S = F.S
  module S' = F.S'
  module F‚āĀ = is-equiv e1
  module F‚āā = is-equiv e2
  module F‚āÉ = is-equiv e3


  K1 : F.h‚āĀ ‚ąė F‚āĀ.bwd ‚ąė S'.left ‚ąė F.h‚āā ~ F.h‚āĀ ‚ąė S.left ‚ąė F‚āā.bwd ‚ąė F.h‚āā
  K1 = (F‚āĀ.őĶ ‚Ėł S'.left ‚Ėł F.h‚āā ~‚ąô (F.H ~‚ĀĽ¬Ļ) ~‚ąô (F.h‚āĀ ‚óā (S.left ‚óā F‚āā.ő∑) ~‚ĀĽ¬Ļ))

  H1 : F‚āĀ.bwd ‚ąė S'.left ~ S.left ‚ąė F‚āā.bwd
  H1 = e1 ‚óāeqv K1 ‚Ėłeqv e2

  K2 : F.h‚āÉ ‚ąė F‚āÉ.bwd ‚ąė S'.right ‚ąė F.h‚āā ~ F.h‚āÉ ‚ąė S.right ‚ąė F‚āā.bwd ‚ąė F.h‚āā
  K2 = (F‚āÉ.őĶ ‚Ėł S'.right ‚Ėł F.h‚āā) ~‚ąô (F.K ~‚ĀĽ¬Ļ) ~‚ąô (F.h‚āÉ ‚óā (S.right ‚óā F‚āā.ő∑) ~‚ĀĽ¬Ļ)

  H2 : F‚āÉ.bwd ‚ąė S'.right ~ S.right ‚ąė F‚āā.bwd
  H2 = e3 ‚óāeqv K2 ‚Ėłeqv e2
}
%```
}

\subtree[stt-00AJ]{
\title{Span map composition}
\taxon{Construction}
\date{2025-11-21}

%```agda
\agda{
compose-span-map
  : ‚ąÄ {ūĚď§ ūĚď• ūĚď¶ ūĚď§' ūĚď•' ūĚď¶' ūĚď§'' ūĚď•'' ūĚď¶''}
      {S : Span ūĚď§ ūĚď• ūĚď¶} {S' : Span ūĚď§' ūĚď•' ūĚď¶'} {S'' : Span ūĚď§'' ūĚď•'' ūĚď¶''}
    ‚Üí Span-map S' S'' ‚Üí Span-map S S'
    ‚Üí Span-map S S''
compose-span-map F G = map where
  module F = Span-map F
  module G = Span-map G

  map : Span-map _ _
  map .Span-map.h‚āĀ = F.h‚āĀ ‚ąė G.h‚āĀ
  map .Span-map.h‚āā = F.h‚āā ‚ąė G.h‚āā
  map .Span-map.h‚āÉ = F.h‚āÉ ‚ąė G.h‚āÉ
  map .Span-map.H = (F.h‚āĀ ‚óā G.H) ~‚ąô (F.H ‚Ėł G.h‚āā)
  map .Span-map.K = F.h‚āÉ ‚óā G.K ~‚ąô F.K ‚Ėł G.h‚āā

id-span-map
  : ‚ąÄ {ūĚď§ ūĚď• ūĚď¶} {S : Span ūĚď§ ūĚď• ūĚď¶}
  ‚Üí Span-map S S
id-span-map = mk-span-map id id id ~refl ~refl

id-span-map-is-equiv
  : ‚ąÄ {ūĚď§ ūĚď• ūĚď¶} {S : Span ūĚď§ ūĚď• ūĚď¶}
    ‚Üí is-Span-equiv (id-span-map {S = S})
id-span-map-is-equiv = (id-is-equiv , id-is-equiv , id-is-equiv)
}
%```
}

\subtree[stt-00AZ]{
\title{Univalence for spans}
\taxon{Theorem}

\p{Span equivalences are an identity system for spans.}

%```
\agda{
Span-equiv
  : {ūĚď§ ūĚď• ūĚď¶ ūĚď§' ūĚď•' ūĚď¶' : Level}
  ‚Üí Span ūĚď§ ūĚď• ūĚď¶
  ‚Üí Span ūĚď§' ūĚď•' ūĚď¶'
  ‚Üí Type (ūĚď§ ‚äĒ ūĚď• ‚äĒ ūĚď¶ ‚äĒ ūĚď§' ‚äĒ ūĚď•' ‚äĒ ūĚď¶')
Span-equiv S S' = ő£[ F ‚ą∂ Span-map S S' ] is-Span-equiv F

Span-equiv'
  : {ūĚď§ ūĚď• ūĚď¶ ūĚď§' ūĚď•' ūĚď¶' : Level}
  ‚Üí Span ūĚď§ ūĚď• ūĚď¶
  ‚Üí Span ūĚď§' ūĚď•' ūĚď¶'
  ‚Üí Type (ūĚď§ ‚äĒ ūĚď• ‚äĒ ūĚď¶ ‚äĒ ūĚď§' ‚äĒ ūĚď•' ‚äĒ ūĚď¶')
Span-equiv' S S'
  = ő£[ F ‚ą∂ (S .Span.Centre ‚ČÉ S' .Span.Centre) ]
    ő£[ L ‚ą∂ (S .Span.Left ‚ČÉ S' .Span.Left) ]
    ő£[ _ ‚ą∂ (L ._‚ČÉ_.fwd ‚ąė S .Span.left ~ S' .Span.left ‚ąė F ._‚ČÉ_.fwd) ]
    ő£[ R ‚ą∂ (S .Span.Right ‚ČÉ S' .Span.Right) ]
      (R ._‚ČÉ_.fwd ‚ąė S .Span.right ~ S' .Span.right ‚ąė F ._‚ČÉ_.fwd)

Span-equiv'‚ČÉSpan-equiv
  : ‚ąÄ {ūĚď§ ūĚď• ūĚď¶ ūĚď§' ūĚď•' ūĚď¶'} {S : Span  ūĚď§ ūĚď• ūĚď¶} {S' : Span ūĚď§' ūĚď•' ūĚď¶'}
    ‚Üí Span-equiv S S' ‚ČÉ Span-equiv' S S'
Span-equiv'‚ČÉSpan-equiv {S = S} {S' = S'}
  = equiv‚Üźqiso qiso where
  qiso : Span-equiv S S' ‚ČÖ Span-equiv' S S'
  qiso ._‚ČÖ_.fwd (smap , (leq , ceq , req))
    =
    ( mk‚ČÉ (smap .Span-map.h‚āā) ceq
    , mk‚ČÉ (smap .Span-map.h‚āĀ) leq
    , smap .Span-map.H
    , mk‚ČÉ (smap .Span-map.h‚āÉ) req
    , smap .Span-map.K)
  qiso ._‚ČÖ_.fwd-iso .fst (mk‚ČÉ c ceq , mk‚ČÉ l leq , H , mk‚ČÉ r req , K)
    = (mk-span-map l c r H K , leq , ceq , req)
  qiso ._‚ČÖ_.fwd-iso .snd .fst = ~refl
  qiso ._‚ČÖ_.fwd-iso .snd .snd = ~refl

components‚ÜźSpan-equiv
  : ‚ąÄ {ūĚď§ ūĚď• ūĚď¶ ūĚď§' ūĚď•' ūĚď¶'} {S : Span ūĚď§ ūĚď• ūĚď¶} {S' : Span ūĚď§' ūĚď•' ūĚď¶'}
    ‚Üí Span-equiv S S' ‚Üí Span-equiv' S S'
components‚ÜźSpan-equiv = _‚ČÉ_.fwd Span-equiv'‚ČÉSpan-equiv

Span-equiv‚Üźcomponents
  : ‚ąÄ {ūĚď§ ūĚď• ūĚď¶ ūĚď§' ūĚď•' ūĚď¶'} {S : Span ūĚď§ ūĚď• ūĚď¶} {S' : Span ūĚď§' ūĚď•' ūĚď¶'}
    ‚Üí Span-equiv' S S' ‚Üí Span-equiv S S'
Span-equiv‚Üźcomponents = _‚ČÉ_.bwd Span-equiv'‚ČÉSpan-equiv

inverse-components‚ÜźSpan-equiv
  : ‚ąÄ {ūĚď§ ūĚď• ūĚď¶ ūĚď§' ūĚď•' ūĚď¶'} {S : Span ūĚď§ ūĚď• ūĚď¶} {S' : Span ūĚď§' ūĚď•' ūĚď¶'}
    ‚Üí Span-equiv S S'
    ‚Üí Span-equiv' S' S
inverse-components‚ÜźSpan-equiv {S = S} {S'} e
  = from-components (components‚ÜźSpan-equiv e)
  where
  from-components
    : Span-equiv' S S'
    ‚Üí Span-equiv' S' S
  from-components (F , L , H , R , K)
    = (F e‚ĀĽ¬Ļ)
    , (L e‚ĀĽ¬Ļ , left-inv-comm , (R e‚ĀĽ¬Ļ , right-inv-comm))
    where
    left-inv-comm : _‚ČÉ_.bwd L ‚ąė S' .Span.left ~ S .Span.left ‚ąė _‚ČÉ_.bwd F
    left-inv-comm p
      = ap (_‚ČÉ_.bwd L) (ap (S' .Span.left) (sym (_‚ČÉ_.őĶ F p)))
      ‚ąô ap (_‚ČÉ_.bwd L) (sym (H (_‚ČÉ_.bwd F p)))
      ‚ąô _‚ČÉ_.ő∑ L (S .Span.left (_‚ČÉ_.bwd F p))

    right-inv-comm : _‚ČÉ_.bwd R ‚ąė S' .Span.right ~ S .Span.right ‚ąė _‚ČÉ_.bwd F
    right-inv-comm p
      = ap (_‚ČÉ_.bwd R) (ap (S' .Span.right) (sym (_‚ČÉ_.őĶ F p)))
      ‚ąô ap (_‚ČÉ_.bwd R) (sym (K (_‚ČÉ_.bwd F p)))
      ‚ąô _‚ČÉ_.ő∑ R (S .Span.right (_‚ČÉ_.bwd F p))

Span-equiv‚Üźinverse-components
  : ‚ąÄ {ūĚď§ ūĚď• ūĚď¶ ūĚď§' ūĚď•' ūĚď¶'} {S : Span ūĚď§ ūĚď• ūĚď¶} {S' : Span ūĚď§' ūĚď•' ūĚď¶'}
    ‚Üí Span-equiv' S' S
    ‚Üí Span-equiv S S'
Span-equiv‚Üźinverse-components {S = S} {S'} (F , L , H , R , K)
  = Span-equiv‚Üźcomponents
      ( (F e‚ĀĽ¬Ļ)
      , (L e‚ĀĽ¬Ļ)
      , (őĽ p
          ‚Üí sym (ap (_‚ČÉ_.bwd L) (ap (Span.left S) (_‚ČÉ_.őĶ F p)))
          ‚ąô sym (ap (_‚ČÉ_.bwd L) (H (_‚ČÉ_.bwd F p)))
          ‚ąô is-equiv.ő∑ (L ._‚ČÉ_.has-is-eqv) (Span.left S' (_‚ČÉ_.bwd F p)))
      , (R e‚ĀĽ¬Ļ)
      , (őĽ p
          ‚Üí sym (ap (_‚ČÉ_.bwd R) (ap (Span.right S) (_‚ČÉ_.őĶ F p)))
          ‚ąô sym (ap (_‚ČÉ_.bwd R) (K (_‚ČÉ_.bwd F p)))
          ‚ąô is-equiv.ő∑ (R ._‚ČÉ_.has-is-eqv) (Span.right S' (_‚ČÉ_.bwd F p))))

Span-equiv‚ÜźId
  : ‚ąÄ {ūĚď§ ūĚď• ūĚď¶} {S S' : Span ūĚď§ ūĚď• ūĚď¶}
    ‚Üí S ÔľĚ S' ‚Üí Span-equiv S S'
Span-equiv‚ÜźId {S = S} refl = (id-span-map , id-span-map-is-equiv {S = S})

opaque
  Span-equiv‚ÜźId-is-equiv
    : ‚ąÄ {ūĚď§ ūĚď• ūĚď¶} {S S' : Span ūĚď§ ūĚď• ūĚď¶} ‚Üí is-equiv (Span-equiv‚ÜźId {S = S}{S'})
  Span-equiv‚ÜźId-is-equiv {S = S} {S'}
    = fundamental-Id
       (Span-equiv S)
       (is-single‚Üźequiv-to-single
         ((ő£-ap-‚ČÉ-fst
            {B = őĽ (C , _ , f , _ , g) ‚Üí Span-equiv S (mk-span C f g) }
            Span-repr‚ČÉ ‚ąô‚ČÉ ő£-ap-‚ČÉ (őĽ a ‚Üí Span-equiv'‚ČÉSpan-equiv)) e‚ĀĽ¬Ļ)
         (is-singleton-structure‚Üźparts (SingS-is-single (Centre S))
          (S .Centre , idequiv)
          (is-singleton-structure‚Üźparts
           (SingS-is-single (Left S))
           (Left S , idequiv)
           (is-singleton-structure‚Üźparts
            (SingS-is-single (left S))
            (left S , ~refl)
            (is-singleton-structure‚Üźparts
              (SingS-is-single (Right S))
              (Right S , idequiv)
              (SingS-is-single (right S)))))))
       (őĽ _ ‚Üí Span-equiv‚ÜźId)
       S' where open Span

instance
  SpanIdS : ‚ąÄ {ūĚď§ ūĚď• ūĚď¶} ‚Üí Identity-system (Span ūĚď§ ūĚď• ūĚď¶) (ūĚď§ ‚äĒ ūĚď• ‚äĒ ūĚď¶)
  SpanIdS .Identity-system.IdS = Span-equiv
  SpanIdS .Identity-system.IdS‚ÜźId = Span-equiv‚ÜźId
  SpanIdS .Identity-system.has-is-ids _ _ = Span-equiv‚ÜźId-is-equiv
}
%```
}


\subtree[stt-00B0]{
\title{Homotopy of span maps}
\taxon{Definition}

%```agda
\agda{
Span-map-homotopy
  : ‚ąÄ {ūĚď§ ūĚď• ūĚď¶ ūĚď§' ūĚď•' ūĚď¶'} {S : Span ūĚď§ ūĚď• ūĚď¶} {S' : Span ūĚď§' ūĚď•' ūĚď¶'}
    ‚Üí (F G : Span-map S S') ‚Üí Type (ūĚď§ ‚äĒ ūĚď• ‚äĒ ūĚď¶ ‚äĒ ūĚď§' ‚äĒ ūĚď•' ‚äĒ ūĚď¶')
Span-map-homotopy F G
  = ő£[ H‚āĀ ‚ą∂ F.h‚āĀ ~ G.h‚āĀ ] ő£[ H‚āā ‚ą∂ F.h‚āā ~ G.h‚āā ] ő£[ H‚āÉ ‚ą∂ F.h‚āÉ ~ G.h‚āÉ ]
       ( F.H ~ H‚āĀ ‚Ėł F.S.left ~‚ąô G.H ~‚ąô F.S'.left ‚óā (H‚āā ~‚ĀĽ¬Ļ)
       √ó  F.K ~ H‚āÉ ‚Ėł F.S.right ~‚ąô G.K ~‚ąô F.S'.right ‚óā (H‚āā ~‚ĀĽ¬Ļ)) where
  module F = Span-map F
  module G = Span-map G

Span-map-homotopy-refl
  : ‚ąÄ {ūĚď§ ūĚď• ūĚď¶ ūĚď§' ūĚď•' ūĚď¶'} {S : Span ūĚď§ ūĚď• ūĚď¶} {S' : Span ūĚď§' ūĚď•' ūĚď¶'}
    ‚Üí (F : Span-map S S') ‚Üí Span-map-homotopy F F
Span-map-homotopy-refl F = ~refl , ~refl , ~refl , ~‚ąô-reflr _ ~‚ĀĽ¬Ļ , ~‚ąô-reflr _ ~‚ĀĽ¬Ļ

Span-map-funext‚Üí
  : ‚ąÄ {ūĚď§ ūĚď• ūĚď¶ ūĚď§' ūĚď•' ūĚď¶'} {S : Span ūĚď§ ūĚď• ūĚď¶} {S' : Span ūĚď§' ūĚď•' ūĚď¶'}
      {F G : Span-map S S'} ‚Üí Span-map-homotopy F G ‚Üí F ÔľĚ G
Span-map-funext‚Üí {S = S} {S'} {F} {G} (p , q , r , s , t)
  = span-map-pathŠĶą‚Üí refl refl refl refl refl
     (funext‚Üí p) (funext‚Üí q) (funext‚Üí r)
     (funext‚Üí (őĽ a ‚Üí s a
                   ‚ąô ap ((p (S.left a) ‚ąô_) ‚ąė (G.H a ‚ąô_))
                        (ap (ap G.S'.left) (q-sym-happly a)))
      ‚ąô ap (őĽ x ‚Üí x ‚Ėł G.S.left ~‚ąô G.H ~‚ąô G.S'.left ‚óā happly (sym (funext‚Üí q)))
           (sym funext-redex))
     (funext‚Üí (őĽ a ‚Üí t a
                   ‚ąô ap ((r (S.right a) ‚ąô_) ‚ąė (G.K a ‚ąô_))
                        (ap (ap S'.right) (q-sym-happly a)))
      ‚ąô ap (őĽ x ‚Üí x ‚Ėł G.S.right ~‚ąô G.K ~‚ąô S'.right ‚óā happly (sym (funext‚Üí q)))
           (sym funext-redex)) where
   module S = Span S
   module S' = Span S'
   module G = Span-map G

   q-sym-happly : ‚ąÄ a ‚Üí sym (q a) ÔľĚ happly (sym (funext‚Üí q)) a
   q-sym-happly a
     = ap sym (sym (happly funext-redex a))
     ‚ąô sym (happly (happly-sym (funext‚Üí q) a) a)
}
%```
}

\subtree[stt-00AM]{
\title{Isomorphisms of spans}
\taxon{Theorem}

\p{An equivalence of spans gives rise to a quasi-isomorphism in span. I.e. we
get a pair of span maps whose composition is homotopic to the identity span map.}


\remark{This remains to be formalised.}

%```agda
\agda{
record Span-quasi-iso {ūĚď§ ūĚď• ūĚď¶ ūĚď§' ūĚď•' ūĚď¶'}
         {S : Span ūĚď§ ūĚď• ūĚď¶} {S' : Span ūĚď§' ūĚď•' ūĚď¶'} (F : Span-map S S')
         : Type (ūĚď§ ‚äĒ ūĚď• ‚äĒ ūĚď¶ ‚äĒ ūĚď§' ‚äĒ ūĚď•' ‚äĒ ūĚď¶') where
  constructor mk-span-qiso
  field
    bwd : Span-map S' S
    őĶ : Span-map-homotopy (compose-span-map F bwd) id-span-map
    ő∑ : Span-map-homotopy (compose-span-map bwd F) id-span-map
}
%```
}


\subtree[stt-00CN]{
\title{Spans of proposition}
\taxon{Definition}

\p{We call a span a \em{span of propositions} if each type is a proposition.}

%```agda
\agda{
is-prop-span : ‚ąÄ {ūĚď§ ūĚď• ūĚď¶} ‚Üí Span ūĚď§ ūĚď• ūĚď¶ ‚Üí Type (ūĚď§ ‚äĒ ūĚď• ‚äĒ ūĚď¶)
is-prop-span S = is-prop Left √ó is-prop Centre √ó is-prop Right
  where open Span S
}
%```

\p{We note that any span map into a propositional span is equal.}

%```agda
\agda{
Span-map-homotopy‚Üźdom-is-prop
  : ‚ąÄ {ūĚď§ ūĚď• ūĚď¶ ūĚď§' ūĚď•' ūĚď¶'} {S : Span ūĚď§ ūĚď• ūĚď¶} {S' : Span ūĚď§' ūĚď•' ūĚď¶'}
    ‚Üí (F G : Span-map S S') ‚Üí is-prop-span S' ‚Üí Span-map-homotopy F G
Span-map-homotopy‚Üźdom-is-prop F G prp .fst a
  = prp .fst (Span-map.h‚āĀ F a) (Span-map.h‚āĀ G a)
Span-map-homotopy‚Üźdom-is-prop F G prp .snd .fst a
  = prp .snd .fst (Span-map.h‚āā F a) (Span-map.h‚āā G a)
Span-map-homotopy‚Üźdom-is-prop F G prp .snd .snd .fst a
  = prp .snd .snd (Span-map.h‚āÉ F a) (Span-map.h‚āÉ G a)
Span-map-homotopy‚Üźdom-is-prop F G prp .snd .snd .snd .fst _
  = is-prop‚Üźis-single (ÔľĚ-singleton‚Üźis-prop (prp .fst) _ _) _ _
Span-map-homotopy‚Üźdom-is-prop F G prp .snd .snd .snd .snd _
  = is-prop‚Üźis-single (ÔľĚ-singleton‚Üźis-prop (prp .snd .snd) _ _) _ _
}
%```
}

\subtree[stt-00CO]{
\title{Logical equivalence of spans}
\taxon{Definition}

\p{Given spans #{S} and #{S'} (which are usually spans of propositions),
a logical equivalence #{S \iff S'} of spans is a logical equivalence between
each point of the spans.}

%```agda
\agda{
Span-logical-equiv : ‚ąÄ {ūĚď§ ūĚď• ūĚď¶ ūĚď§' ūĚď•' ūĚď¶'} (S : Span ūĚď§ ūĚď• ūĚď¶) (S' : Span ūĚď§' ūĚď•' ūĚď¶')
                     ‚Üí Type (ūĚď§ ‚äĒ ūĚď• ‚äĒ ūĚď¶ ‚äĒ ūĚď§' ‚äĒ ūĚď•' ‚äĒ ūĚď¶')
Span-logical-equiv S S' = (S .Left ‚áĒ S' .Left)
                        √ó (S .Centre ‚áĒ S' .Centre)
                        √ó (S .Right ‚áĒ S' .Right)
  where open Span
}
%```

\p{We show a logical equivalence of spans of propositions gives rise to an
equivalence of spans.}

%```agda
\agda{
module Span-logical-equiv {ūĚď§ ūĚď• ūĚď¶ ūĚď§' ūĚď•' ūĚď¶'}
         {S : Span ūĚď§ ūĚď• ūĚď¶} (spr : is-prop-span S)
         {S' : Span ūĚď§' ūĚď•' ūĚď¶'} (s'pr : is-prop-span S')
         (e : Span-logical-equiv S S')
         where
  fwd : Span-map S S'
  fwd .Span-map.h‚āĀ = e .fst .fst
  fwd .Span-map.h‚āā = e .snd .fst .fst
  fwd .Span-map.h‚āÉ = e .snd .snd .fst
  fwd .Span-map.H _ = s'pr .fst _ _
  fwd .Span-map.K _ = s'pr .snd .snd _ _

  bwd : Span-map S' S
  bwd .Span-map.h‚āĀ = e .fst .snd
  bwd .Span-map.h‚āā = e .snd .fst .snd
  bwd .Span-map.h‚āÉ = e .snd .snd .snd
  bwd .Span-map.H _ = spr .fst _ _
  bwd .Span-map.K _ = spr .snd .snd _ _

  fwd-is-equiv : is-Span-equiv fwd
  fwd-is-equiv .fst = is-equiv‚Üźinverse (spr .fst) (s'pr .fst) (e .fst .snd)
  fwd-is-equiv .snd .fst
    = is-equiv‚Üźinverse (spr .snd .fst) (s'pr .snd .fst) (e .snd .fst .snd)
  fwd-is-equiv .snd .snd
    = is-equiv‚Üźinverse (spr .snd .snd) (s'pr .snd .snd) (e .snd .snd .snd)

  fwd-qiso : Span-quasi-iso fwd
  fwd-qiso .Span-quasi-iso.bwd = bwd
  fwd-qiso .Span-quasi-iso.őĶ = Span-map-homotopy‚Üźdom-is-prop _ _ s'pr
  fwd-qiso .Span-quasi-iso.ő∑ = Span-map-homotopy‚Üźdom-is-prop _ _ spr
}
%```
}

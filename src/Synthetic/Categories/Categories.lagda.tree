\subtree[fre-00N1]{
\title{Rezk-completeness}
\taxon{Definition}
\author{fredrikbakke}

\p{
A type is \em{Rezk-complete} if it is null at the walking isomorphism.
}

\agda{
fam-is-rezk-complete : ūĚüô ‚Üí ‚ĄĎ ‚Üí ūĚüôŠīł: ūĚďė
fam-is-rezk-complete _ = !Šīł

is-rezk-complete
  : ‚ąÄ {ūĚď§}
  ‚Üí (A : Type ūĚď§)
  ‚Üí Type (ūĚďė ‚äĒ ūĚď§)
is-rezk-complete A
  = is-local fam-is-rezk-complete A

is-rezk-complete-is-prop
  : ‚ąÄ {ūĚď§} {A : Type ūĚď§}
  ‚Üí is-prop (is-rezk-complete A)
is-rezk-complete-is-prop {A = A}
  = is-local-is-prop A
}

\agda{
RezkCompl-SubU : ‚ąÄ {ūĚď§} ‚Üí SubU ūĚď§ (ūĚď§ ‚äĒ ūĚďė)
RezkCompl-SubU = Local-SubU fam-is-rezk-complete _

RezkCompl-gSubU : gSubU (_‚äĒ ūĚďė)
RezkCompl-gSubU = Local-gSubU fam-is-rezk-complete

RezkCompl-is-globally-reflective

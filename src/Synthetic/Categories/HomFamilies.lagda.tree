}

\subtree[stt-00D9]{
\taxon{Therem}
\title{Covariance of representable families}

\p{We show that a type #{A} is [left Segal](stt-00DA) iff the family
#{\Hom(x,-)} is covariant for each #{x}.}

\proof{
We will show that every #{A_{x/} \to A} is a left fibration iff A is right
orthogonal to the map #{\Lambda^2_1 \to 1 \rtimes \Delta^1}.

\p{First we give an equivalence of arrows:}

\quiver{
\begin{tikzcd}
	{1\rtimes \Delta^1 \to_\bullet A} && {{A_{x/}}^{\Delta^1}} \\
	\\
	{\Lambda^2_1 \to_\bullet A} && {A^{\Delta^1} \times_A A_{x/}}
	\arrow["\sim", from=1-1, to=1-3]
	\arrow[from=1-1, to=3-1]
	\arrow[from=1-3, to=3-3]
	\arrow["\sim"', from=3-1, to=3-3]
\end{tikzcd}
}

\p{The top equivalence is given by the [join-coslice adjunction](stt-00D5), and
the bottom via the universal property of the horn.}


\p{Now we use \ref{stt-00DC} to finish the proof.}
}

\closedScope{
\subtree[stt-00DD]{
\title{The bottom equivalence}
%```agda
\agda{
char-coslice-lift : ‚àÄ {ùì§} {A : Type ùì§} x
      ‚Üí Arrow-map (point i0) {C = Coslice A (point x)} (fst)
      ‚Üí Coslice-map {X = Œõ[2,1]} (Œª _ ‚Üí Œπ‚ÇÅ i0) (point x)
char-coslice-lift x (mk-amap top bot comm)
  = cogap (mk-cocone (top tt .snd tt .Hom·µà.hom)
                     bot
                     (Œª c ‚Üí top tt .snd tt .Hom·µà.hom1 ‚àô sym (comm c)))
  , Œª _ ‚Üí Hom·µà.hom0 (top tt .snd tt)

opaque
  char-coslice-lift-is-equiv
    : ‚àÄ {ùì§} {A : Type ùì§} x
    ‚Üí is-equiv (char-coslice-lift {A = A} x)
  char-coslice-lift-is-equiv x = is-equiv‚Üêqiso qiso where
    qiso : quasi-iso (char-coslice-lift x)
    qiso .fst (a , b) = mk-amap (Œª _ ‚Üí _ , (Œª _ ‚Üí mk-hom (a ‚àò Œπ‚ÇÅ) (b tt) refl))
                                (a ‚àò Œπ‚ÇÇ)
                                (ap a ‚àò sym ‚àò glue)
    qiso .snd .fst (mk-amap top bot comm)
      = let pth = ( top tt .snd tt .Hom·µà.hom1
                  , Œª i ‚Üí ( ~refl
                          , Square-degen-vert _ _ refl
                          , Square-flatten-hor refl))
        in Arrow-map-path‚Üí
          ( (Œª a ‚Üí Coslice-path‚Üí pth)
          , (~refl
          , Œª _ ‚Üí ap (_‚àô ap fst (Coslice-path‚Üí pth))
                    (ap-sym _ (glue tt) ‚àô ap sym (pushout-rec-apŒ≤ tt))
                ‚àô ap (sym (Hom·µà.hom1 (top tt .snd tt) ‚àô sym (comm tt)) ‚àô_)
                     (Coslice-path-ap-fst pth)
                ‚àô ap (_‚àô top tt .snd tt .Hom·µà.hom1) (‚àô-symsym _ (sym (comm tt)))
                ‚àô ‚àô.cancell _  (‚àô-sym' (Hom·µà.hom1 (top tt .snd tt)))
                               {f = sym (sym (comm tt))}
                ‚àô sym-sym ))
    qiso .snd .snd (a , p)
      = ext! ( sym ‚àò pushout-rec-unique _ _ ~refl ~refl
                      (Œª _ ‚Üí ‚àô-reflr _ ‚àô sym (ap sym (ap-sym a _) ‚àô sym-sym))

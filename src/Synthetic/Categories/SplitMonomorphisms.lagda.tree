\subtree[stt-00P9]{
\title{Split monomorphisms}
\author{fredrikbakke}
\taxon{Definition}

\p{
A \em{split monomorphism} is a morphism equipped with a retraction.
}

\agda{
module _ {𝓤} {A : Type 𝓤} where

  split-mono-witness
    : {a b : A} → Hom A a b → Type (𝓘 ⊔ 𝓤)
  split-mono-witness {a} {b} f
    = Σ[ r ∶ Hom A b a ] Hom2 r f (idH a)

  SplitMono
    : A → A → Type (𝓘 ⊔ 𝓤)
  SplitMono a b = Σ[ f ∶ Hom A a b ] split-mono-witness f

  SplitMono-fwd
    : {a b : A} → SplitMono a b → Hom A a b
  SplitMono-fwd = fst

  SplitMono-ret
    : {a b : A} → SplitMono a b → Hom A b a
  SplitMono-ret = fst ∘ snd

  SplitMono-triangle
    : {a b : A}
    → (f : SplitMono a b)
    → Hom2 (SplitMono-ret f) (SplitMono-fwd f) (idH a)
  SplitMono-triangle = snd ∘ snd
}
}

\subtree[stt-00QT]{
\title{The total space of split monomorphisms}
\taxon{Definition}
\author{fredrikbakke}
\date{2026-05-13}

\agda{
TotalSplitMono
  : ∀ {𝓤} → Type 𝓤 → Type (𝓘 ⊔ 𝓤)
TotalSplitMono A = Σ[ a ∶ A ] Σ[ b ∶ A ] SplitMono a b

TotalSplitMono-sec-arr
  : ∀ {𝓤} {A : Type 𝓤}
  → TotalSplitMono A
  → (Δ¹ → A)
TotalSplitMono-sec-arr (_ , _ , f , _ , _) = f .Homᵈ.hom

TotalSplitMono-ret-arr
  : ∀ {𝓤} {A : Type 𝓤}
  → TotalSplitMono A
  → (Δ¹ → A)
TotalSplitMono-ret-arr (_ , _ , _ , r , _) = r .Homᵈ.hom
}
}

\subtree[stt-00Q9]{
\title{Characterising equality of split monomorphisms}
\taxon{Lemma}
\author{fredrikbakke}
\date{2026-05-01}

\agda{
module _ {𝓤} {A : Type 𝓤} {a b : A} where

  SplitMono-Path
    : SplitMono a b → SplitMono a b → Type (𝓘 ⊔ 𝓤)
  SplitMono-Path f g
    = Σ[ fwd＝ ∶ SplitMono-fwd f ＝ SplitMono-fwd g ]
      Σ[ ret＝ ∶ SplitMono-ret f ＝ SplitMono-ret g ]
        Idᵈ (ap₂ (λ fwd ret → Hom2 ret fwd (idH a)) fwd＝ ret＝)
            (SplitMono-triangle f)
            (SplitMono-triangle g)

  SplitMono-path→
    : {f g : SplitMono a b}
    → SplitMono-Path f g → f ＝ g
  SplitMono-path→ {f = (f , (r , η))} {g = (.f , (.r , .η))} (refl , refl , refl)
    = refl

  SplitMono-path←
    : {f g : SplitMono a b}
    → f ＝ g → SplitMono-Path f g
  SplitMono-path← refl = refl , refl , refl

  SplitMono-path→-is-equiv
    : {f g : SplitMono a b}
    → is-equiv (SplitMono-path→ {f} {g})
  SplitMono-path→-is-equiv {f} {g} = (mk-eqv qinv coh)
    where
    qinv : quasi-inv (SplitMono-path→ {f} {g})
    qinv .fst = SplitMono-path←
    qinv .snd .fst (refl , refl , refl) = refl
    qinv .snd .snd refl = refl

    coh : qinv-coh qinv
    coh (refl , refl , refl) = refl

  SplitMono-path
    : {f g : SplitMono a b}
    → SplitMono-Path f g ≃ (f ＝ g)
  SplitMono-path
    = mk≃ SplitMono-path→ SplitMono-path→-is-equiv
}
}

\subtree[stt-00R2]{
\title{Transporting split monomorphisms along endpoint paths}
\taxon{Construction}
\author{fredrikbakke}

\agda{
module _ {𝓤} {A : Type 𝓤} {a b a' b' : A} where

  adjust-split-mono-witness
    : (p : a ＝ a') (q : b ＝ b')
    → {f : Hom A a b}
    → split-mono-witness f
    → split-mono-witness (adjust-hom p q f)
  adjust-split-mono-witness p q {f} (r , η)
    = (r' , η')
    where
    r' : Hom A b' a'
    r' = adjust-hom q p r
    η' : Hom2 r' (adjust-hom p q f) (idH _)
    η' = tr (Hom2 r' (adjust-hom p q f)) (sym (adjust-idH p)) (adjust-Hom2 p q p η)

  adjust-SplitMono
    : (p : a ＝ a') (q : b ＝ b')
    → SplitMono a b
    → SplitMono a' b'
  adjust-SplitMono p q (f , f-smono)
    = (adjust-hom p q f , adjust-split-mono-witness p q f-smono)
}
}

\subtree[stt-00PJ]{
\title{Identity split monomorphisms}
\author{fredrikbakke}
\taxon{Construction}

\agda{
idH-split-mono-witness
  : ∀ {𝓤} {A : Type 𝓤}
  → (a : A)
  → split-mono-witness (idH a)
idH-split-mono-witness a = idH a , idH-Hom2 a

id-SplitMono
  : ∀ {𝓤} {A : Type 𝓤}
  → (a : A)
  → SplitMono a a
id-SplitMono a = idH a , idH-split-mono-witness a

SplitMono←Id
  : ∀ {𝓤} {A : Type 𝓤}
  → {a b : A}
  → (a ＝ b)
  → SplitMono a b
SplitMono←Id refl = id-SplitMono _
}
}

\subtree[stt-00PK]{
\title{Composition of split monomorphisms}
\author{fredrikbakke}
\taxon{Theorem}

\p{
In a Segal type split monomorphisms are closed under composition.
}

\agda{
module _ {𝓤} {A : Type 𝓤} (𝐴 : is-segal A) where

  split-mono-witness≃eq
    : {a b : A} {f : Hom A a b}
    → split-mono-witness f
    ≃ Σ[ r ∶ Hom A b a ] (r ∘[ 𝐴 ] f ＝ idH a)
  split-mono-witness≃eq = Σ-snd-≃ λ r → Hom2≃∘= 𝐴

  split-mono-witness-eq
    : {a b : A} {f : Hom A a b}
    → split-mono-witness f
    → Σ[ r ∶ Hom A b a ] (r ∘[ 𝐴 ] f ＝ idH a)
  split-mono-witness-eq = _≃_.fwd split-mono-witness≃eq

  split-mono-witness←eq
    : {a b : A} {f : Hom A a b}
    → Σ[ r ∶ Hom A b a ] (r ∘[ 𝐴 ] f ＝ idH a)
    → split-mono-witness f
  split-mono-witness←eq = _≃_.bwd split-mono-witness≃eq

  ∘-split-mono-witness
    : {a b c : A}
    → {g : Hom A b c}
    → {f : Hom A a b}
    → split-mono-witness g
    → split-mono-witness f
    → split-mono-witness (g ∘[ 𝐴 ] f)
  ∘-split-mono-witness {g = g} {f} (g⁻¹ , ηg) (f⁻¹ , ηf)
    = split-mono-witness←eq
        ( ( f⁻¹ ∘[ 𝐴 ] g⁻¹)
        , ( sym ∘[ 𝐴 ]-assoc
          ∙ ap (_∘[ 𝐴 ] f) ∘[ 𝐴 ]-assoc
          ∙ ap (λ q → (f⁻¹ ∘[ 𝐴 ] q) ∘[ 𝐴 ] f)
               (snd (split-mono-witness-eq (g⁻¹ , ηg)))
          ∙ ap (_∘[ 𝐴 ] f) ∘[ 𝐴 ]-left-unit
          ∙ snd (split-mono-witness-eq (f⁻¹ , ηf))))

  comp-SplitMono
    : {a b c : A}
    → SplitMono b c
    → SplitMono a b
    → SplitMono a c
  comp-SplitMono (g , g-smono) (f , f-smono)
    = (g ∘[ 𝐴 ] f , ∘-split-mono-witness g-smono f-smono)
}
}

\subtree[stt-00Q7]{
\title{The functorial action on split monomorphisms}
\taxon{Proposition}
\author{fredrikbakke}
\date{2026-05-01}

\agda{
module _ {𝓤 𝓥} {A : Type 𝓤} {B : Type 𝓥} (F : A → B) where

  ap-split-mono-witness
    : {a b : A} {f : Hom A a b}
    → split-mono-witness f
    → split-mono-witness (ap-hom F f)
  ap-split-mono-witness {f = f} (r , η)
    = ap-hom F r , ap-hom2 F r f (idH _) η

  ap-SplitMono
    : {a b : A} → SplitMono a b → SplitMono (F a) (F b)
  ap-SplitMono (f , f-smono)
    = ap-hom F f , ap-split-mono-witness f-smono
}

\p{The action preserves identities.}

\agda{
  ap-idH-split-mono-witness
    : (a : A) → split-mono-witness (ap-hom F (idH a))
  ap-idH-split-mono-witness a
    = ap-split-mono-witness (idH-split-mono-witness a)

  ap-id-SplitMono
    : (a : A) → SplitMono (F a) (F a)
  ap-id-SplitMono a
    = ap-SplitMono (id-SplitMono a)

  ap-id-SplitMono-fwd
    : (a : A)
    → SplitMono-fwd (ap-id-SplitMono a) ＝ SplitMono-fwd (id-SplitMono (F a))
  ap-id-SplitMono-fwd = ~refl

  ap-id-SplitMono-ret
    : (a : A)
    → SplitMono-ret (ap-id-SplitMono a) ＝ SplitMono-ret (id-SplitMono (F a))
  ap-id-SplitMono-ret = ~refl
}

\p{The action preserves composites.}

\agda{
module _
  {𝓤 𝓥 : Level} {A : Type 𝓤} {B : Type 𝓥}
  (𝐴 : is-segal A) (𝐵 : is-segal B) (F : A → B)
  where

  ap-∘-split-mono-witness
    : {a b c : A}
    → {g : Hom A b c}
    → {f : Hom A a b}
    → split-mono-witness g
    → split-mono-witness f
    → split-mono-witness (ap-hom F (g ∘[ 𝐴 ] f))
  ap-∘-split-mono-witness g-smono f-smono
    = ap-split-mono-witness F (∘-split-mono-witness 𝐴 g-smono f-smono)

  ap-comp-SplitMono
    : {a b c : A}
    → SplitMono b c
    → SplitMono a b
    → SplitMono (F a) (F c)
  ap-comp-SplitMono g f
    = ap-SplitMono F (comp-SplitMono 𝐴 g f)

  ap-comp-SplitMono-fwd
    : {a b c : A} (g : SplitMono b c) (f : SplitMono a b)
    → SplitMono-fwd (ap-comp-SplitMono g f)
    ＝ SplitMono-fwd (comp-SplitMono 𝐵 (ap-SplitMono F g) (ap-SplitMono F f))
  ap-comp-SplitMono-fwd (g , g-smono) (f , f-smono)
    = unique-composite 𝐵 (ap-hom F g) (ap-hom F f)
        (ap-hom F (g ∘[ 𝐴 ] f))
        (ap-hom2 F g f (g ∘[ 𝐴 ] f) ∘[ 𝐴 ]-is-composite)

  ap-comp-SplitMono-ret
    : {a b c : A}
    → (g : SplitMono b c)
    → (f : SplitMono a b)
    → SplitMono-ret (ap-comp-SplitMono g f)
    ＝ SplitMono-ret (comp-SplitMono 𝐵 (ap-SplitMono F g) (ap-SplitMono F f))
  ap-comp-SplitMono-ret (g , (g⁻¹ , ηg)) (f , (f⁻¹ , ηf))
    = unique-composite 𝐵 (ap-hom F f⁻¹) (ap-hom F g⁻¹)
        (ap-hom F (f⁻¹ ∘[ 𝐴 ] g⁻¹))
        (ap-hom2 F f⁻¹ g⁻¹ (f⁻¹ ∘[ 𝐴 ] g⁻¹) ∘[ 𝐴 ]-is-composite)
}
\p{
It remains to show that the action preserves composition up to equality of split
monomorphisms.
}
}

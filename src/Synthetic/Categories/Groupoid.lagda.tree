\subtree[stt-00B6]{
\title{#{\Delta^1}-discrete types}
\author{samueltoth}
\contributor{fredrikbakke}
\taxon{Definition}

\p{
A type is \em{#{\Delta^1}-discrete} if it is null at #{\Delta^1}. This forms a
#{\Sigma}-closed reflective subuniverse.
}

%```agda
\agda{
is-О”В№-discrete : вҲҖ {рқ“Ө} (A : Type рқ“Ө) вҶ’ Type (рқ“ҳ вҠ” рқ“Ө)
is-О”В№-discrete = is-null (point О”В№)

О”В№DiscreteType-SubU : вҲҖ {рқ“Ө} вҶ’ SubU рқ“Ө (рқ“Ө вҠ” рқ“ҳ)
О”В№DiscreteType-SubU = Null-SubU (point О”В№) _

О”В№DiscreteType-gSubU : gSubU (_вҠ” рқ“ҳ)
О”В№DiscreteType-gSubU = Null-gSubU (point О”В№)

О”В№DiscreteType-is-globally-reflective
  : is-globally-reflective О”В№DiscreteType-gSubU
О”В№DiscreteType-is-globally-reflective = Null-globally-reflective

О”В№DiscreteType-gRSubU : gRSubU (_вҠ” рқ“ҳ)
О”В№DiscreteType-gRSubU .gRSubU.GS = О”В№DiscreteType-gSubU
О”В№DiscreteType-gRSubU .gRSubU.has-is-globally-reflective = О”В№DiscreteType-is-globally-reflective

open gSubU О”В№DiscreteType-gSubU public using () renaming
  ( вҲҲSвҶҗequiv to is-О”В№-discreteвҶҗequiv)

open gReflectiveClosure О”В№DiscreteType-gRSubU public using () renaming
  ( О вҲҲS to О -is-О”В№-discrete
  ; ULiftвҲҲS to ULift-is-О”В№-discrete
  ; рқҹҷвҲҲS to рқҹҷ-is-О”В№-discrete
  ; вҲҲSвҶҗis-singleton to is-О”В№-discreteвҶҗis-singleton
  ; вҲҲSвҶҗretract to is-О”В№-discreteвҶҗretract
  ; PullbackвҲҲS to Pullback-is-О”В№-discrete
  ; fibreвҲҲS to fibre-is-О”В№-discrete
  ; Г—вҲҲS to Г—-is-О”В№-discrete
  ; пјқвҲҲS to пјқ-is-О”В№-discrete
  ; ~вҲҲS to ~-is-О”В№-discrete
  ; retractвҲҲS to retract-is-О”В№-discrete
  ; biinvвҲҲS to biinv-is-О”В№-discrete
  ; вүғвҲҲS to вүғ-is-О”В№-discrete
  ; EqualiserвҲҲS to Equaliser-is-О”В№-discrete
  ; Seq-limвҲҲS to Seq-lim-is-О”В№-discrete
  ; preidempotent-mapвҲҲS to preidempotent-map-is-О”В№-discrete
  ; qidempotent-mapвҲҲS to qidempotent-map-is-О”В№-discrete
  ; RetractsвҲҲS to Retracts-is-О”В№-discrete)

ОЈ-is-О”В№-discrete : is-globally-ОЈ-closed О”В№DiscreteType-gSubU
ОЈ-is-О”В№-discrete = Null-globally-ОЈ-closed

module О”В№Disc where

  open gSubU О”В№DiscreteType-gSubU public using ()
  open gRSubUInduction О”В№DiscreteType-gRSubU ОЈ-is-О”В№-discrete public
  open gReflectiveClosure О”В№DiscreteType-gRSubU public
  open gRSubU О”В№DiscreteType-gRSubU public
}
%```

%```agda
\agda{
HomвҶҗId
  : вҲҖ {рқ“Ө} {A : Type рқ“Ө} вҶ’ вҲҖ {a b} вҶ’ a пјқ b вҶ’ Hom A a b
HomвҶҗId refl = idH _

Hom-О”В№-discrete
  : вҲҖ {рқ“Ө} {A : Type рқ“Ө} вҶ’ is-О”В№-discrete A
  вҶ’ вҲҖ {a b} вҶ’ is-equiv (HomвҶҗId {_}{A}{a}{b})
Hom-О”В№-discrete О”В№-discrete {a} {b}
  = is-equiv~вҲҳ {f = _вүғ_.bwd HomбөҲ-reprвүғ} {g = g вҲҳ f}
      (О» where refl вҶ’ refl)
      (is-equivвҒ»В№ (_вүғ_.has-is-eqv HomбөҲ-reprвүғ))
      (is-equiv-вҲҳ {f = g} {g = f}
        (total-is-equivвҶҗfst-is-equiv (О”В№-discrete tt))
        (is-equivвҒ»В№ (ОЈ-пјқsingl ._вүғ_.has-is-eqv))) where
  f : a пјқ b вҶ’ ОЈ[ c вҲ¶ _ ] ((c пјқ a) Г— (c пјқ b))
  f = _вүғ_.bwd ОЈ-пјқsingl
  g : ОЈ[ c вҲ¶ _ ] ((c пјқ a) Г— (c пјқ b))
    вҶ’ ОЈ[ g вҲ¶ (О”В№ вҶ’ _) ] ОЈ (g i0 пјқ a) (О» hom2 вҶ’ g i1 пјқ b)
  g (a , p , q) = (const _ _ a , p , q)
}

open import Synthetic.Boundaries Δ¹ I I-distr
open import Synthetic.Horns Δ¹ I I-distr
open import Synthetic.Categories.Precategories Δ¹ I I-distr
open import Synthetic.Categories.SpineLifting Δ¹ I I-distr

open import Algebra.Lattice.Instances.Free.Inductive Δ¹ I
}

\subtree[fre-0001]{
\title{Necklaces}
\taxon{Definition}

\agda{
data Necklace-shape : Type where
  nckl-splx : ℕ → Necklace-shape
  nckl-cons : ℕ → Necklace-shape → Necklace-shape

Necklace-length : Necklace-shape → ℕ
Necklace-length (nckl-splx n) = n
Necklace-length (nckl-cons m N) = m +ℕ Necklace-length N

Necklace-coslice : Necklace-shape → Σ[ X ∶ Type 𝓘 ] (∂Δ¹ → X)
Necklace-coslice (nckl-splx n)
  = (Δ^ n , ∂Δ^ n)
Necklace-coslice (nckl-cons m N)
  = ∂Δ¹-Wedge (∂Δ^ m) (Necklace-coslice N .snd)

Necklace : Necklace-shape → Type 𝓘
Necklace N = Necklace-coslice N .fst

Necklace-boundary
  : (N : Necklace-shape) → ∂Δ¹ → Necklace N
Necklace-boundary N = Necklace-coslice N .snd

Necklace-is-0-truncated
  : (N : Necklace-shape) → is-truncated 0 (Necklace N)
Necklace-is-0-truncated (nckl-splx n)
  = Δ-is-0-truncated
Necklace-is-0-truncated (nckl-cons m N)
  = Wedge-is-0-truncated Δ-is-0-truncated (Necklace-is-0-truncated N)

Necklace-is-set
  : (N : Necklace-shape) → is-set (Necklace N)
Necklace-is-set N
  = is-set←is-truncated (Necklace-is-0-truncated N)
}
}

\subtree[stt-00JV]{
\title{Sharp codiscrete maps lift crisply against the flat counit}
\taxon{Lemma}

\citet{3.1.2}{MR23}

\p{This follows straightforwardly from the fact that for any reflective
subuniverse, connected and modal maps are the (respectively) left and right
classes of an orthogonal factorisation system, and the fact that
#{\varepsilon} is a #{\sharp}-connected map.}

\agda{
lifts-ОөвҷӯвҶҗis-вҷҜ-codiscrete
  : вҲҖ {@вҷӯ рқ“Ө рқ“Ҙ} {@вҷӯ A : Type рқ“Ө} {@вҷӯ B : Type рқ“Ҙ} {@вҷӯ f : A вҶ’ B}
    вҶ’ @вҷӯ is-вҷҜ-codiscrete-map f
    вҶ’ (вҲҖ {@вҷӯ рқ“ } {@вҷӯ Q : Type рқ“ } вҶ’ are-вҷӯ-orthogonal (Оөвҷӯ: Q) f)
lifts-ОөвҷӯвҶҗis-вҷҜ-codiscrete {f = f} fcd {_} {Q}
  = вҷӯ-is-cartesian (power-hom Оөвҷӯ f)
      (is-cartesianвҶҗare-orthogonal
        (gRSubUConnectedCharacterisation.connectedвҠҘmodal вҷҜ-gRSubU
          (is-вҷҜ-connectedвҶҗis-вҷҜ-equiv Оө-is-вҷҜ-equiv)
          fcd))
}
}


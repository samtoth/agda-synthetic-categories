open import Ergonomics.Extensionality
open import Ergonomics.Marker
}
% ```


\subtree[stt-002S]{
\taxon{Definition}
\title{Joins of types}

\p{The join of types #{A} and #{B}, written #{A * B} is
the pushout of the span
#{A \xleftarrow{\pi_1} A \times B \xrightarrow{\pi_2} B}}

\quiver{
\begin{tikzcd}
	{A \times B} && A \\
	\\
	B && {A * B}
	\arrow[from=1-1, to=1-3]
	\arrow[from=1-1, to=3-1]
	\arrow[from=1-3, to=3-3]
	\arrow[from=3-1, to=3-3]
	\arrow["\lrcorner"{anchor=center, pos=0.125, rotate=180}, draw=none, from=3-3, to=1-1]
\end{tikzcd}
}

% ```agda
\agda{
infixl 25 _*_

_*_ : вИА {рЭУ§ рЭУ•} вЖТ Type рЭУ§ вЖТ Type рЭУ• вЖТ Type (рЭУ§ вКФ рЭУ•)
A * B = Pushout {A = A √Ч B} fst snd
}
% ```
}


\subtree[stt-002V]{
\title{Singleton joins}

\p{The join of a singleton with any type is also a singleton}

\proof{
\p{This follows from the fact that [pushing an equivalence out gives
an equivalence](stt-0080).}
}

% ```agda
\agda{
*-comm : вИА {рЭУ§ рЭУ•} {A : Type рЭУ§} {B : Type рЭУ•} вЖТ A * B вЙГ B * A
*-comm {A = A} {B} = pushout-comm вИЩвЙГ (Pushout-adjust-equiv √Ч-swap)


*-single' : вИА {рЭУ§ рЭУ•} {A : Type рЭУ§} {B : Type рЭУ•}
            вЖТ is-singleton B вЖТ is-singleton (A * B)
*-single' {A = A} {B} sb
  = is-singleвЖРequiv-to-single (mkвЙГ _ ќєвВВ-is-equiv) sb where
  ќєвВВ-is-equiv : is-equiv {B = A * B} ќєвВВ
  ќєвВВ-is-equiv = dom-is-equivвЖРcocartesian
                  (mk-amap snd ќєвВБ glue)
                  (singleton-fst-is-equiv (ќї _ вЖТ sb))
                  (is-cocartesianвЖРis-pushout Pushout-is-pushoutѕЙ)

*-single : вИА {рЭУ§ рЭУ•} {A : Type рЭУ§} {B : Type рЭУ•}
           вЖТ is-singleton A вЖТ is-singleton (A * B)
*-single sa
  = is-singleвЖРequiv-to-single *-comm (*-single' sa)
}
% ```
}

\subtree[stt-002W]{
\taxon{Theorem}
\title{Joins of propositions}

\p{The universal property for joins of propositions says that
for propositions #{P} and #{Q}, to eliminate into a proposition #{R},
it suffices to supply #{P \to R}, and #{Q \to R}}

\p{As an easy corollary, we have that the join of two propositions
is again a proposition.}

% ```agda
\agda{
*-prop-disj : вИА {рЭУ§ рЭУ• рЭУ¶} {A : Type рЭУ§} {B : Type рЭУ•}
              {Q : Type рЭУ¶}
           вЖТ is-prop A вЖТ is-prop B
           вЖТ is-prop Q
           вЖТ (A * B вЖТ Q) вЖТ (A вЖТ Q) √Ч (B вЖТ Q)
*-prop-disj a b q f = (f вИШ ќєвВБ , f вИШ ќєвВВ)


*-prop-disjвЙГ : вИА {рЭУ§ рЭУ• рЭУ¶}
              {A : Type рЭУ§} {B : Type рЭУ•} {Q : Type рЭУ¶}
           вЖТ (pq : is-prop Q)
           вЖТ (A * B вЖТ Q) вЙГ ((A вЖТ Q) √Ч (B вЖТ Q))
*-prop-disjвЙГ {A = A} {B} {Q} pq
 = (A * B вЖТ Q)
      вЙГвЯ® Pushout-UPвЙГ вЯ©
   Cocone (mk-span _ fst snd) Q
      вЙГвЯ® cocone-reprвЙГ вЯ©
   ќ£[ f вИґ (A вЖТ Q) ] ќ£[ g вИґ (B вЖТ Q) ] (f вИШ fst ~ g вИШ snd)
      вЙГвЯ® ќ£-ap-вЙГ (ќї f вЖТ ќ£-ap-вЙГ (ќї g вЖТ curryвЙГ)) вЯ©
   ќ£[ f вИґ (A вЖТ Q) ] ќ£[ g вИґ (B вЖТ Q) ] ((a : A) (b : B) вЖТ f a пЉЭ g b)
      вЙГвЯ® ќ£-ap-вЙГ (ќї a вЖТ ќ£-singleton (ќї x вЖТ ќ†-is-single ќї
                     b вЖТ ќ†-is-single (ќї
                       c вЖТ пЉЭ-is-singleвЖРis-prop pq _ _))) вЯ©
   ((A вЖТ Q) √Ч (B вЖТ Q)) вЙГвИО

*-prop-UP : вИА {рЭУ§ рЭУ• рЭУ¶} {A : Type рЭУ§} {B : Type рЭУ•}
              {Q : Type рЭУ¶}
              (ap : is-prop A) (bp : is-prop B)
              (qp : is-prop Q)
            вЖТ is-equiv (*-prop-disj ap bp qp)
*-prop-UP ap bp qp = *-prop-disjвЙГ qp ._вЙГ_.has-is-eqv

opaque
  *-prop-rec
    : вИА {рЭУ§ рЭУ• рЭУ¶}
        {A : Type рЭУ§} {B : Type рЭУ•} {Q : Type рЭУ¶}
      вЖТ (pq : is-prop Q)
      вЖТ (A вЖТ Q) вЖТ (B вЖТ Q) вЖТ (A * B вЖТ Q)
  *-prop-rec pq f g = _вЙГ_.bwd (*-prop-disjвЙГ pq) (f , g)
{-# NOINLINE *-prop-rec #-}

*-is-prop : вИА {рЭУ§ рЭУ•} {A : Type рЭУ§} {B : Type рЭУ•}
            вЖТ is-prop A вЖТ is-prop B
            вЖТ is-prop (A * B)
*-is-prop aprop bprop = is-propвЖРis-single-if-inhabited
  (*-prop-rec is-single-is-prop
    (ќї a вЖТ *-single (mk-singl a (aprop a)))
    (ќї b вЖТ *-single' (mk-singl b (bprop b))))
}
% ```
}


\subtree[stt-009U]{
\title{Joins with the empty type}

\p{The join #{A * 0} for any type #{A} is equivalent to #{A}.}

\proof{The map #{A \times 0 \to 0} is an equivalence so by
\ref{stt-008O}, so must #{A \to A * 0}.}

%```agda
\agda{
*-вИЕ : вИА {рЭУ§} {A : Type рЭУ§} вЖТ A вЙГ вИЕ * A
*-вИЕ = mkвЙГ ќєвВВ (dom-is-equivвЖРcocartesian (mk-amap snd ќєвВБ glue)
             (√Ч-вИЕ ._вЙГ_.has-is-eqv) (is-cocartesianвЖРis-pushout
                                     Pushout-is-pushoutѕЙ))
}
%```
}

\subtree[stt-009L]{
\title{Functoriality of the join}
\taxon{Theorem}

\p{The join operator on types defines a functor
#{\SS \times \SS \to \SS}. We define the action of #{*} on functions,
and show that it preserves equivalences.}

%```agda
\agda{
_*вВБ_ : вИА {рЭУ§ рЭУЬ рЭУ• рЭУ¶} {A : Type рЭУ§} {A' : Type рЭУЬ}
         {B : Type рЭУ•} {B' : Type рЭУ¶}
       вЖТ (A вЖТ A') вЖТ (B вЖТ B') вЖТ A * B вЖТ A' * B'
f *вВБ g = pushout-rec (mk-cocone (ќєвВБ вИШ f) (ќєвВВ вИШ g) (glue вИШ (f вКЧ g)))

*вВБ-is-equiv : вИА {рЭУ§ рЭУЬ рЭУ• рЭУ¶} {A : Type рЭУ§} {A' : Type рЭУЬ}
                {B : Type рЭУ•} {B' : Type рЭУ¶}
              вЖТ {f : A вЖТ A'} {g : B вЖТ B'}
              вЖТ is-equiv f вЖТ is-equiv g
              вЖТ is-equiv (f *вВБ g)
*вВБ-is-equiv {A = A}{B = B}{f = f} {g} feq geq = is-equivвЖРqiso iso where
  module f = is-equiv feq
  module g = is-equiv geq


  opaque
    sec : вИА a вЖТ
        Square (ap ((f *вВБ g) вИШ (f.bwd *вВБ g.bwd)) (glue a))
               (ap id (glue a))
               (((ќєвВБ вЧВ f.ќµ) вИШ fst) a)
               (((ќєвВВ вЧВ g.ќµ) вИШ snd) a)
    sec p@(a , b) = mk-square (
      вМЬ ap ((f *вВБ g) вИШ (f.bwd *вВБ g.bwd)) (glue p) вМЭ вИЩ ((ќєвВВ вЧВ g.ќµ) b)
                                    пЉЭвЯ® ap! (ap-вИШ _ _ (glue p)) вЯ©
      ap (f *вВБ g) вМЬ ap (f.bwd *вВБ g.bwd) (glue p) вМЭ вИЩ ((ќєвВВ вЧВ g.ќµ) b)
                                    пЉЭвЯ® ap! (pushout-rec-apќ≤ p) вЯ©
      вМЬ ap (f *вВБ g) (glue (f.bwd a , g.bwd b)) вМЭ вИЩ ((ќєвВВ вЧВ g.ќµ) b)
                                    пЉЭвЯ® ap! (pushout-rec-apќ≤ ((f.bwd вКЧ g.bwd) p)) вЯ©
      (glue вИШ (f вКЧ g) вИШ (f.bwd вКЧ g.bwd)) p вИЩ (вМЬ ќєвВВ вЧВ g.ќµ вЦЄ snd вМЭ) p
                                    пЉЭвЯ® ap! ( sym (ap-вИШ ќєвВВ snd (√Ч-pathвЖТ (f.ќµ a , g.ќµ b))
                                            вИЩ ap (ap ќєвВВ) √Ч-path-ap-snd)) вЯ©
      ((glue вИШ (f вКЧ g) вИШ (f.bwd вКЧ g.bwd)) ~вИЩ (ќєвВВ вИШ snd вЧВ √Ч~ (f.ќµ , g.ќµ))) p
                                    пЉЭвЯ®вЯ©
      (glue ~вИШ √Ч~ (f.ќµ , g.ќµ)) p    пЉЭвЯ® switch-~вИШ glue (√Ч~ (f.ќµ , g.ќµ)) p вЯ©
      (glue ~вИШ' √Ч~ (f.ќµ , g.ќµ)) p   пЉЭвЯ® ap (_вИЩ glue p) (ap-вИШ ќєвВБ fst (√Ч~ (f.ќµ , g.ќµ) p)) вЯ©
       ((ќєвВБ вЧВ fst вЧВ √Ч~ (f.ќµ , g.ќµ)) ~вИЩ glue) p
                                    пЉЭвЯ® ap (ќї x вЖТ (ap ќєвВБ x) вИЩ glue p) √Ч-path-ap-fst вЯ©
      ap ќєвВБ (f.ќµ a) вИЩ вМЬ glue p вМЭ    пЉЭвЯ® ap! (sym (ap-id (glue p))) вЯ©
      ap ќєвВБ (f.ќµ a) вИЩ ap id (glue p) вИО)

    -- I wanted to generalise sec, and then give f.bwd and g.bwd
    -- but because is-equivвБї¬є goes via composing quasi-inverses it
    -- messes with the ќµ
    ret : вИА a вЖТ
        Square (ap ((f.bwd *вВБ g.bwd) вИШ (f *вВБ g)) (glue a))
               (ap id (glue a))
               (((ќєвВБ вЧВ f.ќЈ) вИШ fst) a)
               (((ќєвВВ вЧВ g.ќЈ) вИШ snd) a)
    ret p@(a , b) = mk-square (
        вМЬ ap ((f.bwd *вВБ g.bwd) вИШ (f *вВБ g)) (glue p) вМЭ вИЩ ((ќєвВВ вЧВ g.ќЈ) b)
                                      пЉЭвЯ® ap! (ap-вИШ _ _ (glue p)) вЯ©
        ap (f.bwd *вВБ g.bwd) вМЬ ap (f *вВБ g) (glue p) вМЭ вИЩ ((ќєвВВ вЧВ g.ќЈ) b)
                                      пЉЭвЯ® ap! (pushout-rec-apќ≤ p) вЯ©
        вМЬ ap (f.bwd *вВБ g.bwd) (glue (f a , g b)) вМЭ вИЩ ((ќєвВВ вЧВ g.ќЈ) b)
                                      пЉЭвЯ® ap! (pushout-rec-apќ≤ ((f вКЧ g) p)) вЯ©
        (glue вИШ (f.bwd вКЧ g.bwd) вИШ (f вКЧ g)) p вИЩ (вМЬ ќєвВВ вЧВ g.ќЈ вЦЄ snd вМЭ) p
                                      пЉЭвЯ® ap! ( sym (ap-вИШ ќєвВВ snd (√Ч-pathвЖТ (f.ќЈ a , g.ќЈ b))
                                              вИЩ ap (ap ќєвВВ) √Ч-path-ap-snd)) вЯ©
        ((glue вИШ (f.bwd вКЧ g.bwd) вИШ (f вКЧ g)) ~вИЩ (ќєвВВ вИШ snd вЧВ √Ч~ (f.ќЈ , g.ќЈ))) p
                                      пЉЭвЯ®вЯ©
        (glue ~вИШ √Ч~ (f.ќЈ , g.ќЈ)) p    пЉЭвЯ® switch-~вИШ glue (√Ч~ (f.ќЈ , g.ќЈ)) p вЯ©
        (glue ~вИШ' √Ч~ (f.ќЈ , g.ќЈ)) p   пЉЭвЯ® ap (_вИЩ glue p) (ap-вИШ ќєвВБ fst (√Ч~ (f.ќЈ , g.ќЈ) p)) вЯ©
         ((ќєвВБ вЧВ fst вЧВ √Ч~ (f.ќЈ , g.ќЈ)) ~вИЩ glue) p
                                      пЉЭвЯ® ap (ќї x вЖТ (ap ќєвВБ x) вИЩ glue p) √Ч-path-ap-fst вЯ©
        ap ќєвВБ (f.ќЈ a) вИЩ вМЬ glue p вМЭ    пЉЭвЯ® ap! (sym (ap-id (glue p))) вЯ©
        ap ќєвВБ (f.ќЈ a) вИЩ ap id (glue p) вИО)

  iso : quasi-iso (f *вВБ g)
  iso .fst = f.bwd *вВБ g.bwd
  iso .snd .fst = pushout-ind _ (mk-coconeбµИ (ќєвВБ вЧВ f.ќЈ) (ќєвВВ вЧВ g.ќЈ)
                    ќї a вЖТ IdбµИ-funcвЖРSquare
                           {f = (f.bwd *вВБ g.bwd) вИШ (f *вВБ g)}
                           {id} (glue a)
                           (ap ќєвВБ (f.ќЈ (fst a))) ((ќєвВВ вЧВ g.ќЈ) (snd a))
                           (ret a))
  iso .snd .snd = pushout-ind _ (mk-coconeбµИ (ќєвВБ вЧВ f.ќµ) (ќєвВВ вЧВ g.ќµ)
                   (ќї a вЖТ  IdбµИ-funcвЖРSquare {f = (f *вВБ g) вИШ (f.bwd *вВБ g.bwd)} {id}
                               (glue a) _ _
                               (sec a)))

*-вЙГ : вИА {рЭУ§ рЭУ• рЭУ¶ рЭУЬ} {A : Type рЭУ§} {B : Type рЭУ•} {C : Type рЭУ¶} {D : Type рЭУЬ}
      вЖТ A вЙГ C вЖТ B вЙГ D вЖТ A * B вЙГ C * D
*-вЙГ (mkвЙГ l le) (mkвЙГ r re)
  = mkвЙГ (l *вВБ r) (*вВБ-is-equiv le re)
}
%```
}

\subtree[stt-00FH]{
\taxon{Theorem}
\date{2026-03-06}
\author{fredrikbakke}
\title{Null-homotopies of maps out of a join}

\p{
Given a map #{q : A * B \to Q}, each point #{a : A} determines a
[null-homotopy](stt-00F3) of the restriction #{q \circ \iota_2 : B \to Q}. Moreover,
null-homotopies of #{q} are equivalent to null-homotopies of this induced family over
#{A}.
}

%```agda
\agda{
join-null-homotopy-at
  : {рЭУ§ рЭУ• рЭУ¶ : Level}
    {A : Type рЭУ§} {B : Type рЭУ•} {Q : Type рЭУ¶}
  вЖТ (q : A * B вЖТ Q)
  вЖТ A
  вЖТ null-homotopy (q вИШ ќєвВВ)
join-null-homotopy-at q a .fst = q (ќєвВБ a)
join-null-homotopy-at q a .snd b = ap q (glue (a , b))

join-recвЙГnull-homotopies
  : {рЭУ§ рЭУ• рЭУ¶ : Level}
    {A : Type рЭУ§} {B : Type рЭУ•} {Q : Type рЭУ¶}
  вЖТ (A * B вЖТ Q)
  вЙГ ќ£[ r вИґ (B вЖТ Q) ] ((a : A) вЖТ null-homotopy r)
join-recвЙГnull-homotopies {A = A} {B} {Q}
  = (A * B вЖТ Q)
      вЙГвЯ® Pushout-UPвЙГ вЯ©
    Cocone (mk-span _ fst snd) Q
      вЙГвЯ® cocone-reprвЙГ вЯ©
    ќ£[ l вИґ (A вЖТ Q) ] ќ£[ r вИґ (B вЖТ Q) ] (l вИШ fst ~ r вИШ snd)
      вЙГвЯ® ќ£-ap-вЙГ (ќї l вЖТ ќ£-ap-вЙГ (ќї r вЖТ curryвЙГ)) вЯ©
    ќ£[ l вИґ (A вЖТ Q) ] ќ£[ r вИґ (B вЖТ Q) ] ((a : A) (b : B) вЖТ l a пЉЭ r b)
      вЙГвЯ® ќ£-comm вЯ©
    ќ£[ r вИґ (B вЖТ Q) ] ќ£[ l вИґ (A вЖТ Q) ] ((a : A) (b : B) вЖТ l a пЉЭ r b)
      вЙГвЯ® ќ£-ap-вЙГ (ќї r вЖТ ќ£-ќ†-swapвЙГ (ќї _ вЖТ Q) (ќї a q вЖТ (b : B) вЖТ q пЉЭ r b) eвБї¬є) вЯ©
    ќ£[ r вИґ (B вЖТ Q) ] ((a : A) вЖТ ќ£[ q вИґ Q ] ((b : B) вЖТ q пЉЭ r b))
      вЙГвЯ®вЯ©
    ќ£[ r вИґ (B вЖТ Q) ] ((a : A) вЖТ null-homotopy r)
      вЙГвИО

join-recбµИвЙГnull-homotopies
  : {рЭУ§1 рЭУ§2 рЭУ§3 рЭУ§4 рЭУ§5 : Level}
    {A : Type рЭУ§1}
    {X : A вЖТ Type рЭУ§2}
    {B : A вЖТ Type рЭУ§3}
    {Y : (a : A) вЖТ X a вЖТ Type рЭУ§4}
    {Q : (a : A) (x : X a) вЖТ Type рЭУ§5}
  вЖТ ((a : A) (x : X a) вЖТ B a * Y a x вЖТ Q a x)
  вЙГ ќ£[ r вИґ ((a : A) (x : X a) вЖТ Y a x вЖТ Q a x) ]
      ((a : A) (b : B a) (x : X a) вЖТ null-homotopy (r a x))
join-recбµИвЙГnull-homotopies
  {A = A} {X} {B} {Y} {Q}
  = ((a : A) (x : X a) вЖТ B a * Y a x вЖТ Q a x)
      вЙГвЯ® ќ†-ap-вЙГ (ќї a вЖТ ќ†-ap-вЙГ (ќї _ вЖТ join-recвЙГnull-homotopies)) вЯ©
    ((a : A) (x : X a) вЖТ ќ£[ r вИґ (Y a x вЖТ Q a x) ] ((b : B a) вЖТ null-homotopy r))
      вЙГвЯ® ќ†-ap-вЙГ
            ( ќї a
              вЖТ ќ£-ќ†-swapвЙГ
                  (ќї x вЖТ Y a x вЖТ Q a x)
                  (ќї x r вЖТ (b : B a) вЖТ null-homotopy r)) вЯ©
    ((a : A)
      вЖТ ќ£[ r вИґ ((x : X a) вЖТ Y a x вЖТ Q a x) ]
          ((x : X a) вЖТ (b : B a) вЖТ null-homotopy (r x)))
      вЙГвЯ® ќ£-ќ†-swapвЙГ
            (ќї a вЖТ (x : X a) вЖТ Y a x вЖТ Q a x)
            (ќї a r вЖТ (x : X a) (b : B a) вЖТ null-homotopy (r x)) вЯ©
    (ќ£[ r вИґ ((a : A) (x : X a) вЖТ Y a x вЖТ Q a x) ]
      ((a : A) вЖТ (x : X a) (b : B a) вЖТ null-homotopy (r a x)))
      вЙГвЯ® ќ£-ap-вЙГ (ќї _ вЖТ ќ†-ap-вЙГ (ќї _ вЖТ flipвЙГ)) вЯ©
    (ќ£[ r вИґ ((a : A) (x : X a) вЖТ Y a x вЖТ Q a x) ]
      ((a : A) вЖТ (b : B a) (x : X a) вЖТ null-homotopy (r a x)))
      вЙГвИО

module _
  {рЭУ§ рЭУ• рЭУ¶ : Level}
  {A : Type рЭУ§} {B : Type рЭУ•} {Q : Type рЭУ¶}
  (q : A * B вЖТ Q)
  (l : Q)
  where

  join-path-from-left
    : (a : A)
    вЖТ const Q B (q (ќєвВБ a)) ~ q вИШ ќєвВВ
  join-path-from-left a b = ap q (glue (a , b))

  join-ind-pathsвЙГnull-homotopy-inner-over
    : (r : (b : B) вЖТ l пЉЭ q (ќєвВВ b))
    вЖТ (a : A)
    вЖТ (ќ£[ t вИґ l пЉЭ q (ќєвВБ a) ]
        ((b : B) вЖТ IdбµИ (ap (ќї j вЖТ l пЉЭ q j) (glue (a , b))) t (r b)))
    вЙГ ((l , r) пЉЭ join-null-homotopy-at q a)
  join-ind-pathsвЙГnull-homotopy-inner-over r a
    = (ќ£[ t вИґ l пЉЭ q (ќєвВБ a) ]
        ((b : B) вЖТ IdбµИ (ap (ќї j вЖТ l пЉЭ q j) (glue (a , b))) t (r b)))
        вЙГвЯ® ќ£-ap-вЙГ (ќї t вЖТ ќ†-ap-вЙГ (ќї b вЖТ IdбµИ-const-вЙГ' q (glue (a , b)) t (r b))) вЯ©
      (ќ£[ t вИґ l пЉЭ q (ќєвВБ a) ]
        ((b : B) вЖТ t вИЩ join-path-from-left a b пЉЭ r b))
        вЙГвЯ® null-homotopy-pathвЙГ
              {f = q вИШ ќєвВВ}
              r
              (join-path-from-left a)
              eвБї¬є вЯ©
      ((l , r) пЉЭ join-null-homotopy-at q a)
        вЙГвИО

  join-ind-pathsвЙГnull-homotopy-inner
    : (r : (b : B) вЖТ l пЉЭ q (ќєвВВ b))
    вЖТ (ќ£[ t вИґ ((a : A) вЖТ l пЉЭ q (ќєвВБ a)) ]
        (((a , b) : A √Ч B) вЖТ IdбµИ (ap (ќї j вЖТ l пЉЭ q j) (glue (a , b))) (t a) (r b)))
    вЙГ ((a : A) вЖТ (l , r) пЉЭ join-null-homotopy-at q a)
  join-ind-pathsвЙГnull-homotopy-inner r
    = (ќ£[ t вИґ ((a : A) вЖТ l пЉЭ q (ќєвВБ a)) ]
        (((a , b) : A √Ч B) вЖТ IdбµИ (ap (ќї j вЖТ l пЉЭ q j) (glue (a , b))) (t a) (r b)))
        вЙГвЯ® ќ£-ap-вЙГ (ќї t вЖТ curryвЙГ) вЯ©
      (ќ£[ t вИґ ((a : A) вЖТ l пЉЭ q (ќєвВБ a)) ]
        ((a : A) (b : B) вЖТ IdбµИ (ap (ќї j вЖТ l пЉЭ q j) (glue (a , b))) (t a) (r b)))
        вЙГвЯ® ќ£-ќ†-swapвЙГ
              (ќї a вЖТ l пЉЭ q (ќєвВБ a))
              (ќї a t вЖТ (b : B) вЖТ IdбµИ (ap (ќї j вЖТ l пЉЭ q j) (glue (a , b))) t (r b))
              eвБї¬є вЯ©
      ((a : A)
        вЖТ ќ£[ t вИґ l пЉЭ q (ќєвВБ a) ]
          ((b : B) вЖТ IdбµИ (ap (ќї j вЖТ l пЉЭ q j) (glue (a , b))) t (r b)))
        вЙГвЯ® ќ†-ap-вЙГ (join-ind-pathsвЙГnull-homotopy-inner-over r) вЯ©
      ((a : A) вЖТ (l , r) пЉЭ join-null-homotopy-at q a)
        вЙГвИО

  join-ind-pathsвЙГnull-homotopy-at
    : (((j : A * B) вЖТ l пЉЭ q j))
    вЙГ (ќ£[ r вИґ ((b : B) вЖТ l пЉЭ q (ќєвВВ b)) ]
        ((a : A) вЖТ (l , r) пЉЭ join-null-homotopy-at q a))
  join-ind-pathsвЙГnull-homotopy-at
    = (((j : A * B) вЖТ l пЉЭ q j))
        вЙГвЯ® Pushout-UPбµИвЙГ eвБї¬є вЯ©
      CoconeбµИ (mk-span _ fst snd) pushout (ќї j вЖТ l пЉЭ q j)
        вЙГвЯ® coconeD-reprвЙГ вЯ©
      (ќ£[ t вИґ ((a : A) вЖТ l пЉЭ q (ќєвВБ a)) ]
       ќ£[ r вИґ ((b : B) вЖТ l пЉЭ q (ќєвВВ b)) ]
         (((a , b) : A √Ч B) вЖТ IdбµИ (ap (ќї j вЖТ l пЉЭ q j) (glue (a , b))) (t a) (r b)))
        вЙГвЯ® ќ£-comm вЯ©
      (ќ£[ r вИґ ((b : B) вЖТ l пЉЭ q (ќєвВВ b)) ]
       ќ£[ t вИґ ((a : A) вЖТ l пЉЭ q (ќєвВБ a)) ]
         (((a , b) : A √Ч B) вЖТ IdбµИ (ap (ќї j вЖТ l пЉЭ q j) (glue (a , b))) (t a) (r b)))
        вЙГвЯ® ќ£-ap-вЙГ join-ind-pathsвЙГnull-homotopy-inner вЯ©
      (ќ£[ r вИґ ((b : B) вЖТ l пЉЭ q (ќєвВВ b)) ]
        ((a : A) вЖТ (l , r) пЉЭ join-null-homotopy-at q a))
        вЙГвИО

join-null-homotopiesвЙГ
  : {рЭУ§ рЭУ• рЭУ¶ : Level}
    {A : Type рЭУ§} {B : Type рЭУ•} {Q : Type рЭУ¶}
  вЖТ (q : A * B вЖТ Q)
  вЖТ null-homotopy q вЙГ null-homotopy (join-null-homotopy-at q)
join-null-homotopiesвЙГ {A = A} {B} {Q} q
  = null-homotopy q
      вЙГвЯ® ќ£-ap-вЙГ (join-ind-pathsвЙГnull-homotopy-at q) вЯ©
    (ќ£[ l вИґ Q ]
     ќ£[ r вИґ ((b : B) вЖТ l пЉЭ q (ќєвВВ b)) ]
       ((a : A) вЖТ (l , r) пЉЭ join-null-homotopy-at q a))
      вЙГвЯ® ќ£-assoc eвБї¬є вЯ©
    null-homotopy (join-null-homotopy-at q)
      вЙГвИО

join-null-homotopiesбµИвЙГ
  : {рЭУ§ рЭУ• рЭУ¶ рЭУ† : Level}
    {X : Type рЭУ§}
    {B : Type рЭУ•}
    {Y : X вЖТ Type рЭУ¶}
    {Q : X вЖТ Type рЭУ†}
  вЖТ (q : (x : X) вЖТ B * Y x вЖТ Q x)
  вЖТ ((x : X) вЖТ null-homotopy (q x))
  вЙГ null-homotopy (ќї b x вЖТ join-null-homotopy-at (q x) b)
join-null-homotopiesбµИвЙГ {X = X} q
  = ((x : X) вЖТ null-homotopy (q x))
      вЙГвЯ® ќ†-ap-вЙГ (ќї x вЖТ join-null-homotopiesвЙГ (q x)) вЯ©
    ((x : X) вЖТ null-homotopy (join-null-homotopy-at (q x)))
      вЙГвЯ® null-homotopy-curryвЙГ (ќї x b вЖТ join-null-homotopy-at (q x) b) вЯ©
    null-homotopy (ќї b x вЖТ join-null-homotopy-at (q x) b)
      вЙГвИО
}

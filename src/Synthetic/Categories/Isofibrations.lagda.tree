\subtree[fre-00N4]{
\title{Isofibrations}
\author{fredrikbakke}
\taxon{Definition}
\date{2026-04-13}

\p{
A map is an \em{isofibration} if it is right orthogonal to the inclusion of the
source object into the walking isomorphism.
}

\agda{
is-isofibration
  : ∀ {𝓤 𝓥} {A : Type 𝓤} {B : Type 𝓥}
  → (A → B)
  → Type (𝓘 ⊔ 𝓤 ⊔ 𝓥)
is-isofibration f = point src-ℑ ⊥ f
}
}

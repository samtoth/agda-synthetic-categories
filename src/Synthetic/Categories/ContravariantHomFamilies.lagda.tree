\subtree[stt-00O7]{
\title{Straightening Hom families}
\taxon{Remark}

\p{The unstraightening of the family #{\Hom(-,x)} is the canonical projection #{X_{/x} \to X}. Thus
representable families are contravariant iff #{X_{/x} \to X} are all right
fibrations.}

\agda{
hom-fam-is-contrav‚Üîis-right-fibration
  : ‚àÄ {ùì§} {X : Type ùì§} (x : X)
    ‚Üí is-contravariant (Œª a ‚Üí Hom X a x)
    ‚Üî is-right-fibration {A = Slice X (point x)} fst
hom-fam-is-contrav‚Üîis-right-fibration {X = X} x
  = is-contravariant‚Üîis-right-fibration (Œª a ‚Üí Hom X a x)
  ‚àôiff right-orthogonal-iff‚Üêequiv (Œª _ ‚Üí i1) amap amap-eq where
  amap : Arrow-map (fst {B = Œª a ‚Üí (i : ùüô) ‚Üí Hom X a x})
                   (fst {B = Œª a ‚Üí Hom X a x})
  amap .Arrow-map.top = total-map (Œª a ‚Üí ev tt)
  amap .Arrow-map.bot = id
  amap .Arrow-map.comm = ~refl

  amap-eq : is-Arrow-equiv amap
  amap-eq .fst = is-total-equiv‚Üêis-fibrewise-equiv (Œª a ‚Üí unit-ev-is-equiv)
  amap-eq .snd = id-is-equiv
}
}

\subtree[stt-00O0]{
\taxon{Theorem}
\title{Contravariance of representable families}

\p{We show that a type #{A} is [right Segal](stt-00O3) iff the family
#{\Hom(-,x)} is contravariant for each #{x}.}

\proof{
We will show that every #{A_{/x} \to A} is a right fibration iff A is
right orthogonal to the map #{\Lambda^2_1 \to \Delta^1 \bjoin 1}.

\p{First we give an equivalence of arrows:}

\quiver{
\begin{tikzcd}
	{\Delta^1\bjoin 1 \to_\bullet A} && {{A_{/x}}^{\Delta^1}} \\
	\\
	{\Lambda^2_1 \to_\bullet A} && {A^{\Delta^1} \times_A A_{/x}}
	\arrow["\sim", from=1-1, to=1-3]
	\arrow[from=1-1, to=3-1]
	\arrow[from=1-3, to=3-3]
	\arrow["\sim"', from=3-1, to=3-3]
\end{tikzcd}
}

\p{The top equivalence is given by the [join-slice adjunction](stt-00D5), and
the bottom via the universal property of the horn.}

\p{Now we use \ref{stt-00DC} to finish the proof.}
}

\closedScope{
\subtree[stt-00O1]{
\title{The bottom equivalence}
\agda{
char-slice-lift
  : ‚àÄ {ùì§} {A : Type ùì§} x
    ‚Üí Arrow-map (point i1) {C = Slice A (point x)} (fst)
    ‚Üí Coslice-map {X = Œõ[2,1]} (Œª _ ‚Üí Œπ‚ÇÇ i1) (point x)
char-slice-lift x (mk-amap top bot comm)
  = cogap (mk-cocone bot
                     (top tt .snd tt .Hom·µà.hom)
                      Œª c ‚Üí comm c ‚àô sym (top tt .snd tt .Hom·µà.hom0))
  , Œª _ ‚Üí top tt .snd tt .Hom·µà.hom1

opaque
  char-slice-lift-is-equiv
    : ‚àÄ {ùì§} {A : Type ùì§} x
      ‚Üí is-equiv (char-slice-lift {A = A} x)
  char-slice-lift-is-equiv x = is-equiv‚Üêqinv qinv where
    qinv : quasi-inv (char-slice-lift x)
    qinv .fst (f , p) = mk-amap (Œª _ ‚Üí (_ , Œª _ ‚Üí mk-hom (f ‚àò Œπ‚ÇÇ) refl (p tt)))
                                (f ‚àò Œπ‚ÇÅ)
                                (ap f ‚àò glue)
    qinv .snd .fst (mk-amap top bot comm)
      = let pth = ( (top tt .snd tt .Hom·µà.hom0)
                  , (Œª i ‚Üí ~refl , Square-flatten-hor refl , Square-degen-vert _ _ refl))
        in Arrow-map-path‚Üí
             ( (Œª a ‚Üí Slice-path‚Üí pth)
             , ~refl
             , Œª a ‚Üí ap (_‚àô ap fst (Slice-path‚Üí pth)) (pushout-rec-apŒ≤ a)
                   ‚àô ap ((comm tt ‚àô sym (Hom·µà.hom0 (top tt .snd tt))) ‚àô_)
                        (Slice-path-ap-fst pth)
                   ‚àô ‚àô.cancell _ (‚àô-sym' (Hom·µà.hom0 (top tt .snd tt))) )
    qinv .snd .snd (f , p) = ext!
      ( (sym ‚àò pushout-rec-unique _ _ ~refl ~refl ~refl)
      , ~refl)
}
}
}

\agda{
slice-is-right‚Üîright-inner-coslice

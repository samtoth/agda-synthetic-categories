--                    (вИЩ-reflr _ вИЩ sym-sym)
--                    (вИЩ-reflr _ вИЩ sym-sym))
--               sq


-- LEMMA-I-is-equiv
--   : вИА {рЭУ§ рЭУ• рЭУ¶ рЭУ§' рЭУ•' рЭУ¶'} {S : Cospan рЭУ§ рЭУ• рЭУ¶} {T : Cospan рЭУ§' рЭУ•' рЭУ¶'}

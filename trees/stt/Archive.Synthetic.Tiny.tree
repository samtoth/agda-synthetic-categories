  \Function{[𝓟₁](stt-00AF)} \Symbol{=} \Function{[postcomp](stt-003Y)} \Symbol{_}

  \Function{[unit](stt-00AF)} \Symbol{:} \Symbol{∀} \Symbol{\lbrace{}}\Bound{[𝓤](stt-00AF)}\Symbol{\rbrace{}} \Symbol{\lbrace{}}\Bound{[Γ](stt-00AF)} \Symbol{:} \Primitive{[Type](Foundations.Universes)} \Bound{[𝓤](stt-00AF)}\Symbol{\rbrace{}} \Symbol{→} \Bound{[Γ](stt-00AF)} \Symbol{→} \Symbol{\lpar{}}\Function{[𝓟](stt-00AG)} \Symbol{\lpar{}}\Bound{[Γ](stt-00AF)} \Function{\Operator{[⨾](stt-00AG)}} \Bound{[I](Archive.Synthetic.Tiny)}\Symbol{\rpar{}\rpar{}}

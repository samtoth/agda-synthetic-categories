\date{2025-06-03}
\title{Equivalences of arrows}
\author{samueltoth}
\import{stt-macros}
\taxon{Module}

\agda{
module Core.ArrowEquiv where

open import Axioms.UF
open import Foundations.Prelude

open import Core.Arrows
open import Core.Coslices
}

\subtree[stt-004R]{
\taxon{Definition}
\title{Arrow equivalences}

\p{A pair of arrows #{A \xrightarrow{f} B} and #{X \xrightarrow{g} Y} are said
to be equivalent if there exists an [arrow map](stt-003U) where both horizontal
morphisms are themselves equivalences.}

\quiver{
\begin{tikzcd}
	A && X \\
	\\
	B && Y
	\arrow["\sim", from=1-1, to=1-3]
	\arrow["f"', from=1-1, to=3-1]
	\arrow["g", from=1-3, to=3-3]
	\arrow["\sim"', from=3-1, to=3-3]
\end{tikzcd}
}

\agda{
is-Arrow-equiv
  : вҲҖ {рқ“Ө рқ“Ҙ рқ“Ұ рқ“ң} {A : Type рқ“Ө} {B : Type рқ“Ҙ} {X : Type рқ“Ұ}
      {Y : Type рқ“ң} {f : A вҶ’ B} {g : X вҶ’ Y}
    вҶ’ Arrow-map f g вҶ’ Type (рқ“Ө вҠ” рқ“Ҙ вҠ” рқ“Ұ вҠ” рқ“ң)
is-Arrow-equiv {f = f} {g} (mk-amap top bot comm)
  = is-equiv top Г— is-equiv bot

id-square-is-equiv
  : вҲҖ {рқ“Ө рқ“Ҙ} {A : Type рқ“Ө} {B : Type рқ“Ҙ}
      {f : A вҶ’ B}
    вҶ’ is-Arrow-equiv (id-square: f)
id-square-is-equiv .fst = id-is-equiv
id-square-is-equiv .snd = id-is-equiv

paste-squares-is-equiv
  : вҲҖ {рқ“Ө рқ“Ҙ рқ“Ұ рқ“ң рқ“қ рқ“ӣ} {A : Type рқ“Ө} {B : Type рқ“Ҙ}
      {C : Type рқ“Ұ} {D : Type рқ“ң} {E : Type рқ“қ} {F : Type рқ“ӣ}
      {f : A вҶ’ B} {g : C вҶ’ D} {h : E вҶ’ F}
    вҶ’ (G : Arrow-map g h) вҶ’ is-Arrow-equiv G
    вҶ’ (F : Arrow-map f g) вҶ’ is-Arrow-equiv F
    вҶ’ is-Arrow-equiv (paste-squares G F)
paste-squares-is-equiv G Ge F Fe .fst = is-equiv-вҲҳ (Ge .fst) (Fe .fst)
paste-squares-is-equiv G Ge F Fe .snd = is-equiv-вҲҳ (Ge .snd) (Fe .snd)

Arrow-equiv
  : вҲҖ {рқ“Ө рқ“Ҙ рқ“Ұ рқ“ң} {A : Type рқ“Ө} {B : Type рқ“Ҙ} {X : Type рқ“Ұ}
      {Y : Type рқ“ң} (f : A вҶ’ B) (g : X вҶ’ Y)
    вҶ’ Type (рқ“Ө вҠ” рқ“Ҙ вҠ” рқ“Ұ вҠ” рқ“ң)
Arrow-equiv f g = ОЈ[ F вҲ¶ Arrow-map f g ] is-Arrow-equiv F

ArrowвҒ»В№вҶҗis-Arrow-equiv
  : вҲҖ {рқ“Ө рқ“Ҙ рқ“Ұ рқ“ң} {A : Type рқ“Ө} {B : Type рқ“Ҙ} {X : Type рқ“Ұ}
      {Y : Type рқ“ң} {f : A вҶ’ B} {g : X вҶ’ Y}
    вҶ’ (F : Arrow-map f g)
    вҶ’ is-Arrow-equiv F
    вҶ’ Arrow-map g f
ArrowвҒ»В№вҶҗis-Arrow-equiv {f = f} {g} (mk-amap top bot comm) (teq , beq)
  = mk-amap top.bwd bot.bwd H module ArrowвҒ»В№ where opaque
  module top = is-equiv teq
  module bot = is-equiv beq

  K : bot вҲҳ bot.bwd вҲҳ g вҲҳ top ~ bot вҲҳ f вҲҳ top.bwd вҲҳ top
  K =   bot.Оө в–ё g в–ё top
     вҲҷh (comm hвҒ»В№)
     вҲҷh (bot в—Ӯ f в—Ӯ top.О· hвҒ»В№)

  H : (bot.bwd вҲҳ g) ~ (f вҲҳ top.bwd)
  H = beq в—Ӯeqv K в–ёeqv teq

ArrowвҒ»В№-is-equiv
  : вҲҖ {рқ“Ө рқ“Ҙ рқ“Ұ рқ“ң} {A : Type рқ“Ө} {B : Type рқ“Ҙ} {X : Type рқ“Ұ}
      {Y : Type рқ“ң} {f : A вҶ’ B} {g : X вҶ’ Y}
    вҶ’ (F : Arrow-map f g)
    вҶ’ (eq : is-Arrow-equiv F)
    вҶ’ is-Arrow-equiv (ArrowвҒ»В№вҶҗis-Arrow-equiv F eq)
ArrowвҒ»В№-is-equiv F (teq , beq) = (is-equivвҒ»В№ teq  , is-equivвҒ»В№ beq)
}
}

\subtree[stt-00EH]{
\title{Basic operations on arrow equivalences}
\author{fredrikbakke}

\agda{
Arrow-equivвҶҗвүғб¶ 
  : {рқ“Ө1 рқ“Ө2 рқ“Ҙ1 рқ“Ҙ2 : Level}
    (F : Fam рқ“Ө1 рқ“Ө2)
    (G : Fam рқ“Ҙ1 рқ“Ҙ2)
  вҶ’ F вүғб¶  G вҶ’ Arrow-equiv (arrowвҶҗFam F) (arrowвҶҗFam G)
Arrow-equivвҶҗвүғб¶  (A , B) (X , Y) (e , ef)
  = mk-amap top bot hrefl
  , top-is-equiv
  , bot-is-equiv
  where
  top : ОЈ A B вҶ’ ОЈ X Y
  top = total-map-fst (e ._вүғ_.fwd) вҲҳ total-map (О» a вҶ’ ef a ._вүғ_.fwd)

  bot : A вҶ’ X
  bot = e ._вүғ_.fwd

  top-is-equiv : is-equiv top
  top-is-equiv
    = is-equiv-вҲҳ
        (total-is-equivвҶҗfst-is-equiv (e ._вүғ_.fwd-is-equiv))
        (is-total-equivвҶҗis-fibrewise-equiv (О» a вҶ’ ef a ._вүғ_.fwd-is-equiv))

  bot-is-equiv : is-equiv bot
  bot-is-equiv = e ._вүғ_.fwd-is-equiv

concat-Arrow-equiv
  : вҲҖ {рқ“Ө рқ“Ҙ рқ“Ұ рқ“ң рқ“  рқ“Ў}
      {A : Type рқ“Ө}
      {B : Type рқ“Ҙ}
      {C : Type рқ“Ұ}
      {D : Type рқ“ң}
      {E : Type рқ“ }
      {F : Type рқ“Ў}
      {f : A вҶ’ B}
      {g : C вҶ’ D}
      {h : E вҶ’ F}
    вҶ’ Arrow-equiv f g
    вҶ’ Arrow-equiv g h
    вҶ’ Arrow-equiv f h
concat-Arrow-equiv (p , peq) (q , qeq)
  = paste-squares q p
  , is-equiv-вҲҳ (qeq .fst) (peq .fst)
  , is-equiv-вҲҳ (qeq .snd) (peq .snd)

concat-Arrow-equiv-вүғб¶ 
  : вҲҖ {рқ“Ө рқ“Ҙ рқ“Ұ1 рқ“Ұ2 рқ“ӣ1 рқ“ӣ2}
      {A : Type рқ“Ө} {B : Type рқ“Ҙ} {f : A вҶ’ B}
      (F : Fam рқ“Ұ1 рқ“Ұ2) (G : Fam рқ“ӣ1 рқ“ӣ2)
    вҶ’ Arrow-equiv f (arrowвҶҗFam F)
    вҶ’ F вүғб¶  G
    вҶ’ Arrow-equiv f (arrowвҶҗFam G)
concat-Arrow-equiv-вүғб¶  F G eвӮҖ e
  = concat-Arrow-equiv eвӮҖ (Arrow-equivвҶҗвүғб¶  F G e)

inv-Arrow-equiv
  : вҲҖ {рқ“Ө рқ“Ҙ рқ“Ұ рқ“ң}
      {A : Type рқ“Ө}
      {B : Type рқ“Ҙ}
      {C : Type рқ“Ұ}
      {D : Type рқ“ң}
      {f : A вҶ’ B}
      {g : C вҶ’ D}
    вҶ’ Arrow-equiv f g
    вҶ’ Arrow-equiv g f
inv-Arrow-equiv (p , peq)
  = ArrowвҒ»В№вҶҗis-Arrow-equiv p peq
  , ArrowвҒ»В№-is-equiv p peq
}
}

\subtree[stt-004S]{
\taxon{Theorem}
\title{Arrow equivalences preserve equivalences}

\p{If there is an [arrow equivalence](stt-004R) from #{A \xrightarrow{f} B} to
#{X \xrightarrow{g} Y}, then #{f} is an equivalence iff #{g} is.
}

\proof{This is a simple application of the [3-for-2](stt-003E) property of
equivalences.}

\agda{
is-equivвҶҗArrow-equiv
  : вҲҖ {рқ“Ө рқ“Ҙ рқ“Ұ рқ“ң} {A : Type рқ“Ө} {B : Type рқ“Ҙ} {X : Type рқ“Ұ}
      {Y : Type рқ“ң} {f : A вҶ’ B} {g : X вҶ’ Y}
      {F : Arrow-map f g}
    вҶ’ is-Arrow-equiv F
    вҶ’ is-equiv f вҶ’ is-equiv g
is-equivвҶҗArrow-equiv {F = mk-amap top bot comm} (teq , beq) feq
  = 3-for-2~' comm teq (is-equiv-вҲҳ beq feq)

is-equivвҶҗArrow-equivвҒ»В№
  : вҲҖ {рқ“Ө рқ“Ҙ рқ“Ұ рқ“ң} {A : Type рқ“Ө} {B : Type рқ“Ҙ} {X : Type рқ“Ұ}
      {Y : Type рқ“ң} {f : A вҶ’ B} {g : X вҶ’ Y}
      {F : Arrow-map f g}
    вҶ’ is-Arrow-equiv F
    вҶ’ is-equiv g вҶ’ is-equiv f
is-equivвҶҗArrow-equivвҒ»В№ {F = mk-amap top bot comm} (teq , beq) geq
  = 3-for-2~ (comm hвҒ»В№) beq (is-equiv-вҲҳ geq teq)

topвҮ”bot-is-equivвҶҗArrow-equiv
  : вҲҖ {рқ“Ө рқ“Ҙ рқ“Ұ рқ“ң} {A : Type рқ“Ө} {B : Type рқ“Ҙ} {X : Type рқ“Ұ}
      {Y : Type рқ“ң} {f : A вҶ’ B} {g : X вҶ’ Y}
      (F : Arrow-map f g)
    вҶ’ is-Arrow-equiv F
    вҶ’ is-equiv f вҮ” is-equiv g
topвҮ”bot-is-equivвҶҗArrow-equiv F eq = ( is-equivвҶҗArrow-equiv {F = F} eq
                                    , is-equivвҶҗArrow-equivвҒ»В№ {F = F} eq)
}
}

\subtree[stt-0069]{
\title{Arrow equivalences preserve sections}
\taxon{Theorem}

\p{If there is an [arrow equivalence](stt-004R) from #{A \xrightarrow{f} B} to
#{X \xrightarrow{g} Y}, then sections of #{f} are equivalent to sections of #{g}.
}

% TODO(sam): Look into why unification isn't working so well for arrow
%            map

\agda{
sectionвҶҗArrow-equiv
  : вҲҖ {рқ“Ө рқ“Ҙ рқ“Ұ рқ“ң} {A : Type рқ“Ө} {B : Type рқ“Ҙ} {X : Type рқ“Ұ}
      {Y : Type рқ“ң} {f : A вҶ’ B} {g : X вҶ’ Y}
      {F : Arrow-map f g}
    вҶ’ is-Arrow-equiv F
    вҶ’ section f вҶ’ section g
sectionвҶҗArrow-equiv {f = f} {g} {F = F} eq (secf , p) .fst
  = top вҲҳ secf вҲҳ bot.bwd where
  open Arrow-map F
  module top = is-equiv (eq .fst)
  module bot = is-equiv (eq .snd)
sectionвҶҗArrow-equiv {f = f} {g} {F} eq (secf , p) .snd
  =  H в–ё top в–ё secf в–ё bot.bwd
  вҲҷh bot в—Ӯ f в—Ӯ top.О· в–ё secf в–ё bot.bwd
  вҲҷh bot в—Ӯ p в–ё bot.bwd
  вҲҷh bot.Оө where
  open Arrow-map F
  module top = is-equiv (eq .fst)
  module bot = is-equiv (eq .snd)
  H : g ~ bot вҲҳ f вҲҳ top.bwd
  H = ((g в—Ӯ top.Оө) hвҒ»В№) вҲҷh (comm hвҒ»В№ в–ё top.bwd)

sectionвҶҗArrow-equivвҒ»В№
  : вҲҖ {рқ“Ө рқ“Ҙ рқ“Ұ рқ“ң} {A : Type рқ“Ө} {B : Type рқ“Ҙ} {X : Type рқ“Ұ}
      {Y : Type рқ“ң} {f : A вҶ’ B} {g : X вҶ’ Y}
      {F : Arrow-map f g}
    вҶ’ is-Arrow-equiv F
    вҶ’ section g вҶ’ section f
sectionвҶҗArrow-equivвҒ»В№ {f = f} {g} {F} EF sec = sectionвҶҗArrow-equiv {f = g} {f}
                                               {ArrowвҒ»В№вҶҗis-Arrow-equiv F EF}
                                               (ArrowвҒ»В№-is-equiv F EF) sec
}
}

\subtree[stt-007M]{
\taxon{Theorem}
\title{Pre/post-composition of arrow equivalences}
\p{Precomposition preserves arrow equivalences}

\agda{
postcomp-Arrow-map
  : вҲҖ {рқ“Ө рқ“Ҙ рқ“Ұ рқ“ң рқ“ } {A : Type рқ“Ө} {B : Type рқ“Ҙ}
      {X : Type рқ“Ұ} {Y : Type рқ“ң}
      {f : A вҶ’ B} {g : X вҶ’ Y}
    вҶ’ (Q : Type рқ“ )
    вҶ’ Arrow-map f g
    вҶ’ Arrow-map (postcomp Q f) (postcomp Q g)
postcomp-Arrow-map Q F = mk-amap (top вҲҳ_) (bot вҲҳ_) (funextвҶ’ вҲҳ (comm в–ё_)) where
  open Arrow-map F


postcomp-square-is-equiv
  : вҲҖ {рқ“Ө рқ“Ҙ рқ“Ұ рқ“ң рқ“ } {A : Type рқ“Ө} {B : Type рқ“Ҙ}
      {X : Type рқ“Ұ} {Y : Type рқ“ң}
      {f : A вҶ’ B} {g : X вҶ’ Y}
      (F : Arrow-map f g)
      {Q : Type рқ“ }
    вҶ’ is-Arrow-equiv F
    вҶ’ is-Arrow-equiv (postcomp-Arrow-map Q F)
postcomp-square-is-equiv F eq
  = (postcomp-equiv (eq .fst) , postcomp-equiv (eq .snd))

precomp-Arrow-map
  : вҲҖ {рқ“Ө рқ“Ҙ рқ“Ұ рқ“ң рқ“ } {A : Type рқ“Ө} {B : Type рқ“Ҙ}
      {X : Type рқ“Ұ} {Y : Type рқ“ң}
      {f : A вҶ’ B} {g : X вҶ’ Y}
    вҶ’ (Q : Type рқ“ )
    вҶ’ Arrow-map f g
    вҶ’ Arrow-map (precomp Q g) (precomp Q f)
precomp-Arrow-map Q F = mk-amap (_вҲҳ bot) (_вҲҳ top) (funextвҶ’ вҲҳ (_в—Ӯ (comm hвҒ»В№))) where
  open Arrow-map F

precomp-square-is-equiv
  : вҲҖ {рқ“Ө рқ“Ҙ рқ“Ұ рқ“ң рқ“ } {A : Type рқ“Ө} {B : Type рқ“Ҙ}
      {X : Type рқ“Ұ} {Y : Type рқ“ң}
      {f : A вҶ’ B} {g : X вҶ’ Y}
      (F : Arrow-map f g)
      {Q : Type рқ“ }
    вҶ’ is-Arrow-equiv F
    вҶ’ is-Arrow-equiv (precomp-Arrow-map Q F)
precomp-square-is-equiv F eq
  = (precomp-equiv (eq .snd) , precomp-equiv (eq .fst))
}
}

\subtree[stt-00BQ]{
\title{Arrow equivalences are cartesian squares}
\taxon{Lemma}

\agda{
opaque
  is-cartesianвҶҗis-equiv
    : вҲҖ {рқ“Ө рқ“Ҙ рқ“Ұ рқ“ң} {A : Type рқ“Ө} {B : Type рқ“Ҙ} {X : Type рқ“Ұ}
        {Y : Type рқ“ң} {f : A вҶ’ B} {g : X вҶ’ Y}
      вҶ’ (F : Arrow-map f g)
      вҶ’ is-Arrow-equiv F вҶ’ is-cartesian F
  is-cartesianвҶҗis-equiv F@(mk-amap top bot p) (teq , beq) b
    = is-equiv-вҲҳ
        {f = total-map-fst top}
        (total-is-equivвҶҗfst-is-equiv teq)
        (is-total-equivвҶҗis-fibrewise-equiv
          (О» a вҶ’ is-equiv-вҲҳ
                   {f = sym (p a) вҲҷ_}
                   (вҲҷ-is-equiv (sym (p a)))
                   (is-embeddingвҶҗis-equiv beq)))

  inverse-is-cartesianвҶҗis-equiv
    : вҲҖ {рқ“Ө рқ“Ҙ рқ“Ұ рқ“ң} {A : Type рқ“Ө} {B : Type рқ“Ҙ} {X : Type рқ“Ұ} {Y : Type рқ“ң}
        {f : A вҶ’ B} {g : X вҶ’ Y} (F : Arrow-map f g)
      вҶ’ (Fe : is-Arrow-equiv F)
      вҶ’ is-cartesian (ArrowвҒ»В№вҶҗis-Arrow-equiv F Fe)
  inverse-is-cartesianвҶҗis-equiv F Fe
    = is-cartesianвҶҗis-equiv _ (ArrowвҒ»В№-is-equiv F Fe)
}
}

\subtree[stt-00D7]{
\title{Right cancelling a cartesian square by an arrow equivalence}
\taxon{Lemma}

\agda{
right-cancel-cartesian
  : вҲҖ {рқ“Ө рқ“Ҙ} {A : Type рқ“Ө} {B : Type рқ“Ҙ} {f : A вҶ’ B}
      {рқ“Ө' рқ“Ҙ'} {A' : Type рқ“Ө'} {B' : Type рқ“Ҙ'} {f' : A' вҶ’ B'}
      {рқ“Ө'' рқ“Ҙ''} {A'' : Type рқ“Ө''} {B'' : Type рқ“Ҙ''} {f'' : A'' вҶ’ B''}
      {a : Arrow-map f' f''} {b : Arrow-map f f'}
      {H : Arrow-map f f''}
    вҶ’ Arrow-map-path H (paste-squares a b)
    вҶ’ is-cartesian H
    вҶ’ is-Arrow-equiv b
    вҶ’ is-cartesian a
right-cancel-cartesian {a = a} {b} {H} path Hc bc b'
  = is-equivвҶҗArrow-equivвҒ»В№ {F = hom} hom-eq lem where
  open Arrow-map
  open is-equiv
  lem : is-equiv (arrow-fibre a (b .bot (bwd (bc .snd) b')))
  lem = 3-for-2~' {f = arrow-fibre a (b .bot (bwd (bc .snd) b'))}
                  {g = arrow-fibre b (bwd (bc .snd) b')}
                 (arrow-fibre-вҲҳ a b (bwd (bc .snd) b'))
                 (is-cartesianвҶҗis-equiv b bc (bwd (bc .snd) b'))
                 (tr is-cartesian (Arrow-map-pathвҶ’ path) Hc (bwd (bc .snd) b'))

  hom : Arrow-map (arrow-fibre a b') (arrow-fibre a (b .bot (bwd (bc .snd) b')))
  hom .top = total-map (О» x вҶ’ _вҲҷ sym (Оө (bc .snd) b'))
  hom .bot = total-map (О» x вҶ’ _вҲҷ ap (bot a) (sym (Оө (bc .snd) b')))
  hom .comm (x , refl)
    = ОЈ-pathвҶ’ (refl , ap (_вҲҷ ap (bot a) _) (вҲҷ-reflr (sym (comm a x))))

  hom-eq : is-Arrow-equiv hom
  hom-eq .fst = is-total-equivвҶҗis-fibrewise-equiv О» _ вҶ’ вҲҷ-is-equiv' _
  hom-eq .snd = is-total-equivвҶҗis-fibrewise-equiv О» _ вҶ’ вҲҷ-is-equiv' _
}
}

\subtree[stt-00K5]{
\title{Canonical cartesian square}

\p{We encode the fact that for each map #{f : A \to B}, there are functors
#{f^* : \Type_B \to \Type_A}. We also note that for each #{f}, there are
cartesian maps of arrows from #{f^*(p)} to #{p}, the canonical pullback squares.}

\agda{
pullback-arrow
  : вҲҖ {рқ“Ө рқ“Ҙ рқ“Ұ} {A : Type рқ“Ө} {B : Type рқ“Ҙ} {E : Type рқ“Ұ}
    вҶ’ (f : A вҶ’ B) вҶ’ (p : E вҶ’ B) вҶ’ (Pullback f p вҶ’ A)
pullback-arrow f p = pb.ПҖвӮҒ

pullback-arrow-map
  : вҲҖ {рқ“Ө рқ“Ҙ рқ“Ұ} {A : Type рқ“Ө} {B : Type рқ“Ҙ} {E : Type рқ“Ұ}
    вҶ’ (f : A вҶ’ B) вҶ’ (p : E вҶ’ B)
    вҶ’ Arrow-map (pullback-arrow f p) p
pullback-arrow-map f p .Arrow-О .top = pb.ПҖвӮӮ
pullback-arrow-map f p .Arrow-О .bot = f
pullback-arrow-map f p .Arrow-О .comm = pb.filler

pullback-arrow-map-is-cartesian
  : вҲҖ {рқ“Ө рқ“Ҙ рқ“Ұ} {A : Type рқ“Ө} {B : Type рқ“Ҙ} {E : Type рқ“Ұ}
    вҶ’ (f : A вҶ’ B) вҶ’ (p : E вҶ’ B)
    вҶ’ is-cartesian (pullback-arrow-map f p)
pullback-arrow-map-is-cartesian f p
  = is-cartesianвҶҗup-pullback _ pullback-has-up-pullback

pullback-arrow-вҲҳ
  : вҲҖ {рқ“Ө рқ“Ҙ рқ“Ұ рқ“ң} {A : Type рқ“Ө} {B : Type рқ“Ҙ} {C : Type рқ“Ұ} {E : Type рқ“ң}
      (g : B вҶ’ C) (f : A вҶ’ B) (p : E вҶ’ C)
    вҶ’ Arrow-equiv (pullback-arrow f (pullback-arrow g p)) (pullback-arrow (g вҲҳ f) p)
pullback-arrow-вҲҳ g f p = ( mk-amap (gap-mapвҶҗsquare lem) id hrefl
                         , is-pullbackвҶҗis-cartesian lem lem-is-cart
                         , id-is-equiv) where
  lem : Arrow-map (pullback-arrow f (pullback-arrow g p)) p
  lem = paste-squares (pullback-arrow-map g p)
                      (pullback-arrow-map f (pullback-arrow g p))

  lem-is-cart : is-cartesian lem
  lem-is-cart = compose-cartesian
                  (pullback-arrow-map-is-cartesian g p)
                  (pullback-arrow-map-is-cartesian f (pullback-arrow g p))
}
}

\subtree[stt-00L0]{
\title{Arrow maps over the unit type}

\agda{
!-map : вҲҖ {рқ“Ө рқ“Ҙ} {A : Type рқ“Ө} {B : Type рқ“Ҙ} вҶ’ (A вҶ’ B) вҶ’ Arrow-map (!: A) (!: B)
!-map f .Arrow-О .top = f
!-map f .Arrow-О .bot = id
!-map f .Arrow-О .comm = hrefl

!-map-is-equiv
  : вҲҖ {рқ“Ө рқ“Ҙ} {A : Type рқ“Ө} {B : Type рқ“Ҙ} {f : A вҶ’ B}
    вҶ’ is-equiv f вҶ’ is-Arrow-equiv (!-map f)
!-map-is-equiv fe = (fe , id-is-equiv)
}
}

\subtree[stt-00MX]{
\date{2026-03-19}
\author{fredrikbakke}
\taxon{Theorem}
\title{Dependent precomposition and straightening}

\p{
Dependent precomposition along #{f} is equivalent, as an arrow, to dependent
precomposition after straightening the family #{U} to the fibre family of its
total-space projection.
}

\agda{
module _
  {рқ“Ө рқ“Ҙ рқ“Ұ : Level}
  {A : Type рқ“Ө} {B : Type рқ“Ҙ}
  (U : B вҶ’ Type рқ“Ұ)
  (f : A вҶ’ B)
  where

  precomp-О -straighten-Arrow-map
    : Arrow-map (precomp-О  U f) (precomp-О  (fibre (fst {B = U})) f)
  precomp-О -straighten-Arrow-map .Arrow-map.top
    = postcomp-О  (О» b вҶ’ (fibre-straighten U b eвҒ»В№) ._вүғ_.fwd)
  precomp-О -straighten-Arrow-map .Arrow-map.bot
    = postcomp-О  (О» a вҶ’ (fibre-straighten U (f a) eвҒ»В№) ._вүғ_.fwd)
  precomp-О -straighten-Arrow-map .Arrow-map.comm _ = refl

  precomp-О -straighten-is-Arrow-equiv
    : is-Arrow-equiv precomp-О -straighten-Arrow-map
  precomp-О -straighten-is-Arrow-equiv
    = ( postcomp-О -equiv (О» {b} вҶ’ (fibre-straighten U b eвҒ»В№) ._вүғ_.fwd-is-equiv)
      , postcomp-О -equiv (О» {a} вҶ’ (fibre-straighten U (f a) eвҒ»В№) ._вүғ_.fwd-is-equiv))

  precomp-О -straighten-Arrow-equiv
    : Arrow-equiv (precomp-О  U f) (precomp-О  (fibre (fst {B = U})) f)
  precomp-О -straighten-Arrow-equiv
    = precomp-О -straighten-Arrow-map
    , precomp-О -straighten-is-Arrow-equiv
}
}

\subtree[stt-00MR]{
\date{2026-03-19}
\author{fredrikbakke}
\taxon{Theorem}
\title{Dependent precomposition as fibrewise constant postcomposition}

\p{
For any family #{U} over #{B}, dependent precomposition along #{f} is
equivalent, as a map of arrows, to fibrewise postcomposition by the constant
maps #{U(b) \to (\fibre{f}{b} \to U(b))}.
}

\agda{
module _
  {рқ“Ө рқ“Ҙ рқ“Ұ : Level}
  {A : Type рқ“Ө} {B : Type рқ“Ҙ}
  (U : B вҶ’ Type рқ“Ұ)
  (f : A вҶ’ B)
  where

  precomp-О -fibre-const-Arrow-map
    : Arrow-map
        (precomp-О  U f)
        (postcomp-О  (О» b вҶ’ const (U b) (fibre f b)))
  precomp-О -fibre-const-Arrow-map .Arrow-map.top = id
  precomp-О -fibre-const-Arrow-map .Arrow-map.bot = precomp-О -over-fibres U f
  precomp-О -fibre-const-Arrow-map .Arrow-map.comm h
    = funextвҶ’ О» b вҶ’ funextвҶ’ О» (a , p) вҶ’ apб¶  h p

  precomp-О -fibre-const-is-Arrow-equiv
    : is-Arrow-equiv precomp-О -fibre-const-Arrow-map
  precomp-О -fibre-const-is-Arrow-equiv
    = (id-is-equiv , precomp-О -over-fibres-is-equiv U f)

  precomp-О -fibre-const-Arrow-equiv
    : Arrow-equiv
        (precomp-О  U f)
        (postcomp-О  (О» b вҶ’ const (U b) (fibre f b)))
  precomp-О -fibre-const-Arrow-equiv
    = precomp-О -fibre-const-Arrow-map
    , precomp-О -fibre-const-is-Arrow-equiv
}
}

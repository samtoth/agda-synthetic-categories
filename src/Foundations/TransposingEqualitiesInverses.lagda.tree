open import Foundations.FunExt
}


\subtree[fre-B2D7]{
\date{2026-05-13}
\author{fredrikbakke}
\taxon{Proposition}
\title{Transposing equalities along one-sided inverses}

\p{
Given two maps #{f : A \to B} and #{g : B \to A}, then the type of homotopies
#{g \circ f \sim \id}, i.e., witnesses that #{g} is a [retraction](stt-000I) of #{f},
is equivalent to the type of families of transposing maps
#{(f(x) = y) \to (x = g(y))} for all #{x} and #{y}.
}

\agda{
module _ {ūĚď§ ūĚď•} {A : Type ūĚď§} {B : Type ūĚď•} (f : A ‚Üí B) (g : B ‚Üí A) where

  eq-transpose‚Üźleft-inverse
    : g ‚ąė f ~ id
      ‚Üí (y : B) (x : A) ‚Üí y ÔľĚ f x ‚Üí g y ÔľĚ x
  eq-transpose‚Üźleft-inverse R y x p
    = ap g p ‚ąô R x

  left-inverse‚Üźeq-transpose
    : ((y : B) (x : A) ‚Üí y ÔľĚ f x ‚Üí g y ÔľĚ x)
      ‚Üí g ‚ąė f ~ id
  left-inverse‚Üźeq-transpose H x
    = H (f x) x refl

  transpose-eq‚Üźleft-inverse
    : g ‚ąė f ~ id
    ‚Üí (y : B) (x : A) ‚Üí f x ÔľĚ y ‚Üí g y ÔľĚ x
  transpose-eq‚Üźleft-inverse R y x p
    = sym (ap g p) ‚ąô R x

  transpose-eq‚Üźleft-inverse'
    : g ‚ąė f ~ id
    ‚Üí (y : B) (x : A) ‚Üí y ÔľĚ f x ‚Üí x ÔľĚ g y
  transpose-eq‚Üźleft-inverse' R y x p
    = sym (R x) ‚ąô ap g (sym p)
}

\agda{
module TransposingEqualitiesWithFunExt
  (FE : FunExt-global) (let open WithFunExt-global FE)
  {ūĚď§ ūĚď•} {A : Type ūĚď§} {B : Type ūĚď•} (f : A ‚Üí B) (g : B ‚Üí A)
  where

  eq-transpose‚Üźleft-inverse-is-equiv
    : is-equiv (eq-transpose‚Üźleft-inverse f g)
  eq-transpose‚Üźleft-inverse-is-equiv
    = is-equiv‚Üźqinv qinv where
    qinv : quasi-inv (eq-transpose‚Üźleft-inverse f g)
    qinv .fst = left-inverse‚Üźeq-transpose f g
    qinv .snd .fst R = refl
    qinv .snd .snd H
      = funext‚Üí őĽ y ‚Üí
        funext‚Üí őĽ x ‚Üí
        funext‚Üí őĽ where refl ‚Üí refl

  eq-transpose-left-inverse‚ČÉ
    : (g ‚ąė f ~ id) ‚ČÉ ((y : B) (x : A) ‚Üí y ÔľĚ f x ‚Üí g y ÔľĚ x)
  eq-transpose-left-inverse‚ČÉ
    = mk‚ČÉ
        (eq-transpose‚Üźleft-inverse f g)
        (eq-transpose‚Üźleft-inverse-is-equiv)
}
}

\subtree[fre-E849]{
\title{Transposing equalities along equivalences}
\taxon{Proposition}
\author{fredrikbakke}
\date{2026-05-13}

\p{
Given an equivalence #{e : X \simeq Y}, then any equality #{e(x) = y} may be
transposed to an equality #{x = e^{-1}(y)}, and this transposing map defines an
equivalence #{(e(x) = y) \simeq (x = e^{-1}(y))}.
}

\agda{
module _ {ūĚď§ ūĚď•} {X : Type ūĚď§} {Y : Type ūĚď•} (e : X ‚ČÉ Y) where

  transpose-eq-equiv
    : (y : Y) (x : X) ‚Üí _‚ČÉ_.fwd e x ÔľĚ y ‚Üí _‚ČÉ_.bwd e y ÔľĚ x
  transpose-eq-equiv
    = transpose-eq‚Üźleft-inverse (_‚ČÉ_.fwd e) (_‚ČÉ_.bwd e) (_‚ČÉ_.ő∑ e)

  transpose-eq-equiv'
    : (y : Y) (x : X) ‚Üí _‚ČÉ_.bwd e y ÔľĚ x ‚Üí _‚ČÉ_.fwd e x ÔľĚ y
  transpose-eq-equiv' y x
    = transpose-eq‚Üźleft-inverse (_‚ČÉ_.bwd e) (_‚ČÉ_.fwd e) (_‚ČÉ_.őĶ e) x y

  transpose-eq-equiv-is-equiv
    : (y : Y) (x : X)
      ‚Üí is-equiv (transpose-eq-equiv y x)
  transpose-eq-equiv-is-equiv y x
    = is-equiv‚Üź~‚ĀĽ¬Ļ
        (őĽ p ‚Üí ap (_‚ąô _‚ČÉ_.ő∑ e x) (ap-sym (_‚ČÉ_.bwd e) p))
        (_‚ČÉ_.fwd-is-equiv
          ( sym‚ČÉ ‚ąô‚ČÉ ÔľĚ-equiv (e e‚ĀĽ¬Ļ) ‚ąô‚ČÉ ÔľĚ-preconcat-‚ČÉ (_‚ČÉ_.ő∑ e x)))

  transpose-eq-equiv‚ČÉ
    : (y : Y) (x : X) ‚Üí (_‚ČÉ_.fwd e x ÔľĚ y) ‚ČÉ (_‚ČÉ_.bwd e y ÔľĚ x)
  transpose-eq-equiv‚ČÉ y x
    = mk‚ČÉ (transpose-eq-equiv y x) (transpose-eq-equiv-is-equiv y x)
}
}

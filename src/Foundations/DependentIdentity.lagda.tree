\date{2025-02-24}
\title{Dependent Identity Types}
\author{samueltoth}

\import{stt-macros}

% ```agda
\agda{
module Foundations.DependentIdentity where

open import Foundations.Universes
open import Foundations.Identity
open import Foundations.Functions
open import Foundations.Sigma
}
% ```


\p{Suppose we have types #{A, B : \UU}, and a path between them #{A =_\UU B}.
We want to talk about equalities between terms #{a : A} and #{b : B}, but the
type #{a =_{?} b} is not well formed (what type do we put for \em{?}).  }

\subtree{
\taxon{Example}

\def\Fin[n]{\bN^{\n}  }

\p{Consider the type of the standard finite types indexed over natural
numbers. Addition can be defined as a function #{(x : \Fin{<m}) \to (y :
\Fin{<n}) \to \Fin{<(m + n)}}. Then consider the type of #{n + 2} and #{2 +
n}. The types aren't definitionally equal but are equal up to a path (the proof
of commutativity of natural number addition). } }

\subtree{
\taxon{Definition}
\title{Dependent Identity}

\p{
Given:
\ul{
\li{two types #{A,B : \UU}}
\li{a path #{P : A =_\UU B}}
\li{an element #{x : A}}
\li{an element #{y : B}}
}

We define the type of dependent identifications over #{P}, written #{x \depid{P} y}.
}


% ```agda
\agda{
module _ {𝓤} {A : Type 𝓤} {B : Type 𝓤} (P : A ＝ B) where
  Idᵈ : A → B → Type 𝓤
  Idᵈ a b = coe P a ＝ b

Idᵈ-syntax : ∀ {𝓤} {A B : Type 𝓤} → A ＝ B → A → B → Type 𝓤
Idᵈ-syntax = Idᵈ

infix 6 Idᵈ-syntax
syntax Idᵈ-syntax P a b = a ＝[ P ] b

module _ {𝓤} {A B : Type 𝓤} where

  symᵈ : ∀ {P : A ＝ B} {a} {b} → Idᵈ P a b → Idᵈ (sym P) b a
  symᵈ {P = refl} p = sym p

  symᵈ' : ∀ {P : A ＝ B} {a} {b} → Idᵈ (sym P) b a → Idᵈ P a b
  symᵈ' {P = refl} p = sym p

  Idᵈ-inl : ∀ {P : A ＝ B} {a : A} {b : B} → coe P a ＝ b → Idᵈ P a b
  Idᵈ-inl {P = P} p = p

  Idᵈ-inr :  ∀ {P : A ＝ B} {a : A} {b : B} → a ＝ coe (sym P) b → Idᵈ P a b
  Idᵈ-inr {P = refl} p = p


  Idᵈ-right : ∀ {P : A ＝ B} {a : A} {b : B}
            → Idᵈ P a b → a ＝ coe (sym P) b
  Idᵈ-right {P = refl} p = p

reflᵈ : ∀ {𝓤} {A : Type 𝓤} {P : A ＝ A} (_ : P ＝ refl) {a : A} → Idᵈ P a a
reflᵈ refl = refl

transp-leftᵈ : ∀ {𝓤}
                 {A B : Type 𝓤} (P : A ＝ B)
                 {a : A}  {b : B}
                 → a ＝[ P ] b → {b' : B} → b ＝ b' → a ＝[ P ] b'
transp-leftᵈ refl p q = p ∙ q

transIdᵈ : ∀ {𝓤} {A B C : Type 𝓤}
             (P : A ＝ B) (Q : B ＝ C)
             {a : A} {b : B} {c : C}
           → a ＝[ P ] b → b ＝[ Q ] c
           → a ＝[ P ∙ Q ] c
transIdᵈ P Q {a} p q = sym (coe∙coe P Q a) ∙ ap (coe Q) p ∙ q
{-# NOINLINE transIdᵈ #-}

syntax transIdᵈ P Q p q = p ∙[ P ∙ Q ] q

Idᵈ-const-coe
  : ∀ {𝓤 𝓥} {A : Type 𝓤} {B : Type 𝓥}
      (f : A → B)
      {x y : A} (p : x ＝ y)
      {l : B}
      (t : f x ＝ l)
    → coe (ap (λ z → f z ＝ l) p) t ＝ ap f (sym p) ∙ t
Idᵈ-const-coe f refl t = refl
}
% ```
}

\subtree[fre-703F]{
\title{Dependent identity in a family}
\taxon{Definition}
\author{fredrikbakke}
\date{2026-04-23}


\p{
Given:
\ul{
\li{a base type #{A : \UU}}
\li{a family #{B : A \to \UV} over A}
\li{a path #{p : a =_A b}}
\li{a term #{(x : B a)} over a}
\li{a term #{(y : B b)} over b}
}

We define the type of dependent identifications over #{p}, written #{x =_B^p y}.
}

%```agda
\agda{
module _ {𝓤 𝓥} {A : Type 𝓤} (B : A → Type 𝓥) {a a' : A} (p : a ＝ a') where

  Idᶠ : B a → B a' → Type 𝓥
  Idᶠ = Idᵈ (ap B p)

  {-# NOINLINE Idᶠ #-}
}
%```

%```agda
\agda{
module _ {𝓤 𝓥} {A : Type 𝓤} {B : A → Type 𝓥} where

  symᶠ : {a a' : A} {p : a ＝ a'} {x : B a} {y : B a'}
       → Idᶠ B p x y → Idᶠ B (sym p) y x
  symᶠ {p = refl} = sym

  symᶠ' : {a a' : A} {p : a ＝ a'} {x : B a} {y : B a'}
        → Idᶠ B (sym p) y x → Idᶠ B p x y
  symᶠ' {p = refl} = sym

  Idᶠ-inl : {a a' : A} {p : a ＝ a'} {x : B a} {y : B a'}
          → tr B p x ＝ y → Idᶠ B p x y
  Idᶠ-inl {p = p} h = h

  Idᶠ-inr : {a a' : A} {p : a ＝ a'} {x : B a} {y : B a'}
          → x ＝ tr B (sym p) y → Idᶠ B p x y
  Idᶠ-inr {p = refl} h = h

  Idᶠ-right : {a a' : A} {p : a ＝ a'} {x : B a} {y : B a'}
            → Idᶠ B p x y → x ＝ tr B (sym p) y
  Idᶠ-right {p = refl} h = h

  reflᶠ : {a : A} {p : a ＝ a} → p ＝ refl → {x : B a} → Idᶠ B p x x
  reflᶠ {a = a} {p = p} r {x = x}
    = reflᵈ {A = B a} {P = ap B p} (ap (ap B) r ∙ ap-refl B) {a = x}

  transp-leftᶠ : {a a' : A} (p : a ＝ a')
                 {x : B a} {y : B a'}
               → Idᶠ B p x y → {z : B a'} → y ＝ z → Idᶠ B p x z
  transp-leftᶠ p = transp-leftᵈ (ap B p)

  transIdᶠ : {a b c : A}
             (p : a ＝ b) (q : b ＝ c)
             {x : B a} {y : B b} {z : B c}
           → Idᶠ B p x y → Idᶠ B q y z
           → Idᶠ B (p ∙ q) x z
  transIdᶠ refl refl h k = h ∙ k

module _ {𝓤} {A : Type 𝓤} where

  apᶠ : ∀ {𝓥} {B : A → Type 𝓥}
           (f : (a  : A) → B a)
           {a b : A}
         → (p : a ＝ b)
         → Idᶠ B p (f a) (f b)
  apᶠ f refl = refl

  apᶠ-is-ap : ∀ {𝓥} {B : Type 𝓥}
              → {f : A → B}
              → {a b : A}
              → {p : a ＝ b}
              → apᶠ f p ＝[ (tr-constant _ _) ∙- ]  ap f p
  apᶠ-is-ap {p = refl} = refl

apᶠ-∘ : ∀ {𝓤 𝓥 𝓦} {A : Type 𝓤} {A' : Type 𝓥} {B : A → Type 𝓦}
          {f : Π A B}
          {a b : A'}
          {g : A' → A}
          {p : a ＝ b}
        → apᶠ (f ∘ g) p ＝[ (tr∘ B g p ∙-) ] apᶠ f (ap g p)
apᶠ-∘ {p = refl} = refl
}
%```
}

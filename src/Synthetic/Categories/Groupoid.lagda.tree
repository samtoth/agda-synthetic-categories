\subtree[fre-3A0E]{
\title{Groupoids}
\author{fredrikbakke}
\taxon{Definition}

\p{
A type is a \em{groupoid} if it is both [#{\Delta^1}-discrete](stt-00B6) and
[simplicial](stt-00AC).
}

%```agda
\agda{
fam-is-groupoid : рқҹҷ вҠҺ (О”В№ Г— О”В№) вҶ’ Type рқ“ҳ
fam-is-groupoid (inl _) = О”В№
fam-is-groupoid (inr ij) = fam-is-simplicial ij

is-groupoid : вҲҖ {рқ“Ө} (A : Type рқ“Ө) вҶ’ Type (рқ“ҳ вҠ” рқ“Ө)
is-groupoid = is-null fam-is-groupoid

is-groupoidвҶҗis-О”В№-discreteГ—is-simplicial
  : вҲҖ {рқ“Ө} {A : Type рқ“Ө}
  вҶ’ is-О”В№-discrete A Г— is-simplicial A
  вҶ’ is-groupoid A
is-groupoidвҶҗis-О”В№-discreteГ—is-simplicial (О”В№-discrete , simp) (inl *) = О”В№-discrete *
is-groupoidвҶҗis-О”В№-discreteГ—is-simplicial (О”В№-discrete , simp) (inr ij) = simp ij

is-О”В№-discreteГ—is-simplicialвҶҗis-groupoid
  : вҲҖ {рқ“Ө} {A : Type рқ“Ө}
  вҶ’ is-groupoid A
  вҶ’ is-О”В№-discrete A Г— is-simplicial A
is-О”В№-discreteГ—is-simplicialвҶҗis-groupoid grp
  = (О» _ вҶ’ grp (inl tt)) , (О» ij вҶ’ grp (inr ij))

is-О”В№-discreteГ—is-simplicial-is-prop
  : вҲҖ {рқ“Ө} {A : Type рқ“Ө}
  вҶ’ is-prop (is-О”В№-discrete A Г— is-simplicial A)
is-О”В№-discreteГ—is-simplicial-is-prop {A = A}
  = is-prop-ОЈ (is-null-is-prop A) (О» _ вҶ’ is-null-is-prop A)

is-groupoidвүғis-О”В№-discreteГ—is-simplicial
  : вҲҖ {рқ“Ө} {A : Type рқ“Ө}
  вҶ’ is-groupoid A вүғ (is-О”В№-discrete A Г— is-simplicial A)
is-groupoidвүғis-О”В№-discreteГ—is-simplicial {A = A}
  = mkвүғ is-О”В№-discreteГ—is-simplicialвҶҗis-groupoid
      (is-equivвҶҗinverse
        (is-null-is-prop A)
        is-О”В№-discreteГ—is-simplicial-is-prop
        is-groupoidвҶҗis-О”В№-discreteГ—is-simplicial)

is-О”В№-discreteвҶҗis-groupoid : вҲҖ {рқ“Ө} {A : Type рқ“Ө} вҶ’ is-groupoid A вҶ’ is-О”В№-discrete A
is-О”В№-discreteвҶҗis-groupoid grp = fst (is-О”В№-discreteГ—is-simplicialвҶҗis-groupoid grp)

is-simplicialвҶҗis-groupoid : вҲҖ {рқ“Ө} {A : Type рқ“Ө} вҶ’ is-groupoid A вҶ’ is-simplicial A
is-simplicialвҶҗis-groupoid grp = snd (is-О”В№-discreteГ—is-simplicialвҶҗis-groupoid grp)

Grpd-SubU : вҲҖ {рқ“Ө} вҶ’ SubU рқ“Ө (рқ“Ө вҠ” рқ“ҳ)
Grpd-SubU = Null-SubU fam-is-groupoid _

Grpd-gSubU : gSubU (_вҠ” рқ“ҳ)
Grpd-gSubU = Null-gSubU fam-is-groupoid

Grpd-is-globally-reflective
  : is-globally-reflective Grpd-gSubU
Grpd-is-globally-reflective = Null-globally-reflective

Grpd-gRSubU : gRSubU (_вҠ” рқ“ҳ)
Grpd-gRSubU .gRSubU.GS = Grpd-gSubU
Grpd-gRSubU .gRSubU.has-is-globally-reflective = Grpd-is-globally-reflective

open gSubU Grpd-gSubU public using () renaming
  ( вҲҲSвҶҗequiv to is-groupoidвҶҗequiv)

open gReflectiveClosure Grpd-gRSubU public using () renaming
  ( О вҲҲS to О -is-groupoid
  ; ULiftвҲҲS to ULift-is-groupoid
  ; рқҹҷвҲҲS to рқҹҷ-is-groupoid
  ; вҲҲSвҶҗis-singleton to is-groupoidвҶҗis-singleton
  ; вҲҲSвҶҗretract to is-groupoidвҶҗretract
  ; PullbackвҲҲS to Pullback-is-groupoid
  ; fibreвҲҲS to fibre-is-groupoid
  ; Г—вҲҲS to Г—-is-groupoid
  ; пјқвҲҲS to пјқ-is-groupoid
  ; ~вҲҲS to ~-is-groupoid
  ; retractвҲҲS to retract-is-groupoid
  ; biinvвҲҲS to biinv-is-groupoid
  ; вүғвҲҲS to вүғ-is-groupoid
  ; EqualiserвҲҲS to Equaliser-is-groupoid
  ; Seq-limвҲҲS to Seq-lim-is-groupoid
  ; preidempotent-mapвҲҲS to preidempotent-map-is-groupoid
  ; qidempotent-mapвҲҲS to qidempotent-map-is-groupoid
  ; RetractsвҲҲS to Retracts-is-groupoid)

ОЈ-is-groupoid : is-globally-ОЈ-closed Grpd-gSubU
ОЈ-is-groupoid = Null-globally-ОЈ-closed

module Grpd where
  open gSubU Grpd-gSubU public using ()
  open gRSubUInduction Grpd-gRSubU ОЈ-is-groupoid public
  open gReflectiveClosure Grpd-gRSubU public
  open gRSubU Grpd-gRSubU public

Grpd-U : (рқ“Ө : Level) вҶ’ Type (lsuc (рқ“ҳ вҠ” рқ“Ө))
Grpd-U рқ“Ө = ОЈ[ A вҲ¶ Type (рқ“ҳ вҠ” рқ“Ө) ] is-groupoid A

Grpd-U-is-simplicial
  : {рқ“Ө : Level} вҶ’ is-simplicial (Grpd-U рқ“Ө)
Grpd-U-is-simplicial {рқ“Ө}
  = is-simplicialвҶҗequiv
      ((ОЈ-ap-вүғ О» A вҶ’ is-groupoidвүғis-О”В№-discreteГ—is-simplicial {A = A}) eвҒ»В№)
      (Null-in-gSubU-is-nullвҶҗis-prop
        {рқ“Ө = рқ“ҳ} {рқ“Ҙ = рқ“Ө}
        {P = fam-is-simplicial}
        {S = О”В№DiscreteType-gSubU}
        (О» (i , j) вҶ’ *-is-prop вүӨ-is-prop вүӨ-is-prop)
        (О» _ вҶ’ О -is-О”В№-discrete))
}
%```
}

\subtree[stt-00B7]{
\title{#{\Delta^1}-discrete types are local at the end point inclusions of the interval}
\taxon{Theorem}
\author{samueltoth}

\p{
A type is [#{\Delta^1}-discrete](stt-00B6) iff it is local with respect to the point
inclusion #{\{0\} \to \Delta^1} iff it is local to the point inclusion
#{\{1\} \to \Delta^1}. In particular, every [groupoid](fre-3A0E) is
left(right)-local.
}

%```agda
\agda{
is-left-local : вҲҖ {рқ“Ө} (A : Type рқ“Ө) вҶ’ Type (рқ“ҳ вҠ” рқ“Ө)
is-left-local = is-local (О» (_ _ : рқҹҷ) вҶ’ i0)

is-О”В№-discreteвҶҗis-left : вҲҖ {рқ“Ө} {A : Type рқ“Ө} вҶ’ is-left-local A вҶ’ is-О”В№-discrete A
is-О”В№-discreteвҶҗis-left {_}{A} il x
  = is-equiv~вҲҳ (il x в—Ӯeqv ((Оө в–ё point) ~вҒ»В№)) (is-equivвҒ»В№ (il x)) point-is-equiv where
  open is-equiv (il x)

is-leftвҶҗis-О”В№-discrete : вҲҖ {рқ“Ө} {A : Type рқ“Ө} вҶ’ is-О”В№-discrete A вҶ’ is-left-local A
is-leftвҶҗis-О”В№-discrete {_} {A} gp x
  = is-equiv~вҲҳ (((point в—Ӯ О·) ~вҒ»В№) в–ёeqv (gp x)) point-is-equiv (is-equivвҒ»В№ (gp x)) where
  open is-equiv (gp x)

is-leftвҶҗis-groupoid : вҲҖ {рқ“Ө} {A : Type рқ“Ө} вҶ’ is-groupoid A вҶ’ is-left-local A
is-leftвҶҗis-groupoid = is-leftвҶҗis-О”В№-discrete вҲҳ is-О”В№-discreteвҶҗis-groupoid
}
%```
}

\subtree[fre-0CC5]{
\title{A type is #{\Delta^1}-discrete if morphisms give equalities}
\taxon{Lemma}
\author{fredrikbakke}
\date{2026-03-30}

\p{
Any type that has a comparison map #{\Hom_A(a,b) \to (a = b)} for all #{a} and #{b}
is [#{\Delta^1}-discrete](stt-00B6).
}

%```agda
\agda{
is-О”В№-discreteвҶҗIdвҶҗHom
  : {рқ“Ө : Level} {A : Type рқ“Ө}
  вҶ’ ({a b : A} вҶ’ Hom A a b вҶ’ a пјқ b)
  вҶ’ is-О”В№-discrete A
is-О”В№-discreteвҶҗIdвҶҗHom {A = A} homвҶ’id
  = is-О”В№-discreteвҶҗis-left О» _ вҶ’ precomp-i0-is-equiv where

    restrict : (h : О”В№ вҶ’ A) (t : О”В№) вҶ’ Hom A (h i0) (h t)
    restrict h t .HomбөҲ.hom j = h (j вҲ§ t)
    restrict h t .HomбөҲ.hom0 = ap h 0-init
    restrict h t .HomбөҲ.hom1 = ap h (вҲ§-comm вҲҷ 1-top)

    precomp-i0-is-equiv : is-equiv (precomp A (point i0))
    precomp-i0-is-equiv
      = is-equivвҶҗqiso
          ( const A О”В№ вҲҳ ev tt
          , (О» h вҶ’ funextвҶ’ О» t вҶ’ homвҶ’id (restrict h t))
          , ~refl)
}
%```
}

\subtree[fre-1337]{
\title{The Hom types of a Segal type are #{\Delta^1}-discrete}
\date{2026-03-30}
\author{fredrikbakke}
\taxon{Theorem}

\p{
If #{A} is a [Segal type](stt-00AI), then every Hom type #{\Hom_A(a,b)} is a
[#{\Delta^1}-discrete](stt-00B6). In fact, any type whose left and right homotopies
characterise equality have #{\Delta^1}-discrete Hom types.
}

\proof{
If left and right homotopies are extensional, then we can construct a map from
morphisms to equalities on the Hom types themselves. Given #{f, g : \Hom_A(a,b)} and
a morphism of morphisms #{\alpha : \Hom_{\Hom_A(a,b)}(f,g)}, viewed as a square
#{(i,j) \mapsto \alpha(i)(j)} that is constantly #{a} on #{j = 0} and constantly #{b}
on #{j = 1}, we apply \ref{fre-1338} to #{\alpha} as a morphism over #{\id_b}
to extract a diagonal #{\alpha_\Delta(i) \coloneqq \alpha(i)(i)} together with two
composition triangles:
\ul{
\li{The upper triangle #{(i,j) \mapsto \alpha(j)(i)} for #{i \leq j} fills
#{\mathrm{Hom}^2(\id_b, f, \alpha_\Delta)}, witnessing #{f \rhtpy \alpha_\Delta}.}
\li{The lower triangle #{(i,j) \mapsto \alpha(i)(j)} for #{i \leq j} fills
#{\mathrm{Hom}^2(g, \id_a, \alpha_\Delta)}, witnessing #{g \lhtpy \alpha_\Delta}.}
}
Hence #{\Hom_A(a,b)} is #{\Delta^1}-discrete.
}

%```agda
\agda{
IdвҶҗHom-Hom
  : {рқ“Ө : Level} {A : Type рқ“Ө} {a b : A}
  вҶ’ ({f g : Hom A a b} вҶ’ f ~в–ө g вҶ’ f пјқ g)
  вҶ’ ({f g : Hom A a b} вҶ’ f в–ө~ g вҶ’ f пјқ g)
  вҶ’ {f g : Hom A a b}
  вҶ’ Hom (Hom A a b) f g
  вҶ’ f пјқ g
IdвҶҗHom-Hom {b = b} leftвҶ’id rightвҶ’id {f} {g} Оұ
  = rightвҶ’id (Hom2вҶҗHom-over (idH b) f {g} Оұ)
  вҲҷ sym (leftвҶ’id (~в–өвҶҗHom-over (idH b) f {g} Оұ))

Hom-is-О”В№-discrete
  : {рқ“Ө : Level} {A : Type рқ“Ө} {a b : A}
  вҶ’ ((f : Hom A a b) вҶ’ is-singleton (ОЈ[ g вҲ¶ Hom A a b ] (f ~в–ө g)))
  вҶ’ ((f : Hom A a b) вҶ’ is-singleton (ОЈ[ g вҲ¶ Hom A a b ] (f в–ө~ g)))
  вҶ’ is-О”В№-discrete (Hom A a b)
Hom-is-О”В№-discrete {рқ“Ө} {A} {a} {b} left-tors right-tors
  = is-О”В№-discreteвҶҗIdвҶҗHom (IdвҶҗHom-Hom leftвҶ’id rightвҶ’id) where

  leftвҶ’id : {f g : Hom A a b} вҶ’ f ~в–ө g вҶ’ f пјқ g
  leftвҶ’id {f} = fundamental-IdвҒ»В№ (f ~в–ө_) (left-tors f) (О» _ вҶ’ ~в–өвҶҗпјқ)

  rightвҶ’id : {f g : Hom A a b} вҶ’ f в–ө~ g вҶ’ f пјқ g
  rightвҶ’id {f} = fundamental-IdвҒ»В№ (f в–ө~_) (right-tors f) (О» _ вҶ’ в–ө~вҶҗпјқ)

Hom-is-О”В№-discreteвҶҗis-segal
  : {рқ“Ө : Level} {A : Type рқ“Ө}
  вҶ’ is-segal A
  вҶ’ {a b : A} вҶ’ is-О”В№-discrete (Hom A a b)
Hom-is-О”В№-discreteвҶҗis-segal рқҗҙ
  = Hom-is-О”В№-discrete (~в–ө-is-torsorial рқҗҙ) (в–ө~-is-torsorial рқҗҙ)
}
%```
}

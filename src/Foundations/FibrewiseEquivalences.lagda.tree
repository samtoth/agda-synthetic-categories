\date{2025-04-14}
\title{Fibrewise equivalences}
\taxon{Module}

\import{stt-macros}

\agda{
module Foundations.FibrewiseEquivalences where

open import Foundations.Universes
open import Foundations.Sigma
open import Foundations.SigmaIdentity
open import Foundations.Identity
open import Foundations.DependentIdentity
open import Foundations.Functions
open import Foundations.QuasiEquivalences
open import Foundations.Equivalences
}

\subtree[stt-0029]{
\taxon{Definition}
\title{Fibrewise equivalence}

\agda{
is-fibrewise-equiv
  : вҲҖ {рқ“Ө рқ“Ҙ рқ“Ұ} {A : Type рқ“Ө} {B : A вҶ’ Type рқ“Ҙ} {B' : A вҶ’ Type рқ“Ұ}
    вҶ’ (вҲҖ a вҶ’ B a вҶ’ B' a) вҶ’ Type (рқ“Ө вҠ” рқ“Ҙ вҠ” рқ“Ұ)
is-fibrewise-equiv f = вҲҖ a вҶ’ is-equiv (f a)
}
}


\subtree[stt-0030]{
\taxon{Theorem}
\title{Equivalences on fibres give equivalences on the total}

\agda{
total-map
  : вҲҖ {рқ“Ө рқ“Ҙ рқ“Ұ} {A : Type рқ“Ө} {B : A вҶ’ Type рқ“Ҙ} {B' : A вҶ’ Type рқ“Ұ}
    вҶ’ (f : вҲҖ a вҶ’ B a вҶ’ B' a) вҶ’ ОЈ A B вҶ’ ОЈ A B'
total-map f (a , b) = (a , f a b)

ap-total-map-ОЈ-pathвҶ’refl
  : вҲҖ {рқ“Ө рқ“Ҙ рқ“Ұ} {A : Type рқ“Ө} {B : A вҶ’ Type рқ“Ҙ} {B' : A вҶ’ Type рқ“Ұ}
    вҶ’ (f : вҲҖ a вҶ’ B a вҶ’ B' a)
    вҶ’ {a : A} {x y : B a}
    вҶ’ (p : x пјқ y)
    вҶ’ ap (total-map f) (ОЈ-pathвҶ’ (refl , p))
    пјқ ОЈ-pathвҶ’ (refl , ap (f a) p)
ap-total-map-ОЈ-pathвҶ’refl f refl = refl

is-total-equivвҶҗis-fibrewise-equiv
  : вҲҖ {рқ“Ө рқ“Ҙ рқ“Ұ} {A : Type рқ“Ө}
      {B : A вҶ’ Type рқ“Ҙ} {B' : A вҶ’ Type рқ“Ұ} вҶ’ {f : вҲҖ a вҶ’ B a вҶ’ B' a}
    вҶ’ is-fibrewise-equiv f вҶ’ is-equiv (total-map f)
is-total-equivвҶҗis-fibrewise-equiv {A = A} {B = B} {f = f} feq = mk-eqv qinv coh where
  module F x = is-equiv (feq x)

  qinv : quasi-inv (total-map f)
  qinv .fst (a , b) = a , F.bwd a b
  qinv .snd .fst (a , b) = ОЈ-pathвҶ’ (refl , F.retraction-fwd a .snd b)
  qinv .snd .snd (a , b) = ОЈ-pathвҶ’ (refl , F.section-fwd a .snd b)

  coh : qinv-coh qinv
  coh (a , b)
    = ap-total-map-ОЈ-pathвҶ’refl f (F.retraction-fwd a .snd b)
    вҲҷ ap (ОЈ-pathвҶ’ вҲҳ (refl ,_)) (F.coherent a b)

ОЈ-snd-вүғ
  : вҲҖ {рқ“Ө рқ“Ҙ рқ“Ұ} {A : Type рқ“Ө} {B : A вҶ’ Type рқ“Ҙ} {B' : A вҶ’ Type рқ“Ұ}
    вҶ’ ((a : A) вҶ’ B a вүғ B' a) вҶ’ ОЈ A B вүғ ОЈ A B'
ОЈ-snd-вүғ eq = mkвүғ (total-map (_вүғ_.fwd вҲҳ eq))
                 (is-total-equivвҶҗis-fibrewise-equiv (_вүғ_.fwd-is-equiv вҲҳ eq))
}
}

\subtree[stt-008R]{
\title{Characterising fibrewise equivalences}
\taxon{Corollary}

\agda{
fibrewise-equivвүғ
  : вҲҖ {рқ“Ө рқ“Ҙ рқ“Ұ} {A : Type рқ“Ө} {B : A вҶ’ Type рқ“Ҙ}
      {B' : A вҶ’ Type рқ“Ұ}
    вҶ’ (ОЈ[ f вҲ¶ (вҲҖ a вҶ’ B a вҶ’ B' a)] is-fibrewise-equiv f)
    вүғ (вҲҖ a вҶ’ B a вүғ B' a)
fibrewise-equivвүғ {B = B} {B'} = mkвүғ map (mk-eqv qinv coh) where
  map : ОЈ (вҲҖ a вҶ’ B a вҶ’ B' a) is-fibrewise-equiv вҶ’ вҲҖ a вҶ’ B a вүғ B' a
  map (f , feq) a = mkвүғ (f a) (feq a)

  qinv : quasi-inv map
  qinv .fst fe = ( (О» a x вҶ’ fe a ._вүғ_.fwd x)
                 , (О» a вҶ’ fe a ._вүғ_.fwd-is-equiv))
  qinv .snd .fst _ = refl
  qinv .snd .snd _ = refl

  coh : qinv-coh qinv
  coh _ = refl
}
}

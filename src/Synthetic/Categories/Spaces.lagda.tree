\p{We recall a few easy consequences of the cubes detect continuity and
#{\Delta^1} detects connectivity axioms.}

\agda{
opaque
  cubes-separate : family-separates □^_
  cubes-separate = family-separates←detects-continuity □^_ cubes-detect-cont

  cubes-separate'
    : ∀ {@♭ 𝓤 𝓥} (@♭ fa : Arrow 𝓤 𝓥) (let @♭ f = Arrow.f fa)
      → @♭ ((∀ {@♭ n} → is-equiv (♭-map (postcomp (□^ n) f))))
      → is-equiv f
  cubes-separate' fa eq
    = cubes-separate
        fa
        (tgt-is-equiv←Arrow-equiv (amap , amap-is-equiv) (eq {0}))
        eq where
    open Arrow fa
    amap : Arrow-map (♭-map (postcomp (□^ 0) f)) (♭-map f)
    amap .Arrow-Π.top = ♭-map (ev ttᴸ)
    amap .Arrow-Π.bot = ♭-map (ev ttᴸ)
    amap .Arrow-Π.comm (mod♭ f) = refl

    amap-is-equiv : is-Arrow-equiv amap
    amap-is-equiv .fst = ♭-map-is-equiv (sing-ev-is-equiv global-funext single!)
    amap-is-equiv .snd = ♭-map-is-equiv (sing-ev-is-equiv global-funext single!)
}

\subtree[stt-00AS]{
\title{There is a universe of amazingly covariant types}
\taxon{Construction}

\p{Assuming that the interval is [tiny](Synthetic.Tiny), there is a universe of
\em{amazingly covariant types}, which weakly classify the left fibrations.
We denote it #{\mathcal{S}}.}

\proof{
\p{Since being covariant (or equivalently being a left fibration), is
a [#{\Delta^1}-relative class of maps](stt-00K1). By the machinery
developed for [amazing right adjoints](stt-00AA), we can construct a universe
which classifies this class.
}
}

\agda{
is-covariant-is-relative : is-relative-fam Δ¹ is-covariant
is-covariant-is-relative {B = A} P = (fwd , bwd) where
  fwd : is-covariant P → (x : Δ¹ → A) → is-covariant (P ∘ x)
  fwd cov f h = cov (f ∘ h)

  bwd : ((x : Δ¹ → A) → is-covariant (P ∘ x)) → is-covariant P
  bwd cov h x₀ = cov h id x₀

open Dependent√ Δ¹ √ √ε is-tiny-str
               public
open AmazinglyFibrant Δ¹ √ √ε is-tiny-str
               is-covariant is-covariant-is-prop is-covariant-is-relative
               public
  renaming (is-afib to is-acov;
            UFib to Space;
            UFib∙ to Space∙;
            UFib-π-is-fib to Space-π-is-covariant)
}
}

\subtree[stt-00AU]{
\title{The objects of #{\mathcal{S}} are groupoids}
\taxon{Theorem}

\p{If #{A :^\flat \UU} is a groupoid, then #{A} is amazing covariant and so
factors through #{\mathcal{S}}.}

\agda{
groupoids-in-Space : ∀ {@♭ 𝓤} (@♭ A : Type 𝓤) → @♭ is-Δ¹-discrete A → is-acov A
groupoids-in-Space A Δ¹-discrete
  = ε♭ (liftFib .fst
         (mod♭ (is-covariant↔is-left-fibration
                 (λ _ → A) .snd
                   (is-orthogonal↔orthogonal-! .snd
                     (is-left←is-Δ¹-discrete
                       (Null-globally-Σ-closed
                         (𝟙-is-Δ¹-discrete)
                         (λ _ → Δ¹-discrete)) tt))))) tt
}
}

\subtree[stt-00L2]{
\title{Closure properties of amazing covariance}
\taxon{Theorem}

\p{The universe of amazingly covariant types is closed under
#{\times, \Sigma} and #{=}.
}

\proof{
\p{The proof strategy for all of the results are the same, in general we may
reduce the problem to the analogous [closure conditions for covariant
families](Synthetic.Categories.CovariantClosure).}

\p{We provide the proof for closure under equality as an example. Let #{\Gamma}
be the type #{\Sigma_{A : \mathcal{S}} (A \times A)}, and #{\sigma} the map
#{\Gamma \to \Type} defined as #{(A,a,b) \mapsto a = b}. We need to show that
#{\Pi_{x : \Gamma} \textsf{is-Acov}(\sigma x)}, which by unfolding the definition
of amazing covariance is just
#{\Pi_{x : \Gamma} \sqrt{\textsf{is-covariant}}(\sigma x)}, but by naturality
of the #{\sqrt[I]{{-}}} former, this is the same as
#{\Pi_{x : \Gamma} \sqrt{\textsf{is-covariant} \circ \sigma_*}(x)}. We may
use the universal property of #{\sqrt{-}} so that it suffices to give an
element #{\Pi_{x : \Gamma^{\Delta^1}} \textsf{is-covariant}(\sigma_* \circ x)}.
}

\p{Now we have dealt with the root former, we may proceed less formally. We have
a map #{A : \Delta^1 \to \mathcal{S}}, which means #{A} is a covariant family of
types over #{\Delta^1}, and a pair of sections #{a\ b : \Pi_{\Delta^1} A},
we want to show #{i \mapsto a_i = b_i} is covariant, which [follows by general
closure properties of orthogonality](stt-00KG).}
}


\agda{
opaque
  ×-is-acov
    : ∀ {@♭ 𝓤 𝓥} {A : Type 𝓤} {B : Type 𝓥}
      → is-acov A → is-acov B → is-acov (A × B)
  ×-is-acov {𝓤} {𝓥} a b = need ((mk-ufib _ a) , (mk-ufib _ b)) where
    open Space
    @♭ ϕ : (x : Δ¹ → Space 𝓤 × Space 𝓥)
         → is-covariant (λ i → x i .fst .Carrier × x i .snd .Carrier)
    ϕ Γ = ×-is-covariant
               {P = Carrier ∘ fst ∘ Γ}
               {Q = Carrier ∘ snd ∘ Γ}
               (UFib-is-fib (fst ∘ Γ))
               (UFib-is-fib (snd ∘ Γ))

    ϕ̂ : Π (Space 𝓤 × Space 𝓥)
              (√ᵈ (λ g → is-covariant (λ i → g i .fst .Carrier × g i .snd .Carrier)))
    ϕ̂ = ε♭ (rintro (mod♭ ϕ))

    need : (Γ : Space 𝓤 × Space 𝓥) → (is-acov (Γ .fst .Carrier × Γ .snd .Carrier))
    need g = √ᵈ-naturality← _ _ _ (ϕ̂ g)

instance
  ×-Is-acov
    : ∀ {@♭ 𝓤 𝓥} {A : Type 𝓤} {B : Type 𝓥}
        ⦃ _ : is-acov A ⦄ ⦃ _ : is-acov B ⦄
      → is-acov (A × B)
  ×-Is-acov = ×-is-acov auto! auto!

opaque
  Σ-is-acov
    : ∀ {@♭ 𝓤 𝓥} {A : Type 𝓤} {B : A → Type 𝓥}
      → is-acov A → (∀ a → is-acov (B a)) → is-acov (Σ A B)
  Σ-is-acov {𝓤} {𝓥} a b = need ((mk-ufib _ a) , (λ i → mk-ufib _ (b i))) where
    open Space
    @♭ Γ : Type (lsuc (𝓘 ⊔ 𝓤 ⊔ 𝓥))
    Γ = Σ[ A ∶ Space 𝓤 ] (A .Carrier → Space 𝓥)

    @♭ πΓ : Γ → Type (𝓤 ⊔ 𝓥)
    πΓ Γ = Σ (Γ .fst .Carrier) (Carrier ∘ Γ .snd)

    @♭ ϕ : (x : Δ¹ → Γ) → is-covariant (λ i → Σ (x i .fst .Carrier) (Carrier ∘ x i .snd))
    ϕ x = Σ-is-covariant
            {B = Carrier ∘ fst ∘ x}
            {C = λ i a → x i .snd a .Carrier}
            (UFib-is-fib (fst ∘ x))
            (UFib-is-fib (uncurry (snd ∘ x)))

    @♭ ϕ̂ : Π Γ (√ᵈ(λ a → is-covariant (λ i → Σ (a i .fst .Carrier) (Carrier ∘ a i .snd))))
    ϕ̂ = ε♭ (rintro (mod♭ ϕ))

    need : (x : Γ) → is-acov (Σ (x .fst .Carrier) (Carrier ∘ x .snd))
    need x = √ᵈ-naturality← is-covariant _ x (ϕ̂ x)

instance
  Σ-Is-acov
    : ∀ {@♭ 𝓤 𝓥} {A : Type 𝓤} {B : A → Type 𝓥}
      → ⦃ _ : is-acov A ⦄ ⦃ _ : ∀ {a} → is-acov (B a) ⦄
      → is-acov (Σ A B)
  Σ-Is-acov = Σ-is-acov auto! (λ _ → auto!)

opaque
  ＝-is-acov
    : ∀ {@♭ 𝓤} {A : Type 𝓤} {a b : A}
      → is-acov A → is-acov (a ＝ b)
  ＝-is-acov {𝓤} {A} ac = need (mk-ufib A ac , _ , _) where
    open Space
    @♭ Γ : Type (lsuc (𝓘 ⊔ 𝓤))
    Γ = Σ (Space 𝓤) (λ A → A .Carrier × A .Carrier)

    @♭ σ : Γ → Type 𝓤
    σ x = x .snd .fst ＝ x .snd .snd

    @♭ ϕ : Π (Δ¹ → Γ) (is-covariant ∘ postcomp Δ¹ σ)
    ϕ g = ＝-is-covariant a b A'-is-cov where
      A' : Δ¹ → Type 𝓤
      A' = Carrier ∘ fst ∘ g

      a b : Π Δ¹ A'
      a = fst ∘ snd ∘ g
      b = snd ∘ snd ∘ g

      A'-is-cov : is-covariant A'
      A'-is-cov = UFib-is-fib (fst ∘ g)

    @♭ ϕ̂ : Π Γ (√ᵈ (is-covariant ∘ postcomp Δ¹ σ))
    ϕ̂ = ε♭ (rintro (mod♭ ϕ))

    need : (x : Γ) → is-acov (σ x)
    need x = √ᵈ-naturality← _ _ _ (ϕ̂ x)

instance
  ＝-is-Acov
    : ∀ {@♭ 𝓤} {A : Type 𝓤} {a b : A} ⦃ _ : is-acov A ⦄
      → is-acov (a ＝ b)
  ＝-is-Acov = ＝-is-acov auto!

opaque
  exp-●-is-acov
   : ∀ {@♭ 𝓤} {A : Type 𝓤}
     → is-acov A
     → (∀ {i} → is-acov (i ＝ i0 → A))
  exp-●-is-acov {𝓤}{A} ac {i}
    = √ᵈ-naturality← _ _ _ (ϕ̂ (mk-ufib A ac , i)) where
    open Space
    @♭ Γ : Type (lsuc (𝓘 ⊔ 𝓤))
    Γ = Space 𝓤 × Δ¹

    @♭ σ : Γ → Type (𝓘 ⊔ 𝓤)
    σ (A , i) = (i ＝ i0) → Carrier A

    @♭ ϕ : Π (Δ¹ → Γ) (is-covariant ∘ postcomp Δ¹ σ)
    ϕ g = ^●-is-covariant Δ¹-endos-mono A' A'-is-cov f where
      A' : Δ¹ → Type 𝓤
      A' = Carrier ∘ fst ∘ g

      A'-is-cov : is-covariant A'
      A'-is-cov = UFib-is-fib (fst ∘ g)

      f : Δ¹ → Δ¹
      f = snd ∘ g

    @♭ ϕ̂ : Π Γ (√ᵈ (is-covariant ∘ postcomp Δ¹ σ))
    ϕ̂ = ε♭ (rintro (mod♭ ϕ))

instance
  exp-●-is-Acov
    : ∀ {@♭ 𝓤} {A : Type 𝓤} ⦃ _ : is-acov A ⦄
      → (∀ {i} → is-acov (i ＝ i0 → A))
  exp-●-is-Acov = exp-●-is-acov auto!
}
}

\subtree[stt-00K6]{
\title{Equivalences of #{Δ¹}-copresheaves}
\taxon{Lemma}

\p{We show that for a pair of copresheaves #{F\ G : \Delta^1 \to \mathcal{S}},
a natural transformation #{\alpha : \Pi_{i} F(i) \to G(i)} is a fibrewise
equivalence iff the restriction along #{\partial \Delta^1 \hookrightarrow \Delta^1}
is a fibrewise-equivalence.}

\p{The proof follows exactly \citet{Lemma 6.8}{GWB24}, although their result
holds more generally for copresheaves #{\Delta^n \to \mathcal{S}}.}

\agda{
transport-Nat-lemma
  : ∀ {𝓤 𝓥 𝓦} {A : Type 𝓤} {F : A → Type 𝓥} {G : A → Type 𝓦}
    → (α : ∀ x → F x → G x) → ∀ x y (x' : F x) (p : x ＝ y)
    → tr G p (α x x')
    ＝ α y (tr F p x')
transport-Nat-lemma α x y x' refl = refl


□-0-is-left-anodyne : ∀ {m : ℕ} → is-left-anodyne (point (□-0 {m}))
□-0-is-left-anodyne {zero} r _ = equiv⊥ lift-is-equiv r
□-0-is-left-anodyne {suc zero} r 0r = 0r
□-0-is-left-anodyne {suc (suc m)} r 0r
  = left-orthogonal-equiv
      (point □-0 ⊗ point i0) (point □-0) a ae r
      (left-orthogonal-× (point □-0) (point i0) r
        (□-0-is-left-anodyne {suc m} r 0r) 0r) where
  a : Arrow-map (point □-0 ⊗ point i0) (point (□-0 , i0))
  a .Arrow-Π.top = !
  a .Arrow-Π.bot = id
  a .Arrow-Π.comm = ~refl

  ae : is-Arrow-equiv a
  ae .fst = sing-!-is-equiv single!
  ae .snd = id-is-equiv
}

\agda{
Cov-Nat-is-equiv
  : ∀ {@♭ 𝓤} (f g : Δ¹ → Space 𝓤) (α : ∀ i → f i .Space.Carrier → g i .Space.Carrier)
    → (∀ x → is-equiv (α (∂Δ¹-incl x))) → ∀ i → is-equiv (α i)
Cov-Nat-is-equiv {𝓤} f g α epeq = is-equiv.bwd part1' epeq where
  @♭ Y : Type (lsuc (𝓤 ⊔ 𝓘))
  Y = Σ[ F G ∶ (Δ¹ → Space 𝓤)]
        Σ[ α' ∶ (∀ i → F i .Space.Carrier → G i .Space.Carrier) ]
          ∀ i → is-equiv (α' i)

  @♭ X : Type (lsuc (𝓤 ⊔ 𝓘))
  X = Σ[ F G ∶ (Δ¹ → Space 𝓤)]
        Σ[ α' ∶ (∀ i → F i .Space.Carrier → G i .Space.Carrier) ]
          ∀ x → is-equiv (α' (∂Δ¹-incl x))

  @♭ forget : Y → X
  forget = total-map
            (λ X → total-map
              (λ Y → total-map (λ α → precomp-Π _ ∂Δ¹-incl)))

  @♭ Γ : ℕ → Type 𝓘
  Γ n = □^ n × Δ¹

  @♭ Γ-is-truncated : ∀ n {k} → is-truncated (𝕋←ℕ k) (Γ n)
  Γ-is-truncated zero = trunc!
  Γ-is-truncated (suc zero) = trunc!
  Γ-is-truncated (suc (suc n)) = trunc!

  open Space

  @♭ Y' : ∀ n → Type (lsuc (𝓘 ⊔ 𝓤))
  Y' n = Σ[ F G ∶ (Γ n → Space 𝓤)]
          Σ[ α' ∶ (∀ i → F i .Space.Carrier → G i .Space.Carrier) ]
            ∀ i → is-equiv (α' i)

  @♭ X' : ∀ n → Type (lsuc (𝓘 ⊔ 𝓤))
  X' n = Σ[ F G ∶ (Γ n → Space 𝓤)]
          Σ[ α' ∶ (∀ i → F i .Space.Carrier → G i .Space.Carrier) ]
            ∀ i → is-equiv (α' (i .fst , ∂Δ¹-incl (i .snd)))

  @♭ arr : ∀ (@♭ n)
        → Arrow-map
            ((postcomp (□^ n) forget))
            {C = Y' n} {X' n}
            (total-map (λ F → total-map λ G → total-map
              (λ α → precomp-Π _ (total-map (λ _ → ∂Δ¹-incl)))))
  arr n .Arrow-Π.top F
    = ( uncurry (fst ∘ F) , uncurry (fst ∘ snd ∘ F)
      , uncurry (fst ∘ snd ∘ snd ∘ F) , uncurry (snd ∘ snd ∘ snd ∘ F))
  arr n .Arrow-Π.bot F
    = ( uncurry (fst ∘ F) , uncurry (fst ∘ snd ∘ F)
      , uncurry (fst ∘ snd ∘ snd ∘ F) , uncurry (snd ∘ snd ∘ snd ∘ F))
  arr n .Arrow-Π.comm = ~refl

  @♭ arr-is-equiv : ∀ (@♭ n) → is-Arrow-equiv (arr n)
  arr-is-equiv n .fst =
    is-equiv←qinv
      ( (λ F g → ( curry (fst F) g , curry (F .snd .fst) g
                 , curry (F .snd .snd .fst) g , curry (F .snd .snd .snd) g))
      , ~refl , ~refl)
  arr-is-equiv n .snd =
    is-equiv←qinv
      ( (λ F g → ( curry (fst F) g , curry (F .snd .fst) g
                 , curry (F .snd .snd .fst) g , curry (F .snd .snd .snd) g))
      , ~refl , ~refl)

  module _ (@♭ n) (@♭ F G : Γ n → Space 𝓤) (@♭ α : ∀ i → F i .Carrier → G i .Carrier) where
     @♭ F̂ : Type (𝓘 ⊔ 𝓤)
     F̂ = Σ (Γ n) (Carrier ∘ F)

     @♭ Ĝ : Type (𝓘 ⊔ 𝓤)
     Ĝ = Σ (Γ n) (Carrier ∘ G)

     @♭ α̂ : F̂ → Ĝ
     α̂ = total-map α

     @♭ lemma
       : @♭ (∀ (k : Σ (□^ n) (λ _ → ∂Δ¹))
         → (is-equiv (α (k .fst , ∂Δ¹-incl (k .snd)))))
         → ⟨♭| Π (Γ n) (λ k → is-equiv (α k)) ⟩
     lemma k = mod♭ (is-fibrewise-equiv←is-total-equiv
                      (cubes-separate'
                        (mk-arrow α̂)
                        λ {m} → part3 m)) where module _ (@♭ m : ℕ) where
       @♭ make-orthogonality
         : Arrow-map (postcomp (□^ m) α̂)
                       {C = Pullback {B = F̂}fst (ev (□-0 {m}))}
                       {D = Pullback {B = Ĝ}fst (ev (□-0 {m}))}
                       (Pullback₁ (mk-cospan-map α̂ id id ~refl ~refl))
       make-orthogonality .Arrow-Π.top = orthogonal-point-gap-map □-0
       make-orthogonality .Arrow-Π.bot = orthogonal-point-gap-map □-0
       make-orthogonality .Arrow-Π.comm x = pullback-path→
         ( refl
         , refl
         , ap (_∙ refl) (ap-id (ap (ev tt) (sym (funext→ ~refl)) ∙ refl)))

       make-orthogonality-is-equiv : is-Arrow-equiv make-orthogonality
       make-orthogonality-is-equiv .fst
         = orthogonal-point-pullback-condition □-0
             (□-0-is-left-anodyne fst
               (is-covariant↔is-left-fibration (Carrier ∘ F) .fst (UFib-is-fib F)))
       make-orthogonality-is-equiv .snd
         = orthogonal-point-pullback-condition □-0
             (□-0-is-left-anodyne fst
               (is-covariant↔is-left-fibration (Carrier ∘ G) .fst (UFib-is-fib G)))

       @♭ final-map : (Σ[♭ k ∶ (□^ m → Γ n)] ⟨♭| F (k □-0) .Carrier ⟩)
                    → (Σ[♭ k ∶ (□^ m → Γ n)] ⟨♭| G (k □-0) .Carrier ⟩)
       final-map = total-map (♭ᶠ-map (λ a → α (a □-0)))

       @♭ refactor-map
         : ∀ (@♭ K : Γ n → Space 𝓤)
             (let @♭ K̂ = Σ _ (Carrier ∘ K))
         → ⟨♭| Pullback {B = K̂}fst (ev (□-0 {m}))⟩
         → (Σ[♭ k ∶ (□^ m → Γ n)] ⟨♭| K (k □-0) .Carrier ⟩)
       refactor-map K (mod♭ ((a , a') , b , p))
          = (mod♭ b , mod♭ (tr (Carrier ∘ K) p a'))

       @♭ refactor-map-is-equiv
         : ∀ (@♭ K : Γ n → Space 𝓤) → is-equiv (refactor-map K)
       refactor-map-is-equiv K = is-equiv←qinv
         ( (λ where (mod♭ f , mod♭ g) → mod♭ ((f □-0 , g) , f , refl))
         , (λ where
               (mod♭ ((a , a') , b , p))
                 → mapply♭
                     (mod♭ (pullback-path→
                             ( Σ-path→ (sym p , tr∘tr-sym p a')
                             , refl
                             , is-set←is-truncated
                                 (Γ-is-truncated n)
                                 _ _ _ _))))
         , λ where (mod♭ a , mod♭ b) → refl)

       @♭ refactor
         : Arrow-map
             {A = ⟨♭| Pullback {B = F̂}fst (ev (□-0 {m}))⟩}
             {B = ⟨♭| Pullback {B = Ĝ}fst (ev (□-0 {m}))⟩}
             (♭-map (Pullback₁ (mk-cospan-map α̂ id id ~refl ~refl)))
             (final-map)
       refactor .Arrow-Π.top = refactor-map F
       refactor .Arrow-Π.bot = refactor-map G
       refactor .Arrow-Π.comm (mod♭ ((x , x') , y , p))
         = Σ-path→ (refl
                   , mapply♭
                       (mod♭ (ap (λ p → tr (Carrier ∘ G) p (α x x'))
                                 (ap (_∙ refl) (ap-id p) ∙ ∙-reflr _)
                             ∙ transport-Nat-lemma α x (y □-0) x' p)))

       @♭ refactor-is-equiv : is-Arrow-equiv refactor
       refactor-is-equiv .fst = refactor-map-is-equiv F
       refactor-is-equiv .snd = refactor-map-is-equiv G

       @♭ part4 : is-equiv final-map
       part4 = is-total-equiv←is-fibrewise-equiv
         (♭-ind λ x → ♭Δ¹-ind (λ i → is-equiv (♭-map (α (x □-0 .fst , i))))
                                (♭-map-is-equiv (k (x □-0 .fst , ∂Δ¹-0)))
                                (♭-map-is-equiv (k (x □-0 .fst , ∂Δ¹-1)))
                                (snd (x □-0)))

       @♭ part3 : is-equiv (♭-map (postcomp (□^ m) α̂))
       part3 = src-is-equiv←Arrow-equiv
                 ( paste-squares refactor (♭Square make-orthogonality)
                 , paste-squares-is-equiv
                     _ refactor-is-equiv
                     _ (♭-square-is-equiv _ (make-orthogonality-is-equiv)))
                 part4

     @♭ part2 : is-equiv (♭-map (precomp-Π (λ k → is-equiv (α k))
                                        (total-map (λ _ → ∂Δ¹-incl))))
     part2 = is-equiv←inverse
               (♭-is-prop (Π-is-prop (λ a → is-equiv-is-prop)))
               (♭-is-prop (Π-is-prop (λ a → is-equiv-is-prop)))
               (♭-ind lemma)


  part1 : is-equiv forget
  part1 = cubes-separate'
    (mk-arrow forget)
    (λ {n} → src-is-equiv←Arrow-equiv
       ( ♭Square (arr n)
       , ♭-map-is-equiv (arr-is-equiv n .fst)
       , ♭-map-is-equiv (arr-is-equiv n .snd))
       (♭-map-total-is-equiv _
         (is-total-equiv←is-fibrewise-equiv
           (♭-ind λ F → ♭-map-total-is-equiv _
             (is-total-equiv←is-fibrewise-equiv
               (♭-ind λ G → ♭-map-total-is-equiv _
                 (is-total-equiv←is-fibrewise-equiv
                   (♭-ind (λ α → part2 n F G α)))))))))

  opaque
    part1' : is-equiv (precomp-Π (λ i → is-equiv (α i)) ∂Δ¹-incl)
    part1' = is-fibrewise-equiv←is-total-equiv
                {f = λ α → precomp-Π _ ∂Δ¹-incl}
                (is-fibrewise-equiv←is-total-equiv
                  (is-fibrewise-equiv←is-total-equiv
                    part1 f) g) α
}
}

\subtree[stt-00KW]{
\title{Paths in #{\mathcal{S}^→}}
\taxon{Lemma}

\agda{
module _ where
  open Space
  SpaceΣ : ∀ (@♭ 𝓤) → Type (lsuc (𝓘 ⊔ 𝓤))
  SpaceΣ 𝓤 = Σ[ A B ∶ Space 𝓤 ] (Carrier A → Carrier B)

  SpaceΣ-Path
    : ∀ {@♭ 𝓤} (x y : (Σ[ A B ∶ Space 𝓤 ] (Carrier A → Carrier B)))
      → Type 𝓤
  SpaceΣ-Path (A , B , f) (X , Y , g)
    = Σ[ e ∶ A .Carrier ≃ X .Carrier ] Σ[ p ∶ B .Carrier ≃ Y .Carrier ]
        (p ._≃_.fwd ∘ f ~ g ∘ e ._≃_.fwd)

  SpaceΣ-Path-refl
    : ∀ {@♭ 𝓤} (x : (Σ[ A B ∶ Space 𝓤 ] (Carrier A → Carrier B)))
      → SpaceΣ-Path x x
  SpaceΣ-Path-refl x = (id≃ , id≃ , ~refl)

module SpacePath
  (@♭ √ᵈ-is-prop : ∀ {@♭ 𝓤 𝓥} {@♭ Γ : Type 𝓤} (@♭ A : (Δ¹ → Γ) → Type 𝓥)
                   → (∀ g → is-prop (A g)) → ∀ g → is-prop (√ᵈ A g))
  where
  open Space
  open UIdS √ᵈ-is-prop

  opaque
    SpaceΣ-Path-is-torsorial
      : ∀ {@♭ 𝓤} (x : (Σ[ A B ∶ Space 𝓤 ] (Carrier A → Carrier B)))
        → is-singleton (Σ _ (SpaceΣ-Path x))
    SpaceΣ-Path-is-torsorial (A , B , f)
      = is-singleton-structure←parts
         (SingS-is-single A)
         (A , id≃)
         (is-singleton-structure←parts
           (SingS-is-single B)
           (B , id≃)
           (SingS-is-single f))

  instance
    SpaceΣ-IdS
      : ∀ {@♭ 𝓤} → Identity-system ((Σ[ A B ∶ Space 𝓤 ] (Carrier A → Carrier B))) 𝓤
    SpaceΣ-IdS .Identity-system.IdS = SpaceΣ-Path
    SpaceΣ-IdS .Identity-system.IdS←Id {a = A} refl = SpaceΣ-Path-refl A
    SpaceΣ-IdS .Identity-system.IdS←Id-is-equiv x
      = fundamental-Id _ (SpaceΣ-Path-is-torsorial x) _
}
}

\subtree[stt-00AT]{
\title{#{\mathcal{S}} is directed univalent}
\taxon{Theorem}

\p{We show that #{\mathcal{S}} is directed univalent. That is, arrows in
#{\mathcal{S}} correspond exactly to pairs of groupoids, together with a function
between them.}

\proof{
\p{We start by noting that there is a canonial map
from #{F : \mathcal{S}^{\Delta^1}} to #{F(0) \to F(1)} given by covariant
transport.}

\agda{
tr-𝓢 : ∀ {@♭ 𝓤} → (f : Δ¹ → Space 𝓤) → Space.Carrier (f i0) → Space.Carrier (f i1)
tr-𝓢 = tr-cov {P = Space.Carrier} Space-π-is-covariant

tr-𝓢-unique
  : ∀ {@♭ 𝓤} (f : Δ¹ → Space 𝓤)
      {F : Space.Carrier (f i0) → Space.Carrier (f i1)}
    → ∀ x → (Homᵈ (Space.Carrier ∘ f) x (F x))
    → tr-𝓢 f x ＝ F x
tr-𝓢-unique f {F = F} x p = ap fst (Space-π-is-covariant f x .central (F x , p))

dua→
  : ∀ {@♭ 𝓤} → (Δ¹ → Space 𝓤)
    → Σ[ A B ∶ Space 𝓤 ] (Space.Carrier A → Space.Carrier B)
dua→ h = (h i0 , h i1 , tr-𝓢 h)

coe-𝓢
  : ∀ {@♭ 𝓤} (f : Δ¹ → Space 𝓤) {i j} → i ≤ j
    → Space.Carrier (f i) → Space.Carrier (f j)
coe-𝓢 f = coe-cov (Space.Carrier ∘ f) (UFib-is-fib f)

coe-𝓢-id
  : ∀ {@♭ 𝓤} (f : Δ¹ → Space 𝓤) {i} (p : i ≤ i)
    → coe-𝓢 f p ~ id
coe-𝓢-id f = coe-cov-id (Space.Carrier ∘ f) (UFib-is-fib f)

module _
  (@♭ √ᵈ-is-prop : ∀ {@♭ 𝓤 𝓥} {@♭ Γ : Type 𝓤} (@♭ A : (Δ¹ → Γ) → Type 𝓥)
                   → (∀ g → is-prop (A g)) → ∀ g → is-prop (√ᵈ A g))
  where
  open SpacePath √ᵈ-is-prop
  open UIdS √ᵈ-is-prop

  module _ {@♭ 𝓤} {@♭ Γ : Type 𝓤} where
    Cov-bundle←SpaceΣ
      : ∀ {@♭ 𝓥} → (Γ → SpaceΣ 𝓥) → Cov-Δ¹-bundle 𝓥 Γ
    Cov-bundle←SpaceΣ
      = map-Σ
          UFib-transport
          (λ _ → map-Σ UFib-transport (λ _ → id) ∘ Σ-Π-swap _ _)
      ∘ Σ-Π-swap _ _

    Cov-bundle←SpaceΣ-is-♭-equiv
      : ∀ {@♭ 𝓥} → is-equiv (♭-map (Cov-bundle←SpaceΣ {𝓥}))
    Cov-bundle←SpaceΣ-is-♭-equiv {𝓥}
      = src-is-equiv←Arrow-equiv
          aeq
          (map-Σ-is-equiv
            UP-UFib
            (♭-ind
              (λ x → map-Σ-is-equiv
                       UP-UFib
                       (♭-ind (λ _ → id-is-equiv)))))
      where
      open Space


      bot-map
        : ∀ {@♭ 𝓤 𝓥} {@♭ X : Type 𝓤} {@♭ Y : X → X → Type 𝓥}
          → ⟨♭| Σ₂ X Y ⟩ → Σ[♭ a ∶ X ] Σ[♭ b ∶ X ] ⟨♭| Y a b ⟩
      bot-map = total-map (♭-ind (λ x → ♭-Σ' _)) ∘ ♭-Σ' _

      bot-map-is-equiv
        : ∀ {@♭ 𝓤 𝓥} {@♭ X : Type 𝓤} {@♭ Y : X → X → Type 𝓥}
          → is-equiv (bot-map {X = X}{Y})
      bot-map-is-equiv
        = is-equiv-∘
            (is-total-equiv←is-fibrewise-equiv
              {f = ♭-ind (λ _ → ♭-Σ' _)}
              (♭-ind (λ X → bwd-is-equiv (♭-commΣ _))))
            (bwd-is-equiv (♭-commΣ _) )

      top-map : (a : ⟨♭| (Γ → SpaceΣ 𝓥) ⟩) →
          Σ[♭ X ∶ (Γ → Space 𝓥) ]
          Σ[♭ Y ∶ (Γ → Space 𝓥) ]
           ⟨♭| fibrewise-map (Carrier ∘ X) (Carrier ∘ Y) ⟩
      top-map = bot-map
              ∘ ♭-map (total-map (λ _ → Σ-Π-swap _ _) ∘ Σ-Π-swap _ _)


      aeq : Arrow-equiv
              {X = Σ[♭ X ∶ (Γ → Space 𝓥)] Σ[♭ Y ∶ (Γ → Space 𝓥)]
                     ⟨♭| fibrewise-map (Carrier ∘ X) (Carrier ∘ Y) ⟩}
              {Y = Σ[♭ X ∶ _ ] Σ[♭ Y ∶ (Σ (Γ → Type 𝓥) is-covariant) ]
                     ⟨♭| fibrewise-map (fst X) (fst Y) ⟩}
              (♭-map Cov-bundle←SpaceΣ)
              (map-Σ (♭-map UFib-transport)
                     (♭-ind (λ _ → map-Σ (♭-map UFib-transport)
                                         (♭-ind (λ _ → id)))))
      aeq .fst .Arrow-Π.top = top-map
      aeq .fst .Arrow-Π.bot = bot-map
      aeq .fst .Arrow-Π.comm (mod♭ f) = refl
      aeq .snd .fst
        = is-equiv-∘
            bot-map-is-equiv
            (♭-map-is-equiv
              (is-equiv-∘
                (is-total-equiv←is-fibrewise-equiv
                  (λ _ → Σ-Π-swap≃ _ _ ._≃_.fwd-is-equiv))
                (Σ-Π-swap≃ _ _ ._≃_.fwd-is-equiv)))
      aeq .snd .snd = bot-map-is-equiv

  dua' : ∀ {@♭ 𝓤} → is-equiv (dua→ {𝓤 ⊔ 𝓘})
  dua' {𝓤}
    = types-separate dua→
        (λ {𝓥} {Γ}
         → src-is-equiv←Arrow-equiv
             ammape
             (trΣ-is-equiv {𝓥}{𝓤} {!Cov-Nat-is-equiv!})) where
    open Space
    module _ {@♭ 𝓥} {@♭ Γ : Type 𝓥} where

      ammap : Arrow-map (♭-map (postcomp Γ (dua→ {𝓤 ⊔ 𝓘}))) (♭-map (trΣ {𝓥} {𝓘 ⊔ 𝓤} {Γ}))
      ammap .Arrow-Π.top = ♭-map UFib-transport ∘ ♭-map uncurry
      ammap .Arrow-Π.bot = ♭-map Cov-bundle←SpaceΣ
      ammap .Arrow-Π.comm (mod♭ f) = mapply♭ (mod♭ (ext! ⦃ cov-Δ¹-bundle-IdS ⦄
        ( (λ _ → id≃)
        , (λ _ → id≃)
        , (λ _ → ~refl)
        )))

      ammape : Arrow-equiv
                 (♭-map (postcomp Γ (dua→ {𝓤 ⊔ 𝓘})))
                 (♭-map (trΣ {𝓥} {𝓘 ⊔ 𝓤} {Γ}))
      ammape .fst = ammap
      ammape .snd .fst
        = is-equiv-∘
            (UIdS.UP-UFib √ᵈ-is-prop)
            (♭-map-is-equiv uncurry-is-equiv)
      ammape .snd .snd = Cov-bundle←SpaceΣ-is-♭-equiv
}

\subtree[fre-0035]{
\title{StraighteningвЂ“unstraightening for type families}
\taxon{Construction}

%```agda
\agda{
arrowв†ђFam
  : {рќ“¤1 рќ“¤2 : Level}
    (F : Fam рќ“¤1 рќ“¤2)
  в†’ ОЈ (fst F) (snd F) в†’ fst F
arrowв†ђFam F = fst

arrowв†ђFam-fibre-fam
  : {рќ“¤1 рќ“¤2 : Level}
    {A : Type рќ“¤1}
    {B : Type рќ“¤2}
    (f : A в†’ B)
  в†’ arrowв†ђFam (fibre-fam f) пјќ fst
arrowв†ђFam-fibre-fam f = refl

fibre-fam-arrowв†ђFamв‰ѓб¶ 
  : {рќ“¤1 рќ“¤2 : Level}
    (F : Fam рќ“¤1 рќ“¤2)
  в†’ fibre-fam (arrowв†ђFam F) в‰ѓб¶  F
fibre-fam-arrowв†ђFamв‰ѓб¶  (A , B)
  = idequiv , fibre-straighten B
}
%```
}

\subtree[fre-0036]{
\title{Dependent type families from nondependent type families}
\taxon{Definition}

%```agda
\agda{

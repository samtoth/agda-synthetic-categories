\date{2025-06-03}
\title{Equivalences of arrows}
\author{samueltoth}
\import{stt-macros}
\taxon{Module}

%```agda
\agda{
module Core.ArrowEquiv where

open import ufAxioms
open import Foundations.Prelude

open import Core.Arrows
open import Core.Coslices
}
%```

\subtree[stt-004R]{
\taxon{Definition}
\title{Arrow equivalences}

\p{A pair of arrows #{A \xrightarrow{f} B} and #{X \xrightarrow{g} Y} are said
to be equivalent if there exists an [arrow map](stt-003U) where both horizontal
morphisms are themselves equivalences.}

\quiver{
\begin{tikzcd}
	A && X \\
	\\
	B && Y
	\arrow["\sim", from=1-1, to=1-3]
	\arrow["f"', from=1-1, to=3-1]
	\arrow["g", from=1-3, to=3-3]
	\arrow["\sim"', from=3-1, to=3-3]
\end{tikzcd}
}

%```agda
\agda{
is-Arrow-equiv : тИА {ЁЭУд ЁЭУе ЁЭУж ЁЭУЬ} {A : Type ЁЭУд} {B : Type ЁЭУе} {X : Type ЁЭУж}
                   {Y : Type ЁЭУЬ} {f : A тЖТ B} {g : X тЖТ Y}
                 тЖТ Arrow-map f g тЖТ Type (ЁЭУд тКФ ЁЭУе тКФ ЁЭУж тКФ ЁЭУЬ)
is-Arrow-equiv {f = f} {g} (mk-amap top bot comm)
  = is-equiv top ├Ч is-equiv bot

id-square-is-equiv
  : тИА {ЁЭУд ЁЭУе} {A : Type ЁЭУд} {B : Type ЁЭУе}
      {f : A тЖТ B}
    тЖТ is-Arrow-equiv (id-square: f)
id-square-is-equiv .fst = id-is-equiv
id-square-is-equiv .snd = id-is-equiv

paste-squares-is-equiv
  : тИА {ЁЭУд ЁЭУе ЁЭУж ЁЭУЬ ЁЭУЭ ЁЭУЫ} {A : Type ЁЭУд} {B : Type ЁЭУе}
      {C : Type ЁЭУж}{D : Type ЁЭУЬ}{E : Type ЁЭУЭ}{F : Type ЁЭУЫ}
      {f : A тЖТ B} {g : C тЖТ D}{h : E тЖТ F}
    тЖТ (G : Arrow-map g h) тЖТ is-Arrow-equiv G
    тЖТ (F : Arrow-map f g) тЖТ is-Arrow-equiv F
    тЖТ is-Arrow-equiv (paste-squares G F)
paste-squares-is-equiv G Ge F Fe .fst = is-equiv-тИШ (Ge .fst) (Fe .fst)
paste-squares-is-equiv G Ge F Fe .snd = is-equiv-тИШ (Ge .snd) (Fe .snd)

Arrow-equiv : тИА {ЁЭУд ЁЭУе ЁЭУж ЁЭУЬ} {A : Type ЁЭУд} {B : Type ЁЭУе} {X : Type ЁЭУж}
                {Y : Type ЁЭУЬ} (f : A тЖТ B) (g : X тЖТ Y)
              тЖТ Type (ЁЭУд тКФ ЁЭУе тКФ ЁЭУж тКФ ЁЭУЬ)
Arrow-equiv f g = ╬г[ F тИ╢ Arrow-map f g ] is-Arrow-equiv F

ArrowтБ╗┬╣тЖРis-Arrow-equiv : тИА {ЁЭУд ЁЭУе ЁЭУж ЁЭУЬ} {A : Type ЁЭУд} {B : Type ЁЭУе} {X : Type ЁЭУж}
                       {Y : Type ЁЭУЬ} {f : A тЖТ B} {g : X тЖТ Y}
                     тЖТ (F : Arrow-map f g)
                     тЖТ is-Arrow-equiv F
                     тЖТ Arrow-map g f
ArrowтБ╗┬╣тЖРis-Arrow-equiv {f = f}{g} (mk-amap top bot comm) (teq , beq)
  = mk-amap top.bwd bot.bwd H module ArrowтБ╗┬╣ where opaque
  module top = is-equiv teq
  module bot = is-equiv beq

  K : bot тИШ bot.bwd тИШ g тИШ top ~ bot тИШ f тИШ top.bwd тИШ top
  K =   bot.╬╡ тЦ╕ g тЦ╕ top
     ~тИЩ (comm ~тБ╗┬╣)
     ~тИЩ (bot тЧВ f тЧВ top.╬╖ ~тБ╗┬╣)

  H : (bot.bwd тИШ g) ~ (f тИШ top.bwd)
  H = beq тЧВeqv K тЦ╕eqv teq

ArrowтБ╗┬╣-is-equiv : тИА {ЁЭУд ЁЭУе ЁЭУж ЁЭУЬ} {A : Type ЁЭУд} {B : Type ЁЭУе} {X : Type ЁЭУж}
                       {Y : Type ЁЭУЬ} {f : A тЖТ B} {g : X тЖТ Y}
                     тЖТ (F : Arrow-map f g)
                     тЖТ (eq : is-Arrow-equiv F)
                     тЖТ is-Arrow-equiv (ArrowтБ╗┬╣тЖРis-Arrow-equiv F eq)
ArrowтБ╗┬╣-is-equiv F (teq , beq) = (is-equivтБ╗┬╣ teq  , is-equivтБ╗┬╣ beq)
}
%```
}

\subtree[stt-00EH]{
\title{Basic operations on arrow equivalences}
\author{fredrikbakke}

%```agda
\agda{
Arrow-equivтЖРтЙГс╢а
  : {ЁЭУд1 ЁЭУд2 ЁЭУе1 ЁЭУе2 : Level}
    (F : Fam ЁЭУд1 ЁЭУд2)
    (G : Fam ЁЭУе1 ЁЭУе2)
  тЖТ F тЙГс╢а G тЖТ Arrow-equiv (arrowтЖРFam F) (arrowтЖРFam G)
Arrow-equivтЖРтЙГс╢а (A , B) (X , Y) (e , ef)
  = mk-amap top bot ~refl
  , top-is-equiv
  , bot-is-equiv
  where
  top : ╬г A B тЖТ ╬г X Y
  top = total-map-fst (e ._тЙГ_.fwd) тИШ total-map (╬╗ a тЖТ ef a ._тЙГ_.fwd)

  bot : A тЖТ X
  bot = e ._тЙГ_.fwd

  top-is-equiv : is-equiv top
  top-is-equiv
    = is-equiv-тИШ
        (total-is-equivтЖРfst-is-equiv (e ._тЙГ_.has-is-eqv))
        (is-total-equivтЖРis-fibrewise-equiv (╬╗ a тЖТ ef a ._тЙГ_.has-is-eqv))

  bot-is-equiv : is-equiv bot
  bot-is-equiv = e ._тЙГ_.has-is-eqv

concat-Arrow-equiv
  : тИА {ЁЭУд ЁЭУе ЁЭУж ЁЭУЬ ЁЭУа ЁЭУб}
      {A : Type ЁЭУд}
      {B : Type ЁЭУе}
      {C : Type ЁЭУж}
      {D : Type ЁЭУЬ}
      {E : Type ЁЭУа}
      {F : Type ЁЭУб}
      {f : A тЖТ B}
      {g : C тЖТ D}
      {h : E тЖТ F}
    тЖТ Arrow-equiv f g
    тЖТ Arrow-equiv g h
    тЖТ Arrow-equiv f h
concat-Arrow-equiv (p , peq) (q , qeq)
  = paste-squares q p
  , is-equiv-тИШ (qeq .fst) (peq .fst)
  , is-equiv-тИШ (qeq .snd) (peq .snd)

concat-Arrow-equiv-тЙГс╢а
  : тИА {ЁЭУд ЁЭУе ЁЭУж1 ЁЭУж2 ЁЭУЫ1 ЁЭУЫ2}
      {A : Type ЁЭУд} {B : Type ЁЭУе} {f : A тЖТ B}
      (F : Fam ЁЭУж1 ЁЭУж2) (G : Fam ЁЭУЫ1 ЁЭУЫ2)
    тЖТ Arrow-equiv f (arrowтЖРFam F)
    тЖТ F тЙГс╢а G
    тЖТ Arrow-equiv f (arrowтЖРFam G)
concat-Arrow-equiv-тЙГс╢а F G eтВА e
  = concat-Arrow-equiv eтВА (Arrow-equivтЖРтЙГс╢а F G e)

inv-Arrow-equiv
  : тИА {ЁЭУд ЁЭУе ЁЭУж ЁЭУЬ}
      {A : Type ЁЭУд}
      {B : Type ЁЭУе}
      {C : Type ЁЭУж}
      {D : Type ЁЭУЬ}
      {f : A тЖТ B}
      {g : C тЖТ D}
    тЖТ Arrow-equiv f g
    тЖТ Arrow-equiv g f
inv-Arrow-equiv (p , peq)
  = ArrowтБ╗┬╣тЖРis-Arrow-equiv p peq
  , ArrowтБ╗┬╣-is-equiv p peq
}
%```
}

\subtree[stt-004S]{
\taxon{Theorem}
\title{Arrow equivalences preserve equivalences}

\p{If there is an [arrow equivalence](stt-004R) from #{A \xrightarrow{f} B} to
#{X \xrightarrow{g} Y}, then #{f} is an equivalence iff #{g} is.
}

\proof{This is a simple application of the [3-for-2](stt-003E) property of
equivalences.}

%```agda
\agda{
is-equivтЖРArrow-equiv : тИА {ЁЭУд ЁЭУе ЁЭУж ЁЭУЬ} {A : Type ЁЭУд} {B : Type ЁЭУе} {X : Type ЁЭУж}
                       {Y : Type ЁЭУЬ} {f : A тЖТ B} {g : X тЖТ Y}
                       {F : Arrow-map f g}
                       тЖТ is-Arrow-equiv F
                       тЖТ is-equiv f тЖТ is-equiv g
is-equivтЖРArrow-equiv {F = mk-amap top bot comm} (teq , beq) feq
  = 3-for-2~' comm teq (is-equiv-тИШ beq feq)

is-equivтЖРArrow-equivтБ╗┬╣ : тИА {ЁЭУд ЁЭУе ЁЭУж ЁЭУЬ} {A : Type ЁЭУд} {B : Type ЁЭУе} {X : Type ЁЭУж}
                       {Y : Type ЁЭУЬ} {f : A тЖТ B} {g : X тЖТ Y}
                       {F : Arrow-map f g}
                       тЖТ is-Arrow-equiv F
                       тЖТ is-equiv g тЖТ is-equiv f
is-equivтЖРArrow-equivтБ╗┬╣ {F = mk-amap top bot comm} (teq , beq) geq
  = 3-for-2~ (comm ~тБ╗┬╣) beq (is-equiv-тИШ geq teq)

topтЗФbot-is-equivтЖРArrow-equiv : тИА {ЁЭУд ЁЭУе ЁЭУж ЁЭУЬ} {A : Type ЁЭУд} {B : Type ЁЭУе} {X : Type ЁЭУж}
                       {Y : Type ЁЭУЬ} {f : A тЖТ B} {g : X тЖТ Y}
                       (F : Arrow-map f g)
                       тЖТ is-Arrow-equiv F
                       тЖТ is-equiv f тЗФ is-equiv g
topтЗФbot-is-equivтЖРArrow-equiv F eq = ( is-equivтЖРArrow-equiv {F = F} eq
                                    , is-equivтЖРArrow-equivтБ╗┬╣ {F = F} eq)
}
%```
}

\subtree[stt-0069]{
\title{Arrow equivalences preserve sections}
\taxon{Theorem}

\p{If there is an [arrow equivalence](stt-004R) from #{A \xrightarrow{f} B} to
#{X \xrightarrow{g} Y}, then sections of #{f} are equivalent to sections of #{g}.
}

% TODO(sam): Look into why unification isn't working so well for arrow
%            map

%```agda
\agda{
sectionтЖРArrow-equiv : тИА {ЁЭУд ЁЭУе ЁЭУж ЁЭУЬ} {A : Type ЁЭУд} {B : Type ЁЭУе} {X : Type ЁЭУж}
                       {Y : Type ЁЭУЬ} {f : A тЖТ B} {g : X тЖТ Y}
                       {F : Arrow-map f g}
                       тЖТ is-Arrow-equiv F
                       тЖТ section f тЖТ section g
sectionтЖРArrow-equiv {f = f} {g} {F = F} eq (secf , p) .fst
  = top тИШ secf тИШ bot.bwd where
  open Arrow-map F
  module top = is-equiv (eq .fst)
  module bot = is-equiv (eq .snd)
sectionтЖРArrow-equiv {f = f} {g} {F} eq (secf , p) .snd
  =  H тЦ╕ top тЦ╕ secf тЦ╕ bot.bwd
  ~тИЩ bot тЧВ f тЧВ top.╬╖ тЦ╕ secf тЦ╕ bot.bwd
  ~тИЩ bot тЧВ p тЦ╕ bot.bwd
  ~тИЩ bot.╬╡ where
  open Arrow-map F
  module top = is-equiv (eq .fst)
  module bot = is-equiv (eq .snd)
  H : g ~ bot тИШ f тИШ top.bwd
  H = comm тЦ╕ top.bwd ~тИЩ g тЧВ top.╬╡ ~тБ╗┬╣

sectionтЖРArrow-equivтБ╗┬╣ : тИА {ЁЭУд ЁЭУе ЁЭУж ЁЭУЬ} {A : Type ЁЭУд} {B : Type ЁЭУе} {X : Type ЁЭУж}
                       {Y : Type ЁЭУЬ} {f : A тЖТ B} {g : X тЖТ Y}
                       {F : Arrow-map f g}
                       тЖТ is-Arrow-equiv F
                       тЖТ section g тЖТ section f
sectionтЖРArrow-equivтБ╗┬╣ {f = f}{g}{F} EF sec = sectionтЖРArrow-equiv {f = g}{f}
                                               {ArrowтБ╗┬╣тЖРis-Arrow-equiv F EF}
                                               (ArrowтБ╗┬╣-is-equiv F EF) sec
}
%```
}

\subtree[stt-007M]{
\taxon{Theorem}
\title{Pre/post-composition of arrow equivalences}
\p{Precomposition preserves arrow equivalences}

%```agda
\agda{
postcomp-Arrow-map
  : тИА {ЁЭУд ЁЭУе ЁЭУж ЁЭУЬ ЁЭУа} {A : Type ЁЭУд} {B : Type ЁЭУе}
      {X : Type ЁЭУж} {Y : Type ЁЭУЬ}
      {f : A тЖТ B} {g : X тЖТ Y}
    тЖТ (Q : Type ЁЭУа)
    тЖТ Arrow-map f g
    тЖТ Arrow-map (postcomp Q f) (postcomp Q g)
postcomp-Arrow-map Q F = mk-amap (top тИШ_) (bot тИШ_) (funextтЖТ тИШ (comm тЦ╕_)) where
  open Arrow-map F


postcomp-square-is-equiv
  : тИА {ЁЭУд ЁЭУе ЁЭУж ЁЭУЬ ЁЭУа} {A : Type ЁЭУд} {B : Type ЁЭУе}
      {X : Type ЁЭУж} {Y : Type ЁЭУЬ}
      {f : A тЖТ B} {g : X тЖТ Y}
      (F : Arrow-map f g)
      {Q : Type ЁЭУа}
    тЖТ is-Arrow-equiv F
    тЖТ is-Arrow-equiv (postcomp-Arrow-map Q F)
postcomp-square-is-equiv F eq
  = (postcomp-equiv (eq .fst) , postcomp-equiv (eq .snd))

precomp-Arrow-map
  : тИА {ЁЭУд ЁЭУе ЁЭУж ЁЭУЬ ЁЭУа} {A : Type ЁЭУд} {B : Type ЁЭУе}
      {X : Type ЁЭУж} {Y : Type ЁЭУЬ}
      {f : A тЖТ B} {g : X тЖТ Y}
    тЖТ (Q : Type ЁЭУа)
    тЖТ Arrow-map f g
    тЖТ Arrow-map (precomp Q g) (precomp Q f)
precomp-Arrow-map Q F = mk-amap (_тИШ bot) (_тИШ top) (funextтЖТ тИШ (_тЧВ (comm ~тБ╗┬╣))) where
  open Arrow-map F

precomp-square-is-equiv
  : тИА {ЁЭУд ЁЭУе ЁЭУж ЁЭУЬ ЁЭУа} {A : Type ЁЭУд} {B : Type ЁЭУе}
      {X : Type ЁЭУж} {Y : Type ЁЭУЬ}
      {f : A тЖТ B} {g : X тЖТ Y}
      (F : Arrow-map f g)
      {Q : Type ЁЭУа}
    тЖТ is-Arrow-equiv F
    тЖТ is-Arrow-equiv (precomp-Arrow-map Q F)
precomp-square-is-equiv F eq
  = (precomp-equiv (eq .snd) , precomp-equiv (eq .fst))
}
%```
}

\subtree[stt-00BQ]{
\title{Arrow equivalences are cartesian squares}
\taxon{Lemma}

%```agda
\agda{
opaque
  is-cartesianтЖРis-equiv
    : тИА {ЁЭУд ЁЭУе ЁЭУж ЁЭУЬ} {A : Type ЁЭУд} {B : Type ЁЭУе} {X : Type ЁЭУж}
        {Y : Type ЁЭУЬ} {f : A тЖТ B} {g : X тЖТ Y}
      тЖТ (F : Arrow-map f g)
      тЖТ is-Arrow-equiv F тЖТ is-cartesian F
  is-cartesianтЖРis-equiv F@(mk-amap top bot p) (teq , beq) b
    = is-equiv-тИШ
        {f = total-map-fst top}
        (total-is-equivтЖРfst-is-equiv teq)
        (is-total-equivтЖРis-fibrewise-equiv
          (╬╗ a тЖТ is-equiv-тИШ
                   {f = sym (p a) тИЩ_}
                   (тИЩ-is-equiv (sym (p a)))
                   (is-embeddingтЖРis-equiv beq)))

  inverse-is-cartesianтЖРis-equiv
    : тИА {ЁЭУд ЁЭУе ЁЭУж ЁЭУЬ} {A : Type ЁЭУд}{B : Type ЁЭУе}{X : Type ЁЭУж}{Y : Type ЁЭУЬ}
        {f : A тЖТ B} {g : X тЖТ Y} (F : Arrow-map f g)
      тЖТ (Fe : is-Arrow-equiv F)
      тЖТ is-cartesian (ArrowтБ╗┬╣тЖРis-Arrow-equiv F Fe)
  inverse-is-cartesianтЖРis-equiv F Fe
    = is-cartesianтЖРis-equiv _ (ArrowтБ╗┬╣-is-equiv F Fe)
}
%```
}

\subtree[stt-00D7]{
\title{Right cancelling a cartesian square by an arrow equivalence}
\taxon{Lemma}

%```agda
\agda{
right-cancel-cartesian
  : тИА {ЁЭУд ЁЭУе} {A : Type ЁЭУд} {B : Type ЁЭУе} {f : A тЖТ B}
      {ЁЭУд' ЁЭУе'} {A' : Type ЁЭУд'} {B' : Type ЁЭУе'} {f' : A' тЖТ B'}
      {ЁЭУд'' ЁЭУе''} {A'' : Type ЁЭУд''} {B'' : Type ЁЭУе''} {f'' : A'' тЖТ B''}
      {a : Arrow-map f' f''} {b : Arrow-map f f'}
      {H : Arrow-map f f''}
    тЖТ Arrow-map-path H (paste-squares a b)
    тЖТ is-cartesian H
    тЖТ is-Arrow-equiv b
    тЖТ is-cartesian a
right-cancel-cartesian {a = a}{b}{H} path Hc bc b'
  = is-equivтЖРArrow-equivтБ╗┬╣ {F = hom} hom-eq lem where
  open Arrow-map
  open is-equiv
  lem : is-equiv (arrow-fibre a (b .bot (bwd (bc .snd) b')))
  lem = 3-for-2~' {f = arrow-fibre a (b .bot (bwd (bc .snd) b'))}
                  {g = arrow-fibre b (bwd (bc .snd) b')}
                 (arrow-fibre-тИШ a b (bwd (bc .snd) b'))
                 (is-cartesianтЖРis-equiv b bc (bwd (bc .snd) b'))
                 (tr is-cartesian (Arrow-map-pathтЖТ path) Hc (bwd (bc .snd) b'))

  hom : Arrow-map (arrow-fibre a b') (arrow-fibre a (b .bot (bwd (bc .snd) b')))
  hom .top = total-map (╬╗ x тЖТ _тИЩ sym (╬╡ (bc .snd) b'))
  hom .bot = total-map (╬╗ x тЖТ _тИЩ ap (bot a) (sym (╬╡ (bc .snd) b')))
  hom .comm (x , refl)
    = ╬г-pathтЖТ (refl , ap (_тИЩ ap (bot a) _) (тИЩ-reflr (sym (comm a x))))

  hom-eq : is-Arrow-equiv hom
  hom-eq .fst = is-total-equivтЖРis-fibrewise-equiv ╬╗ _ тЖТ тИЩ-is-equiv' _
  hom-eq .snd = is-total-equivтЖРis-fibrewise-equiv ╬╗ _ тЖТ тИЩ-is-equiv' _
}
%```
}

\subtree[stt-00K5]{
\title{Canonical cartesian square}

\p{We encode the fact that for each map #{f : A \to B}, there are functors
#{f^* : \Type_B \to \Type_A}. We also note that for each #{f}, there are
cartesian maps of arrows from #{f^*(p)} to #{p}, the canonical pullback squares.}

%```agda
\agda{
pullback-arrow : тИА {ЁЭУд ЁЭУе ЁЭУж} {A : Type ЁЭУд} {B : Type ЁЭУе} {E : Type ЁЭУж}
                 тЖТ (f : A тЖТ B) тЖТ (p : E тЖТ B) тЖТ (Pullback f p тЖТ A)
pullback-arrow f p = pb.╧АтВБ

pullback-arrow-map
  : тИА {ЁЭУд ЁЭУе ЁЭУж} {A : Type ЁЭУд} {B : Type ЁЭУе} {E : Type ЁЭУж}
    тЖТ (f : A тЖТ B) тЖТ (p : E тЖТ B)
    тЖТ Arrow-map (pullback-arrow f p) p
pullback-arrow-map f p .Arrow-╬а.top = pb.╧АтВВ
pullback-arrow-map f p .Arrow-╬а.bot = f
pullback-arrow-map f p .Arrow-╬а.comm = pb.filler

pullback-arrow-map-is-cartesian
  : тИА {ЁЭУд ЁЭУе ЁЭУж} {A : Type ЁЭУд} {B : Type ЁЭУе} {E : Type ЁЭУж}
    тЖТ (f : A тЖТ B) тЖТ (p : E тЖТ B)
    тЖТ is-cartesian (pullback-arrow-map f p)
pullback-arrow-map-is-cartesian f p
  = is-cartesianтЖРis-pullback _ pullback-is-pullback

pullback-arrow-тИШ
  : тИА {ЁЭУд ЁЭУе ЁЭУж ЁЭУЬ} {A : Type ЁЭУд} {B : Type ЁЭУе} {C : Type ЁЭУж} {E : Type ЁЭУЬ}
      (g : B тЖТ C) (f : A тЖТ B) (p : E тЖТ C)
    тЖТ Arrow-equiv (pullback-arrow f (pullback-arrow g p)) (pullback-arrow (g тИШ f) p)
pullback-arrow-тИШ g f p = ( mk-amap (gap-mapтЖРsquare lem) id ~refl
                         , gap-is-equivтЖРis-cartesian lem lem-is-cart
                         , id-is-equiv) where
  lem : Arrow-map (pullback-arrow f (pullback-arrow g p)) p
  lem = paste-squares (pullback-arrow-map g p)
                      (pullback-arrow-map f (pullback-arrow g p))

  lem-is-cart : is-cartesian lem
  lem-is-cart = compose-cartesian
                  (pullback-arrow-map-is-cartesian g p)
                  (pullback-arrow-map-is-cartesian f (pullback-arrow g p))
}
%```
}

\subtree[stt-00L0]{
\title{Arrow maps over the unit type}

%```agda
\agda{
!-map : тИА {ЁЭУд ЁЭУе} {A : Type ЁЭУд} {B : Type ЁЭУе} тЖТ (A тЖТ B) тЖТ Arrow-map (!: A) (!: B)
!-map f .Arrow-╬а.top = f
!-map f .Arrow-╬а.bot = id
!-map f .Arrow-╬а.comm = ~refl

!-map-is-equiv
  : тИА {ЁЭУд ЁЭУе} {A : Type ЁЭУд} {B : Type ЁЭУе} {f : A тЖТ B}
    тЖТ is-equiv f тЖТ is-Arrow-equiv (!-map f)
!-map-is-equiv fe = (fe , id-is-equiv)
}
%```
}

\subtree[stt-00MX]{
\date{2026-03-19}
\author{fredrikbakke}
\taxon{Theorem}
\title{Dependent precomposition and straightening}

\p{
Dependent precomposition along #{f} is equivalent, as an arrow, to dependent
precomposition after straightening the family #{U} to the fibre family of its
total-space projection.
}

%```agda
\agda{
module _
  {ЁЭУд ЁЭУе ЁЭУж : Level}
  {A : Type ЁЭУд} {B : Type ЁЭУе}
  (U : B тЖТ Type ЁЭУж)
  (f : A тЖТ B)
  where

  precomp-╬а-straighten-Arrow-map
    : Arrow-map (precomp-╬а U f) (precomp-╬а (fibre (fst {B = U})) f)
  precomp-╬а-straighten-Arrow-map .Arrow-map.top
    = postcomp-╬а (╬╗ b тЖТ (fibre-straighten U b eтБ╗┬╣) ._тЙГ_.fwd)
  precomp-╬а-straighten-Arrow-map .Arrow-map.bot
    = postcomp-╬а (╬╗ a тЖТ (fibre-straighten U (f a) eтБ╗┬╣) ._тЙГ_.fwd)
  precomp-╬а-straighten-Arrow-map .Arrow-map.comm _ = refl

  precomp-╬а-straighten-is-Arrow-equiv
    : is-Arrow-equiv precomp-╬а-straighten-Arrow-map
  precomp-╬а-straighten-is-Arrow-equiv
    = ( postcomp-╬а-equiv (╬╗ {b} тЖТ (fibre-straighten U b eтБ╗┬╣) ._тЙГ_.has-is-eqv)
      , postcomp-╬а-equiv (╬╗ {a} тЖТ (fibre-straighten U (f a) eтБ╗┬╣) ._тЙГ_.has-is-eqv))

  precomp-╬а-straighten-Arrow-equiv
    : Arrow-equiv (precomp-╬а U f) (precomp-╬а (fibre (fst {B = U})) f)
  precomp-╬а-straighten-Arrow-equiv
    = precomp-╬а-straighten-Arrow-map
    , precomp-╬а-straighten-is-Arrow-equiv
}
%```
}

\subtree[stt-00MR]{
\date{2026-03-19}
\author{fredrikbakke}
\taxon{Theorem}
\title{Dependent precomposition as fibrewise constant postcomposition}

\p{
For any family #{U} over #{B}, dependent precomposition along #{f} is
equivalent, as a map of arrows, to fibrewise postcomposition by the constant
maps #{U(b) \to (\fibre{f}{b} \to U(b))}.
}

% ```agda
\agda{
module _
  {ЁЭУд ЁЭУе ЁЭУж : Level}
  {A : Type ЁЭУд} {B : Type ЁЭУе}
  (U : B тЖТ Type ЁЭУж)
  (f : A тЖТ B)
  where

  precomp-╬а-fibre-const-Arrow-map
    : Arrow-map
        (precomp-╬а U f)
        (postcomp-╬а (╬╗ b тЖТ const (U b) (fibre f b)))
  precomp-╬а-fibre-const-Arrow-map .Arrow-map.top = id
  precomp-╬а-fibre-const-Arrow-map .Arrow-map.bot = precomp-╬а-over-fibres U f
  precomp-╬а-fibre-const-Arrow-map .Arrow-map.comm h
    = funextтЖТ ╬╗ b тЖТ funextтЖТ ╬╗ (a , p) тЖТ apс╢а h p

  precomp-╬а-fibre-const-is-Arrow-equiv
    : is-Arrow-equiv precomp-╬а-fibre-const-Arrow-map
  precomp-╬а-fibre-const-is-Arrow-equiv
    = (id-is-equiv , precomp-╬а-over-fibres-is-equiv U f)

  precomp-╬а-fibre-const-Arrow-equiv
    : Arrow-equiv
        (precomp-╬а U f)
        (postcomp-╬а (╬╗ b тЖТ const (U b) (fibre f b)))
  precomp-╬а-fibre-const-Arrow-equiv
    = precomp-╬а-fibre-const-Arrow-map
    , precomp-╬а-fibre-const-is-Arrow-equiv
}
%```
}

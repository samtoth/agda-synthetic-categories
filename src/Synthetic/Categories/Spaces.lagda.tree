\subtree[stt-00K6]{
\title{Equivalences of #{О”В№}-copresheaves}
\taxon{Lemma}

\p{We show that for a pair of copresheaves #{F\ G : \Delta^1 \to \mathcal{S}},
a natural transformation #{\alpha : \Pi_{i} F(i) \to G(i)} is a fibrewise
equivalence iff the restriction along #{\partial \Delta^1 \hookrightarrow \Delta^1}
is a fibrewise-equivalence.}

\agda{
Cov-Nat-is-equiv
  : вҲҖ {@вҷӯ рқ“Ө} (f g : О”В№ вҶ’ Space рқ“Ө) (Оұ : вҲҖ i вҶ’ f i .Space.Carrier вҶ’ g i .Space.Carrier)
    вҶ’ (вҲҖ x вҶ’ is-equiv (Оұ (вҲӮО”В№-incl x))) вҶ’ вҲҖ i вҶ’ is-equiv (Оұ i)
Cov-Nat-is-equiv {рқ“Ө} f g Оұ
  = is-equiv.bwd
       (is-fibrewise-equivвҶҗfamily-separates-with-рқҹҷ
         в–Ў^_ cubes-separate
         {X = ОЈ[ X Y вҲ¶ (О”В№ вҶ’ Space рқ“Ө) ] (вҲҖ i вҶ’ X i .Space.Carrier вҶ’ Y i .Space.Carrier)}
         {P = О» (X , Y , Оұ) вҶ’ is-fibrewise-equiv Оұ}
         {Q = О» (X , Y , Оұ) вҶ’ is-fibrewise-equiv (Оұ вҲҳ вҲӮО”В№-incl)}
         (О» (X , Y , Оұ) вҶ’ precomp-О  (is-equiv вҲҳ Оұ) вҲӮО”В№-incl)
         {0} single!
         (О» m Пғ
          вҶ’ is-equivвҶҗinverse
              (вҷӯ-is-prop (О -is-prop (О» _ вҶ’ О -is-prop (О» _ вҶ’ is-equiv-is-prop))))
              (вҷӯ-is-prop (О -is-prop (О» _ вҶ’ О -is-prop (О» _ вҶ’ is-equiv-is-prop))))
              (вҷӯ-ind (О» x вҶ’ modвҷӯ (О» c i
               вҶ’ вҲӮО”В№-cov-Nat-is-equiv
                   cubes-separate
                   вҷӯО”В№-ind
                   (UFib-transport (uncurry (fst вҲҳ Пғ)) )
                   (UFib-transport (uncurry (fst вҲҳ snd вҲҳ Пғ)))
                   (uncurry (snd вҲҳ snd вҲҳ Пғ))
                   (О» b i вҶ’ вҷӯ-map-is-equiv (x b i))
                   (c , i)))))
         (f , g , Оұ))
}
}

\subtree[stt-00KW]{
\title{Paths in #{\mathcal{S}^вҶ’}}
\taxon{Lemma}

\agda{
module _ where
  open Space
  SpaceОЈ : вҲҖ (@вҷӯ рқ“Ө) вҶ’ Type (lsuc (рқ“ҳ вҠ” рқ“Ө))
  SpaceОЈ рқ“Ө = ОЈ[ A B вҲ¶ Space рқ“Ө ] (Carrier A вҶ’ Carrier B)

  SpaceОЈ-Path
    : вҲҖ {@вҷӯ рқ“Ө} (x y : (ОЈ[ A B вҲ¶ Space рқ“Ө ] (Carrier A вҶ’ Carrier B)))
      вҶ’ Type рқ“Ө
  SpaceОЈ-Path (A , B , f) (X , Y , g)
    = ОЈ[ e вҲ¶ A .Carrier вүғ X .Carrier ] ОЈ[ p вҲ¶ B .Carrier вүғ Y .Carrier ]
        (p ._вүғ_.fwd вҲҳ f ~ g вҲҳ e ._вүғ_.fwd)

  SpaceОЈ-Path-refl
    : вҲҖ {@вҷӯ рқ“Ө} (x : (ОЈ[ A B вҲ¶ Space рқ“Ө ] (Carrier A вҶ’ Carrier B)))
      вҶ’ SpaceОЈ-Path x x
  SpaceОЈ-Path-refl x = (idвүғ , idвүғ , ~refl)

module SpacePath
  (@вҷӯ вҲҡбөҲ-is-prop
        : вҲҖ {@вҷӯ рқ“Ө рқ“Ҙ} {@вҷӯ О“ : Type рқ“Ө} (@вҷӯ A : (О”В№ вҶ’ О“) вҶ’ Type рқ“Ҙ)
          вҶ’ (вҲҖ g вҶ’ is-prop (A g)) вҶ’ вҲҖ g вҶ’ is-prop (вҲҡбөҲ A g))
  where
  open Space
  open UIdS вҲҡбөҲ-is-prop

  opaque
    SpaceОЈ-Path-is-torsorial
      : вҲҖ {@вҷӯ рқ“Ө} (x : (ОЈ[ A B вҲ¶ Space рқ“Ө ] (Carrier A вҶ’ Carrier B)))
        вҶ’ is-singleton (ОЈ _ (SpaceОЈ-Path x))
    SpaceОЈ-Path-is-torsorial (A , B , f)
      = is-singleton-structureвҶҗparts
         (SingS-is-single A)
         (A , idвүғ)
         (is-singleton-structureвҶҗparts
           (SingS-is-single B)
           (B , idвүғ)
           (SingS-is-single f))

  instance
    SpaceОЈ-IdS
      : вҲҖ {@вҷӯ рқ“Ө} вҶ’ Identity-system ((ОЈ[ A B вҲ¶ Space рқ“Ө ] (Carrier A вҶ’ Carrier B))) рқ“Ө
    SpaceОЈ-IdS .Identity-system.IdS = SpaceОЈ-Path
    SpaceОЈ-IdS .Identity-system.IdSвҶҗId {a = A} refl = SpaceОЈ-Path-refl A
    SpaceОЈ-IdS .Identity-system.IdSвҶҗId-is-equiv x
      = fundamental-Id _ (SpaceОЈ-Path-is-torsorial x) _
}
}

\subtree[stt-00UW]{
\taxon{Lemma}

\p{There is a map ##{(\Gamma \to \Sigma_{X, Y : \mathcal{S}} (X \to Y)) \to
\Sigma_{X, Y : \textrm{LFib}_\Gamma} (X \to Y)} given by the fact #{\mathcal{S}
\to \UU} is a covariant type family. Because #{\mathcal{S}} is the universal such
family, this map is a #{\flat}-equivalence.}

\agda{
module CovBundle
  (@вҷӯ вҲҡбөҲ-is-prop
        : вҲҖ {@вҷӯ рқ“Ө рқ“Ҙ} {@вҷӯ О“ : Type рқ“Ө} (@вҷӯ A : (О”В№ вҶ’ О“) вҶ’ Type рқ“Ҙ)
          вҶ’ (вҲҖ g вҶ’ is-prop (A g)) вҶ’ вҲҖ g вҶ’ is-prop (вҲҡбөҲ A g))
  {@вҷӯ рқ“Ө} {@вҷӯ О“ : Type рқ“Ө}
  where
  open SpacePath вҲҡбөҲ-is-prop
  open UIdS вҲҡбөҲ-is-prop

  Cov-bundleвҶҗSpaceОЈ
    : вҲҖ {@вҷӯ рқ“Ҙ} вҶ’ (О“ вҶ’ SpaceОЈ рқ“Ҙ) вҶ’ Cov-О”В№-bundle рқ“Ҙ О“
  Cov-bundleвҶҗSpaceОЈ
    = map-ОЈ
        UFib-transport
        (О» _ вҶ’ map-ОЈ UFib-transport (О» _ вҶ’ id) вҲҳ ОЈ-О -swap _ _)
    вҲҳ ОЈ-О -swap _ _

  Cov-bundleвҶҗSpaceОЈ-is-вҷӯ-equiv
    : вҲҖ {@вҷӯ рқ“Ҙ} вҶ’ is-equiv (вҷӯ-map (Cov-bundleвҶҗSpaceОЈ {рқ“Ҙ}))
  Cov-bundleвҶҗSpaceОЈ-is-вҷӯ-equiv {рқ“Ҙ}
    = src-is-equivвҶҗArrow-equiv
        aeq
        (map-ОЈ-is-equiv
          UP-UFib
          (вҷӯ-ind
            (О» x
             вҶ’ map-ОЈ-is-equiv
                 UP-UFib
                 (вҷӯ-ind (О» _ вҶ’ id-is-equiv)))))
    where
    open Space


    bot-map
      : вҲҖ {@вҷӯ рқ“Ө рқ“Ҙ} {@вҷӯ X : Type рқ“Ө} {@вҷӯ Y : X вҶ’ X вҶ’ Type рқ“Ҙ}
        вҶ’ вҹЁвҷӯ| ОЈвӮӮ X Y вҹ© вҶ’ ОЈ[вҷӯ a вҲ¶ X ] ОЈ[вҷӯ b вҲ¶ X ] вҹЁвҷӯ| Y a b вҹ©
    bot-map = total-map (вҷӯ-ind (О» x вҶ’ вҷӯ-ОЈ' _)) вҲҳ вҷӯ-ОЈ' _

    bot-map-is-equiv
      : вҲҖ {@вҷӯ рқ“Ө рқ“Ҙ} {@вҷӯ X : Type рқ“Ө} {@вҷӯ Y : X вҶ’ X вҶ’ Type рқ“Ҙ}
        вҶ’ is-equiv (bot-map {X = X}{Y})
    bot-map-is-equiv
      = is-equiv-вҲҳ
          (is-total-equivвҶҗis-fibrewise-equiv
            {f = вҷӯ-ind (О» _ вҶ’ вҷӯ-ОЈ' _)}
            (вҷӯ-ind (О» X вҶ’ bwd-is-equiv (вҷӯ-commОЈ _))))
          (bwd-is-equiv (вҷӯ-commОЈ _) )

    top-map
      : (a : вҹЁвҷӯ| (О“ вҶ’ SpaceОЈ рқ“Ҙ) вҹ©)
      вҶ’ ОЈ[вҷӯ X вҲ¶ (О“ вҶ’ Space рқ“Ҙ) ]
        ОЈ[вҷӯ Y вҲ¶ (О“ вҶ’ Space рқ“Ҙ) ]
         вҹЁвҷӯ| fibrewise-map (Carrier вҲҳ X) (Carrier вҲҳ Y) вҹ©
    top-map = bot-map вҲҳ вҷӯ-map (total-map (О» _ вҶ’ ОЈ-О -swap _ _) вҲҳ ОЈ-О -swap _ _)


    aeq
      : Arrow-equiv
          {X = ОЈ[вҷӯ X вҲ¶ (О“ вҶ’ Space рқ“Ҙ)] ОЈ[вҷӯ Y вҲ¶ (О“ вҶ’ Space рқ“Ҙ)]
                вҹЁвҷӯ| fibrewise-map (Carrier вҲҳ X) (Carrier вҲҳ Y) вҹ©}
          {Y = ОЈ[вҷӯ X вҲ¶ _ ] ОЈ[вҷӯ Y вҲ¶ (ОЈ (О“ вҶ’ Type рқ“Ҙ) is-covariant) ]
                 вҹЁвҷӯ| fibrewise-map (fst X) (fst Y) вҹ©}
          (вҷӯ-map Cov-bundleвҶҗSpaceОЈ)
          (map-ОЈ (вҷӯ-map UFib-transport)
                 (вҷӯ-ind (О» _ вҶ’ map-ОЈ (вҷӯ-map UFib-transport) (вҷӯ-ind (О» _ вҶ’ id)))))
    aeq .fst .Arrow-О .top = top-map
    aeq .fst .Arrow-О .bot = bot-map
    aeq .fst .Arrow-О .comm (modвҷӯ f) = refl
    aeq .snd .fst
      = is-equiv-вҲҳ
          bot-map-is-equiv
          (вҷӯ-map-is-equiv
            (is-equiv-вҲҳ
              (is-total-equivвҶҗis-fibrewise-equiv
                (О» _ вҶ’ ОЈ-О -swapвүғ _ _ ._вүғ_.fwd-is-equiv))
              (ОЈ-О -swapвүғ _ _ ._вүғ_.fwd-is-equiv)))
    aeq .snd .snd = bot-map-is-equiv
}
}

\subtree[stt-00AT]{
\title{#{\mathcal{S}} is directed univalent}
\taxon{Theorem}

\p{We show that #{\mathcal{S}} is directed univalent. That is, arrows in
#{\mathcal{S}} correspond exactly to pairs of groupoids, together with a function
between them.}

\p{We start by noting that there is a canonial map
from #{F : \mathcal{S}^{\Delta^1}} to #{F(0) \to F(1)} given by covariant
transport.}

\agda{
tr-рқ“ў : вҲҖ {@вҷӯ рқ“Ө} вҶ’ (f : О”В№ вҶ’ Space рқ“Ө) вҶ’ Space.Carrier (f i0) вҶ’ Space.Carrier (f i1)
tr-рқ“ў = tr-cov {P = Space.Carrier} Space-ПҖ-is-covariant

tr-рқ“ў-unique
  : вҲҖ {@вҷӯ рқ“Ө} (f : О”В№ вҶ’ Space рқ“Ө)
      {F : Space.Carrier (f i0) вҶ’ Space.Carrier (f i1)}
    вҶ’ вҲҖ x вҶ’ (HomбөҲ (Space.Carrier вҲҳ f) x (F x))
    вҶ’ tr-рқ“ў f x пјқ F x
tr-рқ“ў-unique f {F = F} x p = ap fst (Space-ПҖ-is-covariant f x .central (F x , p))
}

\p{Directed univalence then says that the induced map
#{\mathcal{S}^{\Delta^1} \to \Sigma_{(X, Y : \mathcal{S})} X \to Y}
is an equivalence.}

\proof{
\p{For concision, let #{M := \Sigma_{(X, Y : \mathcal{S})} X \to Y} and
#{N := \Sigma_{X, Y : \textrm{LFib}_{\Gamma}} X \to Y}.
By the fact that types separate, it is enough to show that the induced map
#{\flat(\mathcal{S}^\Gamma) \to \flat(M^{\Gamma})} is an
equivalence. We may construct a square:

\quiver{
\begin{tikzcd}[cramped]
	{\flat(\mathcal{S}^\Gamma)} && {\flat(\textrm{LFib}_{\Delta^1 \times \Gamma})} \\
	\\
	{\flat(M^\Gamma)} && {\flat(N)}
	\arrow["\sim", from=1-1, to=1-3]
	\arrow["{tr_{\mathcal{S}}}"', from=1-1, to=3-1]
	\arrow["{tr_{\textrm{LFib}}}", from=1-3, to=3-3]
	\arrow["\sim"', from=3-1, to=3-3]
\end{tikzcd}
}

where the top equivalence is given by the universal property of #{\mathcal{S}}, and
the bottom by the equivalence constructed in \ref{stt-00UW}. Finally, the domain of this
arrow equivalence is itself an equivalence by \ref{stt-00V5}, where the inverse is
given by constructing the [directed gluing family](2).
}

\agda{
tot-duaвҶ’
  : вҲҖ {@вҷӯ рқ“Ө} вҶ’ (О”В№ вҶ’ Space рқ“Ө)
    вҶ’ ОЈ[ A B вҲ¶ Space рқ“Ө ] (Space.Carrier A вҶ’ Space.Carrier B)
tot-duaвҶ’ h = (h i0 , h i1 , tr-рқ“ў h)

coe-рқ“ў
  : вҲҖ {@вҷӯ рқ“Ө} (f : О”В№ вҶ’ Space рқ“Ө) {i j} вҶ’ i вүӨ j
    вҶ’ Space.Carrier (f i) вҶ’ Space.Carrier (f j)
coe-рқ“ў f = coe-cov (Space.Carrier вҲҳ f) (UFib-is-fib f)

coe-рқ“ў-id
  : вҲҖ {@вҷӯ рқ“Ө} (f : О”В№ вҶ’ Space рқ“Ө) {i} (p : i вүӨ i)
    вҶ’ coe-рқ“ў f p ~ id
coe-рқ“ў-id f = coe-cov-id (Space.Carrier вҲҳ f) (UFib-is-fib f)

module _
  (@вҷӯ вҲҡбөҲ-is-prop
    : вҲҖ {@вҷӯ рқ“Ө рқ“Ҙ} {@вҷӯ О“ : Type рқ“Ө} (@вҷӯ A : (О”В№ вҶ’ О“) вҶ’ Type рқ“Ҙ)
      вҶ’ (вҲҖ g вҶ’ is-prop (A g)) вҶ’ вҲҖ g вҶ’ is-prop (вҲҡбөҲ A g))
  where
  open SpacePath вҲҡбөҲ-is-prop
  open UIdS вҲҡбөҲ-is-prop
  open CovBundle вҲҡбөҲ-is-prop

  tot-dua : вҲҖ {@вҷӯ рқ“Ө} вҶ’ is-equiv (tot-duaвҶ’ {рқ“Ө вҠ” рқ“ҳ})
  tot-dua {рқ“Ө}
    = types-separate tot-duaвҶ’
        (О» {рқ“Ҙ} {О“}
         вҶ’ src-is-equivвҶҗArrow-equiv
             ammape
             (total-tr-cov-is-вҷӯ-equiv {рқ“Ҙ}{рқ“Ө}
               (вҲӮО”В№-cov-Nat-is-equiv cubes-separate вҷӯО”В№-ind))) where
    open Space
    module _ {@вҷӯ рқ“Ҙ} {@вҷӯ О“ : Type рқ“Ҙ} where

      ammap
        : Arrow-map
            (вҷӯ-map (postcomp О“ (tot-duaвҶ’ {рқ“Ө вҠ” рқ“ҳ})))
            (вҷӯ-map (total-tr-cov {рқ“Ҙ} {рқ“ҳ вҠ” рқ“Ө} {О“}))
      ammap .Arrow-О .top = вҷӯ-map UFib-transport вҲҳ вҷӯ-map uncurry
      ammap .Arrow-О .bot = вҷӯ-map Cov-bundleвҶҗSpaceОЈ
      ammap .Arrow-О .comm (modвҷӯ f) = mapplyвҷӯ (modвҷӯ (ext! вҰғ cov-О”В№-bundle-IdS вҰ„
        ( (О» _ вҶ’ idвүғ)
        , (О» _ вҶ’ idвүғ)
        , (О» _ вҶ’ ~refl)
        )))

      ammape
        : Arrow-equiv
            (вҷӯ-map (postcomp О“ (tot-duaвҶ’ {рқ“Ө вҠ” рқ“ҳ})))
            (вҷӯ-map (total-tr-cov  {рқ“Ҙ} {рқ“ҳ вҠ” рқ“Ө} {О“}))
      ammape .fst = ammap
      ammape .snd .fst
        = is-equiv-вҲҳ
            (UIdS.UP-UFib вҲҡбөҲ-is-prop)
            (вҷӯ-map-is-equiv uncurry-is-equiv)
      ammape .snd .snd = Cov-bundleвҶҗSpaceОЈ-is-вҷӯ-equiv
}

\agda{
  duaвҶ’
    : вҲҖ {@вҷӯ рқ“Ө} (A B : Space рқ“Ө)
      вҶ’ Hom (Space рқ“Ө) A B вҶ’ (Space.Carrier A вҶ’ Space.Carrier B)
  duaвҶ’ ._ ._ (mk-hom h refl refl) = tr-рқ“ў h

  tot-dua-Arrow-equiv
    : вҲҖ {@вҷӯ рқ“Ө}
      вҶ’ Arrow-equiv
        (tot-duaвҶ’ {рқ“Ө вҠ” рқ“ҳ})
        (total-map (О» A вҶ’ total-map (duaвҶ’ A)))
  tot-dua-Arrow-equiv .fst .Arrow-О .top = total-hom ._вүғ_.fwd
  tot-dua-Arrow-equiv .fst .Arrow-О .bot = id
  tot-dua-Arrow-equiv .fst .Arrow-О .comm h = refl
  tot-dua-Arrow-equiv .snd .fst = total-hom ._вүғ_.fwd-is-equiv
  tot-dua-Arrow-equiv .snd .snd = id-is-equiv

  dua
    : вҲҖ {@вҷӯ рқ“Ө} (A B : Space (рқ“ҳ вҠ” рқ“Ө)) вҶ’ is-equiv (duaвҶ’ A B)
  dua {рқ“Ө} A
    = is-fibrewise-equivвҶҗis-total-equiv
        {f = duaвҶ’ A}
        (is-fibrewise-equivвҶҗis-total-equiv
          {f = О» A вҶ’ total-map (duaвҶ’ A)}
          (tgt-is-equivвҶҗArrow-equiv (tot-dua-Arrow-equiv {рқ“Ө}) (tot-dua {рқ“Ө}))
          (A))
}
}
}

\title{Strictification of composition}
\date{2026-03-24}
\author{fredrikbakke}
\taxon{Module}
\import{stt-macros}

%```agda
\agda{
open import Foundations.Prelude
open import Algebra.Lattice

module Synthetic.Categories.StrictificationComposition
        {𝓘} (Δ¹ : Type 𝓘) (I : Lattice Δ¹) (I-distr : is-distributive I) where

open Lattice I renaming (0l to i0; 1l to i1)

open import ufAxioms

open import Synthetic.Hom Δ¹ i0 i1
open import Synthetic.Categories.Precategories Δ¹ I I-distr
open import Synthetic.Categories.Covariant Δ¹ I I-distr
open import Synthetic.Categories.LeftSegal Δ¹ I I-distr
open import Synthetic.Categories.CovariantHomFamily Δ¹ I I-distr
open import Synthetic.Categories.AlgebraicLaws Δ¹ I I-distr
open import Synthetic.Categories.Yoneda Δ¹ I I-distr

}
%```

\subtree[fre-1001]{
\title{Strictification of composition in left Segal types}
\taxon{Construction}
\author{fredrikbakke}
\date{2026-03-24}

\p{
Given a [left Segal](stt-00DA) type #{A}, then using the [Yoneda lemma](fre-0001) we
know that composition of morphisms in #{A} is [equivalent](stt-001U) in a coherent
way to composition of families of functions
#{\prod_{(z : A)}\left(\Hom_A(b, z) \to \Hom_A(a, z)\right)}, and composition of families of
functions is strictly associative and two-sided unital. This gives a strictification
procedure for synthetic categories.
}

%```agda
\agda{
module StrictifyLeftSegal
  {𝓤 : Level} {A : Type 𝓤}
  (𝐴ₗ : is-left-segal A)
  (let 𝐴 = is-segal←is-left-segal 𝐴ₗ)
  where

  Homʸ : A → A → Type (𝓘 ⊔ 𝓤)
  Homʸ a b = (z : A) → Hom A b z → Hom A a z

  Homʸ←Hom : {a b : A} → Hom A a b → Homʸ a b
  Homʸ←Hom f z h = h ∘[ 𝐴 ] f

  Hom←Homʸ : {a b : A} → Homʸ a b → Hom A a b
  Hom←Homʸ {b = b} α = α b (idH b)

  Hom←Homʸ-ret
    : {a b : A} (f : Hom A a b) → Hom←Homʸ (Homʸ←Hom f) ＝ f
  Hom←Homʸ-ret = ∘-right-unit 𝐴

  Homʸ←Hom-is-equiv
    : {a b : A} → is-equiv (Homʸ←Hom {a} {b})
  Homʸ←Hom-is-equiv {a}
    = Yoneda-coe-left-segal-is-equiv 𝐴ₗ
        (Hom A a)
        (hom-fam-cov 𝐴ₗ a)
        (Homʸ←Hom)
        (Hom←Homʸ-ret)

  Hom←Homʸ-sec
    : {a b : A} (α : Homʸ a b) → Homʸ←Hom (Hom←Homʸ α) ＝ α
  Hom←Homʸ-sec {a}
    = Yoneda-coe-left-segal-η
        𝐴ₗ
        (Hom A a)
        (hom-fam-cov 𝐴ₗ a)
        (Homʸ←Hom)
        (Hom←Homʸ-ret)

  idʸ : {a : A} → Homʸ a a
  idʸ _ = id

  _∘ʸ_ : {a b c : A} → Homʸ b c → Homʸ a b → Homʸ a c
  (gʸ ∘ʸ fʸ) z h = fʸ z (gʸ z h)

  Homʸ←idH
    : {a : A} → Homʸ←Hom (idH a) ＝ idʸ
  Homʸ←idH {a}
    = funext→ λ z → funext→ λ h → ∘-left-unit 𝐴 h

  idH←Homʸ
    : {a : A} → Hom←Homʸ {a} {a} idʸ ＝ idH a
  idH←Homʸ = refl

  Homʸ←∘
    : {a b c : A} (g : Hom A b c) (f : Hom A a b)
    → Homʸ←Hom (g ∘[ 𝐴 ] f) ＝ Homʸ←Hom g ∘ʸ Homʸ←Hom f
  Homʸ←∘ g f = funext→ λ z → funext→ λ h → sym (∘-assoc 𝐴ₗ h g f)

  ∘←Homʸ
    : {a b c : A} (gʸ : Homʸ b c) (fʸ : Homʸ a b)
    → Hom←Homʸ (gʸ ∘ʸ fʸ) ＝ Hom←Homʸ gʸ ∘[ 𝐴 ] Hom←Homʸ fʸ
  ∘←Homʸ {a} {b} {c} gʸ fʸ
    = ap (λ F → F c (Hom←Homʸ gʸ)) (sym (Hom←Homʸ-sec fʸ))

  ∘ʸ-left-unit
    : {a b : A} (fʸ : Homʸ a b) → idʸ ∘ʸ fʸ ＝ fʸ
  ∘ʸ-left-unit _ = refl

  ∘ʸ-right-unit
    : {a b : A} (fʸ : Homʸ a b) → fʸ ∘ʸ idʸ ＝ fʸ
  ∘ʸ-right-unit _ = refl

  ∘ʸ-assoc
    : {a b c d : A} (hʸ : Homʸ c d) (gʸ : Homʸ b c) (fʸ : Homʸ a b)
    → (hʸ ∘ʸ gʸ) ∘ʸ fʸ ＝ hʸ ∘ʸ (gʸ ∘ʸ fʸ)
  ∘ʸ-assoc _ _ _ = refl

  ∘ʸ-pentagon
    : {a b c d e : A}
      (kʸ : Homʸ d e) (hʸ : Homʸ c d) (gʸ : Homʸ b c) (fʸ : Homʸ a b)
    → ap (λ j → j ∘ʸ fʸ) (∘ʸ-assoc kʸ hʸ gʸ)
    ∙ ∘ʸ-assoc kʸ (hʸ ∘ʸ gʸ) fʸ
    ∙ ap (kʸ ∘ʸ_) (∘ʸ-assoc hʸ gʸ fʸ)
    ＝ ∘ʸ-assoc (kʸ ∘ʸ hʸ) gʸ fʸ
    ∙ ∘ʸ-assoc kʸ hʸ (gʸ ∘ʸ fʸ)
  ∘ʸ-pentagon _ _ _ _ = refl

  Homʸ←∘-nat-right
    : {a b c : A} {g g' : Hom A b c} (p : g ＝ g') (f : Hom A a b)
    → Homʸ←∘ g f
    ∙ ap (λ j → j ∘ʸ Homʸ←Hom f) (ap Homʸ←Hom p)
    ＝ ap Homʸ←Hom (ap (_∘[ 𝐴 ] f) p)
    ∙ Homʸ←∘ g' f
  Homʸ←∘-nat-right {g = g} {g'} p f
    = Homʸ←∘ g f ∙ ap (λ j → j ∘ʸ Homʸ←Hom f) (ap Homʸ←Hom p)
          ＝⟨ ap (Homʸ←∘ g f ∙_) (sym (ap-∘ (λ j → j ∘ʸ Homʸ←Hom f) Homʸ←Hom p)) ⟩
      Homʸ←∘ g f ∙ ap ((λ j → j ∘ʸ Homʸ←Hom f) ∘ Homʸ←Hom) p
          ＝⟨ homotopy-natural (λ j → Homʸ←∘ j f) p ⟩
      ap (Homʸ←Hom ∘ (_∘[ 𝐴 ] f)) p ∙ Homʸ←∘ g' f
          ＝⟨ ap (_∙ Homʸ←∘ g' f) (ap-∘ Homʸ←Hom (_∘[ 𝐴 ] f) p) ⟩
      ap Homʸ←Hom (ap (_∘[ 𝐴 ] f) p) ∙ Homʸ←∘ g' f ∎

  Homʸ←∘-nat-left
    : {a b c : A} (h : Hom A b c) {f f' : Hom A a b} (p : f ＝ f')
    → Homʸ←∘ h f
    ∙ ap (Homʸ←Hom h ∘ʸ_) (ap Homʸ←Hom p)
    ＝ ap Homʸ←Hom (ap (h ∘[ 𝐴 ]_) p)
    ∙ Homʸ←∘ h f'
  Homʸ←∘-nat-left h {f} {f'} p
    = Homʸ←∘ h f ∙ ap (Homʸ←Hom h ∘ʸ_) (ap Homʸ←Hom p)
          ＝⟨ ap (Homʸ←∘ h f ∙_) (sym (ap-∘ (Homʸ←Hom h ∘ʸ_) Homʸ←Hom p)) ⟩
      Homʸ←∘ h f ∙ ap ((Homʸ←Hom h ∘ʸ_) ∘ Homʸ←Hom) p
          ＝⟨ homotopy-natural (Homʸ←∘ h) p ⟩
      ap (Homʸ←Hom ∘ (h ∘[ 𝐴 ]_)) p ∙ Homʸ←∘ h f'
          ＝⟨ ap (_∙ Homʸ←∘ h f') (ap-∘ Homʸ←Hom (h ∘[ 𝐴 ]_) p) ⟩
      ap Homʸ←Hom (ap (h ∘[ 𝐴 ]_) p) ∙ Homʸ←∘ h f' ∎

  ∘ʸ-unique
    : {a b c : A}
      (_∙_ : Homʸ b c → Homʸ a b → Homʸ a c)
    → ((gʸ : Homʸ b c) (fʸ : Homʸ a b)
      → Hom←Homʸ (gʸ ∙ fʸ) ＝ Hom←Homʸ gʸ ∘[ 𝐴 ] Hom←Homʸ fʸ)
    → (gʸ : Homʸ b c) (fʸ : Homʸ a b)
    → gʸ ∙ fʸ ＝ gʸ ∘ʸ fʸ
  ∘ʸ-unique _∙_ comp gʸ fʸ
    = gʸ ∙ fʸ
        ＝⟨ sym (Hom←Homʸ-sec (gʸ ∙ fʸ)) ⟩
      Homʸ←Hom (Hom←Homʸ (gʸ ∙ fʸ))
        ＝⟨ ap Homʸ←Hom (comp gʸ fʸ) ⟩
      Homʸ←Hom (Hom←Homʸ gʸ ∘[ 𝐴 ] Hom←Homʸ fʸ)
        ＝⟨ Homʸ←∘ (Hom←Homʸ gʸ) (Hom←Homʸ fʸ) ⟩
      Homʸ←Hom (Hom←Homʸ gʸ) ∘ʸ Homʸ←Hom (Hom←Homʸ fʸ)
        ＝⟨ ap₂ (_∘ʸ_) (Hom←Homʸ-sec gʸ) (Hom←Homʸ-sec fʸ) ⟩
      gʸ ∘ʸ fʸ ∎
}
%```

%```agda
\agda{
open StrictifyLeftSegal public hiding (_∘ʸ_)

compʸ
  : {𝓤 : Level} {A : Type 𝓤} {a b c : A}
  → (𝐴ₗ : is-left-segal A)
  → Homʸ 𝐴ₗ b c → Homʸ 𝐴ₗ a b → Homʸ 𝐴ₗ a c
compʸ 𝐴ₗ = StrictifyLeftSegal._∘ʸ_ 𝐴ₗ

syntax compʸ 𝐴ₗ gʸ fʸ = gʸ ∘ʸ[ 𝐴ₗ ] fʸ
}
%```

\p{
We rederive associativity of composition in a [left Segal](stt-00DA) type from the
strict associativity of composition in the [Yoneda strictification](fre-1001).
}

%```agda
\agda{
module AssocStrictifyLeftSegal
  {𝓤 : Level} {A : Type 𝓤} (𝐴ₗ : is-left-segal A)
  (let 𝐴 = is-segal←is-left-segal 𝐴ₗ)
  where

  postcompʸ
    : {a b : A} (c : A) (fʸ : Homʸ 𝐴ₗ a b)
    → Homʸ 𝐴ₗ b c → Homʸ 𝐴ₗ a c
  postcompʸ c fʸ x = compʸ 𝐴ₗ x fʸ

  precompʸ
    : {b c : A} (a : A) (hʸ : Homʸ 𝐴ₗ b c)
    → Homʸ 𝐴ₗ a b → Homʸ 𝐴ₗ a c
  precompʸ a hʸ x = compʸ 𝐴ₗ hʸ x

  ∘-assoc-leftʸ
    : {a b c d : A}
      (h : Hom A c d) (g : Hom A b c) (f : Hom A a b)
    → Homʸ←Hom 𝐴ₗ ((h ∘[ 𝐴 ] g) ∘[ 𝐴 ] f)
    ＝ (Homʸ←Hom 𝐴ₗ h ∘ʸ[ 𝐴ₗ ] Homʸ←Hom 𝐴ₗ g) ∘ʸ[ 𝐴ₗ ] Homʸ←Hom 𝐴ₗ f
  ∘-assoc-leftʸ {a} {b} {c} {d} h g f
    = Homʸ←∘ 𝐴ₗ (h ∘[ 𝐴 ] g) f
    ∙ ap (postcompʸ d (Homʸ←Hom 𝐴ₗ f)) (Homʸ←∘ 𝐴ₗ h g)

  ∘-assoc-rightʸ
    : {a b c d : A}
      (h : Hom A c d) (g : Hom A b c) (f : Hom A a b)
    → Homʸ←Hom 𝐴ₗ (h ∘[ 𝐴 ] (g ∘[ 𝐴 ] f))
    ＝ Homʸ←Hom 𝐴ₗ h ∘ʸ[ 𝐴ₗ ] (Homʸ←Hom 𝐴ₗ g ∘ʸ[ 𝐴ₗ ] Homʸ←Hom 𝐴ₗ f)
  ∘-assoc-rightʸ {a} {b} {c} {d} h g f
    = Homʸ←∘ 𝐴ₗ h (g ∘[ 𝐴 ] f)
    ∙ ap (precompʸ a (Homʸ←Hom 𝐴ₗ h)) (Homʸ←∘ 𝐴ₗ g f)

  ∘-assocʸ
    : {a b c d : A}
      (h : Hom A c d) (g : Hom A b c) (f : Hom A a b)
    → Homʸ←Hom 𝐴ₗ ((h ∘[ 𝐴 ] g) ∘[ 𝐴 ] f)
    ＝ Homʸ←Hom 𝐴ₗ (h ∘[ 𝐴 ] (g ∘[ 𝐴 ] f))
  ∘-assocʸ h g f
    = ∘-assoc-leftʸ h g f
    ∙ ∘ʸ-assoc 𝐴ₗ (Homʸ←Hom 𝐴ₗ h) (Homʸ←Hom 𝐴ₗ g) (Homʸ←Hom 𝐴ₗ f)
    ∙ sym (∘-assoc-rightʸ h g f)

  ∘-assoc-strictify
    : {a b c d : A}
      (h : Hom A c d) (g : Hom A b c) (f : Hom A a b)
    → (h ∘[ 𝐴 ] g) ∘[ 𝐴 ] f
    ＝ h ∘[ 𝐴 ] (g ∘[ 𝐴 ] f)
  ∘-assoc-strictify h g f
    = unap-equiv (Homʸ←Hom-is-equiv 𝐴ₗ) (∘-assocʸ h g f)

  ∘-assoc-strictify-coh
    : {a b c d : A}
      (h : Hom A c d) (g : Hom A b c) (f : Hom A a b)
    → ap (Homʸ←Hom 𝐴ₗ) (∘-assoc-strictify h g f)
    ＝ ∘-assocʸ h g f
  ∘-assoc-strictify-coh h g f
    = ap-unap-equiv (Homʸ←Hom-is-equiv 𝐴ₗ) (∘-assocʸ h g f)
}
%```
}

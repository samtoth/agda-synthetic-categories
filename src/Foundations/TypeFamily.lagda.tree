\subtree[fre-0032]{
\title{Type families and dependent type families}
\taxon{Definition}

\p{
A \em{type family} is a function #{B : A \to \UU}. A \em{dependent type family} over the
type family #{B : A \to \UU} is a function #{Y : (a : A) \to X(a) \to \UV}.
}

%```agda
\agda{
Fam : (рќ“¤1 рќ“¤2 : Level) в†’ Type (lsuc рќ“¤1 вЉ” lsuc рќ“¤2)
Fam рќ“¤1 рќ“¤2 = ОЈ (Type рќ“¤1) (О» X в†’ X в†’ Type рќ“¤2)

DepFam
  : {рќ“¤1 рќ“¤2 : Level}
  в†’ (рќ“¤3 рќ“¤4 : Level)
  в†’ Fam рќ“¤1 рќ“¤2
  в†’ Type (рќ“¤1 вЉ” lsuc рќ“¤3 вЉ” lsuc рќ“¤4)
DepFam рќ“¤3 рќ“¤4 (A , B)
  = ОЈ (A в†’ Type рќ“¤3)
      (О» X в†’ (a : A) в†’ X a в†’ Type рќ“¤4)

DepВІFam
  : {рќ“¤1 рќ“¤2 рќ“¤3 рќ“¤4 : Level}
  в†’ (рќ“¤5 рќ“¤6 : Level)
  в†’ (F : Fam рќ“¤1 рќ“¤2)
  в†’ DepFam рќ“¤3 рќ“¤4 F
  в†’ Type (рќ“¤1 вЉ” рќ“¤3 вЉ” lsuc рќ“¤5 вЉ” lsuc рќ“¤6)
DepВІFam рќ“¤5 рќ“¤6 (A , B) (X , Y)
  = ОЈ ((a : A) в†’ X a в†’ Type рќ“¤5)
      (О» U в†’ (a : A) (x : X a) в†’ U a x в†’ Type рќ“¤6)
}
%```
}


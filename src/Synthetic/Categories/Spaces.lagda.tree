\subtree[tot-03AT]{
\title{#{\mathcal{S}} is directed univalent}
\taxon{Theorem}

\agda{
tr-рқ“ў : вҲҖ {@вҷӯ рқ“Ө} вҶ’ (f : О”В№ вҶ’ Space рқ“Ө) вҶ’ Space.Carrier (f i0) вҶ’ Space.Carrier (f i1)
tr-рқ“ў = tr-cov {P = Space.Carrier} Space-ПҖ-is-covariant

tr-рқ“ў-unique
  : вҲҖ {@вҷӯ рқ“Ө} (f : О”В№ вҶ’ Space рқ“Ө)
      {F : Space.Carrier (f i0) вҶ’ Space.Carrier (f i1)}
    вҶ’ вҲҖ x вҶ’ (HomбөҲ (Space.Carrier вҲҳ f) x (F x))
    вҶ’ tr-рқ“ў f x пјқ F x
tr-рқ“ў-unique f {F = F} x p = ap fst (Space-ПҖ-is-covariant f x .central (F x , p))

duaвҶ’
  : вҲҖ {@вҷӯ рқ“Ө} вҶ’ (О”В№ вҶ’ Space рқ“Ө)
    вҶ’ ОЈ[ A B вҲ¶ Space рқ“Ө ] (Space.Carrier A вҶ’ Space.Carrier B)
duaвҶ’ h = (h i0 , h i1 , tr-рқ“ў h)

coe-рқ“ў
  : вҲҖ {@вҷӯ рқ“Ө} (f : О”В№ вҶ’ Space рқ“Ө) {i j} вҶ’ i вүӨ j
    вҶ’ Space.Carrier (f i) вҶ’ Space.Carrier (f j)
coe-рқ“ў f = coe-cov (Space.Carrier вҲҳ f) (UFib-is-fib f)

coe-рқ“ў-id
  : вҲҖ {@вҷӯ рқ“Ө} (f : О”В№ вҶ’ Space рқ“Ө) {i} (p : i вүӨ i)
    вҶ’ coe-рқ“ў f p ~ id
coe-рқ“ў-id f = coe-cov-id (Space.Carrier вҲҳ f) (UFib-is-fib f)


coe-рқ“ў-О”ВІ
  : вҲҖ {@вҷӯ рқ“Ө} (f : О”ВІ вҶ’ Space рқ“Ө) {i j} вҶ’ i рқ•Җ[x].вүӨ j
    вҶ’ Space.Carrier (f i) вҶ’ Space.Carrier (f j)
coe-рқ“ў-О”ВІ f
  = CoeIAlg.coe-cov-alg рқ•Җ[x] О№-const
      (L[x]-is-lattice-algebra I I-distr)
      (Space.Carrier вҲҳ f)
      (UFib-is-fib f)

coe-рқ“ў-О”ВІ-id
  : вҲҖ {@вҷӯ рқ“Ө} (f : О”ВІ вҶ’ Space рқ“Ө) {i} вҶ’ (p : i рқ•Җ[x].вүӨ i)
    вҶ’ coe-рқ“ў-О”ВІ f p ~ id
coe-рқ“ў-О”ВІ-id f
  = CoeIAlg.coe-cov-alg-id рқ•Җ[x] О№-const
      (L[x]-is-lattice-algebra I I-distr)
      (Space.Carrier вҲҳ f)
      (UFib-is-fib f)

import Synthetic.Categories.DirectedGlueing О”В№ I I-distr non-triv as DG

module _
  (@вҷӯ вҲҡбөҲ-is-prop : вҲҖ {@вҷӯ рқ“Ө рқ“Ҙ} {@вҷӯ О“ : Type рқ“Ө} (@вҷӯ A : (О”В№ вҶ’ О“) вҶ’ Type рқ“Ҙ)
                   вҶ’ (вҲҖ g вҶ’ is-prop (A g)) вҶ’ вҲҖ g вҶ’ is-prop (вҲҡбөҲ A g))
  where

  dua' : вҲҖ {@вҷӯ рқ“Ө} вҶ’ is-equiv (duaвҶ’ {рқ“Ө вҠ” рқ“ҳ})
  dua' {рқ“Ө}
    = types-separate duaвҶ’
        (src-is-equivвҶҗArrow-equiv
          ammape
          (вҷӯ-map-is-equiv (DG.trОЈ-is-equiv {!!} {!Cov-Nat-is-equiv!}))) where
    open Space
    module _ {@вҷӯ рқ“Ҙ} {@вҷӯ О“ : Type рқ“Ҙ} where
      TODOMOVE : (О“ вҶ’ ОЈ[ X Y вҲ¶ Space (рқ“ҳ вҠ” рқ“Ө)] (X .Carrier вҶ’ Y .Carrier))

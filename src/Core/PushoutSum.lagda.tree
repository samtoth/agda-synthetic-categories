%```

\subtree[fre-0021]{
\taxon{Construction}
\title{Pushout sums of arrows}

\p{
Given an [arrow](fre-0001) #{f : A \to B} and a dependent arrow over it
#{g : (b : B) \to X(b) \to Y(b)}, then we may form the \em{pushout}
#{\pushsum_f g} as the cogap map in the square

\quiver{
\begin{tikzcd}
	(\Sigma_{(a : A)} X(f(a))) && (\Sigma_{(a : A)} Y(f(a)))\\
	& \bullet \\
	(\Sigma_{(b : B)} X(b)) && (\Sigma_{(b : B)} Y(b))
	\arrow[from=1-1, to=1-3]
	\arrow[from=1-1, to=3-1]
	\arrow[from=1-3, to=3-3]
	\arrow[from=3-1, to=3-3]
	\arrow[from=1-3, to=2-2]
	\arrow[from=3-1, to=2-2]
	\arrow[dashed, from=2-2, to=3-3, "{\pushsum_f g}"]
	\arrow[phantom, from=1-1, to=2-2, "\ulcorner" very near end]
\end{tikzcd}
}
}

%```agda
\agda{
module _
  {рқ“Ө1 рқ“Ө2 рқ“Ө3 рқ“Ө4}
  {A : Type рқ“Ө1} {B : Type рқ“Ө2} (f : A вҶ’ B)
  {X : B вҶ’ Type рқ“Ө3} {Y : B вҶ’ Type рқ“Ө4} (g : (b : B) вҶ’ X b вҶ’ Y b) where

  ОЈМӮ-left : ОЈ A (X вҲҳ f) вҶ’ ОЈ B X
  ОЈМӮ-left = total-map-fst f

  ОЈМӮ-top : ОЈ A (X вҲҳ f) вҶ’ ОЈ A (Y вҲҳ f)
  ОЈМӮ-top = total-map (О» a вҶ’ g (f a))

  ОЈМӮ-right : ОЈ A (Y вҲҳ f) вҶ’ ОЈ B Y
  ОЈМӮ-right = total-map-fst f

  ОЈМӮ-bot : ОЈ B X вҶ’ ОЈ B Y
  ОЈМӮ-bot = total-map g

  ОЈМӮ-square : Arrow-map ОЈМӮ-left ОЈМӮ-right
  ОЈМӮ-square = mk-amap ОЈМӮ-top ОЈМӮ-bot ~refl

  ОЈМӮ : Pushout ОЈМӮ-left ОЈМӮ-top вҶ’ ОЈ B Y
  ОЈМӮ = cogap-mapвҶҗsquare ОЈМӮ-square
}
%```
}

\subtree[stt-00BS]{
\title{Pushout product}
\taxon{Definition}

\p{
The pushout product is, in a sense, dual to the [pullback power](stt-004D).
Given a pair of maps #{f : A \to B} and #{g : C \to D}, we construct a square of both
orders of mapping from #{A \times C} to #{B \times D}, one component
at a time. The pushout product, written #{f \pushprod g}, is the cogap
map of this square.
}

\p{
The pushout product is the nondependent case of the [pushout sum](fre-0021).
}

%```agda
\agda{
Product-hom
  : {рқ“Ө рқ“Ҙ рқ“Ұ рқ“ң : Level}
    {A : Type рқ“Ө} {B : Type рқ“Ҙ} (f : A вҶ’ B)
    {C : Type рқ“Ұ} {D : Type рқ“ң} (g : C вҶ’ D)
  вҶ’ Arrow-map (f вҠ—1 C) (f вҠ—1 D)
Product-hom f g .Arrow-map.top = _ 1вҠ— g
Product-hom f g .Arrow-map.bot = _ 1вҠ— g
Product-hom f g .Arrow-map.comm = ~refl

pushout-product
  : {рқ“Ө рқ“Ҙ рқ“Ұ рқ“ң : Level}
    {A : Type рқ“Ө} {B : Type рқ“Ҙ} (f : A вҶ’ B)
    {C : Type рқ“Ұ} {D : Type рқ“ң} (g : C вҶ’ D)
  вҶ’ Pushout (f вҠ—1 C) (A 1вҠ— g) вҶ’ B Г— D
pushout-product f g = cogap (CoconeвҶҗArrow-map (Product-hom f g) .snd)

infixl 41 _в–Ў_
_в–Ў_ = pushout-product
}
%```

\p{The pushout product of #{f} with #{g} is sometimes written #{f \pushprod g}.}
}

\subtree[fre-0022]{
\taxon{Lemma}
\title{Fibre characterisation of the pushout sum}

\p{
The fibres of #{\pushsum_f g} are given as the fibrewise join of #{f} and #{g}.
Given a pair #{(b , y)} in the codomain of #{\pushsum_f g} then we have

##{\fibre{\pushsum_f g}{(b , y)} \simeq \fibre{f}{b} * \fibre{g(b)}{y}.}
}

%```agda
\agda{
module _
  {рқ“Ө1 рқ“Ө2 рқ“Ө3 рқ“Ө4 : Level}
  {A : Type рқ“Ө1} {B : Type рқ“Ө2} (f : A вҶ’ B)
  {X : B вҶ’ Type рқ“Ө3} {Y : B вҶ’ Type рқ“Ө4} (g : (b : B) вҶ’ X b вҶ’ Y b) where

  ОЈМӮ-fibre-fam
    : Fam (рқ“Ө2 вҠ” рқ“Ө4) (рқ“Ө1 вҠ” рқ“Ө2 вҠ” рқ“Ө3 вҠ” рқ“Ө4)
  ОЈМӮ-fibre-fam
    = ОЈ B Y
    , fibre (ОЈМӮ f g)

  ОЈМӮб¶ -unstraight-fibre-fam
    : Fam (рқ“Ө2 вҠ” рқ“Ө4) (рқ“Ө1 вҠ” рқ“Ө2 вҠ” рқ“Ө3 вҠ” рқ“Ө4)
  ОЈМӮб¶ -unstraight-fibre-fam = ОЈМӮб¶  (fibre-fam f) (fibre-depfam g)

  ОЈМӮ-fibre-family-over
    : (b : B) (y : Y b)
    вҶ’ Pushout (ОЈМӮ-left f g) (ОЈМӮ-top f g)
    вҶ’ Type (рқ“Ө2 вҠ” рқ“Ө4)
  ОЈМӮ-fibre-family-over b y p = (ОЈМӮ f g p пјқ (b , y))

  ОЈМӮ-fibre-total-span
    : (b : B) (y : Y b)
    вҶ’ Span (рқ“Ө1 вҠ” рқ“Ө2 вҠ” рқ“Ө3 вҠ” рқ“Ө4) (рқ“Ө2 вҠ” рқ“Ө3 вҠ” рқ“Ө4) (рқ“Ө1 вҠ” рқ“Ө2 вҠ” рқ“Ө4)
  ОЈМӮ-fibre-total-span b y
    = total-span (ОЈМӮ-left f g) (ОЈМӮ-top f g) (ОЈМӮ-fibre-family-over b y)

  private
    module ОЈМӮ-fibre-total-span (b : B) (y : Y b) = Span (ОЈМӮ-fibre-total-span b y)

  ОЈМӮ-cogap-fibre-at
    : (b : B) (y : Y b)
    вҶ’ fibre (ОЈМӮ f g) (b , y)
    вүғ Pushout
        (ОЈМӮ-fibre-total-span.left b y)
        (ОЈМӮ-fibre-total-span.right b y)
  ОЈМӮ-cogap-fibre-at b y
    = cogap-fibre (CoconeвҶҗArrow-map (ОЈМӮ-square f g) .snd) (b , y)

  fibre-ОЈМӮ-rightвүғfibre-base
    : (b : B) (y : Y b)
    вҶ’ fibre (ОЈМӮ-right f g) (b , y) вүғ fibre f b
  fibre-ОЈМӮ-rightвүғfibre-base b y = fibre-total-map-fst f b y

  ОЈМӮ-fibre-total-span-centreвүғfibrewise-product
    : (b : B) (y : Y b)
    вҶ’ ОЈМӮ-fibre-total-span.Centre b y
    вүғ (fibre f b Г— fibre (g b) y)
  ОЈМӮ-fibre-total-span-centreвүғfibrewise-product b y
    = fibre-map-ОЈ-over f g b y

  ОЈМӮ-fibre-span-equiv
    : (b : B) (y : Y b)
    вҶ’ Span-equiv
        (mk-span (fibre f b Г— fibre (g b) y) snd fst)
        (mk-span
          (ОЈМӮ-fibre-total-span.Centre b y)
          (ОЈМӮ-fibre-total-span.left b y)
          (ОЈМӮ-fibre-total-span.right b y))
  ОЈМӮ-fibre-span-equiv b y = span-equiv where
    CentreвӮҖ : Type (рқ“Ө1 вҠ” рқ“Ө2 вҠ” рқ“Ө3 вҠ” рқ“Ө4)
    CentreвӮҖ = ОЈМӮ-fibre-total-span.Centre b y

    leftвӮҖ : CentreвӮҖ вҶ’ ОЈМӮ-fibre-total-span.Left b y
    leftвӮҖ = ОЈМӮ-fibre-total-span.left b y

    rightвӮҖ : CentreвӮҖ вҶ’ ОЈМӮ-fibre-total-span.Right b y
    rightвӮҖ = ОЈМӮ-fibre-total-span.right b y

    leftвүғ : ОЈМӮ-fibre-total-span.Left b y вүғ fibre (g b) y
    leftвүғ = fibre-total-map {f = g} {a = b} {b = y}

    rightвүғ : ОЈМӮ-fibre-total-span.Right b y вүғ fibre f b
    rightвүғ = fibre-ОЈМӮ-rightвүғfibre-base b y

    centreвүғ : CentreвӮҖ вүғ (fibre f b Г— fibre (g b) y)
    centreвүғ = ОЈМӮ-fibre-total-span-centreвүғfibrewise-product b y

    leftвӮҖ~left'
      : _вүғ_.bwd leftвүғ вҲҳ snd вҲҳ _вүғ_.fwd centreвүғ ~ leftвӮҖ
    leftвӮҖ~left' ((a , x) , p) = fibre-map-ОЈ-over-left f g b y a x p вҲҷ sym Оұ where
      lвӮҖ : ОЈМӮ-fibre-total-span.Left b y
      lвӮҖ = (f a , x) , p

      ОІ
        : coe (ap (ОЈМӮ-fibre-family-over b y) (sym (glue (a , x)))) p
        пјқ p
      ОІ
        = IdбөҲ-const-coe (ОЈМӮ f g) (sym (glue (a , x))) p
        вҲҷ ap (_вҲҷ p) (ap (ap (ОЈМӮ f g)) (sym-sym {p = glue (a , x)}))
        вҲҷ ap (_вҲҷ p) (pushout-rec-apОІ (a , x))
        вҲҷ вҲҷ-refll p

      Оұ : leftвӮҖ ((a , x) , p) пјқ lвӮҖ
      Оұ = ОЈ-pathвҶ’ (refl , ОІ)

    rightвӮҖ~right'
      : _вүғ_.bwd rightвүғ вҲҳ fst вҲҳ _вүғ_.fwd centreвүғ ~ rightвӮҖ
    rightвӮҖ~right' t = _вүғ_.О· rightвүғ (rightвӮҖ t)

    left-comm
      : _вүғ_.fwd leftвүғ вҲҳ leftвӮҖ ~ snd вҲҳ _вүғ_.fwd centreвүғ
    left-comm p
      = sym (ap (_вүғ_.fwd leftвүғ) (leftвӮҖ~left' p))
      вҲҷ _вүғ_.Оө leftвүғ (snd (_вүғ_.fwd centreвүғ p))

    right-comm
      : _вүғ_.fwd rightвүғ вҲҳ rightвӮҖ ~ fst вҲҳ _вүғ_.fwd centreвүғ
    right-comm p
      = sym (ap (_вүғ_.fwd rightвүғ) (rightвӮҖ~right' p))
      вҲҷ _вүғ_.Оө rightвүғ (fst (_вүғ_.fwd centreвүғ p))

    span-equiv
      : Span-equiv
          (mk-span (fibre f b Г— fibre (g b) y) snd fst)
          (mk-span CentreвӮҖ leftвӮҖ rightвӮҖ)
    span-equiv
      = Span-equivвҶҗinverse-components
          ( centreвүғ
          , leftвүғ
          , left-comm
          , rightвүғ
          , right-comm)

  ОЈМӮ-fibreвүғfibrewise-join
    : ((b , y) : ОЈ B Y)
    вҶ’ fibre (ОЈМӮ f g) (b , y) вүғ fibre f b * fibre (g b) y
  ОЈМӮ-fibreвүғfibrewise-join (b , y)
    = fibre (ОЈМӮ f g) (b , y)                  вүғвҹЁ ОЈМӮ-cogap-fibre-at b y вҹ©
      Pushout (ОЈМӮ-fibre-total-span.left b y)
              (ОЈМӮ-fibre-total-span.right b y) вүғвҹЁ PushoutвүғвҶҗSpan-equiv (ОЈМӮ-fibre-span-equiv b y) вҲҷвүғ pushout-comm вҹ©
      (fibre f b * fibre (g b) y)            вүғвҲҺ

  ОЈМӮ-unstraightenвүғб¶ 
    : ОЈМӮ-fibre-fam вүғб¶  ОЈМӮб¶ -unstraight-fibre-fam
  ОЈМӮ-unstraightenвүғб¶ 
    = idequiv
    , ОЈМӮ-fibreвүғfibrewise-join
}
%```
}

\subtree[fre-0024]{
\taxon{Theorem}
\title{The equivalence of unstraightened pushout sums}

%```agda
\agda{
module _ {рқ“Ө1 рқ“Ө2 рқ“Ө3 рқ“Ө4 : Level}
         (F@(A , B) : Fam рқ“Ө1 рқ“Ө2)
         (G@(X , Y) : DepFam рқ“Ө3 рқ“Ө4 F)
         (let fбөҳ = fst {A = A} {B = B})
         (let gбөҳ = О» a вҶ’ fst {A = X a} {B = Y a})
         (let Fбөҳ = fibre-fam fбөҳ)
         (let Gбөҳ = fibre-depfam gбөҳ) where

  ОЈМӮб¶ -fibre-fam-unstraight
    : Fam (рқ“Ө1 вҠ” рқ“Ө3) (рқ“Ө1 вҠ” рқ“Ө2 вҠ” рқ“Ө4)
  ОЈМӮб¶ -fibre-fam-unstraight = ОЈМӮб¶  Fбөҳ G

  ОЈМӮб¶ -unstraight-fibre-famвүғОЈМӮб¶ -fibre-fam-unstraight
    : ОЈМӮб¶ -unstraight-fibre-fam fбөҳ gбөҳ вүғб¶  ОЈМӮб¶ -fibre-fam-unstraight
  ОЈМӮб¶ -unstraight-fibre-famвүғОЈМӮб¶ -fibre-fam-unstraight
    = ОЈМӮб¶ -ap-вүғбөҲб¶  Fбөҳ Gбөҳ G (О» a вҶ’ (idequiv , fibre-straighten (Y a)))
}
%```
}

\subtree[fre-0026]{
\taxon{Theorem}
\title{The equivalence of straightened pushout sums}


\p{
Given families #{B : A \to \UU} and #{Y : (a : A) \to X a \to \UV}, their
fiberwise pushout sum is equivalent, as a family, to the straightening of the pushout
sum power of total space projections.

##{\pushsum^{\mathrm f}\,F\,G \simeq \pushsum_{\text{straight}}\,F\,G}
}

%```agda
\agda{
module _ {рқ“Ө1 рқ“Ө2 рқ“Ө3 рқ“Ө4 : Level}
         (F@(A , B) : Fam рқ“Ө1 рқ“Ө2)
         (G@(X , Y) : DepFam рқ“Ө3 рқ“Ө4 F)
         (let fбөҳ = fst {A = A} {B = B})
         (let gбөҳ = О» a вҶ’ fst {A = X a} {B = Y a})
         (let Fбөҳ = fibre-fam fбөҳ)
         (let Gбөҳ = fibre-depfam gбөҳ) where

  ОЈМӮ-straight
    : Fam (рқ“Ө1 вҠ” рқ“Ө3) (рқ“Ө1 вҠ” рқ“Ө2 вҠ” рқ“Ө3 вҠ” рқ“Ө4)
  ОЈМӮ-straight = ОЈМӮ-fibre-fam fбөҳ gбөҳ

  ОЈМӮ-straightвүғОЈМӮб¶ -unstraight-fibre-fam
    : ОЈМӮ-straight вүғб¶  ОЈМӮб¶ -unstraight-fibre-fam fбөҳ gбөҳ
  ОЈМӮ-straightвүғОЈМӮб¶ -unstraight-fibre-fam
    = ОЈМӮ-unstraightenвүғб¶  fбөҳ gбөҳ

  ОЈМӮб¶ -fibre-fam-unstraightвүғОЈМӮб¶ 
    : ОЈМӮб¶ -fibre-fam-unstraight F G вүғб¶  ОЈМӮб¶  F G
  ОЈМӮб¶ -fibre-fam-unstraightвүғОЈМӮб¶ 
    = ОЈМӮб¶ -ap-base-fam G (fibre-straighten B)

  ОЈМӮб¶ -unstraight-fibre-famвүғОЈМӮб¶ 
    : ОЈМӮб¶ -unstraight-fibre-fam fбөҳ gбөҳ вүғб¶  ОЈМӮб¶  F G
  ОЈМӮб¶ -unstraight-fibre-famвүғОЈМӮб¶ 
    = concatвүғб¶ 
        (ОЈМӮб¶  F G)
        (ОЈМӮб¶ -unstraight-fibre-famвүғОЈМӮб¶ -fibre-fam-unstraight F G)
        (ОЈМӮб¶ -fibre-fam-unstraightвүғОЈМӮб¶ )

  ОЈМӮ-straightenвүғб¶  : ОЈМӮ-straight вүғб¶  ОЈМӮб¶  F G
  ОЈМӮ-straightenвүғб¶ 
    = concatвүғб¶ 
        (ОЈМӮб¶  F G)
        (ОЈМӮ-straightвүғОЈМӮб¶ -unstraight-fibre-fam)
        (ОЈМӮб¶ -unstraight-fibre-famвүғОЈМӮб¶ )
}
%```
}

%```agda
\agda{
record Fam-cospan рЭУ§ рЭУ• рЭУ¶ : Type (lsuc (рЭУ§ вКФ рЭУ• вКФ рЭУ¶)) where
  field
    Centre : Type рЭУ§
    Left : Centre вЖТ Type рЭУ•
    Right : Centre вЖТ Type рЭУ¶

pullbackвВА-fam : вИА {рЭУ§ рЭУ• рЭУ¶} вЖТ Fam-cospan рЭУ§ рЭУ• рЭУ¶ вЖТ Type (рЭУ§ вКФ рЭУ• вКФ рЭУ¶)
pullbackвВА-fam fc
  = ќ£[ a вИґ fc .Fam-cospan.Centre ]
      (fc .Fam-cospan.Left a √Ч fc .Fam-cospan.Right a)

pullbackвВА-fam-path
  : вИА {рЭУ§ рЭУ• рЭУ¶} вЖТ (X : Fam-cospan рЭУ§ рЭУ• рЭУ¶)
    вЖТ pullbackвВА-fam X вЖТ pullbackвВА-fam X вЖТ Type (рЭУ§ вКФ рЭУ• вКФ рЭУ¶)
pullbackвВА-fam-path X (a , b , c) (a' , b' , c')
  = ќ£[ p вИґ a пЉЭ a' ]
    ( (b пЉЭ[ ap (Fam-cospan.Left X) p ] b')
    √Ч
      (c пЉЭ[ ap (Fam-cospan.Right X) p ] c')
    )

pullbackвВА-fam-path-refl
  : вИА {рЭУ§ рЭУ• рЭУ¶} вЖТ (X : Fam-cospan рЭУ§ рЭУ• рЭУ¶)
    вЖТ (x : pullbackвВА-fam X) вЖТ pullbackвВА-fam-path X x x
pullbackвВА-fam-path-refl X x = (refl , refl , refl)

pullbackвВА-fam-pathвЖРId
  : вИА {рЭУ§ рЭУ• рЭУ¶} вЖТ (X : Fam-cospan рЭУ§ рЭУ• рЭУ¶)
    вЖТ {x y : pullbackвВА-fam X} вЖТ (p : x пЉЭ y)
    вЖТ pullbackвВА-fam-path X x y
pullbackвВА-fam-pathвЖРId X refl = pullbackвВА-fam-path-refl X _

opaque
  pullbackвВА-fam-path-is-torsorial
    : вИА {рЭУ§ рЭУ• рЭУ¶} вЖТ (X : Fam-cospan рЭУ§ рЭУ• рЭУ¶)
      вЖТ (x : pullbackвВА-fam X)
      вЖТ is-singleton (ќ£ _ (pullbackвВА-fam-path X x))
  pullbackвВА-fam-path-is-torsorial X x
    = is-singleton-structureвЖРparts
        Sing-is-singleton
        (_ , refl)
        (is-singleton-structureвЖРparts
          Sing-is-singleton
          (_ , refl)
          Sing-is-singleton)

opaque
  pullbackвВА-fam-pathвЖРId-is-equiv
    : вИА {рЭУ§ рЭУ• рЭУ¶} вЖТ (X : Fam-cospan рЭУ§ рЭУ• рЭУ¶)
      вЖТ {x y : pullbackвВА-fam X}
      вЖТ is-equiv (pullbackвВА-fam-pathвЖРId X {x = x} {y})
  pullbackвВА-fam-pathвЖРId-is-equiv X {x} {y}
    = fundamental-Id _
        (pullbackвВА-fam-path-is-torsorial X x)
        (ќї _ вЖТ pullbackвВА-fam-pathвЖРId X)
        y

pullbackвВА-fam-pathвЖТ
    : вИА {рЭУ§ рЭУ• рЭУ¶} вЖТ (X : Fam-cospan рЭУ§ рЭУ• рЭУ¶)
      вЖТ {x y : pullbackвВА-fam X}
      вЖТ pullbackвВА-fam-path X x y вЖТ x пЉЭ y
pullbackвВА-fam-pathвЖТ X = is-equiv.bwd (pullbackвВА-fam-pathвЖРId-is-equiv X)

record Fam-cospan-map {рЭУ§ рЭУ• рЭУ¶ рЭУЬ рЭУЭ рЭУЫ}
                      (S : Fam-cospan рЭУ§ рЭУ• рЭУ¶) (T : Fam-cospan рЭУЬ рЭУЭ рЭУЫ)
                      : Type (рЭУ§ вКФ рЭУ• вКФ рЭУ¶ вКФ рЭУЬ вКФ рЭУЭ вКФ рЭУЫ) where
  module S = Fam-cospan S
  module T = Fam-cospan T
  field
    hвВВ : S.Centre вЖТ T.Centre
    hвВБ : вИА c вЖТ S.Left c вЖТ T.Left (hвВВ c)
    hвВГ : вИА c вЖТ S.Right c вЖТ T.Right (hвВВ c)

Fam-cospan-map-is-equiv
  : вИА {рЭУ§ рЭУ• рЭУ¶ рЭУЬ рЭУЭ рЭУЫ} {S : Fam-cospan рЭУ§ рЭУ• рЭУ¶} {T : Fam-cospan рЭУЬ рЭУЭ рЭУЫ}
      (F : Fam-cospan-map S T) вЖТ Type (рЭУ§ вКФ рЭУ• вКФ рЭУ¶ вКФ рЭУЬ вКФ рЭУЭ вКФ рЭУЫ)
Fam-cospan-map-is-equiv F = is-equiv hвВВ √Ч is-fibrewise-equiv hвВБ √Ч is-fibrewise-equiv hвВГ
  where open Fam-cospan-map F


pullbackвВБ-fam
  : вИА {рЭУ§ рЭУ• рЭУ¶ рЭУЬ рЭУЭ рЭУЫ} {S : Fam-cospan рЭУ§ рЭУ• рЭУ¶} {T : Fam-cospan рЭУЬ рЭУЭ рЭУЫ}
    вЖТ Fam-cospan-map S T вЖТ pullbackвВА-fam S вЖТ pullbackвВА-fam T
pullbackвВБ-fam F = map-ќ£ hвВВ ќї c вЖТ (hвВБ c вКЧ hвВГ c)
  where open Fam-cospan-map F

pullbackвВБ-fam-is-equiv
  : вИА {рЭУ§ рЭУ• рЭУ¶ рЭУЬ рЭУЭ рЭУЫ} {S : Fam-cospan рЭУ§ рЭУ• рЭУ¶} {T : Fam-cospan рЭУЬ рЭУЭ рЭУЫ}
    вЖТ (F : Fam-cospan-map S T)
    вЖТ Fam-cospan-map-is-equiv F
    вЖТ is-equiv (pullbackвВБ-fam F)
pullbackвВБ-fam-is-equiv F (ec , ea , eb)
  = map-ќ£-is-equiv ec ќї c вЖТ вКЧ-is-equiv (ea c) (eb c)

pullback-famвЙГ
  : вИА {рЭУ§ рЭУ• рЭУ¶ рЭУЬ рЭУЭ рЭУЫ} {S : Fam-cospan рЭУ§ рЭУ• рЭУ¶} {T : Fam-cospan рЭУЬ рЭУЭ рЭУЫ}
    вЖТ ќ£ (Fam-cospan-map S T) Fam-cospan-map-is-equiv
    вЖТ pullbackвВА-fam S вЙГ pullbackвВА-fam T
pullback-famвЙГ (F , Fe) = mkвЙГ (pullbackвВБ-fam F) (pullbackвВБ-fam-is-equiv _ Fe)


\subtree[fre-2124]{
\date{2026-03-11}
\author{fredrikbakke}
\title{The canonical sequential limit of a tower}
\taxon{Definition}

\p{
Given a [tower](fre-2120) #{A} of types
##{\cdots \to A_{n+1} \xrightarrow{f_n} A_n \to \cdots \xrightarrow{f_0} A_0,}
the canonical sequential limit of #{A}, #{\lim A}, is given by the type of sequences
of elements #{a_i : A_i} such that #{a_i = f_i(a_{i+1})} for every #{i}.
}

%```agda
\agda{
module _ {рЭУ§ : Level} where

  Seq-lim-witness
    : (T : Tower рЭУ§)
    вЖТ ((n : вДХ) вЖТ Tower.Point T n)
    вЖТ Type рЭУ§
  Seq-lim-witness T a = (n : вДХ) вЖТ a n пЉЭ Tower.decr T (a (suc n))

  Seq-lim : Tower рЭУ§ вЖТ Type рЭУ§
  Seq-lim T = ќ£[ a вИґ ((n : вДХ) вЖТ Tower.Point T n) ] Seq-lim-witness T a

  limit-point : (T : Tower рЭУ§) вЖТ Seq-lim T вЖТ Tower.Point T zero
  limit-point T (a , ќ±) = a zero

  shift-Tower : Tower рЭУ§ вЖТ Tower рЭУ§
  shift-Tower T = mk-tower (Tower.Point T вИШ suc) (ќї {n} вЖТ Tower.decr T {suc n})

  Seq-lim-tail
    : (T : Tower рЭУ§)
    вЖТ Seq-lim T
    вЖТ Seq-lim (shift-Tower T)
  Seq-lim-tail T (a , ќ±) = (ќї n вЖТ a (suc n)) , (ќї n вЖТ ќ± (suc n))

  Seq-lim-shift-map
    : (T : Tower рЭУ§)
    вЖТ ((n : вДХ) вЖТ Tower.Point T n)
    вЖТ ((n : вДХ) вЖТ Tower.Point T n)
  Seq-lim-shift-map T a n = Tower.decr T (a (suc n))
}
%```
}

\subtree[fre-2125]{
\date{2026-03-11}
\author{fredrikbakke}
\title{Equality in sequential limits}
\taxon{Theorem}

\p{
Given a tower
##{\cdots \to A_{n+1} \xrightarrow{f_n} A_n \to \cdots \xrightarrow{f_0} A_0}
and two elements of its [canonical sequential limit](fre-2124), i.e., two sequences
of elements #{a} and #{b} equipped with equalities #{\alpha_i : a_i = f_i(a_{i+1})}
and #{\beta_i : b_i = f_i(b_{i+1})} respectively, then equality of #{(a , \alpha)}
and #{(b , \beta)} is equivalent to pointwise equality of #{a} and #{b},
#{p_i : a_i = b_i} together with a coherence

\quiver{
\begin{tikzcd}
  a_i && b_i \\
  \\
  f_i(a_{i+1}) && f_i(b_{i+1})
  \arrow[from=1-1, to=1-3, "p_i", equals]
  \arrow[from=1-1, to=3-1, "\alpha_i", equals]
  \arrow[from=1-3, to=3-3, "\beta_i", equals]
  \arrow[from=3-1, to=3-3, "\ap_{f_i}(p_{i+1})"', equals]
\end{tikzcd}
}
}

%```agda
\agda{
Seq-lim-htpy
  : {рЭУ§ : Level} (T : Tower рЭУ§)
  вЖТ Seq-lim T вЖТ Seq-lim T вЖТ Type рЭУ§
Seq-lim-htpy T x y
  = ќ£[ p вИґ fst x ~ fst y ]
      ((n : вДХ)
      вЖТ Square
        (p n)
        (ap (Tower.decr T) (p (suc n)))
        (snd x n)
        (snd y n))

module LimitWithFunExt (FE : FunExt-global) {рЭУ§ : Level} (T : Tower рЭУ§) where
  open WithFunExt-global FE

  Seq-lim-htpyвЖРId
    : {x y : Seq-lim T}
    вЖТ x пЉЭ y
    вЖТ Seq-lim-htpy T x y
  Seq-lim-htpyвЖРId {x = x} refl = (~refl , Square-drop-j вИШ x .snd)

  Seq-lim-htpy-is-torsorial
    : (x : Seq-lim T)
    вЖТ is-singleton (ќ£ (Seq-lim T) (Seq-lim-htpy T x))
  Seq-lim-htpy-is-torsorial x
    = is-singleton-structureвЖРparts
        (htpy-is-torsorial FE (fst x))
        (fst x , ~refl)
        (is-singleвЖРequiv-to-single
          (ќ£-ќ†-swapвЙГ _ _)
          (Singleton-ќ† FE ќї n вЖТ
            is-singleвЖРequiv-to-single
              (ќ£-ap-вЙГ (ќї q вЖТ mk-squareвЙГSquare))
              Sing'-is-singleton))

  Seq-lim-htpyвЖРId-is-equiv
    : {x y : Seq-lim T}
    вЖТ is-equiv (Seq-lim-htpyвЖРId {x} {y})
  Seq-lim-htpyвЖРId-is-equiv {x} {y}
    = fundamental-Id
        (Seq-lim-htpy T x)
        (Seq-lim-htpy-is-torsorial x)
        (ќї y вЖТ Seq-lim-htpyвЖРId)
        (y)

  IdвЙГSeq-lim-htpy
    : {x y : Seq-lim T}
    вЖТ (x пЉЭ y) вЙГ Seq-lim-htpy T x y
  IdвЙГSeq-lim-htpy = mkвЙГ Seq-lim-htpyвЖРId Seq-lim-htpyвЖРId-is-equiv

  IdвЖРSeq-lim-htpy
    : {x y : Seq-lim T}
    вЖТ Seq-lim-htpy T x y
    вЖТ x пЉЭ y
  IdвЖРSeq-lim-htpy = is-equiv.bwd Seq-lim-htpyвЖРId-is-equiv

  ap-limit-point-IdвЖРSeq-lim-htpy
    : {x y : Seq-lim T}
    вЖТ (h : Seq-lim-htpy T x y)
    вЖТ ap (limit-point T) (IdвЖРSeq-lim-htpy h) пЉЭ fst h zero
  ap-limit-point-IdвЖРSeq-lim-htpy {x} h
    = fst-htpy-zero (IdвЖРSeq-lim-htpy h)
    вИЩ ap (ќї k вЖТ fst k zero) (is-equiv.ќµ Seq-lim-htpyвЖРId-is-equiv h)
    where
      fst-htpy-zero
        : {x y : Seq-lim T}
        вЖТ (p : x пЉЭ y)
        вЖТ ap (limit-point T) p пЉЭ fst (Seq-lim-htpyвЖРId p) zero
      fst-htpy-zero refl = refl
}
%```
}

\subtree[fre-2151]{
\date{2026-03-16}
\author{fredrikbakke}
\title{Sequential limits as equalisers}
\taxon{Theorem}

\p{
The canonical sequential limit of a [tower](fre-2120) #{T} is the
[equaliser](fre-2100) of the identity and the shift map
#{(a,n) \mapsto f_n(a_{n+1})} on the type of sequences
#{\prod_{(n : \bN)} A_n}.

\quiver{
\begin{tikzcd}
  \lim A_n && \prod_{(n : \bN)} A_n && \prod_{(n : \bN)} A_n
	\arrow["\id", from=1-3, to=1-5, shift left]
	\arrow["\textsf{shift}"', from=1-3, to=1-5, shift right]
	\arrow[from=1-1, to=1-3]
\end{tikzcd}
}
}

%```agda
\agda{
module LimitWithFunExt-equaliser (FE : FunExt-global) {рЭУ§ : Level} (T : Tower рЭУ§) where
  open WithFunExt-global FE

  Seq-lim-fork : Fork id (Seq-lim-shift-map T) (Seq-lim T)
  Seq-lim-fork = fst , (funextвЖТ вИШ snd)

  Seq-lim-equaliser-gap
    : Seq-lim T вЖТ Equaliser id (Seq-lim-shift-map T)
  Seq-lim-equaliser-gap
    = Equaliser-gap id (Seq-lim-shift-map T) Seq-lim-fork

  Seq-lim-equaliser-gap-is-equiv
    : is-equiv (Seq-lim-equaliser-gap)
  Seq-lim-equaliser-gap-is-equiv = is-equivвЖРqiso qiso where
    qiso : quasi-iso Seq-lim-equaliser-gap
    qiso .fst (a , p) = (a , happly p)
    qiso .snd .fst (a , ќ±) = ќ£-pathвЖТ (refl , funext.ќµ ќ±)
    qiso .snd .snd (a , p) = ќ£-pathвЖТ (refl , funext.ќЈ p)

  Seq-limвЙГEqualiser
    : Seq-lim T вЙГ Equaliser id (Seq-lim-shift-map T)
  Seq-limвЙГEqualiser
    = mkвЙГ Seq-lim-equaliser-gap Seq-lim-equaliser-gap-is-equiv
}
%```
}

\subtree[fre-2152]{
\date{2026-03-16}
\author{fredrikbakke}
\title{Sequential limits as pullbacks}
\taxon{Theorem}

\p{
The canonical sequential limit of a [tower](fre-2120) #{T} is the
[pullback](fre-200B) of the diagonal
#{\Delta : \prod_{(n : \bN)} A_n \to (\prod_{(n : \bN)} A_n)^2}
and the pairing
#{({\id},\textsf{shift}) : \prod_{(n : \bN)} A_n \to (\prod_{(n : \bN)} A_n)^2}
of the identity with the [shift map](fre-2124)
#{(a,n) \mapsto f_n(a_{n+1})}.

\quiver{
\begin{tikzcd}
  {\lim A_n} && {\prod_{(n : \bN)} A_n} \\
  \\
  {\prod_{(n : \bN)} A_n} && {(\prod_{(n : \bN)} A_n)^2}
	\arrow["{\pi_1}", from=1-1, to=1-3]
	\arrow["{\pi_2}"', from=1-1, to=3-1]
	\arrow["\Delta", from=1-3, to=3-3]
	\arrow["{(\id, \textsf{shift})}"', from=3-1, to=3-3]
	\arrow["\lrcorner" very near start, draw=none, from=1-1, to=3-3]
\end{tikzcd}
}
}

\p{
The pullback presentation of sequential limits is derived from the
[equaliser presentation](fre-2151) via the general fact that
[equalisers are pullbacks](fre-2102).
}

%```agda
\agda{
module LimitWithFunExt-pullback (FE : FunExt-global) where
  open WithFunExt-global FE
  open LimitWithFunExt-equaliser FE

  module _ {рЭУ§} (T : Tower рЭУ§) where

    Seq-limвЙГPullback
      : Seq-lim T
      вЙГ Pullback
          (ќї b вЖТ (b , b))
          (ќї a вЖТ (a , Seq-lim-shift-map T a))
    Seq-limвЙГPullback
      = Seq-limвЙГEqualiser T вИЩвЙГ EqualiserвЙГPullback-diagonal
}
%```
}

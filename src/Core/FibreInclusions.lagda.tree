\subtree[tot-0KDL]{
\title{Total cospan}
\taxon{Construction}

%```agda
\agda{
ќ£-cospan
  : вИА {рЭУ§ рЭУ• рЭУ¶ рЭУ§' рЭУ•' рЭУ¶'} {S : Cospan рЭУ§ рЭУ• рЭУ¶}
    вЖТ CospanбµИ S рЭУ§' рЭУ•' рЭУ¶' вЖТ Cospan (рЭУ§ вКФ рЭУ§') (рЭУ• вКФ рЭУ•') (рЭУ¶ вКФ рЭУ¶')
ќ£-cospan cc .Cospan.Centre = ќ£ _ (cc .CospanбµИ.CentreбµИ)
ќ£-cospan cc .Cospan.Left = ќ£ _ (cc .CospanбµИ.LeftбµИ)
ќ£-cospan cc .Cospan.left = map-ќ£ _ (cc .CospanбµИ.leftбµИ)
ќ£-cospan cc .Cospan.Right = ќ£ _ (cc .CospanбµИ.RightбµИ)
ќ£-cospan cc .Cospan.right = map-ќ£ _ (cc .CospanбµИ.rightбµИ)

ѕА-cospanбµИ
  : вИА {рЭУ§ рЭУ• рЭУ¶ рЭУ§' рЭУ•' рЭУ¶'} {S : Cospan рЭУ§ рЭУ• рЭУ¶}
    вЖТ (C : CospanбµИ S рЭУ§' рЭУ•' рЭУ¶')
    вЖТ Cospan-map (ќ£-cospan C) S
ѕА-cospanбµИ C .Cospan-map.hвВБ = fst
ѕА-cospanбµИ C .Cospan-map.hвВВ = fst
ѕА-cospanбµИ C .Cospan-map.hвВГ = fst
ѕА-cospanбµИ C .Cospan-map.H = ~refl
ѕА-cospanбµИ C .Cospan-map.K = ~refl
}
%```
}

\subtree[tot-LP21]{
\title{The fibre of a cospan map}
\taxon{Construction}

%```agda
\agda{
fibre-cospanбµИ
  : вИА {рЭУ§ рЭУ• рЭУ¶ рЭУ§' рЭУ•' рЭУ¶'} {S : Cospan рЭУ§ рЭУ• рЭУ¶} {T : Cospan рЭУ§' рЭУ•' рЭУ¶'}
    вЖТ (F : Cospan-map S T) вЖТ CospanбµИ T (рЭУ§ вКФ рЭУ§') (рЭУ• вКФ рЭУ•') (рЭУ¶ вКФ рЭУ¶')
fibre-cospanбµИ F .CospanбµИ.CentreбµИ = fibre (Cospan-map.hвВВ F)
fibre-cospanбµИ F .CospanбµИ.LeftбµИ = fibre (Cospan-map.hвВБ F)
fibre-cospanбµИ {S = S}{T} F .CospanбµИ.leftбµИ
  = arrow-fibre (mk-amap (Cospan.left S) (Cospan.left T) (F .Cospan-map.H ~вБї¬є))
fibre-cospanбµИ F .CospanбµИ.RightбµИ = fibre (Cospan-map.hвВГ F)
fibre-cospanбµИ F .CospanбµИ.rightбµИ
  = arrow-fibre (mk-amap _ _ (F .Cospan-map.K ~вБї¬є))
}
%```
}

\subtree[tot-0201]{
\title{Equivalences of displayed cospans}
\taxon{Definition}

%```agda
\agda{
CospanбµИ-equiv
  : вИА {рЭУ§ рЭУ• рЭУ¶ рЭУ§' рЭУ•' рЭУ¶' рЭУ§'' рЭУ•'' рЭУ¶''}
      (S : Cospan рЭУ§ рЭУ• рЭУ¶)
      (E : CospanбµИ S рЭУ§' рЭУ•' рЭУ¶') (E' : CospanбµИ S рЭУ§'' рЭУ•'' рЭУ¶'')
    вЖТ Type (рЭУ§ вКФ рЭУ• вКФ рЭУ¶ вКФ рЭУ§' вКФ рЭУ•' вКФ рЭУ¶' вКФ рЭУ§'' вКФ рЭУ•'' вКФ рЭУ¶'')
CospanбµИ-equiv S E E'
  = ќ£[ F вИґ (вИА c вЖТ E .CentreбµИ c вЙГ E' .CentreбµИ c) ]
    ќ£[ L вИґ (вИА l вЖТ E .LeftбµИ l вЙГ E' .LeftбµИ l)]
    ќ£[ _ вИґ (вИА l вЖТ F _ ._вЙГ_.fwd вИШ E .leftбµИ l ~ E' .leftбµИ l вИШ L l ._вЙГ_.fwd)]
    ќ£[ R вИґ (вИА r вЖТ E .RightбµИ r вЙГ E' .RightбµИ r)]
    ((вИА r вЖТ F _ ._вЙГ_.fwd вИШ E .rightбµИ r ~ E' .rightбµИ r вИШ R r ._вЙГ_.fwd))
  where
  open Cospan S
  open CospanбµИ

CospanбµИ-idequiv
  : вИА {рЭУ§ рЭУ• рЭУ¶ рЭУ§' рЭУ•' рЭУ¶'}
      {S : Cospan рЭУ§ рЭУ• рЭУ¶}
      (E : CospanбµИ S рЭУ§' рЭУ•' рЭУ¶')
    вЖТ CospanбµИ-equiv S E E
CospanбµИ-idequiv E
  =
  ( (ќї _ вЖТ idequiv)
  , (ќї _ вЖТ idequiv)
  , (ќї _ вЖТ ~refl)
  , (ќї _ вЖТ idequiv)
  , ќї _ вЖТ ~refl)

CospanбµИ-equivвЖРId
  : вИА {рЭУ§ рЭУ• рЭУ¶ рЭУ§' рЭУ•' рЭУ¶'} {S : Cospan рЭУ§ рЭУ• рЭУ¶} {E E' : CospanбµИ S рЭУ§' рЭУ•' рЭУ¶'}
    вЖТ E пЉЭ E' вЖТ CospanбµИ-equiv S E E'
CospanбµИ-equivвЖРId refl = CospanбµИ-idequiv _

opaque
  CospanбµИ-is-torsorial
    : вИА {рЭУ§ рЭУ• рЭУ¶ рЭУ§' рЭУ•' рЭУ¶'} {S : Cospan рЭУ§ рЭУ• рЭУ¶} (E : CospanбµИ S рЭУ§' рЭУ•' рЭУ¶')
      вЖТ is-singleton (ќ£ (CospanбµИ S рЭУ§' рЭУ•' рЭУ¶') (CospanбµИ-equiv S E))
  CospanбµИ-is-torsorial E
    = is-singleвЖРequiv-to-single
        (ќ£-ap-вЙГ-fst (CospanбµИ-reprвЙГ eвБї¬є))
        (is-singleton-structureвЖРparts
          (SingS-is-single _)
          (_ , ќї _ вЖТ idequiv)
          (is-singleton-structureвЖРparts
            (SingS-is-single _)
            (_ , ќї _ вЖТ idequiv)
            (is-singleton-structureвЖРparts
              (SingS-is-single _)
              (_ , ќї _ вЖТ ~refl)
              (is-singleton-structureвЖРparts
                (SingS-is-single _)
                (_ , ќї _ вЖТ idequiv)
                (SingS-is-single _)))))

CospanбµИ-equivвЖРId-is-equiv
  : вИА {рЭУ§ рЭУ• рЭУ¶ рЭУ§' рЭУ•' рЭУ¶'} {S : Cospan рЭУ§ рЭУ• рЭУ¶} {E E' : CospanбµИ S рЭУ§' рЭУ•' рЭУ¶'}
    вЖТ is-equiv (CospanбµИ-equivвЖРId {E = E}{E'})
CospanбµИ-equivвЖРId-is-equiv
  = fundamental-Id _ (CospanбµИ-is-torsorial _) (ќї _ вЖТ CospanбµИ-equivвЖРId) _

instance
  CospanбµИ-IdS
    : вИА {рЭУ§ рЭУ• рЭУ¶ рЭУ§' рЭУ•' рЭУ¶'} {S : Cospan рЭУ§ рЭУ• рЭУ¶}
      вЖТ Identity-system (CospanбµИ S рЭУ§' рЭУ•' рЭУ¶') (рЭУ§ вКФ рЭУ• вКФ рЭУ¶ вКФ рЭУ§' вКФ рЭУ•' вКФ рЭУ¶')
  CospanбµИ-IdS .Identity-system.IdS = CospanбµИ-equiv _
  CospanбµИ-IdS .Identity-system.IdSвЖРId = CospanбµИ-equivвЖРId
  CospanбµИ-IdS .Identity-system.has-is-ids _ _ = CospanбµИ-equivвЖРId-is-equiv
}
%```
}


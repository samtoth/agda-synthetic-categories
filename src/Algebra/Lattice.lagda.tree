\subtree[stt-009T]{
\title{Lattices}
\taxon{Definition}
\p{A lattice #{L} is an algebraic structure with a pair of commutative monoids
#{\wedge,\vee}, satisfying absorption laws.  Equivalently this
structure can be described by a poset, with operations taking binary meets
(#{\land}) and joins (#{\lor}) for each pair of elements.}

%```agda
\agda{
record is-lattice {­ЮЊц} {L : Type ­ЮЊц} (0l 1l : L) (_РѕД_ : L Рєњ L Рєњ L)
                  (_Рѕе_ : L Рєњ L Рєњ L) : Type ­ЮЊц where
  no-eta-equality
  field
    car-is-set  : is-truncated 2 L
    РѕД-assoc : {x y z : L} Рєњ x РѕД (y РѕД z) №╝Ю (x РѕД y) РѕД z
    Рѕе-assoc : {x y z : L} Рєњ x Рѕе (y Рѕе z) №╝Ю (x Рѕе y) Рѕе z
    РѕД-comm : {x y : L} Рєњ x РѕД y №╝Ю y РѕД x
    Рѕе-comm : {x y : L} Рєњ x Рѕе y №╝Ю y Рѕе x
    Рѕе-РѕД-abs : {x y : L} Рєњ x Рѕе (x РѕД y) №╝Ю x
    РѕД-Рѕе-abs : {x y : L} Рєњ x РѕД (x Рѕе y) №╝Ю x
    0-bottom : {x : L} Рєњ x Рѕе 0l №╝Ю x
    1-top    : {x : L} Рєњ x РѕД 1l №╝Ю x

  instance
    Car-is-set : Рѕђ {k} Рєњ Is-truncated (k + 2) L
    Car-is-set = truncation-instance _ car-is-set


record Lattice {РёЊ} (L : Type РёЊ) : Type РёЊ where
  field
    0l 1l : L
    _РѕД_ : L Рєњ L Рєњ L
    _Рѕе_ : L Рєњ L Рєњ L
    str-is-lattice : is-lattice 0l 1l (_РѕД_) (_Рѕе_)
  infixr 25 _РѕД_
  infixr 24 _Рѕе_

  _РЅц_ : L Рєњ L Рєњ Type РёЊ
  x РЅц y = x РѕД y №╝Ю x

  open is-lattice str-is-lattice public

  is-prop-separated : Рѕђ x y Рєњ is-prop (x №╝Ю y)
  is-prop-separated x y = is-setРєљis-truncated car-is-set x y

  1-coinit : Рѕђ {x} Рєњ x Рѕе 1l №╝Ю 1l
  1-coinit {x}
    =   x Рѕе 1l
      №╝ЮРЪе ap (_Рѕе 1l) (sym 1-top РѕЎ РѕД-comm) РЪЕ
        (1l РѕД x) Рѕе 1l
      №╝ЮРЪе Рѕе-comm РѕЎ Рѕе-РѕД-abs РЪЕ
        1l Рѕј

  0-init : Рѕђ {x} Рєњ 0l РѕД x №╝Ю 0l
  0-init {x}
    =   0l РѕД x
      №╝ЮРЪе ap (0l РѕД_) (sym (Рѕе-comm РѕЎ 0-bottom)) РЪЕ
        (0l РѕД (0l Рѕе x))
      №╝ЮРЪе РѕД-Рѕе-abs РЪЕ
        0l Рѕј

  РѕД-idem : Рѕђ {x : L} Рєњ x РѕД x №╝Ю x
  РѕД-idem {x} = x РѕД x             №╝ЮРЪе ap (x РѕД_) (sym Рѕе-РѕД-abs) РЪЕ
               x РѕД (x Рѕе (x РѕД x)) №╝ЮРЪе РѕД-Рѕе-abs РЪЕ
               x Рѕј

  Рѕе-idem : Рѕђ {x : L} Рєњ x Рѕе x №╝Ю x
  Рѕе-idem {x} = (x Рѕе x)        №╝ЮРЪе ap (x Рѕе_) (sym 1-top) РЪЕ
               (x Рѕе (x РѕД 1l)) №╝ЮРЪе Рѕе-РѕД-abs РЪЕ
               x Рѕј

  Рѕе-РѕД-abs' : Рѕђ {a b} Рєњ (a Рѕе b) РѕД b №╝Ю b
  Рѕе-РѕД-abs' = ap (_РѕД _) Рѕе-comm РѕЎ РѕД-comm РѕЎ РѕД-Рѕе-abs

  РѕД-Рѕе-abs' : Рѕђ {a b} Рєњ (a РѕД b) Рѕе b №╝Ю b
  РѕД-Рѕе-abs' = ap (_Рѕе _) РѕД-comm РѕЎ Рѕе-comm РѕЎ Рѕе-РѕД-abs

  =РѕеРєљ= : Рѕђ {a b} Рєњ a №╝Ю b Рєњ a №╝Ю a Рѕе b
  =РѕеРєљ= {a} {b} p = sym Рѕе-idem РѕЎ ap (a Рѕе_) p

  =Рѕе'Рєљ= : Рѕђ {a b} Рєњ a №╝Ю b Рєњ a №╝Ю b Рѕе a
  =Рѕе'Рєљ= {a} {b} p = sym Рѕе-idem РѕЎ ap (_Рѕе a) p

  РЅц-is-poset : is-poset (_РЅц_)
  РЅц-is-poset =
    record { РЅц-is-prop = РЅц-is-prop
           ; РЅц-refl = РЅц-refl
           ; РЅц-trans = РЅц-trans
           ; РЅц-antisym = РЅц-antisym }
    where
      РЅц-is-prop : {x y : L} Рєњ is-prop (x РЅц y)
      РЅц-is-prop = is-prop-separated _ _

      РЅц-refl : {x : L} Рєњ x РЅц x
      РЅц-refl = РѕД-idem

      РЅц-trans : {x y z : L} Рєњ x РЅц y Рєњ y РЅц z Рєњ x РЅц z
      РЅц-trans {x} {y} {z} p q =  x РѕД z        №╝ЮРЪе  ap (_РѕД z) (sym p)  РЪЕ
                                  (x РѕД y) РѕД z №╝ЮРЪе sym РѕД-assoc РЪЕ
                                  x РѕД (y РѕД z) №╝ЮРЪе ap (x РѕД_) q РЪЕ
                                  x РѕД y       №╝ЮРЪе p РЪЕ
                                  x Рѕј

      РЅц-antisym : {x y : L} Рєњ x РЅц y Рєњ y РЅц x Рєњ x №╝Ю y
      РЅц-antisym {x} {y} p q = sym p РѕЎ РѕД-comm РѕЎ q


  open is-poset РЅц-is-poset public

  РЅцРєљ№╝Ю : Рѕђ {a b} Рєњ a №╝Ю b Рєњ a РЅц b
  РЅцРєљ№╝Ю refl = РЅц-refl

  РЅЦРєљ№╝Ю : Рѕђ {a b} Рєњ a №╝Ю b Рєњ b РЅц a
  РЅЦРєљ№╝Ю refl = РЅц-refl

  РЅц-max : Рѕђ {a b} Рєњ a РЅц b Рєњ a Рѕе b №╝Ю b
  РЅц-max {a} {b} p
    = a Рѕе b             №╝ЮРЪе ap (_Рѕе b) (sym p) РЪЕ
      (a РѕД b) Рѕе b       №╝ЮРЪе РѕД-Рѕе-abs' РЪЕ
      b Рѕј

  РЅцРєљРѕе : Рѕђ {a b} Рєњ a Рѕе b №╝Ю b Рєњ a РЅц b
  РЅцРєљРѕе {a} {b} p
    = a РѕД b           №╝ЮРЪе ap (a РѕД_) (sym p) РЪЕ
      a РѕД (a Рѕе b)     №╝ЮРЪе РѕД-Рѕе-abs РЪЕ
      a Рѕј

  Рѕе-UP : Рѕђ {a b c} Рєњ a РЅц c ├Ќ b РЅц c Рєњ (a Рѕе b РЅц c)
  Рѕе-UP {a} {b} {c} (f , g)
    = РЅцРєљРѕе (sym Рѕе-assoc РѕЎ РЅц-max (ap (a РѕД_) (РЅц-max g) РѕЎ f) РѕЎ РЅц-max g)

  Рѕе-UP-is-equiv : Рѕђ {a b c} Рєњ is-equiv (Рѕе-UP {a}{b}{c})
  Рѕе-UP-is-equiv {a} {b} {c} = is-equivРєљinverse
                    (is-prop-╬Б (is-prop-separated _ _) ╬╗ _ Рєњ is-prop-separated _ _)
                    (is-prop-separated _ _)
                    ╬╗ x Рєњ ap (_РѕД _) (sym (РѕД-Рѕе-abs {a}{b}) )
                          РѕЎ sym РѕД-assoc РѕЎ ap (a РѕД_) x
                          РѕЎ РѕД-Рѕе-abs
                        , ap (_РѕД _) (sym (РѕД-Рѕе-abs {b} {a}))
                          РѕЎ sym РѕД-assoc
                          РѕЎ ap (b РѕД_) (ap (_РѕД c) Рѕе-comm РѕЎ x РѕЎ Рѕе-comm)
                          РѕЎ РѕД-Рѕе-abs

  Рѕе-РЅц-introl : Рѕђ {a b c} Рєњ a РЅц b Рєњ a РЅц (b Рѕе c)
  Рѕе-РЅц-introl p = РЅц-trans p РѕД-Рѕе-abs

  Рѕе-РЅц-intror : Рѕђ {a b c} Рєњ a РЅц c Рєњ a РЅц (b Рѕе c)
  Рѕе-РЅц-intror p = РЅц-trans p (ap (_ РѕД_) Рѕе-comm РѕЎ РѕД-Рѕе-abs)

  РѕД-UP : Рѕђ {a b c} Рєњ a РЅц b ├Ќ a РЅц c Рєњ a РЅц b РѕД c
  РѕД-UP (p , q) = РѕД-assoc РѕЎ ap (_РѕД _) p РѕЎ q

  РѕД-РЅц-eliml : Рѕђ {a b c} Рєњ a РЅц c Рєњ (a РѕД b) РЅц c
  РѕД-РЅц-eliml {a}{b}{c} p = РѕД-comm РѕЎ РѕД-assoc РѕЎ ap (_РѕД b) (РѕД-comm РѕЎ p)

  РѕД-РЅц-elimr : Рѕђ {a b c} Рєњ b РЅц c Рєњ (a РѕД b) РЅц c
  РѕД-РЅц-elimr {a}{b}{c} q = sym РѕД-assoc РѕЎ ap (a РѕД_) q

  instance
    РЅц-bot : Рѕђ {i} Рєњ 0l РЅц i
    РЅц-bot = 0-init

    РЅц-refl-inst : Рѕђ {i} Рєњ i РЅц i
    РЅц-refl-inst = РЅц-refl

    РЅц-top = 1-top
    {-# INCOHERENT РЅц-refl-inst РЅц-top #-}

    РЅц-РѕД : Рѕђ {a b c d} Рєњ РдЃ _ : a РЅц b Рдё Рєњ РдЃ _ : c РЅц d Рдё
          Рєњ (a РѕД c) РЅц (b РѕД d)
    РЅц-РѕД = РѕД-UP (РѕД-РЅц-eliml auto! , РѕД-РЅц-elimr auto!)

    РЅц-Рѕе : Рѕђ {a b c d} Рєњ РдЃ _ : a РЅц b Рдё Рєњ РдЃ _ : c РЅц d Рдё
          Рєњ (a Рѕе c) РЅц (b Рѕе d)
    РЅц-Рѕе = Рѕе-UP (Рѕе-РЅц-introl auto! , Рѕе-РЅц-intror auto!)
}
%```
}

\subtree[stt-00A4]{
\title{Lattice homomorphisms}
\taxon{Definition}

\p{Given [lattice structures](stt-009T) #{L} and #{M} over sets #{A} and #{B}, we say
that a function #{f : A \to B} is a \strong{lattice homomorphism} when it
preserves the lattice operations. Being a lattice homomorphisms is a
[property](stt-0009) of a function.}

%```agda
\agda{
record is-lattice-hom
        {­ЮЊц} {­ЮЊц'} {A : Type ­ЮЊц} {B : Type ­ЮЊц'}
        (L : Lattice A) (M : Lattice B) (f : A Рєњ B) : Type (­ЮЊц Ріћ ­ЮЊц') where
  private
    module A = Lattice L
    module B = Lattice M
  field
    pres-Рѕе : {x y : A} Рєњ f (x A.Рѕе y) №╝Ю f x B.Рѕе f y
    pres-РѕД : {x y : A} Рєњ f (x A.РѕД y) №╝Ю f x B.РѕД f y
    pres-0 : f A.0l №╝Ю B.0l
    pres-1 : f A.1l №╝Ю B.1l

unquoteDecl lattice-hom-reprРЅЁ lattice-hom-reprРЅЃ
  = make-record-repr lattice-hom-reprРЅЁ lattice-hom-reprРЅЃ
                     (quote is-lattice-hom)

is-lattice-hom-is-prop
  : Рѕђ {­ЮЊц ­ЮЊЦ} {A : Type ­ЮЊц} {B : Type ­ЮЊЦ}
      (L : Lattice A) (M : Lattice B) (f : A Рєњ B)
    Рєњ is-prop (is-lattice-hom L M f)
is-lattice-hom-is-prop L M f
  = is-propРєљequiv-to-prop
      (lattice-hom-reprРЅЃ eРЂ╗┬╣)
      (is-prop-╬Б (is-prop-╬архб (is-prop-╬архб (is-prop-separated _ _)))
        ╬╗ _ Рєњ is-prop-╬Б
               ((is-prop-╬архб (is-prop-╬архб (is-prop-separated _ _))))
               ╬╗ _ Рєњ is-prop-╬Б
                 (is-prop-separated _ _)
                   ╬╗ _ Рєњ is-prop-separated _ _) where
   open Lattice M
}
%```
}

\subtree[stt-009Z]{
\taxon{Definition}
\title{Lattice algebras and algebra morphisms}

\p{Fixing a lattice #{L}, we say that a lattice #{M} with a map of sets from
#{L} (that is - an object of the [coslice category](stt-0062) under #{L}) is a
lattice algebra if the underlying function is a
[lattice homomorphism](stt-009Y). Given a pair of coslices #{f} and #{g} under
#{L} which are lattice algebras, we say that a [coslice map](stt-0062) #{f \to
g} is a lattice algebra homomorphism if the underlying map is a
[lattice homomorphism](stt-009Y). }

%```agda
\agda{
is-lattice-algebra : Рѕђ {­ЮЊц ­ЮЊЦ : Level} {A : Type ­ЮЊц} {B : Type ­ЮЊЦ}
                       (L : Lattice A) (M : Lattice B) (f : A Рєњ B)
                     Рєњ Type (­ЮЊц Ріћ ­ЮЊЦ)
is-lattice-algebra = is-lattice-hom

is-lattice-alg-hom : Рѕђ {­ЮЊц ­ЮЊЦ ­ЮЊд} {A : Type ­ЮЊц} {B : Type ­ЮЊЦ} {C : Type ­ЮЊд}
                        (L : Lattice A)
                        (M : Lattice B) {f : A Рєњ B}
                      Рєњ is-lattice-algebra L M f
                      Рєњ (N : Lattice C) {g : A Рєњ C}
                      Рєњ is-lattice-algebra L N g
                      Рєњ Coslice-map f g Рєњ Type (­ЮЊЦ Ріћ ­ЮЊд)
is-lattice-alg-hom L M _ N _ (h , H) = is-lattice-hom M N h
}
%```
}

\subtree[stt-00A0]{
\taxon{Theorem}
\title{The initial lattice algebra}

\p{The initial coslice (the identity function) is also the initial lattice
algebra.}

%```agda
\agda{
initial-lattice-algebra : Рѕђ {­ЮЊц : Level} {A : Type ­ЮЊц} (L : Lattice A)
                          Рєњ is-lattice-algebra L L id
initial-lattice-algebra L .is-lattice-hom.pres-Рѕе = refl
initial-lattice-algebra L .is-lattice-hom.pres-РѕД = refl
initial-lattice-algebra L .is-lattice-hom.pres-0 = refl
initial-lattice-algebra L .is-lattice-hom.pres-1 = refl

initial-lattice-algebra-is-initial
  : Рѕђ {­ЮЊц ­ЮЊЦ} {A : Type ­ЮЊц} (L : Lattice A) {X : Type ­ЮЊЦ} (M : Lattice X)
      {f : A Рєњ X}
    Рєњ (falg : is-lattice-algebra L M f)
    Рєњ is-singleton
        (╬Б _ (is-lattice-alg-hom L L (initial-lattice-algebra L) M falg))
initial-lattice-algebra-is-initial L M {f} falg
  = mk-singl (initial-coslice f .centre , falg)
             (is-prop-╬Б (is-propРєљis-single (initial-coslice f))
                        (╬╗ a Рєњ is-lattice-hom-is-prop _ _ _) _)
}
%```
}

\subtree[stt-009S]{
\title{Congruences}
\taxon{Definition}
\p{An equivalence relation #{\sim} on a lattice #{L} is a congruence if it
respects all lattice operations}

%```agda
\agda{
module Congruence where


record LatticeCongruence {­ЮЊц ­ЮЊЦ} {A : Type ­ЮЊц} (L : Lattice A)
                         (_~_ : A Рєњ A Рєњ Type ­ЮЊЦ) : Type (­ЮЊц Ріћ ­ЮЊЦ) where
  open Lattice L
  field
    ~-equivalence : is-equivalence-relation (_~_)
    ~-Рѕе : {a1 a2 b1 b2 : A} Рєњ a1 ~ b1 Рєњ a2 ~ b2 Рєњ a1 Рѕе a2 ~ b1 Рѕе b2
    ~-РѕД : {a1 a2 b1 b2 : A} Рєњ a1 ~ b1 Рєњ a2 ~ b2 Рєњ a1 РѕД a2 ~ b1 РѕД b2

  open is-equivalence-relation (~-equivalence) public


module _ {­ЮЊц} {­ЮЊЦ} {A : Type ­ЮЊц} {L : Lattice A} where
  open Lattice L
  data РЪф_РЪФ (R : A Рєњ A Рєњ Type ­ЮЊЦ) : A Рєњ A Рєњ Type (­ЮЊц Ріћ ­ЮЊЦ) where
    РЪфРЪФ-inc  : {a b : A} Рєњ R a b Рєњ РЪф R РЪФ a b
    РЪфРЪФ-refl : {a : A} Рєњ РЪф R РЪФ a a
    РЪфРЪФ-sym  : {a b : A} Рєњ РЪф R РЪФ a b Рєњ РЪф R РЪФ b a
    РЪфРЪФ-trans : {a b c : A} Рєњ РЪф R РЪФ a b Рєњ РЪф R РЪФ b c Рєњ РЪф R РЪФ a c
    РЪфРЪФ-Рѕе : {a1 a2 b1 b2 : A} Рєњ РЪф R РЪФ a1 b1 Рєњ РЪф R РЪФ a2 b2 Рєњ РЪф R РЪФ (a1 Рѕе a2) (b1 Рѕе b2)
    РЪфРЪФ-РѕД : {a1 a2 b1 b2 : A} Рєњ РЪф R РЪФ a1 b1 Рєњ РЪф R РЪФ a2 b2 Рєњ РЪф R РЪФ (a1 РѕД a2) (b1 РѕД b2)

  РЪфРЪФ-congruence : {R : A Рєњ A Рєњ Type ­ЮЊЦ}
                Рєњ LatticeCongruence L (╬╗ x y Рєњ РЋЉ РЪф R РЪФ x y РЋЉ)
  РЪфРЪФ-congruence {R} = l-con where
    open LatticeCongruence
    open Trunc {1}
    module E = is-equivalence-relation

    l-eq : is-equivalence-relation (╬╗ x y Рєњ РЋЉ РЪф R РЪФ x y РЋЉ)
    l-eq .E.~-is-prop = is-propРєљis-truncated РЌІРѕѕS
    l-eq .E.reflexive = ╬и РЪфРЪФ-refl
    l-eq .E.symmetric a = do
      rxy Рєљ a
      return (РЪфРЪФ-sym rxy)
    l-eq .E.transitive a b = do
      rxy Рєљ a
      ryz Рєљ b
      return (РЪфРЪФ-trans rxy ryz)

    l-con : LatticeCongruence L (╬╗ x y Рєњ РЋЉ РЪф _ РЪФ x y РЋЉ)
    l-con .~-equivalence = l-eq
    l-con .~-Рѕе p q = do
      r1 Рєљ p
      r2 Рєљ q
      return (РЪфРЪФ-Рѕе r1 r2)
    l-con .~-РѕД p q = do
      r1 Рєљ p
      r2 Рєљ q
      return (РЪфРЪФ-РѕД r1 r2)
}
%```
}


\subtree[stt-00A3]{
\title{Distributive lattices}
\taxon{Definition}

%```agda
\agda{
record is-distributive {­ЮЊц} {L : Type ­ЮЊц} (Lat : Lattice L)  : Type ­ЮЊц where
  open Lattice Lat

  field
    has-is-distrib : Рѕђ {x y z} Рєњ x Рѕе (y РѕД z) №╝Ю (x Рѕе y) РѕД (x Рѕе z)

  distrib-Рѕе-РѕД = has-is-distrib

  distrib-Рѕе-РѕД' : Рѕђ {x y z} Рєњ (x РѕД y) Рѕе z №╝Ю (x Рѕе z) РѕД (y Рѕе z)
  distrib-Рѕе-РѕД' = Рѕе-comm РѕЎ distrib-Рѕе-РѕД РѕЎ apРѓѓ _РѕД_ Рѕе-comm Рѕе-comm

  distrib-РѕД-Рѕе : Рѕђ {x y z} Рєњ x РѕД (y Рѕе z) №╝Ю (x РѕД y) Рѕе (x РѕД z)
  distrib-РѕД-Рѕе {x} {y} {z}
    = Рїю x РїЮ РѕД (y Рѕе z)             №╝ЮРЪе ap! (sym РѕД-Рѕе-abs) РЪЕ
      ((x РѕД (x Рѕе z)) РѕД (y Рѕе z) )  №╝ЮРЪе sym РѕД-assoc РЪЕ
      (x РѕД (x Рѕе z) РѕД (y Рѕе z))     №╝ЮРЪе apРѓѓ _РѕД_
                                         (sym Рѕе-РѕД-abs РѕЎ Рѕе-comm)
                                         (sym (distrib-Рѕе-РѕД')) РЪЕ
      ((x РѕД y Рѕе x) РѕД (x РѕД y Рѕе z)) №╝ЮРЪе sym distrib-Рѕе-РѕД РЪЕ
      ((x РѕД y) Рѕе (x РѕД z)) Рѕј

  distrib-РѕД-Рѕе' : Рѕђ {x y z} Рєњ (x Рѕе y) РѕД z №╝Ю (x РѕД z) Рѕе (y РѕД z)
  distrib-РѕД-Рѕе' = РѕД-comm РѕЎ distrib-РѕД-Рѕе РѕЎ apРѓѓ _Рѕе_ РѕД-comm РѕД-comm

  distribРѓѓ-РѕД-Рѕе : Рѕђ {x y z w}
                 Рєњ x РѕД (y Рѕе z Рѕе w) №╝Ю x РѕД y Рѕе x РѕД z Рѕе x РѕД w
  distribРѓѓ-РѕД-Рѕе {x} {y}{z}{w}
    = distrib-РѕД-Рѕе РѕЎ ap (x РѕД y Рѕе_) distrib-РѕД-Рѕе

  distribРѓѓ-РѕД-Рѕе' : Рѕђ {x y z w}
                 Рєњ (y Рѕе z Рѕе w) РѕД x №╝Ю y РѕД x Рѕе z РѕД x Рѕе w РѕД x
  distribРѓѓ-РѕД-Рѕе' {x} {y}{z}{w}
    = РѕД-comm РѕЎ distribРѓѓ-РѕД-Рѕе РѕЎ apРѓЃ (╬╗ x y z Рєњ x Рѕе (y Рѕе z)) РѕД-comm РѕД-comm РѕД-comm

  opaque
    polynomial-mult
      : Рѕђ {aРѓђ aРѓЂ bРѓђ bРѓЂ} x Рєњ
          (aРѓђ Рѕе (aРѓЂ РѕД x)) РѕД (bРѓђ Рѕе (bРѓЂ РѕД x))
        №╝Ю (aРѓђ РѕД bРѓђ) Рѕе (((aРѓЂ РѕД bРѓђ) Рѕе (aРѓђ РѕД bРѓЂ) Рѕе (aРѓЂ РѕД bРѓЂ)) РѕД x)
    polynomial-mult {aРѓђ} {aРѓЂ} {bРѓђ} {bРѓЂ} x
      = (aРѓђ Рѕе aРѓЂ РѕД x) РѕД (bРѓђ Рѕе bРѓЂ РѕД x)
          №╝ЮРЪе distrib-РѕД-Рѕе РЪЕ
        ((aРѓђ Рѕе aРѓЂ РѕД x) РѕД bРѓђ Рѕе Рїю (aРѓђ Рѕе aРѓЂ РѕД x) РѕД bРѓЂ РѕД x РїЮ)
          №╝ЮРЪе ap! (РѕД-assoc РѕЎ ap (_РѕД x) distrib-РѕД-Рѕе' РѕЎ distrib-РѕД-Рѕе' ) РЪЕ
        ((aРѓђ Рѕе aРѓЂ РѕД x) РѕД bРѓђ Рѕе (aРѓђ РѕД bРѓЂ) РѕД x Рѕе Рїю ((aРѓЂ РѕД x) РѕД bРѓЂ) РѕД x РїЮ)
          №╝ЮРЪе ap! (ap (_РѕД x) (sym РѕД-assoc РѕЎ ap (aРѓЂ РѕД_) РѕД-comm) РѕЎ sym РѕД-assoc
                     РѕЎ ap (aРѓЂ РѕД_) (sym РѕД-assoc РѕЎ ap (bРѓЂ РѕД_) РѕД-idem)) РЪЕ
        (Рїю (aРѓђ Рѕе aРѓЂ РѕД x) РѕД bРѓђ РїЮ Рѕе (aРѓђ РѕД bРѓЂ) РѕД x Рѕе aРѓЂ РѕД bРѓЂ РѕД x)
          №╝ЮРЪе ap! (distrib-РѕД-Рѕе'
                 РѕЎ ap (aРѓђ РѕД bРѓђ Рѕе_) (sym РѕД-assoc РѕЎ ap (aРѓЂ РѕД_) РѕД-comm)) РЪЕ
        ((aРѓђ РѕД bРѓђ Рѕе (aРѓЂ РѕД bРѓђ РѕД x)) Рѕе (aРѓђ РѕД bРѓЂ) РѕД x Рѕе aРѓЂ РѕД bРѓЂ РѕД x)
          №╝ЮРЪе apРѓѓ _Рѕе_ (ap (aРѓђ РѕД bРѓђ Рѕе_) РѕД-assoc)
                      (ap ((aРѓђ РѕД bРѓЂ) РѕД x Рѕе_) РѕД-assoc РѕЎ sym distrib-РѕД-Рѕе') РЪЕ
        ((aРѓђ РѕД bРѓђ) Рѕе ((aРѓЂ РѕД bРѓђ) РѕД x)) Рѕе (aРѓђ РѕД bРѓЂ Рѕе aРѓЂ РѕД bРѓЂ) РѕД x
          №╝ЮРЪе sym Рѕе-assoc РѕЎ ap (aРѓђ РѕД bРѓђ Рѕе_) (sym distrib-РѕД-Рѕе') РЪЕ
        (aРѓђ РѕД bРѓђ Рѕе (aРѓЂ РѕД bРѓђ Рѕе aРѓђ РѕД bРѓЂ Рѕе aРѓЂ РѕД bРѓЂ) РѕД x) Рѕј

    polynomial-mult'
      : Рѕђ {aРѓђ aРѓЂ bРѓђ bРѓЂ} x Рєњ
           ((aРѓђ РѕД x) Рѕе aРѓЂ) РѕД ((bРѓђ РѕД x) Рѕе bРѓЂ)
        №╝Ю (((aРѓђ РѕД bРѓЂ) Рѕе (aРѓЂ РѕД bРѓђ) Рѕе (aРѓђ РѕД bРѓђ)) РѕД x) Рѕе (aРѓЂ РѕД bРѓЂ)
    polynomial-mult' {aРѓђ} {aРѓЂ} {bРѓђ} {bРѓЂ} x
      = ((aРѓђ РѕД x Рѕе aРѓЂ) РѕД (bРѓђ РѕД x Рѕе bРѓЂ))
          №╝ЮРЪе apРѓѓ _РѕД_ Рѕе-comm Рѕе-comm РЪЕ
        ((aРѓЂ Рѕе aРѓђ РѕД x) РѕД (bРѓЂ Рѕе bРѓђ РѕД x))
          №╝ЮРЪе polynomial-mult x РЪЕ
        (aРѓЂ РѕД bРѓЂ Рѕе (aРѓђ РѕД bРѓЂ Рѕе aРѓЂ РѕД bРѓђ Рѕе aРѓђ РѕД bРѓђ) РѕД x)
          №╝ЮРЪе Рѕе-comm РЪЕ
        ((aРѓђ РѕД bРѓЂ Рѕе aРѓЂ РѕД bРѓђ Рѕе aРѓђ РѕД bРѓђ) РѕД x Рѕе aРѓЂ РѕД bРѓЂ) Рѕј
}
%```
}

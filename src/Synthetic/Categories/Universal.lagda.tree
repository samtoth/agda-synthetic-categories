--   → ∀ {a b} → is-equiv (Hom←Id {_}{A}{a}{b})
-- Hom-gpd gpd {a} {b}
--   = is-equiv~∘ {f = _≃_.bwd HomP-repr≃} {g = g ∘ f}
--       (λ {refl → refl})
--       (is-equiv⁻¹ (_≃_.has-is-eqv HomP-repr≃))
--       (is-equiv-∘ {f = g} {g = f}
--         (total-is-equiv←fst-is-equiv (gpd tt))
--         (is-equiv⁻¹ (Σ-＝singl ._≃_.has-is-eqv))) where
--   f : a ＝ b → Σ[ c ∶ _ ] ((c ＝ a) × (c ＝ b))
--   f = _≃_.bwd Σ-＝singl
--   g : Σ[ c ∶ _ ] ((c ＝ a) × (c ＝ b))
--     → Σ[ g ∶ (Δ¹ → _) ] Σ (g i0 ＝ a) (λ hom2 → g i1 ＝ b)
--   g (a , p , q) = (const _ _ a , p , q)

yo
  : ∀ {𝓤 𝓥} {A : Type 𝓤} {F : A → Type 𝓥}
    → is-covariant F
    → ∀ b (x : F b) → ∀ a → Hom _ b a → F a
yo Fc b x a f = tr-cov-hom Fc f x

ev-id
  : ∀ {𝓤 𝓥} {A : Type 𝓤} {F : A → Type 𝓥}
    → ∀ b → (∀ a → Hom _ b a → F a) → F b
ev-id b α = α b (idH b)

is-universal
  : ∀ {𝓤 𝓥} {A : Type 𝓤} {F : A → Type 𝓥}
      → is-covariant F
      → Σ A F → Type (𝓘 ⊔ 𝓤 ⊔ 𝓥)
is-universal {F = F} Fcov (a , x)
  = is-fibrewise-equiv (yo Fcov a x)

universal-rec
  : ∀ {𝓤 𝓥} {A : Type 𝓤} {F : A → Type 𝓥}
    → (Fc : is-covariant F)
    → {x : Σ A F}
    → is-universal Fc x
    → ∀ {b} → F b
    → Hom _ (x .fst) b
universal-rec Fc un = is-equiv.bwd (un _)

Hom-∫
  : ∀ {𝓤 𝓥} {A : Type 𝓤} {B : A → Type 𝓥} (Bc : is-covariant B)
      {x} (x' : B x) {y} (y' : B y)
    → Hom (Σ A B) (x , x') (y , y')
    ≃ Σ[ f ∶ Hom A x y ]
        (tr-cov-hom Bc f x' ＝ y')
Hom-∫ {B = B} Bc x' y'
  = Hom-Σ≃ ∙≃ Σ-ap-≃ (λ a → mk≃ _ (Hom-cov'-is-equiv B Bc a x' y') e⁻¹)

universal←initial
  : ∀ {𝓤 𝓥} {A : Type 𝓤} {F : A → Type 𝓥}
    → (Fc : is-covariant F)
    → {x : Σ A F}
    → is-initial x
    → is-universal Fc x
universal←initial {F = F} Fc {x} init a
  = is-equiv←is-contr-map λ
      b → is-single←equiv-to-single
           (Hom-∫ Fc (x .snd) b)
           (init (a , b))


\subtree[stt-0A2C]{
\taxon{Lemma}
\author{samueltoth}

\p{Any map which is both modal and connected is an equivalence. Combined later
with the universal property of connected maps, this also yields the
universal-property formulation.}

%```agda
\agda{
module _ {ќ±} (RS : gRSubU ќ±) where

  open gRSubU RS
  open gReflectiveClosure RS

  is-equivвЖРis-modalвЖРis-connected
    : вИА {рЭУ§ рЭУ•} {A : Type рЭУ§} {B : Type рЭУ•} {f : A вЖТ B}
      вЖТ is-modal-map GS f вЖТ is-connected-map RS f
      вЖТ is-equiv f
  is-equivвЖРis-modalвЖРis-connected m c
    = is-equivвЖРis-contr-map ќї b
      вЖТ is-singleвЖРequiv-to-single
          (mkвЙГ _ (ќЈ-is-equivвЖРin-SubU (reflector (fibre _ b)) (m b)) eвБї¬є)
          (c b)
}
%```
}

\subtree[fre-1007]{
\date{2026-03-19}
\author{fredrikbakke}
\taxon{Theorem}
\title{Unique dependent extension property of #{K}-connected maps}

\p{
#{K}-Connectedness is equivalent to saying every section of a #{K}-valued
family over the domain uniquely extends along the map.
}

% ```agda
\agda{
up-connected-mapвЗФunique-extensions
  : вИА {ќ± рЭУ§ рЭУ•} (K : gSubU ќ±)
      {A : Type рЭУ§} {B : Type рЭУ•}
      (f : A вЖТ B)
    вЖТ up-connected-map K f
    вЖТ вИА {рЭУЪ} {U : B вЖТ Type рЭУЪ}
    вЖТ (вИА b вЖТ U b вИИ gSubU.S K)
    вЖТ (h : ќ† A (U вИШ f))
    вЖТ is-singleton (Ext f h)
up-connected-mapвЗФunique-extensions K f fconn UвИИK h
  = is-contr-mapвЖРis-equiv (fconn UвИИK) h

up-connected-mapвЖРunique-extensions
  : вИА {ќ± рЭУ§ рЭУ•} (K : gSubU ќ±)
      {A : Type рЭУ§} {B : Type рЭУ•}
      (f : A вЖТ B)
    вЖТ (вИА {рЭУЪ} {U : B вЖТ Type рЭУЪ}
        вЖТ (вИА b вЖТ U b вИИ gSubU.S K)
        вЖТ (h : ќ† A (U вИШ f))
        вЖТ is-singleton (Ext f h))
  вЖТ up-connected-map K f
up-connected-mapвЖРunique-extensions K f ext {U = U} UвИИK
  = is-equivвЖРis-contr-map ќї h вЖТ ext UвИИK h
}
%```
}

\subtree[fre-1008]{
\date{2026-03-19}
\author{fredrikbakke}
\taxon{Lemma}
\title{Terminal projection and constant map criteria on fibres}

\p{
For the fibres of a map, asking that the terminal projections be #{K}-equivalences is
equivalent to asking that the fibres satisfy the universal property of
#{K}-connected types.
}

% ```agda
\agda{
up-connected-!-fibresвЗФup-connected-fibres
  : вИА {ќ± рЭУ§ рЭУ•} (K : gSubU ќ±)
      {A : Type рЭУ§} {B : Type рЭУ•}
      (f : A вЖТ B)
  вЖТ up-connected-!-fibre K f
  вЖТ up-connected-fibres K f
up-connected-!-fibresвЗФup-connected-fibres K f fib-eq b UвИИK
  = is-equiv-constвЖРprecomp-! (fib-eq b UвИИK)

up-connected-!-fibresвЖРup-connected-fibres
  : вИА {ќ± рЭУ§ рЭУ•} (K : gSubU ќ±)
      {A : Type рЭУ§} {B : Type рЭУ•}
      (f : A вЖТ B)
  вЖТ up-connected-fibres K f
  вЖТ up-connected-!-fibre K f
up-connected-!-fibresвЖРup-connected-fibres K f fib-const b UвИИK
  = is-equiv-precomp-!вЖРconst (fib-const b UвИИK)
}
%```
}

\subtree[fre-1009]{
\date{2026-03-19}
\author{fredrikbakke}
\taxon{Theorem}
\title{Fibrewise connected maps are connected}

\p{
If each fibre of #{f} is #{K}-connected, i.e., for each #{b} and each #{K}-type #{U},
the constant map #{U \to (\fibre{f}{b} \to U)} is an equivalence, then #{f} is
#{K}-connected.
}

% ```agda
\agda{
up-connected-mapвЖРup-connected-fibres
  : вИА {ќ± рЭУ§ рЭУ•} (K : gSubU ќ±)
      {A : Type рЭУ§} {B : Type рЭУ•}
      (f : A вЖТ B)
  вЖТ up-connected-fibres K f
  вЖТ up-connected-map K f
up-connected-mapвЖРup-connected-fibres K f fibre-const {U = U} UвИИK
  = is-equivвЖРArrow-equivвБї¬є {F = eq .fst} (eq .snd)
      (postcomp-ќ†-equiv ќї {b} вЖТ fibre-const b (UвИИK b)) where
  eq = precomp-ќ†-fibre-const-Arrow-equiv U f

up-connected-mapвЖРfibre-terminal-equiv
  : вИА {ќ± рЭУ§ рЭУ•} (K : gSubU ќ±)
      {A : Type рЭУ§} {B : Type рЭУ•}
      (f : A вЖТ B)
  вЖТ up-connected-!-fibre K f
  вЖТ up-connected-map K f
up-connected-mapвЖРfibre-terminal-equiv K f fibterm
  = up-connected-mapвЖРup-connected-fibres K f
      (up-connected-!-fibresвЗФup-connected-fibres K f fibterm)
}
%```
}


\subtree[fre-0315]{
\date{2026-03-19}
\author{fredrikbakke}
\title{#{K}-Connected maps, given reflections of fibres}

\agda{
module gReflectorConnectedMaps
    {ќ± рЭУ§ рЭУ•} {GS : gSubU ќ±}
    {A : Type рЭУ§} {B : Type рЭУ•}
    (f : A вЖТ B)
    (RрЭЯЩ : gReflector GS рЭЯЩ)
    (вЧЛрЭЯЩ-singleton : is-singleton (gReflector.вЧЛ RрЭЯЩ))
    (Rf : (b : B) вЖТ gReflector GS (fibre f b)) where
  module One = gReflector RрЭЯЩ

  reflected-fibres-singleton
    : Type (рЭУ§ вКФ рЭУ•)
  reflected-fibres-singleton = вИА b вЖТ is-singleton (gReflector.вЧЛ (Rf b))

  reflected-fibres-singletonвЖРup-connected-!-fibre
    : up-connected-!-fibre GS f
    вЖТ (b : B) вЖТ is-singleton (gReflector.вЧЛ (Rf b))
  reflected-fibres-singletonвЖРup-connected-!-fibre fibterm b
    = is-singleвЖРequiv-to-single
        (mkвЙГ (gReflectorMap.вЧЛвВБ (Rf b) RрЭЯЩ (!: fibre f b))
          (gReflectorModalEquivalences.is-modal-equiv-reflectorsвЖРup-modal-equiv
            (Rf b) RрЭЯЩ (!: fibre f b) (fibterm b))
          eвБї¬є)
        вЧЛрЭЯЩ-singleton

  up-connected-!-fibreвЖРreflected-fibres-singleton
    : ((b : B) вЖТ is-singleton (gReflector.вЧЛ (Rf b)))
    вЖТ up-connected-!-fibre GS f
  up-connected-!-fibreвЖРreflected-fibres-singleton sing b
    = gReflectorModalEquivalences.up-modal-equivвЖРis-modal-equiv-reflectors
        (Rf b) RрЭЯЩ (!: fibre f b)
        (is-equivвЖРsingle-to-prop
          (sing b)
          (is-propвЖРis-single вЧЛрЭЯЩ-singleton)
          (gReflectorMap.вЧЛвВБ (Rf b) RрЭЯЩ (!: fibre f b)))
}
%```
}

\subtree[stt-00J4]{
\date{2026-03-28}
\author{fredrikbakke}
\taxon{Corollary}
\title{Pointed fibre criterion for connected maps with sections}

\p{
If a map #{f : A \to B} is equipped with a [section](stt-000H), then each fibre is
canonically pointed. In this case we can use the characterisation of pointed
connected types to obtain another characterisation of connectedness of #{f}.
}

% ```agda
\agda{
module _
  {ќ± рЭУ§ рЭУ•} (K : gSubU ќ±)
  {A : Type рЭУ§} {B : Type рЭУ•}
  (f : A вЖТ B)
  where

  pointed-up-connected-fibres
    : section f
    вЖТ TypeѕЙ
  pointed-up-connected-fibres (s , sec)
    = (b : B) вЖТ up-connectedвИЧ K (mk-typeвИЧ (fibre f b) (s b , sec b))

  up-connected-fibresвЖРpointed-up-connected-fibres
    : (ѕГ : section f)
    вЖТ pointed-up-connected-fibres ѕГ
    вЖТ up-connected-fibres K f
  up-connected-fibresвЖРpointed-up-connected-fibres (s , sec) pconn b
    = up-connectedвЖРup-connectedвИЧ K (mk-typeвИЧ (fibre f b) (s b , sec b)) (pconn b)

  pointed-up-connected-fibresвЖРup-connected-fibres
    : (ѕГ : section f)
    вЖТ up-connected-fibres K f
    вЖТ pointed-up-connected-fibres ѕГ
  pointed-up-connected-fibresвЖРup-connected-fibres (s , sec) fconn b
    = up-connectedвИЧвЖРup-connected K (mk-typeвИЧ (fibre f b) (s b , sec b)) (fconn b)

  up-connected-mapвЖРpointed-up-connected-fibres
    : (ѕГ : section f)
    вЖТ pointed-up-connected-fibres ѕГ
    вЖТ up-connected-map K f
  up-connected-mapвЖРpointed-up-connected-fibres ѕГ pconn
    = up-connected-mapвЖРup-connected-fibres K f
        (up-connected-fibresвЖРpointed-up-connected-fibres ѕГ pconn)
}
%```
}

\subtree[fre-0316]{
\date{2026-03-19}
\author{fredrikbakke}
\taxon{Theorem}
\title{Reflectors of #{\Sigma}-closed reflective global subuniverses are connected}

\agda{
module gRSubUReflectorConnected {ќ±}
    (RS : gRSubU ќ±)
    (Sќ£ : is-globally-ќ£-closed (RS .gRSubU.GS)) where
  open gRSubU RS
  open gReflectiveClosure RS
  open gReflectiveReasoning RS
  open gRSubUInduction RS Sќ£

  ќЈ-up-connected-map
    : вИА {рЭУ§} {A : Type рЭУ§}
    вЖТ up-connected-map GS (ќЈ {A = A})
  ќЈ-up-connected-map {A = A} {U = U} UвИИS
    = is-equivвБї¬є (ind-is-equiv UвИИS)

  ќЈвИШ-connected-mapвЖРup-modal-equiv
    : вИА {рЭУ§ рЭУ•} {A : Type рЭУ§} {B : Type рЭУ•}
      (f : A вЖТ B)
    вЖТ up-modal-equiv GS f
    вЖТ up-connected-map GS (ќЈ {A = B} вИШ f)
  ќЈвИШ-connected-mapвЖРup-modal-equiv {A = A} {B = B} f feq {U = U} UвИИS
    = homotopy-is-equiv (ќї h вЖТ funextвЖТ ќї a вЖТ  (apбµИ h (вЧЛвВБ-ќ≤ f a))) eqv where

    eqv
      : is-equiv
          ( postcomp-ќ† (ќї a вЖТ tr U (вЧЛвВБ-ќ≤ f a))
          вИШ precomp-ќ† (U вИШ вЧЛвВБ f) ќЈ вИШ precomp-ќ† U (вЧЛвВБ f))
    eqv
      = is-equiv-вИШ
          (postcomp-ќ†-equiv ќї {a} вЖТ coe-is-equiv (ap U (вЧЛвВБ-ќ≤ f a)))
          (is-equiv-вИШ
            (ќЈ-up-connected-map (UвИИS вИШ вЧЛвВБ f))
            (precomp-ќ†-is-equiv (is-modal-equivвЖРup-modal-equiv RS feq)))

  is-modal-equivвЖРup-connected-map
    : вИА {рЭУ§ рЭУ•} {A : Type рЭУ§} {B : Type рЭУ•}
      (f : A вЖТ B)
    вЖТ up-connected-map GS f
    вЖТ is-modal-equiv RS f
  is-modal-equivвЖРup-connected-map f fconn
    = is-modal-equivвЖРup-modal-equiv RS
        (up-modal-equivвЖРup-connected-map GS f fconn)
}
%```
}

\subtree[fre-1010]{
\date{2026-03-19}
\author{fredrikbakke}
\taxon{Lemma}
\title{Connections between certain fibre conditions on a map with #{K}-reflections}

%```agda
\agda{
module gReflectorFibres
    {ќ± рЭУ§ рЭУ•} {GS : gSubU ќ±}
    {A : Type рЭУ§} {B : Type рЭУ•}
    (f : A вЖТ B)
    (Rf : (b : B) вЖТ gReflector GS (fibre f b)) where

  ќЈ-fibre-section
    : ќ† A (ќї a вЖТ gReflector.вЧЛ (Rf (f a)))
  ќЈ-fibre-section a = gReflector.ќЈ (Rf (f a)) (a , refl)

  fibre-local-centreвЖРover
    : (b : B)
    вЖТ null-homotopy
        (precomp-ќ†-over-fibres (ќї b вЖТ gReflector.вЧЛ (Rf b)) f ќЈ-fibre-section b)
    вЖТ ќ£[ u вИґ gReflector.вЧЛ (Rf b) ]
        ((x : fibre f b) вЖТ u пЉЭ gReflector.ќЈ (Rf b) x)
  fibre-local-centreвЖРover b (u , H)
    = u , ќї where (a , refl) вЖТ H (a , refl)

  reflected-fibre-singletonвЖРlocal-centre
    : {b : B}
    вЖТ ќ£[ u вИґ gReflector.вЧЛ (Rf b) ]
        ((x : fibre f b) вЖТ u пЉЭ gReflector.ќЈ (Rf b) x)
    вЖТ is-singleton (gReflector.вЧЛ (Rf b))
  reflected-fibre-singletonвЖРlocal-centre {b} (u , H)
    = mk-singl u (happly p) where
    module Fb = gReflector (Rf b)

    p : const Fb.вЧЛ Fb.вЧЛ u пЉЭ id
    p = unap
          (is-embeddingвЖРis-equiv (Fb.reflects Fb.вЧЛвИИS))
          (funextвЖТ H)

  fibre-precomp-ќ†-ќЈ-fibreвЙГќ†-local-centre-over
    : fibre (precomp-ќ† (ќї b вЖТ gReflector.вЧЛ (Rf b)) f) ќЈ-fibre-section
      вЙГ ((b : B)
        вЖТ null-homotopy
            (precomp-ќ†-over-fibres (ќї b вЖТ gReflector.вЧЛ (Rf b)) f
              ќЈ-fibre-section b))
  fibre-precomp-ќ†-ќЈ-fibreвЙГќ†-local-centre-over
    = fibre-precomp-ќ†-null-homotopyвЙГ
        (ќї b вЖТ gReflector.вЧЛ (Rf b)) f ќЈ-fibre-section

  merely-fibre-local-centreвЖРsurjective-precomp-ќ†
    : (вИА {рЭУЪ} {U : B вЖТ Type рЭУЪ}
        вЖТ ((b : B) вЖТ U b вИИ gSubU.S GS)
        вЖТ is-surjective (precomp-ќ† U f))
    вЖТ ((b : B)
      вЖТ вХС ќ£[ u вИґ gReflector.вЧЛ (Rf b) ]
            ((x : fibre f b) вЖТ u пЉЭ gReflector.ќЈ (Rf b) x) вХС)
  merely-fibre-local-centreвЖРsurjective-precomp-ќ† surj b
    = Trunc.вЧЛ-rec Trunc.вЧЛвИИS
        (Trunc.ќЈ вИШ fibre-local-centreвЖРover b вИШ ev b)
        (Trunc.вЧЛ-rec Trunc.вЧЛвИИS
          (Trunc.ќЈ вИШ fibre-precomp-ќ†-ќЈ-fibreвЙГќ†-local-centre-over ._вЙГ_.fwd)
          (surj (ќї b вЖТ gReflector.вЧЛвИИS (Rf b)) ќЈ-fibre-section))
}
%```
}

\subtree[fre-1011]{
\date{2026-03-19}
\author{fredrikbakke}
\taxon{Theorem}
\title{Fibre reflection conditions for #{K}-connected maps}

%```agda
\agda{
module gReflectorConnectedCharacterisation
    {ќ± рЭУ§ рЭУ•} {GS : gSubU ќ±}
    {A : Type рЭУ§} {B : Type рЭУ•}
    (f : A вЖТ B)
    (RрЭЯЩ : gReflector GS рЭЯЩ)
    (вЧЛрЭЯЩ-singleton : is-singleton (gReflector.вЧЛ RрЭЯЩ))
    (Rf : (b : B) вЖТ gReflector GS (fibre f b)) where
  open gReflectorConnectedMaps f RрЭЯЩ вЧЛрЭЯЩ-singleton Rf
  open gReflectorFibres f Rf

  reflected-fibres-singletonвЖРmerely-local-centre
    : ((b : B)
      вЖТ вХС ќ£[ u вИґ gReflector.вЧЛ (Rf b) ]
            ((x : fibre f b) вЖТ u пЉЭ gReflector.ќЈ (Rf b) x) вХС)
    вЖТ reflected-fibres-singleton
  reflected-fibres-singletonвЖРmerely-local-centre mere b
    = Trunc.вЧЛ-rec
        (is-truncatedвЖРis-prop is-single-is-prop)
        reflected-fibre-singletonвЖРlocal-centre
        (mere b)

  up-connected-!-fibreвЖРmerely-local-centre
    : ((b : B)
      вЖТ вХС ќ£[ u вИґ gReflector.вЧЛ (Rf b) ]
            ((x : fibre f b) вЖТ u пЉЭ gReflector.ќЈ (Rf b) x) вХС)
    вЖТ up-connected-!-fibre GS f
  up-connected-!-fibreвЖРmerely-local-centre mere
    = up-connected-!-fibreвЖРreflected-fibres-singleton
        (reflected-fibres-singletonвЖРmerely-local-centre mere)

  up-connected-mapвЖРmerely-local-centre
    : ((b : B)
      вЖТ вХС ќ£[ u вИґ gReflector.вЧЛ (Rf b) ]
           ((x : fibre f b) вЖТ u пЉЭ gReflector.ќЈ (Rf b) x) вХС)
    вЖТ up-connected-map GS f
  up-connected-mapвЖРmerely-local-centre mere
    = up-connected-mapвЖРfibre-terminal-equiv GS f
        (up-connected-!-fibreвЖРmerely-local-centre mere)

  up-connected-mapвЖРsurjective-precomp-ќ†
    : (вИА {рЭУЪ} {U : B вЖТ Type рЭУЪ}
        вЖТ ((b : B) вЖТ U b вИИ gSubU.S GS)
        вЖТ is-surjective (precomp-ќ† U f))
    вЖТ up-connected-map GS f
  up-connected-mapвЖРsurjective-precomp-ќ† surj
    = up-connected-mapвЖРmerely-local-centre
        (merely-fibre-local-centreвЖРsurjective-precomp-ќ† surj)
}
%```
}

\subtree[fre-0319]{
\date{2026-03-19}
\author{fredrikbakke}
\taxon{Corollary}
\title{Equivalent conditions for connected maps in reflective global subuniverses}

%```agda
\agda{
module gRSubUConnectedCharacterisation {ќ±} (RS : gRSubU ќ±) where
  open gRSubU RS
  open gReflectiveReasoning RS

  module _ {рЭУ§ рЭУ•} {A : Type рЭУ§} {B : Type рЭУ•} (f : A вЖТ B) where
    module Ch = gReflectorConnectedCharacterisation
      f
      (gReflectorвЖРgRSubU RS рЭЯЩ)
      (вЧЛрЭЯЩ-is-single RS)
      (ќї b вЖТ gReflectorвЖРgRSubU RS (fibre f b))
    open Ch
    module LC = gReflectorFibres f (ќї b вЖТ gReflectorвЖРgRSubU RS (fibre f b))


    up-connected-fibresвЖРis-connected-map
      : is-connected-map RS f
      вЖТ  up-connected-fibres GS f
    up-connected-fibresвЖРis-connected-map fconn b UвИИS
      = (is-equiv-вИШ
          (reflects UвИИS)
          (sing-const-is-equiv global-funext (fconn b)))

    up-connected-!-fibreвЖРis-connected-map
      : is-connected-map RS f
      вЖТ up-connected-!-fibre GS f
    up-connected-!-fibreвЖРis-connected-map fconn
      = up-connected-!-fibresвЖРup-connected-fibres GS f
          (up-connected-fibresвЖРis-connected-map fconn)

    is-connected-mapвЖРup-connected-!-fibre
      : up-connected-!-fibre GS f
      вЖТ is-connected-map RS f
    is-connected-mapвЖРup-connected-!-fibre fibterm b
      = is-singleвЖРequiv-to-single
          (mkвЙГ (вЧЛвВБ (!: fibre f b))
            (is-modal-equivвЖРup-modal-equiv RS (fibterm b))
            eвБї¬є)
          (вЧЛрЭЯЩ-is-single RS)

    is-connected-mapвЖРup-connected-map
      : up-connected-map GS f
      вЖТ is-connected-map RS f
    is-connected-mapвЖРup-connected-map fconn
      = reflected-fibres-singletonвЖРmerely-local-centre
          (LC.merely-fibre-local-centreвЖРsurjective-precomp-ќ†
            (ќї UвИИK y вЖТ Trunc.ќЈ
              ( is-equiv.bwd (fconn UвИИK) y
              , is-equiv.ќµ (fconn UвИИK) y)))

    up-connected-mapвЖРis-connected-map
      : is-connected-map RS f
      вЖТ up-connected-map GS f
    up-connected-mapвЖРis-connected-map fconn
      = up-connected-mapвЖРfibre-terminal-equiv GS f
          (up-connected-!-fibreвЖРis-connected-map fconn)
}
%```
}

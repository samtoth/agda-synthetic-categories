\date{2025-06-03}
\title{Equivalences of arrows}
\author{samueltoth}
\import{stt-macros}
\taxon{Module}

%```agda
\agda{
module Core.ArrowEquiv where

open import ufAxioms
open import Foundations.Prelude
open import Foundations.UnitUP

open import Core.Arrow
open import Core.CoSlice
}
%```

\subtree[stt-004R]{
\taxon{Definition}
\title{Arrow equivalences}

\p{A pair of arrows #{A \xrightarrow{f} B} and #{X \xrightarrow{g} Y} are said
to be equivalent if there exists an [arrow map](stt-003U) where both horizontal
morphisms are themselves equivalences.}

\quiver{
\begin{tikzcd}
	A && X \\
	\\
	B && Y
	\arrow["\sim", from=1-1, to=1-3]
	\arrow["f"', from=1-1, to=3-1]
	\arrow["g", from=1-3, to=3-3]
	\arrow["\sim"', from=3-1, to=3-3]
\end{tikzcd}
}

%```agda
\agda{
is-Arrow-equiv : вИА {рЭУ§ рЭУ• рЭУ¶ рЭУЬ} {A : Type рЭУ§} {B : Type рЭУ•} {X : Type рЭУ¶}
                   {Y : Type рЭУЬ} {f : A вЖТ B} {g : X вЖТ Y}
                 вЖТ Arrow-map f g вЖТ Type _
is-Arrow-equiv {f = f} {g} (mk-amap top bot comm)
  = is-equiv top √Ч is-equiv bot

id-square-is-equiv
  : вИА {рЭУ§ рЭУ•} {A : Type рЭУ§} {B : Type рЭУ•}
      {f : A вЖТ B}
    вЖТ is-Arrow-equiv (id-square {f = f})
id-square-is-equiv .fst = id-is-equiv
id-square-is-equiv .snd = id-is-equiv

Arrow-equiv : вИА {рЭУ§ рЭУ• рЭУ¶ рЭУЬ} {A : Type рЭУ§} {B : Type рЭУ•} {X : Type рЭУ¶}
                {Y : Type рЭУЬ} (f : A вЖТ B) (g : X вЖТ Y)
              вЖТ Type _
Arrow-equiv f g = ќ£[ F вИґ Arrow-map f g ] is-Arrow-equiv F

ArrowвБї¬євЖРis-Arrow-equiv : вИА {рЭУ§ рЭУ• рЭУ¶ рЭУЬ} {A : Type рЭУ§} {B : Type рЭУ•} {X : Type рЭУ¶}
                       {Y : Type рЭУЬ} {f : A вЖТ B} {g : X вЖТ Y}
                     вЖТ (F : Arrow-map f g)
                     вЖТ is-Arrow-equiv F
                     вЖТ Arrow-map g f
ArrowвБї¬євЖРis-Arrow-equiv {f = f}{g} (mk-amap top bot comm) (teq , beq)
  = mk-amap top.bwd bot.bwd H module ArrowвБї¬є where opaque
  module top = is-equiv teq
  module bot = is-equiv beq

  K : bot вИШ bot.bwd вИШ g вИШ top ~ bot вИШ f вИШ top.bwd вИШ top
  K =   bot.ќµ вЦЄ g вЦЄ top
     ~вИЩ (comm ~вБї¬є)
     ~вИЩ (bot вЧВ f вЧВ top.ќЈ ~вБї¬є)

  H : (bot.bwd вИШ g) ~ (f вИШ top.bwd)
  H = beq вЧВeqv K вЦЄeqv teq

ArrowвБї¬є-is-equiv : вИА {рЭУ§ рЭУ• рЭУ¶ рЭУЬ} {A : Type рЭУ§} {B : Type рЭУ•} {X : Type рЭУ¶}
                       {Y : Type рЭУЬ} {f : A вЖТ B} {g : X вЖТ Y}
                     вЖТ (F : Arrow-map f g)
                     вЖТ (eq : is-Arrow-equiv F)
                     вЖТ is-Arrow-equiv (ArrowвБї¬євЖРis-Arrow-equiv F eq)
ArrowвБї¬є-is-equiv F (teq , beq) = (is-equivвБї¬є teq  , is-equivвБї¬є beq)
}
%```
}

\subtree[stt-00EH]{
\title{Basic operations on arrow equivalences}
\author{fredrikbakke}

%```agda
\agda{
Arrow-equivвЖРвЙГбґ†
  : {рЭУ§1 рЭУ§2 рЭУ•1 рЭУ•2 : Level}
    (F : Fam рЭУ§1 рЭУ§2)
    (G : Fam рЭУ•1 рЭУ•2)
  вЖТ F вЙГбґ† G вЖТ Arrow-equiv (arrowвЖРFam F) (arrowвЖРFam G)
Arrow-equivвЖРвЙГбґ† (A , B) (X , Y) (e , ef)
  = mk-amap top bot ~refl
  , top-is-equiv
  , bot-is-equiv
  where
  top : ќ£ A B вЖТ ќ£ X Y
  top = total-map-fst (e ._вЙГ_.fwd) вИШ total-map (ќї a вЖТ ef a ._вЙГ_.fwd)

  bot : A вЖТ X
  bot = e ._вЙГ_.fwd

  top-is-equiv : is-equiv top
  top-is-equiv
    = is-equiv-вИШ
        (total-is-equivвЖРfst-is-equiv (e ._вЙГ_.has-is-eqv))
        (is-total-equivвЖРis-fibrewise-equiv (ќї a вЖТ ef a ._вЙГ_.has-is-eqv))

  bot-is-equiv : is-equiv bot
  bot-is-equiv = e ._вЙГ_.has-is-eqv

concat-Arrow-equiv
  : вИА {рЭУ§ рЭУ• рЭУ¶ рЭУЬ рЭУ† рЭУ°}
      {A : Type рЭУ§}
      {B : Type рЭУ•}
      {C : Type рЭУ¶}
      {D : Type рЭУЬ}
      {E : Type рЭУ†}
      {F : Type рЭУ°}
      {f : A вЖТ B}
      {g : C вЖТ D}
      {h : E вЖТ F}
    вЖТ Arrow-equiv f g
    вЖТ Arrow-equiv g h
    вЖТ Arrow-equiv f h
concat-Arrow-equiv (p , peq) (q , qeq)
  = paste-squares q p
  , is-equiv-вИШ (qeq .fst) (peq .fst)
  , is-equiv-вИШ (qeq .snd) (peq .snd)

concat-Arrow-equiv-вЙГбґ†
  : вИА {рЭУ§ рЭУ• рЭУ¶1 рЭУ¶2 рЭУЫ1 рЭУЫ2}
      {A : Type рЭУ§} {B : Type рЭУ•} {f : A вЖТ B}
      (F : Fam рЭУ¶1 рЭУ¶2) (G : Fam рЭУЫ1 рЭУЫ2)
    вЖТ Arrow-equiv f (arrowвЖРFam F)
    вЖТ F вЙГбґ† G
    вЖТ Arrow-equiv f (arrowвЖРFam G)
concat-Arrow-equiv-вЙГбґ† F G eвВА e
  = concat-Arrow-equiv eвВА (Arrow-equivвЖРвЙГбґ† F G e)

inv-Arrow-equiv
  : вИА {рЭУ§ рЭУ• рЭУ¶ рЭУЬ}
      {A : Type рЭУ§}
      {B : Type рЭУ•}
      {C : Type рЭУ¶}
      {D : Type рЭУЬ}
      {f : A вЖТ B}
      {g : C вЖТ D}
    вЖТ Arrow-equiv f g
    вЖТ Arrow-equiv g f
inv-Arrow-equiv (p , peq)
  = ArrowвБї¬євЖРis-Arrow-equiv p peq
  , ArrowвБї¬є-is-equiv p peq

total-fibre-Arrow-equiv
  : вИА {рЭУ§ рЭУ•}
      {A : Type рЭУ§}
      {B : Type рЭУ•}
    вЖТ (f : A вЖТ B)
    вЖТ Arrow-equiv f (arrowвЖРFam (fibre-fam f))
total-fibre-Arrow-equiv f
  = mk-amap (refl-fibre f) id ~refl
  , is-equivвБї¬є (totalвЙГtotal-fibre f ._вЙГ_.has-is-eqv)
  , id-is-equiv

Arrow-equivвЖРfibre-famвЙГбґ†
  : вИА {рЭУ§ рЭУ• рЭУ¶ рЭУЬ}
      {A : Type рЭУ§} {B : Type рЭУ•}
      {X : Type рЭУ¶} {Y : Type рЭУЬ}
      {f : A вЖТ B} {g : X вЖТ Y}
    вЖТ fibre-fam f вЙГбґ† fibre-fam g
    вЖТ Arrow-equiv f g
Arrow-equivвЖРfibre-famвЙГбґ† {f = f} {g = g} e
  = concat-Arrow-equiv
      (concat-Arrow-equiv-вЙГбґ†
        (fibre-fam f)
        (fibre-fam g)
        (total-fibre-Arrow-equiv f)
        (e))
      (inv-Arrow-equiv (total-fibre-Arrow-equiv g))

point-base-change-Arrow-equiv
  : вИА {рЭУ§ рЭУ• рЭУ¶}
      {X : Type рЭУ§} {B : Type рЭУ•} {A : Type рЭУ¶}
      {h : X вЖТ B}
    вЖТ (p : A)
    вЖТ (F : Arrow-map h (point p))
    вЖТ is-cartesian F
    вЖТ Arrow-equiv h (arrowвЖРFam (B , ќї b вЖТ Arrow-map.bot F b пЉЭ p))
point-base-change-Arrow-equiv {B = B} {h = h} p F cart
  = concat-Arrow-equiv-вЙГбґ†
      (fibre-fam h)
      (B , ќї b вЖТ Arrow-map.bot F b пЉЭ p)
      (total-fibre-Arrow-equiv h)
      fam-eq where
  open Arrow-map F

  fam-eq : fibre-fam h вЙГбґ† (B , ќї b вЖТ bot b пЉЭ p)
  fam-eq .fst = idequiv
  fam-eq .snd b
    = mkвЙГ (arrow-fibre F b) (cart b)
    вИЩвЙГ fibre-pointвЙГ p (bot b)
    вИЩвЙГ symвЙГ

fibrewise-Arrow-equivвЖРtotal-square
  : вИА {рЭУШ рЭУ§ рЭУ• рЭУ¶ рЭУЬ} {I : Type рЭУШ}
      {A : I вЖТ Type рЭУ§} {B : I вЖТ Type рЭУ•}
      {f : (i : I) вЖТ A i вЖТ B i}
      {C : I вЖТ Type рЭУ¶} {D : I вЖТ Type рЭУЬ}
      {g : (i : I) вЖТ C i вЖТ D i}
    вЖТ (F : (i : I) вЖТ Arrow-map (f i) (g i))
    вЖТ is-Arrow-equiv (total-square F)
    вЖТ (i : I) вЖТ Arrow-equiv (f i) (g i)
fibrewise-Arrow-equivвЖРtotal-square F eq i
  = F i
  , is-fibrewise-equivвЖРis-total-equiv (eq .fst) i
  , is-fibrewise-equivвЖРis-total-equiv (eq .snd) i
}
%```
}

\subtree[stt-004S]{
\taxon{Theorem}
\title{Arrow equivalences preserve equivalences}

\p{If there is an [arrow equivalence](stt-004R) from #{A \xrightarrow{f} B} to
#{X \xrightarrow{g} Y}, then #{f} is an equivalence iff #{g} is.
}

\proof{This is a simple application of the [3-for-2](stt-003E) property of
equivalences.}

%```agda
\agda{
is-equivвЖРArrow-equiv : вИА {рЭУ§ рЭУ• рЭУ¶ рЭУЬ} {A : Type рЭУ§} {B : Type рЭУ•} {X : Type рЭУ¶}
                       {Y : Type рЭУЬ} {f : A вЖТ B} {g : X вЖТ Y}
                       {F : Arrow-map f g}
                       вЖТ is-Arrow-equiv F
                       вЖТ is-equiv f вЖТ is-equiv g
is-equivвЖРArrow-equiv {F = mk-amap top bot comm} (teq , beq) feq
  = 3-for-2~' comm teq (is-equiv-вИШ beq feq)

is-equivвЖРArrow-equivвБї¬є : вИА {рЭУ§ рЭУ• рЭУ¶ рЭУЬ} {A : Type рЭУ§} {B : Type рЭУ•} {X : Type рЭУ¶}
                       {Y : Type рЭУЬ} {f : A вЖТ B} {g : X вЖТ Y}
                       {F : Arrow-map f g}
                       вЖТ is-Arrow-equiv F
                       вЖТ is-equiv g вЖТ is-equiv f
is-equivвЖРArrow-equivвБї¬є {F = mk-amap top bot comm} (teq , beq) geq
  = 3-for-2~ (comm ~вБї¬є) beq (is-equiv-вИШ geq teq)

topвЗФbot-is-equivвЖРArrow-equiv : вИА {рЭУ§ рЭУ• рЭУ¶ рЭУЬ} {A : Type рЭУ§} {B : Type рЭУ•} {X : Type рЭУ¶}
                       {Y : Type рЭУЬ} {f : A вЖТ B} {g : X вЖТ Y}
                       (F : Arrow-map f g)
                       вЖТ is-Arrow-equiv F
                       вЖТ is-equiv f вЗФ is-equiv g
topвЗФbot-is-equivвЖРArrow-equiv F eq = ( is-equivвЖРArrow-equiv {F = F} eq
                                    , is-equivвЖРArrow-equivвБї¬є {F = F} eq)
}
%```
}

\subtree[stt-0069]{
\title{Arrow equivalences preserve sections}
\taxon{Theorem}

\p{If there is an [arrow equivalence](stt-004R) from #{A \xrightarrow{f} B} to
#{X \xrightarrow{g} Y}, then sections of #{f} are equivalent to sections of #{g}.
}

% TODO(sam): Look into why unification isn't working so well for arrow
%            map

%```agda
\agda{
sectionвЖРArrow-equiv : вИА {рЭУ§ рЭУ• рЭУ¶ рЭУЬ} {A : Type рЭУ§} {B : Type рЭУ•} {X : Type рЭУ¶}
                       {Y : Type рЭУЬ} {f : A вЖТ B} {g : X вЖТ Y}
                       {F : Arrow-map f g}
                       вЖТ is-Arrow-equiv F
                       вЖТ section f вЖТ section g
sectionвЖРArrow-equiv {f = f} {g} {F = F} eq (secf , p) .fst
  = top вИШ secf вИШ bot.bwd where
  open Arrow-map F
  module top = is-equiv (eq .fst)
  module bot = is-equiv (eq .snd)
sectionвЖРArrow-equiv {f = f} {g} {F} eq (secf , p) .snd
  =  H вЦЄ top вЦЄ secf вЦЄ bot.bwd
  ~вИЩ bot вЧВ f вЧВ top.ќЈ вЦЄ secf вЦЄ bot.bwd
  ~вИЩ bot вЧВ p вЦЄ bot.bwd
  ~вИЩ bot.ќµ where
  open Arrow-map F
  module top = is-equiv (eq .fst)
  module bot = is-equiv (eq .snd)
  H : g ~ bot вИШ f вИШ top.bwd
  H = comm вЦЄ top.bwd ~вИЩ g вЧВ top.ќµ ~вБї¬є

sectionвЖРArrow-equivвБї¬є : вИА {рЭУ§ рЭУ• рЭУ¶ рЭУЬ} {A : Type рЭУ§} {B : Type рЭУ•} {X : Type рЭУ¶}
                       {Y : Type рЭУЬ} {f : A вЖТ B} {g : X вЖТ Y}
                       {F : Arrow-map f g}
                       вЖТ is-Arrow-equiv F
                       вЖТ section g вЖТ section f
sectionвЖРArrow-equivвБї¬є {f = f}{g}{F} EF sec = sectionвЖРArrow-equiv {f = g}{f}
                                               {ArrowвБї¬євЖРis-Arrow-equiv F EF}
                                               (ArrowвБї¬є-is-equiv F EF) sec
}
%```
}

\subtree[stt-007M]{
\taxon{Theorem}
\title{Pre/post-composition of arrow equivalences}
\p{Precomposition preserves arrow equivalences}

%```agda
\agda{
postcomp-Arrow-map
  : вИА {рЭУ§ рЭУ• рЭУ¶ рЭУЬ рЭУ†} {A : Type рЭУ§} {B : Type рЭУ•}
      {X : Type рЭУ¶} {Y : Type рЭУЬ}
      {f : A вЖТ B} {g : X вЖТ Y}
    вЖТ (Q : Type рЭУ†)
    вЖТ Arrow-map f g
    вЖТ Arrow-map (postcomp Q f) (postcomp Q g)
postcomp-Arrow-map Q F = mk-amap (top вИШ_) (bot вИШ_) (funextвЖТ вИШ (comm вЦЄ_)) where
  open Arrow-map F


postcomp-square-is-equiv
  : вИА {рЭУ§ рЭУ• рЭУ¶ рЭУЬ рЭУ†} {A : Type рЭУ§} {B : Type рЭУ•}
      {X : Type рЭУ¶} {Y : Type рЭУЬ}
      {f : A вЖТ B} {g : X вЖТ Y}
      (F : Arrow-map f g)
      {Q : Type рЭУ†}
    вЖТ is-Arrow-equiv F
    вЖТ is-Arrow-equiv (postcomp-Arrow-map Q F)
postcomp-square-is-equiv F eq
  = (postcomp-equiv (eq .fst) , postcomp-equiv (eq .snd))

precomp-Arrow-map
  : вИА {рЭУ§ рЭУ• рЭУ¶ рЭУЬ рЭУ†} {A : Type рЭУ§} {B : Type рЭУ•}
      {X : Type рЭУ¶} {Y : Type рЭУЬ}
      {f : A вЖТ B} {g : X вЖТ Y}
    вЖТ (Q : Type рЭУ†)
    вЖТ Arrow-map f g
    вЖТ Arrow-map (precomp Q g) (precomp Q f)
precomp-Arrow-map Q F = mk-amap (_вИШ bot) (_вИШ top) (funextвЖТ вИШ (_вЧВ (comm ~вБї¬є))) where
  open Arrow-map F

precomp-square-is-equiv
  : вИА {рЭУ§ рЭУ• рЭУ¶ рЭУЬ рЭУ†} {A : Type рЭУ§} {B : Type рЭУ•}
      {X : Type рЭУ¶} {Y : Type рЭУЬ}
      {f : A вЖТ B} {g : X вЖТ Y}
      (F : Arrow-map f g)
      {Q : Type рЭУ†}
    вЖТ is-Arrow-equiv F
    вЖТ is-Arrow-equiv (precomp-Arrow-map Q F)
precomp-square-is-equiv F eq
  = (precomp-equiv (eq .snd) , precomp-equiv (eq .fst))
}
%```
}

\subtree[stt-00BQ]{
\title{Arrow equivalences are cartesian squares}
\taxon{Lemma}

%```agda
\agda{
opaque
  is-cartesianвЖРis-equiv
    : вИА {рЭУ§ рЭУ• рЭУ¶ рЭУЬ} {A : Type рЭУ§} {B : Type рЭУ•} {X : Type рЭУ¶}
        {Y : Type рЭУЬ} {f : A вЖТ B} {g : X вЖТ Y}
      вЖТ (F : Arrow-map f g)
      вЖТ is-Arrow-equiv F вЖТ is-cartesian F
  is-cartesianвЖРis-equiv F@(mk-amap top bot p) (teq , beq) b
    = is-equiv-вИШ
        {f = total-map-fst top}
        (total-is-equivвЖРfst-is-equiv teq)
        (is-total-equivвЖРis-fibrewise-equiv
          (ќї a вЖТ is-equiv-вИШ
                   {f = sym (p a) вИЩ_}
                   (вИЩ-is-equiv (sym (p a)))
                   (is-embeddingвЖРis-equiv beq)))
}
%```
}

\subtree[stt-00D7]{
\title{Right cancelling a cartesian square by an arrow equivalence}
\taxon{Lemma}

%```agda
\agda{
right-cancel-cartesian
  : вИА {рЭУ§ рЭУ•} {A : Type рЭУ§} {B : Type рЭУ•} {f : A вЖТ B}
      {рЭУ§' рЭУ•'} {A' : Type рЭУ§'} {B' : Type рЭУ•'} {f' : A' вЖТ B'}
      {рЭУ§'' рЭУ•''} {A'' : Type рЭУ§''} {B'' : Type рЭУ•''} {f'' : A'' вЖТ B''}
      {a : Arrow-map f' f''} {b : Arrow-map f f'}
      {H : Arrow-map f f''}
    вЖТ Arrow-map-path H (paste-squares a b)
    вЖТ is-cartesian H
    вЖТ is-Arrow-equiv b
    вЖТ is-cartesian a
right-cancel-cartesian {a = a}{b}{H} path Hc bc b'
  = is-equivвЖРArrow-equivвБї¬є {F = hom} hom-eq lem where
  open Arrow-map
  open is-equiv
  lem : is-equiv (arrow-fibre a (b .bot (bwd (bc .snd) b')))
  lem = 3-for-2~' {f = arrow-fibre a (b .bot (bwd (bc .snd) b'))}
                  {g = arrow-fibre b (bwd (bc .snd) b')}
                 (arrow-fibre-вИШ a b (bwd (bc .snd) b'))
                 (is-cartesianвЖРis-equiv b bc (bwd (bc .snd) b'))
                 (tr is-cartesian (Arrow-map-pathвЖТ path) Hc (bwd (bc .snd) b'))

  hom : Arrow-map (arrow-fibre a b') (arrow-fibre a (b .bot (bwd (bc .snd) b')))
  hom .top = total-map (ќї x вЖТ _вИЩ sym (ќµ (bc .snd) b'))
  hom .bot = total-map (ќї x вЖТ _вИЩ ap (bot a) (sym (ќµ (bc .snd) b')))
  hom .comm (x , refl)
    = ќ£-pathвЖТ (refl , ap (_вИЩ ap (bot a) _) (вИЩ-reflr (sym (comm a x))))

  hom-eq : is-Arrow-equiv hom
  hom-eq .fst = is-total-equivвЖРis-fibrewise-equiv ќї _ вЖТ вИЩ-is-equiv' _
  hom-eq .snd = is-total-equivвЖРis-fibrewise-equiv ќї _ вЖТ вИЩ-is-equiv' _
}
%```
}

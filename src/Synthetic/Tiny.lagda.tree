\subtree[stt-00KA]{
\title{The dependent amazing right adjoint}
\taxon{Theorem}

\p{
For any tiny type #{I}, we may construct a dependent version of the amazing right
adjoint, written
#{\sqrt[I]{-} : \flat(\Gamma^I \to \Type) \to \flat(\Gamma \to \Type^+)}, where
#{\Type^+} is the successor universe. It satisfies the following universal property:

##{\flat(\Pi_{\Gamma^I} P) \simeq \flat(\Pi_{\Gamma} \sqrt[I]{P})}
}


\proof{
\p{We use the theory of [universal fibrations](stt-00K4). There is a map
#{\pi_I : \UU^{\bullet}_I \to \UU_I} which is at least #{\UU^+}-small
, and so by the fact #{\pi : {\UU^+}^{\bullet} \to \UU^+} classifies #{\UU^+}-small
maps, we have a cartesian square from #{\pi_I} to #{\pi}, and
in particular that lifts of #{\pi_I} against some #{A : \Gamma \to \UU_I}
are equivalent to sections (#{\Pi}-types) of the induced map #{\Gamma \to \UU}.}

\p{Finally to finish the proof, we show that lifts of #{\pi} along
#{A : \Gamma^I \to \UU} can be transposed across the adjunction to give
lifts of #{\pi_I} along #{\bar{A} : \Gamma \to \UU_I}.}
}

\remark{
\p{Notice that this construction bumps the universe level. In \citek{GWB2024}
the cubes separate axiom is used to show that the map #{\pi_I} is actually
#{\UU}-small. For the sake of generality we do not want to assume cubes separate
here. It would be interesting to investigate if it follows that this map is
#{\UU}-small without any further axioms, for example by making use of the similar
but weaker theorem that types separate.}
}

%```agda
\agda{
module DependentέΙγ {@έβφ ΏζΥα} (@έβφ I : Type ΏζΥα)
            (@έβφ έΙγ : έΙΑ {@έβφ ΏζΥν} έΗΤ @έβφ Type ΏζΥν έΗΤ Type ΏζΥν)
            (@έβφ έΙγ╬╡ : έΙΑ {@έβφ ΏζΥν} {@έβφ A : Type ΏζΥν} έΗΤ (I έΗΤ έΙγ A) έΗΤ A)
            (@έβφ is-tiny-str : έΙΑ {@έβφ ΏζΥν} {@έβφ A : Type ΏζΥν}
                              έΗΤ is-tiny-structure I A (έΙγ A) έΙγ╬╡)
            (@έβφ types-separate : έΙΑ {@έβφ ΏζΥν ΏζΥξ} {@έβφ A : Type ΏζΥν} {@έβφ B : Type ΏζΥξ}
                                   {@έβφ f : A έΗΤ B} έΗΤ Types-separate f)
             where
  open Tiny I έΙγ έΙγ╬╡ is-tiny-str types-separate

  private
    έΙγTypeέΙβ-╧Α : έΙΑ {@έβφ ΏζΥν} έΗΤ έθρέβφ| (έΙγ(╬μ (Type ΏζΥν) id) έΗΤ έΙγ(Type ΏζΥν)) έθσ
    έΙγTypeέΙβ-╧Α = έΙγέΓΒ (modέβφ (Type-╧Α _))


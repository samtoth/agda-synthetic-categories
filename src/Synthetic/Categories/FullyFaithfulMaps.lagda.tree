\subtree[stt-00LX]{
\title{Computing the source-target transformation associated to a map}
\taxon{Lemma}
\author{fredrikbakke}
\date{2026-04-13}

\p{
For any map #{f : A \to B}, the induced square between the source-target maps
#{A^{\Delta^1} \to A \times A} and #{B^{\Delta^1} \to B \times B} is equivalent to
the square obtained from precomposition along the boundary inclusion
#{\partial\Delta^1 \hookrightarrow \Delta^1}.
}

\agda{
srcأ—tgt : âˆ€ {ً‌“¤} {A : Type ً‌“¤} â†’ (خ”آ¹ â†’ A) â†’ A أ— A
srcأ—tgt u = (u i0 , u i1)

srcأ—tgt:_ : âˆ€ {ً‌“¤} (A : Type ً‌“¤) â†’ (خ”آ¹ â†’ A) â†’ A أ— A
srcأ—tgt: A = srcأ—tgt

srcأ—tgt-homotopy
  : âˆ€ {ً‌“¤} {A : Type ً‌“¤} (u : خ”آ¹ â†’ A)
    â†’ âˆ‚خ”آ¹-UPâ†’ (srcأ—tgt u) ~ precomp A âˆ‚خ”آ¹-incl u
srcأ—tgt-homotopy u âˆ‚خ”آ¹-0 = refl
srcأ—tgt-homotopy u âˆ‚خ”آ¹-1 = refl

srcأ—tgtâ‰ƒboundary-square
  : âˆ€ {ً‌“¤} {A : Type ً‌“¤}
    â†’ Arrow-equiv (srcأ—tgt: A) (precomp A âˆ‚خ”آ¹-incl)
srcأ—tgtâ‰ƒboundary-square
  = (mk-amap id (âˆ‚خ”آ¹-UP ._â‰ƒ_.fwd) (funextâ†’ âˆک srcأ—tgt-homotopy))
  , id-is-equiv
  , âˆ‚خ”آ¹-UP ._â‰ƒ_.fwd-is-equiv

module _ {ً‌“¤ ً‌“¥} {A : Type ً‌“¤} {B : Type ً‌“¥} (f : A â†’ B) where

  srcأ—tgt-square
    : Arrow-map (postcomp خ”آ¹ f) (f âٹ— f)
  srcأ—tgt-square .Arrow-map.top = srcأ—tgt
  srcأ—tgt-square .Arrow-map.bot = srcأ—tgt
  srcأ—tgt-square .Arrow-map.comm = ~refl

  srcأ—tgt-natural-pair
    : (xy : A أ— A)
    â†’ postcomp âˆ‚خ”آ¹ f (âˆ‚خ”آ¹-UPâ†’ xy)
    ~ âˆ‚خ”آ¹-UPâ†’ ((f âٹ— f) xy)
  srcأ—tgt-natural-pair (x , y) âˆ‚خ”آ¹-0 = refl
  srcأ—tgt-natural-pair (x , y) âˆ‚خ”آ¹-1 = refl

  srcأ—tgt-squareâ‰ƒpower-hom
    : Cube (transpose-square srcأ—tgt-square) (transpose-square (power-hom âˆ‚خ”آ¹-incl f))
  srcأ—tgt-squareâ‰ƒpower-hom
    = mk-cube
        (srcأ—tgtâ‰ƒboundary-square .fst)
        (srcأ—tgtâ‰ƒboundary-square .fst)
        ( ~refl
        , funextâ†’ âˆک srcأ—tgt-natural-pair
        , خ» u
          â†’ âˆ™-reflr _
          âˆ™ âˆ™-reflr _
          âˆ™ sym (commutes-postwhisker-funext {h = f} (srcأ—tgt-homotopy u))
          âˆ™ ap funextâ†’
              (funextâ†’ خ» where
                âˆ‚خ”آ¹-0 â†’ sym (âˆ™-reflr _)
                âˆ‚خ”آ¹-1 â†’ sym (âˆ™-reflr _))
          âˆ™ funext-âˆ™
              (srcأ—tgt-natural-pair (srcأ—tgt u))
              (srcأ—tgt-homotopy (postcomp خ”آ¹ f u)))

  srcأ—tgt-squareâ‰ƒpower-hom-is-equiv : is-Cube-equiv srcأ—tgt-squareâ‰ƒpower-hom
  srcأ—tgt-squareâ‰ƒpower-hom-is-equiv
    = srcأ—tgtâ‰ƒboundary-square .snd
    , srcأ—tgtâ‰ƒboundary-square .snd
}
}

\subtree[stt-00LY]{
\title{A map is fully faithful iff the transformation of source-target maps is cartesian}
\taxon{Proposition}
\author{fredrikbakke}
\date{2026-04-13}

\p{
A map #{f : A \to B} is fully faithful if and only if the induced square between
source-target maps #{A^{\Delta^1} \to A \times A} and
#{B^{\Delta^1} \to B \times B} is cartesian.
}

\p{
This result is analogous to \citet{Proposition 2.6.3}{Hau25}, although the definition
of fully faithful maps and the method of proof are different.
}

\proof{
\p{
By \ref{stt-00LX}, this source-target square is equivalent to the exponential square

\quiver{
\begin{tikzcd}
  A^{\Delta^1} && B^{\Delta^1} \\
  \\
  A^{\partial\Delta^1} && B^{\partial\Delta^1}
\arrow[from=1-1, to=1-3]
\arrow[from=1-1, to=3-1]
\arrow[from=1-3, to=3-3]
\arrow[from=3-1, to=3-3]
\end{tikzcd}
}
and this square is cartesian if and only if the pullback power with the boundary
inclusion of #{\Delta^1} is an equivalence, which in turn is the orthogonality
condition for fully faithful maps.
}
}

\agda{
module _ {ً‌“¤ ً‌“¥} {A : Type ً‌“¤} {B : Type ً‌“¥} {f : A â†’ B} where

  is-cartesian-srcأ—tgt-squareâ†گis-ff
    : is-ff f â†’ is-cartesian (srcأ—tgt-square f)
  is-cartesian-srcأ—tgt-squareâ†گis-ff ff
    = front-cartesianâ†گequiv-transpose-cube
        (srcأ—tgt-squareâ‰ƒpower-hom f)
        (srcأ—tgt-squareâ‰ƒpower-hom-is-equiv f)
        (power-hom-cartesianâ†گpullback-power âˆ‚خ”آ¹-incl f (ff tt))

  is-ffâ†گis-cartesian-srcأ—tgt-square
    : is-cartesian (srcأ—tgt-square f) â†’ is-ff f
  is-ffâ†گis-cartesian-srcأ—tgt-square cart _
    = pullback-powerâ†گpower-hom-cartesian
          âˆ‚خ”آ¹-incl f
          (back-cartesianâ†گequiv-transpose-cube
            (srcأ—tgt-squareâ‰ƒpower-hom f)
            (srcأ—tgt-squareâ‰ƒpower-hom-is-equiv f)
            (cart))

  is-ffâ†”is-cartesian-srcأ—tgt-square
    : is-ff f â†” is-cartesian (srcأ—tgt-square f)
  is-ffâ†”is-cartesian-srcأ—tgt-square
    = ( is-cartesian-srcأ—tgt-squareâ†گis-ff
      , is-ffâ†گis-cartesian-srcأ—tgt-square)
}
}

\subtree[stt-00R9]{
\title{Fully faithful maps reflect split monos, split epis, and isos}
\taxon{Proposition}
\author{fredrikbakke}
\date{2026-05-14}

\p{
Given a fully faithful map #{F : A \to B} and a morphism #{f : \Hom_A(a,b)} then if
#{F(f)} is a split mono/split epi/iso then so is #{f}.
}

\proof{
\p{
The isomorphism case follows from the split mono + split epi case, and these two
cases are dual to one another, so let's just demonstrate that split monos are
reflected.
}

\p{
Let #{r'} be such that #{r' \circ F(f) = \id}. Since the action on morphisms of #{F}
has a section there is a morphism #{r : \Hom_A(b,a)} such that #{F(r) = r'}.
Now, by injectivity of the functorial action it suffices to show
#{F(r \circ f) = F(\id)}, which is easy to see by functoriality:
##{F(r \circ f) = F(r) \circ F(f) = r' \circ F(f) = \id = F(\id).}
}
}

\p{
We observe that the proof above only requires that the action on morphisms of
#{F} has a section and is injective on endomorphisms (which in particular means the
action on endomorphisms is an equivalence [[stt-00R6]]). We formalise the proof at
this level of generality.
}

\agda{
module _
  {ً‌“¤ ً‌“¥ : Level} {A : Type ً‌“¤} {B : Type ً‌“¥}
  (ً‌گ´ : is-segal A) (ً‌گµ : is-segal B)
  {F : A â†’ B}
  where

  split-mono-witnessâ†گap-hom-fibre
    : {a b : A} {f : Hom A a b}
      (Ia : {g : Hom A a a} â†’ ap-hom F g ï¼‌ ap-hom F (idH a) â†’ g ï¼‌ idH a)
      {r' : Hom B (F b) (F a)}
    â†’ Hom2 r' (ap-hom F f) (idH (F a))
    â†’ fibre (ap-hom F {b} {a}) r'
    â†’ split-mono-witness f
  split-mono-witnessâ†گap-hom-fibre {a} {b} {f} Ia خ·' (r , rp)
    = split-mono-witnessâ†گeq ً‌گ´
      ( r
      , Ia
        ( unique-composite ً‌گµ (ap-hom F r) (ap-hom F f)
          (ap-hom F (r âˆک[ ً‌گ´ ] f))
          (ap-hom2 F r f (r âˆک[ ً‌گ´ ] f) âˆک[ ً‌گ´ ]-is-composite)
        âˆ™ ap (_âˆک[ ً‌گµ ] ap-hom F f) rp
        âˆ™ âˆک=â†گHom2 ً‌گµ خ·'))

  split-epi-witnessâ†گap-hom-fibre
    : {a b : A} {f : Hom A a b}
      (Ib : {g : Hom A b b} â†’ ap-hom F g ï¼‌ ap-hom F (idH b) â†’ g ï¼‌ idH b)
      {s' : Hom B (F b) (F a)}
    â†’ Hom2 (ap-hom F f) s' (idH (F b))
    â†’ fibre (ap-hom F {b} {a}) s'
    â†’ split-epi-witness f
  split-epi-witnessâ†گap-hom-fibre {a} {b} {f} Ib خµ' (s , sp)
    = s
    , split-mono-witnessâ†گap-hom-fibre Ib
        (tr (خ» h â†’ Hom2 (ap-hom F f) h (idH (F b))) (sym sp) خµ')
        (f , refl)
        .snd
}

\p{
Finally we register the theorems for fully faithful maps.
}

\agda{
module _
  {ً‌“¤ ً‌“¥ : Level} {A : Type ً‌“¤} {B : Type ً‌“¥}
  (ً‌گ´ : is-segal A) (ً‌گµ : is-segal B)
  {F : A â†’ B} (F-is-ff : is-ff' F)
  {a b : A} {f : Hom A a b}
  where

  reflects-split-monosâ†گis-ff'
    : split-mono-witness (ap-hom F f) â†’ split-mono-witness f
  reflects-split-monosâ†گis-ff' (r' , خ·')
    = split-mono-witnessâ†گap-hom-fibre ً‌گ´ ً‌گµ
        (unap-equiv F-is-ff)
        خ·'
        (is-equiv.bwd F-is-ff r' , is-equiv.خµ F-is-ff r')

  reflects-split-episâ†گis-ff'
    : split-epi-witness (ap-hom F f) â†’ split-epi-witness f
  reflects-split-episâ†گis-ff' (s' , خµ')
    = split-epi-witnessâ†گap-hom-fibre ً‌گ´ ً‌گµ
        (unap-equiv F-is-ff)
        خµ'
        (is-equiv.bwd F-is-ff s' , is-equiv.خµ F-is-ff s')

  reflects-isosâ†گis-ff'
    : is-iso (ap-hom F f) â†’ is-iso f
  reflects-isosâ†گis-ff' (r , s , خ· , خµ)
    = is-isoâ†گsplit-mono-witnessأ—split-epi-witness
        ( reflects-split-monosâ†گis-ff' (r , خ·)
        , reflects-split-episâ†گis-ff' (s , خµ))
}
}

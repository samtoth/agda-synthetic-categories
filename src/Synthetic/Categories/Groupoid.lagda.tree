is-leftâ†گis-groupoid = is-leftâ†گis-خ”آ¹-discrete âˆک is-خ”آ¹-discreteâ†گis-groupoid
}
%```
}

\subtree[fre-0CC5]{
\title{A type is #{\Delta^1}-discrete if morphisms give equalities}
\taxon{Lemma}
\author{fredrikbakke}
\date{2026-03-30}

\p{
Any type that has a comparison map #{\Hom_A(a,b) \to (a = b)} for all #{a} and #{b}
is [#{\Delta^1}-discrete](stt-00B6).
}

\proof{
There is a converse map to the precomposition map
#{A^{\point 0} : A^{\Delta^1} \hookrightarrow A^\b1},
given by the constant map. This map is judgmentally a section, so we must only show
it is a retraction.
Unfolding definitions and applying function extensionality, this boils down to
showing, for every #{h : \Delta^1 \to A}, that #{h(0) = h(t)} for all
#{t : \Delta^1}. Assuming a family of maps #{H_{a,b} : \Hom_A(a,b) \to (a = b)}, it
suffices to construct a restricted morphism
#{h\mid_t : \Hom_A(h(0), h(t))}, which we can: #{h\mid_t(j) \coloneqq h(j \land t)}.
}
}

%```agda
\agda{
is-خ”آ¹-discreteâ†گIdâ†گHom
  : {ً‌“¤ : Level} {A : Type ً‌“¤}
  â†’ ({a b : A} â†’ Hom A a b â†’ a ï¼‌ b)
  â†’ is-خ”آ¹-discrete A
is-خ”آ¹-discreteâ†گIdâ†گHom {A = A} homâ†’id
  = is-خ”آ¹-discreteâ†گis-left خ» _ â†’ precomp-i0-is-equiv where

    restrict : (h : خ”آ¹ â†’ A) (t : خ”آ¹) â†’ Hom A (h i0) (h t)
    restrict h t .Homلµˆ.hom j = h (j âˆ§ t)
    restrict h t .Homلµˆ.hom0 = ap h 0-init
    restrict h t .Homلµˆ.hom1 = ap h (âˆ§-comm âˆ™ 1-top)

    precomp-i0-is-equiv : is-equiv (precomp A (point i0))
    precomp-i0-is-equiv
      = is-equivâ†گqiso
          ( const A خ”آ¹ âˆک ev tt
          , (خ» h â†’ funextâ†’ خ» t â†’ homâ†’id (restrict h t))
          , ~refl)
}
%```
}

\subtree[fre-1337]{
\title{The Hom types of a Segal type are #{\Delta^1}-discrete}
\date{2026-03-30}
\author{fredrikbakke}
\taxon{Theorem}

\p{
If #{A} is a [Segal type](stt-00AI), then every Hom type #{\Hom_A(a,b)} is a
[#{\Delta^1}-discrete](stt-00B6). In fact, any type whose left and right homotopies
characterise equality have #{\Delta^1}-discrete Hom types.
}

\proof{
If left and right homotopies are extensional, then we can construct a map from
morphisms to equalities on the Hom types themselves. Given #{f, g : \Hom_A(a,b)} and
a morphism of morphisms #{\alpha : \Hom_{\Hom_A(a,b)}(f,g)}, viewed as a square
#{(i,j) \mapsto \alpha(i)(j)} that is constantly #{a} on #{j = 0} and constantly #{b}
on #{j = 1}, we apply \ref{fre-1338} to #{\alpha} as a morphism over #{\id_b}
to extract a diagonal #{\alpha_\Delta(i) \coloneqq \alpha(i)(i)} together with two
composition triangles:
\ul{
\li{The upper triangle #{(i,j) \mapsto \alpha(j)(i)} for #{i \leq j} fills
#{\mathrm{Hom}^2(\id_b, f, \alpha_\Delta)}, witnessing #{f \rhtpy \alpha_\Delta}.}
\li{The lower triangle #{(i,j) \mapsto \alpha(i)(j)} for #{i \leq j} fills
#{\mathrm{Hom}^2(g, \id_a, \alpha_\Delta)}, witnessing #{g \lhtpy \alpha_\Delta}.}
}
Hence #{\Hom_A(a,b)} is #{\Delta^1}-discrete.
}

%```agda
\agda{
Idâ†گHom-Hom
  : {ً‌“¤ : Level} {A : Type ً‌“¤} {a b : A}
  â†’ ({f g : Hom A a b} â†’ f ~â–µ g â†’ f ï¼‌ g)
  â†’ ({f g : Hom A a b} â†’ f â–µ~ g â†’ f ï¼‌ g)
  â†’ {f g : Hom A a b}
  â†’ Hom (Hom A a b) f g
  â†’ f ï¼‌ g
Idâ†گHom-Hom {b = b} leftâ†’id rightâ†’id {f} {g} خ±
  = rightâ†’id (Hom2â†گHom-over (idH b) f {g} خ±)
  âˆ™ sym (leftâ†’id (~â–µâ†گHom-over (idH b) f {g} خ±))

Hom-is-خ”آ¹-discreteâ†گhomotopies-are-torsorial
  : {ً‌“¤ : Level} {A : Type ً‌“¤} {a b : A}
  â†’ ((f : Hom A a b) â†’ is-singleton (خ£[ g âˆ¶ Hom A a b ] (f ~â–µ g)))
  â†’ ((f : Hom A a b) â†’ is-singleton (خ£[ g âˆ¶ Hom A a b ] (f â–µ~ g)))
  â†’ is-خ”آ¹-discrete (Hom A a b)
Hom-is-خ”آ¹-discreteâ†گhomotopies-are-torsorial {ً‌“¤} {A} {a} {b} left-tors right-tors
  = is-خ”آ¹-discreteâ†گIdâ†گHom (Idâ†گHom-Hom leftâ†’id rightâ†’id) where

  leftâ†’id : {f g : Hom A a b} â†’ f ~â–µ g â†’ f ï¼‌ g
  leftâ†’id {f} = fundamental-Idâپ»آ¹ (f ~â–µ_) (left-tors f) (خ» _ â†’ ~â–µâ†گï¼‌)

  rightâ†’id : {f g : Hom A a b} â†’ f â–µ~ g â†’ f ï¼‌ g
  rightâ†’id {f} = fundamental-Idâپ»آ¹ (f â–µ~_) (right-tors f) (خ» _ â†’ â–µ~â†گï¼‌)

Hom-is-خ”آ¹-discreteâ†گis-segal
  : {ً‌“¤ : Level} {A : Type ً‌“¤}
  â†’ is-segal A
  â†’ {a b : A} â†’ is-خ”آ¹-discrete (Hom A a b)
Hom-is-خ”آ¹-discreteâ†گis-segal ً‌گ´
  = Hom-is-خ”آ¹-discreteâ†گhomotopies-are-torsorial
      (~â–µ-is-torsorial ً‌گ´)
      (â–µ~-is-torsorial ً‌گ´)
}
%```
}

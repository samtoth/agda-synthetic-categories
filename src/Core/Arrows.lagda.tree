
\title{The category of maps of types}
\taxon{Module}
\import{stt-macros}

\agda{
{-# OPTIONS --lossy-unification #-}

module Core.Arrows where

open import Foundations.Prelude
open import UF

open import Ergonomics.Representation
open import Ergonomics.Marker
open import Ergonomics.Extensionality

open import Core.Slices
open import Core.CanonicalPushouts
}

\subtree[stt-0038]{
\taxon{Definition}
\title{Walking morphisms in #{\Type}}
\date{2025-04-18}
\author{samueltoth}
\contributor{fredrikbakke}

\p{
An \em{arrow} of types is the bundled data of a function of types. I.e., it is
the data consisting of two types #{A}, #{B}, and a function between them
#{f : A \to B}.
}

\agda{
record Arrow (𝓤 𝓥 : Level) : Type (lsuc 𝓤 ⊔ lsuc 𝓥) where
  constructor mk-arrow
  no-eta-equality
  field
    {dom} : Type 𝓤
    {cod} : Type 𝓥
    f : dom → cod
}
}

\subtree[stt-00EF]{
\taxon{Definition}
\date{2026-02-20}
\title{Dependent morphisms of arrows}

\p{
Given an arrow #{f : A \to B}, a \em{dependent arrow} over #{f} is a family of arrows
over its domain, #{g : (b : B) \to X(b) \to Y(b)}. Given such a dependent arrow, then a
\em{dependent morphism of arrows} is a pair of dependent functions
#{i : (b : B) \to Y(b)} and #{j : (a : A) \to X (f(a))} so that #{i \circ f \sim g \circ j}.
}

\agda{
module _
  {𝓤1 𝓤2 𝓤3 𝓤4 : Level}
  {A : Type 𝓤1}
  {B : Type 𝓤2}
  (f : A → B)
  {X : B → Type 𝓤3}
  {Y : B → Type 𝓤4}
  (g : (b : B) → X b → Y b)
  where

  record Arrow-Π : Type (𝓤1 ⊔ 𝓤2 ⊔ 𝓤3 ⊔ 𝓤4) where
    constructor mk-amap
    field
      top : (a : A) → X (f a)
      bot : (b : B) → Y b
      comm : precomp-Π Y f bot ~ postcomp-Π (λ a → g (f a)) top

  unquoteDecl Arrow-Π-repr≊ Arrow-Π-repr≃
    = make-record-repr Arrow-Π-repr≊ Arrow-Π-repr≃ (quote Arrow-Π)
}
}

\subtree[stt-003U]{
\taxon{Definition}
\title{Morphisms of arrows}

\p{
Given a pair of arrows, we define a morphism between them to be a commutative square,
that is, a pair of a maps and a homotopy witnessing that the square commutes.
}

\agda{
module _
  {𝓤 𝓥 𝓦 𝓛}
  {A : Type 𝓤} {B : Type 𝓥} (f : A → B)
  {C : Type 𝓦} {D : Type 𝓛} (f' : C → D)
  where

  Arrow-map : Type (𝓤 ⊔ 𝓥 ⊔ 𝓦 ⊔ 𝓛)
  Arrow-map = Arrow-Π f (λ _ → f')

  Arrow-map-repr≊ : Arrow-map ≊ _
  Arrow-map-repr≊ = Arrow-Π-repr≊ f (λ _ → f')

  Arrow-map-repr≃ : Arrow-map ≃ _
  Arrow-map-repr≃ = Arrow-Π-repr≃ f (λ _ → f')

module Arrow-map = Arrow-Π
}
}

\subtree[stt-00EG]{
\taxon{Theorem}
\date{2026-02-20}
\title{The type of dependent morphisms of arrows as a pullback}
\author{fredrikbakke}

\p{The type #{\Hom^{\mathrm{d}}(f,g)} is the pullback of #{g \circ {-}} and
#{{-} \circ f}.}

\agda{
module _
  {𝓤1 𝓤2 𝓤3 𝓤4 : Level}
  {A : Type 𝓤1}
  {B : Type 𝓤2}
  {f : A → B}
  {X : B → Type 𝓤3}
  {Y : B → Type 𝓤4}
  {g : (b : B) → X b → Y b}
  where

  Arrow-Π-cone
    : Cone (mk-cospan ((a : A) → Y (f a))
                      (precomp-Π Y f)
                      (postcomp-Π (λ a → g (f a))))
           (Arrow-Π f g)
  Arrow-Π-cone .Cone.i p = Arrow-Π.bot p
  Arrow-Π-cone .Cone.j p = Arrow-Π.top p
  Arrow-Π-cone .Cone.filler p = funext→ (Arrow-Π.comm p)

  Arrow-Π≃pullback-repr
    : Arrow-Π f g
    ≃ Pullback (precomp-Π Y f) (postcomp-Π (λ a → g (f a)))
  Arrow-Π≃pullback-repr
    = Arrow-Π f g
        ≃⟨ Arrow-Π-repr≃ f g ⟩
      Σ[ t ∶ ((a : A) → X (f a)) ]
      Σ[ b ∶ ((b : B) → Y b) ]
       (precomp-Π Y f b ~ postcomp-Π (λ a → g (f a)) t)
        ≃⟨ Σ-comm ⟩
      Σ[ b ∶ ((b : B) → Y b) ]
      Σ[ t ∶ ((a : A) → X (f a)) ]
       (precomp-Π Y f b ~ postcomp-Π (λ a → g (f a)) t)
        ≃⟨ Σ-ap-≃ (λ _ → Σ-ap-≃ λ _ → (funext≃ e⁻¹)) ⟩
      Pullback (precomp-Π Y f) (postcomp-Π (λ a → g (f a)))
        ≃∎

  Arrow-Π≃pullback-repr~gap
    : Arrow-Π≃pullback-repr ._≃_.fwd ~ gap Arrow-Π-cone
  Arrow-Π≃pullback-repr~gap = ~refl

  Arrow-Π-gap-is-equiv : is-equiv (gap Arrow-Π-cone)
  Arrow-Π-gap-is-equiv
    = homotopy-is-equiv (Arrow-Π≃pullback-repr~gap)
                        (Arrow-Π≃pullback-repr ._≃_.fwd-is-equiv)

  Arrow-Π≃pullback
    : Arrow-Π f g
    ≃ Pullback (precomp-Π Y f) (postcomp-Π (λ a → g (f a)))
  Arrow-Π≃pullback
    = mk≃ (gap Arrow-Π-cone) (Arrow-Π-gap-is-equiv)
}
}

\subtree[stt-004H]{
\taxon{Theorem}
\date{2025-05-17}
\title{The type of morphisms of arrows as a pullback}

\p{The type #{\Hom(f,g)} is the pullback of #{g \circ {-}} and #{{-} \circ f}.}

\agda{
module _ {𝓤 𝓥} {A : Type 𝓤} {B : Type 𝓥} {f : A → B}
         {𝓦 𝓛} {C : Type 𝓦} {D : Type 𝓛} {g : C → D} where

  Arrow-map≃pullback' : Arrow-map f g ≃ Pullback (_∘ f) (g ∘_)
  Arrow-map≃pullback' = Arrow-Π≃pullback {f = f} {g = λ _ → g}

  Arrow-map≃pullback : Arrow-map f g ≃ Pullback (g ∘_) (_∘ f)
  Arrow-map≃pullback = Arrow-map≃pullback' ∙≃ pullback-swap

  pullback←arrow' : Arrow-map f g → Pullback (_∘ f) (g ∘_)
  pullback←arrow' = Arrow-map≃pullback' ._≃_.fwd

  pullback←arrow : Arrow-map f g → Pullback (g ∘_) (_∘ f)
  pullback←arrow = Arrow-map≃pullback ._≃_.fwd
}
}

\subtree[stt-004I]{
\title{Characterising the paths of morphisms of arrows}
\taxon{Theorem}

\agda{
module _ {𝓤 𝓥} {A : Type 𝓤} {B : Type 𝓥} {f : A → B}
         {𝓦 𝓛} {C : Type 𝓦} {D : Type 𝓛} {f' : C → D} where

  Arrow-map-path : ∀ (G H : Arrow-map f f') → Type (𝓤 ⊔ 𝓥 ⊔ 𝓦 ⊔ 𝓛)
  Arrow-map-path (mk-amap t b H) (mk-amap t' b' H')
    = Σ[ p ∶ t ~ t' ] Σ[ q ∶ b ~ b' ]
      (H ~∙ (f' ◂ p) ~ q ▸ f ~∙ H')

  Arrow-map-path-refl : {G : Arrow-map f f'} → Arrow-map-path G G
  Arrow-map-path-refl = ~refl , ~refl , ~∙-reflr _

  Arrow-map-path-is-Rppred
    : ∀ (G : Arrow-map f f')
      → Reflexive-ppred _ G _
  Arrow-map-path-is-Rppred G = (Arrow-map-path G) , Arrow-map-path-refl

  Arrow-map-path←id : ∀ {G H : Arrow-map f f'} → (G ＝ H) → Arrow-map-path G H
  Arrow-map-path←id refl = Arrow-map-path-refl

  opaque
    Arrow-map-path≃ : ∀ (G H : Arrow-map f f') → (G ＝ H) ≃ Arrow-map-path G H
    Arrow-map-path≃ G@(mk-amap t b h) H
      = mk≃ Arrow-map-path←id
            (fundamental-Id
              (Arrow-map-path G)
              (is-single←equiv-to-single
                (Σ-ap-≃-fst (Arrow-map-repr≃ _ _ e⁻¹))
                (is-singleton-structure←parts (SingS-is-single t)
                  (t , ~refl)
                  (is-singleton-structure←parts (SingS-is-single b)
                    (b , ~refl)
                    (SingS-is-single λ a → h a ∙ refl))))
              (λ _ → Arrow-map-path←id) H)

    Arrow-map-path→
      : ∀ {G H : Arrow-map f f'} → Arrow-map-path G H
        → (G ＝ H)
    Arrow-map-path→ = _≃_.bwd (Arrow-map-path≃ _ _)

    Arrow-map-path→-refl
      : ∀ {G : Arrow-map f f'}
        → Arrow-map-path→ (Arrow-map-path-refl {G = G}) ＝ refl
    Arrow-map-path→-refl
      = unap-equiv (Arrow-map-path≃ _ _ ._≃_.fwd-is-equiv)
                   (is-equiv.ε (Arrow-map-path≃ _ _ ._≃_.fwd-is-equiv) _)
}
}

\subtree[stt-003X]{
\taxon{Theorem}
\title{Arrows and squares form a category}

\agda{
id-square
  : ∀ {𝓤 𝓥} {A : Type 𝓤} {B : Type 𝓥} {f : A → B}
    → Arrow-map f f
id-square = mk-amap id id ~refl

infix 30 id-square:_
id-square:_ : ∀ {𝓤 𝓥} {A : Type 𝓤} {B : Type 𝓥} (f : A → B) → Arrow-map f f
id-square: f = id-square

module _ {𝓤 𝓥} {A : Type 𝓤} {B : Type 𝓥} {f : A → B}
         {𝓤' 𝓥'} {A' : Type 𝓤'} {B' : Type 𝓥'} {f' : A' → B'}
         {𝓤'' 𝓥''} {A'' : Type 𝓤''} {B'' : Type 𝓥''} {f'' : A'' → B''} where

  paste-squares
    : Arrow-map f' f''
    → Arrow-map f f'
    → Arrow-map f f''
  paste-squares (mk-amap g' h' comm') (mk-amap g h comm)
    = mk-amap (g' ∘ g) (h' ∘ h) (h' ◂ comm ~∙ comm' ▸ g)
}
}

\subtree[stt-00LU]{
\title{Associativity and unit laws for pasting squares}
\taxon{Lemma}
\author{fredrikbakke}
\date{2026-04-05}

\agda{
paste-squares-assoc
  : {𝓤1 𝓥1 𝓤2 𝓥2 𝓤3 𝓥3 𝓤4 𝓥4 : Level}
    {A1 : Type 𝓤1} {B1 : Type 𝓥1} {f1 : A1 → B1}
    {A2 : Type 𝓤2} {B2 : Type 𝓥2} {f2 : A2 → B2}
    {A3 : Type 𝓤3} {B3 : Type 𝓥3} {f3 : A3 → B3}
    {A4 : Type 𝓤4} {B4 : Type 𝓥4} {f4 : A4 → B4}
  → (H : Arrow-map f3 f4)
  → (G : Arrow-map f2 f3)
  → (F : Arrow-map f1 f2)
  → Arrow-map-path
    (paste-squares H (paste-squares G F))
    (paste-squares (paste-squares H G) F)
paste-squares-assoc H G F .fst = ~refl
paste-squares-assoc H G F .snd .fst = ~refl
paste-squares-assoc H G F .snd .snd a
  = let
      p = Arrow-map.comm F a
      q = Arrow-map.comm G (Arrow-map.top F a)
      r = Arrow-map.comm H (Arrow-map.top G (Arrow-map.top F a))
    in ∙-reflr _
     ∙ ap (_∙ r) (ap-∙ (Arrow-map.bot H) (ap (Arrow-map.bot G) p) q)
     ∙ ∙-assoc
         (ap (Arrow-map.bot H) (ap (Arrow-map.bot G) p))
         (ap (Arrow-map.bot H) q)
         (r)
     ∙ ap
         (_∙ ap (Arrow-map.bot H) q ∙ r)
         (sym (ap-∘ (Arrow-map.bot H) (Arrow-map.bot G) p))

paste-squares-left-id
  : {𝓤1 𝓥1 𝓤2 𝓥2 : Level}
    {A1 : Type 𝓤1} {B1 : Type 𝓥1} {f : A1 → B1}
    {A2 : Type 𝓤2} {B2 : Type 𝓥2} {g : A2 → B2}
  → (F : Arrow-map f g)
  → Arrow-map-path (paste-squares (id-square: g) F) F
paste-squares-left-id F .fst = ~refl
paste-squares-left-id F .snd .fst = ~refl
paste-squares-left-id F .snd .snd a
  = ∙-reflr _
  ∙ ∙-reflr _
  ∙ ap-id (Arrow-map.comm F a)

paste-squares-right-id
  : {𝓤1 𝓥1 𝓤2 𝓥2 : Level}
    {A1 : Type 𝓤1} {B1 : Type 𝓥1} {f : A1 → B1}
    {A2 : Type 𝓤2} {B2 : Type 𝓥2} {g : A2 → B2}
  → (F : Arrow-map f g)
  → Arrow-map-path (paste-squares F (id-square: f)) F
paste-squares-right-id F .fst = ~refl
paste-squares-right-id F .snd .fst = ~refl
paste-squares-right-id F .snd .snd a = ∙-reflr _
}
}

\subtree[stt-003V]{
\taxon{Definition}
\title{Cartesian squares}

\p{Given a map of arrows #{f \to f'}, we can define a family of functions
from the fibre over #{f} to the fibre over #{f'}. If this map is a
fibrewise equivalence, then we say that the square is cartesian (or a pullback
square).
}

\agda{
module _ {𝓤 𝓥} {A : Type 𝓤} {B : Type 𝓥} {f : A → B}
         {𝓦 𝓛} {C : Type 𝓦} {D : Type 𝓛} {f' : C → D} where
  arrow-fibre
    : (gs : Arrow-map f f')
    → (b : B)
    → fibre f b → fibre f' (gs .Arrow-map.bot b)
  arrow-fibre (mk-amap g g' hom) b (a , p) = (g a , sym (hom a) ∙ ap g' p)

  is-cartesian : Arrow-map f f' → Type (𝓤 ⊔ 𝓥 ⊔ 𝓦 ⊔ 𝓛)
  is-cartesian a = is-fibrewise-equiv (arrow-fibre a)

  is-cartesian-is-prop
    : ∀ {F : Arrow-map f f'} → is-prop (is-cartesian F)
  is-cartesian-is-prop
    = Π-is-prop (λ a → is-equiv-is-prop)
}
}

\subtree[stt-003W]{
\taxon{Theorem}
\title{Horizontal composition of cartesian squares}

\agda{
module _ {𝓤 𝓥} {A : Type 𝓤} {B : Type 𝓥} {f : A → B}
         {𝓤' 𝓥'} {A' : Type 𝓤'} {B' : Type 𝓥'} {f' : A' → B'}
        {𝓤'' 𝓥''} {A'' : Type 𝓤''} {B'' : Type 𝓥''} {f'' : A'' → B''} where

  arrow-fibre-∘
    : ∀ (F : Arrow-map f' f'') (G : Arrow-map f f')
      → ∀ b
      → arrow-fibre (paste-squares F G) b
      ~ arrow-fibre F (Arrow-map.bot G b) ∘ arrow-fibre G b
  arrow-fibre-∘ F@(mk-amap f f' fcomm) G@(mk-amap g g' gcomm) b (a , p)
    = Σ-path→ (refl , lem) where
       lem : sym (ap f' (gcomm a) ∙ fcomm (g a)) ∙ ap (f' ∘ g') p ＝
              sym (fcomm (g a)) ∙ ap f' (sym (gcomm a) ∙ ap g' p)
       lem = ⌜ sym (ap f' (gcomm a) ∙ fcomm (g a)) ⌝ ∙ ap (f' ∘ g') p
               ＝⟨ ap! (∙-symsym (ap f' (gcomm a)) _) ⟩
             (sym (fcomm (g a)) ∙ ⌜ sym (ap f' (gcomm a)) ⌝) ∙ ap (f' ∘ g') p
               ＝⟨ ap! (sym (ap-sym f' _)) ⟩
             (sym (fcomm (g a)) ∙ ap f' (sym (gcomm a))) ∙ ap (f' ∘ g') p
               ＝⟨ ∙-assoc (sym (fcomm (g a))) _ _ ⟩
             sym (fcomm (g a)) ∙ ap f' (sym (gcomm a)) ∙ ⌜ ap (f' ∘ g') p ⌝
               ＝⟨ ap! (ap-∘ f' g' p) ⟩
             sym (fcomm (g a)) ∙ ⌜ ap f' (sym (gcomm a)) ∙ (ap f' (ap g' p)) ⌝
               ＝⟨ ap! (sym (ap-∙ f' (sym _) (ap g' p))) ⟩
             sym (fcomm (g a)) ∙ ap f' (sym (gcomm a) ∙ ap g' p) ∎

  compose-cartesian
    : ∀ {a : Arrow-map f' f''} {b : Arrow-map f f'}
      → (ae : is-cartesian a) (be : is-cartesian b)
      → is-cartesian (paste-squares a b)
  compose-cartesian {a} {b} ae be x
    = tr is-equiv (funext→ (arrow-fibre-∘ a b x ~⁻¹))
       (is-equiv-∘ {f = arrow-fibre a (b .Arrow-map.bot x)} {g = arrow-fibre b x}
         (ae (b .Arrow-map.bot x))
         (be x)) where
    module b = is-equiv (be x)
    module a = is-equiv (ae (b .Arrow-map.bot x))

    open Arrow-map

    II : (x : B) (fib : fibre f x) →
       sym (paste-squares a b .Arrow-map.comm (fib .fst)) ∙
         ap (paste-squares a b .Arrow-map.bot) (fib .snd)
        ＝
       (arrow-fibre a (b .Arrow-map.bot x) ∘ arrow-fibre b x)
         fib .snd
    II x (aa , p)
     = sym (paste-squares a b .comm aa) ∙ ap (paste-squares a b .bot) p
         ＝⟨⟩
       ⌜ sym (ap (a .bot) (b .comm aa) ∙ a .comm (b .top aa)) ⌝ ∙ ap (a .bot ∘ b .bot) p
         ＝⟨ ap! (∙-symsym (ap (a .bot) (b .comm aa)) _) ⟩
       (sym (a .comm (b .top aa)) ∙ sym (ap (a .bot) (b .comm aa))) ∙ ap (a .bot ∘ b .bot) p
         ＝⟨ ∙-assoc (sym (a .comm (b .top aa))) _ (ap (a .bot ∘ b .bot) p) ⟩
       sym (a .comm (b .top aa)) ∙ ⌜ sym (ap (a .bot) (b .comm aa)) ⌝ ∙ ap (a .bot ∘ b .bot) p
         ＝⟨ ap! (sym (ap-sym (a .bot) _)) ⟩
       sym (a .comm (b .top aa)) ∙ ap (a .bot) (sym (b .comm aa)) ∙ ⌜ ap (a .bot ∘ b .bot) p ⌝
         ＝⟨ ap! (ap-∘ _ _ _) ⟩
       sym (a .comm (b .top aa)) ∙ ⌜ ap (a .bot) (sym (b .comm aa)) ∙ ap (a .bot) (ap (b .bot) p) ⌝
         ＝⟨ ap! (sym (ap-∙ (a .bot) (sym (b .comm aa)) _)) ⟩
       sym (a .comm (b .top aa)) ∙ ap (a .bot) (sym (b .comm aa) ∙ ap (b .bot) p)
         ＝⟨⟩
       (arrow-fibre a (b .bot x) ∘ arrow-fibre b x) (aa , p) .snd ∎

  3-for-2-cartesian
    : ∀ {a : Arrow-map f' f''} {b : Arrow-map f f'}
        {H : Arrow-map f f''}
      → Arrow-map-path H (paste-squares a b)
      → is-cartesian H
      → is-cartesian a
      → is-cartesian b
  3-for-2-cartesian {a = F@(mk-amap f f' fcomm)} {b = G@(mk-amap g g' gcomm)}
                    K abcart bcart b
    = 3-for-2~ (arrow-fibre-∘ F G b)
               (bcart (g' b))
               (tr is-cartesian (Arrow-map-path→ K) abcart b)
}
}

\subtree[stt-002Z]{
\taxon{Theorem}
\title{Arrow morphisms are squares}

\p{We now have (at least) three things that can be called squares. We give functions
to convert from arrow-map squares, to either cones over cospans or cocones over spans.}

\agda{
Cocone←Arrow-map
  : ∀ {𝓤 𝓥} {A : Type 𝓤} {B : Type 𝓥} {f : A → B}
      {𝓦 𝓛} {C : Type 𝓦} {D : Type 𝓛} {f' : C → D}
    → Arrow-map f f' → Σ[ S ∶  Span 𝓤 𝓥 𝓦 ] Cocone S D
Cocone←Arrow-map {f = f} {f' = f'} (mk-amap g g' comm)
  = (mk-span _ f g) , mk-cocone g' f' comm

Arrow-map←Cocone
  : ∀ {𝓤 𝓥 𝓦 𝓜} {S : Span 𝓤 𝓥 𝓦} {D : Type 𝓜}
    → (C : Cocone S D)
    → Arrow-map (Span.left S) (Cocone.q C)
Arrow-map←Cocone {S = S} C = mk-amap S.right C.p C.filler where
  module S = Span S
  module C = Cocone C

Cone←Arrow-map
  : ∀ {𝓤 𝓥} {A : Type 𝓤} {B : Type 𝓥} {f : A → B}
      {𝓦 𝓛} {C : Type 𝓦} {D : Type 𝓛} {f' : C → D}
    → Arrow-map f f' → Σ[ S ∶ Cospan 𝓛 𝓥 𝓦 ] Cone S A
Cone←Arrow-map {f = f} {f' = f'} (mk-amap top bot comm)
  = (mk-cospan _ bot f') , mk-cone f top comm
}
}

\subtree[stt-004E]{
\taxon{Defition}

\title{(co)gap maps from squares}

\agda{
gap-map←square
  : ∀ {𝓤 𝓥} {A : Type 𝓤} {B : Type 𝓥} {f : A → B}
      {𝓦 𝓛} {C : Type 𝓦} {D : Type 𝓛} {f' : C → D}
    → (g : Arrow-map f f')
    → A → Pullback (g .Arrow-map.bot) f'
gap-map←square g = gap (Cone←Arrow-map g .snd)

cogap-map←square
  : ∀ {𝓤 𝓥} {A : Type 𝓤} {B : Type 𝓥} {f : A → B}
      {𝓦 𝓛} {C : Type 𝓦} {D : Type 𝓛} {f' : C → D}
    → (g : Arrow-map f f')
    → Pushout f (g .Arrow-map.top) → D
cogap-map←square g = cogap (Cocone←Arrow-map g .snd)
}
}

\subtree[stt-003C]{
\title{Pullback squares from cartesian arrow maps}
\taxon{Theorem}
\p{We show that a [cartesian](stt-003V) arrow map gives a pullback square.
 That is, a square is cartesian iff the corresponding cone is a pullback cone.}

\proof{
\p{Suppose we have a square:}

\quiver{
\begin{tikzcd}
	A && C \\
	\\
	B && D
	\arrow["g", from=1-1, to=1-3]
	\arrow["f"', from=1-1, to=3-1]
	\arrow["{f'}", from=1-3, to=3-3]
	\arrow["{g'}"', from=3-1, to=3-3]
\end{tikzcd}
}

\p{such that the map #{\fibre{g'}{a} \toeq \fibre{g}{f'(a)}} is
an equivalence. Then to verify it is a pullback, then we need
to show that the induced map #{A \to C \times_D B} is also an equivalence.}

\p{We can view both of these maps as living in a slice over #{C}, and a
by [[stt-003D]], a map in the slice is in equivalence iff if is an equivalence
on fibres.}

\quiver{
\begin{tikzcd}
	A && {B \times_D C} \\
	& B
	\arrow["{\textit{gap}}", from=1-1, to=1-3]
	\arrow["f"', from=1-1, to=2-2]
	\arrow["{\pi_1}", from=1-3, to=2-2]
\end{tikzcd}
}

\p{So we need to show #{\fibre{f}{c} \to \fibre{\pi_1}{c}} is an equivalence. The
fibre of the projection is equivalent to the fibre of #{g} at #{f(c)}, and so by the
[3-for-2](Foundations.3for2) property of equivalences we have that the square is a
pullback.}

\agda{
is-pullback←is-cartesian : ∀ {𝓤 𝓥 𝓦 𝓜}
  {A : Type 𝓤} {B : Type 𝓥} {f : A → B}
  {C : Type 𝓦} {D : Type 𝓜} {f' : C → D}
  → (g : Arrow-map f f')
  → is-cartesian g
  → let (s , c) = Cone←Arrow-map g
  in is-pullbackω s c
is-pullback←is-cartesian {A = A} {B} {f = f} {C} {D} {f' = f'} G pbsq
  = is-pullback←gap cone (is-equiv←on-fibres slice-map slice-equiv) where
  cospan = Cone←Arrow-map G .fst
  cone = Cone←Arrow-map G .snd

  g : A → C
  g = G .Arrow-map.top

  g' : B → D
  g' = G .Arrow-map.bot

  open pb

  slice-map : Slice-map f π₁
  slice-map .fst = gap cone
  slice-map .snd = ~refl

  lem : {a = b : B} →
      arrow-fibre G b ~
      fib-π₁ g' f' b ._≃_.fwd ∘ Slice-fibre (gap cone , ~refl) b
  lem (a , refl) = Σ-path→ (refl , (∙-reflr _))

  slice-equiv : is-fibrewise-equiv (Slice-fibre {q = π₁} (gap cone , ~refl))
  slice-equiv b = 3-for-2~ {f = fib-π₁ g' f' b ._≃_.fwd}
                           lem
                           (fib-π₁ g' f' b ._≃_.fwd-is-equiv)
                           (pbsq b)


is-cartesian←is-pullback : ∀ {𝓤 𝓥 𝓦 𝓜}
  {A : Type 𝓤} {B : Type 𝓥} {f : A → B}
  {C : Type 𝓦} {D : Type 𝓜} {f' : C → D}
  → (g : Arrow-map f f')
  → let (s , c) = Cone←Arrow-map g
  in is-pullbackω s c
  → is-cartesian g
is-cartesian←is-pullback {f = f} {f' = f'} g pb b
  = homotopy-is-equiv lem
                      (is-equiv-∘ (fib-π₁ bot f' b ._≃_.fwd-is-equiv)
                                  (fibre-equiv←is-equiv slice-map gap-is-equiv b)) where
  open Arrow-map g
  open pb

  cospan = Cone←Arrow-map g .fst
  cone = Cone←Arrow-map g .snd

  gap-is-equiv : is-equiv (gap (mk-cone f top comm))
  gap-is-equiv = gap-is-equiv←is-pullback _ pb

  slice-map : Slice-map f π₁
  slice-map .fst = gap cone
  slice-map .snd = ~refl

  lem : fib-π₁ bot f' b ._≃_.fwd ∘
      Slice-fibre slice-map b
      ~ arrow-fibre g b
  lem (a , refl) = Σ-path→ (refl , sym (∙-reflr _))

is-cartesian←gap-is-equiv
  : ∀ {𝓤 𝓥 𝓦 𝓜} {A : Type 𝓤} {B : Type 𝓥} {f : A → B}
      {C : Type 𝓦} {D : Type 𝓜} {g : C → D}
    → (F : Arrow-map f g)
    → is-equiv (gap (Cone←Arrow-map F .snd))
    → is-cartesian F
is-cartesian←gap-is-equiv F gap
  = is-cartesian←is-pullback F (is-pullback←gap _ gap)

gap-is-equiv←is-cartesian
  : ∀ {𝓤 𝓥 𝓦 𝓜} {A : Type 𝓤} {B : Type 𝓥} {f : A → B}
      {C : Type 𝓦} {D : Type 𝓜} {g : C → D}
    → (F : Arrow-map f g)
    → is-cartesian F
    → is-equiv (gap (Cone←Arrow-map F .snd))
gap-is-equiv←is-cartesian F c
  = gap-is-equiv←is-pullback _ (is-pullback←is-cartesian F c)
}
}
}

\subtree[stt-003P]{
\taxon{Definition}
\title{Squares from pre/post-composition}

\p{Given a square of the form:}

\quiver{
\begin{tikzcd}
	A && C \\
	\\
	B && D
	\arrow["g", from=1-1, to=1-3]
	\arrow["f"', from=1-1, to=3-1]
	\arrow["{f'}", from=1-3, to=3-3]
	\arrow["{g'}"', from=3-1, to=3-3]
\end{tikzcd}
}

\p{For all types #{Q}, we obtain squares:}

\quiver{
\begin{tikzcd}
	{Q \to A} && {Q \to C} \\
	\\
	{Q \to B} && {Q \to D}
	\arrow["{g \circ {-}}", from=1-1, to=1-3]
	\arrow["{f \circ {-}}"', from=1-1, to=3-1]
	\arrow["{f' \circ {-}}", from=1-3, to=3-3]
	\arrow["{g' \circ {-}}"', from=3-1, to=3-3]
\end{tikzcd}
}

\p{and}

\quiver{
\begin{tikzcd}
	{D \to Q} && {B \to Q} \\
	\\
	{C \to Q} && {A \to Q}
	\arrow["{{-} \circ g'}", from=1-1, to=1-3]
	\arrow["{{-} \circ f'}"', from=1-1, to=3-1]
	\arrow["{{-} \circ f'}", from=1-3, to=3-3]
	\arrow["{{-} \circ g}"', from=3-1, to=3-3]
\end{tikzcd}
}

\agda{
precomp-square
  : ∀ {𝓤 𝓥 𝓦 𝓜}
      {A : Type 𝓤} {B : Type 𝓥} {f : A → B}
      {C : Type 𝓦} {D : Type 𝓜} {f' : C → D}
      (g : Arrow-map f f')
    → ∀ {𝓛} (C : Type 𝓛) → Arrow-map (precomp C f') (precomp C f)
precomp-square (mk-amap top bot p) C
 = mk-amap (_∘ bot) (_∘ top) λ f → funext→ (f ◂ (p ~⁻¹))

postcomp-square
  : ∀ {𝓤 𝓥 𝓦 𝓜}
      {A : Type 𝓤} {B : Type 𝓥} {f : A → B}
      {C : Type 𝓦} {D : Type 𝓜} {f' : C → D}
      (g : Arrow-map f f')
    → ∀ {𝓛} (C : Type 𝓛) → Arrow-map (postcomp C f) (postcomp C f')
postcomp-square (mk-amap top bot p) C
  = mk-amap (top ∘_) (bot ∘_) λ f → funext→ (p ▸ f)
}
}

\remark{
\p{Precomposing squares gives the result of applying the functor
#{\Hom(Q,H)} to the square. It is a well known result that this functor preserves
pullback Likewise, postcomposition is given by #{\Hom({-},Q)}, and this functor turns
pushouts in to pullbacks.
}
}

\subtree[stt-003R]{
\title{Precomposition of cartesian squares}
\taxon{Theorem}

\p{Given a square of the following form:}

\quiver{
\begin{tikzcd}
	A && C \\
	\\
	B && D
	\arrow["g", from=1-1, to=1-3]
	\arrow["f"', from=1-1, to=3-1]
	\arrow["{f'}", from=1-3, to=3-3]
	\arrow["{g'}"', from=3-1, to=3-3]
\end{tikzcd}
}

\p{We show that the square obtained via precomposition
   is cartesian iff the original square is.
}

\proof{

\p{
First note that the type of cones on #{(Q \to B) \to (Q \to D) \leftarrow (Q \to C)}
is equivalent to the canonical pullback of #{B \to D \leftarrow C}. We can construct
the following triangle, and apply the three for two property for equivalences:
}

\quiver{
\begin{tikzcd}
	{(A \to Q)} &&& {(B \to Q)\times_{(C \to Q)} (D \to Q)} \\
	\\
	&& {\textrm{Cone}(f,g)}
	\arrow["{\textit{gap}}", from=1-1, to=1-4]
	\arrow["{\textrm{cone-map}}"', from=1-1, to=3-3]
	\arrow["\sim", from=1-4, to=3-3]
\end{tikzcd}
}

\agda{
postcomp-cone≃pb
  : ∀ {𝓤 𝓥 𝓦 𝓜}
      {A : Type 𝓤} {B : Type 𝓥}
      {C : Type 𝓦} {f : A → B}
      {g : C → B} {D : Type 𝓜}
    → Cone (mk-cospan B f g) D ≃ Pullback (postcomp D f) (postcomp D g)
postcomp-cone≃pb {f = f} {g = g} {D = D}
  =  Cone (mk-cospan _ f g) D
  ≃⟨ cone-repr≃ (mk-cospan _ f g) ⟩
      Σ[ f' ∶ (D → _) ] Σ[ g' ∶ (D → _) ]
          (postcomp D f f' ~ postcomp D g g')
  ≃⟨ Σ-ap-≃ (λ f' → Σ-ap-≃ (λ g' → funext≃ e⁻¹)) ⟩
      Pullback (postcomp D f) (postcomp D g)
  ≃∎


postcomp-cartesian
  : ∀ {𝓤 𝓥 𝓦 𝓜}
      {A : Type 𝓤} {B : Type 𝓥} {f : A → B}
      {C : Type 𝓦} {D : Type 𝓜} {f' : C → D}
      (g : Arrow-map f f')
    → is-cartesian g
    → ∀ {𝓛} {C : Type 𝓛}
    → is-cartesian
      (postcomp-square g C)
postcomp-cartesian {A = A} {f = f} {f' = f'} G@(mk-amap g g' H) eq {_} {C}
  = is-cartesian←is-pullback _
      (is-pullback←gap
        (cn∘ C)
        (3-for-2
          {f = _≃_.bwd (postcomp-cone≃pb)}
          {g = gap (cn∘ C)}
          (is-equiv⁻¹ (_≃_.fwd-is-equiv postcomp-cone≃pb))
          (homotopy-is-equiv map-hom
            (cn-is-pb .is-pullbackω.has-is-pb C)))) where
  cs : Cospan _ _ _
  cs = Cone←Arrow-map G .fst

  cn : Cone cs _
  cn = Cone←Arrow-map G .snd

  cs∘ : ∀ {𝓠} (Q : Type 𝓠) → Cospan _ _ _
  cs∘ {𝓠} Q = Cone←Arrow-map (postcomp-square G Q) .fst

  cn∘ : ∀ {𝓠} (Q : Type 𝓠) → Cone (cs∘ Q) _
  cn∘ {𝓠} Q = Cone←Arrow-map (postcomp-square G Q) .snd

  cn-is-pb : is-pullbackω cs cn
  cn-is-pb = is-pullback←is-cartesian G eq

  map-hom : cone-map cs cn ~ (_≃_.bwd postcomp-cone≃pb ∘ gap (cn∘ C))
  map-hom x = ap (mk-cone (f ∘ x) (g ∘ x)) (sym funext-redex)

  map : ∀ {𝓠} {Q : Type 𝓠} → (Q → A) → Cone cs Q
  map {_} {Q} = _≃_.bwd postcomp-cone≃pb ∘ gap (cn∘ Q)
}
}
}

\agda{
transpose-square
  : ∀ {𝓤 𝓥 𝓦 𝓜} {A : Type 𝓤} {B : Type 𝓥}
      {C : Type 𝓦} {D : Type 𝓜}
      {f : A → B} {g : C → D}
    → (F : Arrow-map f g)
    → Arrow-map (F .Arrow-map.top) (F .Arrow-map.bot)
transpose-square {f = f} {g = g} F
  = mk-amap f g (F .Arrow-map.comm ~⁻¹)

transpose-square-involution
  : ∀ {𝓤 𝓥 𝓦 𝓜} {A : Type 𝓤} {B : Type 𝓥}
      {C : Type 𝓦} {D : Type 𝓜}
      {f : A → B} {g : C → D}
    → (F : Arrow-map f g)
    → transpose-square (transpose-square F) ＝ F
transpose-square-involution F@(mk-amap top bot comm)
  = Arrow-map-path→ (~refl , ~refl , λ a → ∙-reflr _ ∙ sym-sym)

transpose-is-cartesian
  : ∀ {𝓤 𝓥 𝓦 𝓜} {A : Type 𝓤} {B : Type 𝓥}
      {C : Type 𝓦} {D : Type 𝓜}
      {f : A → B} {g : C → D}
      (F : Arrow-map f g)
    → is-cartesian F
    → is-cartesian (transpose-square F)
transpose-is-cartesian {f = f} {g} F@(mk-amap top bot comm) fcart
  = is-cartesian←gap-is-equiv _
        (is-equiv-∘ (pullback-swap ._≃_.fwd-is-equiv)
                    (gap-is-equiv←is-pullback _
                      (is-pullback←is-cartesian _ fcart)))

untranspose-is-cartesian
  : ∀ {𝓤 𝓥 𝓦 𝓜} {A : Type 𝓤} {B : Type 𝓥}
      {C : Type 𝓦} {D : Type 𝓜}
      {f : A → B} {g : C → D}
      (F : Arrow-map f g)
    → is-cartesian (transpose-square F)
    → is-cartesian F
untranspose-is-cartesian F
  = tr is-cartesian (transpose-square-involution F)
  ∘ transpose-is-cartesian (transpose-square F)
}

\subtree[stt-00BX]{
\title{The fibre of maps as a cartesian square}
\taxon{Example}

\agda{
fibre-square
  : ∀ {𝓤 𝓥} {A : Type 𝓤} {B : Type 𝓥} (f : A → B) b
    → Arrow-map (!: fibre f b) f
fibre-square f b .Arrow-map.top = fst
fibre-square f b .Arrow-map.bot = point b
fibre-square f b .Arrow-map.comm (x , p) = sym p

fibre-square-is-cartesian
  : ∀ {𝓤 𝓥} {A : Type 𝓤} {B : Type 𝓥} (f : A → B) b
    → is-cartesian (fibre-square f b)
fibre-square-is-cartesian f b = is-cartesian←gap-is-equiv _ eq where
  map : fibre f b → Pullback (point b) f
  map (x , p) = (tt , x , sym p)

  eq : is-equiv map
  eq = is-equiv←qinv ((λ (_ , x , p) → (x , sym p))
                     , (λ where (_ , refl) → refl)
                     , λ where (_ , _ , refl) → refl)
}
}

\subtree[stt-00BR]{
\title{Total squares}
\taxon{Construction}

\p{Given a family of squares, we can define the total square by taking the
sum types and total maps between them.}

\agda{
total-square
  : ∀ {𝓘 𝓤 𝓥 𝓦 𝓜} {I : Type 𝓘}
      {A : I → Type 𝓤} {B : I → Type 𝓥} {f : (i : I) → A i → B i}
      {C : I → Type 𝓦} {D : I → Type 𝓜} {g : (i : I) → C i → D i}
    → (F : (i : I) → Arrow-map (f i) (g i))
    → Arrow-map (total-map f) (total-map g)
total-square F .Arrow-map.top = total-map (Arrow-map.top ∘ F)
total-square F .Arrow-map.bot = total-map (Arrow-map.bot ∘ F)
total-square F .Arrow-map.comm (i , a)
  = Σ-path→ (refl , Arrow-map.comm (F i) a)
}
}

\subtree[stt-00BY]{
\title{Dependent precomposition square}
\taxon{Construction}

\p{Given a family of squares #{F_i : f_i \to g_i}, we can form the product square
#{\Pi_i F_i : \Pi_i f_i \to \Pi_i g_i}}

\agda{
Π-square
  : ∀ {𝓘 𝓤 𝓥 𝓦 𝓜} {I : Type 𝓘}
      {A : I → Type 𝓤} {B : I → Type 𝓥} {f : (i : I) → A i → B i}
      {C : I → Type 𝓦} {D : I → Type 𝓜} {g : (i : I) → C i → D i}
    → (F : (i : I) → Arrow-map (f i) (g i))
    → Arrow-map (postcomp-Π f) (postcomp-Π g)
Π-square F .Arrow-map.top h i = Arrow-map.top (F i) (h i)
Π-square F .Arrow-map.bot h i = Arrow-map.bot (F i) (h i)
Π-square F .Arrow-map.comm h  = funext→ (λ a → Arrow-map.comm (F a) (h a))
}

\p{#{\Pi_i F_i} is cartesian iff each square #{F_i} is.}

\proof{

\p{We use 3-for-2 in the red triangle of the following diagram:}

\quiver{
\begin{tikzcd}[cramped]
	& {\Pi_i(B_i\times_{D_i}C_i)} \\
	{\Pi_i A_i} &&& {\Pi_iC_i} \\
	& {\Pi_iB_i\times_{\Pi_i D_i}\Pi_i c_i} \\
	\\
	{\Pi_iB_i} &&& {\Pi_iD_i}
	\arrow["\sim"{pos=0.3}, color={rgb,255:red,214;green,92;blue,92}, from=1-2, to=3-2]
	\arrow["{\Pi_i(\textrm{gap})}"{pos=0.3}, color={rgb,255:red,214;green,92;blue,92}, from=2-1, to=1-2]
	\arrow[from=2-1, to=2-4]
	\arrow[color={rgb,255:red,214;green,92;blue,92}, from=2-1, to=3-2]
	\arrow[from=2-1, to=5-1]
	\arrow[from=2-4, to=5-4]
	\arrow[from=3-2, to=2-4]
	\arrow[from=3-2, to=5-1]
	\arrow["\lrcorner"{anchor=center, pos=0.125}, draw=none, from=3-2, to=5-4]
	\arrow[from=5-1, to=5-4]
\end{tikzcd}
}
}

\agda{
opaque
  Π-square-is-cartesian
    : ∀ {𝓘 𝓤 𝓥 𝓦 𝓜} {I : Type 𝓘}
        {A : I → Type 𝓤} {B : I → Type 𝓥} {f : (i : I) → A i → B i}
        {C : I → Type 𝓦} {D : I → Type 𝓜} {g : (i : I) → C i → D i}
      → (F : (i : I) → Arrow-map (f i) (g i))
      → (∀ i → is-cartesian (F i))
      → is-cartesian (Π-square F)
  Π-square-is-cartesian {I = I} {g = g} F cart
    = is-cartesian←gap-is-equiv _ eq where
    curry-pb
      : Pullback (Arrow-map.bot (Π-square F)) (postcomp-Π g)
      → Π I (λ z → Pullback (Arrow-map.bot (F z)) (g z))
    curry-pb (f , g , H) i = (f i , g i , happly H i)

    curry-pb-qinv : quasi-inv curry-pb
    curry-pb-qinv .fst f = (pb.π₁ ∘ f , pb.π₂ ∘ f , funext→ (pb.filler ∘ f))
    curry-pb-qinv .snd .fst (f , g , p)
      = pullback-path→ (refl , refl , sym (funext.η p) ∙ sym (∙-reflr _))
    curry-pb-qinv .snd .snd f
      = funext→ λ i → pullback-path→
          (refl , refl , ∙-refll _ ∙ sym (happly funext-redex i) ∙ sym (∙-reflr _))

    htpy : postcomp-Π (λ i → gap-map←square (F i)) ~ curry-pb ∘ gap-map←square (Π-square F)
    htpy a = funext→ λ i → pullback-path→
      (refl , refl , ∙-refll _ ∙ happly funext-redex i ∙ sym (∙-reflr _))

    eq : is-equiv (gap (Cone←Arrow-map (Π-square F) .snd))
    eq = (3-for-2~
            {f = curry-pb}
            {g = gap-map←square (Π-square F)}
            {k = postcomp-Π (λ i → gap-map←square (F i))}
            (htpy)
            (is-equiv←qinv curry-pb-qinv)
            (postcomp-Π-equiv
              (λ {i} → gap-is-equiv←is-pullback _
                (is-pullback←is-cartesian _ (cart i)))))
}
}

\subtree[stt-00JM]{
\title{Maps between equivalences are cartesian}
\taxon{Lemma}

\agda{
is-cartesian←dom+cod-is-equiv
  : ∀ {𝓤 𝓥 𝓦 𝓜} {X : Type 𝓤} {Y : Type 𝓥} {A : Type 𝓦} {B : Type 𝓜}
      {f : X → Y} {g : A → B}
    → (F : Arrow-map f g)
    → is-equiv f → is-equiv g
    → is-cartesian F
is-cartesian←dom+cod-is-equiv F feq geq a
  = is-equiv←single-to-prop
      (has-singleton-fibres←is-equiv feq a)
      (is-prop←is-single (has-singleton-fibres←is-equiv geq _))
      _
}
}

\subtree[stt-00K7]{
\title{Paths in maps of families}
\taxon{Lemma}

\agda{
opaque
  Fam-map-homotopy-is-torsorial
    : ∀ {𝓤 𝓥 𝓦 𝓜} {F@(A , X) : Fam 𝓤 𝓥} {G@(B , Y) : Fam 𝓦 𝓜 }
      → ∀ (a : Fam-map F G)
      → is-singleton (Σ _ (Fam-map-homotopy {F = F} {G} a))
  Fam-map-homotopy-is-torsorial a
    = is-singleton-structure←parts
        (SingS-is-single (a .fst))
        (_ , ~refl)
        (is-single←equiv-to-single
          (Σ-Π-swap≃ _ _)
          (Π-is-single (λ x → SingS-is-single (a .snd x))))

instance
  Fam-map-IdS
    : ∀ {𝓤 𝓥 𝓦 𝓜} {F : Fam 𝓤 𝓥} {G : Fam 𝓦 𝓜}
      → Identity-system (Fam-map F G) (𝓤 ⊔ 𝓥 ⊔ 𝓦 ⊔ 𝓜)
  Fam-map-IdS .Identity-system.IdS = Fam-map-homotopy
  Fam-map-IdS .Identity-system.IdS←Id refl = Fam-map-refl~ _
  Fam-map-IdS .Identity-system.has-is-ids a
    = fundamental-Id _ (Fam-map-homotopy-is-torsorial a) _
}
}

\subtree[stt-00KQ]{
\title{Straightening (cartesian) arrow maps}
\taxon{Lemma}

\p{We show that there is an equivalence between maps of arrows
and maps of families. We also show that an arrow map is cartesian
iff the corresponding map of families is cartesian.}

\agda{
fam-map←arrow-map
  : ∀ {𝓤 𝓥 𝓦 𝓜} {A : Type 𝓤} {B : Type 𝓥}
      {f : A → B} {X : Type 𝓦} {Y : Type 𝓜} {g : X → Y}
    → Arrow-map f g → Fam-map (fibre-fam f) (fibre-fam g)
fam-map←arrow-map F = (F .Arrow-map.bot , arrow-fibre F)

arrow-map←fam-map
  : ∀ {𝓤 𝓥 𝓦 𝓜} {A : Type 𝓤} {B : Type 𝓥}
      {f : A → B} {X : Type 𝓦} {Y : Type 𝓜} {g : X → Y}
    → Fam-map (fibre-fam f) (fibre-fam g)
    → Arrow-map f g
arrow-map←fam-map {f = f} {g = g} (b , t)
  = mk-amap (λ a → t (f a) (a , refl) .fst) b
            (λ a → sym (t (f a) (a , refl) .snd))

fam-map←arrow-map-is-equiv
  : ∀ {𝓤 𝓥 𝓦 𝓜} {A : Type 𝓤} {B : Type 𝓥}
      {f : A → B} {X : Type 𝓦} {Y : Type 𝓜} {g : X → Y}
    → is-equiv (fam-map←arrow-map {f = f} {g = g})
fam-map←arrow-map-is-equiv
  = is-equiv←qinv
      ( arrow-map←fam-map
      , (λ x → Arrow-map-path→ (~refl , ~refl ,
                               (   ~∙-reflr _
                                ~∙ ap sym ∘ ~∙-reflr _
                                ~∙ λ _ → sym-sym)))
      , section-fam-arr) where
  section-fam-arr
    : ∀ {𝓤 𝓥 𝓦 𝓜} {A : Type 𝓤} {B : Type 𝓥}
        {f : A → B} {X : Type 𝓦} {Y : Type 𝓜} {g : X → Y}
      → fam-map←arrow-map ∘ arrow-map←fam-map {f = f} {g = g} ~ id
  section-fam-arr {f = f} {g = g} (b , t)
    = Σ-path→ (refl ,
        (funext→ (λ a → funext→
          (λ where (x , refl) → Σ-path→ (refl , (∙-reflr _ ∙ sym-sym))))))

Cart-fam-map←cart-arrow-map
  : ∀ {𝓤 𝓥 𝓦 𝓜} {A : Type 𝓤} {B : Type 𝓥}
      {f : A → B} {X : Type 𝓦} {Y : Type 𝓜} {g : X → Y}
    → Σ (Arrow-map f g) is-cartesian
    → Cart-fam-map (fibre-fam f) (fibre-fam g)
Cart-fam-map←cart-arrow-map
  = Cart-fam-map←is-cartesian ∘ map-Σ fam-map←arrow-map λ _ → id

Cart-fam-map≃cart-arrow-map
  : ∀ {𝓤 𝓥 𝓦 𝓜} {A : Type 𝓤} {B : Type 𝓥}
      {f : A → B} {X : Type 𝓦} {Y : Type 𝓜} {g : X → Y}
    → Σ (Arrow-map f g) is-cartesian
    ≃ Cart-fam-map (fibre-fam f) (fibre-fam g)
Cart-fam-map≃cart-arrow-map = mk≃ Cart-fam-map←cart-arrow-map
  (is-equiv-∘
    Cart-fam-map←is-cartesian-is-equiv
    (map-Σ-is-equiv
      fam-map←arrow-map-is-equiv
      λ _ → id-is-equiv))
}
}

\subtree[stt-003S]{
\taxon{Theorem}
\title{Replacement by fibres}

\p{Given a map #{p : E \to B}, the type #{\Sigma_{(b:B)} \fibre{p}{b}}
is equivalent to the type #{E}. }

% ```agda
\agda{
totalвЖРtotal-fibre : вИА {рЭУ§} {B : Type рЭУ§}
                     {рЭУ•} {A : Type рЭУ•} (p : A вЖТ B)
                   вЖТ total-fibre p вЖТ A
totalвЖРtotal-fibre p (_ , a , _) = a

refl-fibre : вИА {рЭУ§} {B : Type рЭУ§}
               {рЭУ•} {A : Type рЭУ•} (p : A вЖТ B)
               вЖТ A вЖТ total-fibre  p
refl-fibre p a = (p a , a , refl)

totalвЙГtotal-fibre : вИА {рЭУ§} {B : Type рЭУ§}
                     {рЭУ•} {A : Type рЭУ•} (p : A вЖТ B)
                   вЖТ total-fibre p вЙГ A
totalвЙГtotal-fibre {A = A} p
 = mkвЙГ (totalвЖРtotal-fibre p) (is-equivвЖРqiso f-qiso) where
  f-qiso : quasi-iso (totalвЖРtotal-fibre p)
  f-qiso .fst = refl-fibre p
  f-qiso .snd .fst (_ , a , refl) = refl
  f-qiso .snd .snd a = refl
}
% ```
}

\subtree[stt-003Q]{
\title{Straightening}
\taxon{Theroem}
\date{2025-08-06}

\p{Under the assumption of univalence, given a base type #{B}, we can
define an equivalence between types \em{over} #{B} - #{\Sigma_{E : \UU} (E
\to B)} and type families #{B \to \UU}. The former type is said to be
the \em{unstraightened} version of the later - and
visa-versa. Sometimes, we also call the unstraightened perspective to
be called \em{fibred} and the staightened version \em{indexed}.}

%```agda
\agda{
Bundle : вИА {рЭУ§} вЖТ Type рЭУ§ вЖТ (рЭУ• : Level) вЖТ Type (рЭУ§ вКФ lsuc рЭУ•)
Bundle {рЭУ§} B рЭУ• = ќ£[ E вИґ Type рЭУ• ] (E вЖТ B)

straighten : вИА {рЭУ§ рЭУ• B} вЖТ Bundle {рЭУ§} B рЭУ• вЖТ B вЖТ Type (рЭУ§ вКФ рЭУ•)
straighten (E , p) = fibre p

unstraighten : вИА {рЭУ§ рЭУ• B} вЖТ (B вЖТ Type рЭУ•) вЖТ Bundle {рЭУ§} B (рЭУ§ вКФ рЭУ•)
unstraighten {B} P = (ќ£ _ P , fst)

Bundle-equiv
  : вИА {рЭУ§ рЭУ• рЭУ¶} {B : Type рЭУ§} (E : Bundle B рЭУ•) (E' : Bundle B рЭУ¶)
    вЖТ Type (рЭУ§ вКФ рЭУ• вКФ рЭУ¶)
Bundle-equiv (E , ѕА) (E' , ѕА') = ќ£[ e вИґ E вЙГ E' ] (ѕА' вИШ e ._вЙГ_.fwd ~ ѕА)

Bundle-idequiv
  : вИА {рЭУ§ рЭУ•} {B : Type рЭУ§} вЖТ {E : Bundle B рЭУ•}
    вЖТ Bundle-equiv E E
Bundle-idequiv = (idequiv , ~refl)

Bundle-equivвЖРId
  : вИА {рЭУ§ рЭУ•} {B : Type рЭУ§} вЖТ {E E' : Bundle B рЭУ•}
    вЖТ E пЉЭ E' вЖТ Bundle-equiv E E'
Bundle-equivвЖРId refl = Bundle-idequiv

unstraighten-straighten-bundle-equiv
  : вИА {рЭУ§ рЭУ•} {B : Type рЭУ§} (e : Bundle B рЭУ•)
    вЖТ Bundle-equiv (unstraighten (straighten e)) e
unstraighten-straighten-bundle-equiv (E , ѕА)
  = (totalвЙГtotal-fibre ѕА , ќї (a , b , p) вЖТ p)

module WithUA {рЭУ§} (UU : is-univalent рЭУ§)(FE : FunExt-global) where
  open WithLocalUnivalence UU
  open WithFunExt-global FE

  Bundle-equiv-is-torsorial
    : вИА {B : Type рЭУ§} вЖТ (E : Bundle B рЭУ§)
      вЖТ is-singleton (ќ£ _ (Bundle-equiv E))
  Bundle-equiv-is-torsorial (E , ѕА)
    = is-singleton-structureвЖРparts
        (equiv-is-torsorial E)
        (_ , idequiv)
        (homotopy-is-torsorial' ѕА)

  Bundle-equivвЖРId-is-equiv
    : вИА {B : Type рЭУ§} вЖТ {E E' : Bundle B рЭУ§}
      вЖТ is-equiv (Bundle-equivвЖРId {E = E}{E'})
  Bundle-equivвЖРId-is-equiv
    = fundamental-Id _ (Bundle-equiv-is-torsorial _) (ќї _ вЖТ Bundle-equivвЖРId) _

  Bundle-ua
    : вИА {B : Type рЭУ§} вЖТ {E E' : Bundle B рЭУ§}
      вЖТ Bundle-equiv E E' вЖТ E пЉЭ E'
  Bundle-ua = is-equiv.bwd Bundle-equivвЖРId-is-equiv

  straighten-qiso : вИА {B} вЖТ quasi-iso (straighten {рЭУ§}{рЭУ§}{B})
  straighten-qiso .fst = unstraighten {рЭУ§}{рЭУ§}
  straighten-qiso .snd .snd P
    = funextвЖТ (ќї b вЖТ ua (fibre-straighten P b))
  straighten-qiso .snd .fst E
    = Bundle-ua (unstraighten-straighten-bundle-equiv E)

  straighten-is-equiv : вИА {B} вЖТ is-equiv (straighten {рЭУ§}{рЭУ§}{B})
  straighten-is-equiv = is-equivвЖРqiso straighten-qiso

  straightenвЙГ : вИА {B} вЖТ Bundle B рЭУ§ вЙГ (B вЖТ Type рЭУ§)
  straightenвЙГ = mkвЙГ _ straighten-is-equiv
}
%```
}

\subtree[fre-2D88]{
\title{Essential surjections}
\taxon{Definition}
\author{fredrikbakke}
\date{2026-05-01}

\p{
A map #{f : A \to B} is \em{essentially surjective} if each of its
[essential fibres](fre-0D88) is inhabited.
}

\agda{
is-ess-surjective
  : {𝓤 𝓥 : Level} {A : Type 𝓤} {B : Type 𝓥} → (A → B) → Type (𝓘 ⊔ 𝓤 ⊔ 𝓥)
is-ess-surjective {B = B} f = (b : B) → ║ essfibre f b ║
}
}

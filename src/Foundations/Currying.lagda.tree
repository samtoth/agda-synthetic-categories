\title{Currying and uncurrying functions gives an equivalence}
\taxon{Module}
\author{samueltoth}
\date{2025-03-12}


\import{stt-macros}


\agda{
module Foundations.Currying where

open import Foundations.Universes
open import Foundations.Sigma
open import Foundations.Equivalences
open import Foundations.QuasiEquivalences
open import Foundations.FunctionInverses
open import Foundations.Identity
open import Foundations.Functions
open import Foundations.FibrewiseEquivalences
open import Foundations.Homotopy
}

\agda{
module _ {ūĚď§ ūĚď• ūĚď¶} {A : Type ūĚď§} {B : A ‚Üí Type ūĚď•} {C : (a : A) ‚Üí B a ‚Üí Type ūĚď¶} where
  curry : ((a : ő£[ x ‚ą∂ A ] B x) ‚Üí C (a .fst) (a .snd)) ‚Üí ((x : A) (y : B x) ‚Üí C x y)
  curry f a b = f (a , b)

  uncurry :  ((x : A) (y : B x) ‚Üí C x y) ‚Üí ((a : ő£[ x ‚ą∂ A ] B x) ‚Üí C (a .fst) (a .snd))
  uncurry f (a , b) = f a b

  curry-qinv : quasi-inv curry
  curry-qinv .fst = uncurry
  curry-qinv .snd .fst a = refl
  curry-qinv .snd .snd a = refl

  curry-is-equiv : is-equiv curry
  curry-is-equiv = is-equiv‚Üźqinv curry-qinv

  curry‚ČÉ : ((a : ő£[ x ‚ą∂ A ] B x) ‚Üí C (a .fst) (a .snd)) ‚ČÉ ((x : A) (y : B x) ‚Üí C x y)
  curry‚ČÉ = mk‚ČÉ curry curry-is-equiv

  uncurry-qinv : quasi-inv uncurry
  uncurry-qinv .fst = curry
  uncurry-qinv .snd .fst a = refl
  uncurry-qinv .snd .snd a = refl

  uncurry-is-equiv : is-equiv uncurry
  uncurry-is-equiv = is-equiv‚Üźqinv uncurry-qinv

  uncurry‚ČÉ : ((x : A) (y : B x) ‚Üí C x y) ‚ČÉ ((a : ő£[ x ‚ą∂ A ] B x) ‚Üí C (a .fst) (a .snd))
  uncurry‚ČÉ = mk‚ČÉ uncurry uncurry-is-equiv
}

\agda{
module _ {ūĚď§ ūĚď• ūĚď¶} {A : Type ūĚď§} {B : Type ūĚď•} {C : A ‚Üí B ‚Üí Type ūĚď¶} where
  flip : ((a : A) (b : B) ‚Üí C a b) ‚Üí ((b : B) (a : A) ‚Üí C a b)
  flip f b a = f a b

  flip-qinv : quasi-inv flip
  flip-qinv .fst f a b = f b a
  flip-qinv .snd .fst _ = refl
  flip-qinv .snd .snd _ = refl

  flip-is-equiv : is-equiv flip
  flip-is-equiv = is-equiv‚Üźqinv flip-qinv

  flip‚ČÉ : ((a : A) (b : B) ‚Üí C a b) ‚ČÉ ((b : B) (a : A) ‚Üí C a b)
  flip‚ČÉ = mk‚ČÉ flip flip-is-equiv
}

\subtree[tot-5IUA]{
\taxon{Lemma}
\title{Implicit and explicit functions are equivalent}

\p{There is a natural equivalence between implicit function types
  and explicit function types}

\agda{
ő†-implicit‚ČÉ
  : {ūĚď§ ūĚď• : Level} {A : Type ūĚď§} {B : A ‚Üí Type ūĚď•}
  ‚Üí ő† A B ‚ČÉ ({a : A} ‚Üí B a)
ő†-implicit‚ČÉ ._‚ČÉ_.fwd f {a} = f a
ő†-implicit‚ČÉ ._‚ČÉ_.fwd-is-equiv .is-equiv.qinv .fst f a = f {a}
ő†-implicit‚ČÉ ._‚ČÉ_.fwd-is-equiv .is-equiv.qinv .snd .fst = ~refl
ő†-implicit‚ČÉ ._‚ČÉ_.fwd-is-equiv .is-equiv.qinv .snd .snd = ~refl
ő†-implicit‚ČÉ ._‚ČÉ_.fwd-is-equiv .is-equiv.coherent = ~refl
}
}

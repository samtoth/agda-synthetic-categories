
\title{The category of maps of types}
\taxon{Module}
\import{stt-macros}

\agda{
{-# OPTIONS --lossy-unification #-}

module Core.Arrows where

open import Foundations.Prelude
open import Axioms.UF

open import Ergonomics.Representation
open import Ergonomics.Marker
open import Ergonomics.Extensionality

open import Core.CanonicalPushouts
}

\subtree[stt-0038]{
\taxon{Definition}
\title{Walking morphisms in #{\Type}}
\date{2025-04-18}
\author{samueltoth}
\contributor{fredrikbakke}

\p{
An \em{arrow} of types is the bundled data of a function of types. I.e., it is
the data consisting of two types #{A}, #{B}, and a function between them
#{f : A \to B}.
}

\agda{
record Arrow (рқ“Ө рқ“Ҙ : Level) : Type (lsuc рқ“Ө вҠ” lsuc рқ“Ҙ) where
  constructor mk-arrow
  no-eta-equality
  field
    {dom} : Type рқ“Ө
    {cod} : Type рқ“Ҙ
    f : dom вҶ’ cod
}
}

\subtree[stt-00EF]{
\taxon{Definition}
\date{2026-02-20}
\title{Dependent morphisms of arrows}

\p{
Given an arrow #{f : A \to B}, a \em{dependent arrow} over #{f} is a family of arrows
over its domain, #{g : (b : B) \to X(b) \to Y(b)}. Given such a dependent arrow, then a
\em{dependent morphism of arrows} is a pair of dependent functions
#{i : (b : B) \to Y(b)} and #{j : (a : A) \to X (f(a))} so that #{i \circ f \sim g \circ j}.
}

\agda{
module _
  {рқ“Ө1 рқ“Ө2 рқ“Ө3 рқ“Ө4 : Level}
  {A : Type рқ“Ө1}
  {B : Type рқ“Ө2}
  (f : A вҶ’ B)
  {X : B вҶ’ Type рқ“Ө3}
  {Y : B вҶ’ Type рқ“Ө4}
  (g : (b : B) вҶ’ X b вҶ’ Y b)
  where

  record Arrow-О  : Type (рқ“Ө1 вҠ” рқ“Ө2 вҠ” рқ“Ө3 вҠ” рқ“Ө4) where
    constructor mk-amap
    field
      top : (a : A) вҶ’ X (f a)
      bot : (b : B) вҶ’ Y b
      comm : precomp-О  Y f bot ~ postcomp-О  (О» a вҶ’ g (f a)) top

  unquoteDecl Arrow-О -reprвүҠ Arrow-О -reprвүғ
    = make-record-repr Arrow-О -reprвүҠ Arrow-О -reprвүғ (quote Arrow-О )
}
}

\subtree[stt-003U]{
\taxon{Definition}
\title{Morphisms of arrows}

\p{
Given a pair of arrows, we define a morphism between them to be a commutative square,
that is, a pair of a maps and a homotopy witnessing that the square commutes.
}

\agda{
module _
  {рқ“Ө рқ“Ҙ рқ“Ұ рқ“ӣ}
  {A : Type рқ“Ө} {B : Type рқ“Ҙ} (f : A вҶ’ B)
  {C : Type рқ“Ұ} {D : Type рқ“ӣ} (f' : C вҶ’ D)
  where

  Arrow-map : Type (рқ“Ө вҠ” рқ“Ҙ вҠ” рқ“Ұ вҠ” рқ“ӣ)
  Arrow-map = Arrow-О  f (О» _ вҶ’ f')

  Arrow-map-reprвүҠ : Arrow-map вүҠ _
  Arrow-map-reprвүҠ = Arrow-О -reprвүҠ f (О» _ вҶ’ f')

  Arrow-map-reprвүғ : Arrow-map вүғ _
  Arrow-map-reprвүғ = Arrow-О -reprвүғ f (О» _ вҶ’ f')

module Arrow-map = Arrow-О 
}
}

\subtree[stt-00EG]{
\taxon{Theorem}
\date{2026-02-20}
\title{The type of dependent morphisms of arrows as a pullback}
\author{fredrikbakke}

\p{The type #{\Hom^{\mathrm{d}}(f,g)} is the pullback of #{g \circ {-}} and
#{{-} \circ f}.}

\agda{
module _
  {рқ“Ө1 рқ“Ө2 рқ“Ө3 рқ“Ө4 : Level}
  {A : Type рқ“Ө1}
  {B : Type рқ“Ө2}
  {f : A вҶ’ B}
  {X : B вҶ’ Type рқ“Ө3}
  {Y : B вҶ’ Type рқ“Ө4}
  {g : (b : B) вҶ’ X b вҶ’ Y b}
  where

  Arrow-О -cone
    : Cone (mk-cospan ((a : A) вҶ’ Y (f a))
                      (precomp-О  Y f)
                      (postcomp-О  (О» a вҶ’ g (f a))))
           (Arrow-О  f g)
  Arrow-О -cone .Cone.i p = Arrow-О .bot p
  Arrow-О -cone .Cone.j p = Arrow-О .top p
  Arrow-О -cone .Cone.filler p = funextвҶ’ (Arrow-О .comm p)

  Arrow-О вүғpullback-repr
    : Arrow-О  f g
    вүғ Pullback (precomp-О  Y f) (postcomp-О  (О» a вҶ’ g (f a)))
  Arrow-О вүғpullback-repr
    = Arrow-О  f g
        вүғвҹЁ Arrow-О -reprвүғ f g вҹ©
      ОЈ[ t вҲ¶ ((a : A) вҶ’ X (f a)) ]
      ОЈ[ b вҲ¶ ((b : B) вҶ’ Y b) ]
       (precomp-О  Y f b ~ postcomp-О  (О» a вҶ’ g (f a)) t)
        вүғвҹЁ ОЈ-comm вҹ©
      ОЈ[ b вҲ¶ ((b : B) вҶ’ Y b) ]
      ОЈ[ t вҲ¶ ((a : A) вҶ’ X (f a)) ]
       (precomp-О  Y f b ~ postcomp-О  (О» a вҶ’ g (f a)) t)
        вүғвҹЁ ОЈ-snd-вүғ (О» _ вҶ’ ОЈ-snd-вүғ О» _ вҶ’ (funextвүғ eвҒ»В№)) вҹ©
      Pullback (precomp-О  Y f) (postcomp-О  (О» a вҶ’ g (f a)))
        вүғвҲҺ

  Arrow-О вүғpullback-repr~gap
    : Arrow-О вүғpullback-repr ._вүғ_.fwd ~ gap Arrow-О -cone
  Arrow-О вүғpullback-repr~gap = ~refl

  Arrow-О -is-pullback : is-pullback Arrow-О -cone
  Arrow-О -is-pullback
    = is-equivвҶҗ~вҒ»В№
        (Arrow-О вүғpullback-repr~gap)
        (Arrow-О вүғpullback-repr ._вүғ_.fwd-is-equiv)

  Arrow-О вүғpullback
    : Arrow-О  f g
    вүғ Pullback (precomp-О  Y f) (postcomp-О  (О» a вҶ’ g (f a)))
  Arrow-О вүғpullback
    = mkвүғ (gap Arrow-О -cone) (Arrow-О -is-pullback)
}
}

\subtree[stt-004H]{
\taxon{Theorem}
\date{2025-05-17}
\title{The type of morphisms of arrows as a pullback}

\p{The type #{\Hom(f,g)} is the pullback of #{g \circ {-}} and #{{-} \circ f}.}

\agda{
module _ {рқ“Ө рқ“Ҙ} {A : Type рқ“Ө} {B : Type рқ“Ҙ} {f : A вҶ’ B}
         {рқ“Ұ рқ“ӣ} {C : Type рқ“Ұ} {D : Type рқ“ӣ} {g : C вҶ’ D} where

  Arrow-mapвүғpullback' : Arrow-map f g вүғ Pullback (_вҲҳ f) (g вҲҳ_)
  Arrow-mapвүғpullback' = Arrow-О вүғpullback {f = f} {g = О» _ вҶ’ g}

  Arrow-mapвүғpullback : Arrow-map f g вүғ Pullback (g вҲҳ_) (_вҲҳ f)
  Arrow-mapвүғpullback = Arrow-mapвүғpullback' вҲҷe pullback-swap

  pullbackвҶҗarrow' : Arrow-map f g вҶ’ Pullback (_вҲҳ f) (g вҲҳ_)
  pullbackвҶҗarrow' = Arrow-mapвүғpullback' ._вүғ_.fwd

  pullbackвҶҗarrow : Arrow-map f g вҶ’ Pullback (g вҲҳ_) (_вҲҳ f)
  pullbackвҶҗarrow = Arrow-mapвүғpullback ._вүғ_.fwd

  arrowвҶҗpullback' : Pullback (_вҲҳ f) (g вҲҳ_) вҶ’ Arrow-map f g
  arrowвҶҗpullback' = _вүғ_.bwd Arrow-mapвүғpullback'

  arrowвҶҗpullback : Pullback (g вҲҳ_) (_вҲҳ f) вҶ’ Arrow-map f g
  arrowвҶҗpullback = _вүғ_.bwd Arrow-mapвүғpullback

  arrowвҶҗpullback-is-equiv : is-equiv (arrowвҶҗpullback)
  arrowвҶҗpullback-is-equiv
    = is-equivвҒ»В№ (_вүғ_.fwd-is-equiv Arrow-mapвүғpullback)
}
}

\subtree[stt-004I]{
\title{Characterising the paths of morphisms of arrows}
\taxon{Theorem}

\agda{
module _ {рқ“Ө рқ“Ҙ} {A : Type рқ“Ө} {B : Type рқ“Ҙ} {f : A вҶ’ B}
         {рқ“Ұ рқ“ӣ} {C : Type рқ“Ұ} {D : Type рқ“ӣ} {f' : C вҶ’ D} where

  Arrow-map-path : вҲҖ (G H : Arrow-map f f') вҶ’ Type (рқ“Ө вҠ” рқ“Ҙ вҠ” рқ“Ұ вҠ” рқ“ӣ)
  Arrow-map-path (mk-amap t b H) (mk-amap t' b' H')
    = ОЈ[ p вҲ¶ t ~ t' ] ОЈ[ q вҲ¶ b ~ b' ]
      (H вҲҷh (f' в—Ӯ p) ~ q в–ё f вҲҷh H')

  Arrow-map-path-refl : {G : Arrow-map f f'} вҶ’ Arrow-map-path G G
  Arrow-map-path-refl = ~refl , ~refl , вҲҷh-reflr _

  Arrow-map-path-is-Rppred
    : вҲҖ (G : Arrow-map f f')
      вҶ’ Reflexive-ppred _ G _
  Arrow-map-path-is-Rppred G = (Arrow-map-path G) , Arrow-map-path-refl

  Arrow-map-pathвҶҗid : вҲҖ {G H : Arrow-map f f'} вҶ’ (G пјқ H) вҶ’ Arrow-map-path G H
  Arrow-map-pathвҶҗid refl = Arrow-map-path-refl

  opaque
    Arrow-map-pathвүғ : вҲҖ (G H : Arrow-map f f') вҶ’ (G пјқ H) вүғ Arrow-map-path G H
    Arrow-map-pathвүғ G@(mk-amap t b h) H
      = mkвүғ Arrow-map-pathвҶҗid
            (fundamental-Id
              (Arrow-map-path G)
              (is-singleвҶҗequiv-to-single
                (ОЈ-fst-вүғ (Arrow-map-reprвүғ _ _ eвҒ»В№))
                (is-singleton-structureвҶҗparts (SingS-is-single t)
                  (t , ~refl)
                  (is-singleton-structureвҶҗparts (SingS-is-single b)
                    (b , ~refl)
                    (SingS-is-single О» a вҶ’ h a вҲҷ refl))))
              (О» _ вҶ’ Arrow-map-pathвҶҗid) H)

    Arrow-map-pathвҶ’
      : вҲҖ {G H : Arrow-map f f'} вҶ’ Arrow-map-path G H
        вҶ’ (G пјқ H)
    Arrow-map-pathвҶ’ = _вүғ_.bwd (Arrow-map-pathвүғ _ _)

    Arrow-map-pathвҶ’-refl
      : вҲҖ {G : Arrow-map f f'}
        вҶ’ Arrow-map-pathвҶ’ (Arrow-map-path-refl {G = G}) пјқ refl
    Arrow-map-pathвҶ’-refl
      = unap-equiv (Arrow-map-pathвүғ _ _ ._вүғ_.fwd-is-equiv)
                   (is-equiv.Оө (Arrow-map-pathвүғ _ _ ._вүғ_.fwd-is-equiv) _)
}
}

\subtree[stt-003X]{
\taxon{Theorem}
\title{Arrows and squares form a category}

\agda{
id-square
  : вҲҖ {рқ“Ө рқ“Ҙ} {A : Type рқ“Ө} {B : Type рқ“Ҙ} {f : A вҶ’ B}
    вҶ’ Arrow-map f f
id-square = mk-amap id id ~refl

infix 25 id-square:_
id-square:_ : вҲҖ {рқ“Ө рқ“Ҙ} {A : Type рқ“Ө} {B : Type рқ“Ҙ} (f : A вҶ’ B) вҶ’ Arrow-map f f
id-square: f = id-square

module _ {рқ“Ө рқ“Ҙ} {A : Type рқ“Ө} {B : Type рқ“Ҙ} {f : A вҶ’ B}
         {рқ“Ө' рқ“Ҙ'} {A' : Type рқ“Ө'} {B' : Type рқ“Ҙ'} {f' : A' вҶ’ B'}
         {рқ“Ө'' рқ“Ҙ''} {A'' : Type рқ“Ө''} {B'' : Type рқ“Ҙ''} {f'' : A'' вҶ’ B''} where

  paste-squares
    : Arrow-map f' f''
    вҶ’ Arrow-map f f'
    вҶ’ Arrow-map f f''
  paste-squares (mk-amap g' h' comm') (mk-amap g h comm)
    = mk-amap (g' вҲҳ g) (h' вҲҳ h) (h' в—Ӯ comm вҲҷh comm' в–ё g)
}
}

\subtree[stt-00LU]{
\title{Associativity and unit laws for pasting squares}
\taxon{Lemma}
\author{fredrikbakke}
\date{2026-04-05}

\agda{
paste-squares-assoc
  : {рқ“Ө1 рқ“Ҙ1 рқ“Ө2 рқ“Ҙ2 рқ“Ө3 рқ“Ҙ3 рқ“Ө4 рқ“Ҙ4 : Level}
    {A1 : Type рқ“Ө1} {B1 : Type рқ“Ҙ1} {f1 : A1 вҶ’ B1}
    {A2 : Type рқ“Ө2} {B2 : Type рқ“Ҙ2} {f2 : A2 вҶ’ B2}
    {A3 : Type рқ“Ө3} {B3 : Type рқ“Ҙ3} {f3 : A3 вҶ’ B3}
    {A4 : Type рқ“Ө4} {B4 : Type рқ“Ҙ4} {f4 : A4 вҶ’ B4}
  вҶ’ (H : Arrow-map f3 f4)
  вҶ’ (G : Arrow-map f2 f3)
  вҶ’ (F : Arrow-map f1 f2)
  вҶ’ Arrow-map-path
    (paste-squares H (paste-squares G F))
    (paste-squares (paste-squares H G) F)
paste-squares-assoc H G F .fst = ~refl
paste-squares-assoc H G F .snd .fst = ~refl
paste-squares-assoc H G F .snd .snd a
  = let
      p = Arrow-map.comm F a
      q = Arrow-map.comm G (Arrow-map.top F a)
      r = Arrow-map.comm H (Arrow-map.top G (Arrow-map.top F a))
    in вҲҷ-reflr _
     вҲҷ ap (_вҲҷ r) (ap-вҲҷ (Arrow-map.bot H) (ap (Arrow-map.bot G) p) q)
     вҲҷ вҲҷ-assoc
         (ap (Arrow-map.bot H) (ap (Arrow-map.bot G) p))
         (ap (Arrow-map.bot H) q)
         (r)
     вҲҷ ap
         (_вҲҷ ap (Arrow-map.bot H) q вҲҷ r)
         (sym (ap-вҲҳ (Arrow-map.bot H) (Arrow-map.bot G) p))

paste-squares-left-id
  : {рқ“Ө1 рқ“Ҙ1 рқ“Ө2 рқ“Ҙ2 : Level}
    {A1 : Type рқ“Ө1} {B1 : Type рқ“Ҙ1} {f : A1 вҶ’ B1}
    {A2 : Type рқ“Ө2} {B2 : Type рқ“Ҙ2} {g : A2 вҶ’ B2}
  вҶ’ (F : Arrow-map f g)
  вҶ’ Arrow-map-path (paste-squares (id-square: g) F) F
paste-squares-left-id F .fst = ~refl
paste-squares-left-id F .snd .fst = ~refl
paste-squares-left-id F .snd .snd a
  = вҲҷ-reflr _
  вҲҷ вҲҷ-reflr _
  вҲҷ ap-id (Arrow-map.comm F a)

paste-squares-right-id
  : {рқ“Ө1 рқ“Ҙ1 рқ“Ө2 рқ“Ҙ2 : Level}
    {A1 : Type рқ“Ө1} {B1 : Type рқ“Ҙ1} {f : A1 вҶ’ B1}
    {A2 : Type рқ“Ө2} {B2 : Type рқ“Ҙ2} {g : A2 вҶ’ B2}
  вҶ’ (F : Arrow-map f g)
  вҶ’ Arrow-map-path (paste-squares F (id-square: f)) F
paste-squares-right-id F .fst = ~refl
paste-squares-right-id F .snd .fst = ~refl
paste-squares-right-id F .snd .snd a = вҲҷ-reflr _
}
}



\subtree[stt-002Z]{
\taxon{Theorem}
\title{Arrow morphisms are squares}

\p{We now have (at least) three things that can be called squares. We give functions
to convert from arrow-map squares, to either cones over cospans or cocones over spans.}

\agda{
CoconeвҶҗArrow-map
  : вҲҖ {рқ“Ө рқ“Ҙ} {A : Type рқ“Ө} {B : Type рқ“Ҙ} {f : A вҶ’ B}
      {рқ“Ұ рқ“ӣ} {C : Type рқ“Ұ} {D : Type рқ“ӣ} {f' : C вҶ’ D}
    вҶ’ Arrow-map f f' вҶ’ ОЈ[ S вҲ¶  Span рқ“Ө рқ“Ҙ рқ“Ұ ] Cocone S D
CoconeвҶҗArrow-map {f = f} {f' = f'} (mk-amap g g' comm)
  = (mk-span _ f g) , mk-cocone g' f' comm

Arrow-mapвҶҗCocone
  : вҲҖ {рқ“Ө рқ“Ҙ рқ“Ұ рқ“ң} {S : Span рқ“Ө рқ“Ҙ рқ“Ұ} {D : Type рқ“ң}
    вҶ’ (C : Cocone S D)
    вҶ’ Arrow-map (Span.left S) (Cocone.q C)
Arrow-mapвҶҗCocone {S = S} C = mk-amap S.right C.p C.filler where
  module S = Span S
  module C = Cocone C

ConeвҶҗArrow-map
  : вҲҖ {рқ“Ө рқ“Ҙ} {A : Type рқ“Ө} {B : Type рқ“Ҙ} {f : A вҶ’ B}
      {рқ“Ұ рқ“ӣ} {C : Type рқ“Ұ} {D : Type рқ“ӣ} {f' : C вҶ’ D}
    вҶ’ Arrow-map f f' вҶ’ ОЈ[ S вҲ¶ Cospan рқ“ӣ рқ“Ҙ рқ“Ұ ] Cone S A
ConeвҶҗArrow-map {f = f} {f' = f'} (mk-amap top bot comm)
  = (mk-cospan _ bot f') , mk-cone f top comm
}
}

\subtree[stt-004E]{
\taxon{Definition}

\title{(co)gap maps from squares}

\agda{
gap-mapвҶҗsquare
  : вҲҖ {рқ“Ө рқ“Ҙ} {A : Type рқ“Ө} {B : Type рқ“Ҙ} {f : A вҶ’ B}
      {рқ“Ұ рқ“ӣ} {C : Type рқ“Ұ} {D : Type рқ“ӣ} {f' : C вҶ’ D}
    вҶ’ (g : Arrow-map f f')
    вҶ’ A вҶ’ Pullback (g .Arrow-map.bot) f'
gap-mapвҶҗsquare g = gap (ConeвҶҗArrow-map g .snd)

cogap-mapвҶҗsquare
  : вҲҖ {рқ“Ө рқ“Ҙ} {A : Type рқ“Ө} {B : Type рқ“Ҙ} {f : A вҶ’ B}
      {рқ“Ұ рқ“ӣ} {C : Type рқ“Ұ} {D : Type рқ“ӣ} {f' : C вҶ’ D}
    вҶ’ (g : Arrow-map f f')
    вҶ’ Pushout f (g .Arrow-map.top) вҶ’ D
cogap-mapвҶҗsquare g = cogap (CoconeвҶҗArrow-map g .snd)
}
}


\subtree[stt-003P]{
\taxon{Definition}
\title{Squares from pre/post-composition}

\p{Given a square of the form:}

\quiver{
\begin{tikzcd}
	A && C \\
	\\
	B && D
	\arrow["g", from=1-1, to=1-3]
	\arrow["f"', from=1-1, to=3-1]
	\arrow["{f'}", from=1-3, to=3-3]
	\arrow["{g'}"', from=3-1, to=3-3]
\end{tikzcd}
}

\p{For all types #{Q}, we obtain squares:}

\quiver{
\begin{tikzcd}
	{Q \to A} && {Q \to C} \\
	\\
	{Q \to B} && {Q \to D}
	\arrow["{g \circ {-}}", from=1-1, to=1-3]
	\arrow["{f \circ {-}}"', from=1-1, to=3-1]
	\arrow["{f' \circ {-}}", from=1-3, to=3-3]
	\arrow["{g' \circ {-}}"', from=3-1, to=3-3]
\end{tikzcd}
}

\p{and}

\quiver{
\begin{tikzcd}
	{D \to Q} && {B \to Q} \\
	\\
	{C \to Q} && {A \to Q}
	\arrow["{{-} \circ g'}", from=1-1, to=1-3]
	\arrow["{{-} \circ f'}"', from=1-1, to=3-1]
	\arrow["{{-} \circ f'}", from=1-3, to=3-3]
	\arrow["{{-} \circ g}"', from=3-1, to=3-3]
\end{tikzcd}
}

\agda{
precomp-square
  : вҲҖ {рқ“Ө рқ“Ҙ рқ“Ұ рқ“ң}
      {A : Type рқ“Ө} {B : Type рқ“Ҙ} {f : A вҶ’ B}
      {C : Type рқ“Ұ} {D : Type рқ“ң} {f' : C вҶ’ D}
      (g : Arrow-map f f')
    вҶ’ вҲҖ {рқ“ӣ} (C : Type рқ“ӣ) вҶ’ Arrow-map (precomp C f') (precomp C f)
precomp-square (mk-amap top bot p) C
 = mk-amap (_вҲҳ bot) (_вҲҳ top) О» f вҶ’ funextвҶ’ (f в—Ӯ (p hвҒ»В№))

postcomp-square
  : вҲҖ {рқ“Ө рқ“Ҙ рқ“Ұ рқ“ң}
      {A : Type рқ“Ө} {B : Type рқ“Ҙ} {f : A вҶ’ B}
      {C : Type рқ“Ұ} {D : Type рқ“ң} {f' : C вҶ’ D}
      (g : Arrow-map f f')
    вҶ’ вҲҖ {рқ“ӣ} (C : Type рқ“ӣ) вҶ’ Arrow-map (postcomp C f) (postcomp C f')
postcomp-square (mk-amap top bot p) C
  = mk-amap (top вҲҳ_) (bot вҲҳ_) О» f вҶ’ funextвҶ’ (p в–ё f)
}
}

\remark{
\p{Precomposing squares gives the result of applying the functor
#{\Hom(Q,H)} to the square. It is a well known result that this functor preserves
pullback Likewise, postcomposition is given by #{\Hom({-},Q)}, and this functor turns
pushouts in to pullbacks.
}
}


\subtree[tot-0003]{
\taxon{Construction}
\title{Transposition of squares}

\agda{
transpose-square
  : вҲҖ {рқ“Ө рқ“Ҙ рқ“Ұ рқ“ң} {A : Type рқ“Ө} {B : Type рқ“Ҙ}
      {C : Type рқ“Ұ} {D : Type рқ“ң}
      {f : A вҶ’ B} {g : C вҶ’ D}
    вҶ’ (F : Arrow-map f g)
    вҶ’ Arrow-map (F .Arrow-map.top) (F .Arrow-map.bot)
transpose-square {f = f} {g = g} F
  = mk-amap f g (F .Arrow-map.comm hвҒ»В№)

transpose-square-involution
  : вҲҖ {рқ“Ө рқ“Ҙ рқ“Ұ рқ“ң} {A : Type рқ“Ө} {B : Type рқ“Ҙ}
      {C : Type рқ“Ұ} {D : Type рқ“ң}
      {f : A вҶ’ B} {g : C вҶ’ D}
    вҶ’ (F : Arrow-map f g)
    вҶ’ transpose-square (transpose-square F) пјқ F
transpose-square-involution F@(mk-amap top bot comm)
  = Arrow-map-pathвҶ’ (~refl , ~refl , О» a вҶ’ вҲҷ-reflr _ вҲҷ sym-sym)
}
}


\subtree[stt-00BR]{
\title{Total squares}
\taxon{Construction}

\p{Given a family of squares, we can define the total square by taking the
sum types and total maps between them.}

\agda{
total-square
  : вҲҖ {рқ“ҳ рқ“Ө рқ“Ҙ рқ“Ұ рқ“ң} {I : Type рқ“ҳ}
      {A : I вҶ’ Type рқ“Ө} {B : I вҶ’ Type рқ“Ҙ} {f : (i : I) вҶ’ A i вҶ’ B i}
      {C : I вҶ’ Type рқ“Ұ} {D : I вҶ’ Type рқ“ң} {g : (i : I) вҶ’ C i вҶ’ D i}
    вҶ’ (F : (i : I) вҶ’ Arrow-map (f i) (g i))
    вҶ’ Arrow-map (total-map f) (total-map g)
total-square F .Arrow-map.top = total-map (Arrow-map.top вҲҳ F)
total-square F .Arrow-map.bot = total-map (Arrow-map.bot вҲҳ F)
total-square F .Arrow-map.comm (i , a)
  = ОЈ-pathвҶ’ (refl , Arrow-map.comm (F i) a)
}
}

\subtree[stt-00BY]{
\title{Dependent precomposition square}
\taxon{Construction}

\p{Given a family of squares #{F_i : f_i \to g_i}, we can form the product square
#{\Pi_i F_i : \Pi_i f_i \to \Pi_i g_i}}

\agda{
О -square
  : вҲҖ {рқ“ҳ рқ“Ө рқ“Ҙ рқ“Ұ рқ“ң} {I : Type рқ“ҳ}
      {A : I вҶ’ Type рқ“Ө} {B : I вҶ’ Type рқ“Ҙ} {f : (i : I) вҶ’ A i вҶ’ B i}
      {C : I вҶ’ Type рқ“Ұ} {D : I вҶ’ Type рқ“ң} {g : (i : I) вҶ’ C i вҶ’ D i}
    вҶ’ (F : (i : I) вҶ’ Arrow-map (f i) (g i))
    вҶ’ Arrow-map (postcomp-О  f) (postcomp-О  g)
О -square F .Arrow-map.top h i = Arrow-map.top (F i) (h i)
О -square F .Arrow-map.bot h i = Arrow-map.bot (F i) (h i)
О -square F .Arrow-map.comm h  = funextвҶ’ (О» a вҶ’ Arrow-map.comm (F a) (h a))
}
}


\subtree[stt-00K7]{
\title{Paths in maps of families}
\taxon{Lemma}

\agda{
opaque
  Fam-map-homotopy-is-torsorial
    : вҲҖ {рқ“Ө рқ“Ҙ рқ“Ұ рқ“ң} {F@(A , X) : Fam рқ“Ө рқ“Ҙ} {G@(B , Y) : Fam рқ“Ұ рқ“ң }
      вҶ’ вҲҖ (a : Fam-map F G)
      вҶ’ is-singleton (ОЈ _ (Fam-map-homotopy {F = F} {G} a))
  Fam-map-homotopy-is-torsorial a
    = is-singleton-structureвҶҗparts
        (SingS-is-single (a .fst))
        (_ , ~refl)
        (is-singleвҶҗequiv-to-single
          (ОЈ-О -swapвүғ _ _)
          (О -is-single (О» x вҶ’ SingS-is-single (a .snd x))))

instance
  Fam-map-IdS
    : вҲҖ {рқ“Ө рқ“Ҙ рқ“Ұ рқ“ң} {F : Fam рқ“Ө рқ“Ҙ} {G : Fam рқ“Ұ рқ“ң}
      вҶ’ Identity-system (Fam-map F G) (рқ“Ө вҠ” рқ“Ҙ вҠ” рқ“Ұ вҠ” рқ“ң)
  Fam-map-IdS .Identity-system.IdS = Fam-map-homotopy
  Fam-map-IdS .Identity-system.IdSвҶҗId refl = Fam-map-refl~ _
  Fam-map-IdS .Identity-system.IdSвҶҗId-is-equiv a
    = fundamental-Id _ (Fam-map-homotopy-is-torsorial a) _
}
}

\subtree[stt-00KQ]{
\title{Straightening arrow maps}
\taxon{Lemma}

\p{We show that there is an equivalence between maps of arrows
and maps of families.}

\agda{
module _
  {рқ“Ө рқ“Ҙ рқ“Ұ рқ“ң}
  {A : Type рқ“Ө} {B : Type рқ“Ҙ} {f : A вҶ’ B}
  {X : Type рқ“Ұ} {Y : Type рқ“ң} {g : X вҶ’ Y}
  where

  arrow-fibre
    : (gs : Arrow-map f g)
    вҶ’ (b : B)
    вҶ’ fibre f b вҶ’ fibre g (gs .Arrow-map.bot b)
  arrow-fibre (mk-amap f' g' hom) b (a , p) = (f' a , sym (hom a) вҲҷ ap g' p)

  fam-mapвҶҗarrow-map
    : Arrow-map f g вҶ’ Fam-map (fibre-fam f) (fibre-fam g)
  fam-mapвҶҗarrow-map F = (F .Arrow-map.bot , arrow-fibre F)

  arrow-mapвҶҗfam-map
    : Fam-map (fibre-fam f) (fibre-fam g)
    вҶ’ Arrow-map f g
  arrow-mapвҶҗfam-map (b , t)
    = mk-amap (О» a вҶ’ t (f a) (a , refl) .fst) b
              (О» a вҶ’ sym (t (f a) (a , refl) .snd))

  fam-mapвҶҗarrow-map-is-equiv : is-equiv fam-mapвҶҗarrow-map
  fam-mapвҶҗarrow-map-is-equiv
    = is-equivвҶҗqinv
        ( arrow-mapвҶҗfam-map
        , (О» x вҶ’ Arrow-map-pathвҶ’ (~refl , ~refl ,
                                 (  вҲҷh-reflr _
                                 вҲҷh (ap sym вҲҳ вҲҷh-reflr _)
                                 вҲҷh (О» _ вҶ’ sym-sym))))
        , section-fam-arr) where
    section-fam-arr
      : fam-mapвҶҗarrow-map вҲҳ arrow-mapвҶҗfam-map ~ id
    section-fam-arr (b , t)
      = ОЈ-pathвҶ’ (refl ,
          (funextвҶ’ (О» a вҶ’ funextвҶ’
            (О» where (x , refl) вҶ’ ОЈ-pathвҶ’ (refl , (вҲҷ-reflr _ вҲҷ sym-sym))))))
}
}

\subtree[stt-00OB]{
\title{Half-straightened arrow maps}
\taxon{Definition}

\p{Given a map #{f : A \to B}, and a type family #{P : C \to \Type}, we define the
type of maps from #{f} to #{P}, which consists of the data:}

\ul{
\li{A map #{b : B \to A}}
\li{A section #{t : \Pi_{a} P(b(f(a))) }}
}

\agda{
record ArrFam-map
         {рқ“Ө рқ“Ҙ рқ“Ұ рқ“ң} {A : Type рқ“Ө} {B : Type рқ“Ҙ}
         {C : Type рқ“Ұ} (f : A вҶ’ B)
         (P : C вҶ’ Type рқ“ң) : Type (рқ“ң вҠ” рқ“Ҙ вҠ” рқ“Ө вҠ” рқ“Ұ) where
  constructor mk-afmap
  field
    bot : B вҶ’ C
    top : вҲҖ a вҶ’ P (bot (f a))

unquoteDecl ArrFam-map-reprвүҠ ArrFam-map-reprвүғ
  = make-record-repr ArrFam-map-reprвүҠ ArrFam-map-reprвүғ (quote ArrFam-map)
}
}

\subtree[stt-00OC]{
\taxon{Lemma}

\p{A [half-straightened](stt-00OB) map from a map #{f} to a type family #{P} is equivalent
to an arrow map from #{f} to the unstraightening of #{P}.}

\agda{
unstr-ArrFam
  : вҲҖ {рқ“Ө рқ“Ҙ рқ“Ұ рқ“ң} {A : Type рқ“Ө} {B : Type рқ“Ҙ} {f : A вҶ’ B}
      {C : Type рқ“Ұ} {P : C вҶ’ Type рқ“ң}
    вҶ’ ArrFam-map f P вҶ’ Arrow-map f (fst: P)
unstr-ArrFam {f = f} F .Arrow-О .top a = (_ , F .ArrFam-map.top a)
unstr-ArrFam F .Arrow-О .bot = F .ArrFam-map.bot
unstr-ArrFam F .Arrow-О .comm = ~refl

str-ArrFam
  : вҲҖ {рқ“Ө рқ“Ҙ рқ“Ұ рқ“ң} {A : Type рқ“Ө} {B : Type рқ“Ҙ} {f : A вҶ’ B}
      {C : Type рқ“Ұ} {P : C вҶ’ Type рқ“ң}
    вҶ’ Arrow-map f (fst: P) вҶ’ ArrFam-map f P
str-ArrFam F .ArrFam-map.bot = F .Arrow-map.bot
str-ArrFam {P = P} F .ArrFam-map.top a
  = tr P (sym (F .Arrow-map.comm a)) (F .Arrow-map.top a .snd)

str-ArrFam-is-equiv
  : вҲҖ {рқ“Ө рқ“Ҙ рқ“Ұ рқ“ң} {A : Type рқ“Ө} {B : Type рқ“Ҙ} {f : A вҶ’ B}
      {C : Type рқ“Ұ} {P : C вҶ’ Type рқ“ң}
    вҶ’ is-equiv (str-ArrFam {f = f} {P = P})
str-ArrFam-is-equiv = is-equivвҶҗqinv
  ( unstr-ArrFam
  , (О» {(mk-amap top bot comm) вҶ’ Arrow-map-pathвҶ’
            ((О» a вҶ’ ОЈ-pathвҶ’ ( comm a
                            , trвҲҳtr-sym' (comm a) (top a .snd)))
            , ~refl
            , О» a вҶ’ ОЈ-path-ap-fst)})
  , ~refl)
}
}

\subtree[stt-00RQ]{
\title{The type of morphisms into a terminal projection is equivalent to the type of maps of domains}
\taxon{Lemma}
\date{2026-05-21}
\author{fredrikbakke}

\agda{
arrow-map-to-top-is-equiv
  : вҲҖ {рқ“Ө рқ“Ҙ рқ“Ұ} {A : Type рқ“Ө} {B : Type рқ“Ҙ} {X : Type рқ“Ұ} {f : A вҶ’ B}
    вҶ’ is-equiv (О» (F : Arrow-map f (!: X)) вҶ’ Arrow-map.top F)
arrow-map-to-top-is-equiv =
  is-equivвҶҗqinv

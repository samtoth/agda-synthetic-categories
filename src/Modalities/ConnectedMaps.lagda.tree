\subtree[stt-00MQ]{
\taxon{Definition}
\title{Universal property of #{K}-connected maps}

\p{
Given a global subuniverse #{K} and a map #{f : A \to B}, then #{f} satisfies the
\em{universal property of #{K}-connected maps} if for every #{K}-valued family of
types #{U} over #{B}, the dependent precomposition map
#{\prod_{b : B} U(b) \to \prod_{a : A} U(f(a))} is an equivalence.
}

\p{We use the abbreviation \code{up} for "universal property".}

\agda{
up-connected-map
  : тИА {╬▒ ЁЭУд ЁЭУе} (K : gSubU ╬▒)
    тЖТ {A : Type ЁЭУд} {B : Type ЁЭУе}
    тЖТ (A тЖТ B)
    тЖТ Type╧Й
up-connected-map K f
  = тИА {ЁЭУЪ} {U : _ тЖТ Type ЁЭУЪ}
  тЖТ (тИА b тЖТ U b тИИ gSubU.S K)
  тЖТ is-equiv (precomp-╬а U f)

up-connected-!-fibre
  : тИА {╬▒ ЁЭУд ЁЭУе} (K : gSubU ╬▒)
      {A : Type ЁЭУд} {B : Type ЁЭУе}
      (f : A тЖТ B)
    тЖТ Type╧Й
up-connected-!-fibre K f
  = тИА b тЖТ up-modal-equiv K (!: fibre f b)

up-connected-fibres
  : тИА {╬▒ ЁЭУд ЁЭУе} (K : gSubU ╬▒)
      {A : Type ЁЭУд} {B : Type ЁЭУе}
      (f : A тЖТ B)
    тЖТ Type╧Й
up-connected-fibres K f
  = тИА b {ЁЭУЪ} {U : Type ЁЭУЪ}
    тЖТ U тИИ gSubU.S K
    тЖТ is-equiv (const U (fibre f b))
}
}

\subtree[stt-00MC]{
\date{2026-03-19}
\author{fredrikbakke}
\taxon{Definition}
\title{#{K}-Connected maps}

\p{
If #{K} is a reflective subuniverse, a map is \em{#{K}-connected} if all of its
fibres have contractible reflections.
}

\agda{
is-connected-map
  : тИА {╬▒ ЁЭУд ЁЭУе} (RS : gRSubU ╬▒) {A : Type ЁЭУд} {B : Type ЁЭУе}
    тЖТ (A тЖТ B) тЖТ Type (ЁЭУд тКФ ЁЭУе)
is-connected-map RS {B = B} f = (b : B) тЖТ is-connected RS (fibre f b)

is-connected-map'
  : тИА {ЁЭУд ЁЭУе ЁЭУЬ} {A : Type ЁЭУд} {B : Type ЁЭУе}
      {S : SubU (ЁЭУд тКФ ЁЭУе) ЁЭУЬ}
    тЖТ is-reflective S
    тЖТ (A тЖТ B) тЖТ Type (ЁЭУд тКФ ЁЭУе)
is-connected-map' {B = B} rfl f = (b : B) тЖТ is-connected' rfl (fibre f b)
}
}

\subtree[stt-0A2A]{
\title{Modal units are connected iff the modality is #{╬г}-closed}
\taxon{Lemma}
\author{samueltoth}

\agda{
╬╖-is-connected
  : тИА {╬▒} (RS : gRSubU ╬▒)
    тЖТ is-globally-╬г-closed (gRSubU.GS RS)
    тЖТ тИА {ЁЭУд} {A : Type ЁЭУд}
    тЖТ is-connected-map RS (gRSubU.╬╖ RS {A = A})
╬╖-is-connected RS G╬г {_} {A} x
  = mk-singl
      (ind {P = ╬╗ x тЖТ тЧЛ (fibre ╬╖ x)}
           (╬╗ _ тЖТ тЧЛтИИS) (╬╗ a тЖТ ╬╖ (a , refl)) x)
      (ind (╬╗ _ тЖТ я╝ЭтИИS тЧЛтИИS) ╬╗ where (y , refl) тЖТ ind-╬▓ _ _ y) where
  open gRSubU RS
  open gReflectiveClosure RS
  open gRSubUInduction RS G╬г
}
}

\subtree[stt-0A2B]{
\title{Connected maps are closed under composition and are right cancellable}
\taxon{Lemma}
\author{samueltoth}
\author{fredrikbakke}

\agda{
up-connected-map-тИШ
  : тИА {╬▒ ЁЭУд ЁЭУе ЁЭУж}
      (K : gSubU ╬▒)
      {A : Type ЁЭУд} {B : Type ЁЭУе} {C : Type ЁЭУж}
      (f : A тЖТ B) (g : B тЖТ C)
    тЖТ up-connected-map K f
    тЖТ up-connected-map K g
    тЖТ up-connected-map K (g тИШ f)
up-connected-map-тИШ K f g fconn gconn UтИИK
  = is-equiv-тИШ (fconn (UтИИK тИШ g)) (gconn UтИИK)

up-connected-map-right-cancel
  : тИА {╬▒ ЁЭУд ЁЭУе ЁЭУж}
      (K : gSubU ╬▒)
      {A : Type ЁЭУд} {B : Type ЁЭУе} {C : Type ЁЭУж}
      (f : A тЖТ B) (g : B тЖТ C)
    тЖТ up-connected-map K f
    тЖТ up-connected-map K (g тИШ f)
    тЖТ up-connected-map K g
up-connected-map-right-cancel K f g fconn gfconn UтИИK
  = 3-for-2 (fconn (UтИИK тИШ g)) (gfconn UтИИK)
}

\agda{
module _ {╬▒} (RS : gRSubU ╬▒)
         where
  open gRSubU RS
  open gReflectiveClosure RS

  is-connected-map'-~
    : тИА {ЁЭУд ЁЭУе} {A : Type ЁЭУд} {B : Type ЁЭУе} {f g : A тЖТ B} тЖТ f ~ g
      тЖТ is-connected-map RS f тЖТ is-connected-map RS g
  is-connected-map'-~ = funext-rec _ ╬╗ where refl тЖТ id

  is-connected-mapтЖРis-equiv
    : тИА {ЁЭУд ЁЭУе} {A : Type ЁЭУд} {B : Type ЁЭУе} {f : A тЖТ B}
      тЖТ is-equiv f тЖТ is-connected-map RS f
  is-connected-mapтЖРis-equiv feq b = тЧЛ-is-singleton (has-singleton-fibresтЖРis-equiv feq b)


module _ {╬▒} (RS : gRSubU ╬▒)
         (S╬г : is-globally-╬г-closed (gRSubU.GS RS))
         where
  open gRSubU RS
  open gReflectiveReasoning RS
  open gRSubUInduction RS S╬г

  is-connected-mapтЗФтИШ
    : тИА {ЁЭУд ЁЭУе ЁЭУж} {A : Type ЁЭУд} {B : Type ЁЭУе} {C : Type ЁЭУж} {f : B тЖТ C}
        {g : A тЖТ B}
      тЖТ is-connected-map RS g
      тЖТ is-connected-map RS f
      тЗФ is-connected-map RS (f тИШ g)
  is-connected-mapтЗФтИШ {f = f} {g} gconn
    = ( (╬╗ fc c тЖТ is-singleтЖРequiv-to-single (eqv c eтБ╗┬╣) (fc c))
       , ╬╗ fgc c тЖТ is-singleтЖРequiv-to-single (eqv c) (fgc c)) where
    eqv : тИА z тЖТ тЧЛ (fibre (f тИШ g) z) тЙГ тЧЛ (fibre f z)
    eqv z
      = тЧЛ (fibre (f тИШ g) z) тЙГтЯи тЧЛ-тЙГ (fibre-тИШ z) тЯй
        тЧЛ (╬г (fibre f z) (╬╗ x тЖТ fibre g (fst x)))
                            тЙГтЯи mkтЙГ _ (╬гтЧЛ-is-equiv RS _) тЯй
        тЧЛ (╬г (fibre f z) (╬╗ x тЖТ тЧЛ (fibre g (fst x))))
                            тЙГтЯи тЧЛ-тЙГ (╬г-singleton (╬╗ x тЖТ gconn (fst x))) тЯй
        тЧЛ (fibre f z)       тЙГтИО

  is-connected-map-тИШ
    : тИА {ЁЭУд ЁЭУе ЁЭУж} {A : Type ЁЭУд} {B : Type ЁЭУе} {C : Type ЁЭУж} {f : B тЖТ C}
        {g : A тЖТ B}
      тЖТ is-connected-map RS g
      тЖТ is-connected-map RS f
      тЖТ is-connected-map RS (f тИШ g)
  is-connected-map-тИШ gc = is-connected-mapтЗФтИШ gc .fst

  is-connected-mapтЖРis-arrow-equiv
    : тИА {ЁЭУд ЁЭУе ЁЭУж ЁЭУЬ} {A : Type ЁЭУд} {B : Type ЁЭУе} {X : Type ЁЭУж} {Y : Type ЁЭУЬ}
        {f : A тЖТ B} {g : X тЖТ Y}
      тЖТ (F : Arrow-map f g)
      тЖТ is-Arrow-equiv F
      тЖТ is-connected-map RS f
      тЖТ is-connected-map RS g
  is-connected-mapтЖРis-arrow-equiv {f = f} {g = g} F fe fconn
    = is-connected-mapтЗФтИШ
        {f = g} {F .Arrow-map.top}
        (is-connected-mapтЖРis-equiv RS (fe .fst)) .snd
        (is-connected-map'-~ RS
          (F .Arrow-map.comm)
          (is-connected-map-тИШ fconn (is-connected-mapтЖРis-equiv RS (fe .snd))))

  is-connected-mapтЖРis-arrow-equivтБ╗┬╣
    : тИА {ЁЭУд ЁЭУе ЁЭУж ЁЭУЬ} {A : Type ЁЭУд} {B : Type ЁЭУе} {X : Type ЁЭУж} {Y : Type ЁЭУЬ}
        {f : A тЖТ B} {g : X тЖТ Y}
      тЖТ (F : Arrow-map f g)
      тЖТ (let module F = Arrow-map F)
      тЖТ is-Arrow-equiv F
      тЖТ is-connected-map RS g
      тЖТ is-connected-map RS f
  is-connected-mapтЖРis-arrow-equivтБ╗┬╣ F fe
    = is-connected-mapтЖРis-arrow-equiv
        (ArrowтБ╗┬╣тЖРis-Arrow-equiv F fe)
        (ArrowтБ╗┬╣-is-equiv F fe)
}
}

\subtree[stt-02AE]{
\author{fredrikbakke}
\author{samueltoth}
\taxon{Theorem}
\title{Connected maps are left orthogonal to modal maps}

\agda{
up-connectedтКеmodal
  : тИА {╬▒ ЁЭУд ЁЭУе} (K : gSubU ╬▒)
      {A : Type ЁЭУд} {B : Type ЁЭУе}
      (f : A тЖТ B)
    тЖТ up-connected-map K f
    тЖТ {ЁЭУж ЁЭУЫ : Level} {C : Type ЁЭУж} {D : Type ЁЭУЫ}
      (g : C тЖТ D)
    тЖТ is-modal-map K g
    тЖТ are-orthogonal f g
up-connectedтКеmodal K f fconn g gтИИK
  = orthogonalтЖРprecomp-╬а ╬╗ h тЖТ fconn (╬╗ b тЖТ gтИИK (h b))

up-connected-mapтЖРтКеmodal
  : тИА {╬▒ ЁЭУд ЁЭУе} (K : gSubU ╬▒)
      {A : Type ЁЭУд} {B : Type ЁЭУе}
      (f : A тЖТ B)
    тЖТ (тИА {ЁЭУж ЁЭУЫ} {C : Type ЁЭУж} {D : Type ЁЭУЫ}
      (g : C тЖТ D)
    тЖТ is-modal-map K g
    тЖТ are-orthogonal f g)
    тЖТ up-connected-map K f
up-connected-mapтЖРтКеmodal K f orth {U = U} UтИИK
  = is-equivтЖРArrow-equivтБ╗┬╣ {F = eq .fst} (eq .snd)
      (precomp-╬атЖРorthogonal id (orth fst fstтИИK)) where

  fstтИИK : is-modal-map K (fst {B = U})
  fstтИИK b = gSubU.тИИSтЖРequiv K (fibre-straighten U b eтБ╗┬╣) (UтИИK b)

  eq = precomp-╬а-straighten-Arrow-equiv U f
}
}

\subtree[stt-00MD]{
\date{2026-03-20}
\author{fredrikbakke}
\taxon{Proposition}
\title{Closure properties of #{K}-connected maps}

\p{
Connected maps are stable under homotopies, retracts of arrows, and cobase change.
}

\agda{
up-connected-map-homotopy
  : тИА {╬▒ ЁЭУд ЁЭУе}
      (K : gSubU ╬▒)
      {A : Type ЁЭУд} {B : Type ЁЭУе}
      {f g : A тЖТ B}
    тЖТ f ~ g
    тЖТ up-connected-map K f
    тЖТ up-connected-map K g
up-connected-map-homotopy K {f = f} {g = g} H fconn
  = up-connected-mapтЖРтКеmodal K g ╬╗ h hmodal
      тЖТ left-orthogonal-homotopy h H
          (up-connectedтКеmodal K f fconn h hmodal)

up-connected-map-тИШ~
  : тИА {╬▒ ЁЭУд ЁЭУе ЁЭУж}
      (K : gSubU ╬▒)
      {A : Type ЁЭУд} {B : Type ЁЭУе} {C : Type ЁЭУж}
      {h : A тЖТ C}
      (f : A тЖТ B) (g : B тЖТ C)
    тЖТ h ~ g тИШ f
    тЖТ up-connected-map K f
    тЖТ up-connected-map K g
    тЖТ up-connected-map K h
up-connected-map-тИШ~ K f g H fconn gconn
  = up-connected-map-homotopy K (H ~тБ╗┬╣)
      (up-connected-map-тИШ K f g fconn gconn)

up-connected-map-right-cancel~
  : тИА {╬▒ ЁЭУд ЁЭУе ЁЭУж}
      (K : gSubU ╬▒)
      {A : Type ЁЭУд} {B : Type ЁЭУе} {C : Type ЁЭУж}
      {h : A тЖТ C}
      (f : A тЖТ B) (g : B тЖТ C)
    тЖТ h ~ g тИШ f
    тЖТ up-connected-map K f
    тЖТ up-connected-map K h
    тЖТ up-connected-map K g
up-connected-map-right-cancel~ K f g H fconn hconn
  = up-connected-map-right-cancel K f g fconn
      (up-connected-map-homotopy K H hconn)

up-connected-mapтЖРretraction-arrow-map
  : тИА {╬▒ ЁЭУд ЁЭУе ЁЭУж ЁЭУЫ}
      (K : gSubU ╬▒)
      {A : Type ЁЭУд} {B : Type ЁЭУе} {f : A тЖТ B}
      {X : Type ЁЭУж} {Y : Type ЁЭУЫ} {g : X тЖТ Y}
      (F : Arrow-map f g)
    тЖТ retraction-arrow-map F
    тЖТ up-connected-map K g
    тЖТ up-connected-map K f
up-connected-mapтЖРretraction-arrow-map K {f = f} {g = g} F R gconn
  = up-connected-mapтЖРтКеmodal K f ╬╗ h hmodal
      тЖТ left-orthogonal-retraction f g F R h
          (up-connectedтКеmodal K g gconn h hmodal)

up-connected-mapтЖРcocartesian
  : тИА {╬▒ ЁЭУд ЁЭУе ЁЭУж ЁЭУЫ}
      (K : gSubU ╬▒)
      {A : Type ЁЭУд} {B : Type ЁЭУе} {f : A тЖТ B}
      {X : Type ЁЭУж} {Y : Type ЁЭУЫ} {g : X тЖТ Y}
      (F : Arrow-map f g)
    тЖТ up-cocartesian F
    тЖТ up-connected-map K f
    тЖТ up-connected-map K g
up-connected-mapтЖРcocartesian K {f = f} {g = g} F cocart fconn
  = up-connected-mapтЖРтКеmodal K g ╬╗ h hmodal
      тЖТ left-orthogonal-pushout F cocart h
          (up-connectedтКеmodal K f fconn h hmodal)

up-connected-map-╬╣тВВ
  : тИА {╬▒ ЁЭУд ЁЭУе ЁЭУж}
      (K : gSubU ╬▒)
      {A : Type ЁЭУд} {B : Type ЁЭУе} {C : Type ЁЭУж}
      (f : A тЖТ B) (g : A тЖТ C)
    тЖТ up-connected-map K f
    тЖТ up-connected-map K (╬╣тВВ {f = f} {g = g})
up-connected-map-╬╣тВВ K f g
  = up-connected-mapтЖРcocartesian K
      (Pushout-square (mk-span _ f g))
      (Pushout-square-has-up-cocartesian (mk-span _ f g))
}
}

\subtree[stt-00ME]{
\date{2026-03-19}
\author{fredrikbakke}
\taxon{Lemma}
\title{#{K}-connected maps are #{K}-equivalences}

\agda{
up-modal-equivтЖРup-connected-map
  : тИА {╬▒ ЁЭУд ЁЭУе} (K : gSubU ╬▒)
      {A : Type ЁЭУд} {B : Type ЁЭУе}
      (f : A тЖТ B)
    тЖТ up-connected-map K f
    тЖТ up-modal-equiv K f
up-modal-equivтЖРup-connected-map K f fconn UтИИK = fconn (╬╗ _ тЖТ UтИИK)

module gRSubUConnectedModalEquivalences {╬▒} (RS : gRSubU ╬▒) where
  open gRSubU RS

}
}

\subtree[stt-0A2C]{
\taxon{Lemma}
\author{samueltoth}

\p{Any map which is both modal and connected is an equivalence.}

\agda{
module _ {╬▒} (RS : gRSubU ╬▒) where

  open gRSubU RS
  open gReflectiveClosure RS

  is-equivтЖРis-modalтЖРis-connected
    : тИА {ЁЭУд ЁЭУе} {A : Type ЁЭУд} {B : Type ЁЭУе} {f : A тЖТ B}
      тЖТ is-modal-map GS f тЖТ is-connected-map RS f
      тЖТ is-equiv f
  is-equivтЖРis-modalтЖРis-connected m c
    = is-equivтЖРhas-singleton-fibres ╬╗ b
      тЖТ is-singleтЖРequiv-to-single
          (mkтЙГ _ (╬╖-is-equivтЖРin-SubU (reflector (fibre _ b)) (m b)) eтБ╗┬╣)
          (c b)
}
}

\subtree[stt-00MF]{
\date{2026-03-19}
\author{fredrikbakke}
\taxon{Theorem}
\title{Unique dependent extension property of #{K}-connected maps}

\p{
#{K}-Connectedness is equivalent to saying every section of a #{K}-valued
family over the domain uniquely extends along the map.
}

\agda{
unique-extensionsтЖРup-connected-map
  : тИА {╬▒ ЁЭУд ЁЭУе} (K : gSubU ╬▒)
      {A : Type ЁЭУд} {B : Type ЁЭУе}
      (f : A тЖТ B)
    тЖТ up-connected-map K f
    тЖТ тИА {ЁЭУЪ} {U : B тЖТ Type ЁЭУЪ}
    тЖТ (тИА b тЖТ U b тИИ gSubU.S K)
    тЖТ (h : ╬а A (U тИШ f))
    тЖТ is-singleton (Ext f h)
unique-extensionsтЖРup-connected-map K f fconn UтИИK h
  = is-singleтЖРequiv-to-single
      (╬г-ap-тЙГ (╬╗ _ тЖТ funextтЙГ))
      (has-singleton-fibresтЖРis-equiv (fconn UтИИK) h)

up-connected-mapтЖРunique-extensions
  : тИА {╬▒ ЁЭУд ЁЭУе} (K : gSubU ╬▒)
      {A : Type ЁЭУд} {B : Type ЁЭУе}
      (f : A тЖТ B)
    тЖТ (тИА {ЁЭУЪ} {U : B тЖТ Type ЁЭУЪ}
    тЖТ (тИА b тЖТ U b тИИ gSubU.S K)
    тЖТ (h : ╬а A (U тИШ f))
    тЖТ is-singleton (Ext f h))
    тЖТ up-connected-map K f
up-connected-mapтЖРunique-extensions K f ext {U = U} UтИИK
  = is-equivтЖРhas-singleton-fibres ╬╗ h
    тЖТ is-singleтЖРequiv-to-single
        (╬г-ap-тЙГ (╬╗ _ тЖТ funextтЙГ eтБ╗┬╣))
        (ext UтИИK h)
}
}

\subtree[stt-00MG]{
\date{2026-03-19}
\author{fredrikbakke}
\taxon{Lemma}
\title{Terminal projection and constant map criteria on fibres}

\p{
For the fibres of a map, asking that the terminal projections be #{K}-equivalences is
equivalent to asking that the fibres satisfy the universal property of
#{K}-connected types.
}

\agda{
up-connected-fibresтЖРup-connected-!-fibres
  : тИА {╬▒ ЁЭУд ЁЭУе} (K : gSubU ╬▒)
      {A : Type ЁЭУд} {B : Type ЁЭУе}
      (f : A тЖТ B)
    тЖТ up-connected-!-fibre K f
    тЖТ up-connected-fibres K f
up-connected-fibresтЖРup-connected-!-fibres K f fib-eq b UтИИK
  = is-equiv-constтЖРprecomp-! (fib-eq b UтИИK)

up-connected-!-fibresтЖРup-connected-fibres
  : тИА {╬▒ ЁЭУд ЁЭУе} (K : gSubU ╬▒)
      {A : Type ЁЭУд} {B : Type ЁЭУе}
      (f : A тЖТ B)
    тЖТ up-connected-fibres K f

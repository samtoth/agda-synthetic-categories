\subtree[fre-00N1]{
\title{Rezk completeness}
\taxon{Definition}
\author{fredrikbakke}

\agda{
fam-is-rezk-complete : ūĚüô ‚Üí ‚ĄĎ ‚Üí ūĚüôŠīł: ūĚďė
fam-is-rezk-complete _ = !Šīł

is-rezk-complete
  : ‚ąÄ {ūĚď§}
  ‚Üí (A : Type ūĚď§)
  ‚Üí Type (ūĚďė ‚äĒ ūĚď§)
is-rezk-complete A
  = is-local fam-is-rezk-complete A

is-rezk-complete-is-prop
  : ‚ąÄ {ūĚď§} {A : Type ūĚď§}
  ‚Üí is-prop (is-rezk-complete A)
is-rezk-complete-is-prop {A = A}
  = is-local-is-prop A
}

\agda{
RezkCompl-SubU : ‚ąÄ {ūĚď§} ‚Üí SubU ūĚď§ (ūĚď§ ‚äĒ ūĚďė)
RezkCompl-SubU = Local-SubU fam-is-rezk-complete _

RezkCompl-gSubU : gSubU (_‚äĒ ūĚďė)
RezkCompl-gSubU = Local-gSubU fam-is-rezk-complete

RezkCompl-is-globally-reflective
  : is-globally-reflective RezkCompl-gSubU
RezkCompl-is-globally-reflective = Local-global-reflectors fam-is-rezk-complete

RezkCompl-gRSubU : gRSubU (_‚äĒ ūĚďė)
RezkCompl-gRSubU .gRSubU.GS = RezkCompl-gSubU
RezkCompl-gRSubU .gRSubU.GS-is-globally-reflective = RezkCompl-is-globally-reflective

open gSubU RezkCompl-gSubU public using () renaming
  ( ‚ąąS‚Üźequiv to is-rezk-complete‚Üźequiv)
open gReflectiveClosure RezkCompl-gRSubU public using () renaming
  ( ő†‚ąąS to ő†-is-rezk-complete
  ; ULift‚ąąS to ULift-is-rezk-complete
  ; ūĚüô‚ąąS to ūĚüô-is-rezk-complete
  ; ‚ąąS‚Üźis-singleton to is-rezk-complete‚Üźis-singleton
  ; ‚ąąS‚Üźretract to is-rezk-complete‚Üźretract
  ; Pullback‚ąąS to Pullback-is-rezk-complete
  ; fibre‚ąąS to fibre-is-rezk-complete
  ; Ext‚ąąS to Ext-is-rezk-complete
  ; √ó‚ąąS to √ó-is-rezk-complete
  ; ÔľĚ‚ąąS to ÔľĚ-is-rezk-complete
  ; ~‚ąąS to ~-is-rezk-complete
  ; retract‚ąąS to retract-is-rezk-complete
  ; biinv‚ąąS to biinv-is-rezk-complete
  ; ‚ČÉ‚ąąS to ‚ČÉ-is-rezk-complete
  ; Equaliser‚ąąS to Equaliser-is-rezk-complete
  ; Seq-lim‚ąąS to Seq-lim-is-rezk-complete
  ; preidempotent-map‚ąąS to preidempotent-map-is-rezk-complete
  ; qidempotent-map‚ąąS to qidempotent-map-is-rezk-complete
  ; idempotent-map‚ąąS to idempotent-map-is-rezk-complete
  ; Retracts‚ąąS to Retracts-is-rezk-complete)
open gRSubUHomClosure RezkCompl-gRSubU public using () renaming
  ( Hom‚ąąS to Hom-is-rezk-complete)

module RezkCompl where
  open gRSubU RezkCompl-gRSubU public
  open gReflectiveClosure RezkCompl-gRSubU public
  open gRSubUHomClosure RezkCompl-gRSubU public
}
}


\subtree[fre-00OH]{
\title{Rezk types}
\taxon{Definition}
\author{fredrikbakke}

\agda{
fam-is-complete-segal : ‚®Ą‚āĀŠ∂†-carrier (point őõ[2,1]-incl) (point (!Šīł: ūĚďė ‚ĄĎ))
fam-is-complete-segal = point őõ[2,1]-incl ‚®Ą‚āĀŠ∂† point (!Šīł: ūĚďė ‚ĄĎ)

is-complete-segal : ‚ąÄ {ūĚď§} ‚Üí Type ūĚď§ ‚Üí Type (ūĚďė ‚äĒ ūĚď§)
is-complete-segal A = is-local fam-is-complete-segal A

module _  {ūĚď§ : Level} {A : Type ūĚď§}  where

  is-complete-segal-is-prop : is-prop (is-complete-segal A)
  is-complete-segal-is-prop = is-local-is-prop A

  is-segal√óis-rezk-complete‚Üźis-complete-segal
    : is-complete-segal A ‚Üí is-segal A √ó is-rezk-complete A
  is-segal√óis-rezk-complete‚Üźis-complete-segal = √ó-is-local‚Üźis-local-‚®Ą‚āĀŠ∂†

  is-complete-segal‚Üźis-segal‚Üźis-rezk-complete
    : is-segal A ‚Üí is-rezk-complete A ‚Üí is-complete-segal A
  is-complete-segal‚Üźis-segal‚Üźis-rezk-complete = is-local-‚®Ą‚āĀŠ∂†‚Üźis-local
}


\subtree[fre-00OI]{
\title{Categories}
\taxon{Definition}
\author{fredrikbakke}

\p{
A type is a \em{category} if it is simplicial and a complete Segal type.
}

\agda{
fam-is-category : ‚®Ą‚āĀŠ∂†-carrier fam-is-precategory (point (!Šīł: ūĚďė ‚ĄĎ))
fam-is-category = fam-is-precategory ‚®Ą‚āĀŠ∂† (point (!Šīł: ūĚďė ‚ĄĎ))

is-category
  : ‚ąÄ {ūĚď§} ‚Üí Type ūĚď§ ‚Üí Type (ūĚďė ‚äĒ ūĚď§)
is-category A = is-local fam-is-category A

module _ {ūĚď§} {A : Type ūĚď§} where

  is-category-is-prop  : is-prop (is-category A)
  is-category-is-prop = is-local-is-prop A

  is-precategory√óis-rezk-complete‚Üźis-category
    : is-category A ‚Üí is-precategory A √ó is-rezk-complete A
  is-precategory√óis-rezk-complete‚Üźis-category
    = √ó-is-local‚Üźis-local-‚®Ą‚āĀŠ∂†

  is-precategory‚Üźis-category
    : is-category A ‚Üí is-precategory A
  is-precategory‚Üźis-category Acat
    = is-precategory√óis-rezk-complete‚Üźis-category Acat .fst

  is-simplicial‚Üźis-category
    : is-category A ‚Üí is-simplicial A
  is-simplicial‚Üźis-category
    = is-simplicial‚Üźis-precategory ‚ąė is-precategory‚Üźis-category

  is-triangulated‚Üźis-category
    : is-category A ‚Üí is-triangulated A
  is-triangulated‚Üźis-category
    = simp-is-triangulated ‚ąė is-simplicial‚Üźis-category

  is-rezk-complete‚Üźis-category
    : is-category A ‚Üí is-rezk-complete A
  is-rezk-complete‚Üźis-category Acat
    = is-precategory√óis-rezk-complete‚Üźis-category Acat .snd

  is-category‚Üźis-precategory‚Üźis-rezk-complete
    : is-precategory A ‚Üí is-rezk-complete A ‚Üí is-category A
  is-category‚Üźis-precategory‚Üźis-rezk-complete
    = is-local-‚®Ą‚āĀŠ∂†‚Üźis-local

  is-category‚Üźis-segal√óis-simplicial√óis-rezk-complete
    : is-segal A ‚Üí is-simplicial A ‚Üí is-rezk-complete A ‚Üí is-category A
  is-category‚Üźis-segal√óis-simplicial√óis-rezk-complete A-is-segal A-is-simplicial
    = is-category‚Üźis-precategory‚Üźis-rezk-complete
        (is-precategory‚Üźis-segal‚Üźis-simplicial A-is-segal A-is-simplicial)

  is-complete-segal√óis-simplicial‚Üźis-category
    : is-category A ‚Üí is-complete-segal A √ó is-simplicial A
  is-complete-segal√óis-simplicial‚Üźis-category Acat
    = is-complete-segal‚Üźis-segal‚Üźis-rezk-complete
        (is-segal‚Üźis-precategory (is-precategory‚Üźis-category Acat))
        (is-rezk-complete‚Üźis-category Acat)
    , is-simplicial‚Üźis-category Acat

  is-category‚Üźis-complete-segal√óis-simplicial
    : is-complete-segal A √ó is-simplicial A ‚Üí is-category A
  is-category‚Üźis-complete-segal√óis-simplicial (Arzk , A-is-simplicial)
    = is-category‚Üźis-segal√óis-simplicial√óis-rezk-complete
        (is-segal√óis-rezk-complete‚Üźis-complete-segal Arzk .fst)
        (A-is-simplicial)
        (is-segal√óis-rezk-complete‚Üźis-complete-segal Arzk .snd)

  is-category‚ČÉis-complete-segal√óis-simplicial
    : is-category A ‚ČÉ (is-complete-segal A √ó is-simplicial A)
  is-category‚ČÉis-complete-segal√óis-simplicial
    = equiv‚Üźlogical
        is-category-is-prop
        ( √ó-is-prop is-complete-segal-is-prop (is-null-is-prop A))
        ( is-complete-segal√óis-simplicial‚Üźis-category
        , is-category‚Üźis-complete-segal√óis-simplicial)
}

\agda{
Category-SubU : ‚ąÄ {ūĚď§} ‚Üí SubU ūĚď§ (ūĚď§ ‚äĒ ūĚďė)
Category-SubU = Local-SubU fam-is-category _

Category-gSubU : gSubU (_‚äĒ ūĚďė)
Category-gSubU = Local-gSubU fam-is-category

Category-is-globally-reflective
  : is-globally-reflective Category-gSubU
Category-is-globally-reflective = Local-global-reflectors fam-is-category

Category-gRSubU : gRSubU (_‚äĒ ūĚďė)
Category-gRSubU .gRSubU.GS = Category-gSubU
Category-gRSubU .gRSubU.GS-is-globally-reflective = Category-is-globally-reflective

open gSubU Category-gSubU public using () renaming
  ( ‚ąąS‚Üźequiv to is-category‚Üźequiv)
open gReflectiveClosure Category-gRSubU public using () renaming
  ( ő†‚ąąS to ő†-is-category
  ; ULift‚ąąS to ULift-is-category
  ; ūĚüô‚ąąS to ūĚüô-is-category
  ; ‚ąąS‚Üźis-singleton to is-category‚Üźis-singleton
  ; ‚ąąS‚Üźretract to is-category‚Üźretract
  ; Pullback‚ąąS to Pullback-is-category
  ; fibre‚ąąS to fibre-is-category
  ; Ext‚ąąS to Ext-is-category
  ; √ó‚ąąS to √ó-is-category
  ; ÔľĚ‚ąąS to ÔľĚ-is-category
  ; ~‚ąąS to ~-is-category
  ; retract‚ąąS to retract-is-category
  ; biinv‚ąąS to biinv-is-category
  ; ‚ČÉ‚ąąS to ‚ČÉ-is-category
  ; Equaliser‚ąąS to Equaliser-is-category
  ; Seq-lim‚ąąS to Seq-lim-is-category
  ; preidempotent-map‚ąąS to preidempotent-map-is-category
  ; qidempotent-map‚ąąS to qidempotent-map-is-category
  ; idempotent-map‚ąąS to idempotent-map-is-category
  ; Retracts‚ąąS to Retracts-is-category)
open gRSubUHomClosure Category-gRSubU public using () renaming
  ( Hom‚ąąS to Hom-is-category)

module Cat where
  open gRSubU Category-gRSubU public
  open gReflectiveClosure Category-gRSubU public
  open gRSubUHomClosure Category-gRSubU public

Category-U : (ūĚď§ : Level) ‚Üí Type (lsuc (ūĚďė ‚äĒ ūĚď§))
Category-U ūĚď§ = ő£[ A ‚ą∂ Type (ūĚďė ‚äĒ ūĚď§) ] is-category A

Category-U-is-simplicial
  : {ūĚď§ : Level} ‚Üí is-simplicial (Category-U ūĚď§)
Category-U-is-simplicial {ūĚď§}
  = is-simplicial‚Üźequiv
      ((ő£-snd-‚ČÉ őĽ A ‚Üí is-category‚ČÉis-complete-segal√óis-simplicial {A = A}) e‚ĀĽ¬Ļ)
      (Null-in-gSubU-is-null‚Üźis-prop

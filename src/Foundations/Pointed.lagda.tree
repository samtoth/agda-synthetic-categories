\date{2026-03-28}
\title{Pointed types}
\taxon{Module}
\author{fredrikbakke}
\import{stt-macros}

% ```agda
\agda{
module Foundations.Pointed where

open import Foundations.Universes
open import Foundations.Identity
open import Foundations.Sigma

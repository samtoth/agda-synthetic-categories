\date{2026-05-27}
\title{Morphisms of polynomial endofunctors on types}
\author{fredrikbakke}
\import{stt-macros}
\taxon{Module}

\agda{
module Wild.MorphismsPolynomialEndofunctors where

open import Wild.PolynomialEndofunctors

open import Foundations.Universes
open import Foundations.Sigma
open import Foundations.Functions
open import Foundations.TypeFamilies
}

\subtree[fre-QWOY]{
\title{Morphisms of polynomial endofunctors}
\taxon{Definition}
\author{fredrikbakke}

\p{
Given two polynomial endofunctors #{P \coloneqq (A \mathbin{вЧГ} B)} and
#{Q \coloneqq (C \mathbin{вЧГ} D)}, then a \em{morphism} from #{P} to #{Q} is a map
#{f : A \to C} together with a family of maps #{g : \Pi_{(a : A)}(D(f(a)) \to B(a))}.
}

\p{
Such a morphism induces a natural transformation of functors, but it is not provable
that such data is equivalent to the data of a natural transformation. In general,
morphisms of polynomial endofunctors are better behaved.
}

\p{
Notice that morphisms of polynomial endofunctors are \em{not} the same as morphisms
of their underlying [type families](Foundation.TypeFamilies), even though a
polynomial endofunctor is defined to be just a type family. This is because, in the
action of a polynomial endofunctor, the positions appear in a negative position of
the type signature. Therefore, the map on positions (above #{g}) goes the opposite
way compared to a morphism of type families.
}

\p{
Beware also that some authors take morphisms of polynomial endofunctors to mean
\em{cartesian morphisms}, which are morphisms whose family of maps on positions is a
family of equivalences. We do not use this convention, and reserve the term
\em{cartesian morphism} for such morphisms.
}

\agda{
module _
  {рЭУ§1 рЭУ§2 рЭУ•1 рЭУ•2 : Level}
  (P@(A вЧГ B) : рЭСГ рЭУ§1 рЭУ§2)
  (Q@(C вЧГ D) : рЭСГ рЭУ•1 рЭУ•2)
  where

  record HomрЭСГ : Type (рЭУ§1 вКФ рЭУ§2 вКФ рЭУ•1 вКФ рЭУ•2) where
    constructor mk-HomрЭСГ
    field
      shp : A вЖТ C
      pos : (a : A) вЖТ D (shp a) вЖТ B a

  open HomрЭСГ
}
}

\subtree[fre-QW03]{
\taxon{Definition}
\title{Composition of morphisms of polynomial endofunctors}
\author{fredrikbakke}

\agda{
id-HomрЭСГ
  : {рЭУ§1 рЭУ§2 : Level} (P : рЭСГ рЭУ§1 рЭУ§2) вЖТ HomрЭСГ P P
id-HomрЭСГ P = mk-HomрЭСГ id (ќї a вЖТ id)

infixr 40 _вИШHomрЭСГ_

_вИШHomрЭСГ_
  : {рЭУ§1 рЭУ§2 рЭУ•1 рЭУ•2 рЭУ¶1 рЭУ¶2 : Level}
  вЖТ {P : рЭСГ рЭУ§1 рЭУ§2} {Q : рЭСГ рЭУ•1 рЭУ•2} {R : рЭСГ рЭУ¶1 рЭУ¶2}
  вЖТ HomрЭСГ Q R вЖТ HomрЭСГ P Q вЖТ HomрЭСГ P R
G вИШHomрЭСГ F
  = mk-HomрЭСГ
      ( G .HomрЭСГ.shp вИШ F .HomрЭСГ.shp)
      ( ќї a вЖТ F .HomрЭСГ.pos a вИШ G .HomрЭСГ.pos (F .HomрЭСГ.shp a))

concat-HomрЭСГ
  : {рЭУ§1 рЭУ§2 рЭУ•1 рЭУ•2 рЭУ¶1 рЭУ¶2 : Level}
  вЖТ {P : рЭСГ рЭУ§1 рЭУ§2} {Q : рЭСГ рЭУ•1 рЭУ•2} {R : рЭСГ рЭУ¶1 рЭУ¶2}
  вЖТ HomрЭСГ P Q вЖТ HomрЭСГ Q R вЖТ HomрЭСГ P R
concat-HomрЭСГ F G = G вИШHomрЭСГ F
}
}

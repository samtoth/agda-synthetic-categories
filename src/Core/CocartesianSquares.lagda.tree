\subtree[stt-007V]{
\title{Co-cartesian squares}
\taxon{Definition}

\p{Given a square:}

\quiver{
\begin{tikzcd}
	A && X \\
	\\
	B && Y
	\arrow["{f'}", from=1-1, to=1-3]
	\arrow["f"', from=1-1, to=3-1]
	\arrow["g", from=1-3, to=3-3]
	\arrow["{g'}"', from=3-1, to=3-3]
\end{tikzcd}
}

\p{we say that the square is cocartesian if the square [given by
precomposition](stt-003P) is a [cartesian square](stt-003V).}

\agda{
up-cocartesian'
  : ‚ąÄ {ūĚď§ ūĚď• ūĚď¶ ūĚďú} {A : Type ūĚď§} {B : Type ūĚď•}
      {X : Type ūĚď¶} {Y : Type ūĚďú}
      {f : A ‚Üí B} {g : X ‚Üí Y}
    ‚Üí Arrow-map f g ‚Üí (ūĚď† : Level)
    ‚Üí Type (ūĚď§ ‚äĒ ūĚď• ‚äĒ ūĚď¶ ‚äĒ ūĚďú ‚äĒ lsuc ūĚď†)
up-cocartesian' F ūĚď† = ‚ąÄ (Q : Type ūĚď†)
                     ‚Üí is-cartesian (precomp-square F Q)


up-cocartesian
  : ‚ąÄ {ūĚď§ ūĚď• ūĚď¶ ūĚďú} {A : Type ūĚď§} {B : Type ūĚď•}
      {X : Type ūĚď¶} {Y : Type ūĚďú}
      {f : A ‚Üí B} {g : X ‚Üí Y}
    ‚Üí Arrow-map f g
    ‚Üí TypeŌČ
up-cocartesian F = ‚ąÄ {ūĚď†} (Q : Type ūĚď†)
                    ‚Üí is-cartesian (precomp-square F Q)
}
}

\subtree[stt-007W]{
\title{Cocartesian squares are pushouts}
\taxon{Theorem}

\proof{An easy consequence of \ref{stt-003C} and \ref{stt-007Y}}

\agda{
up-pushout‚Üźup-cocartesian
  : ‚ąÄ {ūĚď§ ūĚď• ūĚď¶ ūĚďú} {A : Type ūĚď§} {B : Type ūĚď•}
      {X : Type ūĚď¶} {Y : Type ūĚďú}
      {f : A ‚Üí B} {g : X ‚Üí Y}
      (F : Arrow-map f g)
    ‚Üí up-cocartesian F ‚Üí up-pushout _ (Cocone‚ÜźArrow-map F .snd)
up-pushout‚Üźup-cocartesian {f = f} {g} F cc
  = up-pushout‚Üźprecomp-pullback _
       (őĽ Q ‚Üí up-pullback‚Üźis-cartesian (precomp-square F Q) (cc Q))

up-cocartesian‚Üźup-pushout
  : ‚ąÄ {ūĚď§ ūĚď• ūĚď¶ ūĚďú} {S : Span ūĚď§ ūĚď• ūĚď¶} {D : Type ūĚďú} {C : Cocone S D}
    ‚Üí up-pushout S C ‚Üí up-cocartesian (Arrow-map‚ÜźCocone C)
up-cocartesian‚Üźup-pushout po Q
  = is-cartesian‚Üźup-pullback
      (precomp-square (Arrow-map‚ÜźCocone _) Q)
      (precomp-pullback‚Üźup-pushout _ po Q)
}
}


\subtree[stt-00CQ]{
\title{The mirror of a cocartesian square is cocartesian}
\taxon{Lemma}

\agda{
transpose-square-has-up-cocartesian
  : ‚ąÄ {ūĚď§ ūĚď• ūĚď¶ ūĚďú} {A : Type ūĚď§} {B : Type ūĚď•}
      {X : Type ūĚď¶} {Y : Type ūĚďú}
      {f : A ‚Üí B} {g : X ‚Üí Y}
      (F : Arrow-map f g)
    ‚Üí up-cocartesian F ‚Üí up-cocartesian (transpose-square F)
transpose-square-has-up-cocartesian F cocart
  = up-cocartesian‚Üźup-pushout
     (up-pushout‚Üźis-pushout _
      (is-equiv-~‚ąė
        {f = cogap-map‚Üźsquare F}
        {g = pushout-flip}
        (sym ‚ąė pushout-rec-unique _ _ hrefl hrefl
          (őĽ a ‚Üí ‚ąô-reflr _ ‚ąô ap-‚ąė (cogap-map‚Üźsquare F) (pushout-flip) (glue a)
          ‚ąô ap (ap _) (pushout-rec-apő≤ a) ‚ąô ap-sym _ (glue a)
          ‚ąô ap sym (pushout-rec-apő≤ a)))
        (is-pushout‚Üźup-pushout _ (up-pushout‚Üźup-cocartesian _ cocart))
        (pushout-comm ._‚ČÉ_.fwd-is-equiv)))

transpose-is-idempotent-cube
  : ‚ąÄ {ūĚď§ ūĚď• ūĚď¶ ūĚďú} {A : Type ūĚď§} {B : Type ūĚď•}
      {X : Type ūĚď¶} {Y : Type ūĚďú}
      {f : A ‚Üí B} {g : X ‚Üí Y}
      (F : Arrow-map f g)
      {ūĚď†} (Q : Type ūĚď†)
    ‚Üí Cube
        (precomp-square (transpose-square (transpose-square F)) Q)
        (precomp-square F Q)
transpose-is-idempotent-cube F Q .Cube.left = id-square
transpose-is-idempotent-cube F Q .Cube.right = id-square
transpose-is-idempotent-cube F Q .Cube.comm .fst = hrefl
transpose-is-idempotent-cube F Q .Cube.comm .snd .fst = hrefl
transpose-is-idempotent-cube F Q .Cube.comm .snd .snd a
  = ap (_‚ąô refl)
       (sym (ap-id _ ‚ąô ap funext‚Üí (funext‚Üí (őĽ x ‚Üí ap (ap a) sym-sym))))

transpose-is-idempotent
  : ‚ąÄ {ūĚď§ ūĚď• ūĚď¶ ūĚďú} {A : Type ūĚď§} {B : Type ūĚď•}
      {X : Type ūĚď¶} {Y : Type ūĚďú}
      {f : A ‚Üí B} {g : X ‚Üí Y}
      (F : Arrow-map f g)
      {ūĚď†} (Q : Type ūĚď†)
    ‚Üí is-Cube-equiv (transpose-is-idempotent-cube F Q)
transpose-is-idempotent {f = f} {g} F Q .fst
  = id-square-is-equiv {f = precomp Q g}
transpose-is-idempotent {f = f} {g} F Q .snd
  = id-square-is-equiv {f = precomp Q f}

untranspose-square-has-up-cocartesian
  : ‚ąÄ {ūĚď§ ūĚď• ūĚď¶ ūĚďú} {A : Type ūĚď§} {B : Type ūĚď•}
      {X : Type ūĚď¶} {Y : Type ūĚďú}
      {f : A ‚Üí B} {g : X ‚Üí Y}
      (F : Arrow-map f g)
    ‚Üí up-cocartesian (transpose-square F)
    ‚Üí up-cocartesian F
untranspose-square-has-up-cocartesian F rFcc Q
  = back-cartesian‚Üźequiv-cube
      {F = (precomp-square (transpose-square (transpose-square F)) Q)}
      {G = precomp-square F Q}
      (transpose-is-idempotent-cube F Q)
      (transpose-is-idempotent F Q)
      (transpose-square-has-up-cocartesian _ rFcc Q)
}
}

\subtree[stt-00BT]{
\title{Canonical pushouts are cocartesian squares}
\taxon{Corollary}

\agda{
Pushout-square
  : ‚ąÄ {ūĚď§ ūĚď• ūĚď¶} (S : Span ūĚď§ ūĚď• ūĚď¶) ‚Üí let open Span S
    in Arrow-map left {D = Pushout left right} őĻ‚āā
Pushout-square S .Arrow-map.top = S .Span.right
Pushout-square S .Arrow-map.bot = őĻ‚āĀ
Pushout-square S .Arrow-map.comm = glue

Pushout-square-has-up-cocartesian
  : ‚ąÄ {ūĚď§ ūĚď• ūĚď¶} (S : Span ūĚď§ ūĚď• ūĚď¶) ‚Üí up-cocartesian (Pushout-square S)
Pushout-square-has-up-cocartesian S = up-cocartesian‚Üźup-pushout Pushout-has-up-pushout

Pushout-square'
  : ‚ąÄ {ūĚď§ ūĚď• ūĚď¶} (S : Span ūĚď§ ūĚď• ūĚď¶) ‚Üí let open Span S
    in Arrow-map right {D = Pushout left right} őĻ‚āĀ
Pushout-square' S = transpose-square (Pushout-square S)

Pushout-square'-has-up-cocartesian
  : ‚ąÄ {ūĚď§ ūĚď• ūĚď¶} (S : Span ūĚď§ ūĚď• ūĚď¶) ‚Üí up-cocartesian (Pushout-square' S)
Pushout-square'-has-up-cocartesian S = transpose-square-has-up-cocartesian _
                                     (up-cocartesian‚Üźup-pushout
                                       Pushout-has-up-pushout)
}
}

\subtree[stt-0080]{
\title{Pushouts squares of equivalences}
\taxon{Theorem}

\p{Given an equivalence #{f} and any map #{g}, together with a
square #{f \to g}, the square is cocartesian iff #{g} is an
equivalence.}

\proof{
\p{We have the following square given by precomposition:}
\quiver{
\begin{tikzcd}
	{Q^Y} &&& {Q^B} \\
	& \bullet \\
	\\
	{Q^X} &&& {Q^A}
	\arrow["{Q^b}", from=1-1, to=1-4]
	\arrow["{\rm{gap}}", dashed, from=1-1, to=2-2]
	\arrow["{Q^g}"', from=1-1, to=4-1]
	\arrow["{Q^f}", from=1-4, to=4-4]
	\arrow[from=2-2, to=1-4]
	\arrow["\sim", from=2-2, to=4-1]
	\arrow["\lrcorner"{anchor=center, pos=0.125}, draw=none, from=2-2, to=4-4]
	\arrow["{Q^t}"', from=4-1, to=4-4]
\end{tikzcd}
}

\p{By \ref{stt-007Z}, the projection from the pullback to #{Q^X} is an
equivalence because #{Q^f} is. Then we have a triangle which, by the
[3 for 2](stt-003E) property, shows that #{Q^g} is an equivalence iff
the gap map is.}
}

\agda{
cocartesian‚Üźequiv-map
  : ‚ąÄ {ūĚď§ ūĚď• ūĚď¶ ūĚďú} {A : Type ūĚď§} {B : Type ūĚď•} {X : Type ūĚď¶}
      {Y : Type ūĚďú} {f : A ‚Üí B} {g : X ‚Üí Y}
      (F : Arrow-map f g)
    ‚Üí is-equiv f
    ‚Üí is-equiv g
    ‚Üí up-cocartesian F
cocartesian‚Üźequiv-map F feq geq Q
  = is-cartesian‚Üźup-pullback (precomp-square F Q)
      (up-pullback‚Üźis-pullback (Cone‚ÜźArrow-map (precomp-square F Q) .snd)
        (3-for-2
           (pullback-equiv‚āĀ (precomp-equiv feq))
           (precomp-equiv geq))) where
  module F = Arrow-map F

dom-is-equiv‚Üźcocartesian
  : ‚ąÄ {ūĚď§ ūĚď• ūĚď¶ ūĚďú} {A : Type ūĚď§} {B : Type ūĚď•} {X : Type ūĚď¶}
      {Y : Type ūĚďú} {f : A ‚Üí B} {g : X ‚Üí Y}
      (F : Arrow-map f g)
    ‚Üí is-equiv f
    ‚Üí up-cocartesian F
    ‚Üí is-equiv g
dom-is-equiv‚Üźcocartesian F feq cart = is-equiv‚Üźprecomp _
  őĽ {_} {Q} ‚Üí is-equiv-‚ąė
      (pullback-equiv‚āĀ (precomp-equiv feq))
      (is-pullback‚Üźup-pullback
        (Cone‚ÜźArrow-map (precomp-square F Q) .snd)
        (up-pullback‚Üźis-cartesian _ (cart Q)))
}
}

\subtree[stt-00EC]{
\title{Pasting for cocartesian squares}
\taxon{Lemma}

\p{Given a pair of squares, as follows: }

\quiver{
\begin{tikzcd}
	\bullet && \bullet && \bullet \\
	\\
	\bullet && \bullet && \bullet
	\arrow[from=1-1, to=1-3]
	\arrow[from=1-1, to=3-1]
	\arrow[from=1-3, to=1-5]
	\arrow[from=1-3, to=3-3]
	\arrow[from=1-5, to=3-5]
	\arrow[from=3-1, to=3-3]
	\arrow["\lrcorner"{anchor=center, pos=0.125, rotate=180}, draw=none, from=3-3, to=1-1]
	\arrow[from=3-3, to=3-5]
\end{tikzcd}
}

\p{The right square is a pushout iff the whole square is.}

\proof{
\p{Call the first square #{F} and the second #{G}. Then we first prove that
#{Q^{F \circ G} \sim Q^G \circ Q^F}. Then the result follows from the
[analogous theorem](stt-003W) for [cartesian squares](stt-003V). Note however,
that the contravariance of taking the postcomposition square means that
cartesian squares are right cancelative, so cocartesian squares must be left
cancelative.}
}

\agda{
precomp-square-‚ąė
  : ‚ąÄ {ūĚď§ ūĚď• ūĚď¶ ūĚďú ūĚďĚ ūĚďõ} {A : Type ūĚď§} {B : Type ūĚď•} {X : Type ūĚď¶} {Y : Type ūĚďú}
      {U : Type ūĚďĚ} {V : Type ūĚďõ} {f : A ‚Üí B} {g : X ‚Üí Y} {h : U ‚Üí V}
      (F : Arrow-map g h) (G : Arrow-map f g)
      {ūĚď†} (Q : Type ūĚď†)
    ‚Üí Arrow-map-path
        (paste-squares (precomp-square G Q) (precomp-square F Q))
        (precomp-square (paste-squares F G) Q)
precomp-square-‚ąė F G Q .fst = hrefl
precomp-square-‚ąė F G Q .snd .fst = hrefl
precomp-square-‚ąė {f = f} {g} {h} F G Q .snd .snd
 = comm (paste-squares (precomp-square G Q) (precomp-square F Q)) ‚ąôh hrefl
       ~‚ü® ‚ąôh-reflr _ ‚ü©
   comm (paste-squares (precomp-square G Q) (precomp-square F Q))
       ~‚ü®‚ü©
    (precomp Q (G .top) ‚óā precomp-square F Q .comm
    ‚ąôh precomp-square G Q .comm ‚Ėł precomp Q (F .bot))
       ~‚ü®‚ü©
    (precomp Q (G .top) ‚óā (funext‚Üí ‚ąė (_‚óā (comm F h‚ĀĽ¬Ļ)))
    ‚ąôh (funext‚Üí ‚ąė (_‚óā (comm G h‚ĀĽ¬Ļ))) ‚Ėł precomp Q (F .bot))
       ~‚ü® (őĽ a ‚Üí ap (_‚ąô funext‚Üí _)
         (sym (commutes-prewhisker-funext (a ‚óā (comm F h‚ĀĽ¬Ļ))))
         ‚ąô sym (funext-‚ąô _ _)) ‚ü©
   funext‚Üí ‚ąė (őĽ a ‚Üí a ‚óā (sym ‚ąė comm F ‚ąė top G) ‚ąôh (a ‚ąė F .bot) ‚óā (sym ‚ąė comm G))
       ~‚ü® (őĽ a ‚Üí ap funext‚Üí (funext‚Üí őĽ x
         ‚Üí ap (ap a (sym (comm F _)) ‚ąô_)
             ( ‚óā‚ąė  a (bot F) (sym ‚ąė comm G) x)
             ‚ąô sym (ap-‚ąô a (sym (comm F (top G x))) (ap (bot F) _))
             ‚ąô ap (ap a) (sym (‚ąô-symsym (ap (bot F) (comm G x)) _
             ‚ąô ap (sym (comm F (top G x)) ‚ąô_)
                  (sym (ap-sym (bot F) (comm G x))))))) ‚ü©
   funext‚Üí ‚ąė (őĽ a ‚Üí a ‚óā ((F .bot ‚óā comm G ‚ąôh comm F ‚Ėł G .top) h‚ĀĽ¬Ļ))
       ~‚ü®‚ü©
   comm (precomp-square (paste-squares F G) Q) ~‚ąé where open Arrow-map

opaque
  cocartesian-square-‚ąė
    : ‚ąÄ {ūĚď§ ūĚď• ūĚď¶ ūĚďú ūĚďĚ ūĚďõ} {A : Type ūĚď§} {B : Type ūĚď•} {X : Type ūĚď¶} {Y : Type ūĚďú}
        {U : Type ūĚďĚ} {V : Type ūĚďõ} {f : A ‚Üí B} {g : X ‚Üí Y} {h : U ‚Üí V}
        {F : Arrow-map g h} {G : Arrow-map f g}
      ‚Üí up-cocartesian F ‚Üí up-cocartesian G
      ‚Üí up-cocartesian (paste-squares F G)
  cocartesian-square-‚ąė {F = F} {G} fc gc Q
    = tr is-cartesian (Arrow-map-path‚Üí (precomp-square-‚ąė F G Q))
        (compose-cartesian (gc Q) (fc Q))

  cocartesian-square-cancel
    : ‚ąÄ {ūĚď§ ūĚď• ūĚď¶ ūĚďú ūĚďĚ ūĚďõ} {A : Type ūĚď§} {B : Type ūĚď•} {X : Type ūĚď¶} {Y : Type ūĚďú}
        {U : Type ūĚďĚ} {V : Type ūĚďõ} {f : A ‚Üí B} {g : X ‚Üí Y} {h : U ‚Üí V}
        {F : Arrow-map g h} {G : Arrow-map f g}
      ‚Üí up-cocartesian G ‚Üí up-cocartesian (paste-squares F G)
      ‚Üí up-cocartesian F
  cocartesian-square-cancel {F = F} {G = G} Gc FGc Q
    = 3-for-2-cartesian
        {a = precomp-square G Q}
        {b = precomp-square F Q}
        (Arrow-map-path‚Üźid (sym (Arrow-map-path‚Üí (precomp-square-‚ąė F G Q))))
        (FGc Q)
        (Gc Q)
}
}

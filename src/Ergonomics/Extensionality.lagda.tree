\agda{
module Ergonomics.Extensionality where

open import Foundations.Prelude
open import Foundations.IdentitySystem public
open import Foundations.Subtypes
open import Foundations.SingletonFibres

open import UF
open Identity-system ‚¶É ... ‚¶Ą public
module Reasoning {ūĚď§ ūĚď•} {A : Type ūĚď§} ‚¶É S : Identity-system A ūĚď• ‚¶Ą where
  open IdSReasoning S public

open Reasoning public

instance
  IdS-default : ‚ąÄ {ūĚď§} {A : Type ūĚď§} ‚Üí Identity-system A ūĚď§
  IdS-default .IdS = _ÔľĚ_
  IdS-default .IdS‚ÜźId = id
  IdS-default .has-is-ids a _ = id-is-equiv

{-# INCOHERENT IdS-default #-}

instance
  IdS-ő†
    : ‚ąÄ {ūĚď§ ūĚď• ūĚď¶} {A : Type ūĚď§} {B : A ‚Üí Type ūĚď•}
      ‚Üí ‚¶É _ : ‚ąÄ {a} ‚Üí Identity-system (B a) ūĚď¶ ‚¶Ą
      ‚Üí Identity-system ((a : A) ‚Üí B a) (ūĚď§ ‚äĒ ūĚď¶)
  IdS-ő† ‚¶É s ‚¶Ą .IdS f g = ‚ąÄ a ‚Üí s .IdS (f a) (g a)
  IdS-ő† ‚¶É s ‚¶Ą .IdS‚ÜźId p a = IdS‚ÜźId (happly p a)
  IdS-ő† {A = A} {B = B} ‚¶É s ‚¶Ą .has-is-ids f
    = fundamental-Id _
        ((is-single‚Üźequiv-to-single (ő£-ő†-swap‚ČÉ B (őĽ x bx ‚Üí s .IdS (f _) bx))
                                    (weak-funext (őĽ a ‚Üí SingS-is-single (f a)
                                    )))) _

{-# OVERLAPPABLE IdS-ő† #-}

instance
  IdS-ő†i
    : ‚ąÄ {ūĚď§ ūĚď• ūĚď¶} {A : Type ūĚď§} {B : A ‚Üí Type ūĚď•}
      ‚Üí ‚¶É _ : ‚ąÄ {a} ‚Üí Identity-system (B a) ūĚď¶ ‚¶Ą
      ‚Üí Identity-system ({a : A} ‚Üí B a) (ūĚď§ ‚äĒ ūĚď¶)
  IdS-ő†i ‚¶É s ‚¶Ą .IdS f g = ‚ąÄ {a} ‚Üí s .IdS (f {a}) g
  IdS-ő†i ‚¶É s ‚¶Ą .IdS‚ÜźId p = IdS‚ÜźId ‚¶É s ‚¶Ą (happlyŠĶĘ p)
  IdS-ő†i {A = A} {B} ‚¶É s ‚¶Ą .has-is-ids f
    = fundamental-Id _
         (is-single‚Üźequiv-to-single (ő£-ő†-swapŠĶĘ‚ČÉ {P = IdS ‚¶É s ‚¶Ą f})
           (ő†ŠĶĘ-is-single (SingS-is-single f))) _

_ÔľĚ‚āĎ_
  : ‚ąÄ {ūĚď§ : Level} {A : Type ūĚď§} {ūĚď• : Level}
      ‚¶É r : Identity-system A ūĚď• ‚¶Ą
    ‚Üí A ‚Üí A ‚Üí Type ūĚď•
_ÔľĚ‚āĎ_ = IdS

instance
  IdS-uncurry
    : ‚ąÄ {ūĚď§ ūĚď• ūĚď¶ ūĚďõ} {A : Type ūĚď§} {B : A ‚Üí Type ūĚď•} {C : (x : A) ‚Üí B x ‚Üí Type ūĚď¶}
      ‚Üí ‚¶É sb : Identity-system ((x : A) (y : B x) ‚Üí C x y) ūĚďõ ‚¶Ą
      ‚Üí Identity-system ((p : ő£ A B) ‚Üí C (p .fst) (p .snd)) ūĚďõ
  IdS-uncurry ‚¶É s ‚¶Ą .IdS f g =  s .IdS (curry f) (curry g)
  IdS-uncurry ‚¶É s ‚¶Ą .IdS‚ÜźId refl = IdS‚ÜźId ‚¶É s ‚¶Ą refl
  IdS-uncurry {A = A} {B} {C} ‚¶É s ‚¶Ą .has-is-ids f
    = fundamental-Id _
      (is-single‚Üźequiv-to-single (ő£-ap-‚ČÉ-fst uncurry‚ČÉ)
                                 (SingS-is-single ‚¶É s ‚¶Ą (curry f))) _

ext!
  : ‚ąÄ {ūĚď§ ūĚď•} {A : Type ūĚď§} ‚¶É s : Identity-system A ūĚď• ‚¶Ą {x y : A}
    ‚Üí s .IdS x y ‚Üí x ÔľĚ y
ext! = Id‚ÜźIdS

ext!-is-equiv
  : ‚ąÄ {ūĚď§ ūĚď•} {A : Type ūĚď§} {x y : A}
      ‚¶É s : Identity-system A ūĚď• ‚¶Ą
    ‚Üí is-equiv (ext! ‚¶É s ‚¶Ą {x} {y})
ext!-is-equiv = is-equiv‚ĀĽ¬Ļ (has-is-ids _ _)


ext!‚ČÉ
  : ‚ąÄ {ūĚď§ ūĚď•} {A : Type ūĚď§} {x y : A} ‚¶É s : Identity-system A ūĚď• ‚¶Ą
    ‚Üí Id A x y ‚ČÉ IdS x y
ext!‚ČÉ = Id‚ČÉIdS

ext!‚ČÉ'
  : ‚ąÄ {ūĚď§ ūĚď•} {A : Type ūĚď§} {x y : A} ‚¶É s : Identity-system A ūĚď• ‚¶Ą
    ‚Üí IdS x y ‚ČÉ Id A x y
ext!‚ČÉ' ‚¶É s ‚¶Ą = Id‚ČÉIdS e‚ĀĽ¬Ļ

IdS‚ÜźEmbedding
  : ‚ąÄ {ūĚď§ ūĚď• ūĚď¶} {A : Type ūĚď§} {B : Type ūĚď•}
    ‚Üí {f : A ‚Üí B} ‚Üí is-prop-map f
    ‚Üí Identity-system B ūĚď¶
    ‚Üí Identity-system A ūĚď¶
IdS‚ÜźEmbedding {f = f} pm s .IdS a b = IdS ‚¶É s ‚¶Ą (f a) (f b)
IdS‚ÜźEmbedding pm s .IdS‚ÜźId refl = IdS‚ÜźId ‚¶É s ‚¶Ą refl
IdS‚ÜźEmbedding {f = f} pm s .has-is-ids a
  = fundamental-Id _
                   ((mk-singl (a , IdS‚āÄ ‚¶É s ‚¶Ą) (is-ss (a , IdS‚āÄ ‚¶É s ‚¶Ą))))
                   _
   where
   is-ss : is-prop (ő£[ z ‚ą∂ _ ] IdS ‚¶É s ‚¶Ą (f a) (f z))
   is-ss = is-prop‚Üźequiv-to-prop (ő£-ap-‚ČÉ (őĽ z ‚Üí sym‚ČÉ ‚ąô‚ČÉ Id‚ČÉIdS ‚¶É s ‚¶Ą)) (pm (f a))

IdS‚ÜźEquiv
  : ‚ąÄ {ūĚď§ ūĚď• ūĚď¶} {A : Type ūĚď§} {B : Type ūĚď•}
    ‚Üí (A ‚ČÉ B)
    ‚Üí Identity-system A ūĚď¶
    ‚Üí Identity-system B ūĚď¶
IdS‚ÜźEquiv eq s = IdS‚ÜźEmbedding (is-prop-map‚Üźhas-singleton-fibres
                    (has-singleton-fibres‚Üźis-equiv ((eq e‚ĀĽ¬Ļ) ._‚ČÉ_.has-is-eqv))) s


IdS‚ÜźSubtype
  : ‚ąÄ {ūĚď§ ūĚď• ūĚď¶} {A : Type ūĚď§} {B : A ‚Üí Type ūĚď•}
    ‚Üí is-subtype B
    ‚Üí Identity-system A ūĚď¶
    ‚Üí Identity-system (ő£ A B) ūĚď¶
IdS‚ÜźSubtype p s = IdS‚ÜźEmbedding {f = fst} ő£ŐÉ-ŌÄ-is-prop-map s
  where open Subtype (mk-subtype p)

instance
  IdS-equiv
    : ‚ąÄ {ūĚď§ ūĚď• ūĚď¶} {A : Type ūĚď§} {B : Type ūĚď•}
      ‚Üí ‚¶É _ : Identity-system (A ‚Üí B) ūĚď¶ ‚¶Ą
      ‚Üí Identity-system (A ‚ČÉ B) ūĚď¶
  IdS-equiv ‚¶É s ‚¶Ą = IdS‚ÜźEquiv (‚ČÉ-rep e‚ĀĽ¬Ļ) (IdS‚ÜźSubtype (őĽ _ ‚Üí is-equiv-is-prop) s)

private module test {ūĚď§ ūĚď• ūĚď¶} {A : Type ūĚď§} {B : Type ūĚď•} {C : Type ūĚď¶} where
  _ : {f g : A ‚Üí B} ‚Üí f ~ g ‚Üí f ÔľĚ g
  _ = ext!

  _ : {f g : A √ó B ‚Üí C} ‚Üí ((a : A) (b : B) ‚Üí f (a , b) ÔľĚ g (a , b)) ‚Üí f ÔľĚ g
  _ = ext!

  _ : {P : A ‚Üí Type ūĚď¶} {f g : ő£ A P ‚Üí B} ‚Üí ((a : A) (b : P a) ‚Üí f (a , b) ÔľĚ g (a , b)) ‚Üí f ÔľĚ g
  _ = ext!

instance
  IdS-Sigma
    : ‚ąÄ {ūĚď§ ūĚď• ūĚď¶ ūĚďú} {A : Type ūĚď§} {B : A ‚Üí Type ūĚď•}
      ‚Üí ‚¶É _ : Identity-system A ūĚď¶ ‚¶Ą
      ‚Üí ‚¶É _ : ‚ąÄ {a : A} ‚Üí Identity-system (B a) ūĚďú ‚¶Ą
      ‚Üí Identity-system (ő£ A B) (ūĚď¶ ‚äĒ ūĚďú)
  IdS-Sigma ‚¶É A ‚¶Ą ‚¶É B ‚¶Ą .IdS (a , b) (a' , b')
    = ő£[ p ‚ą∂ IdS a a' ] IdS (trS ‚¶É A ‚¶Ą p b) b'
  IdS-Sigma {A = A} {B} ‚¶É As ‚¶Ą ‚¶É Bs ‚¶Ą .IdS‚ÜźId refl
    = IdS‚āÄ ‚¶É As ‚¶Ą , IdS‚ÜźId (IdSJ-refl (B ‚ąė fst))
  IdS-Sigma {A = A} {B} ‚¶É As ‚¶Ą ‚¶É Bs ‚¶Ą .has-is-ids (a , b)
    = fundamental-Id _
      (is-single‚Üźequiv-to-single
        (lem e‚ĀĽ¬Ļ)
        (BR.SingS-is-single (trS {B = B} (IdS‚āÄ ‚¶É As ‚¶Ą) b))) _ where
    module BR = IdSReasoning (Bs)

    lem : ő£[ (a' , b') ‚ą∂ ő£ A B ]
          ő£[ p ‚ą∂ IdS a a' ] IdS (trS ‚¶É As ‚¶Ą p b) b'
        ‚ČÉ BR.SingS (trS {B = B} (IdS‚āÄ ‚¶É As ‚¶Ą) b)
    lem = ő£[ (a' , b') ‚ą∂ ő£ A B ]
          ő£[ p ‚ą∂ IdS a a' ] IdS (trS ‚¶É As ‚¶Ą p b) b'
             ‚ČÉ‚ü® ő£-assoc ‚ü©
          (ő£[ a' ‚ą∂ A ] ő£[ b' ‚ą∂ B a' ] ő£[ p ‚ą∂ IdS a a' ] IdS (trS ‚¶É As ‚¶Ą  p b) b')
            ‚ČÉ‚ü® ő£-ap-‚ČÉ (őĽ a‚āĀ ‚Üí ő£-comm) ‚ü©
          (ő£[ a' ‚ą∂ A ] ő£[ p ‚ą∂ IdS a a' ] ő£[ b' ‚ą∂ B a' ] IdS (trS ‚¶É As ‚¶Ą p b) b')
            ‚ČÉ‚ü® ő£-singS' ‚ü©
          BR.SingS (trS {B = B} (IdS‚āÄ ‚¶É As ‚¶Ą) b) ‚ČÉ‚ąé

{-# OVERLAPPABLE IdS-Sigma #-}


instance
  IdS-ua : ‚ąÄ {ūĚď§} ‚Üí Identity-system (Type ūĚď§) ūĚď§
  IdS-ua = mk-identity-system _‚ČÉ_ ua‚ČÉ
}

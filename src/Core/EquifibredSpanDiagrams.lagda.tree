\date{2026-05-19}
\title{Equifibred span diagrams}
\taxon{Module}
\author{fredrikbakke}

\import{stt-macros}

\agda{
module Core.EquifibredSpanDiagrams where

open import Foundations.Prelude
open import Axioms.UF
open import Core.Arrows
open import Core.ArrowEquiv
}

\subtree[fre-0000]{
\title{Equifibred span diagrams}
\taxon{Definition}
\author{fredrikbakke}

\p{
Given a span #{A \xleftarrow{f} S \xrightarrow{g} B}, an \em{equifibred span} between
a family #{L : A \to \Type} and a family #{R : B \to \Type} is a family
#{C : S \to \Type} together with families of equivalences
#{\Pi_{(s : S)}C(s) \simeq L(f(s))} and #{\Pi_{(s : S)}C(s) \simeq R(g(s))}.
}

\agda{
record EquifibredSpan
    {ЁЭУд ЁЭУе ЁЭУж ЁЭУЫ ЁЭУЬ} (S : Span ЁЭУд ЁЭУе ЁЭУж) (ЁЭУЭ : Level)
    (Left : Span.Left S тЖТ Type ЁЭУЫ)
    (Right : Span.Right S тЖТ Type ЁЭУЬ)
  : Type (ЁЭУд тКФ ЁЭУе тКФ ЁЭУж тКФ ЁЭУЫ тКФ ЁЭУЬ тКФ lsuc ЁЭУЭ)
  where
  constructor mk-eqfibspan
  field
    Centre
      : Span.Centre S тЖТ Type ЁЭУЭ
    LeftтЙГ
      : (s : Span.Centre S) тЖТ Centre s тЙГ Left (Span.left S s)
    RightтЙГ
      : (s : Span.Centre S) тЖТ Centre s тЙГ Right (Span.right S s)
}

\agda{
  LeftтЖР : (s : Span.Centre S) тЖТ Centre s тЖТ Left (Span.left S s)
  LeftтЖР s = LeftтЙГ s ._тЙГ_.fwd

  RightтЖР : (s : Span.Centre S) тЖТ Centre s тЖТ Right (Span.right S s)
  RightтЖР s = RightтЙГ s ._тЙГ_.fwd

  LeftтЖР-is-equiv : (s : Span.Centre S) тЖТ is-equiv (LeftтЖР s)
  LeftтЖР-is-equiv s = LeftтЙГ s ._тЙГ_.fwd-is-equiv

  RightтЖР-is-equiv
    : (s : Span.Centre S) тЖТ is-equiv (RightтЖР s)
  RightтЖР-is-equiv s = RightтЙГ s ._тЙГ_.fwd-is-equiv

  LeftтЙГRight
    : (s : Span.Centre S) тЖТ Left (Span.left S s) тЙГ Right (Span.right S s)
  LeftтЙГRight s = LeftтЙГ s eтБ╗┬╣ тИЩтЙГ RightтЙГ s
}

\p{
An \em{equifibred span diagram} over a span is the data of an equifibred span
together with its source and target families.
}

\agda{
record EquifibredSpanDiagram
    {ЁЭУд ЁЭУе ЁЭУж} (S : Span ЁЭУд ЁЭУе ЁЭУж) (ЁЭУЫ ЁЭУЬ ЁЭУЭ : Level)
  : Type (ЁЭУд тКФ ЁЭУе тКФ ЁЭУж тКФ lsuc ЁЭУЫ тКФ lsuc ЁЭУЬ тКФ lsuc ЁЭУЭ)
  where
  constructor mk-eqfibspanD'
  field
    Left
      : Span.Left S тЖТ Type ЁЭУЫ
    Right
      : Span.Right S тЖТ Type ЁЭУЬ
    span
      : EquifibredSpan S ЁЭУЭ Left Right

  open EquifibredSpan span public

pattern mk-eqfibspanD P-left P-right P-centre e-left e-right =
  mk-eqfibspanD' P-left P-right (mk-eqfibspan P-centre e-left e-right)
}
}

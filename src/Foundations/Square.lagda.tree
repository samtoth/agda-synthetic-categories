\title{Squares}
\taxon{Module}
\author{samueltoth}
\import{stt-macros}

% ```agda
\agda{
module Foundations.Square where

open import Foundations.Universes
open import Foundations.Functions
open import Foundations.Identity
open import Foundations.DependentIdentity
open import Foundations.Homotopy

opaque
  Square : ∀ {𝓤} {A : Type 𝓤}
           → {a00 a01 a10 a11 : A}
           → (ai0 : a00 ＝ a10)
           → (ai1 : a01 ＝ a11)
           → (a0i : a00 ＝ a01)
           → (a1i : a10 ＝ a11)
           → Type 𝓤
  Square {a00 = a00} {a01} {a10} {a11}
         ai0 ai1 a0i a1i = ai0 ∙ a1i ＝ a0i ∙ ai1

  Square-reflect-hor
    : ∀ {𝓤} {A : Type 𝓤}
      → {a00 a01 a10 a11 : A}
      → (ai0 : a00 ＝ a10)
      → (ai1 : a01 ＝ a11)
      → (a0i : a00 ＝ a01)
      → (a1i : a10 ＝ a11)
      → Square ai0 ai1 a0i a1i → Square ai1 ai0 (sym a0i) (sym a1i)
  Square-reflect-hor i0 refl refl refl p = sym p ∙ ∙-reflr _

  Square-reflect-vert
    : ∀ {𝓤} {A : Type 𝓤}
      → {a00 a01 a10 a11 : A}
      → (ai0 : a00 ＝ a10)
      → (ai1 : a01 ＝ a11)
      → (a0i : a00 ＝ a01)
      → (a1i : a10 ＝ a11)
      → Square ai0 ai1 a0i a1i → Square (sym ai0) (sym ai1) a1i a0i
  Square-reflect-vert refl ai1 refl refl x = ap sym x

  Square-functorial-top
    : ∀ {𝓤} {A : Type 𝓤}
        {a00 a01 a10 a11 : A}
      → {ai0 ai0' : a00 ＝ a10}
      → ai0 ＝ ai0'
      → {ai1 : a01 ＝ a11}
      → {a0i : a00 ＝ a01}
      → {a1i : a10 ＝ a11}
      → Square ai0 ai1 a0i a1i ＝ Square ai0' ai1 a0i a1i
  Square-functorial-top refl = refl

  Square-functorial-bot
    : ∀ {𝓤} {A : Type 𝓤}
        {a00 a01 a10 a11 : A}
      → {ai0 : a00 ＝ a10}
      → {ai1 ai1' : a01 ＝ a11}
      → ai1 ＝ ai1'
      → {a0i : a00 ＝ a01}
      → {a1i : a10 ＝ a11}
      → Square ai0 ai1 a0i a1i ＝ Square ai0 ai1' a0i a1i
  Square-functorial-bot refl = refl

  Square-squeeze-topr
    : ∀ {𝓤} {A : Type 𝓤}
      → {a00 a01 a10 a20 a21 : A}
      → {ai0 : a00 ＝ a10} (a2i0 : a10 ＝ a20)
      → {ai1 : a01 ＝ a21}
      → {a0i : a00 ＝ a01}
      → {a2i : a20 ＝ a21}
      → Square (ai0 ∙ a2i0) ai1 a0i a2i ＝ Square ai0 ai1 a0i (a2i0 ∙ a2i)
  Square-squeeze-topr {ai0 = refl} _ = refl

  Square-squeeze-botr
    : ∀ {𝓤} {A : Type 𝓤}
      → {a00 a01 a20 a11 a21 : A}
      → {ai0 : a00 ＝ a20}
      → {ai1 : a01 ＝ a11}
      → {a2i1 : a11 ＝ a21} {a2i1' : a21 ＝ a11} (p : a2i1 ＝ sym a2i1')
      → {a0i : a00 ＝ a01}
      → {a2i : a20 ＝ a21}
      → Square ai0 (ai1 ∙ a2i1) a0i a2i ＝ Square ai0 ai1 a0i (a2i ∙ a2i1')
  Square-squeeze-botr {ai1 = refl} {a2i1' = refl} refl {a2i = refl} = refl

  Square-squeeze-botl
    : ∀ {𝓤} {A : Type 𝓤}
      → {a00 a01 a02 a10 a12 : A}
      → {ai0 : a00 ＝ a10}
      → {ai2 : a02 ＝ a12}
      → {a0i : a00 ＝ a01} (a02i : a01 ＝ a02)
      → {a2i : a10 ＝ a12}
      → Square ai0 ai2 (a0i ∙ a02i) a2i ＝ Square ai0 (a02i ∙ ai2) a0i a2i
  Square-squeeze-botl {a0i = refl} refl  = refl

  Square-degen-hor : ∀ {𝓤} {A : Type 𝓤}
                   → {a b : A}
                   → (p q : a ＝ b)
                   → (s : p ＝ q)
                   → Square p q refl refl
  Square-degen-hor p q R = ∙-reflr p ∙ R


  Square-degen-vert : ∀ {𝓤} {A : Type 𝓤}
                   → {a b : A}
                   → (p q : a ＝ b)
                   → (s : p ＝ q)
                   → Square refl refl p q
  Square-degen-vert p q R = sym (∙-reflr p ∙ R)

  Square-degen-diag : ∀ {𝓤} {A : Type 𝓤}
                   → {a b : A}
                   → (p q : a ＝ b)
                   → (s : p ＝ q)
                   → Square (sym p) refl refl q
  Square-degen-diag p q refl = ∙-sym' p

  Square-flatten-hor
    : ∀ {𝓤} {A : Type 𝓤}
      → {a0 a1 a2 : A}
      → {ai0 : a1 ＝ a2}
      → {p   : a0 ＝ a1}
      → {ai1 : a1 ＝ a2}
      → (ai0 ＝ ai1)
      → Square p ai0 p ai1
  Square-flatten-hor {p = p} = ap (p ∙_) ∘ sym

  Square-flatten-vert
    : ∀ {𝓤} {A : Type 𝓤}
      → {a0 a1 a2 : A}
      → {a0i : a2 ＝ a0}
      → {p   : a0 ＝ a1}
      → {a1i : a2 ＝ a0}
      → (a0i ＝ a1i)
      → Square a1i p a0i p
  Square-flatten-vert {p = refl} = sym ∘ ap (_∙ refl)

  Square-left-whisker
    : ∀ {𝓤 𝓥} {A : Type 𝓤} {B : Type 𝓥} (f : A → B)
      → {a00 a01 a10 a11 : A}
      → {fi0 : f a00 ＝ f a10} {ai0 : a00 ＝ a10} (p : fi0 ＝ ap f ai0)
      → {fi1 : f a01 ＝ f a11} {ai1 : a01 ＝ a11} (q : fi1 ＝ ap f ai1)
      → {f0i : f a00 ＝ f a01} {a0i : a00 ＝ a01} (r : f0i ＝ ap f a0i)
      → {f1i : f a10 ＝ f a11} {a1i : a10 ＝ a11} (s : f1i ＝ ap f a1i)
      → Square ai0 ai1 a0i a1i
      → Square fi0 fi1 f0i f1i
  Square-left-whisker f {ai0 = ai0} refl {_} {ai1} refl
                        {_} {a0i} refl {_} {a1i} refl p
    = sym (ap-∙ f ai0 a1i) ∙ ap (ap f) p ∙ ap-∙ f a0i ai1

  Square←Idᵈ : ∀ {𝓤} {A : Type 𝓤}
           → {a00 a01 a10 a11 : A}
           → (ai0 : a00 ＝ a10)
           → (ai1 : a01 ＝ a11)
           → (a0i : a00 ＝ a01)
           → (a1i : a10 ＝ a11)
           → Idᵈ (ap₂ (_＝_) ai0 ai1) a0i a1i
           → Square ai0 ai1 a0i a1i
  Square←Idᵈ refl refl refl a1i p = sym p


  Idᵈ←Square :  ∀ {𝓤} {A : Type 𝓤}
           → {a00 a01 a10 a11 : A}
           → (ai0 : a00 ＝ a10)
           → (ai1 : a01 ＝ a11)
           → (a0i : a00 ＝ a01)
           → (a1i : a10 ＝ a11)
           → Square ai0 ai1 a0i a1i
           → Idᵈ (ap₂ (_＝_) ai0 ai1) a0i a1i
  Idᵈ←Square refl refl refl a1i p = sym p

  Square←Idᵈ-func : ∀ {𝓤 𝓥} {A : Type 𝓤} {B : Type 𝓥}
                    → {a0 a1 : A}
                    → {f g : A → B}
                    → (p : a0 ＝ a1)
                    → (q : f a0 ＝ g a0)
                    → (r : f a1 ＝ g a1)
                    → Idᵈ (ap (λ x → f x ＝ g x) p) q r
                    → Square (ap f p) (ap g p) q r
  Square←Idᵈ-func refl p q r = sym (∙-reflr _ ∙ r)

  Idᵈ-func←Square : ∀ {𝓤 𝓥} {A : Type 𝓤} {B : Type 𝓥}
                    → {a0 a1 : A}
                    → {f g : A → B}
                    → (p : a0 ＝ a1)
                    → (q : f a0 ＝ g a0)
                    → (r : f a1 ＝ g a1)
                    → Square (ap f p) (ap g p) q r
                    → Idᵈ (ap (λ x → f x ＝ g x) p) q r
  Idᵈ-func←Square refl p q r = sym (r ∙ ∙-reflr _)


  Idᵈ-Π←Square : ∀ {𝓤 𝓥} {A : Type 𝓤} {B : A → Type 𝓥}
                    → {a0 a1 : A}
                    → {f g : Π A B}
                    → (p : a0 ＝ a1)
                    → {q : f a0 ＝ g a0}
                    → {r : f a1 ＝ g a1}
                    → Square (apᵈ f p) (apᵈ g p) (ap (tr B p) q) r
                    → Idᵈ (ap (λ x → f x ＝ g x) p) q r
  Idᵈ-Π←Square refl r = sym (r ∙ ∙-reflr _ ∙ ap-id _)

  Square←brt＝l : ∀ {𝓤} {A : Type 𝓤}
           → {a00 a01 a10 a11 : A}
           → (ai0 : a00 ＝ a10)
           → {ai1 : a01 ＝ a11}
           → {a0i : a00 ＝ a01}
           → {a1i : a10 ＝ a11}
           → ai0 ∙ a1i ∙ sym ai1 ＝ a0i
           → Square ai0 ai1 a0i a1i
  Square←brt＝l refl {refl} {refl} p = sym (∙-reflr _) ∙ p

  Square←brt＝l' : ∀ {𝓤} {A : Type 𝓤}
           → {a00 a01 a10 a11 : A}
           → (ai0 : a00 ＝ a10)
           → {ai1 : a11 ＝ a01}
           → {a0i : a00 ＝ a01}
           → {a1i : a10 ＝ a11}
           → ai0 ∙ a1i ∙ ai1 ＝ a0i
           → Square ai0 (sym ai1) a0i a1i
  Square←brt＝l' refl {refl} {refl} p = sym (∙-reflr _) ∙ p

  Square-drop-i : ∀ {𝓤} {A : Type 𝓤}
                  → {a b : A}
                  → (p : a ＝ b)
                  → Square p p refl refl
  Square-drop-i refl = refl

  Square-drop-j : ∀ {𝓤} {A : Type 𝓤}
                  → {a b : A}
                  → (p : a ＝ b)
                  → Square refl refl p p
  Square-drop-j refl = refl

  mk-square : ∀ {𝓤} {A : Type 𝓤}
           → {a00 a01 a10 a11 : A}
           → {ai0 : a00 ＝ a10}
           → {ai1 : a01 ＝ a11}
           → {a0i : a00 ＝ a01}
           → {a1i : a10 ＝ a11}
           → ai0 ∙ a1i ＝ a0i ∙ ai1
           → Square ai0 ai1 a0i a1i
  mk-square = id

  un-square : ∀ {𝓤} {A : Type 𝓤}
           → {a00 a01 a10 a11 : A}
           → {ai0 : a00 ＝ a10}
           → {ai1 : a01 ＝ a11}
           → {a0i : a00 ＝ a01}
           → {a1i : a10 ＝ a11}
           → Square ai0 ai1 a0i a1i
           → ai0 ∙ a1i ＝ a0i ∙ ai1
  un-square = id

  un-mk-square
    : ∀ {𝓤} {A : Type 𝓤}
      {a00 a01 a10 a11 : A}
      {ai0 : a00 ＝ a10}
      {ai1 : a01 ＝ a11}
      {a0i : a00 ＝ a01}
      {a1i : a10 ＝ a11}
    → un-square {ai0 = ai0} {ai1} {a0i} {a1i} ∘ mk-square ~ id
  un-mk-square = ~refl

  mk-un-square
    : ∀ {𝓤} {A : Type 𝓤}
      {a00 a01 a10 a11 : A}
      {ai0 : a00 ＝ a10}
      {ai1 : a01 ＝ a11}
      {a0i : a00 ＝ a01}
      {a1i : a10 ＝ a11}
    → mk-square ∘ un-square {ai0 = ai0} {ai1} {a0i} {a1i}  ~ id
  mk-un-square = ~refl

opaque
  unfolding Square
  Squareᵈ : ∀ {𝓤} {A B C D : Type 𝓤}
            {ab : A ＝ B} {cd : C ＝ D} {ac : A ＝ C} {bd : B ＝ D}
            (S : Square ab cd ac bd)
            {s00 : A} {s10 : B} {s01 : C} {s11 : D}
            → (si0 : Idᵈ ab s00 s10)
            → (si1 : Idᵈ cd s01 s11)
            → (s0i : Idᵈ ac s00 s01)
            → (s1i : Idᵈ bd s10 s11)
            → Type 𝓤
  Squareᵈ {ab = ab} {cd} {ac} S {s00} {s10} {s01} {s11} si0 si1 s0i s1i
    = Idᵈ (ap (λ x → coe x s00 ＝ s11) S)
          (si0 ∙[ ab ∙ _ ] s1i)
          (s0i  ∙[ ac ∙ cd ] si1)

  drop-i : ∀ {𝓤} {A B : Type 𝓤} {P : A ＝ B} {a : A} {b : B} (p : Idᵈ P a b)
           → Squareᵈ {C = A} {D = B} {P} {P}
                     (Square-degen-hor P P refl) p p refl refl
  drop-i {P = refl} refl = refl

  drop-j : ∀ {𝓤} {A B : Type 𝓤} {P : A ＝ B} {a : A} {b : B} (p : Idᵈ P a b)
           → Squareᵈ {ab = refl} (Square-degen-vert P P refl) refl refl p p
  drop-j {P = refl} refl = refl

record Hexagon {𝓤} {A : Type 𝓤} {a b c d e f : A}
               (ab : a ＝ b) (bc : b ＝ c) (cd : c ＝ d)
               (ae : a ＝ e) (ef : e ＝ f) (fd : f ＝ d) : Type 𝓤 where
  no-eta-equality
  constructor mk-hex
  field
    un-hex : ab ∙ bc ∙ cd ＝ ae ∙ ef ∙ fd

  Square←hex : Square ab (ef ∙ fd) ae (bc ∙ cd)
  Square←hex = mk-square un-hex

  Square-compress-bot
    : Square ab (ef ∙ fd ∙ sym cd) ae bc
  Square-compress-bot
    = tr (λ p → Square ab p ae bc) (∙-assoc ef fd (sym cd))
        (coe (sym (Square-squeeze-botr refl)) Square←hex)

  Square-bl
    : Square ab (fd ∙ sym cd) (ae ∙ ef) bc
  Square-bl = coe (sym (Square-squeeze-botl ef)) Square-compress-bot

  Square-compress-left
    : Square ab (sym cd) (ae ∙ ef ∙ fd) bc
  Square-compress-left = tr (λ p → Square ab _ p bc) (∙-assoc ae ef fd)
                           (coe (sym (Square-squeeze-botl fd)) Square-bl)
}
% ```

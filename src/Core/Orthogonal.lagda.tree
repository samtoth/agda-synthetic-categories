\subtree[stt-0048]{
\title{Orthogonal maps}
\taxon{Definition}

\p{Given maps #{f : A \to B} and #{g : C \to D}, we say #{f} is \em{left
orthogonal} to #{g} when the [pullback power](stt-004D) #{\pullpow{f}{g}} is an
equivalence.}

\agda{
module _ {ЁЭУд ЁЭУе ЁЭУж ЁЭУЫ} {A : Type ЁЭУд}
       {B : Type ЁЭУе} {C : Type ЁЭУж}
       {D : Type ЁЭУЫ} where
  are-orthogonal : тИА (f : A тЖТ B) (g : C тЖТ D) тЖТ Type (ЁЭУд тКФ ЁЭУе тКФ ЁЭУж тКФ ЁЭУЫ)
  are-orthogonal f g = is-equiv (pullback-power f g)
}
}

\subtree[stt-00NZ]{
\title{Orthogonal maps admit unique lifting solutions}
\taxon{Lemma}

\p{#{f} and #{g} are orthogonal iff any [square](stt-003U) from #{f} to #{g}
has a unique [lift](stt-0044).}

\proof{
\p{The fibre of the pullback power at a square is equivalent to the data of a lifting of that square.}
}

\agda{
module _ {ЁЭУд ЁЭУе ЁЭУж ЁЭУЫ} {A : Type ЁЭУд}
       {B : Type ЁЭУе} {C : Type ЁЭУж}
       {D : Type ЁЭУЫ} where
  admit-unique-lifts : тИА (f : A тЖТ B) (g : C тЖТ D) тЖТ Type (ЁЭУд тКФ ЁЭУе тКФ ЁЭУж тКФ ЁЭУЫ)
  admit-unique-lifts f g = тИА (F : Arrow-map f g) тЖТ unique-lifts F

  are-orthogonalтЖРunique-lifts
     : тИА {f : A тЖТ B} {g : C тЖТ D}
       тЖТ admit-unique-lifts f g
       тЖТ are-orthogonal f g
  are-orthogonalтЖРunique-lifts {f} {g} lifts
    = is-equivтЖРhas-singleton-fibres ╬╗ where
      G@(mk-amap t b H) тЖТ is-singleтЖРequiv-to-single
                            (pb-power-fibreтЙГlifts f g G eтБ╗┬╣)
                            (lifts G)

  unique-liftsтЖРare-orthogonal
    : тИА {f : A тЖТ B} {g : C тЖТ D}
      тЖТ are-orthogonal f g
      тЖТ admit-unique-lifts f g
  unique-liftsтЖРare-orthogonal {f} {g} orth problem
    = is-singleтЖРequiv-to-single
        (pb-power-fibreтЙГlifts f g problem)
        (has-singleton-fibresтЖРis-equiv
          orth
          problem)

  unique-liftsтЖФare-orthogonal
    : тИА {f : A тЖТ B} {g : C тЖТ D}
      тЖТ admit-unique-lifts f g
      тЖФ are-orthogonal f g
  unique-liftsтЖФare-orthogonal
    = (are-orthogonalтЖРunique-lifts , unique-liftsтЖРare-orthogonal)
}
}

\subtree[stt-00NX]{
\title{Orthogonality of a map with a family}
\taxon{Definition}

\p{Given a map #{f : X \to Y}, and a family #{P : A \to \Type}, we say that
#{f} is orthogonal to #{P} when for each #{g : Y \to A}, the map
#{f^* : \mathsf{\Pi} Pg \to \mathsf{\Pi} Pgf} is an equivalence.}

\agda{
are-orthogonal-fam
  : тИА {ЁЭУд ЁЭУе ЁЭУж ЁЭУЬ} {A : Type ЁЭУд} {B : Type ЁЭУе}
      {C : Type ЁЭУж} (f : A тЖТ B)
      (P : C тЖТ Type ЁЭУЬ)
    тЖТ Type (ЁЭУд тКФ ЁЭУе тКФ ЁЭУж тКФ ЁЭУЬ)
are-orthogonal-fam f P = is-fibrewise-equiv ╬╗ g тЖТ precomp-╬а (P тИШ g) f

are-orthogonal-famтЖРequiv
  : тИА {ЁЭУд ЁЭУе ЁЭУж ЁЭУЬ ЁЭУЭ} {A : Type ЁЭУд} {B : Type ЁЭУе}
      {C : Type ЁЭУж} {f : A тЖТ B}
      {P : C тЖТ Type ЁЭУЬ} {P' : C тЖТ Type ЁЭУЭ}
      (e : тИА c тЖТ P c тЙГ P' c)
    тЖТ are-orthogonal-fam f P тЖТ are-orthogonal-fam f P'
are-orthogonal-famтЖРequiv {f = f} {P} {P'} e o h
  = tgt-is-equivтЖРArrow-equiv
      ( amap
      , postcomp-╬а-equiv (e.fwd-is-equiv _)
      , postcomp-╬а-equiv (e.fwd-is-equiv _))
      (o h) where
  module e c = _тЙГ_ (e c)
  amap : Arrow-map (precomp-╬а (P тИШ h) f) (precomp-╬а (P' тИШ h) f)
  amap .Arrow-╬а.top = postcomp-╬а (e.fwd тИШ h)
  amap .Arrow-╬а.bot = postcomp-╬а (e.fwd тИШ h тИШ f)
  amap .Arrow-╬а.comm = ~refl
}
}

\subtree[stt-00NY]{
\title{Unique extensions from orthogonality}
\taxon{Lemma}

\p{Given a map #{f : A \to B} and a family #{P : C \to \Type},
together with a [morhpism](stt-00OB) from #{f} to #{P}, consisting of
#{g : B \to C} and #{h : \mathsf{\Pi} Pgf}, we define the type of
lifting solutions to be [extensions](stt-00CL) of #{h} along
#{f}. #{f} and #{P} are orthogonal iff such extensions are unique.}

\proof{
\p{
The fibres of the dependent precomposition map at a lifting problem are exactly
the desired extensions.
}
}

\agda{
has-unique-extensions
  : тИА {ЁЭУд ЁЭУе ЁЭУж ЁЭУЬ} {A : Type ЁЭУд} {B : Type ЁЭУе}
      {C : Type ЁЭУж} (f : A тЖТ B)
      (P : C тЖТ Type ЁЭУЬ)
    тЖТ Type (ЁЭУд тКФ ЁЭУе тКФ ЁЭУж тКФ ЁЭУЬ)
has-unique-extensions f P
  = тИА (F : ArrFam-map f P)
    тЖТ is-singleton (Extс╡И f (P тИШ F .ArrFam-map.bot) (F .ArrFam-map.top))

Extс╡И-Subtype-is-prop
  : тИА {ЁЭУд ЁЭУе ЁЭУж ЁЭУЬ} {A : Type ЁЭУд} {B : Type ЁЭУе}
      {C : Type ЁЭУж} (f : A тЖТ B)
      (P : Subtype C ЁЭУЬ)
      (F : ArrFam-map f (P .Subtype.family))
    тЖТ is-prop (Extс╡И f (P .Subtype.family тИШ F .ArrFam-map.bot) (F .ArrFam-map.top))
Extс╡И-Subtype-is-prop f P F
  = ╬г-is-prop
      (╬а-is-prop (P .Subtype.family-is-subtype тИШ F .ArrFam-map.bot))
      (╬╗ a тЖТ ╬а-is-prop
        (╬╗ a' тЖТ я╝Э-is-prop
                  (((P .Subtype.family-is-subtype тИШ F .ArrFam-map.bot) тИШ f) a') _ _))


module _
  {ЁЭУд ЁЭУе ЁЭУж ЁЭУЬ} {A : Type ЁЭУд} {B : Type ЁЭУе}
  {C : Type ЁЭУж} {f : A тЖТ B}
  {P : C тЖТ Type ЁЭУЬ}
  where

  unique-extensionsтЖРare-orthogonal-fam
    : are-orthogonal-fam f P
    тЖТ has-unique-extensions f P
  unique-extensionsтЖРare-orthogonal-fam orth F
    = is-singleтЖРequiv-to-single
        (fibre-precomp-╬атЙГExt (P тИШ F .ArrFam-map.bot) f (F .ArrFam-map.top))
        (has-singleton-fibresтЖРis-equiv
          (orth (F .ArrFam-map.bot))
          (F .ArrFam-map.top))

  are-orthogonal-famтЖРunique-extensions
    : has-unique-extensions f P
    тЖТ are-orthogonal-fam f P
  are-orthogonal-famтЖРunique-extensions ext g
    = is-equivтЖРhas-singleton-fibres
        ╬╗ h тЖТ is-singleтЖРequiv-to-single
                (fibre-precomp-╬атЙГExt _ f _ eтБ╗┬╣)
                (ext (mk-afmap g h))

  are-orthogonal-famтЖФhas-unique-extensions
    : are-orthogonal-fam f P тЖФ has-unique-extensions f P
  are-orthogonal-famтЖФhas-unique-extensions
    = ( unique-extensionsтЖРare-orthogonal-fam
      , are-orthogonal-famтЖРunique-extensions)
}
}

\subtree[stt-00O2]{
\title{(Un)straightening orthogonality at type families}
\taxon{Lemma}

\p{For a maps #{f} and #{g}, we have #{f \perp g} iff #{f \perp \fibre-fam{g}}.}

\agda{
module _
  {ЁЭУд ЁЭУе ЁЭУж ЁЭУЫ} {A : Type ЁЭУд} {B : Type ЁЭУе}
  {C : Type ЁЭУж} {D : Type ЁЭУЫ}
  {f : A тЖТ B} {g : C тЖТ D}
  where

  power-hom-arr-fibre
    : тИА h
      тЖТ Arrow-map
          (arrow-fibre (power-hom f g) h)
          (precomp-╬а (fibre g тИШ h) f)
  power-hom-arr-fibre h .Arrow-map.top = _тЙГ_.fwd (fibre-postcompтЙГ g h)
  power-hom-arr-fibre h .Arrow-map.bot = _тЙГ_.fwd (fibre-postcompтЙГ g (h тИШ f))
  power-hom-arr-fibre h .Arrow-map.comm (_ , refl) = refl

  power-hom-arr-fibre-is-equiv : тИА h тЖТ is-Arrow-equiv (power-hom-arr-fibre h)
  power-hom-arr-fibre-is-equiv h
    = ( fibre-postcompтЙГ g h ._тЙГ_.fwd-is-equiv
      , fibre-postcompтЙГ g (h тИШ f) ._тЙГ_.fwd-is-equiv
      )

  are-orthogonal-fibreтЖРis-cartesian
    : is-cartesian (power-hom f g)
    тЖТ are-orthogonal-fam f (fibre g)
  are-orthogonal-fibreтЖРis-cartesian pb h
    = tgt-is-equivтЖРArrow-equiv
        (power-hom-arr-fibre h , power-hom-arr-fibre-is-equiv h)
        (pb h)

  is-cartesianтЖРare-orthogonal-fibre
    : are-orthogonal-fam f (fibre g)
    тЖТ is-cartesian (power-hom f g)
  is-cartesianтЖРare-orthogonal-fibre eq h
    = src-is-equivтЖРArrow-equiv
        (power-hom-arr-fibre h , power-hom-arr-fibre-is-equiv h)
        (eq h)

  are-orthogonal-fibreтЖРare-orthogonal
      : are-orthogonal f g
      тЖТ are-orthogonal-fam f (fibre g)
  are-orthogonal-fibreтЖРare-orthogonal orth h
    = are-orthogonal-fibreтЖРis-cartesian
        (power-hom-cartesianтЖРpullback-power f g orth)
        h

  are-orthogonalтЖРare-orthogonal-fibre
    : are-orthogonal-fam f (fibre g)
    тЖТ are-orthogonal f g
  are-orthogonalтЖРare-orthogonal-fibre orth
    = pullback-powerтЖРpower-hom-cartesian f g
        (is-cartesianтЖРare-orthogonal-fibre orth)

  are-orthogonalтЖФare-orthogonal-fibre
    : are-orthogonal f g тЖФ are-orthogonal-fam f (fibre g)
  are-orthogonalтЖФare-orthogonal-fibre
    = (are-orthogonal-fibreтЖРare-orthogonal , are-orthogonalтЖРare-orthogonal-fibre)
}

\p{Similarly we have #{f \perp P} iff #{f \perp \pi_P}.}

\agda{
module _
  {ЁЭУд ЁЭУе ЁЭУж ЁЭУЫ} {A : Type ЁЭУд} {B : Type ЁЭУе}
  {C : Type ЁЭУж}
  {f : A тЖТ B} {P : C тЖТ Type ЁЭУЫ}
  where
  are-orthogonal-fstтЖРare-orthogonal-fam
    : are-orthogonal-fam f P тЖТ are-orthogonal f (fst: P)
  are-orthogonal-fstтЖРare-orthogonal-fam orth
    = are-orthogonalтЖРare-orthogonal-fibre
        (are-orthogonal-famтЖРequiv
          {P = P} {fibre (fst: P)}
          (_eтБ╗┬╣ тИШ fibre-straighten P)
          orth)

  are-orthogonal-famтЖРare-orthogonal-fst
    : are-orthogonal f (fst: P) тЖТ are-orthogonal-fam f P
  are-orthogonal-famтЖРare-orthogonal-fst orth
    = are-orthogonal-famтЖРequiv
          (fibre-straighten P)
          (are-orthogonal-fibreтЖРare-orthogonal orth)

  are-orthogonal-famтЖФare-orthogonal-fst
    : are-orthogonal-fam f P тЖФ are-orthogonal f (fst: P)
  are-orthogonal-famтЖФare-orthogonal-fst
    = ( are-orthogonal-fstтЖРare-orthogonal-fam
      , are-orthogonal-famтЖРare-orthogonal-fst)

}
}

\subtree[stt-004A]{
\title{Classification of orthogonal maps}
\taxon{Theorem}

\p{We summarise the main results of this module.
For maps #{f : A \to B} and #{g : C \to D}, we have that the following
are equivalent:}

\ol{
  \li{#{f \perp g} - the pullback power #{\pullpow{f}{g}} is an equivalence.}
  \li{The square defined in \ref{stt-004C} is a pullback square}
  \li{There are unique lifts for any square from #{f} to #{g}}
  \li{#{f \perp \fibre-fam{g}} тАУ i.e the [dependent postcomposition](stt-004M)
        by #{f} at the fibre of #{g} is an equivalence.}
}

\proof{
\p{We have already shown (1) iff (2) as a [corollary](stt-004L) of the fact
that the pullback power [is homotopic to the gap map](stt-004C).
\ref{stt-00NZ} gives us (1) iff (3). Finally, \ref{stt-00O2} proves (2) iff (4).}
}


\p{We record the remaining composite implications in Agda:}

\closedScope{
\subtree{
\title{Details}
\agda{
unique-liftsтЖРare-orthogonal-fam
  : тИА {ЁЭУд ЁЭУе ЁЭУж ЁЭУЫ} {A : Type ЁЭУд} {B : Type ЁЭУе}
      {C : Type ЁЭУж} {D : Type ЁЭУЫ}
      {f : A тЖТ B} {g : C тЖТ D}
    тЖТ are-orthogonal-fam f (fibre g)
    тЖТ admit-unique-lifts f g
unique-liftsтЖРare-orthogonal-fam {f = f} {g} eqv F
  = is-singleтЖРequiv-to-single (pb-power-fibreтЙГlifts _ _ F)
     (has-singleton-fibresтЖРis-equiv
       (pullback-powerтЖРpower-hom-cartesian _ _
         (is-cartesianтЖРare-orthogonal-fibre eqv))
        F)

unique-liftsтЖРis-cartesian
  : тИА {ЁЭУд ЁЭУе ЁЭУж ЁЭУЫ} {A : Type ЁЭУд} {B : Type ЁЭУе}
      {C : Type ЁЭУж} {D : Type ЁЭУЫ}
      {f : A тЖТ B} {g : C тЖТ D}
    тЖТ is-cartesian (power-hom f g)
    тЖТ admit-unique-lifts f g
unique-liftsтЖРis-cartesian cart
  = unique-liftsтЖРare-orthogonal-fam (are-orthogonal-fibreтЖРis-cartesian cart)

is-cartesianтЖРare-orthogonal
  : тИА {ЁЭУд ЁЭУе ЁЭУж ЁЭУЫ} {A : Type ЁЭУд} {B : Type ЁЭУе}
      {C : Type ЁЭУж} {D : Type ЁЭУЫ}
      {f : A тЖТ B} {g : C тЖТ D}
    тЖТ are-orthogonal f g
    тЖТ is-cartesian (power-hom f g)
is-cartesianтЖРare-orthogonal = power-hom-cartesianтЖРpullback-power _ _

are-orthogonalтЖРis-cartesian
  : тИА {ЁЭУд ЁЭУе ЁЭУж ЁЭУЫ} {A : Type ЁЭУд} {B : Type ЁЭУе}
      {C : Type ЁЭУж} {D : Type ЁЭУЫ}
      {f : A тЖТ B} {g : C тЖТ D}
    тЖТ is-cartesian (power-hom f g)
    тЖТ are-orthogonal f g
are-orthogonalтЖРis-cartesian = pullback-powerтЖРpower-hom-cartesian _ _
}
}
}
}


\subtree[stt-004N]{
\date{2025-05-24}
\taxon{Remark}
\title{Orthogonality at types}
\p{We say that a type #{A} is orthogonal to a map when the unique map #{A \to 1}
   is.}
}


\subtree[stt-004O]{
\date{2025-05-24}
\taxon{Theorem}
\title{Orthogonality via composition}

\p{A type #{A} is [orthogonal](stt-004N) to a map #{X \to Y} iff postcomposition
by f is an equivalence.}

\p{We postpone this proof until later, but for now in the formalisation we
   define orthogonality to be the types satisfying the above property.}

\agda{
orthogonal-type
  : тИА {ЁЭУд ЁЭУе ЁЭУж} {X : Type ЁЭУд} {Y : Type ЁЭУе}
      (f : X тЖТ Y) (A : Type ЁЭУж)
    тЖТ Type (ЁЭУд тКФ ЁЭУе тКФ ЁЭУж)
orthogonal-type f A = is-equiv (precomp A f)
}
}


\subtree[stt-004B]{
\taxon{Notation}

\p{When #{f} and #{g} are orthogonal, we write #{f \perp g}. Likewise
if #{A} is a type, then we can write #{f \perp A} to mean #{!_A} is orthogonal to
#{f}. Finally, if #{P} is a type family, then we write #{f \perp P} to mean
#{P} is orthogonal \em{as a type family} to #{f}.}

\remark{Note that for a type family #{P}, it is not in general true that
#{(\forall x. f \perp P(x))} iff #{f \perp P}.}

\agda{
module notation where
  instance
    orth-maps
      : тИА {ЁЭУд ЁЭУе ЁЭУж ЁЭУЫ}
          {A : Type ЁЭУд} {B : Type ЁЭУе} {C : Type ЁЭУж} {D : Type ЁЭУЫ}
        тЖТ Orthogonality (A тЖТ B) (C тЖТ D)
    orth-maps .Orthogonality._тКе_ = are-orthogonal

  {-# OVERLAPPABLE orth-maps #-}

  instance
    orth-map-typ
      : тИА {ЁЭУд ЁЭУе ЁЭУж} {A : Type ЁЭУд} {B : Type ЁЭУе}
        тЖТ Orthogonality (A тЖТ B) (Type ЁЭУж)
    orth-map-typ .Orthogonality._тКе_ = orthogonal-type

  instance
    orth-map-fam
      : тИА {ЁЭУд ЁЭУе ЁЭУж ЁЭУЫ} {A : Type ЁЭУд} {B : Type ЁЭУе} {C : Type ЁЭУж}
        тЖТ Orthogonality (A тЖТ B) (C тЖТ Type ЁЭУЫ)
    orth-map-fam .Orthogonality._тКе_ = are-orthogonal-fam

  {-# OVERLAPPING orth-map-fam #-}

open notation
}
}

\subtree[stt-004Q]{
\taxon{Proof}
\title{Proof of \ref{stt-004O}}

\p{
We want to show #{A \to \b1} is orthogonal to #{f : X \to Y}, which by
the [[stt-004A]], it suffices to show that for all #{h : Y \to 1}, the map
#{{-} \circ f : ((y : Y) \to \fibre{!}{h(y)}) \to ((x : X) \to \fibre{!}{h(f(x))})}
is an equivalence. But the fibre of #{A \to 1} is just A. Formally, we can
use the 3-for-2 property on the following diagram:
}

\quiver{
\begin{tikzcd}
	{\fibre{!}{-}^Y} &&& {\fibre{!}{-}^X} \\
	\\
	& {A^Y} & {A^X}
	\arrow[from=1-1, to=1-4]
	\arrow["\sim"', from=1-1, to=3-2]
	\arrow["{A^f}"', from=3-2, to=3-3]
	\arrow["\sim"', from=3-3, to=1-4]
\end{tikzcd}
}

\agda{
is-orthogonalтЖФorthogonal-!
  : тИА {ЁЭУд ЁЭУе ЁЭУж} {X : Type ЁЭУд} {Y : Type ЁЭУе}
      {f : X тЖТ Y} {A : Type ЁЭУж}
    тЖТ (f тКе (!: A))
    тЖФ (f тКе A)
is-orthogonalтЖФorthogonal-! {X = X} {Y} {f} {A}
  = ((╬╗ orth тЖТ tgt-is-equivтЖРArrow-equiv (sq , sq-is-equiv)
                 (are-orthogonal-fibreтЖРare-orthogonal orth !))
    , ╬╗ orth тЖТ  are-orthogonalтЖРare-orthogonal-fibre
                 (╬╗ _ тЖТ src-is-equivтЖРArrow-equiv (sq , sq-is-equiv) orth)) where
  fstтБ╗┬╣ : A тЖТ fibre {A = A} ! _
  fstтБ╗┬╣ a = a , refl

  fst-is-equiv : is-equiv {A = fibre {A = A} ! tt} fst
  fst-is-equiv = is-equivтЖРqinv (fstтБ╗┬╣
                               , (╬╗ where (a , refl) тЖТ refl)
                               , ~refl)

  H :   (fst тИШ_) тИШ precomp-╬а (fibre ! тИШ (╬╗ _ тЖТ tt)) f
      ~ precomp A f тИШ (fst тИШ_)
  H f' = funextтЖТ ~refl

  sq : Arrow-map (precomp-╬а (fibre {A = A} ! тИШ !) f) (precomp A f)
  sq .Arrow-map.top = fst тИШ_
  sq .Arrow-map.bot = fst тИШ_
  sq .Arrow-map.comm = H

  sq-is-equiv  : is-Arrow-equiv sq
  sq-is-equiv .fst = postcomp-equiv fst-is-equiv
  sq-is-equiv .snd = postcomp-equiv fst-is-equiv
}
}

\subtree[stt-00EB]{
\title{Anodyne maps}
\taxon{Definition}

\p{We say a map #{f} is #{k}-anodyne if any map orthogonal to #{k} is also
orthogonal to #{f}.}

\agda{
is-anodyne
  : тИА {ЁЭУд ЁЭУе ЁЭУж ЁЭУЬ} {A : Type ЁЭУд} {B : Type ЁЭУе} {X : Type ЁЭУж} {Y : Type ЁЭУЬ}
    тЖТ (A тЖТ B) тЖТ (X тЖТ Y) тЖТ Type╧Й
is-anodyne f k
  = тИА {ЁЭУд' ЁЭУе'} {U : Type ЁЭУд'} {V : Type ЁЭУе'} (g : U тЖТ V)
   тЖТ k тКе g тЖТ f тКе g
}
}

\subtree[stt-00L3]{
\title{Orthogonality at a point}


\p{We can give a more simple representation of the type of lifting
problems as a pullback when the left map is an inclusion of a point.}

\agda{
module _ {ЁЭУШ ЁЭУд ЁЭУе} {A : Type ЁЭУд} {B : Type ЁЭУе} {f : A тЖТ B}
         {I : Type ЁЭУШ} (p : I) where
  private
    m : Cospan-map
          (mk-cospan (ЁЭЯЩ тЖТ B) (postcomp _ f) (precomp _ (point p)))
          (mk-cospan B f (ev p))
    m .Cospan-map.hтВБ = ev tt
    m .Cospan-map.hтВВ = ev tt
    m .Cospan-map.hтВГ = id
    m .Cospan-map.H = ~refl
    m .Cospan-map.K = ~refl

    m-is-equiv : is-cospan-equiv m
    m-is-equiv .fst = unit-ev-is-equiv
    m-is-equiv .snd .fst = unit-ev-is-equiv
    m-is-equiv .snd .snd = id-is-equiv

  orthogonal-point-gap-map : (I тЖТ A) тЖТ Pullback f (ev p)
  orthogonal-point-gap-map = PullbackтВБ m
                           тИШ pullbackтЖРarrow
                           тИШ pullback-power (point p) f

  orthogonal-point-pullback-condition
    : point p тКе f тЖТ is-equiv orthogonal-point-gap-map
  orthogonal-point-pullback-condition orth
    = is-equiv-тИШ
        (PullbackтВБ-is-equiv m m-is-equiv)
        (is-equiv-тИШ
          (Arrow-mapтЙГpullback ._тЙГ_.fwd-is-equiv)
          (pullback-powerтЖРpower-hom-cartesian
            (point p) f (is-cartesianтЖРare-orthogonal orth)))
}
}


\subtree[stt-00PI]{
\title{Right classes of coproducts of families of maps}
\taxon{Lemma}

\p{
A map is right orthogonal to the coproduct of two families of maps exactly when it is
right orthogonal to both families.
}

\agda{
right-orthogonal-тиДтВБс╢а
  : тИА {ЁЭУШ ЁЭУЩ ЁЭУд ЁЭУе ЁЭУа ЁЭУб}
      {I : Type ЁЭУШ} {J : Type ЁЭУЩ}
      {A : I тЖТ Type ЁЭУд} {B : I тЖТ Type ЁЭУе}
      {C : J тЖТ Type ЁЭУд} {D : J тЖТ Type ЁЭУе}
      {X : Type ЁЭУа} {Y : Type ЁЭУб}
      {f : (i : I) тЖТ A i тЖТ B i}
      {g : (j : J) тЖТ C j тЖТ D j}
      {h : X тЖТ Y}
    тЖТ ((k : I тКО J) тЖТ are-orthogonal ((f тиДтВБс╢а g) k) h)
    тЖФ (((i : I) тЖТ are-orthogonal (f i) h)
      ├Ч ((j : J) тЖТ are-orthogonal (g j) h))
right-orthogonal-тиДтВБс╢а .fst orth
  = (╬╗ i тЖТ orth (inl i)) , (╬╗ j тЖТ orth (inr j))
right-orthogonal-тиДтВБс╢а .snd (forth , gorth) (inl i) = forth i
right-orthogonal-тиДтВБс╢а .snd (forth , gorth) (inr j) = gorth j
}
}

\subtree[fre-00N1]{
\title{Rezk completeness}
\taxon{Definition}
\author{fredrikbakke}

\agda{
fam-is-rezk-complete : рқҹҷ вҶ’ в„‘ вҶ’ рқҹҷбҙё: рқ“ҳ
fam-is-rezk-complete _ = !бҙё

is-rezk-complete
  : вҲҖ {рқ“Ө}
  вҶ’ (A : Type рқ“Ө)
  вҶ’ Type (рқ“ҳ вҠ” рқ“Ө)
is-rezk-complete A
  = is-local fam-is-rezk-complete A

is-rezk-complete-is-prop
  : вҲҖ {рқ“Ө} {A : Type рқ“Ө}
  вҶ’ is-prop (is-rezk-complete A)
is-rezk-complete-is-prop {A = A}
  = is-local-is-prop A
}

\agda{
RezkCompl-SubU : вҲҖ {рқ“Ө} вҶ’ SubU рқ“Ө (рқ“Ө вҠ” рқ“ҳ)
RezkCompl-SubU = Local-SubU fam-is-rezk-complete _

RezkCompl-gSubU : gSubU (_вҠ” рқ“ҳ)
RezkCompl-gSubU = Local-gSubU fam-is-rezk-complete

RezkCompl-is-globally-reflective
  : is-globally-reflective RezkCompl-gSubU
RezkCompl-is-globally-reflective = Local-global-reflectors fam-is-rezk-complete

RezkCompl-gRSubU : gRSubU (_вҠ” рқ“ҳ)
RezkCompl-gRSubU .gRSubU.GS = RezkCompl-gSubU
RezkCompl-gRSubU .gRSubU.GS-is-globally-reflective = RezkCompl-is-globally-reflective

open gSubU RezkCompl-gSubU public using () renaming
  ( вҲҲSвҶҗequiv to is-rezk-completeвҶҗequiv)

open gReflectiveClosure RezkCompl-gRSubU public using () renaming
  ( О вҲҲS to О -is-rezk-complete
  ; ULiftвҲҲS to ULift-is-rezk-complete
  ; рқҹҷвҲҲS to рқҹҷ-is-rezk-complete
  ; вҲҲSвҶҗis-singleton to is-rezk-completeвҶҗis-singleton
  ; вҲҲSвҶҗretract to is-rezk-completeвҶҗretract
  ; PullbackвҲҲS to Pullback-is-rezk-complete
  ; fibreвҲҲS to fibre-is-rezk-complete
  ; ExtвҲҲS to Ext-is-rezk-complete
  ; Г—вҲҲS to Г—-is-rezk-complete
  ; пјқвҲҲS to пјқ-is-rezk-complete
  ; ~вҲҲS to ~-is-rezk-complete
  ; retractвҲҲS to retract-is-rezk-complete
  ; biinvвҲҲS to biinv-is-rezk-complete
  ; вүғвҲҲS to вүғ-is-rezk-complete
  ; EqualiserвҲҲS to Equaliser-is-rezk-complete
  ; Seq-limвҲҲS to Seq-lim-is-rezk-complete
  ; preidempotent-mapвҲҲS to preidempotent-map-is-rezk-complete
  ; qidempotent-mapвҲҲS to qidempotent-map-is-rezk-complete
  ; idempotent-mapвҲҲS to idempotent-map-is-rezk-complete
  ; RetractsвҲҲS to Retracts-is-rezk-complete)
open gRSubUHomClosure RezkCompl-gRSubU public using () renaming
  ( HomвҲҲS to Hom-is-rezk-complete)

module RezkCompl where
  open gRSubU RezkCompl-gRSubU public
  open gReflectiveClosure RezkCompl-gRSubU public
  open gRSubUHomClosure RezkCompl-gRSubU public
}
}


\subtree[fre-00OH]{
\title{Rezk types}
\taxon{Definition}
\author{fredrikbakke}

\agda{
fam-is-rezk : вЁ„вӮҒб¶ -carrier (point Оӣ[2,1]-incl) (point (!бҙё: рқ“ҳ в„‘))
fam-is-rezk = point Оӣ[2,1]-incl вЁ„вӮҒб¶  point (!бҙё: рқ“ҳ в„‘)

is-rezk : вҲҖ {рқ“Ө} вҶ’ Type рқ“Ө вҶ’ Type (рқ“ҳ вҠ” рқ“Ө)
is-rezk A = is-local fam-is-rezk A

module _  {рқ“Ө : Level} {A : Type рқ“Ө}  where

  is-rezk-is-prop : is-prop (is-rezk A)
  is-rezk-is-prop = is-local-is-prop A

  is-segalГ—is-rezk-completeвҶҗis-rezk
    : is-rezk A вҶ’ is-segal A Г— is-rezk-complete A
  is-segalГ—is-rezk-completeвҶҗis-rezk = Г—-is-localвҶҗis-local-вЁ„вӮҒб¶ 

  is-rezkвҶҗis-segalвҶҗis-rezk-complete
    : is-segal A вҶ’ is-rezk-complete A вҶ’ is-rezk A
  is-rezkвҶҗis-segalвҶҗis-rezk-complete = is-local-вЁ„вӮҒб¶ вҶҗis-local
}

\agda{
Rezk-SubU : вҲҖ {рқ“Ө} вҶ’ SubU рқ“Ө (рқ“Ө вҠ” рқ“ҳ)
Rezk-SubU = Local-SubU fam-is-rezk _

Rezk-gSubU : gSubU (_вҠ” рқ“ҳ)
Rezk-gSubU = Local-gSubU fam-is-rezk

Rezk-is-globally-reflective
  : is-globally-reflective Rezk-gSubU
Rezk-is-globally-reflective = Local-global-reflectors fam-is-rezk

Rezk-gRSubU : gRSubU (_вҠ” рқ“ҳ)
Rezk-gRSubU .gRSubU.GS = Rezk-gSubU
Rezk-gRSubU .gRSubU.GS-is-globally-reflective = Rezk-is-globally-reflective

open gSubU Rezk-gSubU public using () renaming
  ( вҲҲSвҶҗequiv to is-rezkвҶҗequiv)

open gReflectiveClosure Rezk-gRSubU public using () renaming
  ( О вҲҲS to О -is-rezk
  ; ULiftвҲҲS to ULift-is-rezk
  ; рқҹҷвҲҲS to рқҹҷ-is-rezk
  ; вҲҲSвҶҗis-singleton to is-rezkвҶҗis-singleton
  ; вҲҲSвҶҗretract to is-rezkвҶҗretract
  ; PullbackвҲҲS to Pullback-is-rezk
  ; fibreвҲҲS to fibre-is-rezk
  ; ExtвҲҲS to Ext-is-rezk
  ; Г—вҲҲS to Г—-is-rezk
  ; пјқвҲҲS to пјқ-is-rezk
  ; ~вҲҲS to ~-is-rezk
  ; retractвҲҲS to retract-is-rezk
  ; biinvвҲҲS to biinv-is-rezk
  ; вүғвҲҲS to вүғ-is-rezk
  ; EqualiserвҲҲS to Equaliser-is-rezk
  ; Seq-limвҲҲS to Seq-lim-is-rezk
  ; preidempotent-mapвҲҲS to preidempotent-map-is-rezk
  ; qidempotent-mapвҲҲS to qidempotent-map-is-rezk
  ; idempotent-mapвҲҲS to idempotent-map-is-rezk
  ; RetractsвҲҲS to Retracts-is-rezk)
open gRSubUHomClosure Rezk-gRSubU public using () renaming
  ( HomвҲҲS to Hom-is-rezk)

module Rezk where
  open gRSubU Rezk-gRSubU public
  open gReflectiveClosure Rezk-gRSubU public
  open gRSubUHomClosure Rezk-gRSubU public
}
}

\subtree[fre-00OI]{
\title{Categories}
\taxon{Definition}
\author{fredrikbakke}

\agda{
fam-is-category : вЁ„вӮҒб¶ -carrier fam-is-precategory (point (!бҙё: рқ“ҳ в„‘))
fam-is-category = fam-is-precategory вЁ„вӮҒб¶  (point (!бҙё: рқ“ҳ в„‘))

is-category
  : вҲҖ {рқ“Ө} вҶ’ Type рқ“Ө вҶ’ Type (рқ“ҳ вҠ” рқ“Ө)
is-category A = is-local fam-is-category A

module _ {рқ“Ө} {A : Type рқ“Ө} where

  is-category-is-prop  : is-prop (is-category A)
  is-category-is-prop = is-local-is-prop A

  is-precategoryГ—is-rezk-completeвҶҗis-category
    : is-category A вҶ’ is-precategory A Г— is-rezk-complete A
  is-precategoryГ—is-rezk-completeвҶҗis-category
    = Г—-is-localвҶҗis-local-вЁ„вӮҒб¶ 

  is-precategoryвҶҗis-category
    : is-category A вҶ’ is-precategory A
  is-precategoryвҶҗis-category Acat
    = is-precategoryГ—is-rezk-completeвҶҗis-category Acat .fst

  is-simplicialвҶҗis-category
    : is-category A вҶ’ is-simplicial A
  is-simplicialвҶҗis-category
    = is-simplicialвҶҗis-precategory вҲҳ is-precategoryвҶҗis-category

  is-triangulatedвҶҗis-category
    : is-category A вҶ’ is-triangulated A
  is-triangulatedвҶҗis-category
    = simp-is-triangulated вҲҳ is-simplicialвҶҗis-category

  is-rezk-completeвҶҗis-category
    : is-category A вҶ’ is-rezk-complete A
  is-rezk-completeвҶҗis-category Acat
    = is-precategoryГ—is-rezk-completeвҶҗis-category Acat .snd

  is-categoryвҶҗis-precategoryвҶҗis-rezk-complete
    : is-precategory A вҶ’ is-rezk-complete A вҶ’ is-category A
  is-categoryвҶҗis-precategoryвҶҗis-rezk-complete
    = is-local-вЁ„вӮҒб¶ вҶҗis-local

  is-categoryвҶҗis-segalГ—is-simplicialГ—is-rezk-complete
    : is-segal A вҶ’ is-simplicial A вҶ’ is-rezk-complete A вҶ’ is-category A
  is-categoryвҶҗis-segalГ—is-simplicialГ—is-rezk-complete Aseg Asimp
    = is-categoryвҶҗis-precategoryвҶҗis-rezk-complete
        (is-precategoryвҶҗis-segalвҶҗis-simplicial Aseg Asimp)

  is-rezkГ—is-simplicialвҶҗis-category
    : is-category A вҶ’ is-rezk A Г— is-simplicial A
  is-rezkГ—is-simplicialвҶҗis-category Acat
    = is-rezkвҶҗis-segalвҶҗis-rezk-complete
        (is-segalвҶҗis-precategory (is-precategoryвҶҗis-category Acat))
        (is-rezk-completeвҶҗis-category Acat)
    , is-simplicialвҶҗis-category Acat

  is-categoryвҶҗis-rezkГ—is-simplicial
    : is-rezk A Г— is-simplicial A вҶ’ is-category A
  is-categoryвҶҗis-rezkГ—is-simplicial (Arzk , Asimp)
    = is-categoryвҶҗis-segalГ—is-simplicialГ—is-rezk-complete
        (is-segalГ—is-rezk-completeвҶҗis-rezk Arzk .fst)
        Asimp
        (is-segalГ—is-rezk-completeвҶҗis-rezk Arzk .snd)

  is-categoryвүғis-rezkГ—is-simplicial
    : is-category A вүғ (is-rezk A Г— is-simplicial A)
  is-categoryвүғis-rezkГ—is-simplicial
    = equivвҶҗlogical
        is-category-is-prop
        (Г—-is-prop is-rezk-is-prop (is-null-is-prop A))
        ( is-rezkГ—is-simplicialвҶҗis-category
        , is-categoryвҶҗis-rezkГ—is-simplicial)
}

\agda{
Cat-SubU : вҲҖ {рқ“Ө} вҶ’ SubU рқ“Ө (рқ“Ө вҠ” рқ“ҳ)
Cat-SubU = Local-SubU fam-is-category _

Cat-gSubU : gSubU (_вҠ” рқ“ҳ)
Cat-gSubU = Local-gSubU fam-is-category

Cat-is-globally-reflective
  : is-globally-reflective Cat-gSubU
Cat-is-globally-reflective = Local-global-reflectors fam-is-category

Cat-gRSubU : gRSubU (_вҠ” рқ“ҳ)
Cat-gRSubU .gRSubU.GS = Cat-gSubU
Cat-gRSubU .gRSubU.GS-is-globally-reflective = Cat-is-globally-reflective

open gSubU Cat-gSubU public using () renaming
  ( вҲҲSвҶҗequiv to is-categoryвҶҗequiv)

open gReflectiveClosure Cat-gRSubU public using () renaming
  ( О вҲҲS to О -is-category
  ; ULiftвҲҲS to ULift-is-category
  ; рқҹҷвҲҲS to рқҹҷ-is-category
  ; вҲҲSвҶҗis-singleton to is-categoryвҶҗis-singleton
  ; вҲҲSвҶҗretract to is-categoryвҶҗretract
  ; PullbackвҲҲS to Pullback-is-category
  ; fibreвҲҲS to fibre-is-category
  ; ExtвҲҲS to Ext-is-category
  ; Г—вҲҲS to Г—-is-category
  ; пјқвҲҲS to пјқ-is-category
  ; ~вҲҲS to ~-is-category
  ; retractвҲҲS to retract-is-category
  ; biinvвҲҲS to biinv-is-category
  ; вүғвҲҲS to вүғ-is-category
  ; EqualiserвҲҲS to Equaliser-is-category
  ; Seq-limвҲҲS to Seq-lim-is-category
  ; preidempotent-mapвҲҲS to preidempotent-map-is-category
  ; qidempotent-mapвҲҲS to qidempotent-map-is-category
  ; idempotent-mapвҲҲS to idempotent-map-is-category
  ; RetractsвҲҲS to Retracts-is-category)
open gRSubUHomClosure Cat-gRSubU public using () renaming
  ( HomвҲҲS to Hom-is-category)

module Cat where
  open gRSubU Cat-gRSubU public
  open gReflectiveClosure Cat-gRSubU public
  open gRSubUHomClosure Cat-gRSubU public

Category-U : (рқ“Ө : Level) вҶ’ Type (lsuc (рқ“ҳ вҠ” рқ“Ө))
Category-U рқ“Ө = ОЈ[ A вҲ¶ Type (рқ“ҳ вҠ” рқ“Ө) ] is-category A

Category-U-is-simplicial
  : {рқ“Ө : Level} вҶ’ is-simplicial (Category-U рқ“Ө)
Category-U-is-simplicial {рқ“Ө}
  = is-simplicialвҶҗequiv
      ((ОЈ-ap-вүғ О» A вҶ’ is-categoryвүғis-rezkГ—is-simplicial {A = A}) eвҒ»В№)
      (Null-in-gSubU-is-nullвҶҗis-prop
        {рқ“Ө = рқ“ҳ} {рқ“Ҙ = рқ“Ө}
        {P = fam-is-simplicial}
        {S = Rezk-gSubU}
        (fam-is-simplicial-is-prop)
        (О» _ вҶ’ О -is-rezk))
}
}

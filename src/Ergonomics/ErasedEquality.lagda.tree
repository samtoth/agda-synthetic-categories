\title{Erased equality}
\taxon{Module}
\author{fredrikbakke}

\import{stt-macros}

\agda{
module Ergonomics.ErasedEquality where

open import Foundations.Universes
open import Foundations.Identity
}

\subtree[stt-00NW]{
\title{The erase equality primitive}
\taxon{Definition}

\p{
The \code{primEraseEquality} primitive is used with \code{--rewriting} to get
equalities that judgmentally reduce to \code{refl}. When the two end points of an
equality \code{p : x = y} normalize to the same term, then \code{primEraseEquality p}
normalizes to \code{refl}.
}
\agda{
primitive
  primEraseEquality : {𝓤 : Level} {A : Type 𝓤} {x y : A} → x ＝ y → x ＝ y
}

\subtree{
\taxon{Warning}

\p{this is not in general sound with \code{--without-K} — use with caution.}
}
}

\title{Biinvertible maps}
\taxon{Module}

\import{stt-macros}

% ```agda
\agda{
module Foundations.BiinvertibleMap where

open import Foundations.Universes
open import Foundations.Span
open import Foundations.Functions
open import Foundations.FunctionInverses
open import Foundations.Sigma
open import Foundations.Identity
open import Foundations.Homotopy
open import Foundations.QuasiIsomorphism
open import Foundations.CoherentIsomorphism
import Foundations.CanonicalPullbacks as CP

import Foundations.FunExt as FE
}
% ```

\subtree[fre-1002]{
\date{2026-03-10}
\author{fredrikbakke}
\taxon{Definition}
\title{Biinvertible map}

\p{
A map #{f} is \em{biinvertible} if it has a [section](stt-000H) and a
[retraction](stt-000I).
}

\p{
The data of being biinvertible is different from that of being a
[quasi isomorphism](stt-001K). The data of being a quasi isomorphism consists of a
single map #{g} that is both a section and a retraction of #{f}, while the data
of biinvertibility consists of two maps #{s} and #{r}, the first is assumed to be a
section of #{f} and the second is assumed to be a retraction of #{r}. This
distinction matters, even though the inverse of an isomorphism is unique up to
homotopy, because the homotopy of being a section and/or retraction need not be. This
means that when #{f} is a map between types that need not be [sets](stt-006T), the
data of being a quasi isomorphism need not be coherent, i.e., unique. But the data of
being biinvertible on the other hand is always unique, and hence equivalent as types
to that of being a [coherent isomorphism](stt-000K).
}

% ```agda
\agda{
is-biinv : вИА {рЭУ§ рЭУ•} {A : Type рЭУ§} {B : Type рЭУ•} вЖТ (f : A вЖТ B) вЖТ Type (рЭУ§ вКФ рЭУ•)
is-biinv f = section f √Ч retract f

biinv : вИА {рЭУ§ рЭУ•} вЖТ Type рЭУ§ вЖТ Type рЭУ• вЖТ Type (рЭУ§ вКФ рЭУ•)
biinv A B = ќ£ (A вЖТ B) is-biinv
}
% ```
}

\subtree[fre-1001]{
\date{2026-03-10}
\author{fredrikbakke}
\taxon{Theorem}
\title{Biinvertible maps are equivalent to coherent isomorphisms}

% ```agda
\agda{
qisoвЖРis-biinv : вИА {рЭУ§ рЭУ•} {A : Type рЭУ§} {B : Type рЭУ•} {f : A вЖТ B}
              вЖТ is-biinv f вЖТ quasi-iso f
qisoвЖРis-biinv {f = f} ((g , ќµ) , (h , ќЈ)) = (g , ret , ќµ) where
  g~h : g ~ h
  g~h b = sym (ќЈ (g b)) вИЩ ap h (ќµ b)

  ret : retract-witness f g
  ret = g~h вЦЄ f ~вИЩ ќЈ

is-equivвЖРis-biinv : вИА {рЭУ§ рЭУ•} {A : Type рЭУ§} {B : Type рЭУ•} {f : A вЖТ B}
                  вЖТ is-biinv f вЖТ is-equiv f
is-equivвЖРis-biinv = is-equivвЖРqiso вИШ qisoвЖРis-biinv

is-biinvвЖРis-equiv : вИА {рЭУ§ рЭУ•} {A : Type рЭУ§} {B : Type рЭУ•} {f : A вЖТ B}
                  вЖТ is-equiv f вЖТ is-biinv f
is-biinvвЖРis-equiv e = is-equiv.section-fwd e , is-equiv.retract-fwd e
}
% ```


\p{
Under function extensionality, the predicate of being biinvertible is equivalent to
coherent isomorphism library's default notion of equivalence.
}

% ```agda
\agda{
module WithFunExt (FE : FE.FunExt-global) where

  open import Foundations.Singleton
  open import Foundations.SingletonClosure
  open import Foundations.FibrewiseEquiv
  open import Foundations.PropExt using (is-equivвЖРinverse)
  open import Foundations.EquivProp FE

  is-biinv-is-prop : вИА {рЭУ§ рЭУ•} {A : Type рЭУ§} {B : Type рЭУ•} {f : A вЖТ B}
                   вЖТ is-prop (is-biinv f)
  is-biinv-is-prop {f = f} = is-propвЖРis-single-if-inhabited ќї b
    вЖТ Singleton-ќ£ (section-is-singleвЖРqinv (qisoвЖРis-biinv b))
                   (ќї _ вЖТ retracts-is-singleвЖРqinv (qisoвЖРis-biinv b))

  is-biinvвЙГis-equiv : вИА {рЭУ§ рЭУ•} {A : Type рЭУ§} {B : Type рЭУ•} {f : A вЖТ B}
                    вЖТ is-biinv f вЙГ is-equiv f
  is-biinvвЙГis-equiv = mkвЙГ is-equivвЖРis-biinv
    (is-equivвЖРinverse is-biinv-is-prop is-equiv-is-prop is-biinvвЖРis-equiv)

  вЙГ-rep-biinv : вИА {рЭУ§ рЭУ•} {A : Type рЭУ§} {B : Type рЭУ•}
              вЖТ (A вЙГ B) вЙГ biinv A B
  вЙГ-rep-biinv = вЙГ-rep вИЩвЙГ ќ£-ap-вЙГ (ќї f вЖТ is-biinvвЙГis-equiv {f = f} eвБї¬є)
}
% ```
}

\subtree[fre-1000]{
\date{2026-03-10}
\author{fredrikbakke}
\taxon{Theorem}
\title{Biinvertible maps as a pullback}

% ```agda
\agda{
module _
  {рЭУ§ рЭУ• : Level} {A : Type рЭУ§} {B : Type рЭУ•}
  where

  biinv-cone
    : Cone (mk-cospan (A вЖТ B) (fst {B = section}) (fst {B = retract}))
           (biinv A B)
  biinv-cone
    = mk-cone (ќї (f , s , _) вЖТ (f , s))
              (ќї (f , _ , r) вЖТ (f , r))
              (~refl)

  biinv-gap-is-equiv
    : is-equiv (CP.gap biinv-cone)
  biinv-gap-is-equiv = mk-eqv (bwd , ret , sec) coh where
    bwd : CP.Pullback (fst {B = section}) (fst {B = retract}) вЖТ biinv A B
    bwd ((f , s) , (.f , r) , refl) = (f , s , r)
    ret : retract-witness (CP.gap biinv-cone) bwd
    ret (f , s , r) = refl
    sec : section-witness (CP.gap biinv-cone) bwd
    sec ((f , s) , (.f , r) , refl) = refl
    coh : qiso-coh (bwd , ret , sec)
    coh (f , s , r) = refl

  biinvвЙГpullback
    : biinv A B
    вЙГ CP.Pullback (fst {B = section}) (fst {B = retract})
  biinvвЙГpullback
    = mkвЙГ (CP.gap biinv-cone) (biinv-gap-is-equiv)
}
% ```
}

\subtree[fre-2D88]{
\title{Essential surjections}
\taxon{Definition}
\author{fredrikbakke}
\date{2026-05-01}

\p{
A map #{f : A \to B} is \em{essentially surjective} if each of its
[essential fibres](fre-0D88) is inhabited.
}

\agda{
is-ess-surjective
  : {ЁЭУд ЁЭУе : Level} {A : Type ЁЭУд} {B : Type ЁЭУе} тЖТ (A тЖТ B) тЖТ Type (ЁЭУШ тКФ ЁЭУд тКФ ЁЭУе)
is-ess-surjective {B = B} f = (b : B) тЖТ тХС essfibre f b тХС
}
}

\subtree[fre-ES02]{
\title{Composition and right cancellation of essential surjections}
\taxon{Proposition}
\author{fredrikbakke}
\date{2026-05-14}

\agda{
module _
  {ЁЭУд ЁЭУе ЁЭУж} {A : Type ЁЭУд} {B : Type ЁЭУе} {C : Type ЁЭУж} {g : B тЖТ C} {f : A тЖТ B}
  where

  is-ess-surjective-тИШ
    : (ЁЭР╢ : is-segal C)
    тЖТ is-ess-surjective g
    тЖТ is-ess-surjective f
    тЖТ is-ess-surjective (g тИШ f)
  is-ess-surjective-тИШ ЁЭР╢ sg sf c
    = Trunc.тЧЛ-rec Trunc.тЧЛтИИS
        (╬╗ (b , ╬▓)
         тЖТ Trunc.тЧЛ-rec Trunc.тЧЛтИИS (╬╗ ╬│ тЖТ Trunc.╬╖ (essfibre-тИШ ЁЭР╢ ╬│ ╬▓)) (sf b))
        (sg c)

  is-ess-surjective-right-cancel
    : is-ess-surjective (g тИШ f)
    тЖТ is-ess-surjective g
  is-ess-surjective-right-cancel s c
    = Trunc.тЧЛ-rec Trunc.тЧЛтИИS (Trunc.╬╖ тИШ leftтЖРessfibre-тИШ) (s c)
}
}

\subtree[fre-ES04]{
\title{Essential surjections are closed under natural isomorphisms}
\taxon{Proposition}
\author{fredrikbakke}
\date{2026-05-14}

\agda{
module _ {ЁЭУд ЁЭУе} {A : Type ЁЭУд} {B : Type ЁЭУе} (ЁЭР╡ : is-segal B) {f g : A тЖТ B} where

  is-ess-surjectiveтЖРNatIso
    : NatIso f g
    тЖТ is-ess-surjective g
    тЖТ is-ess-surjective f
  is-ess-surjectiveтЖРNatIso ╬▒ sg b
    = Trunc.тЧЛ-rec Trunc.тЧЛтИИS (╬╗ (a , ╬▓) тЖТ Trunc.╬╖ (a , comp-Iso ЁЭР╡ ╬▓ (╬▒ a))) (sg b)
}
}

\subtree[fre-ES05]{
\title{Essential surjections are closed under homotopies}
\taxon{Corollary}
\author{fredrikbakke}
\date{2026-05-14}

\agda{
module _ {ЁЭУд ЁЭУе} {A : Type ЁЭУд} {B : Type ЁЭУе} {f g : A тЖТ B} where

  is-ess-surjective~
    : f ~ g
    тЖТ is-ess-surjective f
    тЖТ is-ess-surjective g
  is-ess-surjective~ H sg b
    = Trunc.тЧЛ-rec Trunc.тЧЛтИИS
        (╬╗ (a , ╬▓) тЖТ Trunc.╬╖ (a , adjust-Iso (H a) refl ╬▓))
        (sg b)
}
}

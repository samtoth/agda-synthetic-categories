\title{Types equivalent to subtypes}
\taxon{Module}
\author{samueltoth}
\date{2026-01-09}
\import{stt-macros}

%```agda
\agda{
module Foundations.SubtypeEquiv where


open import Foundations.Universes
open import Foundations.Functions
open import Foundations.Sigma
open import Foundations.Homotopy
open import Foundations.QuasiIsomorphism
open import Foundations.CoherentIsomorphism
open import Foundations.FibrewiseEquiv
open import Foundations.TotalEquiv
open import Foundations.SigmaProperties
open import Foundations.Straightening
open import Foundations.Embedding
open import Foundations.PropMapEmbedding
open import Foundations.EquivSingleton
open import Foundations.Subtypes
}
%```


\subtree[stt-00CD]{
\taxon{Theorem}

\p{Let #{S} be a subtype of #{A}, and #{X} some other type with a map #{f} into
#{A}. Suppose, for all #{a : A} there is an equivalence #{\fibre{f}{a} \simeq a \in A},
then:}

\ul{
\li{#{f} is an embedding}
\li{There is an equivalence #{e : X \simeq \tilde{S}}}
\li{Such that #{\iota_S e \sim f}}
}

%```agda
\agda{
module FromFibreSubtype {𝓤 𝓥 𝓦} {A : Type 𝓤} (S : Subtype A 𝓥)
         {X : Type 𝓦} (f : X → A) (fib : ∀ a → fibre f a ≃ a ∈ S) where
  open Subtype
  equiv-to-subtype : X ≃ Σ̃ S
  equiv-to-subtype =
    X                 ≃⟨ total≃total-fibre _ e⁻¹ ⟩
    total-fibre f     ≃⟨ Σ-ap-≃ fib ⟩
    Σ̃ S       ≃∎

  open _≃_ equiv-to-subtype

  incl-is-embedding : is-embedding f
  incl-is-embedding = is-embedding←is-prop-map
                        (λ a → is-prop←equiv-to-prop (fib a e⁻¹) (∈-is-prop S a))

  pres-carr
    : fst ∘ fwd ~ f
  pres-carr = ~refl

  pres-carr'
    : f ∘ bwd ~ fst
  pres-carr' = pres-carr ▸ bwd ~∙ fst ◂ ε
}
%```
}

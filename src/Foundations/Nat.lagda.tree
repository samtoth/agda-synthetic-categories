\date{2025-04-18}
\title{Natural numbers}
\author{samueltoth}
\contributor{fredrikbakke}
\taxon{Module}

\import{stt-macros}

% ```agda
\agda{
module Foundations.Nat where

open import Foundations.Universes
open import Foundations.Identity
open import Data.Bool
}
% ```


\subtree[stt-002R]{
\title{Nat}
\taxon{Definition}

% ```agda
\agda{
data ‚Ąē : Type where
  zero : ‚Ąē
  suc : ‚Ąē ‚Üí ‚Ąē

{-# BUILTIN NATURAL ‚Ąē #-}
}
% ```
}

\subtree[fre-3301]{
\date{2026-04-24}
\author{fredrikbakke}
\title{Addition of natural numbers}
\taxon{Definition}

% ```agda
\agda{
infixl 20 _+‚Ąē_

_+‚Ąē_ : ‚Ąē ‚Üí ‚Ąē ‚Üí ‚Ąē
n +‚Ąē zero = n
n +‚Ąē suc m = suc (n +‚Ąē m)

{-# BUILTIN NATPLUS _+‚Ąē_ #-}

+‚Ąē-zero : ‚ąÄ {n} ‚Üí 0 +‚Ąē n ÔľĚ n
+‚Ąē-zero {zero} = refl
+‚Ąē-zero {suc n} = ap suc +‚Ąē-zero

+‚Ąē-succ : ‚ąÄ {n m} ‚Üí suc (n +‚Ąē m) ÔľĚ suc n +‚Ąē m
+‚Ąē-succ {n} {zero} = refl
+‚Ąē-succ {n} {suc m} = ap suc +‚Ąē-succ

+‚Ąē-comm : ‚ąÄ {n m} ‚Üí n +‚Ąē m ÔľĚ m +‚Ąē n
+‚Ąē-comm {n} {zero} = sym +‚Ąē-zero
+‚Ąē-comm {n} {suc m} = ap suc (+‚Ąē-comm {n}) ‚ąô +‚Ąē-succ
}
% ```
}

\subtree[fre-3302]{
\date{2026-04-24}
\author{fredrikbakke}
\title{Distance of natural numbers}
\taxon{Definition}

\p{
We define the distance function on natural numbers. Because of performance
considerations, we define it in terms of the truncated subtraction operation, which
has a fast built-in binding.
}

% ```agda
\agda{
truncminus-‚Ąē : ‚Ąē ‚Üí ‚Ąē ‚Üí ‚Ąē
truncminus-‚Ąē n zero = n
truncminus-‚Ąē zero (suc m) = zero
truncminus-‚Ąē (suc n) (suc m) = truncminus-‚Ąē n m

{-# BUILTIN NATMINUS truncminus-‚Ąē #-}

dist-‚Ąē : ‚Ąē ‚Üí ‚Ąē ‚Üí ‚Ąē
dist-‚Ąē n m = (truncminus-‚Ąē n m) +‚Ąē (truncminus-‚Ąē m n)
}
% ```
}

\subtree[fre-3303]{
\date{2026-04-24}
\author{fredrikbakke}
\title{Multiplication of natural numbers}
\taxon{Definition}

% ```agda
\agda{
infixl 25 _*‚Ąē_

_*‚Ąē_ : ‚Ąē ‚Üí ‚Ąē ‚Üí ‚Ąē
n *‚Ąē zero = zero
n *‚Ąē suc m = n +‚Ąē n *‚Ąē m

{-# BUILTIN NATTIMES _*‚Ąē_ #-}
}
% ```
}

\subtree[fre-3306]{
\date{2026-04-24}
\author{fredrikbakke}
\title{Boolean order on natural numbers}
\taxon{Definition}

% ```agda
\agda{
infix 20 _<Šīģ‚Ąē_

_<Šīģ‚Ąē_ : ‚Ąē ‚Üí ‚Ąē ‚Üí Bool
_ <Šīģ‚Ąē zero = false
zero <Šīģ‚Ąē suc _ = true
suc n <Šīģ‚Ąē suc m = n <Šīģ‚Ąē m

{-# BUILTIN NATLESS _<Šīģ‚Ąē_ #-}
}
% ```
}

\subtree[fre-3307]{
\date{2026-04-24}
\author{fredrikbakke}
\title{Division operation for natural numbers}
\taxon{Definition}

% ```agda
\agda{
div-‚Ąē-helper : (k m n j : ‚Ąē) ‚Üí ‚Ąē
div-‚Ąē-helper k m zero j = k
div-‚Ąē-helper k m (suc n) zero = div-‚Ąē-helper (suc k) m n m
div-‚Ąē-helper k m (suc n) (suc j) = div-‚Ąē-helper k m n j

{-# BUILTIN NATDIVSUCAUX div-‚Ąē-helper #-}

-- TODO
}
% ```
}

\subtree[fre-3308]{
\date{2026-04-24}
\author{fredrikbakke}
\title{Modulo operation for natural numbers}
\taxon{Definition}

% ```agda
\agda{
mod-‚Ąē-helper : (k m n j : ‚Ąē) ‚Üí ‚Ąē
mod-‚Ąē-helper k m zero j = k
mod-‚Ąē-helper k m (suc n) zero = mod-‚Ąē-helper zero m n m
mod-‚Ąē-helper k m (suc n) (suc j) = mod-‚Ąē-helper (suc k) m n j

{-# BUILTIN NATMODSUCAUX mod-‚Ąē-helper #-}

-- TODO
}
% ```
}


\subtree[fre-3310]{
\date{2026-04-24}
\author{fredrikbakke}
\title{Module for unqualified operators}
\taxon{Submodule}

% ```agda
\agda{
module NatOp where
  infix  30 _<Šīģ_
  infixl 35 _+_
  infixl 40 _*_

  _+_ : ‚Ąē ‚Üí ‚Ąē ‚Üí ‚Ąē
  _+_ = _+‚Ąē_

  _*_ : ‚Ąē ‚Üí ‚Ąē ‚Üí ‚Ąē
  _*_ = _*‚Ąē_

  _<Šīģ_ : ‚Ąē ‚Üí ‚Ąē ‚Üí Bool
  _<Šīģ_ = _<Šīģ‚Ąē_
}
% ```
}

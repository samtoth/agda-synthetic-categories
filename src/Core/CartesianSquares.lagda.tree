\subtree[stt-003V]{
\taxon{Definition}
\title{Cartesian squares}

\p{Given a map of arrows #{f \to f'}, we can define a family of functions
from the fibre over #{f} to the fibre over #{f'}. If this map is a
fibrewise equivalence, then we say that the square is cartesian (or a pullback
square).
}

\agda{
module _ {ūĚď§ ūĚď•} {A : Type ūĚď§} {B : Type ūĚď•} {f : A ‚Üí B}
         {ūĚď¶ ūĚďõ} {C : Type ūĚď¶} {D : Type ūĚďõ} {f' : C ‚Üí D} where

  is-cartesian : Arrow-map f f' ‚Üí Type (ūĚď§ ‚äĒ ūĚď• ‚äĒ ūĚď¶ ‚äĒ ūĚďõ)
  is-cartesian a = is-fibrewise-equiv (arrow-fibre a)

  is-cartesian-is-prop
    : ‚ąÄ {F : Arrow-map f f'} ‚Üí is-prop (is-cartesian F)
  is-cartesian-is-prop
    = ő†-is-prop (őĽ a ‚Üí is-equiv-is-prop)
}
}


\subtree[stt-003W]{
\taxon{Theorem}
\title{Horizontal composition of cartesian squares}

\p{If #{f} is a cartesian square, then #{g} is cartesian iff #{f} is.}

\agda{
module _ {ūĚď§ ūĚď•} {A : Type ūĚď§} {B : Type ūĚď•} {f : A ‚Üí B}
         {ūĚď§' ūĚď•'} {A' : Type ūĚď§'} {B' : Type ūĚď•'} {f' : A' ‚Üí B'}
         {ūĚď§'' ūĚď•''} {A'' : Type ūĚď§''} {B'' : Type ūĚď•''} {f'' : A'' ‚Üí B''} where

  arrow-fibre-‚ąė
    : ‚ąÄ (F : Arrow-map f' f'') (G : Arrow-map f f')
      ‚Üí ‚ąÄ b
      ‚Üí arrow-fibre (paste-squares F G) b
      ~ arrow-fibre F (Arrow-map.bot G b) ‚ąė arrow-fibre G b
  arrow-fibre-‚ąė F@(mk-amap f f' fcomm) G@(mk-amap g g' gcomm) b (a , p)
    = ő£-path‚Üí (refl , lem) where
       lem : sym (ap f' (gcomm a) ‚ąô fcomm (g a)) ‚ąô ap (f' ‚ąė g') p ÔľĚ
              sym (fcomm (g a)) ‚ąô ap f' (sym (gcomm a) ‚ąô ap g' p)
       lem = ‚Ćú sym (ap f' (gcomm a) ‚ąô fcomm (g a)) ‚ĆĚ ‚ąô ap (f' ‚ąė g') p
               ÔľĚ‚ü® ap! (‚ąô-symsym (ap f' (gcomm a)) _) ‚ü©
             (sym (fcomm (g a)) ‚ąô ‚Ćú sym (ap f' (gcomm a)) ‚ĆĚ) ‚ąô ap (f' ‚ąė g') p
               ÔľĚ‚ü® ap! (sym (ap-sym f' _)) ‚ü©
             (sym (fcomm (g a)) ‚ąô ap f' (sym (gcomm a))) ‚ąô ap (f' ‚ąė g') p
               ÔľĚ‚ü® ‚ąô-assoc (sym (fcomm (g a))) _ _ ‚ü©
             sym (fcomm (g a)) ‚ąô ap f' (sym (gcomm a)) ‚ąô ‚Ćú ap (f' ‚ąė g') p ‚ĆĚ
               ÔľĚ‚ü® ap! (ap-‚ąė f' g' p) ‚ü©
             sym (fcomm (g a)) ‚ąô ‚Ćú ap f' (sym (gcomm a)) ‚ąô (ap f' (ap g' p)) ‚ĆĚ
               ÔľĚ‚ü® ap! (sym (ap-‚ąô f' (sym _) (ap g' p))) ‚ü©
             sym (fcomm (g a)) ‚ąô ap f' (sym (gcomm a) ‚ąô ap g' p) ‚ąé

  compose-cartesian
    : ‚ąÄ {a : Arrow-map f' f''} {b : Arrow-map f f'}
      ‚Üí (ae : is-cartesian a) (be : is-cartesian b)
      ‚Üí is-cartesian (paste-squares a b)
  compose-cartesian {a} {b} ae be x
    = tr is-equiv (funext‚Üí (arrow-fibre-‚ąė a b x h‚ĀĽ¬Ļ))
       (is-equiv-‚ąė {f = arrow-fibre a (b .Arrow-map.bot x)} {g = arrow-fibre b x}
         (ae (b .Arrow-map.bot x))
         (be x)) where
    module b = is-equiv (be x)
    module a = is-equiv (ae (b .Arrow-map.bot x))

    open Arrow-map

    II : (x : B) (fib : fibre f x) ‚Üí
       sym (paste-squares a b .Arrow-map.comm (fib .fst)) ‚ąô
         ap (paste-squares a b .Arrow-map.bot) (fib .snd)
        ÔľĚ
       (arrow-fibre a (b .Arrow-map.bot x) ‚ąė arrow-fibre b x)
         fib .snd
    II x (aa , p)
     = sym (paste-squares a b .comm aa) ‚ąô ap (paste-squares a b .bot) p
         ÔľĚ‚ü®‚ü©
       ‚Ćú sym (ap (a .bot) (b .comm aa) ‚ąô a .comm (b .top aa)) ‚ĆĚ ‚ąô ap (a .bot ‚ąė b .bot) p
         ÔľĚ‚ü® ap! (‚ąô-symsym (ap (a .bot) (b .comm aa)) _) ‚ü©
       (sym (a .comm (b .top aa)) ‚ąô sym (ap (a .bot) (b .comm aa))) ‚ąô ap (a .bot ‚ąė b .bot) p
         ÔľĚ‚ü® ‚ąô-assoc (sym (a .comm (b .top aa))) _ (ap (a .bot ‚ąė b .bot) p) ‚ü©
       sym (a .comm (b .top aa)) ‚ąô ‚Ćú sym (ap (a .bot) (b .comm aa)) ‚ĆĚ ‚ąô ap (a .bot ‚ąė b .bot) p
         ÔľĚ‚ü® ap! (sym (ap-sym (a .bot) _)) ‚ü©
       sym (a .comm (b .top aa)) ‚ąô ap (a .bot) (sym (b .comm aa)) ‚ąô ‚Ćú ap (a .bot ‚ąė b .bot) p ‚ĆĚ
         ÔľĚ‚ü® ap! (ap-‚ąė _ _ _) ‚ü©
       sym (a .comm (b .top aa)) ‚ąô ‚Ćú ap (a .bot) (sym (b .comm aa)) ‚ąô ap (a .bot) (ap (b .bot) p) ‚ĆĚ
         ÔľĚ‚ü® ap! (sym (ap-‚ąô (a .bot) (sym (b .comm aa)) _)) ‚ü©
       sym (a .comm (b .top aa)) ‚ąô ap (a .bot) (sym (b .comm aa) ‚ąô ap (b .bot) p)
         ÔľĚ‚ü®‚ü©
       (arrow-fibre a (b .bot x) ‚ąė arrow-fibre b x) (aa , p) .snd ‚ąé

  3-for-2-cartesian
    : ‚ąÄ {a : Arrow-map f' f''} {b : Arrow-map f f'}
        {H : Arrow-map f f''}
      ‚Üí Arrow-map-path H (paste-squares a b)
      ‚Üí is-cartesian H
      ‚Üí is-cartesian a
      ‚Üí is-cartesian b
  3-for-2-cartesian {a = F@(mk-amap f f' fcomm)} {b = G@(mk-amap g g' gcomm)}
                    K abcart bcart b
    = 3-for-2~ (arrow-fibre-‚ąė F G b)
               (bcart (g' b))
               (tr is-cartesian (Arrow-map-path‚Üí K) abcart b)
}
}


\subtree[stt-003C]{
\title{Pullback squares from cartesian arrow maps}
\taxon{Theorem}
\p{We show that a [cartesian](stt-003V) arrow map gives a pullback square.
 That is, a square is cartesian iff the corresponding cone is a pullback cone.}

\proof{
\p{Suppose we have a square:}

\quiver{
\begin{tikzcd}
	A && C \\
	\\
	B && D
	\arrow["g", from=1-1, to=1-3]
	\arrow["f"', from=1-1, to=3-1]
	\arrow["{f'}", from=1-3, to=3-3]
	\arrow["{g'}"', from=3-1, to=3-3]
\end{tikzcd}
}

\p{such that the map #{\fibre{g'}{a} \toeq \fibre{g}{f'(a)}} is
an equivalence. Then to verify it is a pullback, then we need
to show that the induced map #{A \to C \times_D B} is also an equivalence.}

\p{We can view both of these maps as living in a slice over #{C}, and a
by [[stt-003D]], a map in the slice is in equivalence iff if is an equivalence
on fibres.}

\quiver{
\begin{tikzcd}
	A && {B \times_D C} \\
	& B
	\arrow["{\textit{gap}}", from=1-1, to=1-3]
	\arrow["f"', from=1-1, to=2-2]
	\arrow["{\pi_1}", from=1-3, to=2-2]
\end{tikzcd}
}

\p{So we need to show #{\fibre{f}{c} \to \fibre{\pi_1}{c}} is an equivalence. The
fibre of the projection is equivalent to the fibre of #{g} at #{f(c)}, and so by the
[3-for-2](Foundations.3for2) property of equivalences we have that the square is a
pullback.}

\agda{
up-pullback‚Üźis-cartesian
  : ‚ąÄ {ūĚď§ ūĚď• ūĚď¶ ūĚďú}
      {A : Type ūĚď§} {B : Type ūĚď•} {f : A ‚Üí B}
      {C : Type ūĚď¶} {D : Type ūĚďú} {f' : C ‚Üí D}
    ‚Üí (g : Arrow-map f f')
    ‚Üí is-cartesian g
    ‚Üí (let (s , c) = Cone‚ÜźArrow-map g)
    ‚Üí up-pullback s c
up-pullback‚Üźis-cartesian {A = A} {B} {f = f} {C} {D} {f' = f'} G pbsq
  = up-pullback‚Üźis-pullback cone (is-equiv‚Üźon-fibres slice-map slice-equiv) where
  cospan = Cone‚ÜźArrow-map G .fst
  cone = Cone‚ÜźArrow-map G .snd

  g : A ‚Üí C
  g = G .Arrow-map.top

  g' : B ‚Üí D
  g' = G .Arrow-map.bot

  open pb

  slice-map : Slice-map f ŌÄ‚āĀ
  slice-map .fst = gap cone
  slice-map .snd = ~refl

  lem : {a = b : B} ‚Üí
      arrow-fibre G b ~
      fib-ŌÄ‚āĀ g' f' b ._‚ČÉ_.fwd ‚ąė Slice-fibre (gap cone , ~refl) b
  lem (a , refl) = ő£-path‚Üí (refl , (‚ąô-reflr _))

  slice-equiv : is-fibrewise-equiv (Slice-fibre {q = ŌÄ‚āĀ} (gap cone , ~refl))
  slice-equiv b = 3-for-2~ {f = fib-ŌÄ‚āĀ g' f' b ._‚ČÉ_.fwd}
                           lem
                           (fib-ŌÄ‚āĀ g' f' b ._‚ČÉ_.fwd-is-equiv)
                           (pbsq b)


is-cartesian‚Üźup-pullback
  : ‚ąÄ {ūĚď§ ūĚď• ūĚď¶ ūĚďú}
      {A : Type ūĚď§} {B : Type ūĚď•} {f : A ‚Üí B}
      {C : Type ūĚď¶} {D : Type ūĚďú} {f' : C ‚Üí D}
    ‚Üí (g : Arrow-map f f')
    ‚Üí (let (s , c) = Cone‚ÜźArrow-map g)
    ‚Üí up-pullback s c
    ‚Üí is-cartesian g
is-cartesian‚Üźup-pullback {f = f} {f' = f'} g pb b
  = is-equiv‚Üź~
      lem
      (is-equiv-‚ąė
        (fib-ŌÄ‚āĀ bot f' b ._‚ČÉ_.fwd-is-equiv)
        (fibre-equiv‚Üźis-equiv slice-map gap-is-equiv b)) where
  open Arrow-map g
  open pb

  cospan = Cone‚ÜźArrow-map g .fst
  cone = Cone‚ÜźArrow-map g .snd

  gap-is-equiv : is-equiv (gap (mk-cone f top comm))
  gap-is-equiv = is-pullback‚Üźup-pullback _ pb

  slice-map : Slice-map f ŌÄ‚āĀ
  slice-map .fst = gap cone
  slice-map .snd = ~refl

  lem
    : arrow-fibre g b
    ~ fib-ŌÄ‚āĀ bot f' b ._‚ČÉ_.fwd ‚ąė Slice-fibre slice-map b
  lem (a , refl) = ő£-path‚Üí (refl , ‚ąô-reflr _)

is-cartesian‚Üźis-pullback
  : ‚ąÄ {ūĚď§ ūĚď• ūĚď¶ ūĚďú} {A : Type ūĚď§} {B : Type ūĚď•} {f : A ‚Üí B}
      {C : Type ūĚď¶} {D : Type ūĚďú} {g : C ‚Üí D}
    ‚Üí (F : Arrow-map f g)
    ‚Üí is-pullback (Cone‚ÜźArrow-map F .snd)
    ‚Üí is-cartesian F
is-cartesian‚Üźis-pullback F gap
  = is-cartesian‚Üźup-pullback F (up-pullback‚Üźis-pullback _ gap)

is-pullback‚Üźis-cartesian
  : ‚ąÄ {ūĚď§ ūĚď• ūĚď¶ ūĚďú} {A : Type ūĚď§} {B : Type ūĚď•} {f : A ‚Üí B}
      {C : Type ūĚď¶} {D : Type ūĚďú} {g : C ‚Üí D}
    ‚Üí (F : Arrow-map f g)
    ‚Üí is-cartesian F
    ‚Üí is-pullback (Cone‚ÜźArrow-map F .snd)
is-pullback‚Üźis-cartesian F c
  = is-pullback‚Üźup-pullback _ (up-pullback‚Üźis-cartesian F c)
}
}
}

\subtree[stt-003R]{
\title{Precomposition of cartesian squares}
\taxon{Theorem}

\p{Given a square of the following form:}

\quiver{
\begin{tikzcd}
	A && C \\
	\\
	B && D
	\arrow["g", from=1-1, to=1-3]
	\arrow["f"', from=1-1, to=3-1]
	\arrow["{f'}", from=1-3, to=3-3]
	\arrow["{g'}"', from=3-1, to=3-3]
\end{tikzcd}
}

\p{We show that the square obtained via precomposition
   is cartesian iff the original square is.
}

\proof{

\p{
First note that the type of cones on #{(Q \to B) \to (Q \to D) \leftarrow (Q \to C)}
is equivalent to the canonical pullback of #{B \to D \leftarrow C}. We can construct
the following triangle, and apply the three for two property for equivalences:
}

\quiver{
\begin{tikzcd}
	{(A \to Q)} &&& {(B \to Q)\times_{(C \to Q)} (D \to Q)} \\
	\\
	&& {\textrm{Cone}(f,g)}
	\arrow["{\textit{gap}}", from=1-1, to=1-4]
	\arrow["{\textrm{cone-map}}"', from=1-1, to=3-3]
	\arrow["\sim", from=1-4, to=3-3]
\end{tikzcd}
}

\agda{
postcomp-cone‚ČÉpb
  : ‚ąÄ {ūĚď§ ūĚď• ūĚď¶ ūĚďú}
      {A : Type ūĚď§} {B : Type ūĚď•}
      {C : Type ūĚď¶} {f : A ‚Üí B}
      {g : C ‚Üí B} {D : Type ūĚďú}
    ‚Üí Cone (mk-cospan B f g) D ‚ČÉ Pullback (postcomp D f) (postcomp D g)
postcomp-cone‚ČÉpb {f = f} {g = g} {D = D}
  =  Cone (mk-cospan _ f g) D
  ‚ČÉ‚ü® cone-repr‚ČÉ (mk-cospan _ f g) ‚ü©
      ő£[ f' ‚ą∂ (D ‚Üí _) ] ő£[ g' ‚ą∂ (D ‚Üí _) ]
          (postcomp D f f' ~ postcomp D g g')
  ‚ČÉ‚ü® ő£-snd-‚ČÉ (őĽ f' ‚Üí ő£-snd-‚ČÉ (őĽ g' ‚Üí funext‚ČÉ e‚ĀĽ¬Ļ)) ‚ü©
      Pullback (postcomp D f) (postcomp D g)
  ‚ČÉ‚ąé


postcomp-cartesian
  : ‚ąÄ {ūĚď§ ūĚď• ūĚď¶ ūĚďú}
      {A : Type ūĚď§} {B : Type ūĚď•} {f : A ‚Üí B}
      {C : Type ūĚď¶} {D : Type ūĚďú} {f' : C ‚Üí D}
      (g : Arrow-map f f')
    ‚Üí is-cartesian g
    ‚Üí ‚ąÄ {ūĚďõ} {C : Type ūĚďõ}
    ‚Üí is-cartesian
      (postcomp-square g C)
postcomp-cartesian {A = A} {f = f} {f' = f'} G@(mk-amap g g' H) eq {_} {C}
  = is-cartesian‚Üźup-pullback _
      (up-pullback‚Üźis-pullback
        (cn‚ąė C)
        (3-for-2
          {f = _‚ČÉ_.bwd (postcomp-cone‚ČÉpb)}
          {g = gap (cn‚ąė C)}
          (is-equiv‚ĀĽ¬Ļ (_‚ČÉ_.fwd-is-equiv postcomp-cone‚ČÉpb))
          (is-equiv‚Üź~ map-hom
            (cn-is-pb .up-pullback.cone-map-is-equiv C)))) where
  cs : Cospan _ _ _
  cs = Cone‚ÜźArrow-map G .fst

  cn : Cone cs _
  cn = Cone‚ÜźArrow-map G .snd

  cs‚ąė : ‚ąÄ {ūĚď†} (Q : Type ūĚď†) ‚Üí Cospan _ _ _
  cs‚ąė {ūĚď†} Q = Cone‚ÜźArrow-map (postcomp-square G Q) .fst

  cn‚ąė : ‚ąÄ {ūĚď†} (Q : Type ūĚď†) ‚Üí Cone (cs‚ąė Q) _
  cn‚ąė {ūĚď†} Q = Cone‚ÜźArrow-map (postcomp-square G Q) .snd

  cn-is-pb : up-pullback cs cn
  cn-is-pb = up-pullback‚Üźis-cartesian G eq

  map-hom : (_‚ČÉ_.bwd postcomp-cone‚ČÉpb ‚ąė gap (cn‚ąė C)) ~ cone-map cs cn
  map-hom x = ap (mk-cone (f ‚ąė x) (g ‚ąė x)) funext-redex

  map : ‚ąÄ {ūĚď†} {Q : Type ūĚď†} ‚Üí (Q ‚Üí A) ‚Üí Cone cs Q
  map {_} {Q} = _‚ČÉ_.bwd postcomp-cone‚ČÉpb ‚ąė gap (cn‚ąė Q)
}
}
}

\subtree[stt-00BX]{
\title{The fibre of maps as a cartesian square}
\taxon{Example}

\agda{
fibre-square
  : ‚ąÄ {ūĚď§ ūĚď•} {A : Type ūĚď§} {B : Type ūĚď•} (f : A ‚Üí B) b
    ‚Üí Arrow-map (!: fibre f b) f
fibre-square f b .Arrow-map.top = fst
fibre-square f b .Arrow-map.bot = point b
fibre-square f b .Arrow-map.comm (x , p) = sym p

fibre-square-is-cartesian
  : ‚ąÄ {ūĚď§ ūĚď•} {A : Type ūĚď§} {B : Type ūĚď•} (f : A ‚Üí B) b
    ‚Üí is-cartesian (fibre-square f b)
fibre-square-is-cartesian f b = is-cartesian‚Üźis-pullback _ eq where
  map : fibre f b ‚Üí Pullback (point b) f
  map (x , p) = (tt , x , sym p)

  eq : is-equiv map
  eq = is-equiv‚Üźqinv ((őĽ (_ , x , p) ‚Üí (x , sym p))
                     , (őĽ where (_ , refl) ‚Üí refl)
                     , őĽ where (_ , _ , refl) ‚Üí refl)
}
}

\subtree[stt-00JM]{
\title{Maps between equivalences are cartesian}
\taxon{Lemma}

\agda{
is-cartesian‚Üźdom+cod-is-equiv
  : ‚ąÄ {ūĚď§ ūĚď• ūĚď¶ ūĚďú} {X : Type ūĚď§} {Y : Type ūĚď•} {A : Type ūĚď¶} {B : Type ūĚďú}
      {f : X ‚Üí Y} {g : A ‚Üí B}
    ‚Üí (F : Arrow-map f g)
    ‚Üí is-equiv f ‚Üí is-equiv g
    ‚Üí is-cartesian F
is-cartesian‚Üźdom+cod-is-equiv F feq geq a
  = is-equiv‚Üźsingle-to-prop
      (has-singleton-fibres‚Üźis-equiv feq a)
      (is-prop‚Üźis-single (has-singleton-fibres‚Üźis-equiv geq _))
      _
}

\p{Similarly, given a square where the bottom map is an equivalence,
the top map is an equivalence iff the square is a pullback}

\agda{
top-is-equiv‚Üźis-cartesian
  : ‚ąÄ {ūĚď§ ūĚď• ūĚď¶ ūĚďú} {X : Type ūĚď§} {Y : Type ūĚď•} {A : Type ūĚď¶} {B : Type ūĚďú}
      {f : X ‚Üí Y} {g : A ‚Üí B}
    ‚Üí (F : Arrow-map f g)
    ‚Üí (let open Arrow-map F)
    ‚Üí is-cartesian F
    ‚Üí is-equiv bot
    ‚Üí is-equiv top
top-is-equiv‚Üźis-cartesian F feq geq
  = is-equiv-‚ąė {f = pb.ŌÄ‚āā} {g = gap-map‚Üźsquare F}
      (pullback-equiv‚āā geq)
      (is-pullback‚Üźis-cartesian F feq)
}

\p{The converse is left to be formalised.}
}

\subtree[stt-00SA]{
\title{Straightening cartesian arrow maps}
\taxon{Lemma}

\p{We show that an arrow map is cartesian
iff the corresponding map of families is cartesian.}

\agda{
module _
  {ūĚď§ ūĚď• ūĚď¶ ūĚďú}
  {A : Type ūĚď§} {B : Type ūĚď•} {f : A ‚Üí B}
  {X : Type ūĚď¶} {Y : Type ūĚďú} {g : X ‚Üí Y}
  where

  Cart-fam-map‚Üźcart-arrow-map
    : ő£ (Arrow-map f g) is-cartesian
    ‚Üí Cart-fam-map (fibre-fam f) (fibre-fam g)
  Cart-fam-map‚Üźcart-arrow-map
    = Cart-fam-map‚Üźis-cartesian {G = fibre-fam g} ‚ąė map-ő£ fam-map‚Üźarrow-map őĽ _ ‚Üí id

  Cart-fam-map‚ČÉcart-arrow-map
    : ő£ (Arrow-map f g) is-cartesian
    ‚ČÉ Cart-fam-map (fibre-fam f) (fibre-fam g)
  Cart-fam-map‚ČÉcart-arrow-map = mk‚ČÉ Cart-fam-map‚Üźcart-arrow-map
    (is-equiv-‚ąė
      (Cart-fam-map‚Üźis-cartesian-is-equiv {G = fibre-fam g})
      (map-ő£-is-equiv
        fam-map‚Üźarrow-map-is-equiv
        őĽ _ ‚Üí id-is-equiv))
}
}

\subtree[stt-00SB]{
\title{Transposing squares preserves being cartesian}
\taxon{Lemma}

\agda{
transpose-is-cartesian
  : ‚ąÄ {ūĚď§ ūĚď• ūĚď¶ ūĚďú} {A : Type ūĚď§} {B : Type ūĚď•}
      {C : Type ūĚď¶} {D : Type ūĚďú}
      {f : A ‚Üí B} {g : C ‚Üí D}
      (F : Arrow-map f g)
    ‚Üí is-cartesian F
    ‚Üí is-cartesian (transpose-square F)
transpose-is-cartesian {f = f} {g} F@(mk-amap top bot comm) fcart
  = is-cartesian‚Üźis-pullback _
        (is-equiv-‚ąė (pullback-swap ._‚ČÉ_.fwd-is-equiv)
                    (is-pullback‚Üźup-pullback _
                      (up-pullback‚Üźis-cartesian _ fcart)))

untranspose-is-cartesian
  : ‚ąÄ {ūĚď§ ūĚď• ūĚď¶ ūĚďú} {A : Type ūĚď§} {B : Type ūĚď•}
      {C : Type ūĚď¶} {D : Type ūĚďú}
      {f : A ‚Üí B} {g : C ‚Üí D}
      (F : Arrow-map f g)
    ‚Üí is-cartesian (transpose-square F)
    ‚Üí is-cartesian F
untranspose-is-cartesian F
  = tr is-cartesian (transpose-square-involution F)
  ‚ąė transpose-is-cartesian (transpose-square F)
}
}

\subtree[stt-00SD]{
\title{Dependent precomposition preserves cartesian squares}
\taxon{Lemma}

\p{#{\Pi_i F_i} is cartesian iff each square #{F_i} is.}

\proof{

\p{We use 3-for-2 in the red triangle of the following diagram:}

\quiver{
\begin{tikzcd}[cramped]
	& {\Pi_i(B_i\times_{D_i}C_i)} \\
	{\Pi_i A_i} &&& {\Pi_iC_i} \\
	& {\Pi_iB_i\times_{\Pi_i D_i}\Pi_i c_i} \\
	\\
	{\Pi_iB_i} &&& {\Pi_iD_i}
	\arrow["\sim"{pos=0.3}, color={rgb,255:red,214;green,92;blue,92}, from=1-2, to=3-2]
	\arrow["{\Pi_i(\textrm{gap})}"{pos=0.3}, color={rgb,255:red,214;green,92;blue,92}, from=2-1, to=1-2]
	\arrow[from=2-1, to=2-4]
	\arrow[color={rgb,255:red,214;green,92;blue,92}, from=2-1, to=3-2]
	\arrow[from=2-1, to=5-1]
	\arrow[from=2-4, to=5-4]
	\arrow[from=3-2, to=2-4]
	\arrow[from=3-2, to=5-1]
	\arrow["\lrcorner"{anchor=center, pos=0.125}, draw=none, from=3-2, to=5-4]
	\arrow[from=5-1, to=5-4]
\end{tikzcd}
}
}

\agda{
opaque
  ő†-square-is-cartesian
    : ‚ąÄ {ūĚďė ūĚď§ ūĚď• ūĚď¶ ūĚďú} {I : Type ūĚďė}
        {A : I ‚Üí Type ūĚď§} {B : I ‚Üí Type ūĚď•} {f : (i : I) ‚Üí A i ‚Üí B i}
        {C : I ‚Üí Type ūĚď¶} {D : I ‚Üí Type ūĚďú} {g : (i : I) ‚Üí C i ‚Üí D i}
      ‚Üí (F : (i : I) ‚Üí Arrow-map (f i) (g i))
      ‚Üí (‚ąÄ i ‚Üí is-cartesian (F i))
      ‚Üí is-cartesian (ő†-square F)
  ő†-square-is-cartesian {I = I} {g = g} F cart
    = is-cartesian‚Üźis-pullback _ eq where
    curry-pb
      : Pullback (Arrow-map.bot (ő†-square F)) (postcomp-ő† g)
      ‚Üí ő† I (őĽ z ‚Üí Pullback (Arrow-map.bot (F z)) (g z))
    curry-pb (f , g , H) i = (f i , g i , happly H i)

    curry-pb-qinv : quasi-inv curry-pb
    curry-pb-qinv .fst f = (pb.ŌÄ‚āĀ ‚ąė f , pb.ŌÄ‚āā ‚ąė f , funext‚Üí (pb.filler ‚ąė f))
    curry-pb-qinv .snd .fst (f , g , p)
      = pullback-path‚Üí (refl , refl , sym (funext.ő∑ p) ‚ąô sym (‚ąô-reflr _))
    curry-pb-qinv .snd .snd f
      = funext‚Üí őĽ i ‚Üí pullback-path‚Üí
          (refl , refl , ‚ąô-refll _ ‚ąô sym (happly funext-redex i) ‚ąô sym (‚ąô-reflr _))

    htpy : postcomp-ő† (őĽ i ‚Üí gap-map‚Üźsquare (F i)) ~ curry-pb ‚ąė gap-map‚Üźsquare (ő†-square F)
    htpy a = funext‚Üí őĽ i ‚Üí pullback-path‚Üí
      (refl , refl , ‚ąô-refll _ ‚ąô happly funext-redex i ‚ąô sym (‚ąô-reflr _))

    eq : is-equiv (gap (Cone‚ÜźArrow-map (ő†-square F) .snd))
    eq = (3-for-2~
            {f = curry-pb}
            {g = gap-map‚Üźsquare (ő†-square F)}
            {k = postcomp-ő† (őĽ i ‚Üí gap-map‚Üźsquare (F i))}
            (htpy)
            (is-equiv‚Üźqinv curry-pb-qinv)
            (postcomp-ő†-equiv
              (őĽ {i} ‚Üí is-pullback‚Üźup-pullback _
                (up-pullback‚Üźis-cartesian _ (cart i)))))
}
}

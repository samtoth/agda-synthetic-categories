\title{Equalisers}
\taxon{Module}

\import{stt-macros}

\agda{
module Foundations.Equalisers where

open import Foundations.Universes
open import Foundations.Functions
open import Foundations.Homotopy
open import Foundations.Forks
open import Foundations.Equivalences
}

\subtree{
\date{2026-03-18}
\author{fredrikbakke}
\taxon{Definition}
\title{Equalisers}

\p{
Given a pair of parallel maps #{f\ g : A \to B}, an \em{equaliser} of #{f} and
#{g} is a fork over #{f} and #{g} satisfying the expected universal property.
}

\agda{
up-equaliser
  : {𝓤 𝓥 𝓦 : Level} {A : Type 𝓤} {B : Type 𝓥}
    (f g : A → B) {E : Type 𝓦}
  → Fork f g E
  → Typeω
up-equaliser f g {E = E} F
  = {𝓠 : Level} {Q : Type 𝓠}
  → is-equiv (fork-map {f = f} {g = g} {E = E} F {Q = Q})
}
}

\subtree[fre-0027]{
\title{Null-homotopies}
\taxon{Definition}

\p{
Given a map #{f : A \to B} then its type of \em{null-homotopies} is the collection of
elements #{b} of #{B} such that for all #{a} in #{A} we have #{f(a) = b}.
##{\nullhtpy{f} \coloneqq \Sigma_{(b : B)}(\Pi_{(a : A)} f(a) = b).}
}

%```agda
\agda{
module _ {ūĚď§1 ūĚď§2} {A : Type ūĚď§1} {B : Type ūĚď§2} where

  fam-null-homotopy : (A ‚Üí B) ‚Üí B ‚Üí Type (ūĚď§1 ‚äĒ ūĚď§2)
  fam-null-homotopy f b = (a : A) ‚Üí f a ÔľĚ b

  null-homotopy : (A ‚Üí B) ‚Üí Type (ūĚď§1 ‚äĒ ūĚď§2)
  null-homotopy f = ő£[ b ‚ą∂ B ] (fam-null-homotopy f b)

  null-homotopy-path-IdŠĶą‚ČÉpointwise
    : {f : A ‚Üí B}
      {c l : B}
      (h : fam-null-homotopy f c)
      (r : fam-null-homotopy f l)
      (t : c ÔľĚ l)
    ‚Üí IdŠĶą (ap (fam-null-homotopy f) t) h r ‚ČÉ ((a : A) ‚Üí h a ‚ąô t ÔľĚ r a)
  null-homotopy-path-IdŠĶą‚ČÉpointwise {f = f} h r t
    = IdŠĶą (ap (fam-null-homotopy f) t) h r
        ‚ČÉ‚ü® ÔľĚ-postcomp-‚ČÉ
            ( J (őĽ l' t' ‚Üí (őĽ a ‚Üí h a ‚ąô t') ÔľĚ coe (ap (fam-null-homotopy f) t') h)
                (funext‚Üí (őĽ a ‚Üí ‚ąô-reflr (h a)))
                (t) ) ‚ü©
      ((őĽ a ‚Üí h a ‚ąô t) ÔľĚ r)
        ‚ČÉ‚ü® funext‚ČÉ ‚ü©
      ((a : A) ‚Üí h a ‚ąô t ÔľĚ r a)
        ‚ČÉ‚ąé

  null-homotopy-path‚ČÉ
    : {f : A ‚Üí B}
      {c l : B}
      (h : f ~ const B A c)
      (r : f ~ const B A l)
    ‚Üí ((c , h) ÔľĚ (l , r))
    ‚ČÉ (ő£[ t ‚ą∂ c ÔľĚ l ] ((a : A) ‚Üí h a ‚ąô t ÔľĚ r a))
  null-homotopy-path‚ČÉ {f = f} {c} {l} h r
    = ((c , h) ÔľĚ (l , r))
        ‚ČÉ‚ü® ő£-path e‚ĀĽ¬Ļ ‚ü©
      (ő£[ t ‚ą∂ c ÔľĚ l ] IdŠĶą (ap (fam-null-homotopy f) t) h r)
        ‚ČÉ‚ü® ő£-ap-‚ČÉ (null-homotopy-path-IdŠĶą‚ČÉpointwise h r) ‚ü©
      (ő£[ t ‚ą∂ c ÔľĚ l ] ((a : A) ‚Üí h a ‚ąô t ÔľĚ r a))
        ‚ČÉ‚ąé
}
%```
}

\subtree[fre-0028]{
\title{The action on identifications of null-homotopic maps is null-homotopic}
\taxon{Proposition}

\p{
If #{f : A \to B} is null-homotopic, then for any #{x,y : A}, the induced map on paths
#{\ap f : (x = y) \to (f(x) = f(y))} is null-homotopic.
}

%```agda
\agda{
ap-null-homotopy
  : ‚ąÄ {ūĚď§ ūĚď•}
      {A : Type ūĚď§}
      {B : Type ūĚď•}
      {f : A ‚Üí B}
    ‚Üí null-homotopy f
    ‚Üí (x y : A)
    ‚Üí null-homotopy (ap f {x} {y})
ap-null-homotopy {f = f} (b , h) x y
  = h x ‚ąô sym (h y)
  , J (őĽ y p ‚Üí ap f p ÔľĚ h x ‚ąô sym (h y)) (sym (‚ąô-sym (h x)))
}
%```
}

\subtree[fre-0029]{
\title{A null-homotopy presentation of domains of maps}
\taxon{Construction}

\p{
Given a map #{g : X \to Y} and any type #{A}, then #{X} is equivalent to the data
consisting of a point #{y : Y}, a map #{j : A \to \fibre{g}{y}}, and a null-homotopy of #{j}.
##{X \;\simeq\; \Sigma_{(y : Y)}\Sigma_{(j : A \to \fibre{g}{y})}\nullhtpy(j)}
}

%```agda
\agda{
module _ {ūĚď§ ūĚď• ūĚď¶} (A : Type ūĚď§) {X : Type ūĚď•} {Y : Type ūĚď¶} (g : X ‚Üí Y) where

  fibre-pointed-total : Type (ūĚď§ ‚äĒ ūĚď• ‚äĒ ūĚď¶)
  fibre-pointed-total
    = ő£[ y ‚ą∂ Y ] ő£[ j ‚ą∂ (A ‚Üí fibre g y) ] null-homotopy j

  fibre-pointed-total‚Üźdomain : X ‚Üí fibre-pointed-total
  fibre-pointed-total‚Üźdomain x
    = g x , const (fibre g (g x)) A (x , refl) , (x , refl) , ~refl

  domain‚Üźfibre-pointed-total : fibre-pointed-total ‚Üí X
  domain‚Üźfibre-pointed-total (_ , _ , y , _) = fst y

  domain‚Üźfibre-pointed-total-qiso : quasi-iso domain‚Üźfibre-pointed-total
  domain‚Üźfibre-pointed-total-qiso .fst = fibre-pointed-total‚Üźdomain
  domain‚Üźfibre-pointed-total-qiso .snd .fst (.(g x) , j , (x , refl) , H)
    = funext-rec
        (őĽ H' ‚Üí fibre-pointed-total‚Üźdomain x ÔľĚ (g x , j , (x , refl) , H'))
        (őĽ where refl ‚Üí refl)
        H
  domain‚Üźfibre-pointed-total-qiso .snd .snd x = refl

  fibre-pointed-total‚ČÉdomain : fibre-pointed-total ‚ČÉ X
  fibre-pointed-total‚ČÉdomain
    = mk‚ČÉ domain‚Üźfibre-pointed-total
          (is-equiv‚Üźqiso domain‚Üźfibre-pointed-total-qiso)
}
%```
}

\subtree[fre-0030]{
\title{Postcomposition preserves null-homotopies}
\taxon{Proposition}

% ```agda
\agda{
module _ {ūĚď§1 ūĚď§2 ūĚď§3} {A : Type ūĚď§1} {B : Type ūĚď§2} {C : Type ūĚď§3}
         (e : A ‚ČÉ B) (j : A ‚Üí C) where

  homotopy-const-postcomp-‚ČÉ
    : (y : C)
    ‚Üí (j ~ const C A y)
    ‚ČÉ (((precomp-‚ČÉ (e e‚ĀĽ¬Ļ)) ._‚ČÉ_.fwd j) ~ const C B y)
  homotopy-const-postcomp-‚ČÉ y
    = precomp-ő†-‚ČÉ (őĽ a ‚Üí j a ÔľĚ y) (e e‚ĀĽ¬Ļ)

  null-homotopy-postcomp-‚ČÉ
    : null-homotopy j
    ‚ČÉ null-homotopy ((precomp-‚ČÉ (e e‚ĀĽ¬Ļ)) ._‚ČÉ_.fwd j)
  null-homotopy-postcomp-‚ČÉ
    = ő£-ap-‚ČÉ homotopy-const-postcomp-‚ČÉ
}
% ```
}

\subtree[fre-0031]{
\title{Equivalences on codomains preserve null-homotopies}
\taxon{Proposition}

% ```agda
\agda{
module _ {ūĚď§1 ūĚď§2 ūĚď§3} {A : Type ūĚď§1} {B : Type ūĚď§2} {C : Type ūĚď§3}
         (e : B ‚ČÉ C) (j : A ‚Üí B) where

  null-homotopy-map-codomain-‚ČÉ
    : null-homotopy j
    ‚ČÉ null-homotopy (e ._‚ČÉ_.fwd ‚ąė j)
  null-homotopy-map-codomain-‚ČÉ
    = null-homotopy j
        ‚ČÉ‚ü® ő£-ap-‚ČÉ (őĽ y ‚Üí ő†-ap-‚ČÉ (őĽ a ‚Üí ÔľĚ-equiv e)) ‚ü©
      (ő£[ y ‚ą∂ B ] ((a : A) ‚Üí e ._‚ČÉ_.fwd (j a) ÔľĚ e ._‚ČÉ_.fwd y))
        ‚ČÉ‚ü® ő£-ap-‚ČÉ-fst e ‚ü©
      null-homotopy (e ._‚ČÉ_.fwd ‚ąė j)
        ‚ČÉ‚ąé
}
% ```
}
